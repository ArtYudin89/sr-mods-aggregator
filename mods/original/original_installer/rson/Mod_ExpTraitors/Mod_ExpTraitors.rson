                    "Pos.x": 180,
                    "Pos.y": 635
                },
                {
                    "Name": "",
                    "Code.Type": "Turn",
                    "Code": [
                        "SkipGreeting();",
                        "if(ShipPilotRace(Player())==0)TempRace=CT(\"Script.Mod_ExpTraitors.28\");",
                        "if(ShipPilotRace(Player())==1)TempRace=CT(\"Script.Mod_ExpTraitors.27\");",
                        "if(ShipPilotRace(Player())==2)TempRace=CT(\"Script.Mod_ExpTraitors.26\");",
                        "if(ShipPilotRace(Player())==3)TempRace=CT(\"Script.Mod_ExpTraitors.25\");",
                        "if(ShipPilotRace(Player())==4)TempRace=CT(\"Script.Mod_ExpTraitors.24\");",
                        "//Конечный модификатор взятки для пиратов - 0.80 (в т.ч. для пеленгов - 0.90)",
                        "RuinBribe=round(0.80*(0.01*(5.0-(0.04*RelationToRanger(GetShipRuins(Player()),Player())))*RangersCapital()));",
                        "DChange(0);",
                        "exit;"
