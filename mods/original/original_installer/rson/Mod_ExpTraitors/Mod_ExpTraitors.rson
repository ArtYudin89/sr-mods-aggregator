                },
                {
                    "Name": "Traitors",
                    "Owner": 62,
                    "Group.Type": 126,
                    "CntShipMin": 0,
                    "CntShipMax": 0,
                    "SpeedMin": 100,
                    "SpeedMax": 10000,
                    "Weapon": 0,
                    "CargoHook": 0,
                    "EmptySpace": 0,
                    "AddPlayer": false,
                    "StatusTraderMin": 100,
                    "StatusTraderMax": 10000,
                    "StatusWarriorMin": 0,
                    "StatusWarriorMax": 0,
                    "StatusPirateMin": 0,
                    "StatusPirateMax": 0,
                    "DistSearch": 2097184,
                    "Dialog": -1,
                    "StrengthMin": "0",
                    "StrengthMax": "0",
                    "Ruins": "",
                    "+Planet": "PlanetPla",
                    "+State": 1,
                    "Type": "TGroup",
                    "Pos.x": 90,
                    "Pos.y": 250,
                    "Parent": -1,
                    "#": 18
                }
            ],
            "Items": [],
            "Operations": [
                {
                    "Name": "",
                    "Code.Type": "Global",
                    "Code": [
                        "GRun();"
                    ],
                    "#": 19,
                    "Type": "Top",
                    "Parent": -1,
                    "Pos.x": 0,
                    "Pos.y": 635
                },
                {
                    "Name": "",
                    "Code.Type": "Init",
                    "Code": [
                        "curStar=-1;",
                        "MoneyGoes=-1;",
                        "",
                        "//Сразу запоминаем, что игрок находится в стартовой системе, иначе при пропуске хода отношение будет снова пересчитано, но уже по общим правилам",
                        "dwd0=ShipStar(Player());",
                        "curStar=Id(dwd0);",
                        "newStar=curStar;",
                        "",
                        "//Выставляем начальное отношение баз в родной системе игрока",
                        "if(StarRuins(dwd0))",
                        "{",
                        "\tfor(i = 0; i < StarRuins(dwd0); i = i + 1)",
                        "\t{",
                        "\t\tdwd1 = StarRuins(dwd0, i);",
                        "\t\tif(RelationToRanger(dwd1,Player()) < 10) continue;",
                        "\t\t//Коалиционные базы",
                        "\t\tif(ShipType(dwd1)=='RC' || ShipType(dwd1)=='SB' || ShipType(dwd1)=='BK' || ShipType(dwd1)=='TC')",
                        "\t\t{",
                        "\t\t\t//Глобальное отношение планет людей, фэй и гаальцев",
                        "\t\t\tint0=GlobalRelationsPlanets(Player(),0,4+8+16)+RelationToRanger(dwd1,Player());",
                        "\t\t\tint0=int0/2;",
                        "\t\t\tif(int0>100)RelationToRanger(dwd1,Player(),100);",
                        "            //Не даём начальному отношению опуститься слишком низко, иначе игрока может послать даже стартовый ЦР",
                        "\t\t\telse if(int0<30)RelationToRanger(dwd1,Player(),30);",
                        "\t\t\telse if(int0>29 && int0<=100)RelationToRanger(dwd1,Player(),int0);",
                        "\t\t}",
                        "\t\t//Военная база",
                        "\t\tif(ShipType(dwd1)=='WB')",
                        "\t\t{",
                        "\t\t\t//Глобальное отношение планет людей, фэй и гаальцев",
                        "\t\t\tint0=GlobalRelationsPlanets(Player(),0,4+8+16)+RelationToRanger(dwd1,Player());",
                        "\t\t\tint0=int0/2;",
                        "\t\t\tif(int0>75)RelationToRanger(dwd1,Player(),75);",
                        "\t\t\telse if(int0<30)RelationToRanger(dwd1,Player(),30);",
                        "\t\t\telse if(int0>29 && int0<=75)RelationToRanger(dwd1,Player(),int0);",
                        "\t\t}",
                        "\t\t//Пиратские базы и доминионы",
                        "\t\tif(ShipType(dwd1)=='PB')",
                        "\t\t{",
                        "\t\t\t//Глобальное отношение клановых планет",
                        "\t\t\tint0=GlobalRelationsPlanets(Player(),0,128)+RelationToRanger(dwd1,Player());",
                        "\t\t\tint0=int0/2;",
                        "\t\t\tif(int0>50)RelationToRanger(dwd1,Player(),50);",
                        "\t\t\telse if(int0<10)RelationToRanger(dwd1,Player(),10);",
                        "\t\t\telse if(int0>9 && int0<=50)RelationToRanger(dwd1,Player(),int0);",
                        "\t\t}",
                        "\t\tif(ShipType(dwd1)=='CB')",
                        "\t\t{",
                        "\t\t\tRelationToRanger(dwd1,Player(),0);",
                        "\t\t}",
                        "\t}",
                        "}",
                        "dwd0=0;"
                    ],
                    "#": 20,
                    "Type": "Top",
                    "Parent": -1,
                    "Pos.x": 60,
                    "Pos.y": 635
                },
                {
                    "Name": "",
                    "Code.Type": "Turn",
                    "Code": [
                        "if(!CoalitionDefeated()) {",
                        "  if(CurTurn() > bornData) {",
                        "    if(ControlledSystems(2) > 2 * GroupCount(Traitors)) {",
                        "      //Добавление рейнджеров-изменников",
                        "      bornData = CurTurn() + 30 + Rnd(1, 30);",
                        "      for(i = 0; i < GalaxyStars(); i = i + 1)",
                        "      {",
                        "      \tif(2 * GroupCount(Traitors) > ControlledSystems(2)) break;",
                        "      \tif(StarOwner(GalaxyStar(i)) != 2) continue;",
                        "      \tif(StarCustomFaction(GalaxyStar(i)) != '') continue;",
                        "      \tfor(j = 0; j < StarPlanets(GalaxyStar(i)); j = j + 1)",
                        "      \t{",
                        "      \t\tif(2 * GroupCount(Traitors) > ControlledSystems(2)) break;",
                        "      \t\tdwd0 = StarPlanets(GalaxyStar(i), j);",
                        "      \t\tif(PlanetOwner(dwd0) == 7)",
                        "      \t\t{",
                        "      \t\t\tdwd1 = BuyRanger(dwd0, 200);",
                        "                  //Избавляемся от возможной серии \"Таухито\", которую вешает хардкод",
                        "                  if(CurTurn() <= 666)",
                        "                  {",
                        "                      if(!(Id(dwd1) % 6))",
                        "                      {",
                        "                          while(ShipPilotRace(dwd1) == People) ShipPilotRace(dwd1, Rnd(Maloc, Gaal));",
                        "                      }",
                        "                  }",
                        "      \t\t\tItemSize(ShipItems(dwd1, 0), Rnd(220, 300) + (50 * GalaxyTechLevel()));",
                        "      \t\t\tHullHP(dwd1, ItemSize(ShipItems(dwd1, 0)));",
                        "      \t\t\tShipRefit(dwd1);",
                        "      \t\t\tShipType(dwd1, 'RangerPirate');",
                        "      \t\t\tShipJoin(Traitors, dwd1);",
                        "      \t\t\tShipJoinsClan(dwd1);",
                        "      \t\t\tChangeState(1, dwd1);",
                        "      \t\t\tSpecialToEquipment(FindBonusByNameInCfg('ExpTraitors_RangerPirateHull'), ShipItems(dwd1, 0));",
                        "      \t\t\tChameleon(dwd1);",
                        "      \t\t\tif(Rnd(1, 10) <= 7)",
                        "      \t\t\t{",
                        "      \t\t\t\tint0 = Rnd(1, 10);",
                        "      \t\t\t\tif(int0 <= 4)",
                        "      \t\t\t\t{",
                        "      \t\t\t\t\tShipStatus(dwd1, 0, 0);",
                        "      \t\t\t\t\tShipStatus(dwd1, 1, 100);",
                        "      \t\t\t\t\tShipStatus(dwd1, 2, 0);",
                        "      \t\t\t\t}",
                        "      \t\t\t\tif(int0 == 5 || int0 == 6)",
                        "      \t\t\t\t{",
                        "      \t\t\t\t\tShipStatus(dwd1, 0, 25);",
                        "      \t\t\t\t\tShipStatus(dwd1, 1, 75);",
                        "      \t\t\t\t\tShipStatus(dwd1, 2, 0);",
                        "      \t\t\t\t}",
                        "      \t\t\t\tif(int0 == 7 || int0 == 8)",
                        "      \t\t\t\t{",
                        "      \t\t\t\t\tShipStatus(dwd1, 0, 0);",
                        "      \t\t\t\t\tShipStatus(dwd1, 1, 75);",
                        "      \t\t\t\t\tShipStatus(dwd1, 2, 25);",
                        "      \t\t\t\t}",
                        "      \t\t\t\tif(int0 == 9 || int0 == 10)",
                        "      \t\t\t\t{",
                        "      \t\t\t\t\tShipStatus(dwd1, 0, 25);",
                        "      \t\t\t\t\tShipStatus(dwd1, 1, 50);",
                        "      \t\t\t\t\tShipStatus(dwd1, 2, 25);",
                        "      \t\t\t\t}",
                        "      \t\t\t\tint0 = 0;",
                        "      \t\t\t}",
                        "      \t\t\tNoTargetToShip(dwd1, 3);",
                        "      \t\t}",
                        "      \t}",
                        "      }",
                        "    }",
                        "  }",
                        "}",
                        "if(Id(ShipStar(Player())) != curStar) {",
                        "  dwd0=ShipStar(Player());",
                        "  curStar=Id(dwd0);",
                        "  newStar=curStar;",
                        "  ",
                        "  //Выставляем начальное отношение баз после перехода в другую систему",
                        "  if(StarRuins(dwd0))",
                        "  {",
                        "  \tfor(i=0;i<StarRuins(dwd0);i=i+1)",
                        "  \t{",
                        "  \t\tdwd1=StarRuins(dwd0,i);",
                        "  \t\tif(RelationToRanger(dwd1,Player())<10)",
                        "          {",
                        "              RelationToRanger(dwd1,Player(),10);",
                        "              continue;",
                        "          }",
                        "  \t\t//Коалиционные базы",
                        "  \t\tif(ShipType(dwd1)=='RC' || ShipType(dwd1)=='SB' || ShipType(dwd1)=='BK' || ShipType(dwd1)=='TC')",
                        "  \t\t{",
                        "  \t\t\t//Глобальное отношение планет людей, фэй и гаальцев",
                        "  \t\t\tint0=GlobalRelationsPlanets(Player(),0,4+8+16)+RelationToRanger(dwd1,Player());",
                        "  \t\t\tint0=int0/2;",
                        "  \t\t\t//Проверяем, не пират ли игрок (БЦ наплевать)",
                        "  \t\t\tif(ShipOwner(Player())!=7 || ShipType(dwd1)=='BK')",
                        "  \t\t\t{",
                        "  \t\t\t\tif(int0>100)RelationToRanger(dwd1,Player(),100);",
                        "  \t\t\t\telse if(int0<10)RelationToRanger(dwd1,Player(),10);",
                        "  \t\t\t\telse if(int0>9 && int0<=100)RelationToRanger(dwd1,Player(),int0);",
                        "  \t\t\t}",
                        "  \t\t\telse",
                        "  \t\t\t{",
                        "  \t\t\t\tif(int0>50)RelationToRanger(dwd1,Player(),50);",
                        "  \t\t\t\telse if(int0<10)RelationToRanger(dwd1,Player(),10);",
                        "  \t\t\t\telse if(int0>9 && int0<=50)RelationToRanger(dwd1,Player(),int0);",
                        "  \t\t\t}",
                        "  \t\t}",
                        "  \t\t//Военная база",
                        "  \t\tif(ShipType(dwd1)=='WB')",
                        "  \t\t{",
                        "  \t\t\t//Глобальное отношение планет людей, фэй и гаальцев",
                        "  \t\t\tint0=GlobalRelationsPlanets(Player(),0,4+8+16)+RelationToRanger(dwd1,Player());",
                        "  \t\t\tint0=int0/2;",
                        "  \t\t\t//Проверяем, не пират ли игрок",
                        "  \t\t\tif(ShipOwner(Player())!=7)",
                        "  \t\t\t{",
                        "  \t\t\t\tif(int0>75)RelationToRanger(dwd1,Player(),75);",
                        "  \t\t\t\telse if(int0<10)RelationToRanger(dwd1,Player(),10);",
                        "  \t\t\t\telse if(int0>9 && int0<=75)RelationToRanger(dwd1,Player(),int0);",
                        "  \t\t\t}",
                        "  \t\t\telse",
                        "  \t\t\t{",
                        "  \t\t\t\tRelationToRanger(dwd1,Player(),10);",
                        "  \t\t\t}",
                        "  \t\t}",
                        "  \t\t//Пиратские базы и доминионы",
                        "  \t\tif(ShipType(dwd1)=='PB' || ShipType(dwd1)=='CB')",
                        "  \t\t{",
                        "  \t\t\t//Глобальное отношение клановых планет",
                        "  \t\t\tint0=GlobalRelationsPlanets(Player(),0,128)+RelationToRanger(dwd1,Player());",
                        "  \t\t\tint0=int0/2;",
                        "  \t\t\t//Проверяем, не пират ли игрок",
                        "  \t\t\tif(ShipOwner(Player())==7)",
                        "  \t\t\t{",
                        "  \t\t\t\tif(int0>100)RelationToRanger(dwd1,Player(),100);",
                        "  \t\t\t\telse if(int0<10)RelationToRanger(dwd1,Player(),10);",
                        "  \t\t\t\telse if(int0>9 && int0<=100)RelationToRanger(dwd1,Player(),int0);",
                        "  \t\t\t}",
                        "  \t\t\telse",
                        "  \t\t\t{",
                        "  \t\t\t\tif(int0>50)RelationToRanger(dwd1,Player(),50);",
                        "  \t\t\t\telse if(int0<10)RelationToRanger(dwd1,Player(),10);",
                        "  \t\t\t\telse if(int0>9 && int0<=50)RelationToRanger(dwd1,Player(),int0);",
                        "  \t\t\t}",
                        "  \t\t}",
                        "  \t}",
                        "  }",
                        "}",
                        "if(newStar == curStar) {",
                        "  dwd0=ShipStar(Player());",
                        "  domBon=0;",
                        "  relation=0;",
                        "  ExtraBon=0;",
                        "  ",
                        "  for(i=GalaxyEvents()-1;i>=0;i=i-1)",
                        "  {",
                        "  \tif(GalaxyEventDate(i)<CurTurn())break;",
                        "  \t//Репутация, снимаемая за рэкет",
                        "  \tif(GalaxyEventType(i)=='PlayerExtortsMoney')relation=relation-8;",
                        "  \tif(GalaxyEventType(i)=='PlayerExtortsGoods')relation=relation-8;",
                        "  \tif(GalaxyEventType(i)=='PlayerKillsShip')",
                        "  \t{",
                        "  \t\t//Репутация, снимаемая/добавляемая за уничтожение кораблей/станций",
                        "  \t\tif(GalaxyEventData(i,0)==t_Kling)domBon=domBon+5;",
                        "  \t\tif(GalaxyEventData(i,0)==t_Ranger)relation=relation-10;",
                        "  \t\tif(GalaxyEventData(i,0)==t_Transport)relation=relation-10;",
                        "  \t\tif(GalaxyEventData(i,0)==t_Pirate)relation=relation+10;",
                        "  \t\tif(GalaxyEventData(i,0)==t_RC)relation=relation-15;",
                        "  \t\tif(GalaxyEventData(i,0)==t_PB)relation=relation+15;",
                        "  \t\tif(GalaxyEventData(i,0)==t_WB)relation=relation-15;",
                        "  \t\tif(GalaxyEventData(i,0)==t_SB)relation=relation-15;",
                        "  \t\tif(GalaxyEventData(i,0)==t_BK)relation=relation-15;",
                        "  \t\tif(GalaxyEventData(i,0)==11)relation=relation-15;",
                        "  \t\tif(GalaxyEventData(i,0)==t_CB)relation=relation+15;",
                        "  \t\tif(GalaxyEventData(i,0)==13)",
                        "  \t\t{",
                        "              //Нейролинк",
                        "  \t\t\tif(GalaxyEventsTextData(i,2)=='KB')relation=relation+15;",
                        "              //Центр наёмников",
                        "  \t\t\tif(GalaxyEventsTextData(i,2)=='MB')ExtraBon=ExtraBon-15;",
                        "              //Ингибитор",
                        "  \t\t\tif(GalaxyEventsTextData(i,2)=='Inhibitor')ExtraBon=ExtraBon-80;",
                        "  \t\t}",
                        "  \t\t//Штраф репутации за уничтожение военных и флагманов",
                        "  \t\tif(GalaxyEventData(i,0)==t_Warrior)",
                        "  \t\t{",
                        "  \t\t\trelation=relation-10;",
                        "  \t\t\tif(findsubstr(GalaxyEventsTextData(i,1),CT('ShipType.Maloc.WarriorBig'))==0)relation=relation-15;",
                        "  \t\t\tif(findsubstr(GalaxyEventsTextData(i,1),CT('ShipType.Peleng.WarriorBig'))==0)relation=relation-15;",
                        "  \t\t\tif(findsubstr(GalaxyEventsTextData(i,1),CT('ShipType.People.WarriorBig'))==0)relation=relation-15;",
                        "  \t\t\tif(findsubstr(GalaxyEventsTextData(i,1),CT('ShipType.Fei.WarriorBig'))==0)relation=relation-15;",
                        "  \t\t\tif(findsubstr(GalaxyEventsTextData(i,1),CT('ShipType.Gaal.WarriorBig'))==0)relation=relation-15;",
                        "  \t\t}",
                        "  \t}",
                        "  }",
                        "  if(relation!=0)",
                        "  {",
                        "  \tif(StarRuins(dwd0))",
                        "  \t{",
                        "  \t\tfor(i=0;i<StarRuins(dwd0);i=i+1)",
                        "  \t\t{",
                        "  \t\t\tdwd1=StarRuins(dwd0,i);",
                        "  \t\t\tif(RelationToRanger(dwd1,Player())<10)continue;",
                        "  \t\t\tif(ShipType(dwd1)=='RC' || ShipType(dwd1)=='WB' || ShipType(dwd1)=='SB' || ShipType(dwd1)=='BK' || ShipType(dwd1)=='TC')",
                        "  \t\t\t{",
                        "  \t\t\t\tint0=RelationToRanger(dwd1,Player())+relation+ExtraBon+domBon;",
                        "  \t\t\t\tif(int0>100)RelationToRanger(dwd1,Player(),100);",
                        "  \t\t\t\tif(int0<10)RelationToRanger(dwd1,Player(),10);",
                        "  \t\t\t\tif(int0>9 && int0<=100)RelationToRanger(dwd1,Player(),int0);",
                        "  \t\t\t\tif(ShipOwner(Player())==7)",
                        "  \t\t\t\t{",
                        "  \t\t\t\t\tif(RelationToRanger(dwd1,Player())>50 && ShipType(dwd1)!='BK')RelationToRanger(dwd1,Player(),50);",
                        "  \t\t\t\t\tif(ShipType(dwd1)=='WB')RelationToRanger(dwd1,Player(),10);",
                        "  \t\t\t\t}",
                        "  \t\t\t}",
                        "  \t\t\tif(ShipType(dwd1)=='PB' || ShipType(dwd1)=='CB')",
                        "  \t\t\t{",
                        "  \t\t\t\tint0=RelationToRanger(dwd1,Player())-relation+ExtraBon+domBon;",
                        "  \t\t\t\tif(int0>100)RelationToRanger(dwd1,Player(),100);",
                        "  \t\t\t\tif(int0<10)RelationToRanger(dwd1,Player(),10);",
                        "  \t\t\t\tif(int0>9 && int0<=100)RelationToRanger(dwd1,Player(),int0);",
                        "  \t\t\t\tif(ShipOwner(Player())!=7)",
                        "  \t\t\t\t{",
                        "  \t\t\t\t\tif(RelationToRanger(dwd1,Player())>50)RelationToRanger(dwd1,Player(),50);",
                        "  \t\t\t\t}",
                        "  \t\t\t}",
                        "  \t\t}",
                        "  \t}",
                        "  \trelation=0;",
                        "  \tdomBon=0;",
                        "  \tExtraBon=0;",
                        "  }",
                        "}",
                        "if(!ShipIsTakeoff(Player())) {",
                        "  if(PirateWin()==3)",
                        "  {",
                        "  \tif(ShipOwner(Player())==7)",
                        "  \t{",
                        "  \t\tShipOwner(Player(),ShipPilotRace(Player()));",
                        "  \t\tShipType(Player(),'Ranger');",
                        "  \t\tdwd0=ShipStar(Player());",
                        "  \t\t//Меняем отношение баз",
                        "  \t\tif(StarRuins(dwd0))",
                        "  \t\t{",
                        "  \t\t\tfor(i=0;i<StarRuins(dwd0);i=i+1)",
                        "  \t\t\t{",
                        "  \t\t\t\tdwd1=StarRuins(dwd0,i);",
                        "  \t\t\t\tif(RelationToRanger(dwd1,Player())<10)continue;",
                        "  \t\t\t\t//Коалиционные базы",
                        "  \t\t\t\tif(ShipType(dwd1)=='RC' || ShipType(dwd1)=='SB' || ShipType(dwd1)=='BK' || ShipType(dwd1)=='TC')",
                        "  \t\t\t\t{",
                        "  \t\t\t\t\t//Глобальное отношение планет людей, фэй и гаальцев",
                        "  \t\t\t\t\tint0=GlobalRelationsPlanets(Player(),0,4+8+16)+RelationToRanger(dwd1,Player());",
                        "  \t\t\t\t\tint0=int0/2;",
                        "  \t\t\t\t\tif(int0>100)RelationToRanger(dwd1,Player(),100);",
                        "  \t\t\t\t\tif(int0<10)RelationToRanger(dwd1,Player(),10);",
                        "  \t\t\t\t\tif(int0>9 && int0<=100)RelationToRanger(dwd1,Player(),int0);",
                        "  \t\t\t\t}",
                        "  \t\t\t\t//Военная база",
                        "  \t\t\t\tif(ShipType(dwd1)=='WB')",
                        "  \t\t\t\t{",
                        "  \t\t\t\t\t//Глобальное отношение планет людей, фэй и гаальцев",
                        "  \t\t\t\t\tint0=GlobalRelationsPlanets(Player(),0,4+8+16)+RelationToRanger(dwd1,Player());",
                        "  \t\t\t\t\tint0=int0/2;",
                        "  \t\t\t\t\tif(int0>75)RelationToRanger(dwd1,Player(),75);",
                        "  \t\t\t\t\tif(int0<10)RelationToRanger(dwd1,Player(),10);",
                        "  \t\t\t\t\tif(int0>9 && int0<=75)RelationToRanger(dwd1,Player(),int0);",
                        "  \t\t\t\t}",
                        "  \t\t\t\t//Пиратские базы и доминионы",
                        "  \t\t\t\tif(ShipType(dwd1)=='PB')",
                        "  \t\t\t\t{",
                        "  \t\t\t\t\t//Глобальное отношение клановых планет",
                        "  \t\t\t\t\tint0=GlobalRelationsPlanets(Player(),0,128)+RelationToRanger(dwd1,Player());",
                        "  \t\t\t\t\tint0=int0/2;",
                        "  \t\t\t\t\tif(int0>50)RelationToRanger(dwd1,Player(),50);",
                        "  \t\t\t\t\tif(int0<10)RelationToRanger(dwd1,Player(),10);",
                        "  \t\t\t\t\tif(int0>9 && int0<=50)RelationToRanger(dwd1,Player(),int0);",
                        "  \t\t\t\t}",
                        "  \t\t\t\tif(ShipType(dwd1)=='CB')",
                        "  \t\t\t\t{",
                        "  \t\t\t\t\tRelationToRanger(dwd1,Player(),0);",
                        "  \t\t\t\t}",
                        "  \t\t\t}",
                        "  \t\t}",
                        "  \t\tdwd0=0;",
                        "  \t}",
                        "  }",
                        "  //Удалённо переводим пиратские налоги на счёт игрока через каждые 100 дней",
                        "  if(PirateWin()==1 || PirateWin()==2 || PirateWin()==5)",
                        "  {",
                        "  \tif((GetShipPirateRank(Player())>=7) && ShipOwner(Player())==7 && StarOwner(GalaxyStar(71))==2 && StarCustomFaction(GalaxyStar(71))!='Klissan')",
                        "  \t{",
                        "  \t\tif(MoneyGoes==-1)MoneyGoes=CurTurn()+100;",
                        "  \t\tif(CurTurn()>=MoneyGoes)",
                        "  \t\t{",
                        "  \t\t\tif((CurTurn()-last_turn_taxes)>=100)",
                        "  \t\t\t{",
                        "  \t\t\t\tNewsAdd(Format(CT(\"Script.Mod_ExpTraitors.102\"),\"<0>\",1000*min(100,(CurTurn()-last_turn_taxes))));",
                        "  \t\t\t\tShipMoney(Player(),ShipMoney(Player())+1000*min(100,(CurTurn()-last_turn_taxes)));",
                        "  \t\t\t\tlast_turn_taxes=CurTurn();",
                        "  \t\t\t\tSound('Sound.Buy');",
                        "  \t\t\t}",
                        "  \t\t}",
                        "  \t}",
                        "  }",
                        "}"
                    ],
                    "#": 21,
                    "Type": "Top",
                    "Parent": -1,
                    "Pos.x": 120,
                    "Pos.y": 635
                },
                {
                    "Name": "",
                    "Code.Type": "DialogBegin",
                    "Code": [
                        "if(GetShipRuins(Player())) {",
                        "  if(!PlayerBridge()) {",
                        "    dwd1=GetShipRuins(Player());",
                        "    if(ShipType(dwd1)=='WB') {",
                        "      if(ShipOwner(Player())==7) {",
                        "        RelationToRanger(dwd1,Player(),10);",
                        "      }",
                        "    }",
                        "    if(RelationToRanger(dwd1,Player())<30) {",
                        "      //Блокируем стандартные кнопки магазинов и инфоцентра, заменяем их на свои",
                        "      InterfaceState('RuinsTalk','PR_Shop',0);",
                        "      InterfaceState('RuinsTalk','PR_ShopBlock',1);",
                        "      InterfaceState('RuinsTalk','PR_Goods',0);",
                        "      InterfaceState('RuinsTalk','PR_GoodsBlock',1);",
                        "      InterfaceState('RuinsTalk','PR_Info',0);",
                        "      InterfaceState('RuinsTalk','PR_InfoBlock',1);",
                        "      InterfaceState('RuinsTalk','PM_EndTurn',0);",
                        "      InterfaceState('RuinsTalk','RT_EndTurn_Block',1);",
                        "      //Выключаем панель Ассистента",
                        "      InterfaceState('RuinsTalk','AstAddRuins',0);",
                        "      ",
                        "      //Добавляем игроку инфошку \"подробной блокировки\" формы Ship",
                        "      if(ShipFindCustomShipInfoByType(Player(),'ExpTraitors_RuinsBlock')==-1)ShipAddCustomShipInfo(Player(),'ExpTraitors_RuinsBlock','NoShow');",
                        "      ",
                        "      //Оверрайды блокировки пиратских станций:",
                        "      //Доминион",
                        "      if(ShipType(dwd1)=='CB')AddDialogOverride('CB',100000);",
                        "      //Пиратская база",
                        "      if(ShipType(dwd1)=='PB')AddDialogOverride('PB',100000);",
                        "      ",
                        "      //Оверрайды блокировки коалиционных станций:",
                        "      //Военная база",
                        "      if(ShipType(dwd1)=='WB')AddDialogOverride('WB',100000);",
                        "      //Центр рейнджеров",
                        "      if(ShipType(dwd1)=='RC')AddDialogOverride('RC',100000);",
                        "      //Научная база",
                        "      if(ShipType(dwd1)=='SB')AddDialogOverride('SB',100000);",
                        "      //Бизнес-центр",
                        "      if(ShipType(dwd1)=='BK')AddDialogOverride('BK',100000);",
                        "      //Технологический центр (из мода ExpTC)",
                        "      if(ShipType(dwd1)=='TC')AddDialogOverride('TC',100000);",
                        "    }",
                        "  }",
                        "}",
                        "if(GetShipRuins(Player())>0) {",
                        "  if(ShipType(GetShipRuins(Player()))=='PB') {",
                        "    if(ShipOwner(Player())!=7 && ShipType(Player())=='RangerPiratePlayer') {",
                        "      ShipType(Player(),'Ranger');",
                        "    }",
                        "    if(ShipOwner(Player())==7 && ShipType(Player())!='RangerPiratePlayer') {",
                        "      ShipType(Player(),'RangerPiratePlayer');",
                        "    }",
                        "  }",
                        "}"
                    ],
                    "#": 22,
                    "Type": "Top",
