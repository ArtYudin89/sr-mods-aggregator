                        "//if(~findsubstr(temp_str, 'visor'))",
                        "//{",
                        "//    temp_str = 'Visor';",
                        "//    temp_int = 10;",
                        "//}",
                        "//else if(~findsubstr(temp_str, 'glasses'))",
                        "//{",
