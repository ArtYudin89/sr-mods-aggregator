                },
                {
                    "Name": "block",
                    "Pos.x": 120,
                    "Pos.y": 1440,
                    "Type": "TDialogAnswer",
                    "Parent": -1,
                    "#": 470,
                    "Msg": "Спонсировать фонд",
                    "AMsg.Num": "76",
                    "_orig_danswer": "DAnswer('block~'+CT(\"Script.Mod_ExpPilotBridge.212\"))"
                },
                {
                    "Name": "block",
                    "Pos.x": 240,
                    "Pos.y": 1440,
                    "Type": "TDialogAnswer",
                    "Parent": -1,
                    "#": 471,
                    "Msg": "Спонсировать фонд",
                    "AMsg.Num": "77",
                    "_orig_danswer": "DAnswer('block~'+CT(\"Script.Mod_ExpPilotBridge.212\"))"
                },
                {
                    "Name": "",
                    "Pos.x": 360,
                    "Pos.y": 1440,
                    "Type": "TDialogAnswer",
                    "Parent": -1,
                    "#": 472,
                    "Msg": "Спонсировать постройку",
                    "AMsg.Num": "78",
                    "_orig_danswer": "DAnswer(CT(\"Script.Mod_ExpPilotBridge.1549\"))"
                },
                {
                    "Name": "restart",
                    "Pos.x": 480,
                    "Pos.y": 1440,
                    "Type": "TDialogAnswer",
                    "Parent": -1,
                    "#": 473,
                    "Msg": "К другим проектам",
                    "AMsg.Num": "79",
                    "_orig_danswer": "DAnswer('restart~'+CT(\"Script.Mod_ExpPilotBridge.988\"))"
                },
                {
                    "Name": "block",
                    "Pos.x": 600,
                    "Pos.y": 1440,
                    "Type": "TDialogAnswer",
                    "Parent": -1,
                    "#": 474,
                    "Msg": "Спонсировать постройку",
                    "AMsg.Num": "80",
                    "_orig_danswer": "DAnswer('block~'+CT(\"Script.Mod_ExpPilotBridge.1549\"))"
                }
            ],
            "DialogMessages": [
                {
                    "Name": "",
                    "Pos.x": 0,
                    "Pos.y": 1120,
                    "Type": "TDialogMsg",
                    "Parent": -1,
                    "#": 328,
                    "Msg": "Заказ подтверждён.\r\n<0>\r\nГруз прибудет на место:\r\n<1> <clr>года<clrEnd>\r\n\r\nПо прибытии груза вам будет направлено соответствующее уведомление. Благодарим вас за выбор <clr>LGL<clrEnd>.",
                    "DMsg.Num": "0",
                    "_orig_dtext": "DText(Format(CT(\"Script.Mod_ExpPilotBridge.967\"),\"<0>\",DefSplt,\"<1>\",GameDateTxtByTurn(transfer_day_orig+1)))"
                },
                {
                    "Name": "",
                    "Pos.x": 150,
                    "Pos.y": 1120,
                    "Type": "TDialogMsg",
                    "Parent": -1,
                    "#": 329,
                    "Msg": "<0>",
                    "DMsg.Num": "1",
                    "_orig_dtext": "DText(Format(CT(\"Script.Mod_ExpPilotBridge.1543\"),\"<0>\",tstr1))"
                },
                {
                    "Name": "",
                    "Pos.x": 300,
                    "Pos.y": 1120,
                    "Type": "TDialogMsg",
                    "Parent": -1,
                    "#": 330,
                    "Msg": "Приветствую и поздравляю. У вас, гражданских ничтожеств, появился шанс помочь доблестной малокской армии наконец-то добить всех врагов и прийти к победе! Мы - группа из <0> военных пилотов-ветеранов, обладающая огромным опытом в ведении боевых действий и до сих пор томившаяся на гражданке, но благодаря вам у нас может наконец появиться шанс вновь сесть за штурвалы боевых кораблей и показать каждому, на что способна великая малокская армия.\r\nВ случае успешного финансирования мы организуем отряд, под названием <1> и немедленно приступим к оказанию боевой поддержки коалиционному флоту и охране порядка, на подконтрольных коалиции территориях. На данный момент мы базируемся на планете <2> в системе <3>, от куда, в случае успеха, <4> и начнем нашу службу. На этом все. Вольно!\r\nСобранные средства: <5>/<6> cr.",
                    "DMsg.Num": "2",
                    "_orig_dtext": "DText(Format(CT(\"Script.Mod_ExpPilotBridge.624\"),\"<0>\",ship_count,\"<1>\",bld_ship_name,\"<2>\",Name(IdToPlanet(bld_ship_planet)),\"<3>\",StarName(PlanetToStar(IdToPlanet(bld_ship_planet))),\"<4>\",GameDateTxtByTurn(bld_day+1),\"<5>\",credits_now,\"<6>\",bld_cost))"
                },
                {
                    "Name": "",
                    "Pos.x": 450,
                    "Pos.y": 1120,
                    "Type": "TDialogMsg",
                    "Parent": -1,
                    "#": 331,
                    "Msg": "Нам прекрасно известно как обстоят дела. Коалиция разваливается на части, ведя малоуспешную войну на два фронта, экономика в упадке, а страдают от этого обычные граждане. Мы тоже от этого пострадали и больше не хотим этого терпеть. Коалиция - это отмершая кожа, которую нужно сбросить с тем, чтобы расти дальше и в наших планах сделать это, или хотя бы помочь этому осуществиться!\r\nМы организовали повстанческий отряд, под названием <0>, сейчас он небольшой, состоит всего из <1> членов, но в будущем к нам наверняка присоединятся и другие. Однако сейчас мы столкнулись с проблемой - для того чтобы действительно сделать что-то значимое нам нужны полностью оборудованные и вооруженные боевые корабли, а это, как известно, удовольствие не из дешевых. Поэтому мы и обращаемся к вам за помощью: помогите освободительному движению! В ваших силах дать нам корабли, а в наших силах подарить вам истинную свободу! Долой коалиционных тиранов!\r\nОтряд набирает добровольцев на планете <2> в системе <3> до <4>.\r\nСобранные средства: <5>/<6> cr.",
                    "DMsg.Num": "3",
                    "_orig_dtext": "DText(Format(CT(\"Script.Mod_ExpPilotBridge.860\"),\"<0>\",bld_ship_name_2,\"<1>\",ship_count_2,\"<2>\",Name(IdToPlanet(bld_ship_planet_2)),\"<3>\",StarName(PlanetToStar(IdToPlanet(bld_ship_planet_2))),\"<4>\",GameDateTxtByTurn(bld_day_2+1),\"<5>\",credits_now_2,\"<6>\",bld_cost_2))"
                },
                {
                    "Name": "",
                    "Pos.x": 600,
                    "Pos.y": 1120,
                    "Type": "TDialogMsg",
                    "Parent": -1,
                    "#": 332,
                    "Msg": "Добро пожаловать на сайт нашего эко-общества \"Очистим космос\".\r\nЗнаете ли вы, что на каждого жителя Коалиции приходиться более 1000 тонн космического мусора ежегодно. А ведь в космосе практически не существует никаких факторов влияющих на разложение объектов! Та маленькая баночка из под Махпеллы, что вы выбросили однажды за борт до сих пор находиться где-то в космосе и будет находиться там вечно. Кому же это мешает, спросите вы! Одна банка, безусловно, никому, но таких банок триллионы и не только банок - контейнеры с бесхозным грузом, детали давным-давно уничтоженных кораблей, да и просто самые обычные минералы, оставшиеся после уничтоженного астероида - все это мусор, а когда мусора много появляется множество проблем. Большие скопления космического мусора серьезно затрудняют навигацию, падение мусора на планеты, мало того, что опасно само по себе, так еще и дополнительно ухудшает экологию планет, большие скопления мусора вокруг звезд могут помешать свету добираться до планет, что может привести к катастрофическим изменениям климата, словом проблема космического мусора сейчас актуальна как никогда.\r\nПоэтому мы будем признательны пилотам, которые помогут сохранить космическое пространство для будущих поколений! Мы публикуем список особо загрязненных систем вы можете помочь нам собрав там весь мусор, какой сможете, если среди мусора найдется что-то ценное вы, разумеется, имеете на это эксклюзивное право.",
                    "DMsg.Num": "4",
                    "_orig_dtext": "DText(CT(\"Script.Mod_ExpPilotBridge.462\"))"
                },
                {
                    "Name": "",
                    "Pos.x": 750,
                    "Pos.y": 1120,
                    "Type": "TDialogMsg",
                    "Parent": -1,
                    "#": 333,
                    "Msg": "<clr>Топ самых грязных систем:<clrEnd>\r\n<0>",
                    "DMsg.Num": "5",
                    "_orig_dtext": "DText(Format(CT(\"Script.Mod_ExpPilotBridge.1298\"),\"<0>\",temp_str))"
                },
                {
                    "Name": "",
                    "Pos.x": 900,
                    "Pos.y": 1120,
                    "Type": "TDialogMsg",
                    "Parent": -1,
                    "#": 334,
                    "Msg": "Здравствуйте, друзья! Сегодня мы обращаемся к вам с просьбой о помощи. Всем известно, что идет война и любой уважающий себя гаалец желает, чтобы война наконец закончилась, но жестокая правда этой жизни в том, что чтобы война закончилась - нужно воевать. И сейчас любой гаалец делает выбор - остаться верным заветам пацифизма, которым нас учит Кодекс Га или же бороться и тем самым приближать мир и благоденствие во всей Галактике.\r\nЯ и мои друзья сделали свой выбор: мы будем бороться, защищать мирных граждан, поддерживать порядок и, что самое главное, справедливость. Но и это не так то просто в нашем мире, в мире где за все нужно платить, особенно за хорошо оборудованные боевые корабли. Поэтому нам и нужна ваша помощь, если финансирование проекта окажется успешным, то <0> кораблей, объединенных в отряд, который мы решили назвать <1>, смогут отправиться в космос, с тем, чтобы привнести хотя бы немного гармонии в этот обезумевший мир. Сейчас мы находимся на планете <2> в системе <3> от сюда же и начнется наша миссия <4>. Заранее приносим нашу благодарность.\r\nСобранные средства: <5>/<6> cr.",
                    "DMsg.Num": "6",
                    "_orig_dtext": "DText(Format(CT(\"Script.Mod_ExpPilotBridge.375\"),\"<0>\",ship_count,\"<1>\",bld_ship_name,\"<2>\",Name(IdToPlanet(bld_ship_planet)),\"<3>\",StarName(PlanetToStar(IdToPlanet(bld_ship_planet))),\"<4>\",GameDateTxtByTurn(bld_day+1),\"<5>\",credits_now,\"<6>\",bld_cost))"
                },
                {
                    "Name": "",
                    "Pos.x": 1050,
                    "Pos.y": 1120,
                    "Type": "TDialogMsg",
                    "Parent": -1,
                    "#": 335,
                    "Msg": "Здравствуйте. Не буду долго ходить вокруг да около, говорю сразу: нам в этой войне не победить! А теперь давайте по порядку. Я представляю фэянский научно-исследовательский институт планеты <0> системы <1>, более известный как НИИ «<2>». Мы специализируемся на математике и статистике. Мы просчитали все возможные варианты развития событий, учитывая даже такие, мало-предсказуемые факторы как: героизм отдельно взятых личностей, природные катаклизмы и общественные волнения вызванные повышением цен на текстильную продукцию, мы даже учитывали принцип «Одного шанса на миллион», сформулированного еще древним человеческим математиком П. Терри, словом, наши результаты могут претендовать на самые полные и объективные из всех возможных. И они неутешительны. Согласно нашим расчетам шансы коалиции на победу сейчас оставляют лишь <3>%. Однако не все еще потеряно! Мы вычислили, что решающий перелом <4> нам могут принести всего несколько дополнительных военных кораблей(если конкретно, то - <5>), мы с коллегами готовы взять на себя эту ношу, однако министерство наотрез отказывается выдавать нам корабли!\r\nТак что теперь все в ваших руках, если вы окажете свою поддержку то мы сможем сами купить и оборудовать себе корабли, что в свою очередь принесет коалиции решающий процент в шансах на победу. Все в наших с вами руках!\r\nСобранные средства: <6>/<7> cr.",
                    "DMsg.Num": "7",
                    "_orig_dtext": "DText(Format(CT(\"Script.Mod_ExpPilotBridge.625\"),\"<0>\",Name(IdToPlanet(bld_ship_planet)),\"<1>\",StarName(PlanetToStar(IdToPlanet(bld_ship_planet))),\"<2>\",bld_ship_name,\"<3>\",substr(0.0001*Rnd(412,963),0,6),\"<4>\",GameDateTxtByTurn(bld_day+1),\"<5>\",ship_count,\"<6>\",credits_now,\"<7>\",bld_cost))"
                },
                {
                    "Name": "",
                    "Pos.x": 1200,
                    "Pos.y": 1120,
                    "Type": "TDialogMsg",
                    "Parent": -1,
                    "#": 336,
                    "Msg": "Мы рады приветствовать вас, друзья. Ни для кого не секрет, что война, которая сейчас идет, очень неблагоприятно отражается на интересах простых и честных предпринимателей, коими мы, разумеется, являемся. Думаю, мы все можем согласиться, что регулярная армия справляется со своей задачей из рук вон плохо, а это значит, что нам, как всегда, придется делать все самим.\r\nЯ и мои друзья, тоже честные предприниматели(всего нас <0>), могли бы заняться этим. Мы даже название нашей банде уже придумали - <1>. Корабли у нас есть, но вот незадача, вооружение и оборудование старое и в основном нерабочее. Обеспечить наши корабли требуемым оборудованием - задача весьма финансоемкая и поэтому нам нужна ваша помощь. Мы гарантируем, что не менее половины полученных денег будет честно потрачено на оборудование и вооружение. Сейчас мы находимся на планете <2>, что в системе <3>. От сюда мы и планируем начать нашу боевую деятельность <4>, в случае успешного финансирования проекта. Надеемся на вашу поддержку.\r\nСобранные средства: <5>/<6> cr.",
                    "DMsg.Num": "8",
                    "_orig_dtext": "DText(Format(CT(\"Script.Mod_ExpPilotBridge.386\"),\"<0>\",ship_count,\"<1>\",bld_ship_name,\"<2>\",Name(IdToPlanet(bld_ship_planet)),\"<3>\",StarName(PlanetToStar(IdToPlanet(bld_ship_planet))),\"<4>\",GameDateTxtByTurn(bld_day+1),\"<5>\",credits_now,\"<6>\",bld_cost))"
                },
                {
                    "Name": "",
                    "Pos.x": 1350,
                    "Pos.y": 1120,
                    "Type": "TDialogMsg",
                    "Parent": -1,
                    "#": 337,
                    "Msg": "Здравствуйте. Я представляю общественную организацию <0> с планеты <1> (система <2>). Мы очень обеспокоены сложившейся ситуацией на военных фронтах. Мы старались оказывать посильную помощь коалиционной армии, в первую очередь, разумеется, финансовую, но сейчас понимаем, что этого недостаточно. Армии нужны люди. В наших рядах нашлись бывшие наемники, военные в отставке, сотрудники правоохранительных структур, словом те, кто имеет некий опыт ведения боевых действий. Всего мы смогли собрать <3> добровольцев, которые были бы готовы встать на защиту коалиции в качестве ополченцев, но, к сожалению, кораблей, необходимого оборудования и оружия у нас нет. Армия, как я уже упомянул, тоже переживает не лучшие времена и выделить нам корабли неспособна, поэтому мы и обращаемся к вам. В случае успешного финансирования проекта наш добровольческий отряд сможет, наконец, делать то, для чего предназначен - защищать жизни невинных граждан и приближать победу в войне. Сбор средств продлится до <4>.\r\nСобранные средства: <5>/<6> cr.",
                    "DMsg.Num": "9",
                    "_orig_dtext": "DText(Format(CT(\"Script.Mod_ExpPilotBridge.650\"),\"<0>\",bld_ship_name,\"<1>\",Name(IdToPlanet(bld_ship_planet)),\"<2>\",StarName(PlanetToStar(IdToPlanet(bld_ship_planet))),\"<3>\",ship_count,\"<4>\",GameDateTxtByTurn(bld_day+1),\"<5>\",credits_now,\"<6>\",bld_cost))"
                },
                {
                    "Name": "",
                    "Pos.x": 1500,
                    "Pos.y": 1120,
                    "Type": "TDialogMsg",
                    "Parent": -1,
                    "#": 338,
                    "Msg": "<clr>Какая система вас интересует?<clrEnd>\r\n<0><1>",
                    "DMsg.Num": "10",
                    "_orig_dtext": "DText(Format(CT(\"Script.Mod_ExpPilotBridge.1299\"),\"<0>\",temp_str_4,\"<1>\",temp_str))"
                },
                {
                    "Name": "",
                    "Pos.x": 1650,
                    "Pos.y": 1120,
                    "Type": "TDialogMsg",
                    "Parent": -1,
                    "#": 339,
                    "Msg": "Систему <0> в данный момент загрязняют следующие бесхозные объекты:\r\n<1>",
                    "DMsg.Num": "11",
                    "_orig_dtext": "DText(Format(CT(\"Script.Mod_ExpPilotBridge.1301\"),\"<0>\",StarName(temp_dword),\"<1>\",temp_str))"
                },
                {
                    "Name": "",
                    "Pos.x": 0,
                    "Pos.y": 1145,
                    "Type": "TDialogMsg",
                    "Parent": -1,
                    "#": 340,
                    "Msg": "Вы находитесь на сайте межзвёздной службы доставки <clr>Lightspeed Galactic Logistics<clrEnd>, или <clr>LGL<clrEnd>.\r\nУ нас вы можете заказать доставку любого груза из любой системы до любой другой звезды. Девиз LGL - \"Со скоростью света, хоть на край вселенной!\".\r\nЗа долгие десятилетия существования LGL, наша служба смогла добиться внушительных показателей качества и надёжности в области подпространственной логистики и осуществлении межзвёздных грузоперевозок. Даже в нелёгких условиях военного времени LGL может с гордостью гарантировать всем своим клиентам <clr>95%<clrEnd> безопасность<0> их грузов.\r\n\r\nВы можете заказать у нас доставку своего груза прямо сейчас! Для этого вам необходимо выбрать пункт отправления из представленного ниже списка (<clr>система<clrEnd> указана в скобках) и приступить к подбору прочих условий доставки, следуя появляющимся подсказкам.\r\n<1>",
                    "DMsg.Num": "12",
                    "_orig_dtext": "DText(Format(CT(\"Script.Mod_ExpPilotBridge.942\"),\"<0>\",temp_str_2,\"<1>\",temp_str))"
                },
                {
                    "Name": "",
                    "Pos.x": 150,
                    "Pos.y": 1145,
                    "Type": "TDialogMsg",
                    "Parent": -1,
                    "#": 341,
                    "Msg": "Выберите <clr>планету<clrEnd> или <clr>станцию<clrEnd>, на которую вы хотите отправить ваш груз (соответствующая <clr>система<clrEnd> указана в скобках).",
                    "DMsg.Num": "13",
                    "_orig_dtext": "DText(CT(\"Script.Mod_ExpPilotBridge.1095\"))"
                },
                {
                    "Name": "",
                    "Pos.x": 300,
                    "Pos.y": 1145,
                    "Type": "TDialogMsg",
                    "Parent": -1,
                    "#": 342,
                    "Msg": "На складе <0><1> у вас хранятся следующие предметы:\r\n<2>\r\n<3>\r\nВы можете составить конкретный <clr>список<clrEnd> или выбрать для отправки сразу <clr>всё<clrEnd> содержимое склада.",
                    "DMsg.Num": "14",
                    "_orig_dtext": "DText(Format(CT(\"Script.Mod_ExpPilotBridge.1379\"),\"<0>\",point_from,\"<1>\",Name(point_1),\"<2>\",DefSplt,\"<3>\",temp_str))"
                },
                {
                    "Name": "",
                    "Pos.x": 450,
                    "Pos.y": 1145,
                    "Type": "TDialogMsg",
                    "Parent": -1,
                    "#": 343,
                    "Msg": "Выберите предметы, которые вы хотите отправить на <0>.\r\n\r\nВыбранные предметы:\r\n<1>\r\n<2>",
                    "DMsg.Num": "15",
                    "_orig_dtext": "DText(Format(CT(\"Script.Mod_ExpPilotBridge.985\"),\"<0>\",point_3_name,\"<1>\",DefSplt,\"<2>\",temp_str))"
                },
                {
                    "Name": "",
                    "Pos.x": 600,
                    "Pos.y": 1145,
                    "Type": "TDialogMsg",
                    "Parent": -1,
                    "#": 344,
                    "Msg": "Выберите предметы, которые вы хотите отправить на <0>.\r\n\r\nВыбранные предметы:\r\n<1>\r\n<2>",
                    "DMsg.Num": "16",
                    "_orig_dtext": "DText(Format(CT(\"Script.Mod_ExpPilotBridge.985\"),\"<0>\",point_3_name,\"<1>\",DefSplt,\"<2>\",temp_str))"
                },
                {
                    "Name": "",
                    "Pos.x": 750,
                    "Pos.y": 1145,
                    "Type": "TDialogMsg",
                    "Parent": -1,
                    "#": 345,
                    "Msg": "Выберите галактический <clr>сектор<clrEnd>, в котором находится конечная точка доставки груза.\r\nПункт отправки находится в секторе, отмеченном синим цветом.",
                    "DMsg.Num": "17",
                    "_orig_dtext": "DText(CT(\"Script.Mod_ExpPilotBridge.1402\"))"
                },
                {
                    "Name": "",
                    "Pos.x": 900,
                    "Pos.y": 1145,
                    "Type": "TDialogMsg",
                    "Parent": -1,
                    "#": 346,
                    "Msg": "Выберите интересующий вас раздел:\r\n<0>",
                    "DMsg.Num": "18",
                    "_orig_dtext": "DText(Format(CT(\"Script.Mod_ExpPilotBridge.476\"),\"<0>\",temp_str))"
                },
                {
                    "Name": "",
                    "Pos.x": 1050,
                    "Pos.y": 1145,
                    "Type": "TDialogMsg",
                    "Parent": -1,
                    "#": 347,
                    "Msg": "<0>",
                    "DMsg.Num": "19",
                    "_orig_dtext": "DText(Format(CT(\"Script.Mod_ExpPilotBridge.1543\"),\"<0>\",temp_str))"
                },
                {
                    "Name": "",
                    "Pos.x": 1200,
                    "Pos.y": 1145,
                    "Type": "TDialogMsg",
                    "Parent": -1,
                    "#": 348,
                    "Msg": "<0>",
                    "DMsg.Num": "20",
                    "_orig_dtext": "DText(Format(CT(\"Script.Mod_ExpPilotBridge.1543\"),\"<0>\",temp_str))"
                },
                {
                    "Name": "",
                    "Pos.x": 1350,
                    "Pos.y": 1145,
                    "Type": "TDialogMsg",
                    "Parent": -1,
                    "#": 349,
                    "Msg": "Общий вес груза: <0> т.\r\n<1>\r\n\r\nВыберите желаемый способ:\r\n<2>\r\n--- <clr>Курьерская<clrEnd> ---\r\nСтоимость: <3> cr.\r\nВремя в пути: <4> дн.\r\n\r\n--- <clr>Ускоренная<clrEnd> ---\r\nСтоимость: <5> cr.\r\nВремя в пути: <6> дн.\r\n\r\n--- <clr>Обычная<clrEnd> ---\r\nСтоимость: <7> cr.\r\nВремя в пути: <8> дн.",
                    "DMsg.Num": "21",
                    "_orig_dtext": "DText(Format(CT(\"Script.Mod_ExpPilotBridge.986\"),\"<0>\",transfer_cargo_size,\"<1>\",dist_to,\"<2>\",DefSplt,\"<3>\",transfer_cargo_cost+(transfer_cargo_cost*20)/100,\"<4>\",transfer_day_start,\"<5>\",(transfer_cargo_cost*80)/100,\"<6>\",transfer_day,\"<7>\",(transfer_cargo_cost*40)/100,\"<8>\",transfer_day+(transfer_day*40)/100))"
                },
                {
                    "Name": "",
                    "Pos.x": 1500,
                    "Pos.y": 1145,
                    "Type": "TDialogMsg",
                    "Parent": -1,
                    "#": 350,
                    "Msg": "Вы выбрали доставку:\r\n<0> <1>\r\n<2> <3>\r\nСистема отправки: <4>\r\nСистема назначения: <5>\r\n<6>\r\n\r\nПолный перечень груза:\r\n<7>\r\n<8>",
                    "DMsg.Num": "22",
                    "_orig_dtext": "DText(Format(CT(\"Script.Mod_ExpPilotBridge.969\"),\"<0>\",point_from,\"<1>\",Name(point_1),\"<2>\",point_to,\"<3>\",Name(point_2),\"<4>\",StarName(GalaxyStar(point_1_star)),\"<5>\",point_3_star_name,\"<6>\",temp_str_4,\"<7>\",DefSplt,\"<8>\",temp_str))"
                },
                {
                    "Name": "",
                    "Pos.x": 1650,
                    "Pos.y": 1145,
                    "Type": "TDialogMsg",
                    "Parent": -1,
                    "#": 351,
                    "Msg": "<0>",
                    "DMsg.Num": "23",
                    "_orig_dtext": "DText(Format(CT(\"Script.Mod_ExpPilotBridge.1543\"),\"<0>\",tstr1))"
                },
                {
                    "Name": "",
                    "Pos.x": 0,
                    "Pos.y": 1170,
                    "Type": "TDialogMsg",
                    "Parent": -1,
                    "#": 352,
                    "Msg": "<0>",
                    "DMsg.Num": "24",
                    "_orig_dtext": "DText(Format(CT(\"Script.Mod_ExpPilotBridge.1543\"),\"<0>\",temp_str))"
                },
                {
                    "Name": "",
                    "Pos.x": 150,
                    "Pos.y": 1170,
                    "Type": "TDialogMsg",
                    "Parent": -1,
                    "#": 353,
                    "Msg": "Приветствуем тебя на сайте агентства <clr>Распутин<clrEnd>! Мы - первые спецы Галактики по перегону корпусов любых серий и размеров.\r\nЕсли у тебя на складе уже давно пылится забытый корпус, а самому лететь за ним лень - <clr>Распутин<clrEnd> решит проблему в мгновение ока! Наше агентство имеет представителей почти на каждой заселённой планете, ведь найти профессионального пилота сегодня можно даже в самой заскорузлой дыре, а всё необходимое для перегона оборудование мы предоставляем в аренду по бросовым ценам.\r\nПросто укажи место, где находится нужный корпус, и следуй за простыми подсказками на белом экране.",
                    "DMsg.Num": "25",
                    "_orig_dtext": "DText(CT(\"Script.Mod_ExpPilotBridge.1533\"))"
                },
                {
                    "Name": "",
                    "Pos.x": 300,
                    "Pos.y": 1170,
                    "Type": "TDialogMsg",
                    "Parent": -1,
                    "#": 354,
                    "Msg": "В какой <clr>сектор<clrEnd> будем перегонять? Место отправки находится в секторе, выделенном синим цветом.",
                    "DMsg.Num": "26",
                    "_orig_dtext": "DText(CT(\"Script.Mod_ExpPilotBridge.1378\"))"
                },
                {
                    "Name": "",
                    "Pos.x": 450,
                    "Pos.y": 1170,
                    "Type": "TDialogMsg",
                    "Parent": -1,
                    "#": 355,
                    "Msg": "<0>",
                    "DMsg.Num": "27",
                    "_orig_dtext": "DText(Format(CT(\"Script.Mod_ExpPilotBridge.1543\"),\"<0>\",temp_str))"
                },
                {
                    "Name": "",
                    "Pos.x": 600,
                    "Pos.y": 1170,
                    "Type": "TDialogMsg",
                    "Parent": -1,
                    "#": 356,
                    "Msg": "Выбери <clr>планету<clrEnd> или <clr>станцию<clrEnd>, на которую нужно перегнать твой корпус (<clr>систему<clrEnd> найдёшь в скобках).",
                    "DMsg.Num": "28",
                    "_orig_dtext": "DText(CT(\"Script.Mod_ExpPilotBridge.1100\"))"
                },
                {
                    "Name": "",
                    "Pos.x": 750,
                    "Pos.y": 1170,
                    "Type": "TDialogMsg",
                    "Parent": -1,
                    "#": 357,
                    "Msg": "На <0><1> у тебя хранятся следующие корпуса:\r\n<2>\r\n<3><4>\r\nЧто будем перегонять?",
                    "DMsg.Num": "29",
                    "_orig_dtext": "DText(Format(CT(\"Script.Mod_ExpPilotBridge.1339\"),\"<0>\",point_from,\"<1>\",Name(HullDelFromId),\"<2>\",DefSplt,\"<3>\",temp_str,\"<4>\",DefSplt))"
                },
                {
                    "Name": "",
                    "Pos.x": 900,
                    "Pos.y": 1170,
                    "Type": "TDialogMsg",
                    "Parent": -1,
                    "#": 358,
                    "Msg": "На <0><1> у тебя хранится <2>\r\nПерегонять будем именно его?",
                    "DMsg.Num": "30",
                    "_orig_dtext": "DText(Format(CT(\"Script.Mod_ExpPilotBridge.1342\"),\"<0>\",point_from,\"<1>\",Name(HullDelFromId),\"<2>\",temp_str))"
                },
                {
                    "Name": "",
                    "Pos.x": 1050,
                    "Pos.y": 1170,
                    "Type": "TDialogMsg",
                    "Parent": -1,
                    "#": 359,
                    "Msg": "Выбери корпуса, которые нужно перегнать на <0>. Однако учти, во избежание возникновения логистической путаницы, перегонять ты можешь <clr>не более трёх<clrEnd> корпусов за раз.\r\nАгентство <clr>Распутин<clrEnd> заботится о материальном благополучии своих клиентов.\r\n\r\nПрямо сейчас выбрано:\r\n<1>\r\n<2>",
                    "DMsg.Num": "31",
                    "_orig_dtext": "DText(Format(CT(\"Script.Mod_ExpPilotBridge.1453\"),\"<0>\",HullDelFromStr,\"<1>\",DefSplt,\"<2>\",temp_str))"
                },
                {
                    "Name": "",
                    "Pos.x": 1200,
                    "Pos.y": 1170,
                    "Type": "TDialogMsg",
                    "Parent": -1,
                    "#": 360,
                    "Msg": "",
                    "DMsg.Num": "32",
                    "_orig_dtext": "DText(Format(CT(\"Script.Mod_ExpPilotBridge.1570\"),\"<0>\",HullDelFromStr,\"<1>\",DefSplt,\"<2>\",temp_str))"
                },
                {
                    "Name": "",
                    "Pos.x": 1350,
                    "Pos.y": 1170,
                    "Type": "TDialogMsg",
                    "Parent": -1,
                    "#": 361,
                    "Msg": "Число перегоняемых корпусов: <0>\r\n<1>\r\n\r\n<2>\r\n<3>\r\n--- <clr><4><clrEnd> ---\r\nСтоимость найма: <5> cr.\r\nАренда оборудования: <6> cr.\r\nВремя в пути: <7> дн.\r\n\r\n--- <clr><8><clrEnd> ---\r\nСтоимость найма: <9> cr.\r\nАренда оборудования: <10> cr.\r\nВремя в пути: <11> дн.\r\n\r\n--- <clr><12><clrEnd> ---\r\nСтоимость найма: <13> cr.\r\nАренда оборудования: <14> cr.\r\nВремя в пути: <15> дн.",
                    "DMsg.Num": "33",
                    "_orig_dtext": "DText(Format(CT(\"Script.Mod_ExpPilotBridge.1346\"),\"<0>\",ArrayDim(transfer_list_can)-1,\"<1>\",dist_to,\"<2>\",temp_array_4[1],\"<3>\",DefSplt,\"<4>\",temp_array_4[2],\"<5>\",((transfer_cargo_cost+(transfer_cargo_cost*20)/100)*75)/100,\"<6>\",((transfer_cargo_cost+(transfer_cargo_cost*20)/100)*25)/100,\"<7>\",temp_int_5,\"<8>\",temp_array_4[3],\"<9>\",round(62.5*((transfer_cargo_cost*80)/100))/100,\"<10>\",((transfer_cargo_cost+(transfer_cargo_cost*20)/100)*25)/100,\"<11>\",HullDelTime,\"<12>\",temp_array_4[4],\"<13>\",(((transfer_cargo_cost*40)/100)*25)/100,\"<14>\",((transfer_cargo_cost+(transfer_cargo_cost*20)/100)*25)/100,\"<15>\",HullDelTime+(HullDelTime*40)/100))"
                },
                {
                    "Name": "",
                    "Pos.x": 1500,
                    "Pos.y": 1170,
                    "Type": "TDialogMsg",
                    "Parent": -1,
                    "#": 362,
                    "Msg": "Итак, ты выбрал перегон:\r\n<0> <1>\r\n<2> <3>\r\nСистема отправки: <4>\r\nСистема назначения: <5>\r\n<6>\r\n\r\nЧто перегоняем:\r\n<7>\r\n<8>\r\n\r\n*Стоимость аренды оборудования не может быть компенсирована клиенту ни при каких условиях. Аренда оборудования осуществляется клиентом на свой страх и риск.\r\n**Реальное время осуществления перегона может незначительно отличаться от указанного в графе.",
                    "DMsg.Num": "34",
                    "_orig_dtext": "DText(Format(CT(\"Script.Mod_ExpPilotBridge.1532\"),\"<0>\",point_from,\"<1>\",Name(HullDelFromId),\"<2>\",point_to,\"<3>\",Name(HullDelEndId),\"<4>\",StarName(GalaxyStar(HullFromStarId)),\"<5>\",StarName(GalaxyStar(HullEndStarId)),\"<6>\",temp_str_4,\"<7>\",DefSplt,\"<8>\",temp_str))"
                },
                {
                    "Name": "",
                    "Pos.x": 1650,
                    "Pos.y": 1170,
                    "Type": "TDialogMsg",
                    "Parent": -1,
                    "#": 363,
                    "Msg": "Заказ подтверждён.\r\n<0>\r\n<1>\r\n<2> <clr>года<clrEnd>\r\n\r\n<3>",
                    "DMsg.Num": "35",
                    "_orig_dtext": "DText(Format(CT(\"Script.Mod_ExpPilotBridge.1142\"),\"<0>\",DefSplt,\"<1>\",point_to,\"<2>\",GameDateTxtByTurn(HullDelTimeExp+1),\"<3>\",temp_str))"
                },
                {
                    "Name": "",
                    "Pos.x": 0,
                    "Pos.y": 1195,
                    "Type": "TDialogMsg",
                    "Parent": -1,
                    "#": 364,
                    "Msg": "<0>",
                    "DMsg.Num": "36",
                    "_orig_dtext": "DText(Format(CT(\"Script.Mod_ExpPilotBridge.1543\"),\"<0>\",temp_str))"
                },
                {
                    "Name": "",
                    "Pos.x": 150,
                    "Pos.y": 1195,
                    "Type": "TDialogMsg",
                    "Parent": -1,
                    "#": 365,
                    "Msg": "Да о чём ты вообще!? Тут сражение в самом разгаре!\r\nДавай-ка мы лучше вернёмся к этому разговору в несколько менее напряжённых обстоятельствах, лады?",
                    "DMsg.Num": "37",
                    "_orig_dtext": "DText(CT(\"Script.Mod_ExpPilotBridge.1422\"))"
                },
                {
                    "Name": "",
                    "Pos.x": 300,
                    "Pos.y": 1195,
                    "Type": "TDialogMsg",
                    "Parent": -1,
                    "#": 366,
                    "Msg": "Чего!? <Player>, ну ты в натуре обезбашенный чертила! Ты вообще хоть видишь, что вокруг-то творится?\r\nКороче, побазарим позже, как свалим отсюда нафиг! Отвечаю.",
                    "DMsg.Num": "38",
                    "_orig_dtext": "DText(CT(\"Script.Mod_ExpPilotBridge.1421\"))"
                },
                {
                    "Name": "",
                    "Pos.x": 450,
                    "Pos.y": 1195,
                    "Type": "TDialogMsg",
                    "Parent": -1,
                    "#": 367,
                    "Msg": "Это что вообще за вопросы в пылу боя!?\r\nНет, говорить на такую тему в подобной обстановке я решительно отказываюсь.\r\nВот как окажемся подальше от всей этой драки, так милости прошу - побеседуем. А прямо сейчас у меня и так проблем по горло!",
                    "DMsg.Num": "39",
                    "_orig_dtext": "DText(CT(\"Script.Mod_ExpPilotBridge.1458\"))"
                },
                {
                    "Name": "",
                    "Pos.x": 600,
                    "Pos.y": 1195,
                    "Type": "TDialogMsg",
                    "Parent": -1,
                    "#": 368,
                    "Msg": "<0>",
                    "DMsg.Num": "40",
                    "_orig_dtext": "DText(Format(CT(\"Script.Mod_ExpPilotBridge.1543\"),\"<0>\",temp_str))"
                },
                {
                    "Name": "",
                    "Pos.x": 750,
                    "Pos.y": 1195,
                    "Type": "TDialogMsg",
                    "Parent": -1,
                    "#": 369,
                    "Msg": "<0>",
                    "DMsg.Num": "41",
                    "_orig_dtext": "DText(Format(CT(\"Script.Mod_ExpPilotBridge.1543\"),\"<0>\",temp_str))"
                },
                {
                    "Name": "",
                    "Pos.x": 900,
                    "Pos.y": 1195,
                    "Type": "TDialogMsg",
                    "Parent": -1,
                    "#": 370,
                    "Msg": "<0>",
                    "DMsg.Num": "42",
                    "_orig_dtext": "DText(Format(CT(\"Script.Mod_ExpPilotBridge.1543\"),\"<0>\",temp_str))"
                },
                {
                    "Name": "",
                    "Pos.x": 1050,
                    "Pos.y": 1195,
                    "Type": "TDialogMsg",
                    "Parent": -1,
                    "#": 371,
                    "Msg": "<0>",
                    "DMsg.Num": "43",
                    "_orig_dtext": "DText(Format(CT(\"Script.Mod_ExpPilotBridge.1543\"),\"<0>\",temp_str_3))"
                },
                {
                    "Name": "",
                    "Pos.x": 1200,
                    "Pos.y": 1195,
                    "Type": "TDialogMsg",
                    "Parent": -1,
                    "#": 372,
                    "Msg": "Подсудимый <Player>, за жестокое убийство нашего уважаемого государственного деятеля, вы приговариваетесь к временному лишению свободы с отбыванием наказания в исправительном заведении строгого режима.\r\nПриговор будет приведён в исполнение немедленно и обжалованию не подлежит!",
                    "DMsg.Num": "44",
                    "_orig_dtext": "DText(CT(\"Script.Mod_ExpPilotBridge.1382\"))"
                },
                {
                    "Name": "",
                    "Pos.x": 1350,
                    "Pos.y": 1195,
                    "Type": "TDialogMsg",
                    "Parent": -1,
                    "#": 373,
                    "Msg": "<Player>, позвольте принести вам свои глубочайшие извинения! Буквально вчера нам пришёл новый отчёт по вашему делу, где говорилось, что убийство совершили не вы, а некто <0>, занимавшийся перегоном вашего корпуса незадолго до того, как в нём было обнаружено тело.\r\nВ качестве скромной компенсации за ваши злоключения, мы хотели бы предложить вам солидную денежную премию в размере <1> cr. за ликвидацию этого подлого преступника в течение <2> дней. По нашим данным, прямо сейчас его корабль находится в системе <3>.\r\nСоглашайтесь, <Player>! Ведь так вы сможете и заработать, и отомстить, а заодно привнести толику подлинной справедливости в нашу погрязшую в пороке Галактику!",
                    "DMsg.Num": "45",
                    "_orig_dtext": "DText(Format(CT(\"Script.Mod_ExpPilotBridge.1383\"),\"<0>\",ShipName(IdToShip(ETargetShip)),\"<1>\",EQuestReward,\"<2>\",ETimeLeft+1,\"<3>\",StarName(ShipStar(IdToShip(ETargetShip)))))"
                },
                {
                    "Name": "",
                    "Pos.x": 1500,
                    "Pos.y": 1195,
                    "Type": "TDialogMsg",
                    "Parent": -1,
                    "#": 374,
                    "Msg": "Наш суд - самый гуманный суд во вселенной, <Player>! Скажите ещё спасибо, что вас прямо на заседании не вздёрнули!\r\nТоже мне, нашлась недотрога!",
                    "DMsg.Num": "46",
                    "_orig_dtext": "DText(CT(\"Script.Mod_ExpPilotBridge.1386\"))"
                },
                {
                    "Name": "",
                    "Pos.x": 1650,
                    "Pos.y": 1195,
                    "Type": "TDialogMsg",
                    "Parent": -1,
                    "#": 375,
                    "Msg": "Замечательно! В таком случае ждём от вас хороших новостей.\r\nИ не забывайте - у вас всего <0> дней, иначе, по законам нашей планеты, у дела истечёт срок давности, и все обвинения с преступника будут сняты. А вы же не станете убивать невинного гуманоида, правда <Player>?",
                    "DMsg.Num": "47",
                    "_orig_dtext": "DText(Format(CT(\"Script.Mod_ExpPilotBridge.1247\"),\"<0>\",ETimeLeft-CurTurn()+1))"
                },
                {
                    "Name": "",
                    "Pos.x": 0,
                    "Pos.y": 1220,
                    "Type": "TDialogMsg",
                    "Parent": -1,
                    "#": 376,
                    "Msg": "А, это ты! Терпеть вас не могу - космические хреньджеры! Только сунься - я те мигом все закрылки пообломаю!",
                    "DMsg.Num": "48",
                    "_orig_dtext": "DText(CT(\"Script.Mod_ExpPilotBridge.1387\"))"
                },
                {
                    "Name": "",
                    "Pos.x": 150,
                    "Pos.y": 1220,
                    "Type": "TDialogMsg",
                    "Parent": -1,
                    "#": 377,
                    "Msg": "А, смотрю тебя уже выпустили! Ну, как отдохнулось? Мне почему-то думается, что неважно.\r\nНу ты не переживай так, сейчас я тебе организую бесплатную путёвку на тот свет! Бассейны там, говорят, просто за-ши-бенные!!!",
                    "DMsg.Num": "49",
                    "_orig_dtext": "DText(CT(\"Script.Mod_ExpPilotBridge.1396\"))"
                },
                {
                    "Name": "",
                    "Pos.x": 300,
                    "Pos.y": 1220,
                    "Type": "TDialogMsg",
                    "Parent": -1,
                    "#": 378,
                    "Msg": "<Player>, позвольте принести вам свои глубочайшие извинения! Буквально вчера нам пришёл новый отчёт по вашему делу, где говорилось, что убийство совершили не вы, а некто <0>, занимавшийся перегоном вашего корпуса незадолго до того, как в нём было обнаружено тело.\r\nПо счастью, правосудие уже настигло преступника в лице <1>, что только лишний раз доказывает вездесущность окружающей нас кармы.\r\nА вот вы, <Player>, верите ли в карму? Как это настигает только в следующей жизни? Ну раз так, то и компенсацию за ложное осуждение мы вам не выплатим - приходите, как переродитесь в бабочку, ну или хотя бы в цветочек.\r\nВ общем, денег нет, но мы вам желаем хорошего настроения и здоровья. Держитесь там - на вас вся Галактика!",
                    "DMsg.Num": "50",
                    "_orig_dtext": "DText(Format(CT(\"Script.Mod_ExpPilotBridge.1399\"),\"<0>\",temp_str_3,\"<1>\",temp_str_4))"
                },
                {
                    "Name": "",
                    "Pos.x": 450,
                    "Pos.y": 1220,
                    "Type": "TDialogMsg",
                    "Parent": -1,
                    "#": 379,
                    "Msg": "Что, решил таки образумиться? Заплатить никогда не поздно, <Player>. Просто переведи деньги и живи себе спокойно.",
                    "DMsg.Num": "51",
                    "_orig_dtext": "DText(CT(\"Script.Mod_ExpPilotBridge.1371\"))"
                },
                {
                    "Name": "",
                    "Pos.x": 600,
                    "Pos.y": 1220,
                    "Type": "TDialogMsg",
                    "Parent": -1,
                    "#": 380,
                    "Msg": "<0>",
                    "DMsg.Num": "52",
                    "_orig_dtext": "DText(Format(CT(\"Script.Mod_ExpPilotBridge.1543\"),\"<0>\",temp_str))"
                },
                {
                    "Name": "",
                    "Pos.x": 750,
                    "Pos.y": 1220,
                    "Type": "TDialogMsg",
                    "Parent": -1,
                    "#": 381,
                    "Msg": "<0>",
                    "DMsg.Num": "53",
                    "_orig_dtext": "DText(Format(CT(\"Script.Mod_ExpPilotBridge.1543\"),\"<0>\",temp_str))"
                },
                {
                    "Name": "",
                    "Pos.x": 900,
                    "Pos.y": 1220,
                    "Type": "TDialogMsg",
                    "Parent": -1,
                    "#": 382,
                    "Msg": "<0>",
                    "DMsg.Num": "54",
                    "_orig_dtext": "DText(Format(CT(\"Script.Mod_ExpPilotBridge.1543\"),\"<0>\",temp_str_2))"
                },
                {
                    "Name": "",
                    "Pos.x": 1050,
                    "Pos.y": 1220,
                    "Type": "TDialogMsg",
                    "Parent": -1,
                    "#": 383,
                    "Msg": "А вот это ты зря! Ой зря-я!\r\nОрудия к бою парни! Сейчас будем трясти фраерка.",
                    "DMsg.Num": "55",
                    "_orig_dtext": "DText(CT(\"Script.Mod_ExpPilotBridge.1361\"))"
                },
                {
                    "Name": "",
                    "Pos.x": 1200,
                    "Pos.y": 1220,
                    "Type": "TDialogMsg",
                    "Parent": -1,
                    "#": 384,
                    "Msg": "<0>",
                    "DMsg.Num": "56",
                    "_orig_dtext": "DText(Format(CT(\"Script.Mod_ExpPilotBridge.1543\"),\"<0>\",temp_str))"
                },
                {
                    "Name": "",
                    "Pos.x": 1350,
                    "Pos.y": 1220,
                    "Type": "TDialogMsg",
                    "Parent": -1,
                    "#": 385,
                    "Msg": "<0>",
                    "DMsg.Num": "57",
                    "_orig_dtext": "DText(Format(CT(\"Script.Mod_ExpPilotBridge.1543\"),\"<0>\",temp_str_3))"
                },
                {
                    "Name": "",
                    "Pos.x": 1500,
                    "Pos.y": 1220,
                    "Type": "TDialogMsg",
                    "Parent": -1,
                    "#": 386,
                    "Msg": "Отсрочку? Ну конечно дадим! Три... два... один... Всё - истекла твоя отсрочка.\r\nНо не переживай, в качестве весомого стимула к скорейшей выплате долга я готов предложить тебе парочку хороших залпов из своих орудий - лови!!!",
                    "DMsg.Num": "58",
                    "_orig_dtext": "DText(CT(\"Script.Mod_ExpPilotBridge.1320\"))"
                },
                {
                    "Name": "",
                    "Pos.x": 1650,
                    "Pos.y": 1220,
                    "Type": "TDialogMsg",
                    "Parent": -1,
                    "#": 387,
                    "Msg": "Извините, <Player>, но торг в данном вопросе нам представляется совершенно неуместным. Речь, в конце концов, идёт о вашей репутации, так что уж, будьте любезны - проявите серьёзность.\r\nНу так что, берётесь за устранение пирата <0> или нет?",
                    "DMsg.Num": "59",
                    "_orig_dtext": "DText(Format(CT(\"Script.Mod_ExpPilotBridge.1384\"),\"<0>\",ShipName(IdToShip(ETargetShip))))"
                },
                {
                    "Name": "",
                    "Pos.x": 0,
                    "Pos.y": 1245,
                    "Type": "TDialogMsg",
                    "Parent": -1,
                    "#": 388,
                    "Msg": "В таком случае и вам желаем той же дороги, <Player>. Всего хорошего.",
                    "DMsg.Num": "60",
                    "_orig_dtext": "DText(CT(\"Script.Mod_ExpPilotBridge.1373\"))"
                },
                {
                    "Name": "",
                    "Pos.x": 150,
                    "Pos.y": 1245,
                    "Type": "TDialogMsg",
                    "Parent": -1,
                    "#": 389,
                    "Msg": "Не стоит браться за несколько дел одновременно. Как только вы выполните условия предыдущего контракта, поговорим о продолжении сотрудничества.",
                    "DMsg.Num": "61",
                    "_orig_dtext": "DText(CT(\"Script.Mod_ExpPilotBridge.1392\"))"
                },
                {
                    "Name": "",
                    "Pos.x": 300,
                    "Pos.y": 1245,
                    "Type": "TDialogMsg",
                    "Parent": -1,
                    "#": 390,
                    "Msg": "<0>",
                    "DMsg.Num": "62",
                    "_orig_dtext": "DText(Format(CT(\"Script.Mod_ExpPilotBridge.1543\"),\"<0>\",temp_str))"
                },
                {
                    "Name": "",
                    "Pos.x": 450,
                    "Pos.y": 1245,
                    "Type": "TDialogMsg",
                    "Parent": -1,
                    "#": 391,
                    "Msg": "",
                    "DMsg.Num": "63",
                    "_orig_dtext": "DText(CT(\"Script.Mod_ExpPilotBridge.802\"))"
                },
                {
                    "Name": "",
                    "Pos.x": 600,
                    "Pos.y": 1245,
                    "Type": "TDialogMsg",
                    "Parent": -1,
                    "#": 392,
                    "Msg": "",
                    "DMsg.Num": "64",
                    "_orig_dtext": "DText(CT(\"Script.Mod_ExpPilotBridge.802\"))"
                },
                {
                    "Name": "",
                    "Pos.x": 750,
                    "Pos.y": 1245,
                    "Type": "TDialogMsg",
                    "Parent": -1,
                    "#": 393,
                    "Msg": "Мы - малокские инженеры, настоящие профессионалы касательно всего, что связано с техникой. Раньше мы работали в сети технологических центров, оказывая технические услуги любой сложности, начиная от обычного апгрейда старого оборудования, и заканчивая сложнейшими операциями по улучшению брони корпусов. Уверены, что даже если вы ни разу не пользовались нашими услугами, то точно слышали о существовании данной организации. К сожалению, война сильно ударила по сети технологических центров. Теперь их вовсе не осталось в Галактике, а ведь мы могли бы заниматься первоклассным обслуживанием любых военных и гражданских кораблей, а также оборудования, вооружения, и даже зондов. Галактический Совет не выделяет нам достаточно денег на открытие своей станции в системе <0>, а оборудование стоит слишком дорого, мы просто не сможем оплатить все из своего кармана. Поэтому нам остается только надеяться на помощь со стороны. Если наша кампания по сбору средств увенчается успехом, мы сможем принимать клиентов не только со всего сектора <1>, но и из соседних. Планируемая дата открытия: <2>.\r\nСобранные средства: <3>/<4> cr.",
                    "DMsg.Num": "65",
                    "_orig_dtext": "DText(Format(CT(\"Script.Mod_ExpPilotBridge.1560\"),\"<0>\",StarName(GalaxyStar(bld_system_Id_TC-1)),\"<1>\",Name(StarToCon(GalaxyStar(bld_system_Id_TC-1))),\"<2>\",GameDateTxtByTurn(bld_day_TC+1),\"<3>\",credits_now_TC,\"<4>\",bld_cost_TC))"
                }
            ],
