                {
                    "Name": "",
                    "Code.Type": "Turn",
                    "Code": [
                        "if(StarBattle(ShipStar(GetTalkShip()))==0) {",
                        "  if(ShipTypeN(GetTalkShip())==1) {",
                        "    ShipCustomShipInfoData(GetTalkShip(),temp_int,1,1);",
                        "    if(ChanceToWin(Player(),GetTalkShip())>(100-ShipCustomShipInfoData(GetTalkShip(),temp_int,2)))",
                        "    {",
                        "    \ttemp_int_5=RelationToRanger(GetTalkShip(),Player());",
                        "    \tTruceBetweenShips(GetTalkShip(),Player());",
                        "    \t//Меняем отношение вора к игроку на \"плохое\", если до того оно было враждебным",
                        "    \tif(RelationToRanger(GetTalkShip(),Player())<10)RelationToRanger(GetTalkShip(),Player(),10+Rnd(0,7));",
                        "    \telse RelationToRanger(GetTalkShip(),Player(),temp_int_5);",
                        "    \tAutoBattle(0);",
                        "    \tOrderFollowShip(Player(),GetTalkShip(),0);",
                        "    \tOrderLanding(GetTalkShip(),NearCivilPlanet(GetTalkShip()));",
                        "    \tOrderLock(GetTalkShip(),1);",
                        "    \tShipCustomShipInfoTextData(GetTalkShip(),temp_int,1,'going_down');",
                        "    \ttemp_int_6=Rnd(1,3);",
                        "    \tif(temp_int_6==1)temp_str_2=CT(\"Script.Mod_ExpPilotBridge.1407\");",
                        "    \tif(temp_int_6==2)temp_str_2=CT(\"Script.Mod_ExpPilotBridge.1406\");",
                        "    \tif(temp_int_6==3)temp_str_2=CT(\"Script.Mod_ExpPilotBridge.1216\");",
                        "    \ttemp_str=CT('Script.Mod_ExpPilotBridge.IDidntHitHer_'+Rnd(1,2));",
                        "    }",
                        "    else",
                        "    {",
                        "    \tif(ShipCustomShipInfoData(GetTalkShip(),temp_int,3)>0)temp_int_6=ShipCustomShipInfoData(GetTalkShip(),temp_int,3);",
                        "    \telse temp_int_6=Rnd(1,2);",
                        "    \ttemp_str=CT('Script.Mod_ExpPilotBridge.Anyway_HowsYourSexLife_'+temp_int_6);",
                        "    \tShipCustomShipInfoData(GetTalkShip(),temp_int,3,temp_int_6);",
                        "    \ttemp_int_6=Rnd(1,3);",
                        "    \tif(temp_int_6==1)temp_str_2=Format(CT(\"Script.Mod_ExpPilotBridge.1228\"),\"<0>\",Name(GetTalkShip()));",
                        "    \tif(temp_int_6==2)temp_str_2=Format(CT(\"Script.Mod_ExpPilotBridge.1404\"),\"<0>\",Name(GetTalkShip()));",
                        "    \tif(temp_int_6==3)temp_str_2=Format(CT(\"Script.Mod_ExpPilotBridge.1226\"),\"<0>\",Name(GetTalkShip()));",
                        "    \tShipCustomShipInfoTextData(GetTalkShip(),temp_int,1,'i_will_fear_no_evil');",
                        "    \tRelationToRanger(GetTalkShip(),Player(),RelationToRanger(GetTalkShip(),Player())-10);",
                        "    }",
                        "    DChange(40);",
                        "    exit;",
                        "  }",
                        "  if(ShipTypeN(GetTalkShip())==2) {",
                        "    ShipCustomShipInfoData(GetTalkShip(),temp_int,1,1);",
                        "    if(ChanceToWin(Player(),GetTalkShip())>(100-ShipCustomShipInfoData(GetTalkShip(),temp_int,2)))",
                        "    {",
                        "    \ttemp_int_5=RelationToRanger(GetTalkShip(),Player());",
                        "    \tTruceBetweenShips(GetTalkShip(),Player());",
                        "    \t//Меняем отношение вора к игроку на \"плохое\", если до того оно было враждебным",
                        "    \tif(RelationToRanger(GetTalkShip(),Player())<10)RelationToRanger(GetTalkShip(),Player(),10+Rnd(0,7));",
                        "    \telse RelationToRanger(GetTalkShip(),Player(),temp_int_5);",
                        "    \tAutoBattle(0);",
                        "    \tOrderFollowShip(Player(),GetTalkShip(),0);",
                        "    \tOrderLanding(GetTalkShip(),NearCivilPlanet(GetTalkShip()));",
