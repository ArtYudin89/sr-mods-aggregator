                {
                    "Name": "",
                    "Code.Type": "Turn",
                    "Code": [
                        "//Непосредственно в Id эти переменные превращаются уже в самом конце оформления (так удобнее)",
                        "HullDelFromId=temp_array[temp_int_3];",
                        "HullFromType=ObjectType(HullDelFromId);",
                        "HullFromStarId=temp_array_3[temp_int_3];",
                        "HullDelEndId=GAnswerData;",
                        "HullEndType=ObjectType(HullDelEndId);",
                        "if(HullEndType==3)HullEndStarId=Id(PlanetToStar(HullDelEndId))-1;",
                        "if(HullEndType==4)HullEndStarId=Id(ShipStar(HullDelEndId))-1;",
                        "HullDelTime=0;",
                        "ArrayClear(transfer_list_can);",
                        "//Расчёт дистанции до системы назначения и времени в пути",
                        "if(HullEndType==3)",
                        "{",
                        "\tfull_distance=Dist2Star(GalaxyStar(HullFromStarId),GalaxyStar(HullEndStarId));",
                        "\tHullDelFromStr=CT(\"Script.Mod_ExpPilotBridge.777\")+PlanetName(GAnswerData);",
                        "}",
                        "if(HullEndType==4)",
                        "{",
                        "\tfull_distance=Dist2Star(GalaxyStar(HullFromStarId),GalaxyStar(HullEndStarId));",
                        "\tHullDelFromStr=Name(GAnswerData);",
                        "}",
                        "temp_int_1=round(sqrt(full_distance));",
                        "//Определяем среднее (при выборе спецов) время доставки",
                        "if(!temp_int_1)HullDelTime=7;",
                        "else if(temp_int_1 && temp_int_1<=9)HullDelTime=10;",
                        "else",
                        "{",
                        "\tif(GalaxyTechLevel()==1)HullDelTime=temp_int_1+(temp_int_1-1*(temp_int_1/20));",
                        "\telse if(GalaxyTechLevel()==2)HullDelTime=temp_int_1+(temp_int_1-2*(temp_int_1/20));",
                        "\telse if(GalaxyTechLevel()==3)HullDelTime=temp_int_1+(temp_int_1-3*(temp_int_1/20));",
                        "\telse if(GalaxyTechLevel()==4)HullDelTime=temp_int_1+(temp_int_1-4*(temp_int_1/20));",
                        "\telse if(GalaxyTechLevel()==5)HullDelTime=temp_int_1+(temp_int_1-5*(temp_int_1/20));",
                        "\telse if(GalaxyTechLevel()==6)HullDelTime=temp_int_1+(temp_int_1-6*(temp_int_1/20));",
                        "\telse if(GalaxyTechLevel()==7)HullDelTime=temp_int_1+(temp_int_1-7*(temp_int_1/20));",
                        "\telse if(GalaxyTechLevel()==8)HullDelTime=temp_int_1+(temp_int_1-8*(temp_int_1/20));",
                        "}",
                        "//Подсчёт размера корпуса, а также составление массива корпусов на складе пункта отправки",
                        "transfer_cargo_cost=0;",
                        "transfer_cargo_size=0;",
                        "for(i=0;i<StorageItems();i=i+1)",
                        "{",
                        "\tif(ItemType(StorageItems(i))!=t_Hull)continue;",
                        "\tif(StorageItemLocation(i)==HullDelFromId)",
                        "\t{",
                        "\t\ttransfer_cargo_size=transfer_cargo_size+ItemSize(StorageItems(i));",
                        "\t\tArrayAdd(transfer_list_can,StorageItems(i));",
                        "\t}",
                        "}",
                        "//Переменные для подстановки в диалог",
                        "if(HullFromType==3)point_from=CT(\"Script.Mod_ExpPilotBridge.1105\")+' ';",
                        "if(HullFromType==4)point_from='';",
                        "//Составляем строку со списком корпусов, доступных для перегона",
                        "temp_str='</color>';",
                        "if(ArrayDim(transfer_list_can)>2)",
                        "{",
                        "\tfor(i=1;i<ArrayDim(transfer_list_can);i=i+1)",
                        "\t{",
                        "\t\ttemp_str=temp_str+i+'. '+'<color=0,50,200>'+DeleteTags(Name(transfer_list_can[i]))+'</color>'+' (<color=0,50,200>'+ItemSize(transfer_list_can[i])+CT(\"Script.Mod_ExpPilotBridge.1094\")+CT(\"Script.Mod_ExpPilotBridge.67\");",
                        "\t}",
                        "}",
                        "if(ArrayDim(transfer_list_can)==2)temp_str='</color>'+Format(CT(\"Script.Mod_ExpPilotBridge.1104\"),\"<0>\",DeleteTags(Name(transfer_list_can[1])),\"<1>\",ItemSize(transfer_list_can[1]));",
                        "if(GetGameOptions('FontDialog')==0)DefSplt='</color>-------------------------------------------------------------';",
                        "if(GetGameOptions('FontDialog')==1)DefSplt='</color>------------------------------------------';",
                        "if(GetGameOptions('FontDialog')==2)DefSplt='</color>-----------------------------------------';",
                        "if(GetGameOptions('FontDialog')==3)DefSplt='</color>-------------------------------------';",
                        "if(ArrayDim(transfer_list_can)==2) {",
                        "  DChange(30);",
                        "  exit;",
                        "}",
                        "if(ArrayDim(transfer_list_can)>2) {",
                        "  DChange(29);",
                        "  exit;",
                        "}"
                    ],
