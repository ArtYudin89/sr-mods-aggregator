                        "    \t\telse if(temp_int_4==2)TransHullCost=round((0.00315*temp_int_1)*(70*temp_int_3));",
                        "    \t\telse if(temp_int_4==3)TransHullCost=round((0.00315*temp_int_1)*(80*temp_int_3));",
