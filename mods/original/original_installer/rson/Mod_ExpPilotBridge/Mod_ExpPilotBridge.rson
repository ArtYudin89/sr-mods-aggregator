                        "else if(HullDelTime == 9) temp_int_5 = 7;",
                        "else temp_int_5 = (-0.25 * HullDelTime) + HullDelTime;",
                        "",
                        "//Если пункт доставки находится в другой системе",
                        "if(temp_int_1)",
                        "{",
                        "    dist_to = Format(CT(\"Script.Mod_ExpPilotBridge.805\"),\"<0>\",temp_int_1);",
                        "    //Определяем стоимость",
                        "\tif(GTL <= 1) transfer_cargo_cost = round((0.00315 * transfer_cargo_size) * ((GalaxyMoney(0, 0) / 5) * temp_int_1));",
                        "\telse if(GTL == 2) transfer_cargo_cost = round((0.00315 * transfer_cargo_size) * ((GalaxyMoney(0, 0) / 5) * temp_int_1));",
                        "\telse if(GTL == 3) transfer_cargo_cost = round((0.00315 * transfer_cargo_size) * ((GalaxyMoney(0, 0) / 5) * temp_int_1));",
                        "\telse if(GTL == 4) transfer_cargo_cost = round((0.00315 * transfer_cargo_size) * ((GalaxyMoney(0, 0) / 5) * temp_int_1));",
                        "\telse if(GTL == 5) transfer_cargo_cost = round((0.00315 * transfer_cargo_size) * ((GalaxyMoney(0, 0) / 5) * temp_int_1));",
                        "\telse if(GTL == 6) transfer_cargo_cost = round((0.00315 * transfer_cargo_size) * ((GalaxyMoney(0, 0) / 5) * temp_int_1));",
                        "\telse if(GTL == 7) transfer_cargo_cost = round((0.00315 * transfer_cargo_size) * ((GalaxyMoney(0, 0) / 5) * temp_int_1));",
                        "\telse if(GTL >= 8) transfer_cargo_cost = round((0.00315 * transfer_cargo_size) * ((GalaxyMoney(0, 0) / 5) * temp_int_1));",
                        "}",
