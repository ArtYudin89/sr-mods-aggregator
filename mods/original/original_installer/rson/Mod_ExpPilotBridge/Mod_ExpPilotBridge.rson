                        "        else if(temp_int_5==0 && HullEndType==4)NewsAdd(Format(CT(\"Script.Mod_ExpPilotBridge.1209\"),\"<0>\",temp_str,\"<1>\",temp_str_2,\"<2>\",ShipName(IdToShip(HullDelEndId)),\"<3>\",StarName(GalaxyStar(HullEndStarId))));",
                        "        //Корпус, прибывший на место, был украден",
                        "        else if(temp_int_5==1)",
                        "        {",
                        "    \t    NewsAdd(Format(CT(\"Script.Mod_ExpPilotBridge.1208\"),\"<0>\",TransHullCost));",
                        "    \t    ShipMoney(Player(),ShipMoney(Player())+TransHullCost);",
                        "    \t    Sound('Sound.Sell');",
                        "        }",
                        "    }",
                        "    else if(HullOnWay==2)",
                        "    {",
                        "        //Оба корпуса из двух доставлены успешно",
                        "        if(temp_int_5==0 && HullEndType==3)NewsAdd(Format(CT(\"Script.Mod_ExpPilotBridge.1207\"),\"<0>\",temp_str_2,\"<1>\",PlanetName(IdToPlanet(HullDelEndId)),\"<2>\",StarName(GalaxyStar(HullEndStarId)),\"<3>\",temp_str));",
                        "        else if(temp_int_5==0 && HullEndType==4)NewsAdd(Format(CT(\"Script.Mod_ExpPilotBridge.1207\"),\"<0>\",temp_str_2,\"<1>\",ShipName(IdToShip(HullDelEndId)),\"<2>\",StarName(GalaxyStar(HullEndStarId)),\"<3>\",temp_str));",
                        "        //Украден один корпус из двух прибывших на место",
                        "        else if(temp_int_5==1 && HullEndType==3)",
                        "        {",
                        "    \t    NewsAdd(Format(CT(\"Script.Mod_ExpPilotBridge.1206\"),\"<0>\",temp_str,\"<1>\",temp_str_2,\"<2>\",PlanetName(IdToPlanet(HullDelEndId)),\"<3>\",StarName(GalaxyStar(HullEndStarId)),\"<4>\",TransHullCost));",
                        "    \t    ShipMoney(Player(),ShipMoney(Player())+TransHullCost);",
                        "    \t    Sound('Sound.Sell');",
                        "        }",
                        "        else if(temp_int_5==1 && HullEndType==4)",
                        "        {",
                        "    \t    NewsAdd(Format(CT(\"Script.Mod_ExpPilotBridge.1206\"),\"<0>\",temp_str,\"<1>\",temp_str_2,\"<2>\",ShipName(IdToShip(HullDelEndId)),\"<3>\",StarName(GalaxyStar(HullEndStarId)),\"<4>\",TransHullCost));",
                        "    \t    ShipMoney(Player(),ShipMoney(Player())+TransHullCost);",
                        "    \t    Sound('Sound.Sell');",
                        "        }",
                        "        //Украдены оба корпуса из двух прибывших на место",
                        "        else if(temp_int_5==2)",
                        "        {",
                        "    \t    NewsAdd(Format(CT(\"Script.Mod_ExpPilotBridge.1202\"),\"<0>\",TransHullCost));",
                        "    \t    ShipMoney(Player(),ShipMoney(Player())+TransHullCost);",
                        "    \t    Sound('Sound.Sell');",
                        "        }",
                        "    }",
                        "    else if(HullOnWay==3)",
                        "    {",
                        "        //Все три корпуса доставлены успешно",
                        "        if(temp_int_5==0 && HullEndType==3)NewsAdd(Format(CT(\"Script.Mod_ExpPilotBridge.1205\"),\"<0>\",temp_str_2,\"<1>\",PlanetName(IdToPlanet(HullDelEndId)),\"<2>\",StarName(GalaxyStar(HullEndStarId)),\"<3>\",temp_str));",
                        "        else if(temp_int_5==0 && HullEndType==4)NewsAdd(Format(CT(\"Script.Mod_ExpPilotBridge.1205\"),\"<0>\",temp_str_2,\"<1>\",ShipName(IdToShip(HullDelEndId)),\"<2>\",StarName(GalaxyStar(HullEndStarId)),\"<3>\",temp_str));",
                        "        //Один из трёх прибывших корпусов был украден",
                        "        else if(temp_int_5==1 && HullEndType==3)",
                        "        {",
                        "    \t    NewsAdd(Format(CT(\"Script.Mod_ExpPilotBridge.1204\"),\"<0>\",temp_str_2,\"<1>\",PlanetName(IdToPlanet(HullDelEndId)),\"<2>\",StarName(GalaxyStar(HullEndStarId)),\"<3>\",TransHullCost,\"<4>\",temp_str));",
                        "    \t    ShipMoney(Player(),ShipMoney(Player())+TransHullCost);",
                        "    \t    Sound('Sound.Sell');",
                        "        }",
                        "        else if(temp_int_5==1 && HullEndType==4)",
                        "        {",
                        "    \t    NewsAdd(Format(CT(\"Script.Mod_ExpPilotBridge.1204\"),\"<0>\",temp_str_2,\"<1>\",ShipName(IdToShip(HullDelEndId)),\"<2>\",StarName(GalaxyStar(HullEndStarId)),\"<3>\",TransHullCost,\"<4>\",temp_str));",
                        "    \t    ShipMoney(Player(),ShipMoney(Player())+TransHullCost);",
                        "    \t    Sound('Sound.Sell');",
                        "        }",
                        "        //Два из трёх прибывших корпусов были украдены",
                        "        else if(temp_int_5==2 && HullEndType==3)",
                        "        {",
                        "    \t    NewsAdd(Format(CT(\"Script.Mod_ExpPilotBridge.1203\"),\"<0>\",temp_str,\"<1>\",temp_str_2,\"<2>\",PlanetName(IdToPlanet(HullDelEndId)),\"<3>\",StarName(GalaxyStar(HullEndStarId)),\"<4>\",TransHullCost));",
                        "    \t    ShipMoney(Player(),ShipMoney(Player())+TransHullCost);",
                        "    \t    Sound('Sound.Sell');",
                        "        }",
                        "        else if(temp_int_5==2 && HullEndType==4)",
                        "        {",
                        "    \t    NewsAdd(Format(CT(\"Script.Mod_ExpPilotBridge.1203\"),\"<0>\",temp_str,\"<1>\",temp_str_2,\"<2>\",ShipName(IdToShip(HullDelEndId)),\"<3>\",StarName(GalaxyStar(HullEndStarId)),\"<4>\",TransHullCost));",
                        "    \t    ShipMoney(Player(),ShipMoney(Player())+TransHullCost);",
                        "    \t    Sound('Sound.Sell');",
                        "        }",
                        "        //Все три прибывших корпуса были украдены - бать, вы лох",
                        "        else if(temp_int_5==3)",
                        "        {",
                        "    \t    NewsAdd(Format(CT(\"Script.Mod_ExpPilotBridge.1202\"),\"<0>\",TransHullCost));",
                        "    \t    ShipMoney(Player(),ShipMoney(Player())+TransHullCost);",
                        "    \t    Sound('Sound.Sell');",
                        "        }",
                        "    }",
                        "    //Запускаем обработчик спавна воров для украденных корпусов",
                        "    if(temp_int_5)HullWasStolenThiefCreate(1);",
                        "    //Переносим успешно доставленные корпуса на планету/станцию, формируем строку с их названиями",
                        "    for(i=1;i<=temp_int_6;i=i+1)",
                        "    {",
                        "    \ttemp_dword=GetItemFromVault('HullDelServ_'+i);",
                        "    \tif(HullEndType==3)AddItemToStorage(IdToPlanet(HullDelEndId),temp_dword);",
                        "    \tif(HullEndType==4)AddItemToStorage(IdToShip(HullDelEndId),temp_dword);",
                        "    \t//Запоминаем событие, которое случится с доставленным корпусом при надевании его игроком (также запоминаем его местонахождение)",
                        "    \ttemp_str_4=''+Id(temp_dword)+','+HullDelEndId+'*'+HullEndType+'&'+GAddTArray[i];",
                        "    \tArrayAdd(GHullsWaitArray,temp_str_4);",
                        "    }",
                        "    ArrayClear(GAddTArray);",
                        "    temp_dword_4=0;",
                        "    HullOnWay=0;",
                        "    HullDelTime=0;",
                        "    HullDelTimeStart=0;",
                        "    HullDelTimeExp=0;",
                        "    HullDelFromId=0;",
                        "    HullFromStarId=0;",
                        "    HullDelFromStr='';",
                        "    HullDelEndId=0;",
                        "    HullEndStarId=0;",
                        "    TransHullCost=0;",
                        "    HullWasStolen=0;",
                        "    HullFromStExist=0;",
                        "    HullEndStExist=0;",
                        "    StartHullDelTechLvl=0;",
                        "    temp_str='';",
                        "    temp_str_2='';",
                        "    temp_str_3='';",
                        "    temp_str_4='';",
                        "  }",
                        "}",
                        "//Обработчик победы/провала скриптового квеста тюрьмы",
                        "if(GQuestStatus == 2)",
                        "{",
                        "    if(RelationToRanger(GetShipPlanet(Player()), Player()) < 40) RelationToRanger(GetShipPlanet(Player()), Player(), 40);",
                        "    GKillQuestCheck = 2;",
                        "    GotoGov(2);",
                        "    exit;",
                        "}",
                        "else if(GQuestStatus == 3)",
                        "{",
                        "    GKillQuestCheck = -1;",
                        "    temp_dword_4 = GetShipPlanet(Player());",
                        "    ExtremalTakeOff();",
                        "    exit;",
                        "}",
                        "if(lastTurn != CurTurn()) {",
                        "  //Запоминаем ход срабатывания терна, чтобы избежать лишних срабатываний за ход (которые случаются)",
                        "  //Нельзя делать это в предыдущем Op, т.к. тогда не будет работать автосрабатывание терна после завершения скриптового квеста",
                        "  lastTurn = CurTurn();",
                        "  ",
                        "  //Для удобства сразу запоминаем текущий ГТУ в отдельную переменную",
                        "  GTL = GalaxyTechLevel();",
                        "  ",
                        "  //Проверка на появление игрока в системе с Уитли (срабатывает один раз за игровую партию)",
                        "  if(GScriptWheatley == -1)",
                        "  {",
                        "  \tif(ShipStar(Player()) == GalaxyStar(ScriptItemData(Script_Wheatley, 3))) GScriptWheatley = 1;",
                        "  }",
                        "  ",
                        "  //Смена отношения на враждебное с планетой, с которой игрок совершил побег",
                        "  if(GKillQuestCheck == -1)",
                        "  {",
                        "  \tRelationToRanger(temp_dword_4, Player(), 0);",
                        "  \tGKillQuestCheck = 0;",
                        "  }",
                        "  ",
                        "  //Таймер и провал квеста на убийство подставившего игрока пирата",
                        "  if(GKillQuestCheck==3)",
                        "  {",
                        "  \tif(ETimeLeft>CurTurn())",
                        "  \t{",
                        "  \t\tCustomEther('QuestNormal',3,'CustomQuestKillBridge',CT(\"Script.Mod_ExpPilotBridge.1273\")+CT('FormInfo.br')+CT(\"Script.Mod_ExpPilotBridge.1272\")+(ETimeLeft-CurTurn())+CT(\"Script.Mod_ExpPilotBridge.1271\")+CT('FormInfo.br')+CT(\"Script.Mod_ExpPilotBridge.1260\")+PlanetName(IdToPlanet(EQuestPlanet))+CT(\"Script.Mod_ExpPilotBridge.1259\")+StarName(PlanetToStar(IdToPlanet(EQuestPlanet)))+'</color>)'+CT('FormInfo.br')+' '+CT('FormInfo.br')+GEQuestText);",
                        "  \t}",
                        "  \tif(ETimeLeft<=CurTurn())",
                        "  \t{",
                        "  \t\tCustomEther('QuestCancel',5,'CustomQuestKillBridge',CT(\"Script.Mod_ExpPilotBridge.1394\")+CT('FormInfo.br')+CT(\"Script.Mod_ExpPilotBridge.1260\")+PlanetName(IdToPlanet(EQuestPlanet))+CT(\"Script.Mod_ExpPilotBridge.1259\")+StarName(PlanetToStar(IdToPlanet(EQuestPlanet)))+'</color>)'+CT('FormInfo.br')+' '+CT('FormInfo.br')+GEQuestText);",
                        "  \t\tNewsAdd(CT(\"Script.Mod_ExpPilotBridge.1280\")+PlanetName(IdToPlanet(EQuestPlanet))+'</color>.'+CT('FormInfo.br')+CT(\"Script.Mod_ExpPilotBridge.1279\"));",
                        "  \t\tif(RelationToRanger(IdToPlanet(EQuestPlanet),Player())>10)RelationToRanger(IdToPlanet(EQuestPlanet),Player(),10);",
                        "  \t\tNoTalkToShip(IdToShip(ETargetShip),0);",
                        "  \t\tGCustomQuestsFailed=GCustomQuestsFailed+1;",
                        "  \t\tShipDeleteCustomShipInfo(IdToShip(ETargetShip),'PlayerBridge_IllWisherInfo');",
                        "  \t\tGEQuestText='';",
                        "  \t\tETargetShip=0;",
                        "  \t\tEQuestPlanet=0;",
                        "  \t\tEQuestReward=0;",
                        "  \t\tEQuestExpReward=0;",
                        "  \t\tETimeLeft=0;",
                        "  \t\tGKillQuestCheck=0;",
                        "  \t}",
                        "  }",
                        "  //Полное снятие преследования, если все корабли преследователей перебиты или выведены из группы",
                        "  if(GCardPursueCheck>0)",
                        "  {",
                        "  \tif(!GroupCount(DebtMG))",
                        "  \t{",
                        "  \t\tGShipJoinGlobal=0;",
                        "  \t\tCardDebt=0;",
                        "  \t\tGCardPursueCheck=0;",
                        "  \t}",
                        "  \telse",
                        "  \t{",
                        "  \t\tfor(i = 0; i < GroupCount(DebtMG); i = i + 1)",
                        "  \t\t{",
                        "  \t\t\ttemp_dword_4=GroupShip(DebtMG,i);",
                        "  \t\t\t//Заправляем и чиним пиратов, которые оказались на планете к концу хода",
                        "  \t\t\tif(GetShipPlanet(temp_dword_4) || GetShipRuins(temp_dword_4))",
                        "  \t\t\t{",
                        "  \t\t\t\tShipRepairEq(temp_dword_4);",
                        "  \t\t\t\tShipRefuel(temp_dword_4);",
                        "  \t\t\t}",
                        "  \t\t}",
                        "  \t}",
                        "  }",
                        "  //Узнаём, что станции назначения и/или отправки груза покинули свою текущую систему",
                        "  if(transfer_day>=CurTurn())",
                        "  {",
                        "  \tif(LTargetType==2 || LTargetType==4)",
                        "  \t{",
                        "  \t\tif(LStationDExist!=1)",
                        "  \t\t{",
                        "  \t\t\tif(ShipInHyperSpace(IdToShip(point_3)))",
                        "  \t\t\t{",
                        "  \t\t\t\t//Станция назначения доставки груза покинула систему",
                        "  \t\t\t\tLStationDExist=2;",
                        "  \t\t\t\tpoint_3_name=ShipName(IdToShip(point_3));",
                        "  \t\t\t}",
                        "  \t\t}",
                        "  \t\tif(LStationSExist!=1)",
                        "  \t\t{",
                        "  \t\t\tif(ShipInHyperSpace(IdToShip(point_1_id)))",
                        "  \t\t\t{",
                        "  \t\t\t\t//Станция отправки груза покинула систему",
                        "  \t\t\t\tLStationSExist=2;",
                        "  \t\t\t\tpoint_1_name=ShipName(IdToShip(point_1_id));",
                        "  \t\t\t}",
                        "  \t\t}",
                        "  \t}",
                        "  }",
                        "  //Узнаём, что станции назначения и/или отправки корпуса покинули свою текущую систему",
                        "  if(HullDelTime>=CurTurn())",
                        "  {",
                        "  \tif(HullFromType==4 || HullEndType==4)",
                        "  \t{",
                        "  \t\tif(HullEndStExist!=1)",
                        "  \t\t{",
                        "  \t\t\tif(ShipInHyperSpace(IdToShip(HullDelEndId)))",
                        "  \t\t\t{",
                        "  \t\t\t\t//Станция назначения доставки корпуса покинула систему",
                        "  \t\t\t\tHullEndStExist=2;",
                        "  \t\t\t\tHullEndName=ShipName(IdToShip(HullDelEndId));",
                        "  \t\t\t}",
                        "  \t\t}",
                        "  \t\tif(HullFromStExist!=1)",
                        "  \t\t{",
                        "  \t\t\tif(ShipInHyperSpace(IdToShip(HullDelFromId)))",
                        "  \t\t\t{",
                        "  \t\t\t\t//Станция отправки корпуса покинула систему",
                        "  \t\t\t\tHullFromStExist=2;",
                        "  \t\t\t\tHullFromName=ShipName(IdToShip(HullDelFromId));",
                        "  \t\t\t}",
                        "  \t\t}",
                        "  \t}",
                        "  }",
                        "  //Перебираем все галактические эвенты, совершаем необходимые действия",
                        "  for(j = GalaxyEvents() - 1; j >= 0; j = j - 1)",
                        "  {",
                        "  \tif(GalaxyEventDate(j)<CurTurn())break;",
                        "      temp_str_4=GalaxyEventType(j);",
                        "  \tif(temp_str_4=='RuinsDestroyed')",
                        "  \t{",
                        "  \t\t//Узнаём, что станции назначения и/или отправки груза были уничтожены",
                        "  \t\tif(transfer_day>=CurTurn())",
                        "  \t\t{",
                        "  \t\t\tif(LTargetType==2 || LTargetType==4)",
                        "  \t\t\t{",
                        "  \t\t\t\tif(GalaxyEventData(j,1)==point_3)",
                        "  \t\t\t\t{",
                        "  \t\t\t\t\t//Была уничтожена станция назначения доставки груза",
                        "  \t\t\t\t\tLStationDExist=1;//Не смотрите на 1 - это значит как раз то, что станция уничтожена",
                        "  \t\t\t\t\tpoint_3_name=GalaxyEventsTextData(j,0);",
                        "  \t\t\t\t}",
                        "  \t\t\t\tif(GalaxyEventData(j,1)==point_1_id)",
                        "  \t\t\t\t{",
                        "  \t\t\t\t\t//Была уничтожена станция отправки груза",
                        "  \t\t\t\t\tLStationSExist=1;",
                        "  \t\t\t\t\tpoint_1_name=GalaxyEventsTextData(j,0);",
                        "  \t\t\t\t}",
                        "  \t\t\t}",
                        "  \t\t}",
                        "  \t\t//Узнаём, что станции назначения и/или отправки корпуса были уничтожены",
                        "  \t\tif(HullDelTime>=CurTurn())",
                        "  \t\t{",
                        "  \t\t\tif(HullFromType==4 || HullEndType==4)",
                        "  \t\t\t{",
                        "  \t\t\t\tif(GalaxyEventData(j,1)==HullDelEndId)",
                        "  \t\t\t\t{",
                        "  \t\t\t\t\t//Была уничтожена станция назначения доставки корпуса",
                        "  \t\t\t\t\tHullEndStExist=1;",
                        "  \t\t\t\t\tHullEndName=GalaxyEventsTextData(j,0);",
                        "  \t\t\t\t}",
                        "  \t\t\t\tif(GalaxyEventData(j,1)==HullDelFromId)",
                        "  \t\t\t\t{",
                        "  \t\t\t\t\t//Была уничтожена станция отправки корпуса",
                        "  \t\t\t\t\tHullFromStExist=1;",
                        "  \t\t\t\t\tHullFromName=GalaxyEventsTextData(j,0);",
                        "  \t\t\t\t}",
                        "  \t\t\t}",
                        "  \t\t}",
                        "  \t\t//Пересобираем массив с доставленными корпусами в случае уничтожения доставочной станции",
                        "  \t\tif(ArrayDim(GHullsWaitArray)>1)",
                        "  \t\t{",
                        "  \t\t\ttemp_dword_1=0;",
                        "  \t\t\t//Проверяем, была ли взорвана станция с корпусом",
                        "  \t\t\tfor(i=1;i<ArrayDim(GHullsWaitArray);i=i+1)",
                        "  \t\t\t{",
                        "  \t\t\t\ttemp_dword=substr(GHullsWaitArray[i],findsubstr(GHullsWaitArray[i],',')+1,(findsubstr(GHullsWaitArray[i],'*')-findsubstr(GHullsWaitArray[i],',')-1));",
                        "  \t\t\t\tif(GalaxyEventData(j,1)==temp_dword)",
                        "  \t\t\t\t{",
                        "  \t\t\t\t\tif(ArrayDim(GHullsWaitArray)==2)ArrayClear(GHullsWaitArray);",
                        "  \t\t\t\t\telse",
                        "  \t\t\t\t\t{",
                        "  \t\t\t\t\t\tGHullsWaitArray[i]=-1;",
                        "  \t\t\t\t\t\ttemp_dword_1=1;",
                        "  \t\t\t\t\t}",
                        "  \t\t\t\t}",
                        "  \t\t\t}",
                        "  \t\t\t//Пересобираем массив, исключаем пропавшие со склада корпуса",
                        "  \t\t\tif(temp_dword_1)",
                        "  \t\t\t{",
                        "  \t\t\t\tArrayClear(GAddTArray2);",
                        "  \t\t\t\tfor(i=1;i<ArrayDim(GHullsWaitArray);i=i+1)",
                        "  \t\t\t\t{",
                        "  \t\t\t\t\tif(GHullsWaitArray[i]!=-1)ArrayAdd(GAddTArray2,GHullsWaitArray[i]);",
                        "  \t\t\t\t}",
                        "  \t\t\t\tArrayClear(GHullsWaitArray);",
                        "  \t\t\t\tfor(i=1;i<ArrayDim(GAddTArray2);i=i+1)",
                        "  \t\t\t\t{",
                        "  \t\t\t\t\tArrayAdd(GHullsWaitArray,GAddTArray2[i]);",
                        "  \t\t\t\t}",
                        "  \t\t\t\tArrayClear(GAddTArray2);",
                        "  \t\t\t}",
                        "  \t\t}",
                        "  \t}",
                        "      //Счётчики уничтоженных кораблей",
                        "  \telse if(temp_str_4 == 'PlayerKillsShip')",
                        "      {",
                        "          UpdateKillShipsStatistic(GalaxyEventData(j, 0), GalaxyEventData(j, 5), GalaxyEventsTextData(j, 2), GalaxyEventsTextData(j, 0), GalaxyEventsTextData(j, 1), GalaxyEventData(j, 3), 0);",
                        "      }",
                        "      else if(temp_str_4 == 'PlayerTranclucatorKillsShip') GTrancKillStat = GTrancKillStat + 1;",
                        "      else if(temp_str_4 == 'PlayerCompanionKillsShip') GCompanionKillStat = GCompanionKillStat + 1;",
                        "      //Счётчики уничтоженных кораблей в гипере",
                        "  //    else if(temp_str_4 == 'LabeledShipKilledInAB')",
                        "  //    {",
                        "  //        tstr2 = GalaxyEventsTextData(j, 0);",
                        "  //        if(ParsCountFromString(tstr2, ',') >= 6)",
                        "  //        {",
                        "  //            if(~findsubstr(GetParFromString(tstr2, ',', 2, 0), '_Friend')) continue; //Пропускаем уничтоженные в гипере, но дружественные по отношению к игроку корабли",
                        "  //            UpdateKillShipsStatistic(GetParFromString(tstr2, ',', 0, 0), GetParFromString(tstr2, ',', 1, 0), GetParFromString(tstr2, ',', 2, 0), GetParFromString(tstr2, ',', 3, 0), GetParFromString(tstr2, ',', 4, 0), GetParFromString(tstr2, ',', 5, 0), 1);",
                        "  //            ShipStatistic(Player(), 7, ShipStatistic(Player(), 7) - 1);",
                        "  //        }",
                        "  //    }",
                        "  \t//Прочие события",
                        "  \telse if(temp_str_4=='PlayerBuysEquipment')money_equip=money_equip+GalaxyEventData(j,1);",
                        "  \telse if(temp_str_4=='PlayerFinishesPlanetaryBattle')",
                        "  \t{",
                        "  \t\tpb_money=pb_money+GalaxyEventData(j,1);",
                        "  \t\tpb_exp=pb_exp+GalaxyEventData(j,2);",
                        "  \t}",
                        "  \telse if(temp_str_4=='PlayerFinishesQuest')",
                        "  \t{",
                        "  \t\tmoney_quest=money_quest+GalaxyEventData(j,2);",
                        "  \t\texp_quest=exp_quest+GalaxyEventData(j,3);",
                        "  \t}",
                        "  \telse if(temp_str_4=='PlayerExtortsMoney')",
                        "  \t{",
                        "  \t\ttemp_int_1=GalaxyEventData(j,0);",
                        "  \t\tmoney_take=money_take+temp_int_1;",
                        "  \t}",
                        "  \telse if(temp_str_4=='PlayerAcceptsMoneyForTruce')",
                        "  \t{",
                        "  \t\ttemp_int_1=GalaxyEventData(j,0);",
                        "  \t\tmoney_take_peace=money_take_peace+temp_int_1;",
                        "  \t}",
                        "  \telse if(temp_str_4=='PlayerBuysGoodsFromPlanet')",
                        "  \t{",
                        "  \t\ttemp_int_1=GalaxyEventData(j,2);",
                        "  \t\tmoney_buys=money_buys+temp_int_1;",
                        "  \t}",
                        "  \telse if(temp_str_4=='PlayerSellsGoodsToPlanet')",
                        "  \t{",
                        "  \t\ttemp_int_1=GalaxyEventData(j,2);",
                        "  \t\tmoney_sale=money_sale+temp_int_1;",
                        "  \t}",
                        "  \telse if(temp_str_4=='PlayerLiberatesSystem')",
                        "  \t{",
                        "  \t\tif(GalaxyEventData(j,1)==0)sys_coal=sys_coal+1;",
                        "  \t\tif(GalaxyEventData(j,1)==2)sys_pirate=sys_pirate+1;",
                        "  \t}",
                        "  }",
                        "  ",
                        "  //Обработчики прерывания доставки груза",
                        "  if(transfer_day>CurTurn())",
                        "  {",
                        "  \t//Груз был в пути на планету отправки, но её захватили (груз перенаправлен в родную систему)",
                        "  \tif(LTargetType==3)",
                        "  \t{",
                        "  \t\tif(StarOwner(PlanetToStar(IdToPlanet(point_1_id)))==1 || StarCustomFaction(PlanetToStar(IdToPlanet(point_1_id)))!='')",
                        "  \t\t{",
                        "  \t\t\tNewsAdd(Format(CT(\"Script.Mod_ExpPilotBridge.1529\"),\"<0>\",PlanetName(IdToPlanet(point_1_id)),\"<1>\",StarName(PlanetToStar(IdToPlanet(point_1_id))),\"<2>\",StarName(PlanetToStar(GetShipHomePlanet(Player()))),\"<3>\",PlanetName(GetShipHomePlanet(Player()))));",
                        "  \t\t\tCargoLostChanceCalcHome();",
                        "  \t\t\tpoint_3=Id(GetShipHomePlanet(Player()));",
                        "  \t\t\tLTargetType=5;",
                        "  \t\t}",
                        "  \t}",
                        "  \t//Груз был в пути на станцию отправки, но она была уничтожена/улетела (груз перенаправлен в родную систему)",
                        "  \tif(LTargetType==4)",
                        "  \t{",
                        "  \t\tif(LStationSExist)",
                        "  \t\t{",
                        "  \t\t\t//Станция отправки была уничтожена",
                        "  \t\t\tif(LStationSExist==1)",
                        "  \t\t\t{",
                        "  \t\t\t\ttemp_str='</color>'+Format(CT(\"Script.Mod_ExpPilotBridge.1520\"),\"<0>\",StarName(GalaxyStar(point_1_star)));",
                        "  \t\t\t\ttemp_str_2='</color>'+CT(\"Script.Mod_ExpPilotBridge.1476\");",
                        "  \t\t\t}",
                        "  \t\t\t//Станция отправки покинула систему",
                        "  \t\t\telse",
                        "  \t\t\t{",
                        "  \t\t\t\ttemp_str='</color>'+Format(CT(\"Script.Mod_ExpPilotBridge.1518\"),\"<0>\",StarName(GalaxyStar(point_1_star)));",
                        "  \t\t\t\ttemp_str_2='</color>'+CT(\"Script.Mod_ExpPilotBridge.1517\");",
                        "  \t\t\t}",
                        "  \t\t\tNewsAdd(Format(CT(\"Script.Mod_ExpPilotBridge.1528\"),\"<0>\",point_1_name,\"<1>\",temp_str,\"<2>\",temp_str_2,\"<3>\",StarName(PlanetToStar(GetShipHomePlanet(Player()))),\"<4>\",PlanetName(GetShipHomePlanet(Player()))));",
                        "  \t\t\tCargoLostChanceCalcHome();",
                        "  \t\t\tpoint_3=Id(GetShipHomePlanet(Player()));",
                        "  \t\t\tLTargetType=5;",
                        "  \t\t}",
                        "  \t}",
                        "  \t//Обработчик прерывания изначальной доставки на планету",
                        "  \tif(LTargetType==1)",
                        "  \t{",
                        "  \t\tif(point_1==3)",
                        "  \t\t{",
                        "  \t\t\tif(StarOwner(PlanetToStar(IdToPlanet(point_3)))==1 || StarCustomFaction(PlanetToStar(IdToPlanet(point_3)))!='')",
                        "  \t\t\t{",
                        "  \t\t\t\t//Груз был в пути на планету доставки, но её захватили, а груз перенаправили на планету отправки",
                        "  \t\t\t\tif(StarOwner(PlanetToStar(IdToPlanet(point_1_id)))!=1 && StarCustomFaction(PlanetToStar(IdToPlanet(point_1_id)))=='')",
                        "  \t\t\t\t{",
                        "  \t\t\t\t\tNewsAdd(Format(CT(\"Script.Mod_ExpPilotBridge.1527\"),\"<0>\",StarName(PlanetToStar(IdToPlanet(point_3))),\"<1>\",PlanetName(IdToPlanet(point_3)),\"<2>\",PlanetName(IdToPlanet(point_1_id)),\"<3>\",StarName(PlanetToStar(IdToPlanet(point_1_id)))));",
                        "  \t\t\t\t\tCargoLostChanceCalc();",
                        "  \t\t\t\t\tpoint_3=point_1_id;",
                        "  \t\t\t\t\tLTargetType=3;",
                        "  \t\t\t\t}",
                        "  \t\t\t\t//Груз был в пути на планету доставки, но её захватили, а планета отправки уже была захвачена (груз перенаправлен в родную систему)",
                        "  \t\t\t\telse",
                        "  \t\t\t\t{",
                        "  \t\t\t\t\tNewsAdd(Format(CT(\"Script.Mod_ExpPilotBridge.1526\"),\"<0>\",StarName(PlanetToStar(IdToPlanet(point_3))),\"<1>\",PlanetName(IdToPlanet(point_3)),\"<2>\",PlanetName(IdToPlanet(point_1_id)),\"<3>\",StarName(PlanetToStar(IdToPlanet(point_1_id))),\"<4>\",StarName(PlanetToStar(GetShipHomePlanet(Player()))),\"<5>\",PlanetName(GetShipHomePlanet(Player()))));",
                        "  \t\t\t\t\tCargoLostChanceCalcHome();",
                        "  \t\t\t\t\tpoint_3=Id(GetShipHomePlanet(Player()));",
                        "  \t\t\t\t\tLTargetType=5;",
                        "  \t\t\t\t}",
                        "  \t\t\t}",
                        "  \t\t}",
                        "  \t\tif(point_1==4)",
                        "  \t\t{",
                        "  \t\t\tif(StarOwner(PlanetToStar(IdToPlanet(point_3)))==1 || StarCustomFaction(PlanetToStar(IdToPlanet(point_3)))!='')",
                        "  \t\t\t{",
                        "  \t\t\t\t//Груз был в пути на планету доставки, но её захватили, а груз перенаправили на станцию отправки",
                        "  \t\t\t\tif(!LStationSExist)",
                        "  \t\t\t\t{",
                        "  \t\t\t\t\tNewsAdd(Format(CT(\"Script.Mod_ExpPilotBridge.1525\"),\"<0>\",StarName(PlanetToStar(IdToPlanet(point_3))),\"<1>\",PlanetName(IdToPlanet(point_3)),\"<2>\",ShipName(IdToShip(point_1_id)),\"<3>\",StarName(ShipStar(IdToShip(point_1_id)))));",
                        "  \t\t\t\t\tCargoLostChanceCalc();",
                        "  \t\t\t\t\tpoint_3=point_1_id;",
                        "  \t\t\t\t\tLTargetType=4;",
                        "  \t\t\t\t}",
                        "  \t\t\t\t//Груз был в пути на планету доставки, но её захватили, а станция отправки уже была уничтожена/улетела (груз перенаправлен в родную систему)",
                        "  \t\t\t\telse",
                        "  \t\t\t\t{",
                        "  \t\t\t\t\t//Станция отправки была уничтожена",
                        "  \t\t\t\t\tif(LStationSExist==1)",
                        "  \t\t\t\t\t{",
                        "  \t\t\t\t\t\ttemp_str='</color>'+Format(CT(\"Script.Mod_ExpPilotBridge.1520\"),\"<0>\",StarName(GalaxyStar(point_1_star)));",
                        "  \t\t\t\t\t\ttemp_str_2='</color>'+CT(\"Script.Mod_ExpPilotBridge.1476\");",
                        "  \t\t\t\t\t}",
                        "  \t\t\t\t\t//Станция отправки покинула систему",
                        "  \t\t\t\t\telse",
                        "  \t\t\t\t\t{",
                        "  \t\t\t\t\t\ttemp_str='</color>'+Format(CT(\"Script.Mod_ExpPilotBridge.1518\"),\"<0>\",StarName(GalaxyStar(point_1_star)));",
                        "  \t\t\t\t\t\ttemp_str_2='</color>'+CT(\"Script.Mod_ExpPilotBridge.1517\");",
                        "  \t\t\t\t\t}",
                        "  \t\t\t\t\tNewsAdd(Format(CT(\"Script.Mod_ExpPilotBridge.1524\"),\"<0>\",StarName(PlanetToStar(IdToPlanet(point_3))),\"<1>\",PlanetName(IdToPlanet(point_3)),\"<2>\",point_1_name,\"<3>\",temp_str,\"<4>\",temp_str_2,\"<5>\",StarName(PlanetToStar(GetShipHomePlanet(Player()))),\"<6>\",PlanetName(GetShipHomePlanet(Player()))));",
                        "  \t\t\t\t\tCargoLostChanceCalcHome();",
                        "  \t\t\t\t\tpoint_3=Id(GetShipHomePlanet(Player()));",
                        "  \t\t\t\t\tLTargetType=5;",
                        "  \t\t\t\t}",
                        "  \t\t\t}",
                        "  \t\t}",
                        "  \t}",
                        "  \t//Обработчик прерывания изначальной доставки на станцию",
                        "  \tif(LTargetType==2)",
                        "  \t{",
                        "  \t\tif(point_1==3)",
                        "  \t\t{",
                        "  \t\t\tif(LStationDExist)",
                        "  \t\t\t{",
                        "  \t\t\t\t//Груз был в пути на станцию доставки, но её уничтожили, а груз перенаправили на планету отправки",
                        "  \t\t\t\tif(StarOwner(PlanetToStar(IdToPlanet(point_1_id)))!=1 && StarCustomFaction(PlanetToStar(IdToPlanet(point_1_id)))=='')",
                        "  \t\t\t\t{",
                        "  \t\t\t\t\t//Станция доставки была уничтожена",
                        "  \t\t\t\t\tif(LStationDExist==1)",
                        "  \t\t\t\t\t{",
                        "  \t\t\t\t\t\ttemp_str='</color>'+Format(CT(\"Script.Mod_ExpPilotBridge.1520\"),\"<0>\",point_3_star_name);",
                        "  \t\t\t\t\t\ttemp_str_2='</color>'+CT(\"Script.Mod_ExpPilotBridge.1476\");",
                        "  \t\t\t\t\t}",
                        "  \t\t\t\t\t//Станция доставки покинула систему",
                        "  \t\t\t\t\telse",
                        "  \t\t\t\t\t{",
                        "  \t\t\t\t\t\ttemp_str='</color>'+Format(CT(\"Script.Mod_ExpPilotBridge.1518\"),\"<0>\",point_3_star_name);",
                        "  \t\t\t\t\t\ttemp_str_2='</color>'+CT(\"Script.Mod_ExpPilotBridge.1517\");",
                        "  \t\t\t\t\t}",
                        "  \t\t\t\t\tNewsAdd(Format(CT(\"Script.Mod_ExpPilotBridge.1523\"),\"<0>\",point_3_name,\"<1>\",temp_str,\"<2>\",temp_str_2,\"<3>\",PlanetName(IdToPlanet(point_1_id)),\"<4>\",StarName(PlanetToStar(IdToPlanet(point_1_id)))));",
                        "  \t\t\t\t\tCargoLostChanceCalc();",
                        "  \t\t\t\t\tpoint_3=point_1_id;",
                        "  \t\t\t\t\tLTargetType=3;",
                        "  \t\t\t\t}",
                        "  \t\t\t\t//Груз был в пути на станцию доставки, но её уничтожили, а планета отправки уже была захвачена (груз перенаправлен в родную систему)",
                        "  \t\t\t\telse",
                        "  \t\t\t\t{",
                        "  \t\t\t\t\t//Станция доставки была уничтожена",
                        "  \t\t\t\t\tif(LStationDExist==1)",
                        "  \t\t\t\t\t{",
                        "  \t\t\t\t\t\ttemp_str='</color>'+Format(CT(\"Script.Mod_ExpPilotBridge.1520\"),\"<0>\",point_3_star_name);",
                        "  \t\t\t\t\t\ttemp_str_2='</color>'+CT(\"Script.Mod_ExpPilotBridge.1476\");",
                        "  \t\t\t\t\t}",
                        "  \t\t\t\t\t//Станция доставки покинула систему",
                        "  \t\t\t\t\telse",
                        "  \t\t\t\t\t{",
                        "  \t\t\t\t\t\ttemp_str='</color>'+Format(CT(\"Script.Mod_ExpPilotBridge.1518\"),\"<0>\",point_3_star_name);",
                        "  \t\t\t\t\t\ttemp_str_2='</color>'+CT(\"Script.Mod_ExpPilotBridge.1517\");",
                        "  \t\t\t\t\t}",
                        "  \t\t\t\t\tNewsAdd(Format(CT(\"Script.Mod_ExpPilotBridge.1522\"),\"<0>\",point_3_name,\"<1>\",temp_str,\"<2>\",temp_str_2,\"<3>\",PlanetName(IdToPlanet(point_1_id)),\"<4>\",StarName(PlanetToStar(IdToPlanet(point_1_id))),\"<5>\",StarName(PlanetToStar(GetShipHomePlanet(Player()))),\"<6>\",PlanetName(GetShipHomePlanet(Player()))));",
                        "  \t\t\t\t\tCargoLostChanceCalcHome();",
                        "  \t\t\t\t\tpoint_3=Id(GetShipHomePlanet(Player()));",
                        "  \t\t\t\t\tLTargetType=5;",
                        "  \t\t\t\t}",
                        "  \t\t\t}",
                        "  \t\t}",
                        "  \t\tif(point_1==4)",
                        "  \t\t{",
                        "  \t\t\tif(LStationDExist)",
                        "  \t\t\t{",
                        "  \t\t\t\t//Груз был в пути на станцию доставки, но её уничтожили, а груз перенаправили на станцию отправки",
                        "  \t\t\t\tif(!LStationSExist)",
                        "  \t\t\t\t{",
                        "  \t\t\t\t\t//Станция доставки была уничтожена",
                        "  \t\t\t\t\tif(LStationDExist==1)",
                        "  \t\t\t\t\t{",
                        "  \t\t\t\t\t\ttemp_str='</color>'+Format(CT(\"Script.Mod_ExpPilotBridge.1520\"),\"<0>\",point_3_star_name);",
                        "  \t\t\t\t\t\ttemp_str_2='</color>'+CT(\"Script.Mod_ExpPilotBridge.1476\");",
                        "  \t\t\t\t\t}",
                        "  \t\t\t\t\t//Станция доставки покинула систему",
                        "  \t\t\t\t\telse",
                        "  \t\t\t\t\t{",
                        "  \t\t\t\t\t\ttemp_str='</color>'+Format(CT(\"Script.Mod_ExpPilotBridge.1518\"),\"<0>\",point_3_star_name);",
                        "  \t\t\t\t\t\ttemp_str_2='</color>'+CT(\"Script.Mod_ExpPilotBridge.1517\");",
                        "  \t\t\t\t\t}",
                        "  \t\t\t\t\tNewsAdd(Format(CT(\"Script.Mod_ExpPilotBridge.1521\"),\"<0>\",point_3_name,\"<1>\",temp_str,\"<2>\",temp_str_2,\"<3>\",ShipName(IdToShip(point_1_id)),\"<4>\",StarName(ShipStar(IdToShip(point_1_id)))));",
                        "  \t\t\t\t\tCargoLostChanceCalc();",
                        "  \t\t\t\t\tpoint_3=point_1_id;",
                        "  \t\t\t\t\tLTargetType=4;",
                        "  \t\t\t\t}",
                        "  \t\t\t\t//Груз был в пути на станцию доставки, но её уничтожили, а станция отправки уже была уничтожена (груз перенаправлен в родную систему)",
                        "  \t\t\t\telse",
                        "  \t\t\t\t{",
                        "  \t\t\t\t\t//Станция доставки была уничтожена",
                        "  \t\t\t\t\tif(LStationDExist==1)",
                        "  \t\t\t\t\t{",
                        "  \t\t\t\t\t\ttemp_str='</color>'+Format(CT(\"Script.Mod_ExpPilotBridge.1520\"),\"<0>\",point_3_star_name);",
                        "  \t\t\t\t\t\ttemp_str_2='</color>'+CT(\"Script.Mod_ExpPilotBridge.1476\");",
                        "  \t\t\t\t\t}",
                        "  \t\t\t\t\t//Станция доставки покинула систему",
                        "  \t\t\t\t\telse",
                        "  \t\t\t\t\t{",
                        "  \t\t\t\t\t\ttemp_str='</color>'+Format(CT(\"Script.Mod_ExpPilotBridge.1518\"),\"<0>\",point_3_star_name);",
                        "  \t\t\t\t\t\ttemp_str_2='</color>'+CT(\"Script.Mod_ExpPilotBridge.1517\");",
                        "  \t\t\t\t\t}",
                        "  \t\t\t\t\t//Станция отправки была уничтожена",
                        "  \t\t\t\t\tif(LStationSExist==1)",
                        "  \t\t\t\t\t{",
                        "  \t\t\t\t\t\ttemp_str_3='</color>'+Format(CT(\"Script.Mod_ExpPilotBridge.1520\"),\"<0>\",StarName(GalaxyStar(point_1_star)));",
                        "  \t\t\t\t\t\tif(LStationDExist==1)temp_str_4='</color>'+CT(\"Script.Mod_ExpPilotBridge.1519\");",
                        "  \t\t\t\t\t\telse temp_str_4='</color>'+CT(\"Script.Mod_ExpPilotBridge.1476\");",
                        "  \t\t\t\t\t}",
                        "  \t\t\t\t\t//Станция отправки покинула систему",
                        "  \t\t\t\t\telse",
                        "  \t\t\t\t\t{",
                        "  \t\t\t\t\t\ttemp_str_3='</color>'+Format(CT(\"Script.Mod_ExpPilotBridge.1518\"),\"<0>\",StarName(GalaxyStar(point_1_star)));",
                        "  \t\t\t\t\t\tif(LStationDExist==1)temp_str_4='</color>'+CT(\"Script.Mod_ExpPilotBridge.1517\");",
                        "  \t\t\t\t\t\telse temp_str_4='</color>'+CT(\"Script.Mod_ExpPilotBridge.1516\");",
                        "  \t\t\t\t\t}",
                        "  \t\t\t\t\tNewsAdd(Format(CT(\"Script.Mod_ExpPilotBridge.1515\"),\"<0>\",point_3_name,\"<1>\",temp_str,\"<2>\",temp_str_2,\"<3>\",point_1_name,\"<4>\",temp_str_3,\"<5>\",temp_str_4,\"<6>\",StarName(PlanetToStar(GetShipHomePlanet(Player()))),\"<7>\",PlanetName(GetShipHomePlanet(Player()))));",
                        "  \t\t\t\t\tCargoLostChanceCalcHome();",
                        "  \t\t\t\t\tpoint_3=Id(GetShipHomePlanet(Player()));",
                        "  \t\t\t\t\tLTargetType=5;",
                        "  \t\t\t\t}",
                        "  \t\t\t}",
                        "  \t\t}",
                        "  \t}",
                        "  \t//Груз был в пути в родную систему, но её захватили (передаёт команду обработчику утери груза по прибытии)",
                        "  \tif(LTargetType==5 && CargoLost!=5)",
                        "  \t{",
                        "  \t\tif(StarOwner(PlanetToStar(IdToPlanet(point_3)))==1 || StarCustomFaction(PlanetToStar(IdToPlanet(point_3)))!='')",
                        "  \t\t{",
                        "  \t\t\tCargoLostChanceCalcHome();",
                        "  \t\t}",
                        "  \t}",
                        "  \t//Груз был в пути в захваченную родную систему, но её освободили (снимает команду на утерю груза по прибытии)",
                        "  \tif(LTargetType==5 && CargoLost==5)",
                        "  \t{",
                        "  \t\tif(StarOwner(PlanetToStar(IdToPlanet(point_3)))!=1 && StarCustomFaction(PlanetToStar(IdToPlanet(point_3)))=='')",
                        "  \t\t{",
                        "  \t\t\tCargoLostChanceCalcHome();",
                        "  \t\t}",
                        "  \t}",
                        "  }",
                        "  ",
                        "  //Восстановление груза, утерянного при доставке в захваченную родную систему",
                        "  if(saved_items)",
                        "  {",
                        "  \tif(StarOwner(PlanetToStar(GetShipHomePlanet(Player())))!=1 && StarCustomFaction(PlanetToStar(GetShipHomePlanet(Player())))=='')",
                        "  \t{",
                        "  \t\tfor(j=1;j<=saved_items;j=j+1)",
                        "  \t\t{",
                        "  \t\t\ttemp_dword=GetItemFromVault('saved_by_miracle_'+j);",
                        "  \t\t\tAddItemToStorage(GetShipHomePlanet(Player()),temp_dword);",
                        "  \t\t\tNewsAdd(Format(CT(\"Script.Mod_ExpPilotBridge.1512\"),\"<0>\",PlanetName(GetShipHomePlanet(Player()))));",
                        "  \t\t}",
                        "  \t\tsaved_items=0;",
                        "  \t}",
                        "  }",
                        "  ",
                        "  //Обработчики прерывания перегона корпусов",
                        "  if(HullDelTime>CurTurn())",
                        "  {",
                        "  \t//Корпус был в пути на планету отправки, но её захватили (корпус украден)",
                        "  \tif(LHullTargetType==3)",
                        "  \t{",
                        "  \t\tif(StarOwner(PlanetToStar(IdToPlanet(HullDelFromId)))==1 || StarCustomFaction(PlanetToStar(IdToPlanet(HullDelFromId)))!='')",
                        "  \t\t{",
                        "  \t\t\tif(HullOnWay==1)NewsAdd(Format(CT(\"Script.Mod_ExpPilotBridge.1511\"),\"<0>\",StarName(PlanetToStar(IdToPlanet(HullDelFromId))),\"<1>\",PlanetName(IdToPlanet(HullDelFromId))));",
                        "  \t\t\telse if(HullOnWay>1)NewsAdd(Format(CT(\"Script.Mod_ExpPilotBridge.1510\"),\"<0>\",StarName(PlanetToStar(IdToPlanet(HullDelFromId))),\"<1>\",PlanetName(IdToPlanet(HullDelFromId))));",
                        "  \t\t\tHullWasStolen=7;",
                        "  \t\t\tHullWasStolenThiefCreate(0);",
                        "  \t\t}",
                        "  \t}",
                        "  \t//Корпус был в пути на станцию отправки, но её уничтожили, либо она покинула систему (корпус украден)",
                        "  \tif(LHullTargetType==4)",
                        "  \t{",
                        "  \t\tif(HullFromStExist)",
                        "  \t\t{",
                        "  \t\t\t//Станция доставки была уничтожена",
                        "  \t\t\tif(HullFromStExist==1)",
                        "  \t\t\t{",
                        "  \t\t\t\ttemp_str_2='</color>'+Format(CT(\"Script.Mod_ExpPilotBridge.1477\"),\"<0>\",StarName(GalaxyStar(HullFromStarId)));",
                        "  \t\t\t\ttemp_str_3='</color>'+CT(\"Script.Mod_ExpPilotBridge.1476\");",
                        "  \t\t\t}",
                        "  \t\t\t//Станция доставки покинула систему",
                        "  \t\t\telse",
                        "  \t\t\t{",
                        "  \t\t\t\ttemp_str_2='</color>'+Format(CT(\"Script.Mod_ExpPilotBridge.1475\"),\"<0>\",StarName(GalaxyStar(HullFromStarId)));",
                        "  \t\t\t\ttemp_str_3='</color>'+CT(\"Script.Mod_ExpPilotBridge.1474\");",
                        "  \t\t\t}",
                        "  \t\t\tif(HullOnWay==1)NewsAdd(Format(CT(\"Script.Mod_ExpPilotBridge.1509\"),\"<0>\",HullFromName,\"<1>\",temp_str_2,\"<2>\",temp_str_3));",
                        "  \t\t\telse if(HullOnWay>1)NewsAdd(Format(CT(\"Script.Mod_ExpPilotBridge.1508\"),\"<0>\",HullFromName,\"<1>\",temp_str_2,\"<2>\",temp_str_3));",
                        "  \t\t\tHullWasStolen=7;",
                        "  \t\t\tHullWasStolenThiefCreate(0);",
                        "  \t\t}",
                        "  \t}",
                        "  \t//Обработчик прерывания изначальной доставки корпуса",
                        "  \tif(LHullTargetType==1)",
                        "  \t{",
                        "  \t\tif(HullFromType==3)",
                        "  \t\t{",
                        "  \t\t\tif(StarOwner(PlanetToStar(IdToPlanet(HullDelEndId)))==1 || StarCustomFaction(PlanetToStar(IdToPlanet(HullDelEndId)))!='')",
                        "  \t\t\t{",
                        "  \t\t\t\t//Корпус был в пути на планету доставки, но её захватили, а корпус перенаправили (возможно) на планету отправки",
                        "  \t\t\t\tif(StarOwner(PlanetToStar(IdToPlanet(HullDelFromId)))!=1 && StarCustomFaction(PlanetToStar(IdToPlanet(HullDelFromId)))=='')",
                        "  \t\t\t\t{",
                        "  \t\t\t\t\tif(HullOnWay==1 && HullWasStolen==0 && (HullAgentType==1 || HullAgentType==2))NewsAdd(Format(CT(\"Script.Mod_ExpPilotBridge.1514\"),\"<0>\",StarName(PlanetToStar(IdToPlanet(HullDelEndId))),\"<1>\",PlanetName(IdToPlanet(HullDelEndId)),\"<2>\",PlanetName(IdToPlanet(HullDelFromId)),\"<3>\",StarName(PlanetToStar(IdToPlanet(HullDelFromId)))));",
                        "  \t\t\t\t\telse if(HullOnWay==1 && (HullWasStolen>0 || HullAgentType==22 || HullAgentType==3))NewsAdd(Format(CT(\"Script.Mod_ExpPilotBridge.1500\"),\"<0>\",StarName(PlanetToStar(IdToPlanet(HullDelEndId))),\"<1>\",PlanetName(IdToPlanet(HullDelEndId))));",
                        "  \t\t\t\t\telse if(HullOnWay>1 && HullWasStolen==0 && (HullAgentType==1 || HullAgentType==2))NewsAdd(Format(CT(\"Script.Mod_ExpPilotBridge.1506\"),\"<0>\",StarName(PlanetToStar(IdToPlanet(HullDelEndId))),\"<1>\",PlanetName(IdToPlanet(HullDelEndId)),\"<2>\",PlanetName(IdToPlanet(HullDelFromId)),\"<3>\",StarName(PlanetToStar(IdToPlanet(HullDelFromId)))));",
                        "  \t\t\t\t\telse if(HullOnWay>1 && HullWasStolen>0 && HullWasStolen<7 && (HullAgentType==1 || HullAgentType==2))NewsAdd(Format(CT(\"Script.Mod_ExpPilotBridge.1505\"),\"<0>\",StarName(PlanetToStar(IdToPlanet(HullDelEndId))),\"<1>\",PlanetName(IdToPlanet(HullDelEndId)),\"<2>\",PlanetName(IdToPlanet(HullDelFromId)),\"<3>\",StarName(PlanetToStar(IdToPlanet(HullDelFromId)))));",
                        "  \t\t\t\t\telse if(HullOnWay>1 && (HullWasStolen==7 || HullAgentType==22 || HullAgentType==3))NewsAdd(Format(CT(\"Script.Mod_ExpPilotBridge.1504\"),\"<0>\",StarName(PlanetToStar(IdToPlanet(HullDelEndId))),\"<1>\",PlanetName(IdToPlanet(HullDelEndId))));",
                        "  \t\t\t\t\tif(HullAgentType==22 || HullAgentType==3)HullWasStolen=7;",
                        "  \t\t\t\t\tif(HullWasStolen>0)HullWasStolenThiefCreate(0);",
                        "  \t\t\t\t\tHullDelTime=CurTurn()-HullDelTimeStart;",
                        "  \t\t\t\t\tHullDelTimeExp=HullDelTime+CurTurn();",
                        "  \t\t\t\t\tif(Rnd(1,100)<=35 && HullAgentType==1)HullDelTime=HullDelTime+((HullDelTime*Rnd(15,25))/100);",
                        "  \t\t\t\t\tif(Rnd(1,100)<=65 && HullAgentType==2)HullDelTime=HullDelTime+((HullDelTime*Rnd(25,40))/100);",
                        "  \t\t\t\t\tHullDelTime=HullDelTime+CurTurn();",
                        "  \t\t\t\t\tHullDelEndId=HullDelFromId;",
                        "  \t\t\t\t\ttemp_int_1=HullFromStarId;",
                        "  \t\t\t\t\tHullEndStarId=HullFromStarId;",
                        "  \t\t\t\t\tHullFromStarId=temp_int_1;",
                        "  \t\t\t\t\tLHullTargetType=3;",
                        "  \t\t\t\t}",
                        "  \t\t\t\t//Корпус был в пути на планету доставки, но её захватили, а планета отправки уже была захвачена (корпус украден)",
                        "  \t\t\t\telse",
                        "  \t\t\t\t{",
                        "  \t\t\t\t\tif(HullOnWay==1)NewsAdd(Format(CT(\"Script.Mod_ExpPilotBridge.1503\"),\"<0>\",StarName(PlanetToStar(IdToPlanet(HullDelEndId))),\"<1>\",PlanetName(IdToPlanet(HullDelEndId)),\"<2>\",PlanetName(IdToPlanet(HullDelFromId)),\"<3>\",StarName(PlanetToStar(IdToPlanet(HullDelFromId)))));",
                        "  \t\t\t\t\telse if(HullOnWay>1)NewsAdd(Format(CT(\"Script.Mod_ExpPilotBridge.1502\"),\"<0>\",StarName(PlanetToStar(IdToPlanet(HullDelEndId))),\"<1>\",PlanetName(IdToPlanet(HullDelEndId)),\"<2>\",PlanetName(IdToPlanet(HullDelFromId)),\"<3>\",StarName(PlanetToStar(IdToPlanet(HullDelFromId)))));",
                        "  \t\t\t\t\tHullWasStolen=7;",
                        "  \t\t\t\t\tHullWasStolenThiefCreate(0);",
                        "  \t\t\t\t}",
                        "  \t\t\t}",
                        "  \t\t}",
                        "  \t\tif(HullFromType==4)",
                        "  \t\t{",
                        "  \t\t\tif(StarOwner(PlanetToStar(IdToPlanet(HullDelEndId)))==1 || StarCustomFaction(PlanetToStar(IdToPlanet(HullDelEndId)))!='' && (HullAgentType==1 || HullAgentType==22))",
                        "  \t\t\t{",
                        "  \t\t\t\t//Корпус был в пути на планету доставки, но её захватили, а корпус перенаправили (возможно) на станцию отправки",
                        "  \t\t\t\tif(!HullFromStExist)",
                        "  \t\t\t\t{",
                        "  \t\t\t\t\tif(HullOnWay==1 && HullWasStolen==0 && (HullAgentType==1 || HullAgentType==2))NewsAdd(Format(CT(\"Script.Mod_ExpPilotBridge.1501\"),\"<0>\",StarName(PlanetToStar(IdToPlanet(HullDelEndId))),\"<1>\",PlanetName(IdToPlanet(HullDelEndId)),\"<2>\",ShipName(IdToShip(HullDelFromId)),\"<3>\",StarName(ShipStar(IdToShip(HullDelFromId)))));",
                        "  \t\t\t\t\telse if(HullOnWay==1 && (HullWasStolen>0 || HullAgentType==22 || HullAgentType==3))NewsAdd(Format(CT(\"Script.Mod_ExpPilotBridge.1500\"),\"<0>\",StarName(PlanetToStar(IdToPlanet(HullDelEndId))),\"<1>\",PlanetName(IdToPlanet(HullDelEndId))));",
                        "  \t\t\t\t\telse if(HullOnWay>1 && HullWasStolen==0 && (HullAgentType==1 || HullAgentType==2))NewsAdd(Format(CT(\"Script.Mod_ExpPilotBridge.1499\"),\"<0>\",StarName(PlanetToStar(IdToPlanet(HullDelEndId))),\"<1>\",PlanetName(IdToPlanet(HullDelEndId)),\"<2>\",ShipName(IdToShip(HullDelFromId)),\"<3>\",StarName(ShipStar(IdToShip(HullDelFromId)))));",
                        "  \t\t\t\t\telse if(HullOnWay>1 && HullWasStolen>0 && HullWasStolen<7 && (HullAgentType==1 || HullAgentType==2))NewsAdd(Format(CT(\"Script.Mod_ExpPilotBridge.1498\"),\"<0>\",StarName(PlanetToStar(IdToPlanet(HullDelEndId))),\"<1>\",PlanetName(IdToPlanet(HullDelEndId)),\"<2>\",ShipName(IdToShip(HullDelFromId)),\"<3>\",StarName(ShipStar(IdToShip(HullDelFromId)))));",
                        "  \t\t\t\t\telse if(HullOnWay>1 && (HullWasStolen==7 || HullAgentType==22 || HullAgentType==3))NewsAdd(Format(CT(\"Script.Mod_ExpPilotBridge.1497\"),\"<0>\",StarName(PlanetToStar(IdToPlanet(HullDelEndId))),\"<1>\",PlanetName(IdToPlanet(HullDelEndId))));",
                        "  \t\t\t\t\tif(HullAgentType==22 || HullAgentType==3)HullWasStolen=7;",
                        "  \t\t\t\t\tif(HullWasStolen>0)HullWasStolenThiefCreate(0);",
                        "  \t\t\t\t\tHullDelTime=CurTurn()-HullDelTimeStart;",
                        "  \t\t\t\t\tHullDelTimeExp=HullDelTime+CurTurn();",
                        "  \t\t\t\t\tif(Rnd(1,100)<=35 && HullAgentType==1)HullDelTime=HullDelTime+((HullDelTime*Rnd(15,25))/100);",
                        "  \t\t\t\t\tif(Rnd(1,100)<=65 && HullAgentType==2)HullDelTime=HullDelTime+((HullDelTime*Rnd(25,40))/100);",
                        "  \t\t\t\t\tHullDelTime=HullDelTime+CurTurn();",
                        "  \t\t\t\t\tHullDelEndId=HullDelFromId;",
                        "  \t\t\t\t\ttemp_int_1=HullFromStarId;",
                        "  \t\t\t\t\tHullEndStarId=HullFromStarId;",
                        "  \t\t\t\t\tHullFromStarId=temp_int_1;",
                        "  \t\t\t\t\tHullEndType=4;",
                        "  \t\t\t\t\tLHullTargetType=4;",
                        "  \t\t\t\t}",
                        "  \t\t\t\t//Корпус был в пути на планету доставки, но её захватили, а станция отправки уже была уничтожена (корпус украден)",
                        "  \t\t\t\telse",
                        "  \t\t\t\t{",
                        "  \t\t\t\t\t//Станция отправки была уничтожена",
                        "  \t\t\t\t\tif(HullFromStExist==1)",
                        "  \t\t\t\t\t{",
                        "  \t\t\t\t\t\ttemp_str='</color>'+Format(CT(\"Script.Mod_ExpPilotBridge.1473\"),\"<0>\",StarName(GalaxyStar(HullFromStarId)));",
                        "  \t\t\t\t\t\ttemp_str_2='</color>'+CT(\"Script.Mod_ExpPilotBridge.1472\");",
                        "  \t\t\t\t\t}",
                        "  \t\t\t\t\t//Станция отправки покинула систему",
                        "  \t\t\t\t\telse",
                        "  \t\t\t\t\t{",
                        "  \t\t\t\t\t\ttemp_str='</color>'+Format(CT(\"Script.Mod_ExpPilotBridge.1471\"),\"<0>\",StarName(GalaxyStar(HullFromStarId)));",
                        "  \t\t\t\t\t\ttemp_str_2='</color>'+CT(\"Script.Mod_ExpPilotBridge.1470\");",
                        "  \t\t\t\t\t}",
                        "  \t\t\t\t\tif(HullOnWay==1)NewsAdd(Format(CT(\"Script.Mod_ExpPilotBridge.1496\"),\"<0>\",StarName(PlanetToStar(IdToPlanet(HullDelEndId))),\"<1>\",PlanetName(IdToPlanet(HullDelEndId)),\"<2>\",HullFromName,\"<3>\",temp_str,\"<4>\",temp_str_2));",
                        "  \t\t\t\t\telse if(HullOnWay>1)NewsAdd(Format(CT(\"Script.Mod_ExpPilotBridge.1495\"),\"<0>\",StarName(PlanetToStar(IdToPlanet(HullDelEndId))),\"<1>\",PlanetName(IdToPlanet(HullDelEndId)),\"<2>\",HullFromName,\"<3>\",temp_str,\"<4>\",temp_str_2));",
                        "  \t\t\t\t\tHullWasStolen=7;",
                        "  \t\t\t\t\tHullWasStolenThiefCreate(0);",
                        "  \t\t\t\t}",
                        "  \t\t\t}",
                        "  \t\t}",
                        "  \t}",
                        "  \t//Обработчик прерывания изначальной доставки на станцию",
                        "  \tif(LHullTargetType==2)",
                        "  \t{",
                        "  \t\tif(HullFromType==3)",
                        "  \t\t{",
                        "  \t\t\tif(HullEndStExist)",
                        "  \t\t\t{",
                        "  \t\t\t\t//Корпус был в пути на станцию доставки, но её уничтожили, а корпус перенаправили (возможно) на планету отправки",
                        "  \t\t\t\tif(StarOwner(PlanetToStar(IdToPlanet(HullDelFromId)))!=1 && StarCustomFaction(PlanetToStar(IdToPlanet(HullDelFromId)))=='')",
                        "  \t\t\t\t{",
                        "  \t\t\t\t\t//Станция доставки была уничтожена",
                        "  \t\t\t\t\tif(HullEndStExist==1)",
                        "  \t\t\t\t\t{",
                        "  \t\t\t\t\t\ttemp_str_2='</color>'+Format(CT(\"Script.Mod_ExpPilotBridge.1477\"),\"<0>\",StarName(GalaxyStar(HullEndStarId)));",
                        "  \t\t\t\t\t\ttemp_str_3='</color>'+CT(\"Script.Mod_ExpPilotBridge.1476\");",
                        "  \t\t\t\t\t\ttemp_str_4='</color>'+CT(\"Script.Mod_ExpPilotBridge.1484\");",
                        "  \t\t\t\t\t}",
                        "  \t\t\t\t\t//Станция доставки покинула систему",
                        "  \t\t\t\t\telse",
                        "  \t\t\t\t\t{",
                        "  \t\t\t\t\t\ttemp_str_2='</color>'+Format(CT(\"Script.Mod_ExpPilotBridge.1475\"),\"<0>\",StarName(GalaxyStar(HullEndStarId)));",
                        "  \t\t\t\t\t\ttemp_str_3='</color>'+CT(\"Script.Mod_ExpPilotBridge.1474\");",
                        "  \t\t\t\t\t\ttemp_str_4='</color>'+CT(\"Script.Mod_ExpPilotBridge.1483\");",
                        "  \t\t\t\t\t}",
                        "  \t\t\t\t\tif(HullOnWay==1 && HullWasStolen==0 && (HullAgentType==1 || HullAgentType==2))NewsAdd(Format(CT(\"Script.Mod_ExpPilotBridge.1494\"),\"<0>\",HullEndName,\"<1>\",temp_str_2,\"<2>\",temp_str_3,\"<3>\",PlanetName(IdToPlanet(HullDelFromId)),\"<4>\",StarName(PlanetToStar(IdToPlanet(HullDelFromId)))));",
                        "  \t\t\t\t\telse if(HullOnWay==1 && (HullWasStolen>0 || HullAgentType==22 || HullAgentType==3))NewsAdd(Format(CT(\"Script.Mod_ExpPilotBridge.1481\"),\"<0>\",HullEndName,\"<1>\",temp_str_2,\"<2>\",temp_str_3,\"<3>\",temp_str_4));",
                        "  \t\t\t\t\telse if(HullOnWay>1 && HullWasStolen==0 && (HullAgentType==1 || HullAgentType==2))NewsAdd(Format(CT(\"Script.Mod_ExpPilotBridge.1493\"),\"<0>\",HullEndName,\"<1>\",temp_str_2,\"<2>\",temp_str_3,\"<3>\",PlanetName(IdToPlanet(HullDelFromId)),\"<4>\",StarName(PlanetToStar(IdToPlanet(HullDelFromId)))));",
                        "  \t\t\t\t\telse if(HullOnWay>1 && HullWasStolen>0 && HullWasStolen<7 && (HullAgentType==1 || HullAgentType==2))NewsAdd(Format(CT(\"Script.Mod_ExpPilotBridge.1492\"),\"<0>\",HullEndName,\"<1>\",temp_str_2,\"<2>\",temp_str_3,\"<3>\",PlanetName(IdToPlanet(HullDelFromId)),\"<4>\",StarName(PlanetToStar(IdToPlanet(HullDelFromId))),\"<5>\",temp_str_4));",
                        "  \t\t\t\t\telse if(HullOnWay>1 && (HullWasStolen==7 || HullAgentType==22 || HullAgentType==3))NewsAdd(Format(CT(\"Script.Mod_ExpPilotBridge.1478\"),\"<0>\",HullEndName,\"<1>\",temp_str_2,\"<2>\",temp_str_3,\"<3>\",temp_str_4));",
                        "  \t\t\t\t\tif(HullAgentType==22 || HullAgentType==3)HullWasStolen=7;",
                        "  \t\t\t\t\tif(HullWasStolen>0)HullWasStolenThiefCreate(0);",
                        "  \t\t\t\t\tHullDelTime=CurTurn()-HullDelTimeStart;",
                        "  \t\t\t\t\tHullDelTimeExp=HullDelTime+CurTurn();",
                        "  \t\t\t\t\tif(Rnd(1,100)<=35 && HullAgentType==1)HullDelTime=HullDelTime+((HullDelTime*Rnd(15,25))/100);",
                        "  \t\t\t\t\tif(Rnd(1,100)<=65 && HullAgentType==2)HullDelTime=HullDelTime+((HullDelTime*Rnd(25,40))/100);",
                        "  \t\t\t\t\tHullDelTime=HullDelTime+CurTurn();",
                        "  \t\t\t\t\tHullDelEndId=HullDelFromId;",
                        "  \t\t\t\t\ttemp_int_1=HullFromStarId;",
                        "  \t\t\t\t\tHullEndStarId=HullFromStarId;",
                        "  \t\t\t\t\tHullFromStarId=temp_int_1;",
                        "  \t\t\t\t\tHullEndType=3;",
                        "  \t\t\t\t\tLHullTargetType=3;",
                        "  \t\t\t\t}",
                        "  \t\t\t\t//Корпус был в пути на станцию доставки, но её уничтожили, а планета отправки уже была захвачена (корпус украден)",
                        "  \t\t\t\telse",
                        "  \t\t\t\t{",
                        "  \t\t\t\t\t//Станция доставки была уничтожена",
                        "  \t\t\t\t\tif(HullEndStExist==1)",
                        "  \t\t\t\t\t{",
                        "  \t\t\t\t\t\ttemp_str_2='</color>'+Format(CT(\"Script.Mod_ExpPilotBridge.1477\"),\"<0>\",StarName(GalaxyStar(HullEndStarId)));",
                        "  \t\t\t\t\t\ttemp_str_3='</color>'+CT(\"Script.Mod_ExpPilotBridge.1476\");",
                        "  \t\t\t\t\t}",
                        "  \t\t\t\t\t//Станция доставки покинула систему",
                        "  \t\t\t\t\telse",
                        "  \t\t\t\t\t{",
                        "  \t\t\t\t\t\ttemp_str_2='</color>'+Format(CT(\"Script.Mod_ExpPilotBridge.1475\"),\"<0>\",StarName(GalaxyStar(HullEndStarId)));",
                        "  \t\t\t\t\t\ttemp_str_3='</color>'+CT(\"Script.Mod_ExpPilotBridge.1474\");",
                        "  \t\t\t\t\t}",
                        "  \t\t\t\t\tif(HullOnWay==1)NewsAdd(Format(CT(\"Script.Mod_ExpPilotBridge.1491\"),\"<0>\",HullEndName,\"<1>\",temp_str_2,\"<2>\",temp_str_3,\"<3>\",PlanetName(IdToPlanet(HullDelFromId)),\"<4>\",StarName(PlanetToStar(IdToPlanet(HullDelFromId)))));",
                        "  \t\t\t\t\telse if(HullOnWay>1)NewsAdd(Format(CT(\"Script.Mod_ExpPilotBridge.1490\"),\"<0>\",HullEndName,\"<1>\",temp_str_2,\"<2>\",temp_str_3,\"<3>\",PlanetName(IdToPlanet(HullDelFromId)),\"<4>\",StarName(PlanetToStar(IdToPlanet(HullDelFromId)))));",
                        "  \t\t\t\t\tHullWasStolen=7;",
                        "  \t\t\t\t\tHullWasStolenThiefCreate(0);",
                        "  \t\t\t\t}",
                        "  \t\t\t}",
                        "  \t\t}",
                        "  \t\tif(HullFromType==4)",
                        "  \t\t{",
                        "  \t\t\tif(HullEndStExist)",
                        "  \t\t\t{",
                        "  \t\t\t\t//Корпус был в пути на станцию доставки, но её уничтожили, а корпус перенаправили (возможно) на станцию отправки",
                        "  \t\t\t\tif(!HullFromStExist)",
                        "  \t\t\t\t{",
                        "  \t\t\t\t\t//Станция доставки была уничтожена",
                        "  \t\t\t\t\tif(HullEndStExist==1)",
                        "  \t\t\t\t\t{",
                        "  \t\t\t\t\t\ttemp_str_3='</color>'+Format(CT(\"Script.Mod_ExpPilotBridge.1477\"),\"<0>\",StarName(GalaxyStar(HullEndStarId)));",
                        "  \t\t\t\t\t\ttemp_str_4='</color>'+CT(\"Script.Mod_ExpPilotBridge.1476\");",
                        "  \t\t\t\t\t\ttemp_str_2='</color>'+CT(\"Script.Mod_ExpPilotBridge.1484\");",
                        "  \t\t\t\t\t}",
                        "  \t\t\t\t\t//Станция доставки покинула систему",
                        "  \t\t\t\t\telse",
                        "  \t\t\t\t\t{",
                        "  \t\t\t\t\t\ttemp_str_3='</color>'+Format(CT(\"Script.Mod_ExpPilotBridge.1475\"),\"<0>\",StarName(GalaxyStar(HullEndStarId)));",
                        "  \t\t\t\t\t\ttemp_str_4='</color>'+CT(\"Script.Mod_ExpPilotBridge.1474\");",
                        "  \t\t\t\t\t\ttemp_str_2='</color>'+CT(\"Script.Mod_ExpPilotBridge.1483\");",
                        "  \t\t\t\t\t}",
                        "  \t\t\t\t\tif(HullOnWay==1 && HullWasStolen==0 && (HullAgentType==1 || HullAgentType==2))NewsAdd(Format(CT(\"Script.Mod_ExpPilotBridge.1489\"),\"<0>\",HullEndName,\"<1>\",temp_str_3,\"<2>\",temp_str_4,\"<3>\",ShipName(IdToShip(HullDelFromId)),\"<4>\",StarName(ShipStar(IdToShip(HullDelFromId)))));",
                        "  \t\t\t\t\telse if(HullOnWay==1 && (HullWasStolen>0 || HullAgentType==22 || HullAgentType==3))NewsAdd(Format(CT(\"Script.Mod_ExpPilotBridge.1481\"),\"<0>\",HullEndName,\"<1>\",temp_str_3,\"<2>\",temp_str_4,\"<3>\",temp_str_2));",
                        "  \t\t\t\t\telse if(HullOnWay>1 && HullWasStolen==0 && (HullAgentType==1 || HullAgentType==2))NewsAdd(Format(CT(\"Script.Mod_ExpPilotBridge.1488\"),\"<0>\",HullEndName,\"<1>\",temp_str_3,\"<2>\",temp_str_4,\"<3>\",ShipName(IdToShip(HullDelFromId)),\"<4>\",StarName(ShipStar(IdToShip(HullDelFromId)))));",
                        "  \t\t\t\t\telse if(HullOnWay>1 && HullWasStolen>0 && HullWasStolen<7 && (HullAgentType==1 || HullAgentType==2))NewsAdd(Format(CT(\"Script.Mod_ExpPilotBridge.1487\"),\"<0>\",HullEndName,\"<1>\",temp_str_3,\"<2>\",temp_str_4,\"<3>\",ShipName(IdToShip(HullDelFromId)),\"<4>\",StarName(ShipStar(IdToShip(HullDelFromId))),\"<5>\",temp_str_2));",
                        "  \t\t\t\t\telse if(HullOnWay>1 && (HullWasStolen==7 || HullAgentType==22 || HullAgentType==3))NewsAdd(Format(CT(\"Script.Mod_ExpPilotBridge.1478\"),\"<0>\",HullEndName,\"<1>\",temp_str_3,\"<2>\",temp_str_4,\"<3>\",temp_str_2));",
                        "  \t\t\t\t\tif(HullAgentType==22 || HullAgentType==3)HullWasStolen=7;",
                        "  \t\t\t\t\tif(HullWasStolen>0)HullWasStolenThiefCreate(0);",
                        "  \t\t\t\t\tHullDelTime=CurTurn()-HullDelTimeStart;",
                        "  \t\t\t\t\tHullDelTimeExp=HullDelTime+CurTurn();",
                        "  \t\t\t\t\tif(Rnd(1,100)<=35 && HullAgentType==1)HullDelTime=HullDelTime+((HullDelTime*Rnd(15,25))/100);",
                        "  \t\t\t\t\tif(Rnd(1,100)<=65 && HullAgentType==2)HullDelTime=HullDelTime+((HullDelTime*Rnd(25,40))/100);",
                        "  \t\t\t\t\tHullDelTime=HullDelTime+CurTurn();",
                        "  \t\t\t\t\tHullDelEndId=HullDelFromId;",
                        "  \t\t\t\t\ttemp_int_1=HullFromStarId;",
                        "  \t\t\t\t\tHullEndStarId=HullFromStarId;",
                        "  \t\t\t\t\tHullFromStarId=temp_int_1;",
                        "  \t\t\t\t\tLHullTargetType=4;",
                        "  \t\t\t\t}",
                        "  \t\t\t\t//Корпус был в пути на станцию доставки, но её уничтожили, а станция отправки уже была уничтожена (корпус украден)",
                        "  \t\t\t\telse",
                        "  \t\t\t\t{",
                        "  \t\t\t\t\t//Станция доставки была уничтожена",
                        "  \t\t\t\t\tif(HullEndStExist==1)",
                        "  \t\t\t\t\t{",
                        "  \t\t\t\t\t\ttemp_str_3='</color>'+Format(CT(\"Script.Mod_ExpPilotBridge.1477\"),\"<0>\",StarName(GalaxyStar(HullEndStarId)));",
                        "  \t\t\t\t\t\ttemp_str_4='</color>'+CT(\"Script.Mod_ExpPilotBridge.1476\");",
                        "  \t\t\t\t\t}",
                        "  \t\t\t\t\t//Станция доставки покинула систему",
                        "  \t\t\t\t\telse",
                        "  \t\t\t\t\t{",
                        "  \t\t\t\t\t\ttemp_str_3='</color>'+Format(CT(\"Script.Mod_ExpPilotBridge.1475\"),\"<0>\",StarName(GalaxyStar(HullEndStarId)));",
                        "  \t\t\t\t\t\ttemp_str_4='</color>'+CT(\"Script.Mod_ExpPilotBridge.1474\");",
                        "  \t\t\t\t\t}",
                        "  \t\t\t\t\t//Станция отправки была уничтожена",
                        "  \t\t\t\t\tif(HullFromStExist==1)",
                        "  \t\t\t\t\t{",
                        "  \t\t\t\t\t\ttemp_str='</color>'+Format(CT(\"Script.Mod_ExpPilotBridge.1473\"),\"<0>\",StarName(GalaxyStar(HullFromStarId)));",
                        "  \t\t\t\t\t\ttemp_str_2='</color>'+CT(\"Script.Mod_ExpPilotBridge.1472\");",
                        "  \t\t\t\t\t}",
                        "  \t\t\t\t\t//Станция отправки покинула систему",
                        "  \t\t\t\t\telse",
                        "  \t\t\t\t\t{",
                        "  \t\t\t\t\t\ttemp_str='</color>'+Format(CT(\"Script.Mod_ExpPilotBridge.1471\"),\"<0>\",StarName(GalaxyStar(HullFromStarId)));",
                        "  \t\t\t\t\t\ttemp_str_2='</color>'+CT(\"Script.Mod_ExpPilotBridge.1470\");",
                        "  \t\t\t\t\t}",
                        "  \t\t\t\t\tif(HullOnWay==1)NewsAdd(Format(CT(\"Script.Mod_ExpPilotBridge.1486\"),\"<0>\",HullEndName,\"<1>\",temp_str_3,\"<2>\",temp_str_4,\"<3>\",HullFromName,\"<4>\",temp_str,\"<5>\",temp_str_2));",
                        "  \t\t\t\t\telse if(HullOnWay>1)NewsAdd(Format(CT(\"Script.Mod_ExpPilotBridge.1485\"),\"<0>\",HullEndName,\"<1>\",temp_str_3,\"<2>\",temp_str_4,\"<3>\",HullFromName,\"<4>\",temp_str,\"<5>\",temp_str_2));",
                        "  \t\t\t\t\tHullWasStolen=7;",
                        "  \t\t\t\t\tHullWasStolenThiefCreate(0);",
                        "  \t\t\t\t}",
                        "  \t\t\t}",
                        "  \t\t}",
                        "  \t}",
                        "  }",
                        "  //Выставляются планеты для спавна кораблей со Слэпстартера",
                        "  if(!CoalitionDefeated())",
                        "  {",
                        "      if(!bld_planet_chsn_2 || !bld_planet_chsn)",
                        "      {",
                        "          for(i=0;i<GalaxyStars();i=i+1)",
                        "          {",
                        "              temp_dword=GalaxyStar(i);",
                        "              if(StarOwner(temp_dword)==1)continue;",
                        "              if(StarCustomFaction(temp_dword)!='')continue;",
                        "              if(StarToCon(temp_dword)==StarToCon(PlanetToStar(PlanetPirateClan())))continue;",
                        "              for(count2=0;count2<StarPlanets(temp_dword);count2=count2+1)",
                        "              {",
                        "                  temp_dword_2=StarPlanets(temp_dword,count2);",
                        "                  temp_int_2=PlanetOwner(temp_dword_2);",
                        "                  if(temp_int_2==6)continue;",
                        "                  if(!PirateWin() && StarOwner(temp_dword)==2 && bld_planet_chsn_2==0)ArrayAdd(bld_ship_planet_list_2,Id(temp_dword_2));",
                        "                  if(StarOwner(temp_dword)==0 && bld_planet_chsn==0)ArrayAdd(bld_ship_planet_list,Id(temp_dword_2));",
                        "              }",
                        "          }",
                        "      }",
                        "  }",
                        "  //Выбор системы для постройки ТЦ, определение стоимости",
                        "  if(InitExpTC) {",
                        "      if(!GlobalVarTcCount && !bld_system_Id_TC) bld_system_Id_TC=SelectSystemTC();",
                        "  //    if(bld_system_Id_TC) bld_cost_TC=GTL*GalaxyDiffLevels()*800+Rnd(GalaxyMoney(2,2),GalaxyMoney(4,4));",
                        "  }",
                        "  //Создаём Коалиционные проекты Слэпстартера (срабатывает, если предыдущий проект завершён)",
                        "  if(!bld_planet_chsn && ArrayDim(bld_ship_planet_list)>1)",
                        "  {",
                        "  \t//Обнуляем сумму возврата в случае не набора проектом требуемой суммы (сумма возврата задаётся при внесении донатов игроком)",
                        "  \trepay=0;",
                        "  \t//Тип коалиционных кораблей (влияет только на название)",
                        "  \ttype_coal=Rnd(1,3);",
                        "  \t//Число коалиционных кораблей",
                        "  \tship_count=Rnd(4,8);",
                        "  \ttemp_int=Rnd(1,ArrayDim(bld_ship_planet_list)-1);",
                        "  \tbld_ship_planet=bld_ship_planet_list[temp_int];",
                        "      //Определяем имя коалиционного отряда",
                        "  \tif(PlanetRace(IdToPlanet(bld_ship_planet))==0)bld_ship_name=CT('ShipType.Maloc.Militiaman'+type_coal);",
                        "  \telse if(PlanetRace(IdToPlanet(bld_ship_planet))==1)bld_ship_name=CT('ShipType.Peleng.Militiaman'+type_coal);",
                        "  \telse if(PlanetRace(IdToPlanet(bld_ship_planet))==2)bld_ship_name=CT('ShipType.People.Militiaman'+type_coal);",
                        "  \telse if(PlanetRace(IdToPlanet(bld_ship_planet))==3)bld_ship_name=CT('ShipType.Fei.Militiaman'+type_coal);",
                        "  \telse if(PlanetRace(IdToPlanet(bld_ship_planet))==4)bld_ship_name=CT('ShipType.Gaal.Militiaman'+type_coal);",
                        "  \t//Проверочная переменная, что сбор коалиционных донатов начался",
                        "  \tbld_planet_chsn=1;",
                        "  \t//Устанавливаем общую стоимость реализации проекта",
                        "  \tbld_cost=GalaxyTechLevel()*GalaxyDiffLevels()*ship_count*105;",
                        "  \t//Устанавливаем общее время сбора донатов (от 45 до 60 дней)",
                        "  \tbld_day=45+CurTurn()+Rnd(0,15);",
                        "  \t//Задаём общий размер всех пассивных взносов, которые поступят на коалиционный проект",
                        "  \ttemp_int_7=GalaxyDiffLevels();",
                        "  \tif(temp_int_7<=125) dif_koef=bld_cost-round(0.35*bld_cost)+round((0.01*Rnd(0,15))*bld_cost);",
                        "  \tif(temp_int_7>125 && temp_int_7<=250) dif_koef=bld_cost-round(0.45*bld_cost)+round((0.01*Rnd(0,15))*bld_cost);",
                        "  \tif(temp_int_7>250) dif_koef=bld_cost-round(0.60*bld_cost)+round((0.01*Rnd(0,15))*bld_cost);",
                        "  \t//Имеется 11% шанс, что проект окупит себя даже без участия игрока",
                        "  \tif(Rnd(1,100)<=11) dif_koef=bld_cost+33000;",
                        "  \ttemp_int_3=bld_day-CurTurn();",
                        "  \t//Задаём размер ежедневных пассивных взносов на коалиционный проект",
                        "  \tadd_cr_day_1=dif_koef/temp_int_3;",
                        "  }",
                        "  //Создаём пиратский проект Слэпстартера (срабатывает, если предыдущий проект завершён)",
                        "  if(!bld_planet_chsn_2 && ArrayDim(bld_ship_planet_list_2)>1)",
                        "  {",
                        "  \t//Обнуляем сумму возврата в случае не набора проектом требуемой суммы (сумма возврата задаётся при внесении донатов игроком)",
                        "  \trepay_2=0;",
                        "  \t//Число пиратских кораблей",
                        "  \tship_count_2=Rnd(4,8);",
                        "  \ttemp_int=Rnd(1,ArrayDim(bld_ship_planet_list_2)-1);",
                        "  \tbld_ship_planet_2=bld_ship_planet_list_2[temp_int];",
                        "      //Определяем имя пиратского отряда",
                        "      if(PlanetRace(IdToPlanet(bld_ship_planet_2))==0)bld_ship_name_2=CT(\"Script.Mod_ExpPilotBridge.516\");",
                        "      else if(PlanetRace(IdToPlanet(bld_ship_planet_2))==1)bld_ship_name_2=CT(\"Script.Mod_ExpPilotBridge.515\");",
                        "      else if(PlanetRace(IdToPlanet(bld_ship_planet_2))==2)bld_ship_name_2=CT(\"Script.Mod_ExpPilotBridge.514\");",
                        "      else if(PlanetRace(IdToPlanet(bld_ship_planet_2))==3)bld_ship_name_2=CT(\"Script.Mod_ExpPilotBridge.513\");",
                        "      else if(PlanetRace(IdToPlanet(bld_ship_planet_2))==4)bld_ship_name_2=CT(\"Script.Mod_ExpPilotBridge.512\");",
                        "  \t//Проверочная переменная, что сбор пиратских донатов начался",
                        "  \tbld_planet_chsn_2=1;",
                        "  \t//Устанавливаем общую стоимость реализации проекта",
                        "  \tbld_cost_2=GalaxyTechLevel()*GalaxyDiffLevels()*ship_count_2*100;",
                        "  \t//Устанавливаем общее время сбора донатов (от 45 до 60 дней)",
                        "  \tbld_day_2=45+CurTurn()+Rnd(0,15);",
                        "  \t//Задаём общий размер всех пассивных взносов, которые поступят на пиратский проект",
                        "  \ttemp_int_7=GalaxyDiffLevels();",
                        "  \tif(temp_int_7<=125) dif_koef_2=bld_cost_2-round(0.35*bld_cost_2)+round((0.01*Rnd(0,15))*bld_cost);",
                        "  \tif(temp_int_7>125 && temp_int_7<=250) dif_koef_2=bld_cost_2-round(0.45*bld_cost_2)+round((0.01*Rnd(0,15))*bld_cost);",
                        "  \tif(temp_int_7>250) dif_koef_2=bld_cost_2-round(0.60*bld_cost_2)+round((0.01*Rnd(0,15))*bld_cost);",
                        "  \t//Имеется 9% шанс, что проект окупит себя даже без участия игрока",
                        "  \tif(Rnd(1,100)<=9) dif_koef_2=bld_cost_2+27000;",
                        "  \ttemp_int_3=bld_day_2-CurTurn();",
                        "  \t//Задаём размер ежедневных пассивных взносов на пиратский проект",
                        "  \tadd_cr_day_2=dif_koef_2/temp_int_3;",
                        "  }",
                        "  //Идёт пассивный набор донатов на реализацию текущего коалиционного проекта",
                        "  if(bld_day!=0 && bld_day>CurTurn() && credits_now<dif_koef)",
                        "  {",
                        "  \tcredits_now=credits_now+add_cr_day_1;",
                        "  }",
                        "  //Идёт пассивный набор донатов на реализацию текущего пиратского проекта",
                        "  if(bld_day_2!=0 && bld_day_2>CurTurn() && credits_now_2<dif_koef_2)",
                        "  {",
                        "  \tcredits_now_2=credits_now_2+add_cr_day_2;",
                        "  }",
                        "  //Проверка на захват коалиционной системы, в которой находилась планета, собирающая донаты",
                        "  if(bld_day>CurTurn() && ArrayDim(bld_ship_planet_list)>1)",
                        "  {",
                        "  \tif(StarOwner(PlanetToStar(IdToPlanet(bld_ship_planet)))!=0)",
                        "  \t{",
                        "  \t\ttemp_dword=PlanetToStar(IdToPlanet(bld_ship_planet));",
                        "  \t\tbld_day=CurTurn()-10;",
                        "  \t\tif(repay>=100)",
                        "  \t\t{",
                        "  \t\t\tif(PlanetRace(IdToPlanet(bld_ship_planet))==0)temp_int=round(0.90*repay);",
                        "  \t\t\telse if(PlanetRace(IdToPlanet(bld_ship_planet))==1)temp_int=round(0.5*repay);",
                        "  \t\t\telse if(PlanetRace(IdToPlanet(bld_ship_planet))==2)temp_int=round(0.80*repay);",
                        "  \t\t\telse if(PlanetRace(IdToPlanet(bld_ship_planet))==3)temp_int=round(0.90*repay);",
                        "  \t\t\telse if(PlanetRace(IdToPlanet(bld_ship_planet))==4)temp_int=repay;",
                        "  \t\t\tEther('mp_Galaxy','',Format(CT(\"Script.Mod_ExpPilotBridge.708\"),\"<0>\",StarName(temp_dword),\"<1>\",bld_ship_name,\"<2>\",temp_int));",
                        "  \t\t\tShipMoney(Player(),ShipMoney(Player())+temp_int);",
                        "  \t\t\tSound('Sound.Buy');",
                        "  \t\t}",
                        "  \t\tArrayClear(bld_ship_planet_list);",
                        "  \t\tbld_planet_chsn=0;",
                        "  \t\tcredits_now=0;",
                        "  \t\twait_day=CurTurn()+Rnd(5,20);",
                        "  \t}",
                        "  }",
                        "  //Проверка на захват пиратской системы, в которой находилась планета, собирающая донаты",
                        "  if(bld_day_2>CurTurn() && ArrayDim(bld_ship_planet_list_2)>1)",
                        "  {",
                        "  \tif(StarOwner(PlanetToStar(IdToPlanet(bld_ship_planet_2)))!=2 || StarCustomFaction(PlanetToStar(IdToPlanet(bld_ship_planet_2)))!='')",
                        "  \t{",
                        "  \t\ttemp_dword=PlanetToStar(IdToPlanet(bld_ship_planet_2));",
                        "  \t\tbld_day_2=CurTurn()-10;",
                        "  \t\tif(repay_2>=100)",
                        "  \t\t{",
                        "  \t\t\ttemp_int=round(0.75*repay_2);",
                        "  \t\t\tEther('mp_Galaxy','',Format(CT(\"Script.Mod_ExpPilotBridge.708\"),\"<0>\",StarName(temp_dword),\"<1>\",bld_ship_name_2,\"<2>\",temp_int));",
                        "  \t\t\tShipMoney(Player(),ShipMoney(Player())+temp_int);",
                        "  \t\t\tSound('Sound.Buy');",
                        "  \t\t}",
                        "  \t\tArrayClear(bld_ship_planet_list_2);",
                        "  \t\tbld_planet_chsn_2=0;",
                        "  \t\tcredits_now_2=0;",
                        "  \t\twait_day_2=CurTurn()+Rnd(5,20);",
                        "  \t}",
                        "  }",
                        "  //Спавним военных или выдаём сообщение о нехватке денег (если игрок вносил платеж)",
                        "  if(bld_day<=CurTurn() && ArrayDim(bld_ship_planet_list)>1)",
                        "  {",
                        "  \tif(credits_now>=bld_cost)",
                        "  \t{",
                        "  \t\tfor(count2=1;count2<=ship_count;count2=count2+1)",
                        "  \t\t{",
                        "  \t\t\t//Функция спавна военного корабля (тип 1), возвращает корабль",
                        "  \t\t\tSpawnSlapstarter(1,IdToPlanet(bld_ship_planet));",
                        "  \t\t}",
                        "  \t\ttemp_dword=PlanetToStar(IdToPlanet(bld_ship_planet));",
                        "  \t\tif(repay>=100)Ether('mp_Galaxy',CurTurn()+'-1-'+'MERCS',Format(CT(\"Script.Mod_ExpPilotBridge.1467\"),\"<0>\",StarName(temp_dword),\"<1>\",bld_ship_name));",
                        "          AddPlanetNews(Format(CT(\"Script.Mod_ExpPilotBridge.1467\"),\"<0>\",StarName(temp_dword),\"<1>\",bld_ship_name));",
                        "      }",
                        "  \tif(credits_now<bld_cost && repay>=100)",
                        "  \t{",
                        "  \t\tif(PlanetRace(IdToPlanet(bld_ship_planet))==0)temp_int=round(0.90*repay);",
                        "  \t\telse if(PlanetRace(IdToPlanet(bld_ship_planet))==1)temp_int=round(0.5*repay);",
                        "  \t\telse if(PlanetRace(IdToPlanet(bld_ship_planet))==2)temp_int=round(0.80*repay);",
                        "  \t\telse if(PlanetRace(IdToPlanet(bld_ship_planet))==3)temp_int=round(0.90*repay);",
                        "  \t\telse if(PlanetRace(IdToPlanet(bld_ship_planet))==4)temp_int=repay;",
                        "  \t\tEther('mp_Galaxy',CurTurn()+'-1-'+'MERCS',Format(CT(\"Script.Mod_ExpPilotBridge.706\"),\"<0>\",bld_ship_name,\"<1>\",temp_int));",
                        "  \t\tShipMoney(Player(),ShipMoney(Player())+temp_int);",
                        "  \t\tSound('Sound.Sell');",
                        "  \t}",
                        "  \tArrayClear(bld_ship_planet_list);",
                        "  \tbld_planet_chsn=0;",
                        "  \tcredits_now=0;",
                        "  \twait_day=CurTurn()+Rnd(5,20);",
                        "  }",
                        "  //Спавним пиратов или выдаём сообщение о нехватке денег (если игрок вносил платеж)",
                        "  if(bld_day_2<=CurTurn() && ArrayDim(bld_ship_planet_list_2)>1)",
                        "  {",
                        "  \tif(credits_now_2>=bld_cost_2)",
                        "  \t{",
                        "  \t\tfor(count2=1;count2<=ship_count_2;count2=count2+1)",
                        "  \t\t{",
                        "  \t\t\t//Функция спавна пиратского корабля (тип 2), возвращает корабль",
                        "  \t\t\tSpawnSlapstarter(2,IdToPlanet(bld_ship_planet_2));",
                        "  \t\t}",
                        "  \t\ttemp_dword=PlanetToStar(IdToPlanet(bld_ship_planet_2));",
                        "  \t\tif(repay_2>=100)Ether('mp_Galaxy',CurTurn()+'-2-'+'MERCS',Format(CT(\"Script.Mod_ExpPilotBridge.1465\"),\"<0>\",bld_ship_name_2,\"<1>\",StarName(temp_dword)));",
                        "          AddPlanetNews(Format(CT(\"Script.Mod_ExpPilotBridge.1465\"),\"<0>\",bld_ship_name_2,\"<1>\",StarName(temp_dword)));",
                        "      }",
                        "      if(credits_now_2<bld_cost_2 && repay_2>=100)",
                        "  \t{",
                        "  \t\ttemp_int=round(0.75*repay_2);",
                        "  \t\tEther('mp_Galaxy',CurTurn()+'-2-'+'MERCS',Format(CT(\"Script.Mod_ExpPilotBridge.704\"),\"<0>\",bld_ship_name_2,\"<1>\",temp_int));",
                        "  \t\tShipMoney(Player(),ShipMoney(Player())+temp_int);",
                        "  \t\tSound('Sound.Sell');",
                        "  \t}",
                        "  \tArrayClear(bld_ship_planet_list_2);",
                        "  \tbld_planet_chsn_2=0;",
                        "  \tcredits_now_2=0;",
                        "  \twait_day_2=CurTurn()+Rnd(5,20);",
                        "  }",
                        "  if(!InitExpTC) {",
                        "      if(IsScriptActive('Mod_ExpTC')) InitExpTC=1;",
                        "  }",
                        "  ",
                        "  //Создаем проект ТЦ",
                        "  if(!bld_TC_chsn && bld_system_Id_TC) {",
                        "  \trepay_TC=0;//Обнуляем сумму возврата в случае не набора проектом требуемой суммы",
                        "  \ttemp_int=Rnd(1,ArrayDim(bld_ship_planet_list)-1);",
                        "  \tbld_TC_chsn=1;//Проверочная переменная, что сбор коалиционных донатов начался",
                        "  \tbld_cost_TC=GTL*GalaxyDiffLevels()*800+Rnd(GalaxyMoney(2,2),GalaxyMoney(4,4));//Устанавливаем общую стоимость реализации проекта",
                        "  \tbld_day_TC=CurTurn()+Rnd(45,60);//Устанавливаем общее время сбора донатов (от 45 до 60 дней)",
                        "  \ttemp_int_7=GalaxyDiffLevels();//Задаём общий размер всех пассивных взносов, которые поступят на проект",
                        "  \tif(temp_int_7<=125) dif_koef_3=bld_cost_TC-round(0.35*bld_cost_TC)+round((0.01*Rnd(0,15))*bld_cost_TC);",
                        "  \telse if(temp_int_7>125 && temp_int_7<=250) dif_koef_3=bld_cost_TC-round(0.45*bld_cost_TC)+round((0.01*Rnd(0,15))*bld_cost_TC);",
                        "      else dif_koef_3=bld_cost_TC-round(0.60*bld_cost_TC)+round((0.01*Rnd(0,15))*bld_cost_TC);",
                        "  \ttemp_int_3=bld_cost_TC-CurTurn();",
                        "  \tadd_cr_day_TC=dif_koef/temp_int_3;//Задаём размер ежедневных пассивных взносов на проект ТЦ",
                        "  }",
                        "  //Идёт пассивный набор донатов на постройку ТЦ",
                        "  if(bld_day_TC!=0 && bld_day_TC>CurTurn() && credits_now_TC<dif_koef_3) {",
                        "  \tcredits_now_TC=credits_now_TC+add_cr_day_TC;",
                        "  }",
                        "  //Проверка на захват системы, в которой будет построен ТЦ",
                        "  if(bld_day_TC>CurTurn() && bld_system_Id_TC) {",
                        "      temp_dword=GalaxyStar(bld_system_Id_TC-1);",
                        "  \tif(StarOwner(temp_dword) && StarOwner(temp_dword)!=2) {",
                        "  \t\tbld_day_TC=CurTurn()-10;",
                        "  \t\tif(repay_TC>=100) {",
                        "  \t\t\ttemp_int=round(0.90*repay_TC);",
                        "  \t\t\tEther('mp_Galaxy','',Format(CT(\"Script.Mod_ExpPilotBridge.1555\"),\"<0>\",StarName(temp_dword),\"<1>\",temp_int));",
                        "  \t\t\tShipMoney(Player(),ShipMoney(Player())+temp_int);",
                        "  \t\t\tSound('Sound.Buy');",
                        "  \t\t}",
                        "  \t\tbld_system_Id_TC=0;",
                        "  \t\tbld_TC_chsn=0;",
                        "  \t\tcredits_now_TC=0;",
                        "  \t\twait_day_3=CurTurn()+Rnd(5,20);",
                        "  \t}",
                        "  }",
                        "  //Спавним ТЦ или выдаём сообщение о нехватке денег (если игрок вносил платеж)",
                        "  if(bld_day_TC<=CurTurn() && bld_system_Id_TC) {",
                        "  \tif(credits_now_TC>=bld_cost_TC) {",
                        "  \t\tBuyTC(GalaxyStar(bld_system_Id_TC-1));",
                        "      }",
                        "  \tif(credits_now_TC<bld_cost_TC && repay_TC>=100) {",
                        "  \t\ttemp_int=round(0.90*repay_TC);",
                        "  \t\tEther('mp_Galaxy',CurTurn(),Format(CT(\"Script.Mod_ExpPilotBridge.1554\"),\"<0>\",temp_int));",
                        "  \t\tShipMoney(Player(),ShipMoney(Player())+temp_int);",
                        "  \t\tSound('Sound.Sell');",
                        "  \t}",
                        "  \tbld_system_Id_TC=0;",
                        "  \tbld_TC_chsn=0;",
                        "  \tcredits_now_TC=0;",
                        "  \twait_day_3=CurTurn()+Rnd(5,20);",
                        "  }",
                        "}"
                    ],
                    "#": 266,
                    "Type": "Top",
                    "Parent": -1,
                    "Pos.x": 120,
                    "Pos.y": 1510
                },
                {
                    "Name": "",
                    "Code.Type": "DialogBegin",
                    "Code": [
                        "if(GetTalkShip()) {",
                        "  if(!TalkByAI()) {",
                        "    if(~ShipFindCustomShipInfoByType(GetTalkShip(), 'PlayerBridge_ThiefInfo')) {",
                        "      temp_int = ShipFindCustomShipInfoByType(GetTalkShip(), 'PlayerBridge_ThiefInfo');",
                        "      if(ShipCustomShipInfoTextData(GetTalkShip(), temp_int, 1) != 'no_mercy') {",
                        "        if(RelationToRanger(GetTalkShip(), Player()) >= 10 && ShipGetBad(GetTalkShip()) != Player()) {",
                        "          if(ShipCustomShipInfoTextData(GetTalkShip(), temp_int, 1) != 'going_down') {",
                        "            AddDialogInject('ThiefTalk','',CT('Script.Mod_ExpPilotBridge.Oh_hiMark_'+Rnd(1,3)),100);",
                        "          }",
                        "          if(ShipCustomShipInfoTextData(GetTalkShip(), temp_int, 1) == 'going_down') {",
                        "            AddDialogOverride('ISwearIt!',1000);",
                        "          }",
                        "        }",
                        "        if(RelationToRanger(GetTalkShip(), Player()) < 10 || ShipGetBad(GetTalkShip()) == Player()) {",
                        "          temp_int_6=Rnd(1,3);",
                        "          if(temp_int_6==1)temp_str=CT(\"Script.Mod_ExpPilotBridge.1456\");",
                        "          if(temp_int_6==2)temp_str=CT(\"Script.Mod_ExpPilotBridge.1454\");",
                        "          if(temp_int_6==3)temp_str=CT(\"Script.Mod_ExpPilotBridge.1416\");",
                        "          AddDialogInject('NoWay','',temp_str,100);",
                        "        }",
                        "      }",
                        "    }",
                        "  }",
                        "  if(GInitDialogCheck == 2) {",
                        "    GInitDialogCheck=0;",
                        "    AddDialogOverride('DamnYou!',1000);",
                        "  }",
                        "  if(TalkByAI()) {",
                        "    if(~ShipFindCustomShipInfoByType(GetTalkShip(), 'PlayerBridge_ThiefInfo')) {",
                        "      if(GetTalkType() == TalkTruce) {",
                        "        if(!StarBattle(ShipStar(GetTalkShip()))) {",
                        "          temp_int=ShipFindCustomShipInfoByType(GetTalkShip(),'PlayerBridge_ThiefInfo');",
                        "          if(ShipCustomShipInfoTextData(GetTalkShip(),temp_int,1)=='i_will_fear_no_evil')AddDialogOverride('Surrender!',1000);",
                        "          if(ShipCustomShipInfoTextData(GetTalkShip(),temp_int,1)!='i_will_fear_no_evil')",
                        "          {",
                        "          \t//Данные реплики (из temp_str) не подставляются в текущий диалог, но всё равно содержатся в Lang про запас",
                        "          \tif(ShipTypeN(GetTalkShip())==1)",
                        "          \t{",
                        "          \t\ttemp_str=CT('Script.Mod_ExpPilotBridge.WhatYouWant_1');",
                        "          \t\ttemp_str_3=CT('Script.Mod_ExpPilotBridge.AlrightThan_1');",
                        "          \t}",
                        "          \tif(ShipTypeN(GetTalkShip())==2)",
                        "          \t{",
                        "          \t\ttemp_str=CT('Script.Mod_ExpPilotBridge.WhatYouWant_2');",
                        "          \t\ttemp_str_3=CT('Script.Mod_ExpPilotBridge.AlrightThan_2');",
                        "          \t}",
                        "          \tif(ShipTypeN(GetTalkShip())==3)",
                        "          \t{",
                        "          \t\ttemp_str=CT('Script.Mod_ExpPilotBridge.WhatYouWant_3');",
                        "          \t\ttemp_str_3=CT('Script.Mod_ExpPilotBridge.AlrightThan_3');",
                        "          \t}",
                        "          \ttemp_int_6=Rnd(1,3);",
                        "          \tif(temp_int_6==1)temp_str_2=CT(\"Script.Mod_ExpPilotBridge.1407\");",
                        "          \tif(temp_int_6==2)temp_str_2=CT(\"Script.Mod_ExpPilotBridge.1406\");",
                        "          \tif(temp_int_6==3)temp_str_2=CT(\"Script.Mod_ExpPilotBridge.1216\");",
                        "          \tGInitDialogCheck=0;",
                        "          \tAddDialogInject('WhatYouWant?','',CT(\"Script.Mod_ExpPilotBridge.1411\"),100);",
                        "          }",
                        "        }",
                        "      }",
                        "    }",
                        "  }",
                        "}",
                        "if(GetShipPlanet(Player())) {",
                        "  if(GKillQuestCheck == 1) {",
                        "    AddDialogOverride('GoToPrison', 9999);",
                        "  }",
                        "  if(GKillQuestCheck == 2) {",
                        "    AddDialogOverride('OutOfPrison', 9999);",
                        "  }",
                        "}",
                        "if(GetShipPlanet(Player())) {",
                        "  if(GKillQuestCheck==3) {",
                        "    if(GetShipPlanet(Player())==IdToPlanet(EQuestPlanet)) {",
                        "      AddDialogBlock(CT(\"Script.Mod_ExpPilotBridge.1393\"),2);",
                        "      //В нижней фразе использована латинская 'c'",
                        "      AddDialogInject('NotYet','',CT(\"Script.Mod_ExpPilotBridge.1390\"),100);",
                        "    }",
                        "  }",
                        "  if(GKillQuestCheck==4) {",
                        "    if(GetShipPlanet(Player())==IdToPlanet(EQuestPlanet)) {",
                        "      AddDialogInject('',Format(CT(\"Script.Mod_ExpPilotBridge.1398\"),\"<0>\",ShipName(Player()),\"<1>\",EQuestReward)+' '+EQuestExpReward+' '+CT(\"Script.Mod_ExpPilotBridge.1397\"),'set_block',10,1);",
                        "      AddDialogBlock('set_block',2);",
                        "      GCustomQuestsDone=GCustomQuestsDone+1;",
                        "      money_quest=money_quest+EQuestReward;",
                        "      ShipMoney(Player(),ShipMoney(Player())+EQuestReward);",
                        "      exp_quest=exp_quest+EQuestExpReward;",
                        "      ShipFreeExp(Player(),ShipFreeExp(Player())+EQuestExpReward);",
                        "      RelationToRanger(GetShipPlanet(Player()),Player(),100);",
                        "      CustomEther('QuestOk',4,'CustomQuestKillBridge',CT(\"Script.Mod_ExpPilotBridge.1261\")+CT('FormInfo.br')+CT(\"Script.Mod_ExpPilotBridge.1260\")+PlanetName(IdToPlanet(EQuestPlanet))+CT(\"Script.Mod_ExpPilotBridge.1259\")+StarName(PlanetToStar(IdToPlanet(EQuestPlanet)))+'</color>)'+CT('FormInfo.br')+' '+CT('FormInfo.br')+GEQuestText);",
                        "      EQuestReward=0;",
                        "      EQuestExpReward=0;",
                        "      ETimeLeft=0;",
                        "      EQuestPlanet=0;",
                        "      ETargetShip=0;",
                        "      GEQuestText='';",
                        "      GKillQuestCheck=0;",
                        "    }",
                        "  }",
                        "}",
                        "if(GetTalkShip()) {",
                        "  if(!TalkByAI()) {",
                        "    if(ShipFindCustomShipInfoByType(GetTalkShip(),'PlayerBridge_IllWisherInfo')>-1) {",
                        "      temp_int=ShipFindCustomShipInfoByType(GetTalkShip(),'PlayerBridge_IllWisherInfo');",
                        "      if(ShipCustomShipInfoTextData(GetTalkShip(),temp_int,1)!='talked') {",
                        "        AddDialogInject('IllWisherTalk','',CT('Script.Mod_ExpPilotBridge.WishYouWell_'+Rnd(1,3)),10);",
                        "      }",
                        "    }",
                        "  }",
                        "  if(GInitDialogCheck==3) {",
                        "    temp_int=ShipFindCustomShipInfoByType(GetTalkShip(),'PlayerBridge_IllWisherInfo');",
                        "    GInitDialogCheck=0;",
                        "    AddDialogOverride('IllWisherCall',1000);",
                        "  }",
                        "}",
                        "if(PlayerBridge()==12) {",
                        "  AddDialogInject('',CT(\"Script.Mod_ExpPilotBridge.802\"),'BlockThisAnswer',1,1);",
                        "  AddDialogBlock('BlockThisAnswer',2);",
                        "  AddDialogBlock(CT('FormRuins.Bridge.BridgeExit'),2);",
                        "  if(!NoTalkToShip(Player()))",
                        "  {",
                        "  \ttemp_str=CT(\"Script.Mod_ExpPilotBridge.698\");",
                        "  \tAddDialogInject('Comm_OFF',Format(CT(\"Script.Mod_ExpPilotBridge.696\"),\"<0>\",temp_str),CT(\"Script.Mod_ExpPilotBridge.1569\"),15);",
                        "  }",
                        "  else",
                        "  {",
                        "  \ttemp_str=CT(\"Script.Mod_ExpPilotBridge.697\");",
                        "  \tAddDialogInject('Comm_ON',Format(CT(\"Script.Mod_ExpPilotBridge.696\"),\"<0>\",temp_str),CT(\"Script.Mod_ExpPilotBridge.1568\"),15);",
                        "  }",
                        "  if(ShipFindCustomShipInfoByType(Player(), 'PlayerBridge_AutoDisableForsage')==-1)",
                        "  {",
                        "  \ttemp_str=CT(\"Script.Mod_ExpPilotBridge.1563\");",
                        "  \tAddDialogInject('Forsage_ON',Format(CT(\"Script.Mod_ExpPilotBridge.1562\"),\"<0>\",temp_str),CT(\"Script.Mod_ExpPilotBridge.1567\"),14);",
                        "  }",
                        "  else",
                        "  {",
                        "      temp_str=CT(\"Script.Mod_ExpPilotBridge.1565\");",
                        "  \tAddDialogInject('Forsage_OFF',Format(CT(\"Script.Mod_ExpPilotBridge.1562\"),\"<0>\",temp_str),CT(\"Script.Mod_ExpPilotBridge.1566\"),14);",
                        "  }",
                        "  AddDialogInject('BoardComp','',CT(\"Script.Mod_ExpPilotBridge.668\"),-1);",
                        "}",
                        "if(PlayerBridge()==14) {",
                        "  //Меняем вступительное описание в зависимости от того, подключён ли мод ExpBK",
                        "  temp_str=CT(\"Script.Mod_ExpPilotBridge.1542\");",
                        "  AddDialogInject('',temp_str,'BlockThisAnswer',1,1);",
                        "  AddDialogBlock('BlockThisAnswer',2);",
                        "  AddDialogBlock(CT('FormRuins.Bridge.BridgeExit'),2);",
                        "  AddDialogInject('Galanet','',CT(\"Script.Mod_ExpPilotBridge.701\"),-1);",
                        "}",
                        "if(PlayerBridge()==1) {",
                        "  if(!GetShipPlanet(GetShipRuins(Player())) && !GetShipRuins(GetShipRuins(Player()))) {",
                        "    //Если мостик ТИ, то добавляем реплику без текста",
                        "    AddDialogInject('BoardComp','',CT(\"Script.Mod_ExpPilotBridge.154\"),0);",
                        "  }",
                        "  if(GetShipPlanet(GetShipRuins(Player())) || GetShipRuins(GetShipRuins(Player()))) {",
                        "    //Если мостик ТИ, то добавляем реплику без текста",
                        "    AddDialogBlock(CT(\"Script.Mod_ExpPilotBridge.1461\"),2);",
                        "    AddDialogInject('BoardComp','',CT(\"Script.Mod_ExpPilotBridge.154\"),0);",
                        "    if(GotoGov())AddDialogBlock(CT(\"Script.Mod_ExpPilotBridge.1462\"),1);",
                        "    temp_dword=GetShipPlanet(GetShipRuins(Player()));",
                        "    if(temp_dword)",
                        "    {",
                        "        //Делаем проверку на отношение планеты к рейнджеру",
                        "        if(PlanetOwner(temp_dword)!=7)",
                        "        {",
                        "            if(RelationToRanger(temp_dword,Player())<=9)",
                        "            {",
                        "                AddDialogBlock(CT(\"Script.Mod_ExpPilotBridge.1462\"),1);",
                        "            }",
                        "        }",
                        "        //Пиратские планеты не имеют своего отношения (вернее их реальное отношение не применяется к игроку, пока планета пиратская) и наследуют его от Роджерии",
                        "        else",
                        "        {",
                        "            if(RelationToRanger(PlanetPirateClan(),Player())<=9)",
                        "            {",
                        "                AddDialogBlock(CT(\"Script.Mod_ExpPilotBridge.1462\"),1);",
                        "            }",
                        "        }",
                        "    }",
                        "    else if(!ShipInHyperSpace(GetShipRuins(GetShipRuins(Player()))))",
                        "    {",
                        "        //Проверка на блокировку игрока на базе в ExpHullsBases",
                        "        if(IsScriptActive('Mod_ExpHullsBases'))",
                        "        {",
                        "            if(GetValueFromScript('Mod_ExpHullsBases','jumpCheck')!='')AddDialogBlock(CT(\"Script.Mod_ExpPilotBridge.1462\"),1);",
                        "        }",
                        "    }",
                        "    AddDialogInject('LunchIt','',CT(\"Script.Mod_ExpPilotBridge.1462\"),-1);",
                        "    AddDialogInject('LeaveShip','',CT(\"Script.Mod_ExpPilotBridge.1460\"),-2);",
                        "  }",
                        "}",
                        "if(GetTalkShip()>0) {",
                        "  if(GInitDialogCheck==1) {",
                        "    if(GCardPursueCheck==2) {",
                        "      GInitDialogCheck=0;",
                        "      AddDialogOverride('WheresTheMoneyLebowski?',1000);",
                        "    }",
                        "    if(GCardPursueCheck==3) {",
                        "      GInitDialogCheck=0;",
                        "      AddDialogOverride('LetMeTakeAnotherLook',1000);",
                        "    }",
                        "  }",
                        "}",
                        "if(PlayerBridge()==3) {",
                        "  if(!GetShipPlanet(GetShipRuins(Player())) && !GetShipRuins(GetShipRuins(Player()))) {",
                        "    //Если мостик не ТИ, то добавляем реплику с текстом",
                        "    AddDialogInject('BoardComp',CT(\"Script.Mod_ExpPilotBridge.653\"),CT(\"Script.Mod_ExpPilotBridge.154\"),0,1);",
                        "  }",
                        "  if(GetShipPlanet(GetShipRuins(Player())) || GetShipRuins(GetShipRuins(Player()))) {",
                        "    //Если мостик не ТИ, то добавляем реплику с текстом",
                        "    AddDialogBlock(CT(\"Script.Mod_ExpPilotBridge.1461\"),2);",
                        "    AddDialogInject('BoardComp',CT(\"Script.Mod_ExpPilotBridge.653\"),CT(\"Script.Mod_ExpPilotBridge.154\"),0,1);",
                        "    if(GotoGov())AddDialogBlock(CT(\"Script.Mod_ExpPilotBridge.1462\"),1);",
                        "    temp_dword=GetShipPlanet(GetShipRuins(Player()));",
                        "    if(temp_dword)",
                        "    {",
                        "        //Делаем проверку на отношение планеты к рейнджеру",
                        "        if(PlanetOwner(temp_dword)!=7)",
                        "        {",
                        "            if(RelationToRanger(temp_dword,Player())<=9)",
                        "            {",
                        "                AddDialogBlock(CT(\"Script.Mod_ExpPilotBridge.1462\"),1);",
                        "            }",
                        "        }",
                        "        //Пиратские планеты не имеют своего отношения (вернее их реальное отношение не применяется к игроку, пока планета пиратская) и наследуют его от Роджерии",
                        "        else",
                        "        {",
                        "            if(RelationToRanger(PlanetPirateClan(),Player())<=9)",
                        "            {",
                        "                AddDialogBlock(CT(\"Script.Mod_ExpPilotBridge.1462\"),1);",
                        "            }",
                        "        }",
                        "    }",
                        "    else if(!ShipInHyperSpace(GetShipRuins(GetShipRuins(Player()))))",
                        "    {",
                        "        //Проверка на блокировку игрока на базе в ExpHullsBases",
                        "        if(IsScriptActive('Mod_ExpHullsBases'))",
                        "        {",
                        "            if(GetValueFromScript('Mod_ExpHullsBases','jumpCheck')!='')AddDialogBlock(CT(\"Script.Mod_ExpPilotBridge.1462\"),1);",
                        "        }",
                        "    }",
                        "    AddDialogInject('LunchIt','',CT(\"Script.Mod_ExpPilotBridge.1462\"),-1);",
                        "    AddDialogInject('LeaveShip','',CT(\"Script.Mod_ExpPilotBridge.1460\"),-2);",
                        "  }",
                        "}",
                        "if(PlayerBridge()==10) {",
                        "  AddDialogInject('',CT(\"Script.Mod_ExpPilotBridge.1538\"),'BlockThisAnswer',1,1);",
                        "  AddDialogBlock('BlockThisAnswer',2);",
                        "  AddDialogBlock(CT('FormRuins.Bridge.BridgeExit'),2);",
                        "  AddDialogInject('Galanet','',CT(\"Script.Mod_ExpPilotBridge.694\"),15);",
                        "  AddDialogInject('Settings','',CT(\"Script.Mod_ExpPilotBridge.801\"),10);",
                        "  AddDialogInject('Stata','',CT(\"Script.Mod_ExpPilotBridge.654\"),5);",
                        "  AddDialogInject('CompExit','',CT(\"Script.Mod_ExpPilotBridge.655\"),-1);",
                        "}",
                        "if(PlayerBridge()==11) {",
                        "  AddDialogInject('',CT(\"Script.Mod_ExpPilotBridge.216\"),'BlockThisAnswer',1,1);",
                        "  AddDialogBlock('BlockThisAnswer',2);",
                        "  AddDialogBlock(CT('FormRuins.Bridge.BridgeExit'),2);",
                        "  //Инфоцентр",
                        "  AddDialogInject('InfoCenter','',CT(\"Script.Mod_ExpPilotBridge.803\"),20);",
                        "  //Служба доставки",
                        "  if(!CoalitionDefeated())",
                        "  {",
                        "  \tif(cargo_in_way==0)AddDialogInject('del_serv','',CT(\"Script.Mod_ExpPilotBridge.500\"),15);",
                        "  \telse AddDialogInject('DeliveryInfo','',CT(\"Script.Mod_ExpPilotBridge.500\"),15);",
                        "  }",
                        "  if(HullOnWay==0)AddDialogInject('HullTrans','',CT(\"Script.Mod_ExpPilotBridge.1093\"),14);",
                        "  else AddDialogInject('HullTransInfo','',CT(\"Script.Mod_ExpPilotBridge.1093\"),14);",
                        "  //Интерселлар",
                        "  if(IsScriptActive('Mod_ExpAutoSearch'))",
                        "  {",
                        "      //Также проверяем наличие в Галактике хотя бы одного БЦ",
                        "      if(GetValueFromScript('Mod_ExpAutoSearch','TotalBKCount'))AddDialogInject('Intersellar','',CT(\"Script.Mod_ExpPilotBridge.1537\"),9);",
                        "  }",
                        "  else if(IsScriptActive('Mod_ExpBK'))",
                        "  {",
                        "      //Также проверяем наличие в Галактике хотя бы одного БЦ",
                        "      if(GetValueFromScript('Mod_ExpBK','TotalBKCount'))AddDialogInject('Intersellar','',CT(\"Script.Mod_ExpPilotBridge.1537\"),9);",
                        "  }",
                        "  //Слэпстартер",
                        "  if(!CoalitionDefeated())AddDialogInject('Slapstarter','',CT(\"Script.Mod_ExpPilotBridge.970\"),7);",
                        "  //Прочее",
                        "  AddDialogInject('ClearSpace','',CT(\"Script.Mod_ExpPilotBridge.700\"),5);",
                        "  AddDialogInject('Galapedia','',CT(\"Script.Mod_ExpPilotBridge.494\"),5);",
                        "  AddDialogInject('BoardComp','',CT(\"Script.Mod_ExpPilotBridge.154\"),-1);",
                        "}",
                        "if(GetTalkShip()>0) {",
                        "  if(!TalkByAI()) {",
                        "    if(ShipFindCustomShipInfoByType(GetTalkShip(),'PlayerBridge_PiratesPursue')>-1) {",
                        "      if(GCardPursueCheck==1) {",
                        "        AddDialogOverride('WheresTheMoneyLebowski?',1000);",
                        "        GCardPursueCheck=2;",
                        "        for(i=0;i<GroupCount(DebtMG);i=i+1)RelationToRanger(GroupShip(DebtMG,i),Player(),0);",
                        "      }",
                        "      if(GCardPursueCheck>1) {",
                        "        AddDialogOverride('IWannaQuit',1000);",
                        "        SkipGreeting();",
                        "      }",
                        "    }",
                        "  }",
                        "}",
                        "if(PlayerBridge()==13) {",
                        "  AddDialogInject('',CT(\"Script.Mod_ExpPilotBridge.978\"),'BlockThisAnswer',1,1);",
                        "  AddDialogBlock('BlockThisAnswer',2);",
                        "  AddDialogBlock(CT('FormRuins.Bridge.BridgeExit'),2);",
                        "  //Слэпстартер - проекты Коалиции",
                        "  if(ArrayDim(bld_ship_planet_list)>1 && wait_day<=CurTurn())",
                        "  {",
                        "  \tif(PlanetOwner(IdToPlanet(bld_ship_planet))==0)AddDialogInject('ProjMaloc','',CT(\"Script.Mod_ExpPilotBridge.977\"),20);",
                        "  \tif(PlanetOwner(IdToPlanet(bld_ship_planet))==1)AddDialogInject('ProjPeleng','',CT(\"Script.Mod_ExpPilotBridge.976\"),20);",
                        "  \tif(PlanetOwner(IdToPlanet(bld_ship_planet))==2)AddDialogInject('ProjPeople','',CT(\"Script.Mod_ExpPilotBridge.975\"),20);",
                        "  \tif(PlanetOwner(IdToPlanet(bld_ship_planet))==3)AddDialogInject('ProjFei','',CT(\"Script.Mod_ExpPilotBridge.974\"),20);",
                        "  \tif(PlanetOwner(IdToPlanet(bld_ship_planet))==4)AddDialogInject('ProjGaal','',CT(\"Script.Mod_ExpPilotBridge.973\"),20);",
                        "  }",
                        "  if(wait_day>CurTurn())",
                        "  {",
                        "  \tif(PlanetOwner(IdToPlanet(bld_ship_planet))==0)AddDialogInject('','',CT(\"Script.Mod_ExpPilotBridge.994\"),20);",
                        "  \tif(PlanetOwner(IdToPlanet(bld_ship_planet))==0)AddDialogBlock(CT(\"Script.Mod_ExpPilotBridge.994\"),1);",
                        "  \tif(PlanetOwner(IdToPlanet(bld_ship_planet))==1)AddDialogInject('','',CT(\"Script.Mod_ExpPilotBridge.993\"),20);",
                        "  \tif(PlanetOwner(IdToPlanet(bld_ship_planet))==1)AddDialogBlock(CT(\"Script.Mod_ExpPilotBridge.993\"),1);",
                        "  \tif(PlanetOwner(IdToPlanet(bld_ship_planet))==2)AddDialogInject('','',CT(\"Script.Mod_ExpPilotBridge.992\"),20);",
                        "  \tif(PlanetOwner(IdToPlanet(bld_ship_planet))==2)AddDialogBlock(CT(\"Script.Mod_ExpPilotBridge.992\"),1);",
                        "  \tif(PlanetOwner(IdToPlanet(bld_ship_planet))==3)AddDialogInject('','',CT(\"Script.Mod_ExpPilotBridge.991\"),20);",
                        "  \tif(PlanetOwner(IdToPlanet(bld_ship_planet))==3)AddDialogBlock(CT(\"Script.Mod_ExpPilotBridge.991\"),1);",
                        "  \tif(PlanetOwner(IdToPlanet(bld_ship_planet))==4)AddDialogInject('','',CT(\"Script.Mod_ExpPilotBridge.990\"),20);",
                        "  \tif(PlanetOwner(IdToPlanet(bld_ship_planet))==4)AddDialogBlock(CT(\"Script.Mod_ExpPilotBridge.990\"),1);",
                        "  }",
                        "  //Слэпстартер - пиратские проекты",
                        "  if(ArrayDim(bld_ship_planet_list_2)>1 && wait_day_2<=CurTurn())",
                        "  {",
                        "  \tAddDialogInject('ProjPirat','',CT(\"Script.Mod_ExpPilotBridge.972\"),15);",
                        "  }",
                        "  if(wait_day_2>CurTurn())",
                        "  {",
                        "  \tAddDialogInject('','',CT(\"Script.Mod_ExpPilotBridge.989\"),15);",
                        "  \tAddDialogBlock(CT(\"Script.Mod_ExpPilotBridge.989\"),1);",
                        "  }",
                        "  //Постройка ТЦ, если их нет в Галактике",
                        "  if(InitExpTC) {",
                        "      if(bld_system_Id_TC && wait_day_3<=CurTurn()) {",
                        "      \tAddDialogInject('ProjTC','',CT(\"Script.Mod_ExpPilotBridge.1559\"),20);",
                        "      }",
                        "      if(wait_day_3>CurTurn()) {",
                        "          AddDialogInject('','',CT(\"Script.Mod_ExpPilotBridge.1558\"),20);",
                        "      \tAddDialogBlock(CT(\"Script.Mod_ExpPilotBridge.1558\"),1);",
                        "      }",
                        "  }",
                        "  AddDialogInject('Galanet','',CT(\"Script.Mod_ExpPilotBridge.701\"),-1);",
                        "}"
                    ],
                    "#": 267,
                    "Type": "Top",
                    "Parent": -1,
                    "Pos.x": 180,
                    "Pos.y": 1510
                },
                {
                    "Name": "",
                    "Code.Type": "Turn",
                    "Code": [
                        "if(ShipStar(CurShip)==ShipStar(Player())) {",
                        "  //Дублируем запуск форсажа в стейт код, чтобы в конце хода игрок мог видеть, кто из пиратов его использует",
                        "  //В противном случае боты всегда вырубают форсаж к концу хода",
                        "  if((OrderForsage(Player()) || ShipSpeed(Player())>ShipSpeed(CurShip)) && Dist(CurShip,Player())>190 && GCardPursueCheck>1)OrderForsage(CurShip,1);",
                        "}"
                    ],
                    "#": 475,
                    "Type": "Top",
                    "Parent": -1,
                    "Pos.x": 80
                },
                {
                    "Name": "",
                    "Code.Type": "Turn",
                    "Code": [
                        "if(!OrderLock(CurShip)) OrderLock(CurShip,1);",
                        "if(GetShipPlanet(CurShip)) OrderTakeOff(CurShip);",
                        "else if(ShipInNormalSpace(CurShip)) {",
                        "    if(CoordX(CurShip)!=Coord_X_TC && CoordY(CurShip)!=Coord_Y_TC) {",
                        "        OrderMove(CurShip, Coord_X_TC, Coord_Y_TC);",
                        "    }",
                        "    else {",
                        "        if(OrderLock(CurShip)) OrderLock(CurShip,0);",
                        "        ShipOut(CurShip);",
                        "    }",
                        "}"
                    ],
                    "#": 476,
                    "Type": "Top",
                    "Parent": -1,
                    "Pos.x": 160
                },
                {
                    "Name": "",
