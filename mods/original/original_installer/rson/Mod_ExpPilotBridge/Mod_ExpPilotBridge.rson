                    "Parent": -1,
                    "#": 257
                },
                {
                    "Type": "TItem",
                    "Name": "Semerenka",
                    "Class": 5,
                    "Item.Type": 0,
                    "Size": 10,
                    "Level": 1,
                    "Radius": 150,
                    "Owner": 6,
                    "Useless": "",
                    "+Place": "",
                    "Pos.x": 90,
                    "Pos.y": 780,
                    "Parent": -1,
                    "#": 258
                },
                {
                    "Type": "TItem",
                    "Name": "Semerenka_2",
                    "Class": 5,
                    "Item.Type": 0,
                    "Size": 10,
                    "Level": 1,
                    "Radius": 150,
                    "Owner": 6,
