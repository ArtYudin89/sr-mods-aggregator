                        "else",
                        "{",
                        "    if(GetShipPlanet(temp_dword))",
                        "    {",
                        "        if(PlanetOwner(GetShipPlanet(temp_dword)) == None)",
                        "        {",
                        "            ShipType(temp_dword, 'CBRUAlpha');",
                        "        }",
                        "        else ShipType(temp_dword, 'CBRHAlpha');",
                        "    }",
                        "    else if(GetShipRuins(temp_dword)) ShipType(temp_dword, 'CBRHAlpha');",
                        "    else ShipType(temp_dword, 'CBRCAlpha');",
                        "}"
