                        "    else temp_str=temp_str+'</color><clrEnd>'+temp_int+'. <color=0,50,200>'+DeleteTags(Name(temp_dword_2))+Format(CT(\"Script.Mod_ExpPilotBridge.1290\"),\"<0>\",ItemSize(temp_dword_2))+CT(\"Script.Mod_ExpPilotBridge.67\");",
