                        "\ttemp_str_3='</color><color=0,50,200>'+DeleteTags(Name(temp_dword))+'</color> (<color=0,50,200>'+ItemSize(temp_dword)+CT(\"Script.Mod_ExpPilotBridge.1094\");",
