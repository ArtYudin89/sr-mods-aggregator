                        "\t// else if(GTL == 5) transfer_cargo_cost = round((0.00315 * transfer_cargo_size) * (100 * temp_int_1));",
                        "\t// else if(GTL == 6) transfer_cargo_cost = round((0.00315 * transfer_cargo_size) * (110 * temp_int_1));",
                        "\t// else if(GTL == 7) transfer_cargo_cost = round((0.00315 * transfer_cargo_size) * (130 * temp_int_1));",
                        "\t// else if(GTL >= 8) transfer_cargo_cost = round((0.00315 * transfer_cargo_size) * (150 * temp_int_1));",
