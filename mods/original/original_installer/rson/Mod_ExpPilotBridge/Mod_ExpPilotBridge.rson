                        "\tArrayAdd(temp_array_4,CT(\"Script.Mod_ExpPilotBridge.1160\"));//3",
                        "\tArrayAdd(temp_array_4,CT(\"Script.Mod_ExpPilotBridge.1159\"));//4",
