                        "\t\tArrayAdd(temp_array_3,temp_int-1);",
                        "\t}",
                        "\tif(ObjectType(temp_dword)==4)",
                        "\t{",
                        "\t\tif(StarOwner(ShipStar(temp_dword))==1)continue;",
                        "\t\tif(StarCustomFaction(ShipStar(temp_dword))!='')continue;",
                        "        if(StarToCon(ShipStar(temp_dword))==StarToCon(PlanetToStar(PlanetPirateClan())));",
