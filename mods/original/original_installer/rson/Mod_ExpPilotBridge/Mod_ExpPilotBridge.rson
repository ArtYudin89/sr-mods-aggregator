                        "else",
                        "{",
                        "\tif(GetGameOptions('FontDialog') < 3) dist_to = Format(CT(\"Script.Mod_ExpPilotBridge.1123\"),\"<0>\",Dist(HullDelFromId, HullDelEndId));",
                        "\telse dist_to = Format(CT(\"Script.Mod_ExpPilotBridge.1380\"),\"<0>\",Dist(HullDelFromId, HullDelEndId));",
                        "    //Определяем стоимость",
                        "\tif(GTL <= 1) transfer_cargo_cost = round((0.00315 * transfer_cargo_size) * GalaxyMoney(0, 0));",
                        "\telse if(GTL == 2) transfer_cargo_cost = round((0.00315 * transfer_cargo_size) * GalaxyMoney(0, 0));",
                        "\telse if(GTL == 3) transfer_cargo_cost = round((0.00315 * transfer_cargo_size) * GalaxyMoney(0, 0));",
                        "\telse if(GTL == 4) transfer_cargo_cost = round((0.00315 * transfer_cargo_size) * GalaxyMoney(0, 0));",
                        "\telse if(GTL == 5) transfer_cargo_cost = round((0.00315 * transfer_cargo_size) * GalaxyMoney(0, 0));",
                        "\telse if(GTL == 6) transfer_cargo_cost = round((0.00315 * transfer_cargo_size) * GalaxyMoney(0, 0));",
                        "\telse if(GTL == 7) transfer_cargo_cost = round((0.00315 * transfer_cargo_size) * GalaxyMoney(0, 0));",
                        "\telse if(GTL >= 8) transfer_cargo_cost = round((0.00315 * transfer_cargo_size) * GalaxyMoney(0, 0));",
                        "}",
                        "",
                        "//Старые расчёты",
                        "//Если пункт доставки находится в другой системе",
                        "// if(temp_int_1)",
                        "// {",
                        "    // dist_to = \"<clrEnd>До системы назначения: <temp_int_1> пк.\";",
