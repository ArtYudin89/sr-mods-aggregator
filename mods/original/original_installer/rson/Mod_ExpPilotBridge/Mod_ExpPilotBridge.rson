                {
                    "Name": "",
                    "Code.Type": "Turn",
                    "Code": [
                        "point_1=temp_array[temp_int_3];",
                        "point_1_id=Id(point_1);",
                        "point_1_star=temp_array_3[temp_int_3];",
                        "transfer_day=0;",
                        "ArrayClear(transfer_list_can);",
                        "point_2=GAnswerData;",
                        "//Определение типа пункта доставки: 3 - планета, 4 - станция",
                        "//Не обращайте внимания на разницу point_2 и point_3 - это всё система прибытия",
                        "if(ObjectType(GAnswerData)==3)",
                        "{",
                        "\tpoint_2_star=Id(PlanetToStar(GAnswerData))-1;",
                        "\tpoint_3_name=CT(\"Script.Mod_ExpPilotBridge.777\")+PlanetName(GAnswerData);",
                        "\tpoint_3_star_name=StarName(PlanetToStar(GAnswerData));",
                        "\tLTargetType=1;",
                        "}",
                        "if(ObjectType(GAnswerData)==4)",
                        "{",
                        "\tpoint_2_star=Id(ShipStar(GAnswerData))-1;",
                        "\tpoint_3_name=Name(GAnswerData);",
                        "\tpoint_3_star_name=StarName(ShipStar(GAnswerData));",
                        "\tLTargetType=2;",
                        "}",
                        "//Расчёт дистанции до системы назначения и времени в пути",
                        "full_distance=Dist2Star(GalaxyStar(point_1_star),GalaxyStar(point_2_star));",
                        "temp_int_1=round(sqrt(full_distance));",
                        "//Определяем среднее (при выборе ускоренной) время доставки",
                        "if(!temp_int_1)transfer_day=7;",
                        "else if(temp_int_1 && temp_int_1<=9)transfer_day=10;",
                        "else",
                        "{",
                        "\tif(GalaxyTechLevel()==1)transfer_day=temp_int_1+(temp_int_1-1*(temp_int_1/20));",
                        "\telse if(GalaxyTechLevel()==2)transfer_day=temp_int_1+(temp_int_1-2*(temp_int_1/20));",
                        "\telse if(GalaxyTechLevel()==3)transfer_day=temp_int_1+(temp_int_1-3*(temp_int_1/20));",
                        "\telse if(GalaxyTechLevel()==4)transfer_day=temp_int_1+(temp_int_1-4*(temp_int_1/20));",
                        "\telse if(GalaxyTechLevel()==5)transfer_day=temp_int_1+(temp_int_1-5*(temp_int_1/20));",
                        "\telse if(GalaxyTechLevel()==6)transfer_day=temp_int_1+(temp_int_1-6*(temp_int_1/20));",
                        "\telse if(GalaxyTechLevel()==7)transfer_day=temp_int_1+(temp_int_1-7*(temp_int_1/20));",
                        "\telse if(GalaxyTechLevel()==8)transfer_day=temp_int_1+(temp_int_1-8*(temp_int_1/20));",
                        "}",
                        "//Подсчёт веса грузов, а также составление массива предметов на складе пункта отправки",
                        "transfer_cargo_cost=0;",
                        "transfer_cargo_size=0;",
                        "for(i=0;i<StorageItems();i=i+1)",
                        "{",
                        "\tif(ItemType(StorageItems(i))==t_Hull)continue;",
                        "\tif(StorageItemLocation(i)==point_1)",
                        "\t{",
                        "\t\ttransfer_cargo_size=transfer_cargo_size+ItemSize(StorageItems(i));",
                        "\t\tArrayAdd(transfer_list_can,StorageItems(i));",
                        "\t}",
                        "}",
                        "//Переменные для подстановки в диалог",
                        "if(ObjectType(point_1)==3)point_from=CT(\"Script.Mod_ExpPilotBridge.1002\")+' ';",
                        "if(ObjectType(point_1)==4)point_from='';",
                        "//Составляем строку со списком предметов, доступных для отправки со склада",
                        "temp_str='</color>';",
                        "for(i=1;i<ArrayDim(transfer_list_can);i=i+1)",
                        "{",
                        "\ttemp_str=temp_str+i+'. '+'<color=0,50,200>'+Name(transfer_list_can[i])+'</color>'+' (<color=0,50,200>'+ItemSize(transfer_list_can[i])+CT(\"Script.Mod_ExpPilotBridge.771\")+CT(\"Script.Mod_ExpPilotBridge.67\");",
                        "}",
                        "if(GetGameOptions('FontDialog')==0)DefSplt='</color>-------------------------------------------------------------';",
                        "if(GetGameOptions('FontDialog')==1)DefSplt='</color>------------------------------------------';",
                        "if(GetGameOptions('FontDialog')==2)DefSplt='</color>-----------------------------------------';",
                        "if(GetGameOptions('FontDialog')==3)DefSplt='</color>-------------------------------------';",
                        "DChange(14);",
                        "exit;"
                    ],
                    "#": 480,
                    "Type": "Top",
                    "Parent": -1,
                    "Pos.x": 430,
                    "Pos.y": 950
                },
                {
                    "Name": "",
                    "Code.Type": "Turn",
                    "Code": [
                        "//Формирование списка предметов в диалоге и соответствующих ему ответов",
                        "if(GAnswerData>=100000000)temp_int=GAnswerData%100000000;",
                        "else temp_int=GAnswerData;",
                        "temp_int_2=0;",
                        "//Значения переменной temp_int_2: 1 - игрок нажал кнопку \"Добавить\", 2 - игрок нажал кнопку \"Удалить\"",
                        "//Добавляем предмет в список на перевозку",
                        "if(GAnswerData<100000000 && temp_int_2==0)",
                        "{",
                        "\tif(((ItemType(transfer_list_can[temp_int])>=0 && ItemType(transfer_list_can[temp_int])<=7) || ItemType(transfer_list_can[temp_int])==t_Protoplasm || ItemType(transfer_list_can[temp_int])==t_UselessCountableItem) && ItemSize(transfer_list_can[temp_int])>1)",
                        "\t{",
                        "\t\tif((ItemType(transfer_list_can[temp_int])>=0 && ItemType(transfer_list_can[temp_int])<=7) || ItemType(transfer_list_can[temp_int])==t_Protoplasm)",
                        "\t\t{",
                        "\t\t\tif(ItemType(transfer_list_can[temp_int])==0)temp_str='Bm.Items.2Food';",
                        "\t\t\tif(ItemType(transfer_list_can[temp_int])==1)temp_str='Bm.Items.2Medicine';",
                        "\t\t\tif(ItemType(transfer_list_can[temp_int])==2)temp_str='Bm.Items.2Technics';",
                        "\t\t\tif(ItemType(transfer_list_can[temp_int])==3)temp_str='Bm.Items.2Luxury';",
                        "\t\t\tif(ItemType(transfer_list_can[temp_int])==4)temp_str='Bm.Items.2Minerals';",
                        "\t\t\tif(ItemType(transfer_list_can[temp_int])==5)temp_str='Bm.Items.2Alcohol';",
                        "\t\t\tif(ItemType(transfer_list_can[temp_int])==6)temp_str='Bm.Items.2Arms';",
                        "\t\t\tif(ItemType(transfer_list_can[temp_int])==7)temp_str='Bm.Items.2Narcotics';",
                        "\t\t\t//Ноды",
                        "\t\t\tif(ItemType(transfer_list_can[temp_int])==t_Protoplasm)",
                        "\t\t\t{",
                        "\t\t\t\ttemp_str='Bm.Items.2Nod4_s';",
                        "\t\t\t\tif(ItemSize(transfer_list_can[temp_int])<=79)temp_str='Bm.Items.2Nod3_s';",
                        "\t\t\t\tif(ItemSize(transfer_list_can[temp_int])<=59)temp_str='Bm.Items.2Nod2_s';",
                        "\t\t\t\tif(ItemSize(transfer_list_can[temp_int])<=39)temp_str='Bm.Items.2Nod1_s';",
                        "\t\t\t\tif(ItemSize(transfer_list_can[temp_int])<=19)temp_str='Bm.Items.2Nod0_s';",
                        "\t\t\t}",
                        "\t\t}",
                        "\t\tif(ItemType(transfer_list_can[temp_int])==t_UselessCountableItem)",
                        "\t\t{",
                        "\t\t\ttemp_str='Bm.Items.2'+EquipmentImageName(transfer_list_can[temp_int])+'4_s';",
                        "\t\t\tif(ItemSize(transfer_list_can[temp_int])<=79)temp_str='Bm.Items.2'+EquipmentImageName(transfer_list_can[temp_int])+'3_s';",
                        "\t\t\tif(ItemSize(transfer_list_can[temp_int])<=59)temp_str='Bm.Items.2'+EquipmentImageName(transfer_list_can[temp_int])+'2_s';",
                        "\t\t\tif(ItemSize(transfer_list_can[temp_int])<=39)temp_str='Bm.Items.2'+EquipmentImageName(transfer_list_can[temp_int])+'1_s';",
                        "\t\t\tif(ItemSize(transfer_list_can[temp_int])<=19)temp_str='Bm.Items.2'+EquipmentImageName(transfer_list_can[temp_int])+'0_s';",
                        "\t\t}",
                        "\t\ttemp_str_4=CT(\"Script.Mod_ExpPilotBridge.1013\");",
                        "\t\tif(temp_array_5[temp_int]==0)temp_array_5[temp_int]=CountBox(temp_str,temp_str_4,0,ItemSize(transfer_list_can[temp_int]),0,1,ItemSize(transfer_list_can[temp_int]),ItemSize(transfer_list_can[temp_int]),ItemSize(transfer_list_can[temp_int]),ItemSize(transfer_list_can[temp_int]));",
                        "\t\telse temp_array_5[temp_int]=temp_array_5[temp_int]+CountBox(temp_str,temp_str_4,0,ItemSize(transfer_list_can[temp_int])-temp_array_5[temp_int],0,1,ItemSize(transfer_list_can[temp_int])-temp_array_5[temp_int],ItemSize(transfer_list_can[temp_int])-temp_array_5[temp_int],ItemSize(transfer_list_can[temp_int])-temp_array_5[temp_int],ItemSize(transfer_list_can[temp_int])-temp_array_5[temp_int]);",
                        "\t\tif(temp_array_5[temp_int]==ItemSize(transfer_list_can[temp_int]))temp_array_5[temp_int]=-1;",
                        "\t}",
                        "\telse temp_array_5[temp_int]=-1;",
                        "\ttemp_int_2=1;",
                        "}",
                        "//Удаляем предмет из списка на перевозку",
                        "if(GAnswerData>=100000000 && temp_int_2==0)",
                        "{",
                        "\tif(((ItemType(transfer_list_can[temp_int])>=0 && ItemType(transfer_list_can[temp_int])<=7) || ItemType(transfer_list_can[temp_int])==t_Protoplasm || ItemType(transfer_list_can[temp_int])==t_UselessCountableItem) && ItemSize(transfer_list_can[temp_int])>1)",
                        "\t{",
                        "\t\tif((ItemType(transfer_list_can[temp_int])>=0 && ItemType(transfer_list_can[temp_int])<=7) || ItemType(transfer_list_can[temp_int])==t_Protoplasm)",
                        "\t\t{",
                        "\t\t\tif(ItemType(transfer_list_can[temp_int])==0)temp_str='Bm.Items.2Food';",
                        "\t\t\tif(ItemType(transfer_list_can[temp_int])==1)temp_str='Bm.Items.2Medicine';",
                        "\t\t\tif(ItemType(transfer_list_can[temp_int])==2)temp_str='Bm.Items.2Technics';",
                        "\t\t\tif(ItemType(transfer_list_can[temp_int])==3)temp_str='Bm.Items.2Luxury';",
                        "\t\t\tif(ItemType(transfer_list_can[temp_int])==4)temp_str='Bm.Items.2Minerals';",
                        "\t\t\tif(ItemType(transfer_list_can[temp_int])==5)temp_str='Bm.Items.2Alcohol';",
                        "\t\t\tif(ItemType(transfer_list_can[temp_int])==6)temp_str='Bm.Items.2Arms';",
                        "\t\t\tif(ItemType(transfer_list_can[temp_int])==7)temp_str='Bm.Items.2Narcotics';",
                        "\t\t\t//Ноды",
                        "\t\t\tif(ItemType(transfer_list_can[temp_int])==t_Protoplasm)",
                        "\t\t\t{",
                        "\t\t\t\ttemp_str='Bm.Items.2Nod4_s';",
                        "\t\t\t\tif(ItemSize(transfer_list_can[temp_int])<=79)temp_str='Bm.Items.2Nod3_s';",
                        "\t\t\t\tif(ItemSize(transfer_list_can[temp_int])<=59)temp_str='Bm.Items.2Nod2_s';",
                        "\t\t\t\tif(ItemSize(transfer_list_can[temp_int])<=39)temp_str='Bm.Items.2Nod1_s';",
                        "\t\t\t\tif(ItemSize(transfer_list_can[temp_int])<=19)temp_str='Bm.Items.2Nod0_s';",
                        "\t\t\t}",
                        "\t\t}",
                        "\t\tif(ItemType(transfer_list_can[temp_int])==t_UselessCountableItem)",
                        "\t\t{",
                        "\t\t\ttemp_str='Bm.Items.2'+EquipmentImageName(transfer_list_can[temp_int])+'4_s';",
                        "\t\t\tif(ItemSize(transfer_list_can[temp_int])<=79)temp_str='Bm.Items.2'+EquipmentImageName(transfer_list_can[temp_int])+'3_s';",
                        "\t\t\tif(ItemSize(transfer_list_can[temp_int])<=59)temp_str='Bm.Items.2'+EquipmentImageName(transfer_list_can[temp_int])+'2_s';",
                        "\t\t\tif(ItemSize(transfer_list_can[temp_int])<=39)temp_str='Bm.Items.2'+EquipmentImageName(transfer_list_can[temp_int])+'1_s';",
                        "\t\t\tif(ItemSize(transfer_list_can[temp_int])<=19)temp_str='Bm.Items.2'+EquipmentImageName(transfer_list_can[temp_int])+'0_s';",
                        "\t\t}",
                        "\t\ttemp_str_4=CT(\"Script.Mod_ExpPilotBridge.1012\");",
                        "\t\tif(temp_array_5[temp_int]==-1)temp_array_5[temp_int]=ItemSize(transfer_list_can[temp_int])-CountBox(temp_str,temp_str_4,0,ItemSize(transfer_list_can[temp_int]),0,1,ItemSize(transfer_list_can[temp_int]),ItemSize(transfer_list_can[temp_int]),ItemSize(transfer_list_can[temp_int]),ItemSize(transfer_list_can[temp_int]));",
                        "\t\telse temp_array_5[temp_int]=temp_array_5[temp_int]-CountBox(temp_str,temp_str_4,0,temp_array_5[temp_int],0,1,temp_array_5[temp_int],temp_array_5[temp_int],temp_array_5[temp_int],temp_array_5[temp_int]);",
                        "\t}",
                        "\telse temp_array_5[temp_int]=0;",
                        "\ttemp_int_2=2;",
                        "}",
                        "temp_int=0;",
                        "temp_str='';",
                        "//Заполняем строку с содержанием списка",
                        "for(i=1;i<ArrayDim(temp_array_5);i=i+1)",
                        "{",
                        "\t//Нажали \"Добавить\"",
                        "\tif(temp_int_2==1)",
                        "\t{",
                        "\t\tif(temp_array_5[i]==-1)",
                        "\t\t{",
                        "\t\t\ttemp_array_2[i]=Name(transfer_list_can[i])+' (<color=0,50,200>'+ItemSize(transfer_list_can[i])+'</color>';",
                        "\t\t\ttemp_int=temp_int+1;",
                        "\t\t\ttemp_str=temp_str+'</color>'+temp_int+'. '+temp_array_6[i]+CT(\"Script.Mod_ExpPilotBridge.67\");",
                        "\t\t}",
                        "\t\tif(temp_array_5[i]>0)",
                        "\t\t{",
                        "\t\t\ttemp_array_2[i]=Name(transfer_list_can[i])+' (<color=0,50,200>'+(ItemSize(transfer_list_can[i])-temp_array_5[i])+'</color>';",
                        "\t\t\ttemp_array_4[i]=Name(transfer_list_can[i])+' (<color=0,50,200>'+temp_array_5[i]+'</color>';",
                        "\t\t\ttemp_int=temp_int+1;",
                        "\t\t\ttemp_str=temp_str+'</color>'+temp_int+'. </color><color=0,50,200>'+DeleteTags(Name(transfer_list_can[i]))+'</color> (<color=0,50,200>'+temp_array_5[i]+CT(\"Script.Mod_ExpPilotBridge.771\")+CT(\"Script.Mod_ExpPilotBridge.67\");",
                        "\t\t}",
                        "\t}",
                        "\t//Нажали \"Удалить\"",
                        "\tif(temp_int_2==2)",
                        "\t{",
                        "\t\tif(temp_array_5[i]==0)temp_array_2[i]=Name(transfer_list_can[i])+' (<color=0,50,200>'+ItemSize(transfer_list_can[i])+'</color>';",
                        "\t\tif(temp_array_5[i]>0)",
                        "\t\t{",
                        "\t\t\ttemp_array_2[i]=Name(transfer_list_can[i])+' (<color=0,50,200>'+(ItemSize(transfer_list_can[i])-temp_array_5[i])+'</color>';",
                        "\t\t\ttemp_array_4[i]=Name(transfer_list_can[i])+' (<color=0,50,200>'+temp_array_5[i]+'</color>';",
                        "\t\t\ttemp_int=temp_int+1;",
                        "\t\t\ttemp_str=temp_str+'</color>'+temp_int+'. </color><color=0,50,200>'+DeleteTags(Name(transfer_list_can[i]))+'</color> (<color=0,50,200>'+temp_array_5[i]+CT(\"Script.Mod_ExpPilotBridge.771\")+CT(\"Script.Mod_ExpPilotBridge.67\");",
                        "\t\t}",
                        "\t}",
                        "}",
                        "if(temp_int==0)temp_str=CT('FormInfo.td_otstup_CargoList')+CT(\"Script.Mod_ExpPilotBridge.1009\");",
                        "//Установка длины \"дефисного разделителя\" в зависимости от выбранного в игре размера шрифта",
                        "if(GetGameOptions('FontDialog')==0)DefSplt='</color>-----------------------------';",
                        "if(GetGameOptions('FontDialog')==1)DefSplt='</color>-------------------------';",
                        "if(GetGameOptions('FontDialog')==2)DefSplt='</color>--------------------------';",
                        "if(GetGameOptions('FontDialog')==3)DefSplt='</color>-------------------------';",
                        "DChange(16);",
                        "exit;"
                    ],
                    "#": 481,
                    "Type": "Top",
                    "Parent": -1,
                    "Pos.x": 580,
                    "Pos.y": 950
                },
                {
                    "Name": "",
                    "Code.Type": "Turn",
                    "Code": [
                        "ArrayClear(transfer_list_done);",
                        "ArrayClear(temp_array_6);",
                        "transfer_cargo_cost=0;",
                        "transfer_cargo_size=0;",
                        "//Составляем предотправочный список",
                        "//Массив temp_array_6 нужен для записи выбранного \"количества\" сыпучих предметов",
                        "for(i=1;i<ArrayDim(temp_array_5);i=i+1)",
                        "{",
                        "\tif(temp_array_5[i]==-1 || temp_array_5[i]>0)",
                        "\t{",
                        "\t\ttemp_dword=transfer_list_can[i];",
                        "\t\tif(temp_array_5[i]==-1)transfer_cargo_size=transfer_cargo_size+ItemSize(temp_dword);",
                        "\t\telse transfer_cargo_size=transfer_cargo_size+temp_array_5[i];",
                        "\t\tArrayAdd(transfer_list_done,temp_dword);",
                        "\t\tArrayAdd(temp_array_6,temp_array_5[i]);",
                        "\t}",
                        "}",
                        "//Переменная transfer_day_start используется как времянка для записи значения идущего в разговорный ответ для времени курьерской доставки",
                        "//Это не истинный смысл существования данной переменной, дальше она будет перезаписана уже нормальным значением",
                        "//Ниже идёт прописка подстановочной переменной для курьерского вида доставки",
                        "//Если этого не делать, то разница между курьерским и ускоренным видом доставки на минимальных временных отрезках будет составлять всего 1 день - не круто",
                        "if(transfer_day <= 7) transfer_day_start = 5;",
                        "else if(transfer_day == 8) transfer_day_start = 6;",
                        "else if(transfer_day == 9) transfer_day_start = 7;",
                        "else transfer_day_start = (-0.25 * transfer_day) + transfer_day;",
                        "",
                        "//Если пункт доставки находится в другой системе",
                        "if(temp_int_1)",
                        "{",
                        "    dist_to = Format(CT(\"Script.Mod_ExpPilotBridge.805\"),\"<0>\",temp_int_1);",
                        "    //Определяем стоимость",
                        "\tif(GTL <= 1) transfer_cargo_cost = ((GalaxyMoney(0, 0) / 25) * transfer_cargo_size) + (40 * temp_int_1);",
                        "\telse if(GTL == 2) transfer_cargo_cost = ((GalaxyMoney(0, 0) / 25) * transfer_cargo_size) + (50 * temp_int_1);",
                        "\telse if(GTL == 3) transfer_cargo_cost = ((GalaxyMoney(0, 0) / 25) * transfer_cargo_size) + (60 * temp_int_1);",
                        "\telse if(GTL == 4) transfer_cargo_cost = ((GalaxyMoney(0, 0) / 25) * transfer_cargo_size) + (70 * temp_int_1);",
                        "\telse if(GTL == 5) transfer_cargo_cost = ((GalaxyMoney(0, 0) / 25) * transfer_cargo_size) + (80 * temp_int_1);",
                        "\telse if(GTL == 6) transfer_cargo_cost = ((GalaxyMoney(0, 0) / 25) * transfer_cargo_size) + (90 * temp_int_1);",
                        "\telse if(GTL == 7) transfer_cargo_cost = ((GalaxyMoney(0, 0) / 25) * transfer_cargo_size) + (105 * temp_int_1);",
                        "\telse if(GTL >= 8) transfer_cargo_cost = ((GalaxyMoney(0, 0) / 25) * transfer_cargo_size) + (120 * temp_int_1);",
                        "}",
                        "//Если пункт доставки находится в той же системе",
                        "else",
                        "{",
                        "\tif(GetGameOptions('FontDialog') < 3) dist_to = Format(CT(\"Script.Mod_ExpPilotBridge.1123\"),\"<0>\",Dist(point_1, point_2));",
                        "\telse dist_to = Format(CT(\"Script.Mod_ExpPilotBridge.1380\"),\"<0>\",Dist(point_1, point_2));",
                        "    //Определяем стоимость",
                        "\tif(GTL <= 1) transfer_cargo_cost = ((GalaxyMoney(0, 0) / 25) * transfer_cargo_size) + 100;",
                        "\telse if(GTL == 2) transfer_cargo_cost = ((GalaxyMoney(0, 0) / 25) * transfer_cargo_size) + 150;",
                        "\telse if(GTL == 3) transfer_cargo_cost = ((GalaxyMoney(0, 0) / 25) * transfer_cargo_size) + 200;",
                        "\telse if(GTL == 4) transfer_cargo_cost = ((GalaxyMoney(0, 0) / 25) * transfer_cargo_size) + 250;",
                        "\telse if(GTL == 5) transfer_cargo_cost = ((GalaxyMoney(0, 0) / 25) * transfer_cargo_size) + 300;",
                        "\telse if(GTL == 6) transfer_cargo_cost = ((GalaxyMoney(0, 0) / 25) * transfer_cargo_size) + 350;",
                        "\telse if(GTL == 7) transfer_cargo_cost = ((GalaxyMoney(0, 0) / 25) * transfer_cargo_size) + 500;",
                        "\telse if(GTL >= 8) transfer_cargo_cost = ((GalaxyMoney(0, 0) / 25) * transfer_cargo_size) + 650;",
                        "}",
                        "",
                        "//Старые расчёты",
                        "//Если пункт доставки находится в другой системе",
                        "// if(temp_int_1)",
                        "// {",
                        "    // dist_to = \"<clrEnd>До системы назначения: <temp_int_1> пк.\";",
                        "    //Определяем стоимость",
                        "\t// if(GTL <= 1) transfer_cargo_cost = (15 * transfer_cargo_size) + (40 * temp_int_1);",
                        "\t// else if(GTL == 2) transfer_cargo_cost = (25 * transfer_cargo_size) + (50 * temp_int_1);",
                        "\t// else if(GTL == 3) transfer_cargo_cost = (35 * transfer_cargo_size) + (60 * temp_int_1);",
                        "\t// else if(GTL == 4) transfer_cargo_cost = (45 * transfer_cargo_size) + (70 * temp_int_1);",
                        "\t// else if(GTL == 5) transfer_cargo_cost = (60 * transfer_cargo_size) + (80 * temp_int_1);",
                        "\t// else if(GTL == 6) transfer_cargo_cost = (70 * transfer_cargo_size) + (90 * temp_int_1);",
                        "\t// else if(GTL == 7) transfer_cargo_cost = (85 * transfer_cargo_size) + (105 * temp_int_1);",
                        "\t// else if(GTL >= 8) transfer_cargo_cost = (100 * transfer_cargo_size) + (120 * temp_int_1);",
                        "// }",
                        "//Если пункт доставки находится в той же системе",
                        "// else",
                        "// {",
                        "\t// if(GetGameOptions('FontDialog') < 3) dist_to = \"<clrEnd>До места назначения: <Dist(point_1, point_2)> млн. км.\";",
                        "\t// else dist_to = \"<clrEnd>До места назнач.: <Dist(point_1, point_2)> млн. км.\";",
                        "    //Определяем стоимость",
                        "\t// if(GTL <= 1) transfer_cargo_cost = (15 * transfer_cargo_size) + 100;",
                        "\t// else if(GTL == 2) transfer_cargo_cost = (25 * transfer_cargo_size) + 150;",
                        "\t// else if(GTL == 3) transfer_cargo_cost = (35 * transfer_cargo_size) + 200;",
                        "\t// else if(GTL == 4) transfer_cargo_cost = (45 * transfer_cargo_size) + 250;",
                        "\t// else if(GTL == 5) transfer_cargo_cost = (60 * transfer_cargo_size) + 300;",
                        "\t// else if(GTL == 6) transfer_cargo_cost = (70 * transfer_cargo_size) + 350;",
                        "\t// else if(GTL == 7) transfer_cargo_cost = (85 * transfer_cargo_size) + 500;",
                        "\t// else if(GTL >= 8) transfer_cargo_cost = (100 * transfer_cargo_size) + 650;",
                        "// }",
                        "",
                        "//Установка минимальной цены доставки",
                        "if(transfer_cargo_cost < 1875 && (GTL == 1 || GTL == 2 || GTL == 3)) transfer_cargo_cost = 1875;",
                        "else if(transfer_cargo_cost < 2500 && (GTL == 4 || GTL == 5 || GTL == 6)) transfer_cargo_cost = 2500;",
                        "else if(transfer_cargo_cost < 5000 && (GTL == 7 || GTL == 8)) transfer_cargo_cost = 5000;",
                        "//Установка \"дефисного разделителя\" в зависимости от размера шрифта в настройках игры",
                        "if(GetGameOptions('FontDialog') == '0') DefSplt = '</color>-------------------------------------';",
                        "else if(GetGameOptions('FontDialog') == '1') DefSplt = '</color>--------------------------------';",
                        "else if(GetGameOptions('FontDialog') == '2') DefSplt = '</color>----------------------------------';",
                        "else DefSplt = '</color>--------------------------------';",
                        "DChange(21);",
                        "exit;"
                    ],
                    "#": 482,
                    "Type": "Top",
                    "Parent": -1,
                    "Pos.x": 730,
                    "Pos.y": 950
                },
                {
                    "Name": "",
                    "Code.Type": "Turn",
                    "Code": [
                        "temp_int_3=GAnswerData;",
                        "DChange(17);",
                        "exit;"
                    ],
                    "#": 483,
                    "Type": "Top",
                    "Parent": -1,
                    "Pos.x": 880,
                    "Pos.y": 950
                },
                {
                    "Name": "",
                    "Code.Type": "Turn",
                    "Code": [
                        "//Формируется строка оглавления Галапедии",
                        "temp_str=CT('Galapedia.TotalPages');",
                        "temp_int=temp_str;",
                        "temp_str='';",
                        "for(i=1;i<temp_int+1;i=i+1)",
                        "{",
                        "    temp_str=temp_str+'</color>'+i+'. <color=0,50,200>'+CT('Galapedia.'+i+'.Name')+CT(\"Script.Mod_ExpPilotBridge.67\");",
                        "}",
                        "//Добавляем в конце раздел биомодулей, если мод ExpImplant подключён",
                        "if(IsScriptActive('Mod_ExpImplants'))temp_str=temp_str+'</color>'+(i+1)+'. <color=0,50,200>'+CT(\"Script.Mod_ExpPilotBridge.661\")+CT(\"Script.Mod_ExpPilotBridge.67\");",
                        "DChange(18);",
                        "exit;"
                    ],
                    "#": 484,
                    "Type": "Top",
                    "Parent": -1,
                    "Pos.x": 1060,
                    "Pos.y": 950
                },
                {
                    "Name": "",
                    "Code.Type": "Turn",
                    "Code": [
                        "temp_int_2=GAnswerData;",
                        "temp_int_3=1;",
                        "//Был выбран стандартный раздел",
                        "if(temp_int_2!=9999)",
                        "{",
                        "    //Сразу выбирается первый абзац (страница) выбранного раздела",
                        "    temp_str='</color>'+CT('Galapedia.'+temp_int_2+'.'+temp_int_3);",
                        "}",
                        "//Был выбран раздел с биомодулями",
                        "else",
                        "{",
                        "    //Выбирается общее описание биомодулей",
                        "    temp_str='</color>'+CT('Galapedia.BioMM.Text');",
                        "}",
                        "DChange(19);",
                        "exit;"
                    ],
                    "#": 485,
                    "Type": "Top",
                    "Parent": -1,
                    "Pos.x": 1210,
                    "Pos.y": 950
                },
                {
                    "Name": "",
                    "Code.Type": "Turn",
                    "Code": [
                        "//Если игрок выбрал следующую страницу в стандартном разделе, подгружаем её",
                        "if(temp_int_2 != 9999)",
                        "{",
                        "    temp_str = '</color>'+CT('Galapedia.'+temp_int_2+'.'+GAnswerData);",
                        "}",
                        "//Если был выбран конкретный биомодуль из раздела биомодулей, то подгружаем его описание",
                        "else",
                        "{",
                        "    temp_str=GAnswerData;",
                        "    //\"Дешифруем\" из числа номер ГТУ",
                        "    temp_int_3=substr(temp_str,0,1);",
                        "    //И номер самого импланта",
                        "    temp_int_7=substr(temp_str,1);",
                        "    //Формируем общую строку с полным описанием биомодуля",
                        "    temp_str_4=CT(\"Script.Mod_ExpPilotBridge.664\")+' '+CT('Biomodules.'+temp_int_3+'_gtu.'+temp_int_7+'.Name')+CT(\"Script.Mod_ExpPilotBridge.67\");",
                        "    temp_str_4=temp_str_4+CT(\"Script.Mod_ExpPilotBridge.663\")+' '+CT('Biomodules.'+temp_int_3+'_gtu.'+temp_int_7+'.Description')+CT(\"Script.Mod_ExpPilotBridge.662\");",
                        "    temp_str=temp_str_4;",
                        "}",
                        "DChange(20);",
                        "exit;"
                    ],
                    "#": 486,
                    "Type": "Top",
                    "Parent": -1,
                    "Pos.x": 1450,
                    "Pos.y": 950
                },
                {
                    "Name": "",
                    "Code.Type": "Turn",
                    "Code": [
                        "NoTalkToShip(Player(),1);",
                        "DAnswer('main');",
                        "Sound('Sound.ButtonInfoEnter');"
                    ],
                    "#": 487,
                    "Type": "Top",
                    "Parent": -1,
                    "Pos.x": 1660,
                    "Pos.y": 950
                },
                {
                    "Name": "",
                    "Code.Type": "Turn",
                    "Code": [
                        "plan_bat = PlayerPlanetaryBattlesCompleted();",
                        "txt_q_ok = PlayerQuestsCompleted(2);",
                        "SendQuestsOK = PlayerQuestsCompleted(0);",
                        "KillQuestsOK = PlayerQuestsCompleted(1);",
                        "DefSysQuestsOK = PlayerQuestsCompleted(3);",
                        "DefShipQuestsOK = PlayerQuestsCompleted(4);",
                        "//temp_str = CT('FormInfo.align_right') + CT('FormInfo.td_otstup_230') + CT('FormInfo.align_close');",
                        "//temp_str_2 = CT('FormInfo.align_right') + CT('FormInfo.td_otstup_240') + CT('FormInfo.align_close');",
                        "temp_str = CT('FormInfo.align_right') + CT('FormInfo.td_otstup_240') + CT('FormInfo.align_close');",
                        "",
                        "//Считаем проваленные текстовые квесты",
                        "TextQuestsFailed = 0;",
                        "for(i = 0; i <= 71; i = i + 1)",
                        "{",
                        "    if(QuestsStatusByNom(2, i) == 4) TextQuestsFailed = TextQuestsFailed + 1;",
                        "}",
                        "",
                        "//Считаем проваленные правительственные задания",
                        "//SendLetter",
                        "SendQuestsFailed = 0;",
                        "for(i = 0; i <= 86; i = i + 1)",
                        "{",
                        "    if(QuestsStatusByNom(0, i) == 4) SendQuestsFailed = SendQuestsFailed + 1;",
                        "}",
                        "//KillShip",
                        "KillQuestsFailed = 0;",
                        "for(i = 0; i <= 64; i = i + 1)",
                        "{",
                        "    if(QuestsStatusByNom(1, i) == 4) KillQuestsFailed = KillQuestsFailed + 1;",
                        "}",
                        "//DefSystem",
                        "DefSysQuestsFailed = 0;",
                        "for(i = 0; i <= 55; i = i + 1)",
                        "{",
                        "    if(QuestsStatusByNom(3, i) == 4) DefSysQuestsFailed = DefSysQuestsFailed + 1;",
                        "}",
                        "//DefShip",
                        "DefShipQuestsFailed = 0;",
                        "for(i = 0; i <= 58; i = i + 1)",
                        "{",
                        "    if(QuestsStatusByNom(4, i) == 4) DefShipQuestsFailed = DefShipQuestsFailed + 1;",
                        "}",
                        "",
                        "//Открываем счетчики для подключённых модов",
                        "//Проверка на подключение мода ExpTraitors (изменники)",
                        "LRangPirStat = '';",
                        "if(IsScriptActive('Mod_ExpTraitors'))",
                        "{",
                        "    LRangPirStat = '</color>' + Format(CT('Script.Mod_ExpPilotBridge.PersonalStatistic.DetailedShipsStatsTraitors'), '<KillTraitors' + '>', temp_str + GRangPirStat);",
                        "}",
                        "",
                        "//Проверка на подключение мода ShuSmugglers (контрабандисты)",
                        "LPirSmugStat = '';",
                        "if(IsScriptActive('Mod_ShuSmugglers'))",
                        "{",
                        "    LPirSmugStat = '</color>' + Format(CT('Script.Mod_ExpPilotBridge.PersonalStatistic.DetailedShipsStatsSmugglers'), '<KillSmugglers' + '>', temp_str + GPirSmugStat);",
                        "}",
                        "",
                        "//Проверка на подключение мода ShuMercs (наёмники)",
                        "temp_int_6 = 0;",
                        "LMercStat = '';",
                        "LMercLine = '<clr><clrEnd>'; //Если ShuMercs не подключён, здесь будет пропуск строки",
                        "if(IsScriptActive('Mod_ShuMercs'))",
                        "{",
                        "    if(G_MercCStat == -1) G_MercCStat = 0; //Вроде бы это костыль для синхронизации переменной с ShuMercs",
                        "    LMercStat = '</color>' + Format(CT('Script.Mod_ExpPilotBridge.PersonalStatistic.TotalStatsKillMercs'), '<KillMercs' + '>', temp_str + GMercStat);",
                        "    LMercLine = '</color>' + Format(CT('Script.Mod_ExpPilotBridge.PersonalStatistic.DetailedShipsStatsMercs'),",
                        "                     '<KillAtlants' + '>', temp_str + GMercAtlStat,",
                        "                     '<KillRedAxes' + '>', temp_str + GMercAxeStat,",
                        "                     '<KillFaeys' + '>', temp_str + GMercFeiStat,",
                        "                     '<KillFreelancers' + '>', temp_str + GMercFreeStat,",
                        "                     '<KillOtherMercs' + '>', temp_str + GMercOtherStat,",
                        "                     '<KillMercenaryCenters' + '>', temp_str + G_MercCStat",
                        "                     );",
                        "}",
                        "else temp_int_6 = GMercFreeStat; //Считаем встроенных в мод мостика фрилансеров как простых рейнджеров, если ShuMercs не подключён",
                        "",
                        "//Проверка на подключение мода ShuMiniBoss (баттлстары, баржи, прокси и супердоминаторы)",
                        "LSupDomStat = '';",
                        "if(CT('ShuDomiks.ShuSuperdominator'))",
                        "{",
                        "    LSupDomStat = '</color>' + Format(CT('Script.Mod_ExpPilotBridge.PersonalStatistic.DetailedShipsStatsDomikSupers'), '<KillDomikSupers' + '>', temp_str + GSupDomStat);",
                        "}",
                        "",
                        "//Проверка на подключение мода ShuDomiks (верфи и ингибиторы)",
                        "L_IngBStat = '';",
                        "L_DomBStat = '';",
                        "if(IsScriptActive('Mod_ShuDomiks'))",
                        "{",
                        "    L_IngBStat = '</color>' + Format(CT('Script.Mod_ExpPilotBridge.PersonalStatistic.DetailedShipsStatsInhibitors'), '<KillInhibitors' + '>', temp_str + G_IngBStat);",
                        "    L_DomBStat = '</color>' + Format(CT('Script.Mod_ExpPilotBridge.PersonalStatistic.DetailedShipsStatsDomikShipyards'), '<KillDomikShipyards' + '>', temp_str + G_DomBStat);",
                        "}",
                        "",
                        "//Проверка на подключение мода ShuKlissan (клисане и нейролинки)",
                        "LKlissanStat = '';",
                        "LKlissanLine = '<clr><clrEnd>'; //Если ShuKlissan не подключён, здесь будет пропуск строки",
                        "if(IsScriptActive('Mod_ShuKlissan'))",
                        "{",
                        "    LKlissanStat = '</color>' + Format(CT('Script.Mod_ExpPilotBridge.PersonalStatistic.TotalStatsKillKlissan'), '<KillKlissan' + '>', temp_str + GKlissanStat);",
                        "    LKlissanLine = '</color>' + Format(CT('Script.Mod_ExpPilotBridge.PersonalStatistic.DetailedShipsStatsKlissan'),",
                        "                     '<KillMutonies' + '>', temp_str + GKlissMutStat,",
                        "                     '<KillMonchiks' + '>', temp_str + GKlissRogStat,",
                        "                     '<KillCatauris' + '>', temp_str + GKlissKatStat,",
                        "                     '<KillNonduses' + '>', temp_str + GKlissNonStat,",
                        "                     '<KillEgemons' + '>', temp_str + GKlissEgeStat,",
                        "                     '<KillNeurolinks' + '>', temp_str + G_KBStat",
                        "                     );",
                        "}",
                        "",
                        "//Проверка на подключение мода ExpTC (техн. центры)",
                        "L_TCStat = '';",
                        "if(IsScriptActive('Mod_ExpTC'))",
                        "{",
                        "    L_TCStat = '</color>' + Format(CT('Script.Mod_ExpPilotBridge.PersonalStatistic.DetailedShipsStatsTechnologicalCenters'), '<KillTechnologicalCenters' + '>', temp_str + G_TCStat);",
                        "}",
                        "",
                        "LArmWarStat = '';",
                        "LArmPirStat = '';",
                        "if(IsScriptActive('Mod_EvoArmada'))",
                        "{",
                        "    LArmWarStat = '</color>' + Format(CT('Script.Mod_ExpPilotBridge.PersonalStatistic.DetailedShipsStatsDreadnoughts'), '<KillDreadnoughts' + '>', temp_str + GWarDreadStat);",
                        "    LArmPirStat = '</color>' + Format(CT('Script.Mod_ExpPilotBridge.PersonalStatistic.DetailedShipsStatsPirateCapitals'),",
                        "                     '<KillCorvettes' + '>', temp_str + GPirCorvStat,",
                        "                     '<KillFrigates' + '>', temp_str + GPirFrigStat,",
                        "                     '<KillGalleons' + '>', temp_str + GPirGallStat",
                        "                     );",
                        "}",
                        "",
                        "LPirSpecStat = '';",
                        "if(IsScriptActive('Mod_ShuPirates'))",
                        "{",
                        "    LPirSpecStat = '</color>' + Format(CT('Script.Mod_ExpPilotBridge.PersonalStatistic.DetailedShipsStatsPirateSpecials'),",
                        "                     '<KillThugs' + '>', temp_str + GPirThugStat,",
                        "                     '<KillKhans' + '>', temp_str + GPirKhanStat",
                        "                     );",
                        "}",
                        "",
                        "//Графа \"Прочих: [станций]\" на основном экране статистики",
                        "//Полностью пропадает если ни один из модов: Mod_ShuDomiks, ShuKlissan и ShuMercs не подключён",
                        "L_OtherStStat = '';",
                        "if(IsScriptActive('Mod_ShuDomiks') || IsScriptActive('Mod_ShuKlissan') || IsScriptActive('Mod_ShuMercs'))",
                        "{",
                        "    L_OtherStStat = '</color>' + Format(CT('Script.Mod_ExpPilotBridge.PersonalStatistic.TotalStatsKillOtherStations'), '<KillOtherStations' + '>', temp_str + (G_DomBStat + G_KBStat + G_MercCStat));",
                        "}",
                        "",
                        "//Сборка готового текста в диалоговом окне",
                        "tstr1 = '</color>' + Format(CT('Script.Mod_ExpPilotBridge.PersonalStatistic.TotalStats'),",
                        "                     '<KillDomiks' + '>', temp_str + GDomStat,",
                        "                     '<KillKlissan' + '>', LKlissanStat,",
                        "                     '<KillPirates' + '>', temp_str + (GPirStat + ShipStatistic(Player(), 8)), //В зачёт также идут гиперпираты",
                        "                     '<KillMercs' + '>', LMercStat,",
                        "                     '<KillRangers' + '>', temp_str + (GRangStat + GRangSpecStat + temp_int_6),",
                        "                     '<KillWarriors' + '>', temp_str + GWarStat,",
                        "                     '<KillCivils' + '>', temp_str + GCivilStat,",
                        "                     '<KillOthers' + '>', temp_str + (GTrankStat + GUnknStat + ShipStatistic(Player(), 7) + ShipStatistic(Player(), 8)),",
                        "                     '<KillWithCompanions' + '>', temp_str + GCompanionKillStat,",
                        "                     '<KillWithTrancs' + '>', temp_str + GTrancKillStat,",
                        "                     '<KillCoalStations' + '>', temp_str + (G_MBStat + G_RCStat + G_SBStat + G_BCStat + G_MCStat + G_TCStat + G_IngBStat),",
                        "                     '<KillPirateStations' + '>', temp_str + (G_PCBStat + G_PBStat),",
                        "                     '<KillOtherStations' + '>', L_OtherStStat,",
                        "                     '<FreeStarsForCoal' + '>', temp_str + sys_coal,",
                        "                     '<FreeStarsForPirates' + '>', temp_str + sys_pirate,",
                        "                     '<TextQuestsCompleted' + '>', temp_str + txt_q_ok,",
                        "                     '<DeliveryQuestsCompleted' + '>', temp_str + SendQuestsOK,",
                        "                     '<GuardQuestsCompleted' + '>', temp_str + DefShipQuestsOK,",
                        "                     '<KillQuestsCompleted' + '>', temp_str + (KillQuestsOK + GCustomQuestsDone),",
                        "                     '<StarDefenceQuestsCompleted' + '>', temp_str + DefSysQuestsOK,",
                        "                     '<PlanetBattlesCompleted' + '>', temp_str + plan_bat,",
                        "                     '<TextQuestsFailed' + '>', temp_str + TextQuestsFailed,",
                        "                     '<DeliveryQuestsFailed' + '>', temp_str + SendQuestsFailed,",
                        "                     '<ShipGuardQuestsFailed' + '>', temp_str + DefShipQuestsFailed,",
                        "                     '<KillQuestsFailed' + '>', temp_str + (KillQuestsFailed + GCustomQuestsFailed),",
                        "                     '<StarGuardQuestsFailed' + '>', temp_str + DefSysQuestsFailed,",
                        "                     '<GoodsBoughtTotal' + '>', temp_str + 10000000,//money_buys,",
                        "                     '<GoodsSellTotal' + '>', temp_str + money_sale,",
                        "                     '<CurrentTradeLoss' + '>', temp_str + ShipStatistic(Player(), 9),",
                        "                     '<EquipmentBoughtTotal' + '>', temp_str + money_equip,",
                        "                     '<RacketeeringReceived' + '>', temp_str + money_take,",
                        "                     '<RansomsReceived' + '>', temp_str + money_take_peace,",
                        "                     '<QuestsReward' + '>', temp_str + money_quest,",
                        "                     '<PlanetBattlesReward' + '>', temp_str + pb_money,",
                        "                     '<ExpForKillDomiks' + '>', temp_str + GetShipExpByType(Player(), 1),",
                        "                     '<ExpForKillPirates' + '>', temp_str + GetShipExpByType(Player(), 2),",
                        "                     '<ExpForKillOthers' + '>', temp_str + GetShipExpByType(Player(), 3),",
                        "                     '<ExpForTradeGoods' + '>', temp_str + GetShipExpByType(Player(), 4),",
                        "                     '<ExpForQuests' + '>', temp_str + exp_quest,",
                        "                     '<ExpForPlanetBattles' + '>', temp_str + pb_exp",
                        "                     );",
                        "DChange(1);",
                        "exit;"
