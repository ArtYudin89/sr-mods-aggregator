                        "\t// else if(GTL == 4) transfer_cargo_cost = round((0.00315 * transfer_cargo_size) * 1000.0);",
                        "\t// else if(GTL == 5) transfer_cargo_cost = round((0.00315 * transfer_cargo_size) * 1330.0);",
                        "\t// else if(GTL == 6) transfer_cargo_cost = round((0.00315 * transfer_cargo_size) * 1660.0);",
