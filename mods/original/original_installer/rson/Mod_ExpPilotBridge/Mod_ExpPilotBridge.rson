                {
                    "Name": "",
                    "Code.Type": "Turn",
                    "Code": [
                        "ArrayClear(temp_array);",
                        "ArrayClear(temp_array_2);",
                        "ArrayClear(temp_array_3);",
                        "for(i=0;i<GalaxyStars()-2;i=i+1)",
                        "{",
                        "\ttemp_dword=GalaxyStar(i);",
                        "\tif(StarOwner(temp_dword)==1)continue;",
                        "\tif(StarCustomFaction(temp_dword)!='')continue;",
                        "\tif(StarToCon(temp_dword)==StarToCon(PlanetToStar(PlanetPirateClan())))",
                        "    {",
                        "        if(StarOwner(temp_dword)!=0)continue;",
                        "    }",
                        "\tif(!StarItems(temp_dword))continue;",
                        "\tif(!SectorVisible(StarToCon(temp_dword)))continue;",
                        "\tArrayAdd(temp_array,i);",
                        "\ttemp_int_2=0;",
                        "\tfor(count2=0;count2<StarItems(temp_dword);count2=count2+1) temp_int_2=temp_int_2+ItemSize(StarItems(temp_dword,count2));",
                        "\tArrayAdd(temp_array_3,temp_int_2);",
                        "\tif(temp_int_2<=9)ArrayAdd(temp_array_2,'</color><clrEnd>'+StarName(temp_dword)+': <clr>'+CT('FormInfo.td_otstup_166')+temp_int_2+CT(\"Script.Mod_ExpPilotBridge.1291\"));",
                        "\tif(temp_int_2>9 && temp_int_2<=99)ArrayAdd(temp_array_2,'</color><clrEnd>'+StarName(temp_dword)+': <clr>'+CT('FormInfo.td_otstup_158')+temp_int_2+CT(\"Script.Mod_ExpPilotBridge.1291\"));",
                        "\tif(temp_int_2>99)ArrayAdd(temp_array_2,'</color><clrEnd>'+StarName(temp_dword)+': <clr>'+CT('FormInfo.td_otstup_150')+temp_int_2+CT(\"Script.Mod_ExpPilotBridge.1291\"));",
                        "}",
                        "temp_str='';",
                        "ArraySort(temp_array_3,temp_array_2,temp_array);",
                        "if(ArrayDim(temp_array_2)<=1)temp_str=CT(\"Script.Mod_ExpPilotBridge.675\");",
                        "if(ArrayDim(temp_array_2)>1)",
                        "{",
                        "    for(i=ArrayDim(temp_array_2)-1;i>=1;i=i-1)temp_str=temp_str+temp_array_2[i]+CT(\"Script.Mod_ExpPilotBridge.67\");",
                        "}",
                        "if(GetGameOptions('FontDialog')==0)temp_str='</color>----------------------------------'+CT(\"Script.Mod_ExpPilotBridge.67\")+temp_str;",
                        "if(GetGameOptions('FontDialog')==1)temp_str='</color>------------------------------'+CT(\"Script.Mod_ExpPilotBridge.67\")+temp_str;",
                        "if(GetGameOptions('FontDialog')==2)temp_str='</color>---------------------------------'+CT(\"Script.Mod_ExpPilotBridge.67\")+temp_str;",
                        "if(GetGameOptions('FontDialog')==3)temp_str='</color>------------------------------'+CT(\"Script.Mod_ExpPilotBridge.67\")+temp_str;",
                        "if(GetGameOptions('FontDialog')==0)temp_str_4='</color>------';",
                        "if(GetGameOptions('FontDialog')==1)temp_str_4='</color>----';",
                        "if(GetGameOptions('FontDialog')==2)temp_str_4='</color>----';",
                        "if(GetGameOptions('FontDialog')==3)temp_str_4='</color>----';",
                        "DChange(5);",
                        "exit;"
