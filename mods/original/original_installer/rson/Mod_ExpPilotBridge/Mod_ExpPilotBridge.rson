                    "Parent": -1,
                    "#": 259
                }
            ],
            "Operations": [
                {
                    "Name": "",
                    "Code.Type": "Global",
                    "Code": [
                        "GRun();"
                    ],
                    "#": 264,
                    "Type": "Top",
                    "Parent": -1,
                    "Pos.x": 0,
                    "Pos.y": 1510
                },
                {
                    "Name": "",
                    "Code.Type": "Init",
                    "Code": [
                        "bld_ship_planet_list = newarray(1);",
                        "bld_ship_planet_list_2 = newarray(1);",
                        "transfer_list_can = newarray(1);",
                        "transfer_list_done = newarray(1);",
                        "GHullsWaitArray = newarray(1);",
                        "GAddTArray = newarray(1);",
                        "GAddTArray2 = newarray(1);",
                        "temp_array = newarray(1);",
                        "temp_array_2 = newarray(1);",
                        "temp_array_3 = newarray(1);",
                        "temp_array_4 = newarray(1);",
                        "temp_array_5 = newarray(1);",
                        "temp_array_6 = newarray(1);",
                        "TForLegUp = '';",
                        "TForLegUp2 = '';",
                        "TLegUpCount = -1;",
                        "TLegUpCount2 = -1;",
                        "",
                        "LRangPirStat = '';",
                        "L_TCStat = '';",
                        "L_OtherStStat = '';",
                        "LKlissanStat = '';",
                        "LUnknStat = '';",
                        "LMercStat = '';",
                        "LPirBargStat = '';",
                        "LPirSmugStat = '';",
                        "LSupDomStat = '';",
                        "L_DomBStat = '';",
                        "L_IngBStat = '';",
                        "LKlissanLine = '';",
                        "LMercLine = '';",
                        "",
                        "//Для удобства сразу запоминаем текущий ГТУ в отдельную переменную",
                        "GTL = GalaxyTechLevel();",
                        "",
                        "if(CapitalShipStats(ShipItems(Player(), 0)) == 0) CapitalShipStats(ShipItems(Player(), 0), 3);",
                        "else if(CapitalShipStats(ShipItems(Player(), 0)) == 2) CapitalShipStats(ShipItems(Player(), 0), 3);",
                        "ShipAddCustomShipInfo(Player(), 'PlayerBridgeHV_infos', 'NoShow');",
                        "",
                        "//Выставляем самые первые планеты для слэпстартера",
                        "for(i = 0; i < GalaxyStars(); i = i + 1)",
                        "{",
                        "\ttemp_dword = GalaxyStar(i);",
                        "\tif(StarOwner(temp_dword) == 1) continue;",
                        "\tif(StarCustomFaction(temp_dword) != '') continue;",
                        "    //Исключаем Тортугац и Нифигац",
                        "    if(StarToCon(temp_dword) == StarToCon(PlanetToStar(PlanetPirateClan()))) continue;",
                        "\tfor(count2 = 0; count2 < StarPlanets(temp_dword); count2 = count2+1)",
                        "\t{",
                        "\t\ttemp_dword_2 = StarPlanets(temp_dword, count2);",
                        "\t\ttemp_int_2 = PlanetOwner(temp_dword_2);",
                        "\t\tif(temp_int_2 == 6) continue;",
                        "\t\tif(PirateWin() < 3 && StarOwner(temp_dword) == 2 && bld_planet_chsn_2 == 0) ArrayAdd(bld_ship_planet_list_2, Id(temp_dword_2));",
                        "\t\tif(!CoalitionDefeated() && StarOwner(temp_dword) == 0 && bld_planet_chsn == 0) ArrayAdd(bld_ship_planet_list, Id(temp_dword_2));",
                        "\t}",
                        "}",
                        "//Создаём Коалиционные проекты Слэпстартера",
                        "if(!bld_planet_chsn && ArrayDim(bld_ship_planet_list) > 1)",
                        "{",
                        "\t//Обнуляем сумму возврата в случае не набора проектом требуемой суммы (сумма возврата задаётся при внесении донатов игроком)",
                        "\trepay = 0;",
                        "\t//Тип коалиционных кораблей (влияет только на название)",
                        "\ttype_coal = Rnd(1, 3);",
                        "\t//Число коалиционных кораблей",
                        "\tship_count=Rnd(4,8);",
                        "\ttemp_int=Rnd(1,ArrayDim(bld_ship_planet_list)-1);",
                        "\tbld_ship_planet=bld_ship_planet_list[temp_int];",
                        "    //Определяем имя коалиционного отряда",
                        "\tif(PlanetRace(IdToPlanet(bld_ship_planet))==0)bld_ship_name=CT('ShipType.Maloc.Militiaman'+type_coal);",
                        "\telse if(PlanetRace(IdToPlanet(bld_ship_planet))==1)bld_ship_name=CT('ShipType.Peleng.Militiaman'+type_coal);",
                        "\telse if(PlanetRace(IdToPlanet(bld_ship_planet))==2)bld_ship_name=CT('ShipType.People.Militiaman'+type_coal);",
                        "\telse if(PlanetRace(IdToPlanet(bld_ship_planet))==3)bld_ship_name=CT('ShipType.Fei.Militiaman'+type_coal);",
                        "\telse if(PlanetRace(IdToPlanet(bld_ship_planet))==4)bld_ship_name=CT('ShipType.Gaal.Militiaman'+type_coal);",
                        "\t//Проверочная переменная, что сбор коалиционных донатов начался",
                        "\tbld_planet_chsn=1;",
                        "\t//Устанавливаем общую стоимость реализации проекта",
                        "\tbld_cost=GTL*GalaxyDiffLevels()*ship_count*105;",
                        "\t//Устанавливаем общее время сбора донатов (от 45 до 60 дней)",
                        "\tbld_day=45+CurTurn()+Rnd(0,15);",
                        "\t//Задаём общий размер всех пассивных взносов, которые поступят на коалиционный проект",
                        "\ttemp_int_7=GalaxyDiffLevels();",
                        "\tif(temp_int_7<=125)dif_koef=bld_cost-round(0.35*bld_cost)+round((0.01*Rnd(0,15))*bld_cost);",
                        "\tif(temp_int_7>125 && temp_int_7<=250)dif_koef=bld_cost-round(0.45*bld_cost)+round((0.01*Rnd(0,15))*bld_cost);",
                        "\tif(temp_int_7>250)dif_koef=bld_cost-round(0.60*bld_cost)+round((0.01*Rnd(0,15))*bld_cost);",
                        "\ttemp_int_3=bld_day-CurTurn();",
                        "\t//Задаём размер ежедневных пассивных взносов на коалиционный проект",
                        "\tadd_cr_day_1=dif_koef/temp_int_3;",
                        "\tcredits_now=round(0.61*bld_cost);",
                        "}",
                        "//Создаём пиратский проект Слэпстартера (срабатывает, если предыдущий проект завершён)",
                        "if(!bld_planet_chsn_2 && ArrayDim(bld_ship_planet_list_2)>1)",
                        "{",
                        "\t//Обнуляем сумму возврата в случае не набора проектом требуемой суммы (сумма возврата задаётся при внесении донатов игроком)",
                        "\trepay_2=0;",
                        "\t//Число пиратских кораблей",
                        "\tship_count_2=Rnd(4,8);",
                        "\ttemp_int=Rnd(1,ArrayDim(bld_ship_planet_list_2)-1);",
                        "\tbld_ship_planet_2=bld_ship_planet_list_2[temp_int];",
                        "    //Определяем имя пиратского отряда",
                        "    if(PlanetRace(IdToPlanet(bld_ship_planet_2))==0)bld_ship_name_2=CT(\"Script.Mod_ExpPilotBridge.516\");",
                        "    else if(PlanetRace(IdToPlanet(bld_ship_planet_2))==1)bld_ship_name_2=CT(\"Script.Mod_ExpPilotBridge.515\");",
                        "    else if(PlanetRace(IdToPlanet(bld_ship_planet_2))==2)bld_ship_name_2=CT(\"Script.Mod_ExpPilotBridge.514\");",
                        "    else if(PlanetRace(IdToPlanet(bld_ship_planet_2))==3)bld_ship_name_2=CT(\"Script.Mod_ExpPilotBridge.513\");",
                        "    else if(PlanetRace(IdToPlanet(bld_ship_planet_2))==4)bld_ship_name_2=CT(\"Script.Mod_ExpPilotBridge.512\");",
                        "\t//Проверочная переменная, что сбор пиратских донатов начался",
                        "\tbld_planet_chsn_2=1;",
                        "\t//Устанавливаем общую стоимость реализации проекта",
                        "\tbld_cost_2=GTL*GalaxyDiffLevels()*ship_count_2*100;",
                        "\t//Устанавливаем общее время сбора донатов (от 45 до 60 дней)",
                        "\tbld_day_2=45+CurTurn()+Rnd(0,15);",
                        "\t//Задаём общий размер всех пассивных взносов, которые поступят на пиратский проект",
                        "\ttemp_int_7=GalaxyDiffLevels();",
                        "\tif(temp_int_7<=125)dif_koef_2=bld_cost_2-round(0.35*bld_cost_2)+round((0.01*Rnd(0,15))*bld_cost);",
                        "\tif(temp_int_7>125 && temp_int_7<=250)dif_koef_2=bld_cost_2-round(0.45*bld_cost_2)+round((0.01*Rnd(0,15))*bld_cost);",
                        "\tif(temp_int_7>250)dif_koef_2=bld_cost_2-round(0.60*bld_cost_2)+round((0.01*Rnd(0,15))*bld_cost);",
                        "\ttemp_int_3=bld_day_2-CurTurn();",
                        "\t//Задаём размер ежедневных пассивных взносов на пиратский проект",
                        "\tadd_cr_day_2=dif_koef_2/temp_int_3;",
                        "\tcredits_now_2=round(0.39*bld_cost_2);",
                        "}",
                        "",
                        "//Спавним Уитли",
                        "temp_dword=StarNearbyStars(PlanetToStar(GetShipHomePlanet(Player())),Rnd(35,45));",
                        "if(StarToCon(temp_dword)==StarToCon(PlanetToStar(PlanetPirateClan())))temp_dword=StarNearbyStars(temp_dword,Rnd(5,6));",
                        "temp_dword_1=CreateQuestItem('ExpPilotBridge_Wheatley',6);",
                        "ItemSize(temp_dword_1,2);",
                        "ItemCost(temp_dword_1,2011);",
                        "EqCustomFaction(temp_dword_1,'Aperture_Science');",
                        "UselessItemData(temp_dword_1,3,temp_dword);",
                        "//Для спавна вычисляем случайную точку на окружности системы (почти у самого её края)",
                        "//Вычислили угол",
                        "TempFloat3=0.01*Rnd(0,200);",
                        "//Вычислили радиус",
                        "temp_int=PlanetOrbitRadius(StarPlanets(temp_dword,StarPlanets(temp_dword)-1))+800;",
                        "TempFloat2=round(sin(TempFloat3*pi)*temp_int);",
                        "temp_int_1=TempFloat2;//Координата X",
                        "TempFloat2=round(cos(TempFloat3*pi)*temp_int);",
                        "temp_int=TempFloat2;//Координата Y",
                        "DropItemInSystem(temp_dword,temp_dword_1,temp_int_1,temp_int,temp_int_1,temp_int);",
                        "StopMovingItem(temp_dword,temp_dword_1);",
                        "//Заносим Уитли в скриптовый объект (чтобы NPC его не трогали)",
                        "LinkItemToScript(temp_dword_1,Script_Wheatley);",
                        "ScriptItemData(Script_Wheatley,1,temp_int_1);//Запоминаем координату X",
                        "ScriptItemData(Script_Wheatley,2,temp_int);//Запоминаем координату Y",
                        "ScriptItemData(Script_Wheatley,3,Id(temp_dword)-1);//Запоминаем систему, в которой появился Уитли",
                        "GScriptWheatley=-1;",
                        "",
                        "//Акткод для скриптового объекта Уитли",
                        "function OnActCode_ScriptWheatley()",
                        "{",
                        "\tif(ScriptItemActionType()==t_OnItemDestroy)",
                        "\t{",
                        "\t\t//Создаём нового Уитли если старый был случайно уничтожен, а игрок ещё не побывал в этой системе",
                        "\t\tif(GScriptWheatley==-1)",
                        "\t\t{",
                        "\t\t\tReleaseItemFromScript(Script_Wheatley);",
                        "\t\t\ttemp_dword_4=CreateQuestItem('ExpPilotBridge_Wheatley',6);",
                        "\t\t\tItemSize(temp_dword_4,2);",
                        "\t\t\tItemCost(temp_dword_4,2011);",
                        "\t\t\tEqCustomFaction(temp_dword_4,'Aperture_Science');",
                        "\t\t\tDropItemInSystem(GalaxyStar(ScriptItemData(Script_Wheatley,3)),temp_dword_4,ScriptItemData(Script_Wheatley,1),ScriptItemData(Script_Wheatley,2),ScriptItemData(Script_Wheatley,1),ScriptItemData(Script_Wheatley,2));",
                        "\t\t\tStopMovingItem(GalaxyStar(ScriptItemData(Script_Wheatley,3)),temp_dword_4);",
                        "\t\t\tLinkItemToScript(temp_dword_4,Script_Wheatley);",
                        "\t\t}",
                        "\t}",
                        "\tif(ScriptItemActionType()==t_OnItemPickUp && ScriptItemActObject1()==CurItem())",
                        "\t{",
                        "\t\t//Выводим Уитли из скриптового объекта при подборе его игроком",
                        "\t\tReleaseItemFromScript(Script_Wheatley);",
                        "\t}",
                        "}",
                        "//Присваиваем объекту вышеописанный акткод",
                        "ItemOnActCode(Script_Wheatley,'OnActCode_ScriptWheatley();');",
                        "",
                        "//Акткод для костыльных семерёнок",
                        "function OnActCode_Semerenka(ship)",
                        "{",
                        "\tShipJoin(DebtMG,ship);",
                        "}",
                        "",
                        "function OnActCode_Semerenka_2(ship)",
                        "{",
                        "\tShipOut(ship);",
                        "}",
                        "",
                        "//Костыльные семерёнки для обработки акткода с доступом к переменным скрипта",
                        "temp_dword = CreateQuestItem('Usl_62', 0);",
                        "LinkItemToScript(temp_dword, Semerenka);",
                        "PutItemInVault('Semerenka', temp_dword);",
                        "ItemOnActCode(Semerenka, 'OnActCode_Semerenka(GShipJoinGlobal);');",
                        "",
                        "temp_dword = CreateQuestItem('Usl_62', 0);",
                        "LinkItemToScript(temp_dword, Semerenka_2);",
                        "PutItemInVault('Semerenka_2', temp_dword);",
                        "ItemOnActCode(Semerenka_2, 'OnActCode_Semerenka_2(GShipJoinGlobal);');",
                        "",
                        "//Функция расчёта шанса утери груза при его доставке, либо при его возвращении на планету отправки",
                        "function CargoLostChanceCalc()",
                        "{",
                        "\t//Если системы отправки и/или доставки пиратские",
                        "    temp_str_3 = GalaxyStar(DeliveryMainArray[0]); //Система откуда",
                        "    temp_str_4 = GalaxyStar(DeliveryMainArray[1]); //Система куда",
                        "",
                        "\tif((StarOwner(temp_str_3) == 2 && StarCustomFaction(temp_str_3) == '') ||",
                        "       (StarOwner(temp_str_4) == 2 && StarCustomFaction(temp_str_4) == '')",
                        "      )",
                        "\t{",
                        "\t\tif(LTargetType == 1 || LTargetType == 2)",
                        "\t\t{",
                        "\t\t\tif(Rnd(1, 100) <= 15)",
                        "\t\t\t{",
                        "\t\t\t\tif(transfer_day_old > 14)",
                        "\t\t\t\t{",
                        "\t\t\t\t\tif(StarOwner(temp_str_3) == 2 && StarCustomFaction(temp_str_3) == '')",
                        "\t\t\t\t\t{",
                        "\t\t\t\t\t\tCargoLost = 2;",
                        "\t\t\t\t\t\ttransfer_day_orig = transfer_day;",
                        "\t\t\t\t\t\ttransfer_day = transfer_day - (Rnd(5, 6) * (transfer_day_old / 7));",
                        "\t\t\t\t\t}",
                        "\t\t\t\t\tif(StarOwner(temp_str_4) == 2 && StarCustomFaction(temp_str_4) == '')",
                        "\t\t\t\t\t{",
                        "\t\t\t\t\t\tif(CargoLost == 2)",
                        "\t\t\t\t\t\t{",
                        "\t\t\t\t\t\t\tCargoLost = 3;",
                        "\t\t\t\t\t\t}",
                        "\t\t\t\t\t\telse",
                        "\t\t\t\t\t\t{",
                        "\t\t\t\t\t\t\tCargoLost = 4;",
                        "\t\t\t\t\t\t}",
                        "\t\t\t\t\t\tif(CargoLost == 3)",
                        "\t\t\t\t\t\t{",
                        "\t\t\t\t\t\t\ttransfer_day_orig = transfer_day;",
                        "\t\t\t\t\t\t\tif(Rnd(0, 1))",
                        "\t\t\t\t\t\t\t{",
                        "\t\t\t\t\t\t\t\ttransfer_day = transfer_day - (Rnd(5, 6) * (transfer_day_old / 7));",
                        "\t\t\t\t\t\t\t}",
                        "\t\t\t\t\t\t\telse",
                        "\t\t\t\t\t\t\t{",
                        "\t\t\t\t\t\t\t\ttransfer_day = transfer_day - (Rnd(1, 2) * (transfer_day_old / 7));",
                        "\t\t\t\t\t\t\t}",
                        "\t\t\t\t\t\t}",
                        "\t\t\t\t\t\tif(CargoLost == 4)",
                        "\t\t\t\t\t\t{",
                        "\t\t\t\t\t\t\ttransfer_day_orig = transfer_day;",
                        "\t\t\t\t\t\t\ttransfer_day = transfer_day - (Rnd(1, 2) * (transfer_day_old / 7));",
                        "\t\t\t\t\t\t}",
                        "\t\t\t\t\t}",
                        "\t\t\t\t}",
                        "\t\t\t\telse",
                        "\t\t\t\t{",
                        "\t\t\t\t\ttransfer_day = transfer_day;",
                        "\t\t\t\t\ttransfer_day_orig = transfer_day;",
                        "\t\t\t\t}",
                        "\t\t\t}",
                        "\t\t\telse",
                        "\t\t\t{",
                        "\t\t\t\ttransfer_day = transfer_day;",
                        "\t\t\t\ttransfer_day_orig = transfer_day;",
                        "\t\t\t}",
                        "\t\t}",
                        "\t\tif(LTargetType == 3 || LTargetType == 4)",
                        "\t\t{",
                        "\t\t\tif(StarOwner(temp_str_4) == 2 && StarCustomFaction(temp_str_4) == '')",
                        "\t\t\t{",
                        "\t\t\t\tif(Rnd(1, 100) <= 15)",
                        "\t\t\t\t{",
                        "\t\t\t\t\tif(transfer_day_old - (transfer_day - CurTurn()) > 14)",
                        "\t\t\t\t\t{",
                        "\t\t\t\t\t\tCargoLost = 4;",
                        "\t\t\t\t\t\ttransfer_day = (transfer_day_old - (transfer_day - CurTurn())) - (Rnd(1, 2) * ((transfer_day_old - (transfer_day - CurTurn())) / 7)) + CurTurn();",
                        "\t\t\t\t\t\ttransfer_day_orig = (transfer_day_old - (transfer_day - CurTurn())) + CurTurn();",
                        "\t\t\t\t\t}",
                        "\t\t\t\t\telse",
                        "\t\t\t\t\t{",
                        "\t\t\t\t\t\ttransfer_day = (transfer_day_old - (transfer_day - CurTurn())) + CurTurn();",
                        "\t\t\t\t\t\ttransfer_day_orig = transfer_day;",
                        "\t\t\t\t\t}",
                        "\t\t\t\t}",
                        "\t\t\t\telse",
                        "\t\t\t\t{",
                        "\t\t\t\t\ttransfer_day = (transfer_day_old - (transfer_day - CurTurn())) + CurTurn();",
                        "\t\t\t\t\ttransfer_day_orig = transfer_day;",
                        "\t\t\t\t}",
                        "\t\t\t}",
                        "\t\t\telse",
                        "\t\t\t{",
                        "\t\t\t\tif(Rnd(1, 100) <= 5)",
                        "\t\t\t\t{",
                        "\t\t\t\t\tif(transfer_day_old - (transfer_day - CurTurn()) > 14)",
                        "\t\t\t\t\t{",
                        "\t\t\t\t\t\tCargoLost = 1;",
                        "\t\t\t\t\t\ttransfer_day = (transfer_day_old - (transfer_day - CurTurn())) - (Rnd(1, 6) * ((transfer_day_old - (transfer_day - CurTurn())) / 7)) + CurTurn();",
                        "\t\t\t\t\t\ttransfer_day_orig = (transfer_day_old - (transfer_day - CurTurn())) + CurTurn();",
                        "\t\t\t\t\t}",
                        "\t\t\t\t}",
                        "\t\t\t\telse",
                        "\t\t\t\t{",
                        "\t\t\t\t\ttransfer_day = (transfer_day_old - (transfer_day - CurTurn())) + CurTurn();",
                        "\t\t\t\t\ttransfer_day_orig = transfer_day;",
                        "\t\t\t\t}",
                        "\t\t\t}",
                        "\t\t}",
                        "\t}",
                        "\t//Если системы отправки и/или доставки не пиратские",
                        "\telse",
                        "\t{",
                        "\t\tif(LTargetType == 1 || LTargetType == 2)",
                        "\t\t{",
                        "\t\t\tif(Rnd(1, 100) <= 5 && transfer_day_old > 14)",
                        "\t\t\t{",
                        "\t\t\t\tCargoLost = 1;",
                        "\t\t\t\ttransfer_day_orig = transfer_day;",
                        "\t\t\t\ttransfer_day = transfer_day - (Rnd(1, 6) * (transfer_day_old / 7));",
                        "\t\t\t}",
                        "\t\t\telse",
                        "\t\t\t{",
                        "\t\t\t\ttransfer_day_orig = transfer_day;",
                        "\t\t\t\ttransfer_day = transfer_day;",
                        "\t\t\t}",
                        "\t\t}",
                        "\t\tif(LTargetType == 3 || LTargetType == 4)",
                        "\t\t{",
                        "\t\t\tif(Rnd(1, 100) <= 5 && (transfer_day_old - (transfer_day - CurTurn())) > 14)",
                        "\t\t\t{",
                        "\t\t\t\tCargoLost = 1;",
                        "\t\t\t\ttransfer_day = (transfer_day_old - (transfer_day - CurTurn())) - (Rnd(1, 6) * ((transfer_day_old - (transfer_day - CurTurn())) / 7)) + CurTurn();",
                        "\t\t\t\ttransfer_day_orig = (transfer_day_old - (transfer_day - CurTurn())) + CurTurn();",
                        "\t\t\t}",
                        "\t\t\telse",
                        "\t\t\t{",
                        "\t\t\t\ttransfer_day = (transfer_day_old - (transfer_day - CurTurn())) + CurTurn();",
                        "\t\t\t\ttransfer_day_orig = transfer_day;",
                        "\t\t\t}",
                        "\t\t}",
                        "\t}",
                        "}",
                        "",
                        "//Функция расчёта шанса утери груза при его возвращении в домашнюю систему (при возвращении в домашнюю систему к таймеру добавляется 21 дополнительный день доставки)",
                        "function CargoLostChanceCalcHome()",
                        "{",
                        "\tif(LTargetType != 5)",
                        "\t{",
                        "\t\t//Если домашняя система захвачена доминаторами или клисанами",
                        "\t\tif((StarOwner(PlanetToStar(GetShipHomePlanet(Player()))) == 1 || StarCustomFaction(PlanetToStar(GetShipHomePlanet(Player()))) != ''))",
                        "\t\t{",
                        "\t\t\tCargoLost = 5;",
                        "\t\t\ttransfer_day = ((transfer_day_old - (transfer_day - CurTurn())) + 21) - (7 * (((transfer_day_old - (transfer_day - CurTurn())) / 8) + 21)) + CurTurn();",
                        "\t\t\ttransfer_day_orig = transfer_day;",
                        "\t\t}",
                        "\t\t//Если домашняя система пиратская и не захватывалась доминаторами/клисанами, пока к ней летел транспорт",
                        "\t\tif((StarOwner(PlanetToStar(GetShipHomePlanet(Player()))) == 2 && StarCustomFaction(PlanetToStar(GetShipHomePlanet(Player()))) == ''))",
                        "\t\t{",
                        "\t\t\tif(Rnd(1, 100) <= 15)",
                        "\t\t\t{",
                        "\t\t\t\tCargoLost = 4;",
                        "\t\t\t\ttransfer_day = ((transfer_day_old - (transfer_day - CurTurn())) + 21) - (Rnd(5, 6) * (((transfer_day_old - (transfer_day - CurTurn())) / 7) + 21)) + CurTurn();",
                        "\t\t\t\ttransfer_day_orig = (transfer_day_old - (transfer_day - CurTurn())) + 21 + CurTurn();",
                        "\t\t\t}",
                        "\t\t\telse",
                        "\t\t\t{",
                        "\t\t\t\tCargoLost = 0;",
                        "\t\t\t\ttransfer_day = (transfer_day_old - (transfer_day - CurTurn())) + 21 + CurTurn();",
                        "\t\t\t\ttransfer_day_orig = transfer_day;",
                        "\t\t\t}",
                        "\t\t}",
                        "\t\t//Если домашняя система коалиционная и не захватывалась доминаторами/клисанами, пока к ней летел транспорт",
                        "\t\tif(StarOwner(PlanetToStar(GetShipHomePlanet(Player()))) == 0)",
                        "\t\t{",
                        "\t\t\tif(Rnd(1, 100) <= 5)",
                        "\t\t\t{",
                        "\t\t\t\tCargoLost = 1;",
                        "\t\t\t\ttransfer_day = ((transfer_day_old - (transfer_day - CurTurn())) + 21) - (Rnd(1, 6) * (((transfer_day_old - (transfer_day - CurTurn())) / 7) + 21)) + CurTurn();",
                        "\t\t\t\ttransfer_day_orig = (transfer_day_old - (transfer_day - CurTurn())) + 21 + CurTurn();",
                        "\t\t\t}",
                        "\t\t\telse",
                        "\t\t\t{",
                        "\t\t\t\tCargoLost = 0;",
                        "\t\t\t\ttransfer_day = (transfer_day_old - (transfer_day - CurTurn())) + 21 + CurTurn();",
                        "\t\t\t\ttransfer_day_orig = transfer_day;",
                        "\t\t\t}",
                        "\t\t}",
                        "\t}",
                        "\telse",
                        "\t{",
                        "\t\t//Если домашняя система была захвачена доминаторами или клисанами пока к ней летел транспорт",
                        "\t\tif((StarOwner(PlanetToStar(GetShipHomePlanet(Player()))) == 1 || StarCustomFaction(PlanetToStar(GetShipHomePlanet(Player()))) != ''))",
                        "\t\t{",
                        "\t\t\tCargoLost = 5;",
                        "\t\t\ttransfer_day = ((transfer_day_old - ((transfer_day_start + transfer_day_old) - CurTurn())) + 21) - (7 * (((transfer_day_old - ((transfer_day_start + transfer_day_old) - CurTurn())) / 8) + 21)) + CurTurn();",
                        "\t\t\ttransfer_day_orig = transfer_day;",
                        "\t\t}",
                        "",
                        "\t\t//Если домашняя система пиратская и уже захватывалась доминаторами/клисанами, пока к ней летел транспорт",
                        "\t\tif((StarOwner(PlanetToStar(GetShipHomePlanet(Player()))) == 2 && StarCustomFaction(PlanetToStar(GetShipHomePlanet(Player()))) == ''))",
                        "\t\t{",
                        "\t\t\tif(Rnd(1, 100) <= 15)",
                        "\t\t\t{",
                        "\t\t\t\tCargoLost = 4;",
                        "\t\t\t\ttransfer_day = ((transfer_day_old - ((transfer_day_start + transfer_day_old) - CurTurn())) + 21) - (Rnd(5, 6) * (((transfer_day_old - ((transfer_day_start + transfer_day_old) - CurTurn())) / 7) + 21)) + CurTurn();",
                        "\t\t\t\ttransfer_day_orig = (transfer_day_old - ((transfer_day_start + transfer_day_old) - CurTurn())) + 21 + CurTurn();",
                        "\t\t\t}",
                        "\t\t\telse",
                        "\t\t\t{",
                        "\t\t\t\tCargoLost = 0;",
                        "\t\t\t\ttransfer_day = (transfer_day_old - ((transfer_day_start + transfer_day_old) - CurTurn())) + 21 + CurTurn();",
                        "\t\t\t\ttransfer_day_orig = transfer_day;",
                        "\t\t\t}",
                        "\t\t}",
                        "\t\t//Если домашняя система коалиционная и уже захватывалась доминаторами/клисанами, пока к ней летел транспорт",
                        "\t\tif(StarOwner(PlanetToStar(GetShipHomePlanet(Player()))) == 0)",
                        "\t\t{",
                        "\t\t\tif(Rnd(1, 100) <= 5)",
                        "\t\t\t{",
                        "\t\t\t\tCargoLost = 1;",
                        "\t\t\t\ttransfer_day = ((transfer_day_old - ((transfer_day_start + transfer_day_old) - CurTurn())) + 21) - (Rnd(1, 6) * (((transfer_day_old - ((transfer_day_start + transfer_day_old) - CurTurn())) / 7) + 21)) + CurTurn();",
                        "\t\t\t\ttransfer_day_orig = (transfer_day_old - ((transfer_day_start + transfer_day_old) - CurTurn())) + 21 + CurTurn();",
                        "\t\t\t}",
                        "\t\t\telse",
                        "\t\t\t{",
                        "\t\t\t\tCargoLost = 0;",
                        "\t\t\t\ttransfer_day = (transfer_day_old - ((transfer_day_start + transfer_day_old) - CurTurn())) + 21 + CurTurn();",
                        "\t\t\t\ttransfer_day_orig = transfer_day;",
                        "\t\t\t}",
                        "\t\t}",
                        "\t}",
                        "}",
                        "",
                        "//Функция создания кораблей, присвоивших корпус(а) игрока",
                        "function HullWasStolenThiefCreate(HullDelEndCheck)",
                        "{",
                        "\ttemp_str_3='';",
                        "\t//Просто берём одну из ближайших к доставочной систем, если корпус был украден в конце доставки",
                        "\ttemp_dword_2=StarNearbyStars(GalaxyStar(HullEndStarId),1);",
                        "\ttemp_dword_3=StarNearbyStars(GalaxyStar(HullEndStarId),2);",
                        "\tif(HullDelEndCheck==1 && ((StarOwner(temp_dword_2)!=1 && StarCustomFaction(temp_dword_2)=='') || (StarOwner(temp_dword_3)!=1 && StarCustomFaction(temp_dword_3)=='')))",
                        "\t{",
                        "\t\tif(StarOwner(temp_dword_2)!=1 && StarCustomFaction(temp_dword_2)=='')temp_dword_2=StarNearbyStars(GalaxyStar(HullEndStarId),1);",
                        "\t\tif(StarOwner(temp_dword_3)!=1 && StarCustomFaction(temp_dword_3)=='')temp_dword_2=StarNearbyStars(GalaxyStar(HullEndStarId),2);",
                        "\t\tif((StarOwner(temp_dword_2)!=1 && StarCustomFaction(temp_dword_2)=='') && (StarOwner(temp_dword_3)!=1 && StarCustomFaction(temp_dword_3)==''))temp_dword_2=StarNearbyStars(GalaxyStar(HullEndStarId),Rnd(1,2));",
                        "\t}",
                        "\telse",
                        "\t{",
                        "\t\t//Вычисляем и сравниваем квадрат расстояния от точки условного",
                        "\t\t//местонахождения курьера(ов) (на отрезке пути от системы А к системе Б)",
                        "\t\t//до каждой звезды в рукаве Галактики.",
                        "\t\t//Таким образом определяем условную систему его текущего местоположения",
                        "\t\tTempFloat1=0;",
                        "\t\tTempFloat2=0;",
                        "\t\tTempFloat3=0;",
                        "\t\ttemp_dword_2=0;",
                        "\t\tTempFloat4=100000000;",
                        "\t\ttemp_dword_3=GalaxyStar(HullFromStarId);",
                        "\t\ttemp_dword_4=GalaxyStar(HullEndStarId);",
                        "\t\t//Определяем процент расстояния положения курьера между системами А и Б",
                        "\t\tTempFloat2=min((1.0*(CurTurn()-HullDelTimeStart))/(HullDelTime-HullDelTimeStart));",
                        "\t\t//Определяем точку координат условного местоположения курьера по X и Y",
                        "\t\tTempFloat1=TempFloat2*CoordX(temp_dword_4)+(1-TempFloat2)*CoordX(temp_dword_3);",
                        "\t\tTempFloat2=TempFloat2*CoordY(temp_dword_4)+(1-TempFloat2)*CoordY(temp_dword_3);",
                        "\t\tfor(i=0;i<GalaxyStars();i=i+1)",
                        "\t\t{",
                        "\t\t\tif(StarOwner(GalaxyStar(i))==1)continue;",
                        "\t\t\tif(StarCustomFaction(GalaxyStar(i))!='')continue;",
                        "\t\t\tif(StarToCon(GalaxyStar(i))==StarToCon(PlanetToStar(PlanetPirateClan())))continue;",
                        "\t\t\t//Определяем квадрат расстояния удаления каждой системы от точки условного расположения курьера",
                        "\t\t\tTempFloat3=sqr(CoordX(GalaxyStar(i))-TempFloat1)+sqr(CoordY(GalaxyStar(i))-TempFloat2);",
                        "\t\t\t//Сравниваем и запоминаем систему с наименьшим удалением от установленной точки координат",
                        "\t\t\tif(TempFloat3<TempFloat4)",
                        "\t\t\t{",
                        "\t\t\t\tTempFloat4=TempFloat3;",
                        "\t\t\t\ttemp_dword_2=GalaxyStar(i);",
                        "\t\t\t}",
                        "\t\t}",
                        "\t\t//Повтор цикла без пропуска доминаторских и клисанских систем, на случай полного захвата рукава галактики",
                        "\t\tif(temp_dword_2==0)",
                        "\t\t{",
                        "\t\t\tfor(i=0;i<GalaxyStars();i=i+1)",
                        "\t\t\t{",
                        "\t\t\t\tif(StarToCon(GalaxyStar(i))==StarToCon(PlanetToStar(PlanetPirateClan())))continue;",
                        "\t\t\t\t//Определяем квадрат расстояния удаления каждой системы от точки условного расположения курьера",
                        "\t\t\t\tTempFloat3=sqr(CoordX(GalaxyStar(i))-TempFloat1)+sqr(CoordY(GalaxyStar(i))-TempFloat2);",
                        "\t\t\t\t//Сравниваем и запоминаем систему с наименьшим удалением от установленной точки координат",
                        "\t\t\t\tif(TempFloat3<TempFloat4)",
                        "\t\t\t\t{",
                        "\t\t\t\t\tTempFloat4=TempFloat3;",
                        "\t\t\t\t\ttemp_dword_2=GalaxyStar(i);",
                        "\t\t\t\t}",
                        "\t\t\t}",
                        "\t\t}",
                        "\t}",
                        "\t//Перебираем корпуса (если их несколько), определяем, какие именно украли",
                        "\tArrayClear(temp_array_6);",
                        "\ttemp_int_3=0;",
                        "\tfor(i=1;i<=HullOnWay;i=i+1)",
                        "\t{",
                        "\t\tif((i==1 && (HullWasStolen==1 || HullWasStolen==3 || HullWasStolen==5 || HullWasStolen==7)) || (i==2 && (HullWasStolen==2 || HullWasStolen==3 || HullWasStolen==6 || HullWasStolen==7)) || (i==3 && (HullWasStolen==4 || HullWasStolen==5 || HullWasStolen==6 || HullWasStolen==7)))",
                        "\t\t{",
                        "\t\t\t//Рандомно определяем планету или станцию спавна корабля вора",
                        "\t\t\ttemp_dword_3=0;",
                        "\t\t\twhile(temp_dword_3==0)",
                        "\t\t\t{",
                        "\t\t\t\tfor(j=0;j<StarPlanets(temp_dword_2);j=j+1)",
                        "\t\t\t\t{",
                        "\t\t\t\t\tif(PlanetOwner(StarPlanets(temp_dword_2,j))==6)continue;",
                        "\t\t\t\t\tif(Rnd(1,100)<=50)",
                        "\t\t\t\t\t{",
                        "\t\t\t\t\t\ttemp_dword_3=StarPlanets(temp_dword_2,j);",
                        "\t\t\t\t\t\tbreak;",
                        "\t\t\t\t\t}",
                        "\t\t\t\t}",
                        "\t\t\t}",
                        "\t\t\t//Доставлял профи",
                        "\t\t\tif(substr(GAddTArray[i],0,1)==1)",
                        "\t\t\t{",
                        "\t\t\t\t//Спавним рейнджера",
                        "\t\t\t\tif(substr(GAddTArray[i],1,1)==1 || substr(GAddTArray[i],1,1)==2)",
                        "\t\t\t\t{",
                        "\t\t\t\t\ttemp_dword_1=ThiefCreate(1,temp_dword_3,Rnd(310,400),i,1);",
                        "\t\t\t\t}",
                        "\t\t\t\t//Спавним фрилансера (тоже рейнджер)",
                        "\t\t\t\tif(substr(GAddTArray[i],1,1)==3 || substr(GAddTArray[i],1,1)==4)",
                        "\t\t\t\t{",
                        "\t\t\t\t\ttemp_dword_1=ThiefCreate(1,temp_dword_3,Rnd(310,400),i,1);",
                        "\t\t\t\t\tShipType(temp_dword_1,'Freelancer');",
                        "\t\t\t\t\tShipStatus(temp_dword_1,0,34);",
                        "\t\t\t\t\tShipStatus(temp_dword_1,1,33);",
                        "\t\t\t\t\tShipStatus(temp_dword_1,2,33);",
                        "\t\t\t\t\tRangerExcludedFromRating(temp_dword_1,1);",
                        "\t\t\t\t}",
                        "\t\t\t\ttemp_str_2=CT(\"Script.Mod_ExpPilotBridge.1154\");",
                        "\t\t\t}",
                        "\t\t\t//Доставлял умелец",
                        "\t\t\tif(substr(GAddTArray[i],0,1)==2)",
                        "\t\t\t{",
                        "\t\t\t\t//Спавним рейнджера",
                        "\t\t\t\tif(substr(GAddTArray[i],1,1)==1)",
                        "\t\t\t\t{",
                        "\t\t\t\t\ttemp_dword_1=ThiefCreate(1,temp_dword_3,Rnd(250,310),i,2);",
                        "\t\t\t\t}",
                        "\t\t\t\t//Спавним фрилансера (тоже рейнджер)",
                        "\t\t\t\tif(substr(GAddTArray[i],1,1)==2)",
                        "\t\t\t\t{",
                        "\t\t\t\t\ttemp_dword_1=ThiefCreate(1,temp_dword_3,Rnd(250,310),i,2);",
                        "\t\t\t\t\tShipType(temp_dword_1,'Freelancer');",
                        "\t\t\t\t\tRangerExcludedFromRating(temp_dword_1,1);",
                        "\t\t\t\t}",
                        "\t\t\t\t//Спавним пирата",
                        "\t\t\t\tif(substr(GAddTArray[i],1,1)==3 || substr(GAddTArray[i],1,1)==4)",
                        "\t\t\t\t{",
                        "\t\t\t\t\ttemp_dword_1=ThiefCreate(2,temp_dword_3,Rnd(250,310),i,2);",
                        "\t\t\t\t}",
                        "\t\t\t\t//Спавним транспорт",
                        "\t\t\t\tif(substr(GAddTArray[i],1,1)==5)",
                        "\t\t\t\t{",
                        "\t\t\t\t\ttemp_dword_1=ThiefCreate(3,temp_dword_3,Rnd(250,310),i,2);",
                        "\t\t\t\t}",
                        "\t\t\t\ttemp_str_2=CT(\"Script.Mod_ExpPilotBridge.1160\");",
                        "\t\t\t}",
                        "\t\t\t//Доставлял салага",
                        "\t\t\tif(substr(GAddTArray[i],0,1)==3)",
                        "\t\t\t{",
                        "\t\t\t\t//Спавним рейнджера",
                        "\t\t\t\tif(substr(GAddTArray[i],1,1)==1)",
                        "\t\t\t\t{",
                        "\t\t\t\t\ttemp_dword_1=ThiefCreate(1,temp_dword_3,Rnd(160,200),i,3);",
                        "\t\t\t\t}",
                        "\t\t\t\t//Спавним пирата",
                        "\t\t\t\tif(substr(GAddTArray[i],1,1)==2 || substr(GAddTArray[i],1,1)==3 || substr(GAddTArray[i],1,1)==4)",
                        "\t\t\t\t{",
                        "\t\t\t\t\ttemp_dword_1=ThiefCreate(2,temp_dword_3,Rnd(160,200),i,3);",
                        "\t\t\t\t}",
                        "\t\t\t\t//Спавним транспорт",
                        "\t\t\t\tif(substr(GAddTArray[i],1,1)==5 || substr(GAddTArray[i],1,1)==6)",
                        "\t\t\t\t{",
                        "\t\t\t\t\ttemp_dword_1=ThiefCreate(3,temp_dword_3,Rnd(160,200),i,3);",
                        "\t\t\t\t}",
                        "\t\t\t\ttemp_str_2=CT(\"Script.Mod_ExpPilotBridge.1159\");",
                        "\t\t\t}",
                        "\t\t\t//Запоминаем счётчик дней до отправки сообщения о местонахождении воров",
                        "\t\t\t//Нужен, чтобы дать ворам фору на взлёт с планеты",
                        "\t\t\ttemp_int_3=temp_int_3+1;",
                        "\t\t\t//Формируем уведомление о кораблях воров",
                        "\t\t\tif(i>1)temp_str_3=temp_str_3+CT('FormInfo.br')+' '+CT('FormInfo.br');",
                        "\t\t\ttemp_str_3=temp_str_3+CT(\"Script.Mod_ExpPilotBridge.1200\")+Name(temp_dword_1)+'<clrEnd>'+CT('FormInfo.br')+CT(\"Script.Mod_ExpPilotBridge.1199\")+temp_str_2+'<clrEnd>'+CT('FormInfo.br')+CT(\"Script.Mod_ExpPilotBridge.1198\")+ConName(StarToCon(PlanetToStar(temp_dword_3)))+'<clrEnd>'+CT('FormInfo.br')+CT(\"Script.Mod_ExpPilotBridge.1197\")+StarName(PlanetToStar(temp_dword_3))+'<clrEnd>'+CT('FormInfo.br')+CT(\"Script.Mod_ExpPilotBridge.1196\")+Name(ShipItems(temp_dword_1,0))+' [<color=0,255,0>'+ItemSize(ShipItems(temp_dword_1,0))+'</color>]<clrEnd>';",
                        "\t\t\tArrayAdd(temp_array_6,0);",
                        "\t\t}",
                        "\t\telse ArrayAdd(temp_array_6,1);//Маркер, что корпус не украли",
                        "\t}",
                        "\t//Добавляем к уведомлению \"шапку\" и \"подвал\"",
                        "\tif(temp_int_3==1)temp_str_3=CT(\"Script.Mod_ExpPilotBridge.1195\")+CT('FormInfo.br')+'<color=127,127,127>--------------------------------------------------------------------------------------------------</color>'+CT('FormInfo.br')+temp_str_3+CT('FormInfo.br')+'<color=127,127,127>--------------------------------------------------------------------------------------------------</color>'+CT('FormInfo.br')+CT(\"Script.Mod_ExpPilotBridge.1193\");",
                        "\tif(temp_int_3>1)temp_str_3=CT(\"Script.Mod_ExpPilotBridge.1194\")+CT('FormInfo.br')+'<color=127,127,127>--------------------------------------------------------------------------------------------------</color>'+CT('FormInfo.br')+temp_str_3+CT('FormInfo.br')+'<color=127,127,127>--------------------------------------------------------------------------------------------------</color>'+CT('FormInfo.br')+CT(\"Script.Mod_ExpPilotBridge.1193\");",
                        "\tif(temp_int_3>0)",
                        "\t{",
                        "\t\t//Ставим вывод уведомления о кораблях-похитителях на таймер",
                        "\t\tif(TLegUpCount==-1)",
                        "\t\t{",
                        "\t\t\tTForLegUp=temp_str_3;",
                        "\t\t\tTLegUpCount=4;",
                        "\t\t}",
                        "\t\t//Второй счетчик с переменной нужен на случай, если произойдут две кражи подряд (в теории возможно)",
                        "\t\telse",
                        "\t\t{",
                        "\t\t\tTForLegUp2=temp_str_3;",
                        "\t\t\tTLegUpCount2=4;",
                        "\t\t}",
                        "\t\t//Пересобираем массив и счётчик, исключаем украденные корпуса",
                        "\t\ttemp_int_3=0;",
                        "\t\tArrayClear(temp_array_4);",
                        "\t\tArrayClear(temp_array_5);",
                        "\t\tfor(i=1;i<=HullOnWay;i=i+1)",
                        "\t\t{",
                        "\t\t\tif(temp_array_6[i]!=0)",
                        "\t\t\t{",
                        "\t\t\t\tArrayAdd(temp_array_5,GAddTArray[i]);",
                        "\t\t\t\tArrayAdd(temp_array_4,GetItemFromVault('HullDelServ_'+i));",
                        "\t\t\t\ttemp_int_3=temp_int_3+1;",
                        "\t\t\t}",
                        "\t\t}",
                        "\t\tArrayClear(GAddTArray);",
                        "\t\tfor(i=1;i<ArrayDim(temp_array_5);i=i+1)",
                        "\t\t{",
                        "\t\t\tArrayAdd(GAddTArray,temp_array_5[i]);",
                        "\t\t\tPutItemInVault('HullDelServ_'+i,temp_array_4[i]);",
                        "\t\t}",
                        "\t\tHullOnWay=temp_int_3;",
                        "\t\tHullWasStolen=0;",
                        "\t}",
                        "\tArrayClear(temp_array_4);",
                        "\tArrayClear(temp_array_5);",
                        "\tArrayClear(temp_array_6);",
                        "}",
                        "",
                        "//Функция спавна корабля, похитившего корпус (возвращает заспавленный корабль):",
                        "//Stype - тип корабля",
                        "//Splanet - планета спавна",
                        "//Cmode - модификатор стартового капитала",
                        "//Hnumb - номер корпуса игрока в хранилище",
                        "//Dtype - тип агента по перегону",
                        "function ThiefCreate(Stype,Splanet,Cmode,Hnumb,Dtype)",
                        "{",
                        "\tif(StarOwner(PlanetToStar(Splanet))==1 || StarCustomFaction(PlanetToStar(Splanet))!='')",
                        "\t{",
                        "\t\ttemp_dword_4=PlanetOwner(Splanet);",
                        "\t\tPlanetOwner(Splanet,PlanetRace(Splanet));",
                        "\t}",
                        "\tif(Stype==1 && !CoalitionDefeated())",
                        "\t{",
                        "\t\ttemp_dword_5=BuyRanger(Splanet,Cmode);",
                        "\t\tShipSkill(temp_dword_5,0,3);",
                        "\t\tShipSkill(temp_dword_5,1,3);",
                        "\t\tShipSkill(temp_dword_5,2,2);",
                        "\t\tShipSkill(temp_dword_5,3,2);",
                        "\t\tShipSkill(temp_dword_5,4,2);",
                        "\t\tShipSkill(temp_dword_5,5,2);",
                        "\t\ttemp_int_4=1;",
                        "\t}",
                        "\tif(Stype==1 && CoalitionDefeated())",
                        "\t{",
                        "\t\ttemp_dword_5=BuyPirate(Splanet,Cmode);",
                        "\t\tShipSkill(temp_dword_5,0,3);",
                        "\t\tShipSkill(temp_dword_5,1,3);",
                        "\t\tShipSkill(temp_dword_5,2,1);",
                        "\t\tShipSkill(temp_dword_5,3,1);",
                        "\t\ttemp_int_4=2;",
                        "\t}",
                        "\tif(Stype==2)",
                        "\t{",
                        "\t\ttemp_dword_5=BuyPirate(Splanet,Cmode);",
                        "\t\tShipSkill(temp_dword_5,0,3);",
                        "\t\tShipSkill(temp_dword_5,1,3);",
                        "\t\tShipSkill(temp_dword_5,2,1);",
                        "\t\tShipSkill(temp_dword_5,3,1);",
                        "\t\ttemp_int_4=2;",
                        "\t}",
                        "\tif(Stype==3 && !CoalitionDefeated())",
                        "\t{",
                        "\t\ttemp_dword_5=BuyTransport(Splanet,0,Cmode);",
                        "\t\tShipSkill(temp_dword_5,0,2);",
                        "\t\tShipSkill(temp_dword_5,1,2);",
                        "\t\tShipSkill(temp_dword_5,2,3);",
                        "\t\tShipSkill(temp_dword_5,3,3);",
                        "\t\ttemp_int_4=3;",
                        "\t}",
                        "\tif(Stype==3 && CoalitionDefeated())",
                        "\t{",
                        "\t\ttemp_dword_5=BuyPirate(Splanet,Cmode);",
                        "\t\tShipSkill(temp_dword_5,0,3);",
                        "\t\tShipSkill(temp_dword_5,1,3);",
                        "\t\tShipSkill(temp_dword_5,2,1);",
                        "\t\tShipSkill(temp_dword_5,3,1);",
                        "\t\ttemp_int_4=2;",
                        "\t}",
                        "\tShipRefit(temp_dword_5);",
                        "\tShipRefit(temp_dword_5);",
                        "\tShipRefit(temp_dword_5);",
                        "\tShipImproveItems(temp_dword_5,Rnd(4,5));",
                        "\tif(StarOwner(PlanetToStar(Splanet))==1 || StarCustomFaction(PlanetToStar(Splanet))!='')PlanetOwner(Splanet,temp_dword_4);",
                        "\ttemp_int_5=0;",
                        "\ttemp_int_6=0;",
                        "\t//Спавним корабль и производим надевание нового корпуса строго по алгоритму:",
                        "\t//1. Забрать корпус",
                        "\t//2. Забрать у корабля все вещи кроме корпуса (удалить если не нужны, или в массив/воулт положить)",
                        "\t//3. Выдать новый корпус (п.1,2 нужны чтобы корпус оказался в 0-й позиции в списке эквипа, это принципиально)",
                        "\t//4. Активировать новый корпус",
                        "\t//5. Удалить старый корпус (не раньше! до активации нового корпуса у корабля все ещё есть линк на старый)",
                        "\t//6. Отдать эквип или сделать новый",
                        "\twhile(ShipItems(temp_dword_5)!=0)",
                        "\t{",
                        "\t\tif(ItemType(ShipItems(temp_dword_5,0))==t_Hull)",
                        "\t\t{",
                        "\t\t\ttemp_dword_4=GetItemFromShip(temp_dword_5,0);",
                        "\t\t\tcontinue;",
                        "\t\t}",
                        "\t\telse",
                        "\t\t{",
                        "\t\t\tif(ItemIsInUse(ShipItems(temp_dword_5,0)))",
                        "\t\t\t{",
                        "\t\t\t\ttemp_int_5=temp_int_5+1;",
                        "\t\t\t\tPutItemInVault('ExpBridgeUsedItems_'+temp_int_5,GetItemFromShip(temp_dword_5,0));",
                        "\t\t\t}",
                        "\t\t\telse",
                        "\t\t\t{",
                        "\t\t\t\ttemp_int_6=temp_int_6+1;",
                        "\t\t\t\tPutItemInVault('ExpBridgeUslItems_'+temp_int_6,GetItemFromShip(temp_dword_5,0));",
                        "\t\t\t}",
                        "\t\t}",
                        "\t}",
                        "\t//Надеваем на корабль корпус игрока",
                        "\tAddItemToShip(temp_dword_5,GetItemFromVault('HullDelServ_'+Hnumb));",
                        "\tItemIsInUse(ShipItems(temp_dword_5,0),temp_dword_5,1);",
                        "\tChameleon(temp_dword_5);",
                        "\t//Запрещаем кораблю снимать корпус игрока",
                        "\tNoDropItem(ShipItems(temp_dword_5,0),1);",
                        "\tFreeItem(temp_dword_4);",
                        "\tfor(count3=1; count3<=temp_int_5; count3=count3+1)",
                        "\t{",
                        "\t\ttemp_dword_4=GetItemFromVault('ExpBridgeUsedItems_'+count3);",
                        "\t\tAddItemToShip(temp_dword_5,temp_dword_4);",
                        "\t\tItemIsInUse(temp_dword_4,temp_dword_5,1);",
                        "\t}",
                        "\tfor(count3=1; count3<=temp_int_6; count3=count3+1)",
                        "\t{",
                        "\t\ttemp_dword_4=GetItemFromVault('ExpBridgeUslItems_'+count3);",
                        "\t\tAddItemToShip(temp_dword_5,temp_dword_4);",
                        "\t}",
                        "\t//В числе профи чаще оказываются люди, феяне и гаальцы",
                        "\tif(Dtype==1)",
                        "\t{",
                        "\t\ttemp_dword_1=Rnd(1,10);",
                        "\t\tif(temp_dword_1>=1 && temp_dword_1<=7)ShipPilotRace(temp_dword_5,Rnd(2,4));",
                        "\t\telse ShipPilotRace(temp_dword_5,Rnd(0,1));",
                        "\t}",
                        "\tif(Dtype==2)",
                        "\t{",
                        "\t\tShipPilotRace(temp_dword_5,Rnd(0,4));",
                        "\t}",
                        "\t//В числе салаг чаще оказываются малоки и пеленги",
                        "\tif(Dtype==3)",
                        "\t{",
                        "\t\ttemp_dword_1=Rnd(1,10);",
                        "\t\tif(temp_dword_1>=1 && temp_dword_1<=7)ShipPilotRace(temp_dword_5,Rnd(0,1));",
                        "\t\telse ShipPilotRace(temp_dword_5,Rnd(2,4));",
                        "\t}",
                        "\tif(!CoalitionDefeated())ShipOwner(temp_dword_5,ShipPilotRace(temp_dword_5));",
                        "\t//Ровняем производителя всех эквипнутых вещей на расу пилота",
                        "\tfor(count3=1; count3<ShipItems(temp_dword_5); count3=count3+1)",
                        "\t{",
                        "\t\tif(ItemIsInUse(ShipItems(temp_dword_5,count3)))ItemOwner(ShipItems(temp_dword_5,count3),ShipPilotRace(temp_dword_5));",
                        "\t}",
                        "\t//На всякий случай даём кораблю команду проверить оборудку, чтобы пофиксить возможный перевес",
                        "\tShipFreeFlight(temp_dword_5);",
                        "\t//Добавляем кораблю воровскую инфошку и запоминаем шанс добровольной сдачи корпуса игроку при соответствующем запросе",
                        "\tif(temp_int_4==1) temp_int_4=Rnd(30,50) / Dtype; //Рейнджер",
                        "\tif(temp_int_4==2) temp_int_4=Rnd(20,40) / Dtype; //Пират",
                        "\tif(temp_int_4==3) temp_int_4=Rnd(50,100) / Dtype; //Транспорт",
                        "\tShipAddCustomShipInfo(temp_dword_5,'PlayerBridge_ThiefInfo','NoShow',-1,temp_int_4);",
                        "\tShipJoin(HullThieves,temp_dword_5);",
                        "\tresult=temp_dword_5;",
                        "}",
                        "",
                        "//Функция создания кораблей по проекту со Слэпстартера",
                        "function SpawnSlapstarter(type,planet) {",
                        "    dword ship, hull, item; int i;",
                        "    dword GTL=GalaxyTechLevel();",
                        "\tif(type==1) ship=BuyWarrior(planet, 1000);",
                        "\telse if(type==2) ship=BuyWarrior(planet, 1000); //???",
                        "\tfor(i=0; i<=2; i=i+1) ShipSkill(ship, i, round(0.5*GTL+Rnd(0, 2)));",
                        "\tfor(i=3; i<=5; i=i+1) ShipSkill(ship, i, Rnd(0, 3));",
                        "    hull=ShipItems(ship, 0);",
                        "\tItemSize(hull, (150+GTL*80));",
                        "\tfor(i=ShipItems(ship)-1; i>0; i=i-1) FreeItem(GetItemFromShip(ship, i));",
                        "\tif(ShipOnSidePirateClan(ship)) ShipType(ship, 'Rebel');",
                        "\telse ShipType(ship, 'Militiaman'+type_coal);",
                        "\tfor(i=0; i<10; i=i+1) ShipRefit(ship);",
                        "\tShipImproveItems(ship, round(0.5*GTL+Rnd(7, 10)));",
                        "\tif(GetEquipmentStats(ShipItems(ship, 0), 5)) { //Выдаем ГЗП и дроида если их нет",
                        "\t\tif(!ShipEqInSlot(ship, t_RepairRobot)) {",
                        "\t\t\titem = CreateEquipment(t_RepairRobot, Rnd(20, 80), GTL, ShipOwner(ship));",
                        "\t\t\tAddItemToShip(ship, item);",
                        "\t\t\tItemIsInUse(item, ship, 1);",
                        "\t\t}",
                        "\t}",
                        "\tif(GetEquipmentStats(ShipItems(ship, 0), 7)) {",
                        "\t\tif(!ShipEqInSlot(ship, t_DefGenerator)) {",
                        "\t\t\titem=CreateEquipment(t_DefGenerator, Rnd(20, 80), GTL, ShipOwner(ship));",
                        "\t\t\tAddItemToShip(ship, item);",
                        "\t\t\tItemIsInUse(item, ship, 1);",
                        "\t\t}",
                        "\t}",
                        "    ShipCalcParam(ship);",
                        "    hull=ShipItems(ship, 0);",
                        "\tif(ShipFreeSpace(ship)<0) ItemSize(hull, ItemSize(hull)+abs(ShipFreeSpace(ship))+Rnd(1, 5));",
                        "\tHullHP(ship, 'To100');",
                        "    Chameleon(ship);",
                        "\tresult=ship;",
                        "}",
                        "",
                        "//Функция проверки условий для появления ТЦ. Возвращает Id системы для постройки или 0, если нет подходящей системы.",
                        "function SelectSystemTC() {",
                        "    int i, j, k;",
                        "    dword con, system, ruins_count, systems_count;",
                        "    for(i=0; i<GalaxySectors(); i=i+1) {",
                        "        con=GalaxySectors(i);",
                        "        if(con==StarToCon(PlanetToStar(PlanetPirateClan()))) continue;",
                        "        ruins_count=0;",
                        "        systems_count=0;",
                        "        for(j=0; j<ConStars(con); j=j+1) {",
                        "            system=ConStar(con, j);",
                        "            if(!StarOwner(system) || StarOwner(system)==2) systems_count=systems_count+1;",
                        "            if(StarRuins(system)) {",
                        "                ruins_count=ruins_count+StarRuins(system);",
                        "                if(StarRuins(system)>=3) continue;",
                        "            }",
                        "        }",
                        "        if(ruins_count<systems_count) { //Проверка на кол-во станций в секторе",
                        "            for(k=0; k<ConStars(con); k=k+1) {",
                        "                system=ConStar(con, k);",
                        "                if(StarOwner(system)==1) continue; //Пропуск доминаторов",
                        "                if(StarCustomFaction(system)!='') continue; //Пропуск кастомов",
                        "                if(StarBattle(system)) continue; //Пропуск оспариваемых систем",
                        "                if(StarRuins(system)>=3) continue; //Меньше 3 баз в системе",
                        "                ArrayAdd(bld_TC_array, Id(system));",
                        "            }",
                        "        }",
                        "    }",
                        "    if(ArrayDim(bld_TC_array)<=1) system=0;",
                        "    else system=bld_TC_array[Rnd(1,ArrayDim(bld_TC_array)-1)];",
                        "    ArrayClear(bld_TC_array);",
                        "    result=system;",
                        "}",
                        "//Функция создания нового ТЦ (запускается из тернкода)",
                        "function BuyTC(dword system) {",
                        "    dword station, planet; int tint;",
                        "    str station_name, temp_news;",
                        "    station = BuildCustomRuins(system, 'TC', 5); //Если подключён мод ExpBasesAutoUpgrade, то накидываем на ТЦ инфошку для автоулучшения",
                        "    if(BlockExist('ShipInfo.AddInfo.CustomInfos.ExpBasesAutoUpgradeInfo')) ShipAddCustomShipInfo(station, 'ExpBasesAutoUpgradeInfo', 'NoShow');",
                        "    Chameleon(station, 'Ruins.TC'); //Меняем шкурку на ТЦ",
                        "    //Меняем овнера и расу базы на малоков, заодно, на всякий случай, обновляя лицо капитана",
                        "    ShipOwner(station, 0);",
                        "    ShipPilotRace(station, 0);",
                        "    ShipFace(station, -1);",
                        "    station_name = CT('RuinName.TC.'+Rnd(1,CT('RuinName.TC.Name_count'))); //Выбираем имя для нового ТЦ",
                        "    SetName(station, station_name); //Устанавливаем имя новому ТЦ",
                        "    GlobalVarTcCount=GlobalVarTcCount+1; //Глобальный счётчик числа ТЦ в Галактике",
                        "    planet=FindPlanet(system, 'NotNone', 0, 0); //Ищем обитаемую планету, с нее полетит ТЦ",
                        "    ShipJoin(GroupTC, station);",
                        "    Coord_X_TC=CoordX(station); //Запоминаем координаты",
                        "    Coord_Y_TC=CoordY(station);",
                        "    TransferShip(station, planet);",
                        "    CoordX(station, planet); //Меняем координаты, т.к. они сами не поменяются",
                        "    CoordY(station, planet);",
                        "    //Выводим сообщение о постройке нового ТЦ, если у игрока есть карта этого сектора",
                        "    if(SectorVisible(StarToCon(system))) {",
                        "    \ttint = Rnd(0, 3);",
                        "    \tif(!tint) temp_news = Format(CT(\"Script.Mod_ExpPilotBridge.1553\"),\"<0>\",StarName(system),\"<1>\",station_name,\"<2>\",Name(StarToCon(system)));",
                        "    \telse if(tint == 1) temp_news = Format(CT(\"Script.Mod_ExpPilotBridge.1552\"),\"<0>\",StarName(system),\"<1>\",Name(StarToCon(system)),\"<2>\",station_name);",
                        "    \telse if(tint == 2) temp_news = Format(CT(\"Script.Mod_ExpPilotBridge.1551\"),\"<0>\",station_name,\"<1>\",StarName(system),\"<2>\",Name(StarToCon(system)));",
                        "    \telse temp_news = Format(CT(\"Script.Mod_ExpPilotBridge.1550\"),\"<0>\",station_name,\"<1>\",StarName(system),\"<2>\",Name(StarToCon(system)));",
                        "    \tNewsAdd(temp_news);",
                        "    \tAddPlanetNews(temp_news);",
                        "    }",
                        "}",
                        "function UpdateKillShipsStatistic(int type, int sub_type, str str_type, str name, str full_name, int owner, int in_hyper)",
                        "{",
                        "    //Доминаторы и клисане",
                        "    if(type == t_Kling)",
                        "    {",
                        "        //Оригинальные доминаторы",
                        "        if(str_type == '' || str_type == 'Kling')",
                        "        {",
                        "            //Определяем оригинального доминатора по подтипу",
                        "            //Штип",
                        "            if(sub_type == 5)",
                        "            {",
                        "                GDomShtStat = GDomShtStat + 1;",
                        "                GDomStat = GDomStat + 1;",
                        "                if(in_hyper) PlayerDominatorStatistic(5, PlayerDominatorStatistic(5) + 1);",
                        "            }",
                        "            //Менок",
                        "            else if(sub_type == 4)",
                        "            {",
                        "                GDomMenStat = GDomMenStat + 1;",
                        "                GDomStat = GDomStat + 1;",
                        "                if(in_hyper) PlayerDominatorStatistic(4, PlayerDominatorStatistic(4) + 1);",
                        "            }",
                        "            //Смерш",
                        "            else if(sub_type == 3)",
                        "            {",
                        "                GDomSmrStat = GDomSmrStat + 1;",
                        "                GDomStat = GDomStat + 1;",
                        "                if(in_hyper) PlayerDominatorStatistic(3, PlayerDominatorStatistic(3) + 1);",
                        "            }",
                        "            //Ургант",
                        "            else if(sub_type == 2)",
                        "            {",
                        "                GDomUrgStat = GDomUrgStat + 1;",
                        "                GDomStat = GDomStat + 1;",
                        "                if(in_hyper) PlayerDominatorStatistic(2, PlayerDominatorStatistic(2) + 1);",
                        "            }",
                        "            //Эквентор",
                        "            else if(sub_type == 1)",
                        "            {",
                        "                GDomIkvStat = GDomIkvStat + 1;",
                        "                GDomStat = GDomStat + 1;",
                        "                if(in_hyper) PlayerDominatorStatistic(1, PlayerDominatorStatistic(1) + 1);",
                        "            }",
                        "            //Клиг",
                        "            else if(sub_type == 7)",
                        "            {",
                        "                GDomKlgStat = GDomKlgStat + 1;",
                        "                GDomStat = GDomStat + 1;",
                        "                if(in_hyper) PlayerDominatorStatistic(7, PlayerDominatorStatistic(7) + 1);",
                        "            }",
                        "            //Бертор",
                        "            else if(sub_type == 6)",
                        "            {",
                        "                GDomBerStat = GDomBerStat + 1;",
                        "                GDomStat = GDomStat + 1;",
                        "                if(in_hyper) PlayerDominatorStatistic(6, PlayerDominatorStatistic(6) + 1);",
                        "            }",
                        "            //Босс",
                        "            else //if(!sub_type)",
                        "            {",
                        "                //Блазер",
                        "                if(full_name == CT('ShipType.Dominator.Blazer.0'))",
                        "                {",
                        "                    GDomStat = GDomStat + 1;",
                        "                    if(in_hyper) PlayerDominatorStatistic(0, PlayerDominatorStatistic(0) + 1);",
                        "                }",
                        "                //Келлер",
                        "                else if(full_name == CT('ShipType.Dominator.Keller.0'))",
                        "                {",
                        "                    GDomStat = GDomStat + 1;",
                        "                    if(in_hyper) PlayerDominatorStatistic(0, PlayerDominatorStatistic(0) + 1);",
                        "                }",
                        "                //Террон",
                        "                else if(full_name == CT('ShipType.Dominator.Terron.0'))",
                        "                {",
                        "                    GDomStat = GDomStat + 1;",
                        "                    if(in_hyper) PlayerDominatorStatistic(0, PlayerDominatorStatistic(0) + 1);",
                        "                }",
                        "            }",
                        "",
                        "            if(in_hyper) ShipStatistic(Player(), 2, ShipStatistic(Player(), 2) + 1);",
                        "        }",
                        "        else",
                        "        {",
                        "            //Эгемон",
                        "            if(str_type == 'Klissan5')",
                        "            {",
                        "                GKlissMutStat = GKlissMutStat + 1;",
                        "                GKlissanStat = GKlissanStat + 1;",
                        "            }",
                        "            //Нондус",
                        "            else if(str_type == 'Klissan4')",
                        "            {",
                        "                GKlissRogStat = GKlissRogStat + 1;",
                        "                GKlissanStat = GKlissanStat + 1;",
                        "            }",
                        "            //Катаури",
                        "            else if(str_type == 'Klissan3')",
                        "            {",
                        "                GKlissKatStat = GKlissKatStat + 1;",
                        "                GKlissanStat = GKlissanStat + 1;",
                        "            }",
                        "            //Рогит",
                        "            else if(str_type == 'Klissan2')",
                        "            {",
                        "                GKlissNonStat = GKlissNonStat + 1;",
                        "                GKlissanStat = GKlissanStat + 1;",
                        "            }",
                        "            //Мутенок",
                        "            else if(str_type == 'Klissan1')",
                        "            {",
                        "                GKlissEgeStat = GKlissEgeStat + 1;",
                        "                GKlissanStat = GKlissanStat + 1;",
                        "            }",
                        "            //Супердоминатор",
                        "            else if(str_type == 'Superdominator')",
                        "            {",
                        "                GSupDomStat = GSupDomStat + 1;",
                        "                GDomStat = GDomStat + 1;",
                        "                if(in_hyper) ShipStatistic(Player(), 2, ShipStatistic(Player(), 2) + 1);",
                        "            }",
                        "            //Верфь, а точнее эквентор, имитирующий станцию (ShuDomiks)",
                        "            else if(str_type == 'DomRuins')",
                        "            {",
                        "                G_DomBStat = G_DomBStat + 1;",
                        "                if(in_hyper) ShipStatistic(Player(), 2, ShipStatistic(Player(), 2) + 1);",
                        "                else PlayerDominatorStatistic(1, PlayerDominatorStatistic(1) - 1);",
                        "            }",
                        "            //Клон Келлера (ShuDomiks)",
                        "            else if(str_type == 'KellerClone')",
                        "            {",
                        "                GDomStat = GDomStat + 1;",
                        "                if(in_hyper) ShipStatistic(Player(), 2, ShipStatistic(Player(), 2) + 1);",
                        "                else PlayerDominatorStatistic(1, PlayerDominatorStatistic(1) - 1);",
                        "                PlayerDominatorStatistic(0, PlayerDominatorStatistic(0) + 1);",
                        "            }",
                        "            //Неизвестный (ShuKlissan)",
                        "            else if(str_type == 'None')",
                        "            {",
                        "                GUnknStat = GUnknStat + 1;",
                        "                if(in_hyper) ShipStatistic(Player(), 7, ShipStatistic(Player(), 7) + 1);",
                        "            }",
                        "            else if(str_type == 'Machpella')",
                        "            {",
                        "                GKlissanStat = GKlissanStat + 1;",
                        "            }",
                        "        }",
                        "    }",
                        "    //Пираты и наёмники",
                        "    else if(type == t_Pirate)",
                        "    {",
                        "        if(str_type == '' || str_type == 'Pirate')",
                        "        {",
                        "            //Вольные пираты",
                        "            if(sub_type == 0)",
                        "            {",
                        "                GPirStat = GPirStat + 1;",
                        "                GPirFreeStat = GPirFreeStat + 1;",
                        "            }",
                        "            //Клановые пираты",
                        "            else",
                        "            {",
                        "                GPirStat = GPirStat + 1;",
                        "                GPirClanStat = GPirClanStat + 1;",
                        "            }",
                        "        }",
                        "        else",
                        "        {",
                        "            if(str_type == 'Rebel')",
                        "            {",
                        "                GPirStat = GPirStat + 1;",
                        "                GPirRebStat = GPirRebStat + 1;",
                        "            }",
                        "            //Пиратские крупные корабли (EvoArmada)",
                        "            else if(str_type == 'PirateCorvette')",
                        "            {",
                        "                GPirStat = GPirStat + 1;",
                        "                GPirCorvStat = GPirCorvStat + 1;",
                        "            }",
                        "            else if(str_type == 'PirateFrigate')",
                        "            {",
                        "                GPirStat = GPirStat + 1;",
                        "                GPirFrigStat = GPirFrigStat + 1;",
                        "            }",
                        "            else if(str_type == 'PirateGalleon')",
                        "            {",
                        "                GPirStat = GPirStat + 1;",
                        "                GPirGallStat = GPirGallStat + 1;",
                        "            }",
                        "            //Пираты-загонщики (событие в ExpPilotBridge)",
                        "            else if(str_type == 'PirateRunner')",
                        "            {",
                        "                GPirStat = GPirStat + 1;",
                        "                GPirFreeStat = GPirFreeStat + 1;",
                        "            }",
                        "            //Головорез (ShuPirates)",
                        "            else if(str_type == 'Thug')",
                        "            {",
                        "                GPirStat = GPirStat + 1;",
                        "                GPirThugStat = GPirThugStat + 1;",
                        "            }",
                        "            //Хан (ShuPirates)",
                        "            else if(str_type == 'Khan')",
                        "            {",
                        "                GPirStat = GPirStat + 1;",
                        "                GPirKhanStat = GPirKhanStat + 1;",
                        "            }",
                        "        }",
                        "",
                        "        if(in_hyper) ShipStatistic(Player(), 1, ShipStatistic(Player(), 1) + 1);",
                        "    }",
                        "    //Рейнджеры и наёмники",
                        "    else if(type == t_Ranger)",
                        "    {",
                        "        //Простые рейнджеры, либо спецагентки",
                        "        if(str_type == '' || str_type == 'Ranger' || str_type == 'FemRanger')",
                        "        {",
                        "            //Спецагентки (ищем по имени корабля, т.к. никак иначе здесь не получится)",
                        "            if(findsubstr(CT('Script.Mod_ExpPilotBridge.PersonalStatistic.SpecialAgentSearchString'), '$' + name + '$') >= 0)",
                        "            {",
                        "                GRangSpecStat = GRangSpecStat + 1;",
                        "            }",
                        "            //Простые рейнджеры",
                        "            else",
                        "            {",
                        "                GRangStat = GRangStat + 1;",
                        "            }",
                        "        }",
                        "        else",
                        "        {",
                        "            //Рейнджер исследователь (проходит в статистике как обычный рейнджер)",
                        "            if(str_type == 'RangerExplorer')",
                        "            {",
                        "                GRangStat = GRangStat + 1;",
                        "            }",
                        "            //Рейнджер изменник, считается пиратом (ExpTraitors)",
                        "            else if(str_type == 'RangerPirate' || str_type == 'RangerPirateExplorer')",
                        "            {",
                        "                GPirStat = GPirStat + 1;",
                        "                LRangPirStat = LRangPirStat + 1;",
                        "            }",
                        "            //Наёмники",
                        "            else if(str_type == 'Merc')",
                        "            {",
                        "                GMercStat = GMercStat + 1;",
                        "                //Принадлежность к организации определяем по приставке к имени",
                        "                if(!findsubstr(full_name, CT('ShipType.People.Merc') + ' '))",
                        "                {",
                        "                    GMercAtlStat = GMercAtlStat + 1;",
                        "                }",
                        "                else if(!findsubstr(full_name, CT('ShipType.Maloc.Merc') + ' '))",
                        "                {",
                        "                    GMercAxeStat = GMercAxeStat + 1;",
                        "                }",
                        "                else if(!findsubstr(full_name, CT('ShipType.Fei.Merc') + ' '))",
                        "                {",
                        "                    GMercFeiStat = GMercFeiStat + 1;",
                        "                }",
                        "            }",
                        "            else if(str_type == 'AtlantLeader')",
                        "            {",
                        "                GMercStat = GMercStat + 1;",
                        "                GMercAtlStat = GMercAtlStat + 1;",
                        "            }",
                        "            else if(str_type == 'RedLeader')",
                        "            {",
                        "                GMercStat = GMercStat + 1;",
                        "                GMercAxeStat = GMercAxeStat + 1;",
                        "            }",
                        "            else if(str_type == 'FeiLeader')",
                        "            {",
                        "                GMercStat = GMercStat + 1;",
                        "                GMercFeiStat = GMercFeiStat + 1;",
                        "            }",
                        "            else if(str_type == 'Freelancer')",
                        "            {",
                        "                GMercStat = GMercStat + 1;",
                        "                GMercFreeStat = GMercFreeStat + 1;",
                        "            }",
                        "            else if(str_type == 'PlayerMerc' || str_type == 'StarCockerel')",
                        "            {",
                        "                GMercStat = GMercStat + 1;",
                        "                GMercOtherStat = GMercOtherStat + 1;",
                        "            }",
                        "        }",
                        "",
                        "        if(in_hyper) ShipStatistic(Player(), 6, ShipStatistic(Player(), 6) + 1);",
                        "    }",
                        "    //Военные Коалиции",
                        "    else if(type == t_Warrior)",
                        "    {",
                        "        //Простые военные, либо флагманы (линкоры)",
                        "        if(str_type == '' || str_type == 'Warrior')",
                        "        {",
                        "            //Простые военные",
                        "            if(!sub_type)",
                        "            {",
                        "                GWarStat = GWarStat + 1;",
                        "                GWarPrivStat = GWarPrivStat + 1;",
                        "            }",
                        "            //Линкоры",
                        "            else",
                        "            {",
                        "                GWarStat = GWarStat + 1;",
                        "                GWarFlagStat = GWarFlagStat + 1;",
                        "            }",
                        "        }",
                        "        //Из модов",
                        "        else",
                        "        {",
                        "            //Дредноуты",
                        "            if(str_type == 'Dreadnought')",
                        "            {",
                        "                GWarStat = GWarStat + 1;",
                        "                GWarDreadStat = GWarDreadStat + 1;",
                        "            }",
                        "            //Ополченцы",
                        "            else if(str_type == 'Militiaman1' || str_type == 'Militiaman2' || str_type == 'Militiaman3')",
                        "            {",
                        "                GWarStat = GWarStat + 1;",
                        "                GWarMilitStat = GWarMilitStat + 1;",
                        "            }",
                        "        }",
                        "",
                        "        if(in_hyper) ShipStatistic(Player(), 5, ShipStatistic(Player(), 5) + 1);",
                        "    }",
                        "    //Гражданские суда и контрабандисты",
                        "    else if(type == t_Transport)",
                        "    {",
                        "        //Транспорты, лайнеры и дипломаты",
                        "        if(str_type == '' || str_type == 'Transport' || str_type == 'Liner' || str_type == 'Diplomat')",
                        "        {",
                        "            //Транспорты",
                        "            if(!sub_type)",
                        "            {",
                        "                GCivilStat = GCivilStat + 1;",
                        "                GCoalTranStat = GCoalTranStat + 1;",
                        "            }",
                        "            //Лайнеры",
                        "            else if(sub_type == 1)",
                        "            {",
                        "                GCivilStat = GCivilStat + 1;",
                        "                GCoalLinStat = GCoalLinStat + 1;",
                        "            }",
                        "            //Дипломаты",
                        "            else //if(sub_type == 2)",
                        "            {",
                        "                GCivilStat = GCivilStat + 1;",
                        "                GCoalDipStat = GCoalDipStat + 1;",
                        "            }",
                        "        }",
                        "        //Контрабандисты",
                        "        else",
                        "        {",
                        "            if(str_type == 'Smuggler')",
                        "            {",
                        "                GPirStat = GPirStat + 1;",
                        "                GPirSmugStat = GPirSmugStat + 1;",
                        "            }",
                        "        }",
                        "",
                        "        if(in_hyper) ShipStatistic(Player(), 4, ShipStatistic(Player(), 4) + 1);",
                        "    }",
                        "    //Транклюкаторы",
                        "    else if(type == t_Tranclucator)",
                        "    {",
                        "        //if(str_type == '' || str_type == 'Tranclucator')",
                        "        GTrankStat = GTrankStat + 1;",
                        "    }",
                        "    //Счётчики уничтоженных станций",
                        "    //Центры рейнджеров",
                        "    else if(type == t_RC)",
                        "    {",
                        "        G_RCStat = G_RCStat + 1;",
                        "    }",
                        "    //Пиратские базы",
                        "    else if(type == t_PB)",
                        "    {",
                        "        //if(str_type == 'BM') //Чёрный рынок",
                        "        //{}",
                        "        //else if(str_type == 'SSB') //ППБ (не может быть уничтожена)",
                        "        //else",
                        "        G_PBStat = G_PBStat + 1;",
                        "    }",
                        "    //Военные базы",
                        "    else if(type == t_WB)",
                        "    {",
                        "        G_MBStat = G_MBStat + 1;",
                        "    }",
                        "    //Научные базы",
                        "    else if(type == t_SB)",
                        "    {",
                        "        G_SBStat = G_SBStat + 1;",
                        "    }",
                        "    //Бизнес-центры",
                        "    else if(type == t_BK)",
                        "    {",
                        "        G_BCStat = G_BCStat + 1;",
                        "    }",
                        "    //Медицинские центры",
                        "    else if(type == t_MC)",
                        "    {",
                        "        G_MCStat = G_MCStat + 1;",
                        "    }",
                        "    //Доминионы",
                        "    else if(type == t_CB)",
                        "    {",
                        "        G_PCBStat = G_PCBStat + 1;",
                        "    }",
                        "    //Центры наёмников, нейролинки и ингибиторы (определяем по типу и имени)",
                        "    else if(type == t_UB)",
                        "    {",
                        "        str_type = Format(str_type, '_licensed', '', '');",
                        "",
                        "        //Технологический центр (ExpTC)",
                        "        if(str_type == 'TC')",
                        "        {",
                        "            G_TCStat = G_TCStat + 1;",
                        "        }",
                        "        //Нейролинк (ShuKlissan)",
                        "        else if(str_type == 'KB')",
                        "        {",
                        "            G_KBStat = G_KBStat + 1;",
                        "        }",
                        "        //Центр наёмников (ShuMercs)",
                        "        else if(str_type == 'MB' || str_type == 'Manaan' || str_type == 'PlayerMB')",
                        "        {",
                        "            G_MercCStat = G_MercCStat + 1;",
                        "        }",
                        "        //Ингибитор (ShuDomiks)",
                        "        else if(str_type == 'Inhibitor')",
                        "        {",
                        "            G_IngBStat = G_IngBStat + 1;",
                        "        }",
                        "        //Махпелла в текущей версии ShuKlissan является станцией",
                        "        else if(str_type == 'Machpella')",
                        "        {",
                        "            GKlissanStat = GKlissanStat + 1;",
                        "        }",
                        "    }",
                        "}"
                    ],
                    "#": 265,
                    "Type": "Top",
                    "Parent": -1,
                    "Pos.x": 60,
                    "Pos.y": 1510
                },
                {
                    "Name": "",
                    "Code.Type": "Turn",
                    "Code": [
                        "if(cargo_in_way!=0) {",
                        "  if(transfer_day<=CurTurn()) {",
                        "    //Значения переменной LTargetType",
                        "    //1 - Груз в пути к планете назначения",
                        "    //2 - Груз в пути к станции назначения",
                        "    //3 - Груз в пути к планете отправки (если планета назначения захвачена, либо станция назначения уничтожена)",
                        "    //4 - Груз в пути к станции отправки (если планета назначения захвачена, либо станция назначения уничтожена)",
                        "    //5 - Груз в пути к родной планете (если обе планеты назначения и отправки захвачены, либо уничтожены обе станции)",
                        "    ",
                        "    //Значения переменной CargoLost",
                        "    //0 - Груз успешно доставлен или возвращён обратно",
                        "    //1 - Груз будет потерян в пути, а системы отправки и назначения не пиратские",
                        "    //2 - Груз будет разграблен пиратами ближе к началу пути - система отправки пиратская",
                        "    //3 - Груз будет разграблен пиратами ближе к началу или к концу пути - системы отправки и назначения пиратские",
                        "    //4 - Груз будет разграблен пиратами ближе к концу пути - система назначения пиратская",
                        "    //5 - Груз будет потерян по прибытии в родную систему, которая захвачена доминаторами или клисанами",
                        "    ",
                        "    temp_str_4='';",
                        "    transfer_list='';",
                        "    if(LTargetType<5)",
                        "    {",
                        "    \tif(CargoLost==0)",
                        "    \t{",
                        "    \t\t//Прибытие груза на планету доставки",
                        "    \t\tif(LTargetType==1)",
                        "    \t\t{",
                        "    \t\t\tpoint_1=IdToPlanet(point_3);",
                        "    \t\t\ttemp_int=0;",
                        "    \t\t\ttemp_int_2=0;",
                        "    \t\t\tfor(i=1; i<=cargo_in_way; i=i+1)",
                        "    \t\t\t{",
                        "    \t\t\t\ttemp_dword=GetItemFromVault('player_bridge_transverservece_item_'+i);",
                        "    \t\t\t\ttransfer_list=transfer_list+'</color>- <color=255,240,100>'+Name(temp_dword)+'</color>'+Format(CT(\"Script.Mod_ExpPilotBridge.727\"),\"<0>\",ItemSize(temp_dword))+CT(\"Script.Mod_ExpPilotBridge.67\");",
                        "    \t\t\t\tAddItemToStorage(point_1,temp_dword);",
                        "    \t\t\t\ttemp_int=temp_int+1;",
                        "    \t\t\t\tif(temp_int>37)",
                        "    \t\t\t\t{",
                        "    \t\t\t\t\tif(!temp_int_2)NewsAdd(Format(CT(\"Script.Mod_ExpPilotBridge.755\"),\"<0>\",Name(point_1),\"<1>\",StarName(GalaxyStar(point_2_star)),\"<2>\",transfer_list));",
                        "    \t\t\t\t\telse NewsAdd(Format(CT(\"Script.Mod_ExpPilotBridge.730\"),\"<0>\",transfer_list));",
                        "    \t\t\t\t\ttransfer_list='';",
                        "    \t\t\t\t\ttemp_int_2=1;",
                        "    \t\t\t\t\ttemp_int=0;",
                        "    \t\t\t\t}",
                        "    \t\t\t}",
                        "    \t\t\tif(!temp_int_2)NewsAdd(Format(CT(\"Script.Mod_ExpPilotBridge.755\"),\"<0>\",Name(point_1),\"<1>\",StarName(GalaxyStar(point_2_star)),\"<2>\",transfer_list));",
                        "    \t\t\telse NewsAdd(Format(CT(\"Script.Mod_ExpPilotBridge.730\"),\"<0>\",transfer_list));",
                        "    \t\t\tcargo_in_way=0;",
                        "    \t\t}",
                        "    \t\t//Прибытие груза на станцию доставки",
                        "    \t\telse if(LTargetType==2)",
                        "    \t\t{",
                        "    \t\t\tpoint_1=IdToShip(point_3);",
                        "    \t\t\ttemp_int=0;",
                        "    \t\t\ttemp_int_2=0;",
                        "    \t\t\tfor(i=1; i<=cargo_in_way; i=i+1)",
                        "    \t\t\t{",
                        "    \t\t\t\ttemp_dword=GetItemFromVault('player_bridge_transverservece_item_'+i);",
                        "    \t\t\t\ttransfer_list=transfer_list+'</color>- <color=255,240,100>'+Name(temp_dword)+'</color>'+Format(CT(\"Script.Mod_ExpPilotBridge.727\"),\"<0>\",ItemSize(temp_dword))+CT(\"Script.Mod_ExpPilotBridge.67\");",
                        "    \t\t\t\tAddItemToStorage(point_1,temp_dword);",
                        "    \t\t\t\ttemp_int=temp_int+1;",
                        "    \t\t\t\tif(temp_int>37)",
                        "    \t\t\t\t{",
                        "    \t\t\t\t\tif(!temp_int_2)NewsAdd(Format(CT(\"Script.Mod_ExpPilotBridge.754\"),\"<0>\",Name(point_1),\"<1>\",StarName(ShipStar(point_1)),\"<2>\",transfer_list));",
                        "    \t\t\t\t\telse NewsAdd(Format(CT(\"Script.Mod_ExpPilotBridge.730\"),\"<0>\",transfer_list));",
