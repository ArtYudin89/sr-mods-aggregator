                    "Type": "Top",
                    "Parent": -1,
                    "Pos.x": 1270,
                    "Pos.y": 1000
                },
                {
                    "Name": "",
                    "Code.Type": "Turn",
                    "Code": [
                        "//Формирование списка предметов в диалоге и соответствующих ему ответов",
                        "if(GAnswerData>=100000000)temp_int=GAnswerData%100000000;",
                        "else temp_int=GAnswerData;",
                        "temp_int_2=0;",
                        "//Значения переменной temp_int_2: 1 - игрок нажал кнопку \"Добавить\", 2 - игрок нажал кнопку \"Удалить\"",
                        "//Добавляем предмет в список на перевозку",
                        "if(GAnswerData<100000000 && temp_int_2==0)",
                        "{",
                        "\ttemp_array_5[temp_int]=-1;",
                        "\ttemp_int_6=temp_int_6+1;",
                        "\ttemp_int_2=1;",
                        "}",
                        "//Удаляем предмет из списка на перевозку",
                        "if(GAnswerData>=100000000 && temp_int_2==0)",
                        "{",
                        "\ttemp_array_5[temp_int]=0;",
                        "\ttemp_int_6=temp_int_6-1;",
                        "\ttemp_int_2=2;",
                        "}",
                        "temp_int=0;",
                        "temp_str='';",
                        "//Заполняем строку с содержанием списка",
                        "for(i=1;i<ArrayDim(temp_array_5);i=i+1)",
                        "{",
                        "\tif(temp_array_5[i]==-1)",
                        "\t{",
                        "\t\ttemp_int=temp_int+1;",
                        "\t\ttemp_str=temp_str+'</color>'+temp_int+'. '+temp_array_6[i]+CT(\"Script.Mod_ExpPilotBridge.67\");",
                        "\t}",
                        "}",
                        "if(temp_int==0)temp_str=CT('FormInfo.td_otstup_HullCargoList'+GetGameOptions('FontDialog'))+CT(\"Script.Mod_ExpPilotBridge.1450\");",
                        "//Установка длины \"дефисного разделителя\" в зависимости от выбранного в игре размера шрифта",
                        "if(GetGameOptions('FontDialog')==0)DefSplt='</color>------------------------------';",
                        "if(GetGameOptions('FontDialog')==1)DefSplt='</color>--------------------------';",
                        "if(GetGameOptions('FontDialog')==2)DefSplt='</color>-----------------------------';",
                        "if(GetGameOptions('FontDialog')==3)DefSplt='</color>--------------------------';",
                        "DChange(31);",
                        "exit;"
