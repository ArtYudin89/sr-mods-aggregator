                        "    \t//Считаем украденные корпуса",
                        "    \tif((i==1 && (HullWasStolen==1 || HullWasStolen==3 || HullWasStolen==5 || HullWasStolen==7)) || (i==2 && (HullWasStolen==2 || HullWasStolen==3 || HullWasStolen==6 || HullWasStolen==7)) || (i==3 && (HullWasStolen==4 || HullWasStolen==5 || HullWasStolen==6 || HullWasStolen==7)))",
                        "    \t{",
