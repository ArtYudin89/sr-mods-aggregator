                        "    \t    else if((TransHullCost+temp_int_2)<1000 && (temp_int_4==4 || temp_int_4==5 || temp_int_4==6))TransHullCost=1000/3;",
                        "    \t    else if((TransHullCost+temp_int_2)<2000 && (temp_int_4==7 || temp_int_4==8))TransHullCost=2000/3;",
