                        "    \ttemp_str_2=CT('FormInfo.br')+'</color>- <color=255,240,100>'+Name(temp_dword_4)+'</color>'+' <color=255,240,100>[</color><color=0,255,0>'+ItemSize(temp_dword_4)+'</color><color=255,240,100>]</color>';",
                        "    \ttemp_int=substr(GAddTArray[i],0,1);",
