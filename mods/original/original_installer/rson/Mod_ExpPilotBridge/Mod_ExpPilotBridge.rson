                        "temp_int=NumberBox('Bm.ItemsUseless.2Usl_Elus_s',CT(\"Script.Mod_ExpPilotBridge.995\"),100,bld_cost-credits_now,ShipMoney(Player()),'Bm.FormCount2.2KindCredits');",
