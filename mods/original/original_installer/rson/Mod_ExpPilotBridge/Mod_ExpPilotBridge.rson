                        "\ttemp_dword=GetItemFromVault('player_bridge_transverservece_item_'+i);",
                        "\ttemp_str=temp_str+CT(\"Script.Mod_ExpPilotBridge.67\")+i+'. '+'<clr>'+DeleteTags(Name(temp_dword))+'<clrEnd>'+'</color> (<color=0,50,200>'+ItemSize(temp_dword)+CT(\"Script.Mod_ExpPilotBridge.771\");",
                        "\tPutItemInVault('player_bridge_transverservece_item_'+i,temp_dword);",
                        "}",
