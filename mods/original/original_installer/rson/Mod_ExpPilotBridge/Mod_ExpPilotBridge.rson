                        "    //Были украдены все корпуса",
                        "    if(HullOnWay==1 || (HullOnWay==2 && temp_int_5==2) || (HullOnWay==3 && temp_int_5==3))",
                        "    {",
                        "    \t//Установка минимальной цены (межсистемной)",
                        "        if(temp_int_3)",
                        "        {",
                        "    \t    if(TransHullCost<1250 && (temp_int_4==1 || temp_int_4==2 || temp_int_4==3))TransHullCost=1250;",
                        "    \t    else if(TransHullCost<3125 && (temp_int_4==4 || temp_int_4==5 || temp_int_4==6))TransHullCost=3125;",
                        "    \t    else if(TransHullCost<5000 && (temp_int_4==7 || temp_int_4==8))TransHullCost=5000;",
                        "        }",
