                    "#": 312
                },
                {
                    "Name": "GoToPrison",
                    "Type": "TDialog",
                    "Pos.x": 1020,
                    "Pos.y": 1025,
                    "Parent": -1,
                    "#": 313
                },
                {
                    "Name": "OutOfPrison",
                    "Type": "TDialog",
                    "Pos.x": 1170,
                    "Pos.y": 1025,
                    "Parent": -1,
                    "#": 314
                },
                {
