                        "      tstr=tstr+Format(CT(\"Script.Mod_ExpAcryn.859\"),\"<0>\",lowercase(substr(DeleteTags(Name(tdwd2)),0,1))+substr(DeleteTags(Name(tdwd2)),1));",
                        "      tstr2=tstr2+CT(\"Script.Mod_ExpAcryn.621\");",
                        "  }",
                        "  //Награда пиратами вручается во второй раз",
                        "  else if(fl_array[owner,1]==3)",
                        "  {",
                        "      tstr=tstr+Format(CT(\"Script.Mod_ExpAcryn.624\"),\"<0>\",lowercase(substr(DeleteTags(Name(tdwd2)),0,1))+substr(DeleteTags(Name(tdwd2)),1));",
                        "      tstr2=tstr2+CT(\"Script.Mod_ExpAcryn.616\");",
                        "  }",
                        "  //Награда пиратами вручается в третий раз",
                        "  else",
                        "  {",
                        "      tstr=tstr+Format(CT(\"Script.Mod_ExpAcryn.628\"),\"<0>\",lowercase(substr(DeleteTags(Name(tdwd2)),0,1))+substr(DeleteTags(Name(tdwd2)),1));",
                        "      tstr2=tstr2+CT(\"Script.Mod_ExpAcryn.619\");",
                        "  }",
                        "  ",
                        "  //Повышаем репутацию на всех пиратских планетах (они все наследуют отношение Роджерии)",
                        "  if(fl_array[owner,1]==2)tint=30;",
                        "  else if(fl_array[owner,1]==3)tint=50;",
                        "  else tint=70;",
                        "  RelationToRanger(PlanetPirateClan(),Player(),RelationToRanger(PlanetPirateClan(),Player())+tint);",
                        "  if(RelationToRanger(PlanetPirateClan(),Player())>100)RelationToRanger(PlanetPirateClan(),Player(),100);",
                        "  tdwd2=GetShipRuins(Player());",
