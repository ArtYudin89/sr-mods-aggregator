                    "Code.Type": "Turn",
                    "Code": [
                        "if(fl_array[owner,1]==2 && item_count<3) {",
                        "  DAdd(42);",
                        "  DAdd(44);",
                        "}",
                        "if(fl_array[owner,1]!=2 || item_count==3) {",
                        "  ExpAcrynQuestStatus=5;//Снова можно получать задания у других флагманов",
                        "  if(item_count==3)ExpAcrynQuestStatus=7;//Если получил 3 трионки в партии, то задания блокируются",
                        "  //Удаляем локализатор из трюма",
                        "  tdwd=ScriptItemToItem(Q_item);",
                        "  ReleaseItemFromScript(Q_item);",
                        "  FreeItem(GetArtFromShip(Player(),FindItemInShip(Player(),tdwd)));",
                        "  //Выдача трионных бонусов флагману, которому игрок сдал задание",
                        "  //Накладываем бонус на ту оборудку, которая доступна для выдачи данной расой",
                        "  tdwd=ShipEqInSlot(GetTalkShip(),fl_array[owner,7]);",
                        "  if(tdwd)",
                        "  {",
                        "      if(EqSpecial(tdwd)>-1)",
                        "      {",
                        "          //Сперва снимаем имеющийся акрин, если он есть",
                        "          //Но только если бонус не является неснимаемым",
                        "          if(CT('MicroModuls.'+BonusNumInCfg(EqSpecial(tdwd))+'.LockedAcryn')!=1 && CT('MicroModuls.'+BonusNumInCfg(EqSpecial(tdwd))+'.LockedAcryn')!=3)SpecialToEquipment(-1,tdwd);",
                        "          else tdwd=0;",
                        "      }",
                        "      if(tdwd)",
                        "      {",
                        "  \t    NoDropItem(tdwd,1);",
                        "  \t    for(i=0;i<7;i=i+1)",
                        "  \t    {",
                        "  \t\t    if(!MayAddBonusToEq(FindBonusByCustomTag('Fakrin_'+owner+'_'+i),tdwd))continue;",
                        "  \t\t    if(fl_array[owner,7]!=t_DefGenerator)EqSpecial(tdwd,FindBonusByCustomTag('Fakrin_'+owner+'_'+i));",
                        "  \t\t    if(fl_array[owner,7]==t_DefGenerator)",
                        "  \t\t    {",
                        "  \t\t\t    if(Rnd(0,100)<=50)EqSpecial(tdwd,FindBonusByCustomTag('Fakrin_'+owner+'_'+i));",
                        "  \t\t\t    else EqSpecial(tdwd,FindBonusByCustomTag('Fakrin_'+owner+'_'+i+'_2'));",
                        "  \t\t    }",
                        "  \t\t    break;",
                        "  \t    }",
                        "      }",
                        "  }",
                        "  tdwd=ShipEqInSlot(GetTalkShip(),fl_array[owner,8]);",
                        "  if(tdwd)",
                        "  {",
                        "      if(EqSpecial(tdwd)>-1)",
                        "      {",
                        "          //Сперва снимаем имеющийся акрин, если он есть",
                        "          //Но только если бонус не является неснимаемым",
                        "          if(CT('MicroModuls.'+BonusNumInCfg(EqSpecial(tdwd))+'.LockedAcryn')!=1 && CT('MicroModuls.'+BonusNumInCfg(EqSpecial(tdwd))+'.LockedAcryn')!=3)SpecialToEquipment(-1,tdwd);",
                        "          else tdwd=0;",
                        "      }",
                        "      if(tdwd)",
                        "      {",
                        "  \t    NoDropItem(tdwd,1);",
                        "  \t    for(i=0;i<7;i=i+1)",
                        "  \t    {",
                        "              if(EqSpecial(tdwd)>-1)SpecialToEquipment(-1,tdwd);//Сперва снимаем имеющийся акрин, если он есть",
                        "  \t\t    if(!MayAddBonusToEq(FindBonusByCustomTag('Fakrin_'+owner+'_'+i),tdwd))continue;",
                        "  \t\t    if(fl_array[owner,8]!=t_DefGenerator)EqSpecial(tdwd,FindBonusByCustomTag('Fakrin_'+owner+'_'+i));",
                        "  \t\t    if(fl_array[owner,8]==t_DefGenerator)",
                        "  \t\t    {",
                        "  \t\t\t    if(Rnd(0,100)<=50)EqSpecial(tdwd,FindBonusByCustomTag('Fakrin_'+owner+'_'+i));",
                        "  \t\t\t    else EqSpecial(tdwd,FindBonusByCustomTag('Fakrin_'+owner+'_'+i+'_2'));",
                        "  \t\t    }",
                        "  \t\t    break;",
                        "  \t    }",
