                        "  if(tint==1)tstr='</color>'+CT(\"Script.Mod_ExpAcryn.609\");",
                        "  else if(tint>=2 && tint<=4)tstr='</color>'+CT(\"Script.Mod_ExpAcryn.608\");",
                        "  else if(tint>=5)tstr='</color>'+CT(\"Script.Mod_ExpAcryn.607\");",
                        "  tstr2='</color>'+CT(\"Script.Mod_ExpAcryn.337\");",
                        "  DChange(21);",
                        "  exit;",
                        "}",
