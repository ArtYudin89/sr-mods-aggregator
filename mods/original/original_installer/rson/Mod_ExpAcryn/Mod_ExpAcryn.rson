                        "          if(ExpAcrynQuestStatus == 3 || ExpAcrynQuestStatus == 4)",
                        "          {",
                        "              tstr2=tstr2+Format(CT(\"Script.Mod_ExpAcryn.730\"),\"<0>\",DefSplt,\"<1>\",tstr,\"<2>\",DefSplt);",
                        "              tstr3='</color>'+CT(\"Script.Mod_ExpAcryn.370\");",
                        "          }",
                        "          //Игрок согласился выполнить первое задание пеленгов или людей",
                        "          else",
                        "          {",
                        "              tstr2=tstr2+Format(CT(\"Script.Mod_ExpAcryn.593\"),\"<0>\",DefSplt,\"<1>\",tstr,\"<2>\",DefSplt);",
                        "              tstr3='</color>'+CT(\"Script.Mod_ExpAcryn.473\");",
                        "          }",
                        "      }",
                        "      else if(GAnswerData == 3)",
                        "      {",
                        "          //Игрок согласился выполнить второе задание пеленгов",
                        "          tstr2=tstr2+Format(CT(\"Script.Mod_ExpAcryn.409\"),\"<0>\",DefSplt,\"<1>\",tstr,\"<2>\",DefSplt);",
                        "          tdwd=ScriptItemToItem(Q_item);",
                        "          UselessItemData(tdwd,2,0);",
                        "          UselessItemData(tdwd,1,0);",
                        "          Ether(3,'ExpAcryn_quest_1',CT('Script.Mod_ExpAcryn.MissionIsActive')+Format(CT('Script.Mod_ExpAcryn.PelengMission2'),'#ItemName#',addItemName));",
                        "          tstr3='</color>'+CT(\"Script.Mod_ExpAcryn.473\");",
                        "      }",
                        "      else if(GAnswerData == 4)",
                        "      {",
                        "          //Игрок согласился выполнить второе задание людей",
                        "          tstr2=tstr2+Format(CT(\"Script.Mod_ExpAcryn.602\"),\"<0>\",DefSplt,\"<1>\",tstr,\"<2>\",DefSplt);",
                        "          PlayerChameleonCharges(0,PlayerChameleonCharges(0)+1);",
                        "          PlayerChameleonCharges(1,PlayerChameleonCharges(1)+1);",
                        "          PlayerChameleonCharges(2,PlayerChameleonCharges(2)+1);",
                        "          //Выдаём пять \"Интеркомов\"",
                        "          SetProgramm(5,GetProgramm(5)+5);",
                        "          Ether(3,'ExpAcryn_quest_2',CT('Script.Mod_ExpAcryn.MissionIsActive')+Format(CT('Script.Mod_ExpAcryn.PeopleMission2'),'#ItemName#',addItemName));",
                        "          tstr3='</color>'+CT(\"Script.Mod_ExpAcryn.583\");",
                        "      }",
                        "      else if(GAnswerData == 5)",
                        "      {",
                        "          //Игрок согласился выполнить второе задание фэян или гаальцев",
                        "          tstr2=tstr2+Format(CT(\"Script.Mod_ExpAcryn.718\"),\"<0>\",DefSplt,\"<1>\",tstr,\"<2>\",DefSplt);",
                        "          tstr3='</color>'+CT(\"Script.Mod_ExpAcryn.846\");",
                        "      }",
                        "      else if(GAnswerData == 10)tstr2=tstr2+Format(CT(\"Script.Mod_ExpAcryn.402\"),\"<0>\",DefSplt,\"<1>\",tstr,\"<2>\",DefSplt);",
                        "  }",
                        "  else tstr2=tstr2+Format(CT(\"Script.Mod_ExpAcryn.594\"),\"<0>\",DefSplt,\"<1>\",tstr,\"<2>\",DefSplt);",
                        "  DChange(23);",
                        "  exit;",
                        "}"
