                },
                {
                    "Name": "",
                    "Pos.x": 840,
                    "Pos.y": 715,
                    "Type": "TDialogAnswer",
                    "Parent": -1,
                    "#": 139,
                    "Msg": "Научный прогресс для меня превыше личной безопасности - я в деле",
