                        "    tint=5-fl_array[owner,2];",
                        "    if(tint==1)tstr2='</color>'+CT(\"Script.Mod_ExpAcryn.557\");",
                        "    else if(tint>=2 && tint<=4)tstr2='</color>'+CT(\"Script.Mod_ExpAcryn.556\");",
                        "    else if(tint==5)tstr2='</color>'+CT(\"Script.Mod_ExpAcryn.555\");",
                        "    if(tint2)tstr='</color>'+Format(CT(\"Script.Mod_ExpAcryn.589\"),\"<0>\",tint,\"<1>\",tstr2);",
                        "    else tstr='</color>'+Format(CT(\"Script.Mod_ExpAcryn.553\"),\"<0>\",tint,\"<1>\",tstr2);",
                        "    DChange(7);",
                        "    exit;",
                        "  }",
