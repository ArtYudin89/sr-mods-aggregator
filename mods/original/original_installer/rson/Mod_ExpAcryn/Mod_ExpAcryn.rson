                {
                    "Name": "",
                    "Code.Type": "Turn",
                    "Code": [
                        "if(GAnswerData==1) {",
                        "  DChange(50);",
                        "  exit;",
                        "}",
                        "if(GAnswerData!=1) {",
                        "  tint=max(1000,GalaxyMoney(2,3));",
                        "  tint=round(1.20*tint);",
                        "  tint=tint+(tint*PlayerChameleonCharges(0))/10;",
                        "  //У пеленгов цена камуфляжа будет всегда выше, а у фэян и гаальцев ниже базовой",
                        "  if(owner==1)tint=round(1.30*tint);",
                        "  else if(owner==3)tint=round(0.75*tint);",
                        "  else if(owner==4)tint=round(0.90*tint);",
                        "  i=tint;",
                        "  tstr='</color>'+Format(CT(\"Script.Mod_ExpAcryn.362\"),\"<0>\",tint);",
                        "  tint=max(1000,GalaxyMoney(2,3));",
                        "  tint=round(1.10*tint);",
                        "  tint=tint+(tint*PlayerChameleonCharges(1))/10;",
                        "  if(owner==1)tint=round(1.30*tint);",
                        "  else if(owner==3)tint=round(0.75*tint);",
                        "  else if(owner==4)tint=round(0.90*tint);",
                        "  j=tint;",
                        "  tstr=tstr+CT(\"Script.Mod_ExpAcryn.147\")+Format(CT(\"Script.Mod_ExpAcryn.361\"),\"<0>\",tint);",
                        "  tint=max(1000,GalaxyMoney(2,3));",
                        "  tint=round(1.30*tint);",
                        "  tint=tint+(tint*PlayerChameleonCharges(2))/10;",
                        "  if(owner==1)tint=round(1.30*tint);",
                        "  else if(owner==3)tint=round(0.75*tint);",
                        "  else if(owner==4)tint=round(0.90*tint);",
                        "  k=tint;",
                        "  tstr=tstr+CT(\"Script.Mod_ExpAcryn.147\")+Format(CT(\"Script.Mod_ExpAcryn.360\"),\"<0>\",tint);",
                        "  ",
                        "  if(GetGameOptions('FontDialog') == 0)DefSplt='</color>------------------------------------------------------------------';",
                        "  else if(GetGameOptions('FontDialog') == 1)DefSplt='</color>-----------------------------------------------';",
                        "  else if(GetGameOptions('FontDialog') == 2)DefSplt='</color>-----------------------------------------------';",
                        "  else if(GetGameOptions('FontDialog') == 3)DefSplt='</color>-----------------------------------------';",
                        "  ",
                        "  tstr2='</color>';",
                        "  tstr3='</color>'+CT(\"Script.Mod_ExpAcryn.370\");",
                        "  if(GAnswerData)",
                        "  {",
