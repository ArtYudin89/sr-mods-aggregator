                        "  RelationToRanger(tdwd2,Player(),RelationToRanger(tdwd2,Player())+tint);",
                        "  if(RelationToRanger(tdwd2,Player())>100)RelationToRanger(tdwd2,Player(),100);",
                        "  ",
                        "  //Выводим уведомление о продлении и об успешном выполнении миссии (если была выполнена уже третья)",
                        "  if(fl_array[owner,1]==2)Ether(3,'ExpAcryn_quest_5',CT('Script.Mod_ExpAcryn.MissionIsActive')+CT('Script.Mod_ExpAcryn.PirateMission2'));",
                        "  else if(fl_array[owner,1]==3)Ether(3,'ExpAcryn_quest_5',CT('Script.Mod_ExpAcryn.MissionIsActive')+CT('Script.Mod_ExpAcryn.PirateMission3'));",
                        "  else Ether(4,'ExpAcryn_quest_5',CT('Script.Mod_ExpAcryn.MissionAccomplished')+CT('Script.Mod_ExpAcryn.PirateMission3'));",
                        "  DChange(22);",
                        "  exit;",
