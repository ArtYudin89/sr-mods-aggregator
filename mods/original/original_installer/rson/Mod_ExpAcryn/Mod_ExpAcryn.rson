            "Operations": [
                {
                    "Name": "",
                    "Code.Type": "Global",
                    "Code": [
                        "GRun();"
                    ],
                    "#": 38,
                    "Type": "Top",
                    "Parent": -1,
                    "Pos.x": 0,
                    "Pos.y": 885
                },
                {
                    "Name": "",
                    "Code.Type": "Init",
                    "Code": [
                        "//Значения массива fl_array:",
                        "//fl_array[0], fl_array[1], fl_array[2], fl_array[3], fl_array[4], fl_array[5] - разделы всех коалиционных рас и пиратов",
                        "//   0 - малоки",
                        "//   1 - пеленги",
                        "//   2 - люди",
                        "//   3 - фэяне",
                        "//   4 - гаальцы",
                        "//   5 - пираты",
                        "//Каждый элемент разбит на 11 подразделов:",
                        "//fl_array[owner, 0] - --- (видимо, Хук оставил пустым, чтобы удобнее было переборы делать :|)",
                        "//fl_array[owner, 1] - статус задания данной расы:",
                        "//   0 - не взято",
                        "//   1 - взято",
                        "//   2 - выполнено один раз",
                        "//   3 - выполнено два раза (за второе выполнение доп. награда - набор)",
                        "//   4 - задание выполнено три раза (только для пиратов)",
                        "//fl_array[owner, 2] - число собранных по заданию предметов/данных/кораблей (обычно от 0 до 5, но у пиратов до 6)",
                        "//fl_array[owner, 3] - ---",
                        "//fl_array[owner, 4] - ---",
                        "//fl_array[owner, 5] - переменная в задании гаальцев, в которую записывается время до раскрытия доминаторами намерений игрока после захвата им бертора (CurTurn() + X)",
                        "//fl_array[owner, 6] - переменная в задании фэян, засекает время, которое робот-шпион проводит на борту бертора перед взлётом или перепрограммированием (CurTurn() + 2)",
                        "//fl_array[owner, 7] - тип первого трионного оборудования, которое игрок сможет получить в этой партии у данной расы",
                        "//fl_array[owner, 8] - тип второго трионного оборудования, которое игрок сможет получить в этой партии у данной расы",
                        "//fl_array[owner, 9] - тип третьего трионного оборудования, которое игрок сможет получить в этой партии у данной расы",
                        "//(если задания берутся у флагманов, то третье оборудования всегда получается у другой расы, не первой, к которой обратился игрок)",
                        "//fl_array[owner, 10] - ---",
                        "",
                        "//Значения переменной ExpAcrynQuestStatus:",
                        "//ExpAcrynQuestStatus == 10 - стартовое значение переменной, означает, что игрок может получить кейс при повышении звания на ВБ",
                        "//ExpAcrynQuestStatus == 11 - игрок получил звание \"Капитан\" и вместе с ним кейс - начало цепочки всех дальнейших событий",
                        "//ExpAcrynQuestStatus == 12 - игрок сдал кейс пиратам, задания флагманов более недоступны (хотя фактически они перестают быть доступны уже после вступления игрока в пиратский клан)",
                        "//ExpAcrynQuestStatus == 0 - игрок в настоящий момент выполняет задание для малокского флагмана",
                        "//ExpAcrynQuestStatus == 1 - игрок в настоящий момент выполняет задание для пеленгского флагмана",
                        "//ExpAcrynQuestStatus == 2 - игрок в настоящий момент выполняет задание для человеческого флагмана",
                        "//ExpAcrynQuestStatus == 3 - игрок в настоящий момент выполняет задание для фэянского флагмана",
                        "//ExpAcrynQuestStatus == 4 - игрок в настоящий момент выполняет задание для гаальского флагмана",
                        "//ExpAcrynQuestStatus == 5 - игрок готов получить задание у любого флагмана (кейс уже сдан на флагман и получить пиратское задание больше нельзя)",
                        "//ExpAcrynQuestStatus == 7 - все дальнейшие задания в партии заблокированы, т.к. сработало одно из завершающих условий;",
                        "",
                        "//Значения переменной GFlagFeiTempVar (фэянская переменная):",
                        "//GFlagFeiTempVar == 0 - базовое состояние, задание ещё не взято, либо по квесту пока ничего не происходит",
                        "//GFlagFeiTempVar == 1 - робот-шпион запущен и сейчас направляется к бертору",
                        "//GFlagFeiTempVar == 2 - робот-шпион добрался до бертора и передаёт игроку код для расшифровки",
                        "//GFlagFeiTempVar == 3 - робот-шпион получил от игрока код и тот оказался верным, совершается посадка на бертора",
                        "//GFlagFeiTempVar == 4 - робот-шпион получил от игрока код и тот оказался неверным, совершается посадка на бертора",
                        "//GFlagFeiTempVar == 5 - робот-шпион извлёк данные из бертора, взлетел, и сейчас возвращается к игроку",
                        "//GFlagFeiTempVar == 6 - робот-шпион садится на игрока после возвращения с данными",
                        "//GFlagFeiTempVar == 7 - робот-шпион совершил успешную посадку на игрока после извлечения данных",
                        "//GFlagFeiTempVar == 8 - что-то пошло не так, и робот-шпион возвращается к игроку не долетев до бертора",
                        "//GFlagFeiTempVar == 9 - робот-шпион вернулся на игрока без данных (трансферим его на планету для уничтожения, а если у игрока в трюме нет Р.Д.П.К., то выводим экран смерти)",
                        "//GFlagFeiTempVar == 10 - робот-шпион вернулся на игрока с данными (трансферим его на планету для уничтожения, а если у игрока в трюме нет Р.Д.П.К., то выводим экран смерти)",
                        "",
                        "//Значения переменной GFlagGaalTempVar (гаальская переменная):",
                        "//GFlagGaalTempVar == 0 - задание гаальцев ещё не взято",
                        "//GFlagGaalTempVar == 1 - задание гаальцев взято, но бертор ещё не захвачен (состояние готовности конвектора к захвату бертора)",
                        "//GFlagGaalTempVar == 2 - бертор захвачен конвектором и следует за игроком",
                        "//GFlagGaalTempVar == 3 - захваченный бертор выполняет приказ игрока на прыжок",
                        "//GFlagGaalTempVar == 4 - захваченный бертор прибыл в другую систему или ещё находится в гипере, но уже точно в другой системе",
                        "//GFlagGaalTempVar == 5 - захваченный бертор уничтожен правильно и должен дропнуть блок памяти (это состояние переменной выставляется акткодом костыльной \"семерёнки\")",
                        "",
                        "//Переменная, обозначающая какой расе был сдан кейс с секретными данными",
                        "caseIn = 10;",
                        "",
                        "//Создаём костыльную \"семерёнку\" для занесения кораблей в скриптовые группы непосредственно из акт и юзкода",
                        "tdwd = CreateQuestItem('Usl_62', 0);",
                        "LinkItemToScript(tdwd, Semerenka);",
                        "PutItemInVault('Mod_ExpAcryn_Semerenka', tdwd);",
                        "ItemOnActCode(Semerenka, 'if(ScriptItemActionType(t_OnStep, 0)){ShipJoin(q_ship, ScriptItemActShip());}if(ScriptItemActionType(t_OnStep, 1)){ShipJoin(q_ship2, ScriptItemActShip());}');",
                        "",
                        "//Выставляем маркер о том, что был подключён мод EvoArmada",
                        "if(BlockExist('Script.Mod_EvoArmada')) EvoArmadaInit = 1;",
                        "",
                        "//Главный двухмерный массив мода заполняется нулями",
                        "fl_array = newarray(6, 11);",
                        "for(i = 0; i < 6; i = i + 1)",
                        "{",
                        "\tfor(j = 1; j < 11; j = j + 1) fl_array[i, j] = 0;",
                        "}",
                        "//Функция перезаполнения массива в случае, если награды кончились",
                        "function FormRewardsArray() {",
                        "    ArrayClear(temp_array);",
                        "    for(int i=t_FuelTanks; i<=t_DefGenerator; i=i+1) ArrayAdd(temp_array, i);",
                        "}",
                        "FormRewardsArray(); //Формируем первичный список выдачи оборудки",
                        "//Запоминаются типы трионки, которые игрок сможет получить в этой партии:",
                        "for(i=0; i<6; i=i+1) { //Расы",
                        "    for(j=7; j<=8; j=j+1) { //Номера оборудки",
                        "        if(ArrayDim(temp_array)<=1) FormRewardsArray(); //Если кончилось уникальное оборудование, перезаполняем массив",
                        "        tint=Rnd(1, ArrayDim(temp_array)-1);",
                        "        if(j==8) { //Вторая трионка",
                        "            while(temp_array[tint]==fl_array[i,7]) {",
                        "                ArrayDelete(temp_array, tint);",
                        "                if(ArrayDim(temp_array)<=1) FormRewardsArray();",
                        "                tint=Rnd(1, ArrayDim(temp_array)-1);",
                        "            }",
                        "        }",
                        "        fl_array[i,j]=temp_array[tint]; //Запоминаем тип оборудки для первой трионки",
                        "        ArrayDelete(temp_array, tint); //Удаляем из массива во избежание повторов",
                        "    }",
                        "    if(i==5) { //Третья трионка для пиратов",
                        "        if(ArrayDim(temp_array)<=1) FormRewardsArray();",
                        "        tint=Rnd(1, ArrayDim(temp_array)-1);",
                        "        while(temp_array[tint]==fl_array[i,7] || temp_array[tint]==fl_array[i,8]) {",
                        "            ArrayDelete(temp_array, tint);",
                        "            if(ArrayDim(temp_array)<=1) FormRewardsArray();",
                        "            tint=Rnd(1, ArrayDim(temp_array)-1);",
                        "        }",
                        "        fl_array[i,9]=temp_array[tint];",
                        "        ArrayDelete(temp_array, tint);",
                        "    }",
                        "}",
                        "ArrayClear(temp_array);",
                        "//Неизвестные модификации раскидываются по берторам",
                        "for(j=0;j<GalaxyStars();j=j+1)",
                        "{",
                        "\ttdwd=GalaxyStar(j);",
                        "\tfor(i=0;i<StarShips(tdwd);i=i+1)",
                        "\t{",
                        "\t\ttdwd2=StarShips(tdwd,i);",
                        "\t\tif(ShipTypeN(tdwd2)!=t_Kling)continue;",
                        "\t\tif(ShipSubType(tdwd2)!=6)continue;",
                        "\t\ttint=ItemSubrace(ShipItems(tdwd2,0));",
                        "\t\tif(!ShipEqInSlot(tdwd2,t_RepairRobot))",
                        "\t\t{",
                        "\t\t\ttdwd3=CreateEquipment(t_RepairRobot,Rnd(35,60),GalaxyTechLevel(),Kling);",
                        "\t\t\tItemSubrace(tdwd3,tint);",
                        "\t\t\tAddItemToShip(tdwd2,tdwd3);",
                        "\t\t\tItemIsInUse(tdwd3,tdwd2,1);",
                        "\t\t}",
                        "\t\tif(!ShipEqInSlot(tdwd2,t_DefGenerator))",
                        "\t\t{",
                        "\t\t\ttdwd3=CreateEquipment(t_DefGenerator,Rnd(35,60),GalaxyTechLevel(),Kling);",
                        "\t\t\tItemSubrace(tdwd3,tint);",
                        "\t\t\tAddItemToShip(tdwd2,tdwd3);",
                        "\t\t\tItemIsInUse(tdwd3,tdwd2,1);",
                        "\t\t}",
                        "\t\ttint=0;",
                        "\t\twhile(!tint)",
                        "\t\t{",
                        "\t\t\ttdwd3=ShipEqInSlot(tdwd2,Rnd(t_FuelTanks,t_DefGenerator));",
                        "\t\t\tif(tdwd3)",
                        "\t\t\t{",
                        "\t\t\t\ttint=1;",
                        "\t\t\t\ttstr2='<color=255,167,84>'+Name(tdwd3)+'</color>';",
                        "\t\t\t\tEqSpecial(tdwd3,FindBonusByCustomTag('Akrin_dom_ship'));",
                        "\t\t\t\tSetName(tdwd3,tstr2);",
                        "                NoDropItem(tdwd3,1);",
                        "\t\t\t}",
                        "\t\t}",
                        "\t}",
                        "}",
                        "last_ship_id=GalaxyShipId()-1;",
                        "",
                        "//Функция для завершения миссии флагмана/доминиона и выдачи награды",
                        "function EndFlagmanMission()",
                        "{",
                        "\ttdwd2=0;",
                        "\ttdwd3=0;",
                        "    //Определяем, какую именно трионку получит игрок (типы записаны в массив при инициации скрипта)",
                        "    if(owner==5) { //Три трионки у пиратов",
                        "    \tif(item_count==0) tint=7;",
                        "\t    else if(item_count==1) tint=8;",
                        "\t    else if(item_count==2) tint=9;",
                        "    }",
                        "    else { //Две у остальных",
                        "        if(item_count==1) tint=8;",
                        "        else tint=7;",
                        "    }",
                        "\t//Если типом выпавшей оборудки оказался сканер или радар, то создаём трионку с весом 15",
                        "\tif(fl_array[owner,tint]==t_Scaner || fl_array[owner,tint]==t_Radar)",
                        "    {",
                        "        if(owner<5)tdwd2=CreateEquipment(fl_array[owner,tint],15,GalaxyTechLevel(),owner);",
                        "        else tdwd2=CreateEquipment(fl_array[owner,tint],15,GalaxyTechLevel(),7);",
                        "    }",
                        "\t//Иначе - с весом 20",
                        "\telse if(owner<5)tdwd2=CreateEquipment(fl_array[owner,tint],20,GalaxyTechLevel(),owner);",
                        "    else tdwd2=CreateEquipment(fl_array[owner,tint],20,GalaxyTechLevel(),7);",
                        "\t//Ищем корректный тип бонуса для данного типа оборудки",
                        "\tfor(i=0;i<7;i=i+1)",
                        "\t{",
                        "\t\tif(!MayAddBonusToEq(FindBonusByCustomTag('Fakrin_'+owner+'_'+i),tdwd2))continue;",
                        "\t\tif(fl_array[owner,tint]!=t_DefGenerator)EqSpecial(tdwd2,FindBonusByCustomTag('Fakrin_'+owner+'_'+i));",
                        "\t\t//Если оборудка - ГЗП, то с шансом в 50% вешаем на неё альтернативный вариант бонуса",
                        "\t\telse",
                        "\t\t{",
                        "\t\t\tif(Rnd(1,100)>50)EqSpecial(tdwd2,FindBonusByCustomTag('Fakrin_'+owner+'_'+i));",
                        "\t\t\telse EqSpecial(tdwd2,FindBonusByCustomTag('Fakrin_'+owner+'_'+i+'_2'));",
                        "\t\t}",
                        "\t\tbreak;",
                        "\t}",
                        "\t//Переносим готовую трионку на корабль игрока и прокручиваем счётчики",
                        "\tAddItemToShip(Player(),tdwd2);",
                        "    item_count=item_count+1;",
                        "    //Если заказчик - флагман",
                        "\tif(owner<5)",
                        "    {",
                        "        fl_array[owner,2]=fl_array[owner,2]-5;",
                        "        tint2=3;",
                        "    }",
                        "    //Если заказчик - пираты",
                        "    else",
                        "    {",
                        "        fl_array[owner,2]=fl_array[owner,2]-6;",
                        "        tint2=4;",
                        "    }",
                        "\tfl_array[owner,1]=fl_array[owner,1]+1;",
                        "",
                        "\t//Игрок выполнил второе (если заказчик пираты, то уже третье) задание и вместе с трионкой получил дополнительную награду - набор для замены системы-блокиратора",
                        "    if(fl_array[owner,1]==tint2)",
                        "\t{",
                        "\t\ttdwd3=CreateQuestItem('Mod_ExpAcryn_item_'+(tint2-2));",
                        "        if(owner<5)ItemOwner(tdwd3,owner);",
                        "        else ItemOwner(tdwd3,7);",
                        "\t\tAddItemToShip(Player(),tdwd3);",
                        "\t}",
                        "}"
                    ],
                    "#": 39,
                    "Type": "Top",
                    "Parent": -1,
                    "Pos.x": 60,
                    "Pos.y": 885
                },
                {
                    "Name": "",
                    "Code.Type": "Turn",
                    "Code": [
                        "if(!ShipIsTakeoff(Player())) {",
                        "  //Выставляем маркер о том, что был подключён мод EvoArmada",
                        "  if(!EvoArmadaInit)",
                        "  {",
                        "      if(BlockExist('Script.Mod_EvoArmada')) EvoArmadaInit = 1;",
                        "  }",
                        "  ",
                        "  if(ExpAcrynQuestStatus!=7)",
                        "  {",
                        "  \t//Проверка на прибытие игрока на родную планету для получения звания Капитан (работает только вместе с модом ShuHomeland)",
                        "  \t//Выдаём игроку чемодан даже в столь необычной ситуации",
                        "  \tif(~HomeGiveCaseCheck)",
                        "  \t{",
                        "  \t\tif(IsScriptActive('Mod_ShuHomeland'))",
                        "  \t\t{",
                        "  \t\t\tif(GetValueFromScript('Mod_ShuHomeland','MBExist')==0)",
                        "  \t\t\t{",
                        "  \t\t\t\tif(GetShipPlanet(Player())==GetShipHomePlanet(Player()))",
                        "  \t\t\t\t{",
                        "  \t\t\t\t\tif(PlanetOwner(GetShipPlanet(Player()))>=0 && PlanetOwner(GetShipPlanet(Player()))<=4)",
                        "  \t\t\t\t\t{",
                        "  \t\t\t\t\t\tif(RelationToRanger(GetShipPlanet(Player()),Player())>=30)",
                        "  \t\t\t\t\t\t{",
                        "  \t\t\t\t\t\t\tif(ShipOwner(Player())>=0 && ShipOwner(Player())<=4)",
                        "  \t\t\t\t\t\t\t{",
                        "  \t\t\t\t\t\t\t\tif(ShipRank(Player())==2 && !ShipInPirateClan(Player()))",
                        "  \t\t\t\t\t\t\t\t{",
                        "  \t\t\t\t\t\t\t\t\tif(ShipRankPoints(Player())>=ShipNextRankPoints(Player())) HomeGiveCaseCheck=1;",
                        "  \t\t\t\t\t\t\t\t}",
                        "  \t\t\t\t\t\t\t}",
                        "  \t\t\t\t\t\t}",
                        "  \t\t\t\t\t}",
                        "  \t\t\t\t}",
                        "  \t\t\t\telse if(HomeGiveCaseCheck==1) HomeGiveCaseCheck=0;",
                        "  \t\t\t}",
                        "  \t\t}",
                        "  \t}",
                        "  \tif(ExpAcrynQuestStatus==11 && HomeGiveCaseCheck==1) HomeGiveCaseCheck=-1;//Выключаем проверочную переменную выдачи кейса на родной планете до конца партии",
                        "  ",
                        "  \t//Игрок взял задание у флагмана, а потом вступил в пиратский клан (либо уничтожил всех доминаторов) - все задания провалены до конца партии",
                        "  \tif(ExpAcrynQuestStatus<6 && (ShipInPirateClan(Player()) || DomiksDefeated()))",
                        "  \t{",
                        "  \t\tif(EtherState('ExpAcryn_quest_'+ExpAcrynQuestStatus)>-1)",
                        "  \t\t{",
                        "  \t\t\tif(fl_array[ExpAcrynQuestStatus,1]==1)tstr='';",
                        "  \t\t\telse tstr='2';",
                        "  \t\t\tif(ExpAcrynQuestStatus==0)Ether(5,'ExpAcryn_quest_0',CT('Script.Mod_ExpAcryn.MissionFailed')+Format(CT('Script.Mod_ExpAcryn.MalocMission'+tstr),'#ItemName#',addItemName));",
                        "  \t\t\telse if(ExpAcrynQuestStatus==1)Ether(5,'ExpAcryn_quest_1',CT('Script.Mod_ExpAcryn.MissionFailed')+Format(CT('Script.Mod_ExpAcryn.PelengMission'+tstr),'#ItemName#',addItemName));",
                        "  \t\t\telse if(ExpAcrynQuestStatus==2)",
                        "              {",
                        "                  Ether(5,'ExpAcryn_quest_2',CT('Script.Mod_ExpAcryn.MissionFailed')+Format(CT('Script.Mod_ExpAcryn.PeopleMission'+tstr),'#ItemName#',addItemName));",
                        "                  ShipDeleteCustomShipInfo(Player(),'ExpAcryn_mimi_player_infos');",
                        "              }",
                        "  \t\t\telse if(ExpAcrynQuestStatus==3)Ether(5,'ExpAcryn_quest_3',CT('Script.Mod_ExpAcryn.MissionFailed')+Format(CT('Script.Mod_ExpAcryn.FeiMission'+tstr),'#ItemName#',addItemName));",
                        "  \t\t\telse if(ExpAcrynQuestStatus==4)Ether(5,'ExpAcryn_quest_4',CT('Script.Mod_ExpAcryn.MissionFailed')+Format(CT('Script.Mod_ExpAcryn.GaalMission'+tstr),'#ItemName#',addItemName));",
                        "  \t\t}",
                        "  \t\t//Также понижаем его репутацию на всех планетах соответствующей расы",
                        "  \t\tfor(i=0;i<GalaxyStars();i=i+1)",
                        "  \t\t{",
                        "  \t\t\ttdwd=GalaxyStar(i);",
                        "  \t\t\tif(StarOwner(tdwd)!=0)continue;",
                        "  \t\t\tfor(j=0;j<StarPlanets(tdwd);j=j+1)",
                        "  \t\t\t{",
                        "  \t\t\t\ttdwd2=StarPlanets(tdwd,j);",
                        "  \t\t\t\tif(PlanetOwner(tdwd2)!=ExpAcrynQuestStatus)continue;",
                        "  \t\t\t\tRelationToRanger(tdwd2,Player(),RelationToRanger(tdwd2,Player())-30);",
                        "  \t\t\t\tif(RelationToRanger(tdwd2,Player())<10)RelationToRanger(tdwd2,Player(),10);",
                        "  \t\t\t}",
                        "  \t\t}",
                        "  \t\tReleaseItemFromScript(Q_item);",
                        "  \t\tExpAcrynQuestStatus=7;",
                        "  \t}",
                        "  \t//Игрок выполнял задание пиратов, но те победили/проиграли (либо побеждены домики) - все задания провалены до конца партии",
                        "  \tif(ExpAcrynQuestStatus==12 && (PirateWin() || DomiksDefeated()))",
                        "  \t{",
                        "  \t    if(EtherState('ExpAcryn_quest_5')>-1)Ether(5,'ExpAcryn_quest_5',CT('Script.Mod_ExpAcryn.MissionFailed')+CT('Script.Mod_ExpAcryn.PirateMission'));",
                        "  \t    ExpAcrynQuestStatus=7;",
                        "  \t}",
                        "  ",
                        "  \t//Код, исполняемый пока игрок выполняет задание малоков",
                        "      if(ExpAcrynQuestStatus==0)",
                        "      {",
                        "          //Задание будет провалено, если уничтожен локализатор",
                        "  \t\tif(!ItemExist(Q_item))",
                        "  \t\t{",
                        "  \t\t\t//Локализатор уничтожен - все задания флагманов провалены до конца партии",
                        "  \t\t\tif(EtherState('ExpAcryn_quest_0')>-1)",
                        "  \t\t\t{",
                        "  \t\t\t\ttstr='';",
                        "  \t\t\t\tif(fl_array[0,1]!=1)tstr='2';",
                        "  \t\t\t\tEther(5,'ExpAcryn_quest_0',CT('Script.Mod_ExpAcryn.MissionFailed')+Format(CT('Script.Mod_ExpAcryn.MalocMission'+tstr),'#ItemName#',GetValueFromScript('Mod_ExpAcryn','addItemName')));",
                        "  \t\t\t}",
                        "  \t\t\t//Также снижаем репутацию на всех малокских планетах",
                        "              tdwd=GlobalRelationsPlanets(Player(), 0, 1);",
                        "              if(tdwd>85) ChangeGlobalRelationsPlanets(Player(), 0, 3, 75, 1);",
                        "              else ChangeGlobalRelationsPlanets(Player(), 0, 0, 10, 1);",
                        "  \t\t\tExpAcrynQuestStatus=7;",
                        "  \t\t}",
                        "      }",
                        "  \t//Код, исполняемый пока игрок выполняет задание пеленгских флагманов (сканирование берторов разведзондом)",
                        "  \telse if(ExpAcrynQuestStatus==1)",
                        "  \t{",
                        "          if(fl_array[1,2]<5)",
                        "          {",
                        "  \t\t\ttdwd=ScriptItemToItem(Q_item);",
                        "  \t\t\tif(tdwd)",
                        "  \t\t\t{",
                        "  \t\t\t\ttint=UselessItemData(tdwd,3);",
                        "  \t\t\t\tif(tint!=-1)",
                        "  \t\t\t\t{",
                        "  \t\t\t\t\ttdwd2=GalaxyStar(tint-1);",
                        "  \t\t\t\t\tif(ItemIn(Q_item,tdwd2))",
                        "  \t\t\t\t\t{",
                        "  \t\t\t\t\t\tfor(i=0;i<StarShips(tdwd2);i=i+1)",
                        "  \t\t\t\t\t\t{",
                        "  \t\t\t\t\t\t\ttdwd3=StarShips(tdwd2,i);",
                        "  \t\t\t\t\t\t\tif(ShipOwner(tdwd3)!=5)continue;",
                        "  \t\t\t\t\t\t\tif(ShipSubType(tdwd3)!=6)continue;",
                        "  \t\t\t\t\t\t\tif(ShipFindCustomShipInfoByType(tdwd3,'ExpAcryn_block_infos')!=-1)continue;",
                        "  \t\t\t\t\t\t\tif(Dist(tdwd3,tdwd)>250)continue;",
                        "  \t\t\t\t\t\t\tif(HullHP(tdwd3)!=ItemSize(ShipItems(tdwd3,0)))continue;",
                        "  \t\t\t\t\t\t\tif(ScriptItemData(Q_item,1)!=Id(tdwd3))",
                        "  \t\t\t\t\t\t\t{",
                        "  \t\t\t\t\t\t\t\tScriptItemData(Q_item,1,Id(tdwd3));",
                        "  \t\t\t\t\t\t\t\tUselessItemData(tdwd,2,0);",
                        "  \t\t\t\t\t\t\t}",
                        "  \t\t\t\t\t\t\tUselessItemData(tdwd,2,UselessItemData(tdwd,2)+Rnd(5,9));",
                        "  \t\t\t\t\t\t\tif(UselessItemData(tdwd,2)>=100)",
                        "  \t\t\t\t\t\t\t{",
                        "  \t\t\t\t\t\t\t\tUselessItemData(tdwd,2,100);",
                        "  \t\t\t\t\t\t\t\tUselessItemData(tdwd,1,UselessItemData(tdwd,1)+20);",
                        "  \t\t\t\t\t\t\t\tfl_array[1,2]=fl_array[1,2]+1;",
                        "  \t\t\t\t\t\t\t\tShipAddCustomShipInfo(tdwd3,'ExpAcryn_block_infos');",
                        "  \t\t\t\t\t\t\t\tNoTalkToShip(tdwd3,1);",
                        "  \t\t\t\t\t\t\t\tNewsAdd(CT(\"Script.Mod_ExpAcryn.397\"));",
                        "  \t\t\t\t\t\t\t}",
                        "  \t\t\t\t\t\t\tbreak;",
                        "  \t\t\t\t\t\t}",
                        "  \t\t\t\t\t}",
                        "  \t\t\t\t}",
                        "  \t\t\t}",
                        "          }",
                        "  \t}",
                        "  \t//Код, исполняемый пока игрок выполняет задание человеческих флагманов (сбор энергоядер)",
                        "  \telse if(ExpAcrynQuestStatus==2)",
                        "  \t{",
                        "  \t\ttdwd=ScriptItemToItem(Q_item);",
                        "  \t\tif(tdwd)",
                        "  \t\t{",
                        "  \t\t\tif(UselessItemData(tdwd,1))UselessItemData(tdwd,1,UselessItemData(tdwd,1)-1);",
                        "  \t\t\tif(!UselessItemData(tdwd,1) && !ItemIn(Q_item,Player()))",
                        "  \t\t\t{",
                        "  \t\t\t\tSetName(tdwd,CT(\"Script.Mod_ExpAcryn.258\"));",
                        "  \t\t\t\tUselessItemText(tdwd,CT('UselessItems.Mod_ExpAcryn_mimi.Text')+CT(\"Script.Mod_ExpAcryn.147\")+' '+CT(\"Script.Mod_ExpAcryn.147\")+CT(\"Script.Mod_ExpAcryn.257\"));",
                        "  \t\t\t\ttdwd2=CreateQuestItem('Mod_ExpAcryn_mimi');",
                        "  \t\t\t\tLinkItemToScript(tdwd2,Q_item);",
                        "  \t\t\t\tFreeItem(tdwd2);",
                        "  \t\t\t}",
                        "  \t\t}",
                        "  \t}",
                        "  \t//Код, исполняемый пока игрок выполняет задание фэянских флагманов (с Р.Д.П.К.)",
                        "  \telse if(ExpAcrynQuestStatus==3)",
                        "  \t{",
                        "          //Если как-то уничтожили оба корабля в задании фэй, то обнуляется флаг квеста",
                        "  \t\tif(!GroupToShip(q_ship) && !GroupToShip(q_ship2))GFlagFeiTempVar=0;",
                        "          //Игрок растратил всех роботов-шпионов в Р.Д.П.К., все задания флагманов провалены",
                        "          if(!UselessItemData(Q_item,2) && !GroupCount(q_ship))",
                        "          {",
                        "              if(fl_array[3,2]<5)",
                        "              {",
                        "  \t\t\t    if(EtherState('ExpAcryn_quest_3')>-1)",
                        "  \t\t\t    {",
                        "  \t\t\t        tstr='';",
                        "  \t\t\t\t    if(fl_array[3,1]!=1)tstr='2';",
                        "  \t\t\t\t    Ether(5,'ExpAcryn_quest_3',CT('Script.Mod_ExpAcryn.MissionFailed')+Format(CT('Script.Mod_ExpAcryn.FeiMission'+tstr),'#ItemName#',addItemName));",
                        "  \t\t\t    }",
                        "  \t\t\t    //Также снижаем репутацию на всех фэянских планетах",
                        "                  tdwd=GlobalRelationsPlanets(Player(), 0, 8);",
                        "                  if(tdwd>45) ChangeGlobalRelationsPlanets(Player(), 0, 3, 35, 8);",
                        "                  else ChangeGlobalRelationsPlanets(Player(), 0, 0, 10, 8);",
                        "                  ReleaseItemFromScript(Q_item);",
                        "  \t\t\t    ExpAcrynQuestStatus=7;",
                        "              }",
                        "          }",
                        "  \t}",
                        "  \t//Код, исполняемый пока игрок выполняет задание гаальских флагманов (отправляем берторов на смерть с помощью асинхронного конвектора)",
                        "  \telse if(ExpAcrynQuestStatus==4)",
                        "  \t{",
                        "          if(fl_array[4,1]<3)",
                        "          {",
                        "              //Если игрок ещё не захватил бертор конвектором",
                        "  \t\t\tif(GFlagGaalTempVar==1)",
                        "  \t\t\t{",
                        "                  //Если игрок ещё не собрал нужное число блоков памяти",
                        "                  if(fl_array[4,2]<5)",
                        "                  {",
                        "                      //Если асинхронный конвектор на борту игрока и ни один бертор ещё не захвачен",
                        "                      if(ItemIn(Q_item,Player()) && !GroupCount(q_ship2))",
                        "                      {",
                        "                          //Ищем берторов в системе игрока",
                        "  \t\t\t\t        tdwd = ShipStar(Player());",
                        "  \t\t\t\t        for(i = 0; i < StarShips(tdwd); i = i + 1)",
                        "  \t\t\t\t        {",
                        "                              //У игрока обязательно должен быть включён камуфляж, соответствующий серии бертора",
                        "  \t\t\t\t\t        if(PlayerChameleonCurType() == -1)break;",
                        "  \t\t\t\t\t        tdwd3 = StarShips(tdwd, i);",
                        "  \t\t\t\t\t        if(ShipTypeN(tdwd3) != t_Kling)continue;",
                        "                              //Камуфляж игрока не должен быть разоблачён",
                        "  \t\t\t\t\t        if(PlayerChameleonDetected(ItemSubrace(ShipItems(tdwd3,0))))break;",
                        "  \t\t\t\t\t        if(ShipSubType(tdwd3) != 6)continue;",
                        "                              //Бертор не должен иметь инфошку повышенных протоколов безопасности",
                        "  \t\t\t\t\t        if(ShipFindCustomShipInfoByType(tdwd3, 'ExpAcryn_block_infos') != -1)continue;",
                        "  \t\t\t\t\t        if(ItemSubrace(ShipItems(tdwd3, 0)) != PlayerChameleonCurType())continue;",
                        "                              //Расстояние до бертора должно составлять не более 250 млн. км.",
                        "  \t\t\t\t\t        if(Dist(tdwd3,Player()) > 250)continue;",
                        "                              //И не должен быть занесён в скриптовую группу",
                        "  \t\t\t\t\t        if(ShipInScript(tdwd3))continue;",
                        "                              //Захватываем бертор конвектором",
                        "  \t\t\t\t\t        ShipJoin(q_ship2, tdwd3);",
                        "  \t\t\t\t\t        ChangeState(1, tdwd3);",
                        "  \t\t\t\t\t        NewsAdd(Format(CT(\"Script.Mod_ExpAcryn.760\"),\"<0>\",ShipName(tdwd3)));",
                        "  \t\t\t\t\t        GFlagGaalTempVar = 2;",
                        "                              //Устанавливаем несколько дней, через которые другие доминаторы заметят странное поведение бертора и раскроют камуфляж игрока",
                        "                              tint2 = 2500 / ShipSpeed(tdwd3);",
                        "                              if(tint2 < 4)tint2 = 4;",
                        "                              fl_array[4, 5] = CurTurn() + tint2;",
                        "  \t\t\t\t\t        break;",
                        "  \t\t\t\t        }",
                        "                      }",
                        "                  }",
                        "  \t\t\t}",
                        "              //Если бертор захвачен игроком, но приказ прыжка ему ещё не отдан",
                        "  \t\t\tif(GFlagGaalTempVar==2)",
                        "  \t\t\t{",
                        "  \t\t\t\ttdwd4=GroupToShip(q_ship2);",
                        "  \t\t\t\tif(CurTurn()<fl_array[4,5])",
                        "  \t\t\t\t{",
                        "                      //Пока захваченный игроком бертор не прыгает, имеется 33% шанс, что время обнаружения доминаторами подвоха продлится на 1 день дольше",
                        "  \t\t\t\t\tif(ShipOrderObj(tdwd4)==Player())",
                        "  \t\t\t\t\t{",
                        "  \t\t\t\t\t\tif(Rnd(1,100)<=33)fl_array[4,5]=fl_array[4,5]+1;",
                        "  \t\t\t\t\t}",
                        "  \t\t\t\t}",
                        "  \t\t\t}",
                        "              //Если захваченный бертор выполняет приказ на прыжок",
                        "  \t\t\tif(GFlagGaalTempVar==3)",
                        "  \t\t\t{",
                        "                  tdwd4=GroupToShip(q_ship2);",
                        "                  //Захваченный конвертором бертор вошел в гипер",
                        "                  if(ShipInHyperSpace(tdwd4))",
                        "                  {",
                        "                      //Добавляем инфошку-блокиратор",
                        "  \t\t\t\t    ShipAddCustomShipInfo(tdwd4,'ExpAcryn_block_infos');",
                        "  \t\t\t\t    NoTalkToShip(tdwd4,1);",
                        "                      //Вешаем на бертор инфошку для дропа блока памяти после его смерти",
                        "                      ShipAddCustomShipInfo(tdwd4,'ExpAcryn_GaalQuest_BertorInfo','NoShow');",
                        "                      //Добавляем маркер, что бертор прибыл в другую систему",
                        "  \t\t\t\t    GFlagGaalTempVar=4;",
                        "                      ChangeState(4,tdwd4);",
                        "  \t\t\t\t    OrderLock(tdwd4,0);",
                        "                  }",
                        "  \t\t\t}",
                        "  \t\t\tif(GFlagGaalTempVar==4)",
                        "              {",
                        "                  tdwd4=GroupToShip(q_ship2);",
                        "                  //Если прибывший в другую систему бертор был уничтожен неправильно",
                        "                  if(!GroupToShip(q_ship2))GFlagGaalTempVar=1;",
                        "                  //Либо если серия доминаторов этой системы совпадает с его собственной серией",
                        "                  else if(StarOwner(ShipStar(tdwd4))==1)",
                        "                  {",
                        "                      if(StarSeries(ShipStar(tdwd4))==ShipSubType(tdwd4))",
                        "                      {",
                        "                          //На всякий случай ещё проверяем, не захвачена ли система кастомной фракцией",
                        "                          if(StarCustomFaction(ShipStar(tdwd4))=='')",
                        "                          {",
                        "                              //Удаляем инфошку для дропа блока памяти",
                        "                              ShipDeleteCustomShipInfo(tdwd4,'ExpAcryn_GaalQuest_BertorInfo');",
                        "                              //И переводим задание в состояние готовности к захвату другого бертора",
                        "                              ShipOut(tdwd4);",
                        "                              GFlagGaalTempVar=1;",
                        "                          }",
                        "                      }",
                        "                  }",
                        "              }",
                        "              //Если захваченный бертор уничтожен доминаторами противоположной серии",
                        "  \t\t\tif(GFlagGaalTempVar==5)",
                        "  \t\t\t{",
                        "                  //Сбрасываем маркер задания в состояние готовности к захвату другого бертора",
                        "  \t\t\t\tGFlagGaalTempVar=1;",
                        "  \t\t\t}",
                        "          }",
                        "  \t}",
                        "  \t//Код, исполняемый пока игрок выполняет задание доминиона",
                        "  \telse if(ExpAcrynQuestStatus==12)",
                        "  \t{",
                        "          if(fl_array[5,1]<4 && fl_array[5,2]<6)",
                        "          {",
                        "  \t\t    for(i=GalaxyEvents()-1;i>=0;i=i-1)",
                        "  \t\t    {",
                        "  \t\t\t    if(GalaxyEventDate(i)<CurTurn())break;",
                        "                  if(fl_array[5,2]>=6)break;",
                        "                  //Детектим уничтоженные игроком корабли, ищем среди них флагманы и берторы",
                        "  \t\t\t    if(GalaxyEventType(i)=='PlayerKillsShip')",
                        "  \t\t\t    {",
                        "  \t\t\t\t    if(GalaxyEventData(i,0)==t_Warrior)",
                        "  \t\t\t\t    {",
                        "  \t\t\t\t\t    if(GalaxyEventData(i,5)==1)fl_array[5,2]=fl_array[5,2]+1;",
                        "  \t\t\t\t    }",
                        "  \t\t\t\t    else if(GalaxyEventData(i,0)==t_Kling)",
                        "  \t\t\t\t    {",
                        "  \t\t\t\t\t    if(GalaxyEventData(i,5)==6)fl_array[5,2]=fl_array[5,2]+1;",
                        "  \t\t\t\t    }",
                        "  \t\t\t    }",
                        "  \t\t    }",
                        "          }",
                        "  \t}",
                        "  }",
                        "  ",
                        "  //Выдаём новорождённым берторам и флагманам новые модификации, нужные по заданиям",
                        "  if(GalaxyShipId() > last_ship_id)",
                        "  {",
                        "  \ti = BuildListOfNewShips(temp_array, last_ship_id, 1+8+16, 1+2+4+8+16+32+128, 1, '', ',Dreadnought,PirateFrigate,PirateGalleon');",
                        "  \tif(i)//Если был обнаружен хотя бы один новый корабль, подходящий по заданным фильтрам",
                        "  \t{",
                        "  \t\tfor(i = 0; i < ArrayDim(temp_array); i = i + 1)",
                        "  \t\t{",
                        "  \t\t\ttdwd2 = temp_array[i];",
                        "  ",
                        "  \t\t\ttint2 = ShipOwner(tdwd2);",
                        "  \t\t\t//Выдача неизвестных модификаций берторам (нужно для малокского задания)",
                        "  \t\t\tif(tint2 == Kling)",
                        "  \t\t\t{",
                        "  \t\t\t\t//Отсекаем не берторов",
                        "  \t\t\t\tif(ShipSubType(tdwd2) != 6) continue;",
                        "  ",
                        "  \t\t\t\ttint = ItemSubrace(ShipItems(tdwd2, 0));",
                        "  \t\t\t\tif(!ShipEqInSlot(tdwd2, t_RepairRobot))",
                        "  \t\t\t\t{",
                        "  \t\t\t\t\ttdwd3 = CreateEquipment(t_RepairRobot, Rnd(35, 60), GalaxyTechLevel(), Kling);",
                        "  \t\t\t\t\tItemSubrace(tdwd3, tint);",
                        "  \t\t\t\t\tAddItemToShip(tdwd2, tdwd3);",
                        "  \t\t\t\t\tItemIsInUse(tdwd3, tdwd2, 1);",
                        "  \t\t\t\t}",
                        "  \t\t\t\tif(!ShipEqInSlot(tdwd2, t_DefGenerator))",
                        "  \t\t\t\t{",
                        "  \t\t\t\t\ttdwd3 = CreateEquipment(t_DefGenerator, Rnd(35, 60), GalaxyTechLevel(), Kling);",
                        "  \t\t\t\t\tItemSubrace(tdwd3, tint);",
                        "  \t\t\t\t\tAddItemToShip(tdwd2, tdwd3);",
                        "  \t\t\t\t\tItemIsInUse(tdwd3, tdwd2, 1);",
                        "  \t\t\t\t}",
                        "  \t\t\t\ttint = 0;",
                        "  \t\t\t\twhile(!tint)",
                        "  \t\t\t\t{",
                        "  \t\t\t\t\ttdwd3 = ShipEqInSlot(tdwd2, Rnd(t_FuelTanks, t_DefGenerator));",
                        "  \t\t\t\t\tif(tdwd3)",
                        "  \t\t\t\t\t{",
                        "  \t\t\t\t\t\ttint = 1;",
                        "                          module = EqModule(tdwd3);",
                        "  \t\t\t\t\t\tif(~module) ModuleToEquipment(-1, tdwd3);",
                        "  \t\t\t\t\t\ttstr2 = '<color=255,167,84>' + Name(tdwd3) + '</color>';",
                        "  \t\t\t\t\t\tif(~module) ModuleToEquipment(module, tdwd3);",
                        "  \t\t\t\t\t\tEqSpecial(tdwd3, FindBonusByCustomTag('Akrin_dom_ship'));",
                        "  \t\t\t\t\t\tSetName(tdwd3, tstr2);",
                        "  \t\t\t\t\t\tNoDropItem(tdwd3, 1);",
                        "  \t\t\t\t\t}",
                        "  \t\t\t\t}",
                        "  \t\t\t}",
                        "  \t\t\t//Раздаём трионку пиратам, если игрок уже выполнил хотя бы одно задание доминиона",
                        "  \t\t\telse if(tint2 == PirateClan)",
                        "  \t\t\t{",
                        "  \t\t\t\tif(fl_array[5,1] < 2) continue;",
                        "  ",
                        "                  //Если подключён мод EvoArmada, то получать трионку будут лишь крупные пиратские корабли",
                        "                  if(EvoArmadaInit)",
                        "                  {",
                        "  \t\t\t\t    if(ShipType(tdwd2) == 'Pirate') continue;",
                        "                  }",
                        "  ",
                        "  \t\t\t\t//Шанс тем выше, чем больше заданий для пиратов выполнил игрок",
                        "  \t\t\t\tif(Rnd(1, 100) > (5 * (fl_array[5, 1] - 1))) continue;",
                        "  ",
                        "  \t\t\t\ttint = 0;",
                        "  \t\t\t\twhile(!tint)",
                        "  \t\t\t\t{",
                        "  \t\t\t\t\ttdwd3 = ShipEqInSlot(tdwd2, Rnd(t_FuelTanks, t_DefGenerator));",
                        "  \t\t\t\t\tif(tdwd3)",
                        "  \t\t\t\t\t{",
                        "  \t\t\t\t\t\ttint = 1;",
                        "  \t\t\t\t\t\tEqSpecial(tdwd3, -1);",
                        "  \t\t\t\t\t\tNoDropItem(tdwd3, 1);",
                        "  \t\t\t\t\t\tfor(k = 0; k < 7; k = k + 1)",
                        "  \t\t\t\t\t\t{",
                        "  \t\t\t\t\t\t\tif(!MayAddBonusToEq(FindBonusByCustomTag('Fakrin_5_'+k),tdwd3))continue;",
                        "  \t\t\t\t\t\t\tif(ItemType(tdwd3)!=t_DefGenerator)SpecialToEquipment(FindBonusByCustomTag('Fakrin_5_'+k),tdwd3);",
                        "  \t\t\t\t\t\t\telse",
                        "  \t\t\t\t\t\t\t{",
                        "  \t\t\t\t\t\t\t\tif(Rnd(1,100)>50)SpecialToEquipment(FindBonusByCustomTag('Fakrin_5_'+k),tdwd3);",
                        "  \t\t\t\t\t\t\t\telse SpecialToEquipment(FindBonusByCustomTag('Fakrin_5_'+k+'_2'),tdwd3);",
                        "  \t\t\t\t\t\t\t}",
                        "  \t\t\t\t\t\t\tbreak;",
                        "  \t\t\t\t\t\t}",
                        "  \t\t\t\t\t}",
                        "  \t\t\t\t}",
                        "  \t\t\t}",
                        "  \t\t\t//Раздача трионки флагманам (если игрок уже выполнил задания соответствующей расы)",
                        "  \t\t\telse",
                        "  \t\t\t{",
                        "  \t\t\t\t//Отсекаем не флагманы",
                        "  \t\t\t\tif(ShipSubType(tdwd2) != 1)continue;",
                        "  ",
                        "  \t\t\t\tif(ExpAcrynQuestStatus == 10)continue;",
                        "  \t\t\t\tj=ShipOwner(tdwd2);",
                        "  \t\t\t\tif(fl_array[j, 1] >= 2)",
                        "  \t\t\t\t{",
                        "  \t\t\t\t\ttdwd=0;",
                        "  \t\t\t\t\ttdwd=ShipEqInSlot(tdwd2,fl_array[j,7]);",
                        "  \t\t\t\t\tif(!tdwd)",
                        "  \t\t\t\t\t{",
                        "  \t\t\t\t\t\ttdwd=CreateEquipment(fl_array[j,7],Rnd(40,60),GalaxyTechLevel(),j);",
                        "  \t\t\t\t\t\tAddItemToShip(tdwd2,tdwd);",
                        "  \t\t\t\t\t\tItemIsInUse(tdwd,tdwd2,1);",
                        "  \t\t\t\t\t}",
                        "  \t\t\t\t\telse",
                        "  \t\t\t\t\t{",
                        "  \t\t\t\t\t\tif(ItemOwner(tdwd)!=j)ItemOwner(tdwd,j);",
                        "  \t\t\t\t\t\tNoDropItem(tdwd,1);",
                        "  \t\t\t\t\t\tfor(k=0; k<7; k=k+1)",
                        "  \t\t\t\t\t\t{",
                        "  \t\t\t\t\t\t\tif(!MayAddBonusToEq(FindBonusByCustomTag('Fakrin_'+j+'_'+k),tdwd))continue;",
                        "  \t\t\t\t\t\t\tif(fl_array[j,7]!=t_DefGenerator)EqSpecial(tdwd,FindBonusByCustomTag('Fakrin_'+j+'_'+k));",
                        "  \t\t\t\t\t\t\telse",
                        "  \t\t\t\t\t\t\t{",
                        "  \t\t\t\t\t\t\t\tif(Rnd(1,100)>50)EqSpecial(tdwd,FindBonusByCustomTag('Fakrin_'+j+'_'+k));",
                        "  \t\t\t\t\t\t\t\telse EqSpecial(tdwd,FindBonusByCustomTag('Fakrin_'+j+'_'+k+'_2'));",
                        "  \t\t\t\t\t\t\t}",
                        "  \t\t\t\t\t\t\tbreak;",
                        "  \t\t\t\t\t\t}",
                        "  \t\t\t\t\t}",
                        "  \t\t\t\t\ttdwd=0;",
                        "  \t\t\t\t\ttdwd=ShipEqInSlot(tdwd2,fl_array[j,8]);",
                        "  \t\t\t\t\tif(!tdwd)",
                        "  \t\t\t\t\t{",
                        "  \t\t\t\t\t\ttdwd=CreateEquipment(fl_array[j,8],Rnd(40,60),GalaxyTechLevel(),j);",
                        "  \t\t\t\t\t\tAddItemToShip(tdwd2,tdwd);",
                        "  \t\t\t\t\t\tItemIsInUse(tdwd,tdwd2,1);",
                        "  \t\t\t\t\t}",
                        "  \t\t\t\t\telse",
                        "  \t\t\t\t\t{",
                        "  \t\t\t\t\t\tif(ItemOwner(tdwd)!=j)ItemOwner(tdwd,j);",
                        "  \t\t\t\t\t\tNoDropItem(tdwd,1);",
                        "  \t\t\t\t\t\tfor(k=0; k<7; k=k+1)",
                        "  \t\t\t\t\t\t{",
                        "  \t\t\t\t\t\t\tif(!MayAddBonusToEq(FindBonusByCustomTag('Fakrin_'+j+'_'+k),tdwd))continue;",
                        "  \t\t\t\t\t\t\tif(fl_array[j, 8] != t_DefGenerator)EqSpecial(tdwd,FindBonusByCustomTag('Fakrin_'+j+'_'+k));",
                        "  \t\t\t\t\t\t\telse",
                        "  \t\t\t\t\t\t\t{",
                        "  \t\t\t\t\t\t\t\tif(Rnd(1, 100) > 50)EqSpecial(tdwd,FindBonusByCustomTag('Fakrin_'+j+'_'+k));",
                        "  \t\t\t\t\t\t\t\telse EqSpecial(tdwd,FindBonusByCustomTag('Fakrin_'+j+'_'+k+'_2'));",
                        "  \t\t\t\t\t\t\t}",
                        "  \t\t\t\t\t\t\tbreak;",
                        "  \t\t\t\t\t\t}",
                        "  \t\t\t\t\t}",
                        "  \t\t\t\t}",
                        "  \t\t\t}",
                        "  \t\t}",
                        "  \t}",
                        "  \tlast_ship_id=GalaxyShipId();",
                        "  }",
                        "}"
                    ],
                    "#": 40,
                    "Type": "Top",
                    "Parent": -1,
                    "Pos.x": 120,
                    "Pos.y": 885
                },
                {
                    "Name": "",
                    "Code.Type": "DialogBegin",
                    "Code": [
                        "if(GetTalkShip()) {",
                        "  if(ExpAcrynQuestStatus!=7) {",
                        "    if(ShipTypeN(GetTalkShip())==t_Kling) {",
                        "      if(ShipSubType(GetTalkShip())==6) {",
                        "        if(ShipCustomFaction(GetTalkShip())=='') {",
                        "          if(ShipScanerPower(Player())>ShipProtectability(GetTalkShip())) {",
                        "            //Добавляется доп. реплика в диалог с бертором",
                        "            //Помимо инфошки \"Детачера\", у игрока обязательно должна быть копия \"Интеркома\"",
                        "            if(GetProgramm(5))",
                        "            {",
                        "                if(ShipFindCustomShipInfoByType(Player(),'ExpAcryn_mimi_player_infos')>-1)",
                        "                {",
                        "                    if(ShipFindCustomShipInfoByType(GetTalkShip(),'ExpAcryn_block_infos')==-1)AddDialogInject('Bertor_mimi','',CT(\"Script.Mod_ExpAcryn.333\"),3);",
                        "                }",
                        "            }",
                        "          }",
                        "        }",
                        "      }",
                        "    }",
                        "  }",
                        "  if(ShipTypeN(GetTalkShip())==t_Warrior) {",
                        "    if(ShipSubType(GetTalkShip())==1) {",
                        "      if(!StarBattle(ShipStar(GetTalkShip()))) {",
                        "        if(PlayerChameleonCurType()==-1 && !ShipInPirateClan(Player()) && RelationToRanger(GetTalkShip(),Player())>=20 && ShipGetBad(GetTalkShip())!=Player()) {",
                        "          flagman=GetTalkShip();",
                        "          owner=ShipOwner(flagman);",
                        "          if(ExpAcrynQuestStatus==owner || ExpAcrynQuestStatus==5)",
                        "          {",
                        "          \tif(fl_array[owner,1]<3)",
                        "          \t{",
                        "          \t\tif(!fl_array[owner,1])",
                        "          \t\t{",
                        "          \t\t\t//Если кейс уже был сдан флагману ранее",
                        "          \t\t\ttstr='';",
                        "          \t\t\tif(caseIn<5)",
                        "          \t\t\t{",
                        "          \t\t\t\t//Ещё не было выполнено ни одного задания флагманов",
                        "          \t\t\t\tif(!item_count)",
                        "          \t\t\t\t{",
                        "          \t\t\t\t\t//Ранее кейс был сдан флагману этой расы",
                        "          \t\t\t\t\tif(caseIn==owner)tstr='</color>'+CT(\"Script.Mod_ExpAcryn.476\")+CT(\"Script.Mod_ExpAcryn.147\");",
                        "                              //Ранее кейс был сдан флагману другой расы",
                        "          \t\t\t\t\telse tstr='</color>'+CT(\"Script.Mod_ExpAcryn.470\")+CT(\"Script.Mod_ExpAcryn.147\");",
                        "          \t\t\t\t}",
                        "          \t\t\t\t//Игрок уже выполнил минимум одно задание другого флагмана",
                        "          \t\t\t\telse tstr='</color>'+CT(\"Script.Mod_ExpAcryn.475\")+CT(\"Script.Mod_ExpAcryn.147\");",
                        "          \t\t\t}",
                        "          \t\t\ttstr2=CT(\"Script.Mod_ExpAcryn.326\");",
                        "          \t\t}",
                        "          \t\telse",
                        "          \t\t{",
                        "          \t\t\tif(owner==0)",
                        "          \t\t\t{",
                        "          \t\t\t\t//Считаем неизвестные доминаторские модификации, необходимые по заданию малоков",
                        "          \t\t\t\t//Если нашли нужное количество, то подставляем ответ об окончании задания",
                        "          \t\t\t\ttint=fl_array[0,2];",
                        "          \t\t\t\tfor(i=ShipItems(Player())-1;i>0;i=i-1)",
                        "          \t\t\t\t{",
                        "          \t\t\t\t\ttdwd=ShipItems(Player(),i);",
                        "          \t\t\t\t\tif(EqSpecial(tdwd)==-1)continue;",
                        "          \t\t\t\t\tif(EqSpecial(tdwd)!=FindBonusByCustomTag('ExpAcryn_ship_maloc'))continue;",
                        "          \t\t\t\t\ttint=tint+1;",
                        "          \t\t\t\t}",
                        "          \t\t\t\tif(tint<5)",
                        "          \t\t\t\t{",
                        "          \t\t\t\t\ttstr2=CT(\"Script.Mod_ExpAcryn.323\");",
                        "          \t\t\t\t\tif(!1)AddDialogInject('TestCoal','',CT(\"Script.Mod_ExpAcryn.391\"),2);",
                        "          \t\t\t\t}",
                        "          \t\t\t\telse",
                        "          \t\t\t\t{",
                        "          \t\t\t\t\tif(fl_array[0,1]==1)tstr2=CT(\"Script.Mod_ExpAcryn.388\");",
                        "          \t\t\t\t\telse tstr2=CT(\"Script.Mod_ExpAcryn.439\");",
                        "          \t\t\t\t}",
                        "          \t\t\t}",
                        "          \t\t\telse if(owner==2)",
                        "          \t\t\t{",
                        "          \t\t\t\t//Считаем энергоядра, необходимые по заданию людей",
                        "          \t\t\t\t//Если нашли нужное количество, то подставляем ответ об окончании задания",
                        "          \t\t\t\ttint=fl_array[2,2];",
                        "          \t\t\t\tfor(i=ShipItems(Player())-1;i>0;i=i-1)",
                        "          \t\t\t\t{",
                        "          \t\t\t\t\ttdwd=ShipItems(Player(),i);",
                        "          \t\t\t\t\tif(ItemType(tdwd)!=t_UselessItem)continue;",
                        "          \t\t\t\t\tif(EquipmentImageName(tdwd)!='Mod_ExpAcryn_mimi')continue;",
                        "          \t\t\t\t\ttint=tint+1;",
                        "          \t\t\t\t}",
                        "          \t\t\t\tif(tint<5)",
                        "          \t\t\t\t{",
                        "          \t\t\t\t\ttstr2=CT(\"Script.Mod_ExpAcryn.323\");",
                        "          \t\t\t\t\tif(!1)AddDialogInject('TestCoal','',CT(\"Script.Mod_ExpAcryn.391\"),2);",
                        "          \t\t\t\t}",
                        "          \t\t\t\telse",
                        "          \t\t\t\t{",
                        "          \t\t\t\t\tif(fl_array[2,1]==1)tstr2=CT(\"Script.Mod_ExpAcryn.388\");",
                        "          \t\t\t\t\telse tstr2=CT(\"Script.Mod_ExpAcryn.439\");",
                        "          \t\t\t\t}",
                        "          \t\t\t}",
                        "                      else if(owner == 4)",
                        "                      {",
                        "                          //Считываем, сколько блоков памяти уже загрузил в конвектор игрок",
                        "          \t\t\t    tdwd = ScriptItemToItem(Q_item);",
                        "          \t\t\t\tfl_array[4, 2] = UselessItemData(tdwd, 1) / 20;",
                        "                          //Вероятно, здесь была ошибка",
                        "                          //fl_array[4, 2] = fl_array[4, 2] + UselessItemData(tdwd, 1) / 20;",
                        "          ",
                        "          \t\t\t\tif(fl_array[4, 2] < 5)",
                        "          \t\t\t\t{",
                        "          \t\t\t\t\ttstr2 = CT(\"Script.Mod_ExpAcryn.323\");",
                        "          \t\t\t\t\tif(!1) AddDialogInject('TestCoal', '', CT(\"Script.Mod_ExpAcryn.391\"), 2);",
                        "          \t\t\t\t}",
                        "          \t\t\t\telse",
                        "          \t\t\t\t{",
                        "          \t\t\t\t\tif(fl_array[4, 1] == 1) tstr2 = CT(\"Script.Mod_ExpAcryn.388\");",
                        "          \t\t\t\t\telse tstr2 = CT(\"Script.Mod_ExpAcryn.804\");",
                        "          \t\t\t\t}",
                        "                      }",
                        "          \t\t\telse",
                        "          \t\t\t{",
                        "          \t\t\t\tif(fl_array[owner,2]<5)",
                        "          \t\t\t\t{",
                        "          \t\t\t\t\ttstr2=CT(\"Script.Mod_ExpAcryn.323\");",
                        "          \t\t\t\t\tif(!1)AddDialogInject('TestCoal','',CT(\"Script.Mod_ExpAcryn.391\"),2);",
                        "          \t\t\t\t}",
                        "          \t\t\t\telse",
                        "          \t\t\t\t{",
                        "          \t\t\t\t\tif(fl_array[owner,1]==1)tstr2=CT(\"Script.Mod_ExpAcryn.388\");",
                        "          \t\t\t\t\telse tstr2=CT(\"Script.Mod_ExpAcryn.439\");",
                        "          \t\t\t\t}",
                        "          \t\t\t}",
                        "          \t\t}",
                        "          \t\tif(Dist(flagman,Player())<=250)AddDialogInject('Flagm_'+owner,'',tstr2,3,0,fl_array[owner,1]);",
                        "          \t\telse AddDialogInject('Dist_no','',tstr2,3);",
                        "                  if(fl_array[owner,1]<2) tint=7;",
                        "                  else tint=8;",
                        "                  if(fl_array[owner,tint]==t_FuelTanks) addItemName=CT(\"Script.Mod_ExpAcryn.512\");",
                        "                  else if(fl_array[owner,tint]==t_Engine) addItemName=CT(\"Script.Mod_ExpAcryn.511\");",
                        "                  else if(fl_array[owner,tint]==t_Radar) addItemName=CT(\"Script.Mod_ExpAcryn.510\");",
                        "                  else if(fl_array[owner,tint]==t_Scaner) addItemName=CT(\"Script.Mod_ExpAcryn.509\");",
                        "                  else if(fl_array[owner,tint]==t_RepairRobot) addItemName=CT(\"Script.Mod_ExpAcryn.865\");",
                        "                  else if(fl_array[owner,tint]==t_CargoHook) addItemName=CT(\"Script.Mod_ExpAcryn.508\");",
                        "                  else if(fl_array[owner,tint]==t_DefGenerator) addItemName=CT(\"Script.Mod_ExpAcryn.507\");",
                        "          \t}",
                        "          }",
                        "          if(cham)",
                        "          {",
                        "              if(ExpAcrynQuestStatus<=6)",
                        "              {",
                        "                  if(ShipOwner(flagman)>0)",
                        "                  {",
                        "                      if(Dist(flagman,Player())<=250)AddDialogInject('Flag_ch','',CT(\"Script.Mod_ExpAcryn.330\"),2,0,0);",
                        "                      else AddDialogInject('Dist_no','',CT(\"Script.Mod_ExpAcryn.330\"),2,0,0);",
                        "                  }",
                        "              }",
                        "          }",
                        "          if(ExpAcrynQuestStatus==11)",
                        "          {",
                        "              if(ItemIn(Q_item,Player()))",
                        "              {",
                        "                  if(Dist(flagman,Player())<=250)AddDialogInject('Flagm','',CT(\"Script.Mod_ExpAcryn.484\"),1);",
                        "                  else AddDialogInject('Dist_no','',CT(\"Script.Mod_ExpAcryn.484\"),1);",
                        "              }",
                        "          }",
                        "        }",
                        "      }",
                        "    }",
                        "  }",
                        "}",
                        "if(GetShipRuins(Player())) {",
                        "  if(ExpAcrynQuestStatus>10) {",
                        "    if(ShipType(GetShipRuins(Player()))=='CB') {",
                        "      owner=5;",
                        "      if(item_count<4)",
                        "      {",
                        "          if(ExpAcrynQuestStatus==12)",
                        "          {",
                        "              if(fl_array[5,1]<4)",
                        "              {",
                        "                  //Задание ещё не взято или уже в процессе",
                        "                  if(fl_array[5,2]<6)",
                        "                  {",
                        "                      AddDialogInject('Dom_q','',CT(\"Script.Mod_ExpAcryn.335\"),1,0,2);",
                        "                      if(!1)AddDialogInject('TestPir','',CT(\"Script.Mod_ExpAcryn.391\"),2);",
                        "                  }",
                        "                  //Задание выполнено в первый раз",
                        "                  else if(fl_array[5,1]==1)AddDialogInject('Dom_q','',CT(\"Script.Mod_ExpAcryn.358\"),2,0,3);",
                        "                  //Во второй раз",
                        "                  else if(fl_array[5,1]==2)AddDialogInject('Dom_q','',CT(\"Script.Mod_ExpAcryn.615\"),2,0,3);",
                        "                  //В третий раз",
                        "                  else if(fl_array[5,1]==3)AddDialogInject('Dom_q','',CT(\"Script.Mod_ExpAcryn.625\"),2,0,3);",
                        "              }",
                        "          }",
                        "          else if(ExpAcrynQuestStatus==11)AddDialogInject('Dom_q','',CT(\"Script.Mod_ExpAcryn.322\"),1,0,1);",
                        "      }",
                        "    }",
                        "    if(ShipType(GetShipRuins(Player()))=='PB') {",
                        "      if(!PirateWin() && !DomiksDefeated()) {",
                        "        owner=5;",
                        "        if(ExpAcrynQuestStatus==11)",
                        "        {",
                        "            if(ShipOnSidePirateClan(Player()))AddDialogInject('Dom_q','',CT(\"Script.Mod_ExpAcryn.634\"),1,0,4);",
                        "        }",
                        "      }",
                        "    }",
                        "  }",
                        "  if(ExpAcrynQuestStatus==10) {",
                        "    if(ShipType(GetShipRuins(Player()))=='WB') {",
                        "      if(!ShipInPirateClan(Player())) {",
                        "        if(ShipRank(Player())==3)",
                        "        {",
                        "            if(corVar==0)",
                        "            {",
                        "                tint=0;",
                        "                for(i=1;i<ShipItems(Player());i=i+1)",
                        "                {",
                        "                    tdwd=ShipItems(Player(),i);",
                        "                    if(Id(tdwd)>tint)",
                        "                    {",
                        "                        tint=Id(tdwd);",
                        "                        tstr=Name(tdwd);",
                        "                    }",
                        "                }",
                        "                corVar=1;",
                        "            }",
                        "            AddDialogOverride('WB_q',100);",
                        "        }",
                        "      }",
                        "    }",
                        "  }",
                        "}",
                        "if(HomeGiveCaseCheck==1) {",
                        "  if(ExpAcrynQuestStatus!=11) {",
                        "    if(ShipOwner(Player())>=0 && ShipOwner(Player())<=4) {",
                        "      //Выдача кейса, если игрок получил звание \"Капитан\" на родной планете по моду ShuHomeland",
                        "      //Все сопутствующие диалоги прописаны в том же моде",
                        "      tdwd=CreateQuestItem('Mod_ExpAcryn_case');",
                        "      NoDropItem(tdwd,1);",
                        "      ItemOwner(tdwd,PlanetOwner(GetShipPlanet(Player())));",
                        "      ItemSize(tdwd,1);",
                        "      LinkItemToScript(tdwd,Q_item);",
                        "      AddItemToShip(Player(),tdwd);",
                        "      ExpAcrynQuestStatus=11;//Игрок взял первый квест;",
                        "    }",
                        "  }",
                        "}"
                    ],
                    "#": 41,
                    "Type": "Top",
                    "Parent": -1,
                    "Pos.x": 180,
                    "Pos.y": 885
                },
                {
                    "Name": "",
                    "Code.Type": "Turn",
                    "Code": [
                        "if(GFlagFeiTempVar>0) {",
                        "  if(GFlagFeiTempVar>5 && CurTurn()==fl_array[3,6])//Снимается камуфляж при выполнении задания",
                        "  {",
                        "      if(GFlagFeiTempVar!=10 && GroupToShip(q_ship))NewsAdd(CT(\"Script.Mod_ExpAcryn.649\"));",
                        "      else if(GFlagFeiTempVar==10 || !GroupToShip(q_ship))NewsAdd(CT(\"Script.Mod_ExpAcryn.661\"));",
                        "      fl_array[3,6]=0;",
                        "      PlayerChameleonDetected(ItemSubrace(ShipItems(CurShip,0)),1);",
                        "      ShipOut(CurShip);",
                        "  }",
                        "  if(!GroupToShip(q_ship))",
                        "  {",
                        "      GFlagFeiTempVar=0;",
                        "      ShipOut(CurShip);",
                        "  }",
                        "}",
                        "if(GFlagGaalTempVar==2) {",
                        "  if(Dist(CurShip,Player())<=250 && ItemIn(Q_item,Player())) {",
                        "    ChangeState(3);",
                        "    exit;",
                        "  }",
                        "}"
                    ],
                    "#": 196,
                    "Type": "Top",
                    "Parent": -1,
                    "Pos.x": 80
                },
                {
                    "Name": "",
                    "Code.Type": "Turn",
                    "Code": [
                        "if(GFlagFeiTempVar>0) {",
                        "  //Проверка системы",
                        "  //Если шпион не в системе игрока, то группы очищаются и квест обнуляется",
                        "  if(ShipStar(Player())!=ShipStar(CurShip))",
                        "  {",
                        "  \tGFlagFeiTempVar=0;",
                        "  \tShipOut(CurShip);",
                        "  \tShipOut(GroupToShip(q_ship2));",
                        "  }",
                        "  if(GFlagFeiTempVar==1 && GroupToShip(q_ship2))",
                        "  {",
                        "      //Если бертор улетел от шпиона, то возвращаем шпиона назад",
                        "  \tif(ShipStar(GroupToShip(q_ship2))!=ShipStar(CurShip))",
                        "  \t{",
                        "  \t\tNewsAdd(Format(CT(\"Script.Mod_ExpAcryn.642\"),\"<0>\",0));",
                        "  \t\tGFlagFeiTempVar=8;",
                        "  \t\tOrderFollowShip(CurShip,Player());",
                        "  \t\tOrderLock(CurShip,1);",
                        "  \t\tShipOut(GroupToShip(q_ship2));",
                        "  \t}",
                        "  }",
                        "  //Провальные варианты",
                        "  if(GFlagFeiTempVar==1 && (PlayerChameleonCurType()!=ItemSubrace(ShipItems(CurShip,0)) || PlayerChameleonDetected(ItemSubrace(ShipItems(CurShip,0)))))",
                        "  {",
                        "      //Если камуфляж упал до посадки на бертора, возвращаем шпиона на игрока",
                        "  \tNewsAdd(CT(\"Script.Mod_ExpAcryn.647\"));",
                        "  \tGFlagFeiTempVar=8;",
                        "  \tOrderFollowShip(CurShip,Player());",
                        "  \tOrderLock(CurShip,1);",
                        "  }",
                        "  if(GFlagFeiTempVar==8 && Dist(CurShip,Player())<=300 && ItemIn(Q_item,Player()))",
                        "  {",
                        "      //Сажаем шпиона на игрока",
                        "      OrderLanding(CurShip,Player());",
                        "      GFlagFeiTempVar=9;",
                        "  }",
                        "  if(GFlagFeiTempVar==9 && GetShipRuins(CurShip)==Player())",
                        "  {",
                        "      //Шпион вернулся без данных, не увеличиваем счётчик выполнения",
                        "  \tGFlagFeiTempVar=0;",
                        "  \tif(ItemIn(Q_item,Player()))",
                        "  \t{",
                        "  \t\ttdwd=ScriptItemToItem(Q_item);",
                        "          //+1 заряд для запуска шпиона",
                        "  \t\tUselessItemData(tdwd,2,UselessItemData(tdwd,2)+1);",
                        "  \t}",
                        "  \tTransferShip(CurShip,StarPlanets(ShipStar(CurShip),0));",
                        "  \tOrderNone(CurShip);",
                        "  \tif(!ItemIn(Q_item,Player()))",
                        "  \t{",
                        "  \t\tfor(i=1;i<ShipItems(Player());i=i+1)",
                        "  \t\t{",
                        "  \t\t\ttdwd=ShipItems(Player(),i);",
                        "  \t\t\tif(!ItemIsInUse(tdwd))continue;",
                        "  \t\t\tItemDurability(tdwd,0);",
                        "  \t\t}",
                        "  \t\tOrderNone(Player());",
                        "  \t\tOrderLock(Player(),1);",
                        "  \t\tCustomLose(CT(\"Script.Mod_ExpAcryn.652\"));",
                        "  \t}",
                        "  \tShipDestroy(CurShip,1);",
                        "  }",
                        "  //Если бертора уничтожили до посадки, возвращаем шпиона на игрока",
                        "  if(GFlagFeiTempVar==1 && !GroupToShip(q_ship2))",
                        "  {",
                        "  \tNewsAdd(Format(CT(\"Script.Mod_ExpAcryn.645\"),\"<0>\",0));",
                        "  \tGFlagFeiTempVar=8;",
                        "  \tOrderFollowShip(CurShip,Player());",
                        "  \tOrderLock(CurShip,1);",
                        "  }",
                        "  //Обычные варианты",
                        "  //Шпион следует за бертором и открывает диалог",
                        "  if(GFlagFeiTempVar==1 && Dist(CurShip,GroupToShip(q_ship2))<=300)",
                        "  {",
                        "  \tGFlagFeiTempVar=2;",
                        "  \tDialog(Bertor_fei_crack,CurShip);",
                        "  }",
                        "  //После диалога отдаём приказ на посадку",
                        "  if((GFlagFeiTempVar==3 || GFlagFeiTempVar==4) && !fl_array[3,6])",
                        "  {",
                        "  \tOrderLanding(CurShip,GroupToShip(q_ship2));",
                        "  \tfl_array[3,6]=CurTurn()+2;",
                        "  \tOrderLock(CurShip,1);",
                        "  }",
                        "  //После посадки взлёт, если игрок выбрал верный ответ",
                        "  if(GFlagFeiTempVar==3 && CurTurn()==fl_array[3,6])",
                        "  {",
                        "  \tOrderTakeOff(CurShip);",
                        "  \tfl_array[3,6]=CurTurn()+3;",
                        "  \tGFlagFeiTempVar=5;",
                        "  }",
                        "  //После посадки перепрограммируют клига, если игрок выбрал неверный ответ",
                        "  if(GFlagFeiTempVar==4 && CurTurn()==fl_array[3,6])",
                        "  {",
                        "  \tGFlagFeiTempVar=0;",
                        "  \tPlayerChameleonDetected(ItemSubrace(ShipItems(CurShip,0)),1);",
                        "  \tNewsAdd(CT(\"Script.Mod_ExpAcryn.663\"));",
                        "  \tfl_array[3,6]=0;",
                        "  \tOrderLock(CurShip,0);",
                        "  \tShipOut(GroupToShip(q_ship2));",
                        "  \tOrderTakeOff(CurShip);",
                        "  \tShipOut(CurShip);",
                        "  }",
                        "  //После взлёта с бертора отдаём приказ следовать за игроком",
                        "  if(GFlagFeiTempVar==5 && ShipInNormalSpace(CurShip))",
                        "  {",
                        "  \tOrderFollowShip(CurShip,Player());",
                        "  \tGFlagFeiTempVar=6;",
                        "  }",
                        "  //Посадка шпиона на игрока, когда догнал",
                        "  if(GFlagFeiTempVar==6 && Dist(CurShip,Player())<=300 && ItemIn(Q_item,Player()))",
                        "  {",
                        "  \tOrderLanding(CurShip,Player());",
                        "  \tGFlagFeiTempVar=7;",
                        "  }",
                        "  //Если сел на игрока, то квест засчитан",
                        "  if(GFlagFeiTempVar==7 && GetShipRuins(CurShip)==Player())",
                        "  {",
                        "  \tGFlagFeiTempVar=10;",
                        "  \tif(ItemIn(Q_item,Player()))",
                        "  \t{",
                        "  \t\tNewsAdd(CT(\"Script.Mod_ExpAcryn.673\"));",
                        "  \t\ttdwd=ScriptItemToItem(Q_item);",
                        "          //+20% к квесту",
                        "  \t\tUselessItemData(tdwd,1,UselessItemData(tdwd,1)+20);",
                        "          //+1 заряд для запуска шпиона",
                        "  \t\tUselessItemData(tdwd,2,UselessItemData(tdwd,2)+1);",
                        "          //Увеличиваем счётчик выполнения задания фэян",
                        "  \t\tfl_array[3,2]=fl_array[3,2]+1;",
                        "  \t}",
                        "  \tTransferShip(CurShip,StarPlanets(ShipStar(CurShip),0));",
                        "  \tOrderNone(CurShip);",
                        "  \tif(!ItemIn(Q_item,Player()))",
                        "  \t{",
                        "  \t\tfor(i=1;i<ShipItems(Player());i=i+1)",
                        "  \t\t{",
                        "  \t\t\ttdwd=ShipItems(Player(),i);",
                        "  \t\t\tif(!ItemIsInUse(tdwd))continue;",
                        "  \t\t\tItemDurability(tdwd,0);",
                        "  \t\t}",
                        "  \t\tOrderNone(Player());",
                        "  \t\tOrderLock(Player(),1);",
                        "  \t\tCustomLose(CT(\"Script.Mod_ExpAcryn.652\"));",
                        "  \t}",
                        "  \tShipDestroy(CurShip,1);",
                        "  }",
                        "}"
                    ],
                    "#": 197,
                    "Type": "Top",
                    "Parent": -1,
                    "Pos.x": 160
                },
                {
                    "Name": "",
                    "Code.Type": "Turn",
                    "Code": [
                        "//Запрещаем бертору вести огонь по игроку",
                        "for(i=ShipCntWeapon(CurShip);i>0;i=i-1)",
                        "{",
                        "    tdwd=ShipWeapon(CurShip,i);",
                        "    if(WeaponTarget(tdwd)==Player())WeaponTarget(tdwd,0);",
                        "}",
                        "if(Dist(CurShip,Player())>250) {",
                        "  ShipAddCustomShipInfo(CurShip,'ExpAcryn_block_infos');",
                        "  NoTalkToShip(CurShip,1);",
                        "  NewsAdd(CT(\"Script.Mod_ExpAcryn.762\"));",
                        "  GFlagGaalTempVar=1;",
                        "  if(PlayerChameleonDetected(ItemSubrace(ShipItems(CurShip,0)))!=1)PlayerChameleonDetected(ItemSubrace(ShipItems(CurShip,0)),1);",
                        "  OrderLock(CurShip,0);",
                        "  ShipOut(CurShip);",
                        "}",
                        "if(!ItemIn(Q_item,Player())) {",
                        "  ShipAddCustomShipInfo(CurShip,'ExpAcryn_block_infos');",
                        "  NoTalkToShip(CurShip,1);",
                        "  NewsAdd(CT(\"Script.Mod_ExpAcryn.758\"));",
                        "  GFlagGaalTempVar=1;",
                        "  if(PlayerChameleonDetected(ItemSubrace(ShipItems(CurShip,0)))!=1)PlayerChameleonDetected(ItemSubrace(ShipItems(CurShip,0)),1);",
                        "  OrderLock(CurShip,0);",
                        "  ShipOut(CurShip);",
                        "}",
                        "if(fl_array[4,5]!=0) {",
                        "  if(CurTurn()>=fl_array[4,5] && !PlayerChameleonDetected(ItemSubrace(ShipItems(CurShip,0)))) {",
                        "    fl_array[4,5]=0;",
                        "    NewsAdd(CT(\"Script.Mod_ExpAcryn.756\"));",
                        "    PlayerChameleonDetected(ItemSubrace(ShipItems(CurShip,0)),1);",
                        "  }",
                        "}",
                        "if(!1) {",
                        "  ChangeState(4);",
                        "  exit;",
                        "}"
                    ],
                    "#": 198,
                    "Type": "Top",
                    "Parent": -1,
                    "Pos.x": 240
                },
                {
                    "Name": "",
                    "Code.Type": "Turn",
                    "Code": [
                        "if(!GAnswerData) {",
                        "  DChange(0);",
                        "  exit;",
                        "}",
                        "if(GAnswerData) {",
                        "  //Ищем неизвестные доминаторские модификации, необходимые по заданию малоков",
                        "  //Если нашли, то увеличиваем счетчик предметов и удаляем модификацию из трюма",
                        "  tint2=0;",
                        "  for(i=ShipItems(Player())-1;i>0;i=i-1)",
                        "  {",
                        "      tdwd=ShipItems(Player(),i);",
                        "      if(EqSpecial(tdwd)==-1)continue;",
                        "      if(EqSpecial(tdwd)!=FindBonusByCustomTag('ExpAcryn_ship_maloc'))continue;",
                        "      fl_array[0,2]=fl_array[0,2]+1;",
                        "      FreeItem(GetItemFromShip(Player(),i));",
                        "      tint2=1;",
                        "  }",
                        "  if(fl_array[owner,2]>=5 && !ItemIn(Q_item,Player())) {",
                        "    DChange(25);",
                        "    exit;",
                        "  }",
                        "  if(fl_array[owner,2]<5) {",
                        "    tint=5-fl_array[owner,2];",
                        "    if(tint==1)tstr2='</color>'+CT(\"Script.Mod_ExpAcryn.491\");",
                        "    else if(tint>=2 && tint<=4)tstr2='</color>'+CT(\"Script.Mod_ExpAcryn.490\");",
                        "    else if(tint==5)tstr2='</color>'+CT(\"Script.Mod_ExpAcryn.489\");",
                        "    if(tint2)tstr='</color>'+Format(CT(\"Script.Mod_ExpAcryn.836\"),\"<0>\",tint,\"<1>\",tstr2);",
                        "    else tstr='</color>'+Format(CT(\"Script.Mod_ExpAcryn.835\"),\"<0>\",tint,\"<1>\",tstr2);",
                        "    DChange(1);",
                        "    exit;",
                        "  }",
                        "  if(fl_array[owner,2]>=5 && ItemIn(Q_item,Player())) {",
                        "    //Завершаем миссию и выдаём награду",
                        "    EndFlagmanMission();",
                        "    ",
                        "    //Формируются строчки уведомления о награде и о предложении выполнить квесты других флагманов (последнее, если игрок уже выполнил задание текущей расы два раза)",
                        "    tstr='</color>';",
                        "    tstr2='</color>';",
                        "    //Награда этой расой вручается первый раз",
                        "    if(fl_array[owner,1]==2)tstr=tstr+Format(CT(\"Script.Mod_ExpAcryn.519\"),\"<0>\",lowercase(substr(DeleteTags(Name(tdwd2)),0,1))+substr(DeleteTags(Name(tdwd2)),1));",
                        "    //Награда этой расой вручается уже второй раз",
                        "    else if(fl_array[owner,1]==3)tstr=tstr+Format(CT(\"Script.Mod_ExpAcryn.879\"),\"<0>\",lowercase(substr(DeleteTags(Name(tdwd2)),0,1))+substr(DeleteTags(Name(tdwd2)),1));",
                        "    //Награда была вручена первый раз и ещё есть \"место\" под вручение второй награды",
                        "    if(fl_array[owner,1]==2 && item_count<3)",
                        "    {",
                        "        tint=tint+1;",
                        "        if(fl_array[owner,tint]==t_FuelTanks)addItemName=CT(\"Script.Mod_ExpAcryn.512\");",
                        "        else if(fl_array[owner,tint]==t_Engine)addItemName=CT(\"Script.Mod_ExpAcryn.511\");",
                        "        else if(fl_array[owner,tint]==t_Radar)addItemName=CT(\"Script.Mod_ExpAcryn.510\");",
                        "        else if(fl_array[owner,tint]==t_Scaner)addItemName=CT(\"Script.Mod_ExpAcryn.509\");",
                        "        else if(fl_array[owner,tint]==t_RepairRobot)addItemName=CT(\"Script.Mod_ExpAcryn.450\");",
                        "        else if(fl_array[owner,tint]==t_CargoHook)addItemName=CT(\"Script.Mod_ExpAcryn.508\");",
                        "        else if(fl_array[owner,tint]==t_DefGenerator)addItemName=CT(\"Script.Mod_ExpAcryn.507\");",
                        "    \ttstr=tstr+'...'+CT(\"Script.Mod_ExpAcryn.147\")+Format(CT(\"Script.Mod_ExpAcryn.540\"),\"<0>\",addItemName);",
                        "    \ttstr2=tstr2+CT(\"Script.Mod_ExpAcryn.531\");",
                        "    }",
                        "    //Награда этой расой вручена второй раз, направляем игрока к другим флагманам",
                        "    else if(fl_array[owner,1]==3 && item_count<3)",
                        "    {",
                        "    \ttstr=tstr+CT(\"Script.Mod_ExpAcryn.147\")+CT(\"Script.Mod_ExpAcryn.504\");",
                        "    \ttstr2=tstr2+CT(\"Script.Mod_ExpAcryn.503\");",
                        "    }",
                        "    //Награда этой расой была вручена первый раз, но все награды в партии игроку уже выданы",
                        "    else if(fl_array[owner,1]==2 && item_count==3)",
                        "    {",
                        "    \ttstr=tstr+'</color>'+CT(\"Script.Mod_ExpAcryn.516\");",
                        "    \ttstr2=tstr2+CT(\"Script.Mod_ExpAcryn.460\");",
                        "    }",
                        "    //Награда этой расой вручена второй раз, но все награды в партии игроку уже выданы",
                        "    else if(fl_array[owner,1]==3 && item_count==3)",
                        "    {",
                        "    \ttstr=tstr+CT(\"Script.Mod_ExpAcryn.147\")+CT(\"Script.Mod_ExpAcryn.502\");",
                        "    \ttstr2=tstr2+CT(\"Script.Mod_ExpAcryn.501\");",
                        "    }",
                        "    ",
