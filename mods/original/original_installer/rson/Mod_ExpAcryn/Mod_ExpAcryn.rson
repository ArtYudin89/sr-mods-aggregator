                    "Code": [
                        "for(i = 1; i < ArrayDim(temp_array); i = i + 1)",
                        "{",
                        "    //Определяем имя текущего владельца системы",
                        "    if(StarOwner(temp_array[i]) == 0) tstr3 = CT(\"Script.Mod_ExpAcryn.780\");",
                        "    else if(StarOwner(temp_array[i]) == 1)",
                        "    {",
                        "        if(StarSeries(temp_array[i]) == 0) tstr3 = lowercase('<color=220,0,0>' + CT(\"Script.Mod_ExpAcryn.779\") + '</color>');",
                        "        else if(StarSeries(temp_array[i]) == 1) tstr3 = lowercase('<color=0,140,220>' + CT(\"Script.Mod_ExpAcryn.778\") + '</color>');",
                        "        else if(StarSeries(temp_array[i]) == 2) tstr3 = lowercase('<color=50,140,15>' + CT(\"Script.Mod_ExpAcryn.777\") + '</color>');",
                        "    }",
                        "    else if(StarOwner(temp_array[i]) == 2) tstr3 = lowercase(CT(\"Script.Mod_ExpAcryn.776\"));",
                        "    //Проверяем наличие в системе кастомной фракции",
                        "    if(StarCustomFaction(temp_array[i]) != '')",
                        "    {",
                        "        if(StarCustomFaction(temp_array[i]) == 'Klissan') tstr3 = lowercase(CT(\"Script.Mod_ExpAcryn.775\"));",
                        "        else if(StarCustomFaction(temp_array[i]) == 'AMod_Invaders') tstr3 = lowercase(CT(\"Script.Mod_ExpAcryn.878\"));",
                        "        else tstr3 = StarCustomFaction(temp_array[i]);",
                        "    }",
                        "    InjectAnswer('BertorGoJump', CT(\"Script.Mod_ExpAcryn.787\") + ' <color=0,50,200>' + Name(temp_array[i]) + '</color>' + ' (' + tstr3 + ')', temp_array[i]);",
                        "}",
                        "DAnswer('fastexit~' + CT(\"Script.Mod_ExpAcryn.768\"));",
                        "ArrayClear(temp_array);"
