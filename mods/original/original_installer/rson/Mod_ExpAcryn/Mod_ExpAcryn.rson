                        "    if(fl_array[owner,1]==2)Ether(4,'ExpAcryn_quest_4',CT('Script.Mod_ExpAcryn.MissionAccomplished')+CT('Script.Mod_ExpAcryn.GaalMission'));",
                        "    else Ether(4,'ExpAcryn_quest_4',CT('Script.Mod_ExpAcryn.MissionAccomplished')+Format(CT('Script.Mod_ExpAcryn.GaalMission2'),'#ItemName#',addItemName));",
                        "    DChange(17);",
