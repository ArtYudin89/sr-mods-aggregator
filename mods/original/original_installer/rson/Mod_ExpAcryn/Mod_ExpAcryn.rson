                {
                    "Name": "",
                    "Code.Type": "Turn",
                    "Code": [
                        "tdwd3 = GetTalkShip();",
                        "tdwd = ShipStar(tdwd3);",
                        "tint2 = 0;",
                        "ArrayClear(temp_array);",
                        "for(i = 1; i < GalaxyStars(); i = i + 1)",
                        "{",
                        "    tdwd2=StarNearbyStars(tdwd,i);",
                        "    //Оставляем в списке только системы, принадлежащие доминаторам других серий (проверка убрана)",
                        "    //if(StarOwner(tdwd2) != 1) continue;",
                        "    //if(StarCustomFaction(tdwd2) != '') continue;",
                        "    //Пропускаем Тортугац и Нифигац, если они всё ещё принадлежат пиратам",
                        "    if(StarToCon(tdwd2) == StarToCon(PlanetToStar(PlanetPirateClan())))",
                        "    {",
                        "        if(StarOwner(tdwd2) == 2) continue;",
                        "    }",
                        "    //Проверяем, может ли бертор совершить прыжок в систему по дальности двигателя (топливо не проверяем)",
                        "    if(!ShipCanJump(tdwd3, tdwd, tdwd2)) continue;",
                        "    tint2 = tint2 + 1;",
                        "    ArrayAdd(temp_array, tdwd2);",
                        "}",
                        "if(!tint2) {",
                        "  DChange(65);",
                        "  exit;",
                        "}",
                        "if(tint2) {",
                        "  DChange(29);",
                        "  exit;",
                        "}"
