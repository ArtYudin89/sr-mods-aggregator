            "Operations": [
                {
                    "Name": "",
                    "Code.Type": "Global",
                    "Code": [
                        "if(!GCntRun(GScriptName)) {",
                        "  if(CurTurn()>2200) GRun();",
                        "}"
                    ],
                    "#": 51,
                    "Type": "Top",
                    "Parent": -1,
                    "Pos.x": 0,
                    "Pos.y": 810
                },
                {
                    "Name": "",
                    "Code.Type": "Init",
                    "Code": [
                        "//NewsAdd(ScriptRun(ShipStar(Player()),GetShipPlanet(Player()),'Mod_RevColonization'));",
                        "//Значения переменной scrStatus: 0 - скрипт запущен, ничего нет;",
                        "//1 - найдена подходящая система, добавлен диалог на МЦ;",
                        "//2 - игрок оплатил постройку базы на незаселенной планете;",
                        "//3 - база приземлилась на планету, запущен таймер до конца;",
                        "//100 - завершение колонизации или же отказ от нее;",
                        "//200 - заселение планеты;",
                        "//Значения переменной rewardStatus: 0 - нет предмета, ведутся раскопки",
                        "//1 - предмет найден",
                        "//2 - доставляется к игроку транспортом",
                        "//Функция выбора системы для колонизации. Ищет неоспариваемую коалиционную систему с МЦ.",
                        "//Возвращает указатель на систему или 0.",
                        "function SelectSystem() {",
                        "    int i;",
                        "    dword system, ruin;",
                        "    for(i=5;i<GalaxyStars();i=i+1) {    //Пропуск родных систем кажой расы",
                        "        system=GalaxyStar(i);",
                        "\t\tif(StarOwner(system)) continue;    //Пропуск некоалиционных систем",
                        "        if(StarBattle(system)) continue;    //Пропуск оспариваемых систем",
                        "        if(!StarRuins(system)) continue;    //Пропуск систем без станций",
                        "        ruin=StarRuins(system,'MC');        //Поиск МЦ",
                        "        if(ruin) ArrayAdd(tempArray,system);",
                        "    }",
                        "    if(ArrayDim(tempArray)<=1) system=0;",
                        "    else system=tempArray[Rnd(1,ArrayDim(tempArray)-1)];",
                        "    ArrayClear(tempArray);",
                        "    result=system;",
                        "}",
                        "//Функция переноса кораблей из МЦ на планету.",
                        "function TransferShipsToPlanet(dword ruins, dword planetId) {",
                        "    int i;",
                        "    dword ship, planet, star;",
                        "    star=ShipStar(ruins);",
                        "    planet=IdToPlanet(planetId);",
                        "    for(i=0;i<StarShips(star);i=i+1) {",
                        "        ship=StarShips(star,i);",
                        "        if(ship==Player()) continue;",
                        "        if(GetShipRuins(ship)==ruins) TransferShip(ship,planet);",
                        "    }",
                        "}",
                        "//Функция поиска наибольшей цены на товары в системе. Первый параметр - Id системы,",
                        "//Второй - тип товара соответствующий prodType. Возвращает либо цену конкретного товара",
                        "function FindOutPrices(dword starId, dword productionType) {",
                        "    int i;",
                        "    dword star, planet, price, tempPrice, goodsType;",
                        "    star=GalaxyStar(starId-1);",
                        "    price=0;",
                        "    if(productionType==1) goodsType=t_Minerals;",
                        "    else if(productionType==2) goodsType=t_Food;",
                        "    else if(productionType==3) goodsType=t_Medicine;",
                        "    else if(productionType==4) goodsType=t_Alcohol;",
                        "    else goodsType=t_Luxury;",
                        "    for(i=0;i<StarPlanets(star);i=i+1) {",
                        "        planet=StarPlanets(star,i);",
                        "        tempPrice=GoodsBuyPrice(planet,goodsType);",
                        "        if(tempPrice>price) price=tempPrice;",
                        "    }",
                        "    result=price;",
                        "}",
                        "//Функция инициализации массивов наград и событий",
                        "function InitArrays() {",
                        "    int i, itemTL, itemSize, itemOwner;",
                        "    dword tempItem, itemSubtype;",
                        "    str itemTypeStr, subTypeStr, copyStr;",
                        "    eventsCount=15;",
                        "    for(i=0;i<eventsCount;i=i+1) ArrayAdd(eventsArray,0);",
                        "    rewardsCount=CT('ColonizationRewards.TotalRewards');",
                        "    for(i=0;i<rewardsCount;i=i+1) ArrayAdd(rewardsArray,0);",
                        "    for(i=1;i<ArrayDim(rewardsArray);i=i+1) {",
                        "        itemTypeStr=CT('ColonizationRewards.'+i+'.Type');",
                        "        if(itemTypeStr=='useless') {",
                        "            subTypeStr=CT('ColonizationRewards.'+i+'.Subtype');",
                        "            copyStr=CT('ColonizationRewards.'+i+'.Owner');",
                        "            itemOwner=GetValueFromScript('',copyStr);",
                        "            tempItem=CreateQuestItem(subTypeStr,itemOwner);",
                        "        }",
                        "        else if(itemTypeStr=='artifact') {",
                        "            itemSubtype=GetValueFromScript('',CT('ColonizationRewards.'+i+'.Subtype'));",
                        "            copyStr=CT('ColonizationRewards.'+i+'.Owner');",
                        "            if(copyStr=='-1') itemOwner=Rnd(Maloc,Gaal);",
                        "            else itemOwner=GetValueFromScript('',copyStr);",
                        "            tempItem=CreateArt(itemSubtype,itemOwner);",
                        "        }",
                        "        else if(itemTypeStr=='equipment') {",
                        "            itemSubtype=GetValueFromScript('',CT('ColonizationRewards.'+i+'.Subtype'));",
                        "            copyStr=CT('ColonizationRewards.'+i+'.Owner');",
                        "            if(copyStr=='-1') itemOwner=Rnd(Maloc,Gaal);",
                        "            else itemOwner=GetValueFromScript('',copyStr);",
                        "            itemSize=CT('ColonizationRewards.'+i+'.Size');",
                        "            if(itemSize<0) {",
                        "                if(itemSubtype==t_FuelTanks) itemSize=CT('Items.FuelTanks.AverageSize');",
                        "    \t\t\telse if(itemSubtype==t_Engine) itemSize=CT('Items.Engine.AverageSize');",
                        "    \t\t\telse if(itemSubtype==t_Radar) itemSize=CT('Items.Radar.AverageSize');",
                        "    \t\t\telse if(itemSubtype==t_Scaner) itemSize=CT('Items.Scaner.AverageSize');",
                        "    \t\t\telse if(itemSubtype==t_RepairRobot) itemSize=CT('Items.RepairRobot.AverageSize');",
                        "    \t\t\telse if(itemSubtype==t_CargoHook) itemSize=CT('Items.CargoHook.AverageSize');",
                        "    \t\t\telse if(itemSubtype==t_DefGenerator) itemSize=CT('Items.DefGenerator.AverageSize');",
                        "    \t\t\telse if(itemSubtype>t_DefGenerator && itemSubtype<t_CustomWeapon) itemSize=CT('Items.Weapon.Stats.'+(itemSubtype-t_DefGenerator)+'.AverageSize');",
                        "                itemSize=round(Rnd(itemSize/2,itemSize*2));",
                        "            }",
                        "            itemTL=CT('ColonizationRewards.'+i+'.ItemTechLevel');",
                        "            if(itemTL<0) itemTL=GalaxyTechLevel();",
                        "            tempItem=CreateEquipment(itemSubtype,itemSize,itemTL,itemOwner);",
                        "        }",
                        "        PutItemInVault('RevColonization_Vault_'+i,tempItem);",
                        "    }",
                        "}",
                        "//Функция создания корабля-доставщика",
                        "function BuyDelivery(dword planetId) {",
                        "    dword planet, ship;",
                        "    planet=IdToPlanet(planetId);",
                        "    ship=BuyTransport(planet);",
                        "    ShipJoin(DeliveryGroup,ship);",
                        "    TransferShip(ship, planet);",
                        "    NoTargetToShip(ship,3);",
                        "}",
                        "//Функция генерации случайных событий для колонии. Все доступные события заносятся во временный массив",
                        "//После чего одно из них случайно выбирается и срабатывает.",
                        "//Отношения не могут опуститься до враждебных по событию.",
                        "function CreateEvent() {",
                        "    int i;",
                        "    dword curEvent, curRelations;",
                        "    str newsText, addition;",
                        "    for(i=1;i<ArrayDim(eventsArray);i=i+1) {",
                        "        if(!eventsArray[i]) ArrayAdd(tempArray,i);",
                        "    }",
                        "    addition='';",
                        "    if(ArrayDim(tempArray)<=1) curEvent=0;",
                        "    else {",
                        "        curEvent=tempArray[Rnd(1,ArrayDim(tempArray)-1)];",
                        "        if(curEvent==1) {",
                        "            newsText=Format(CT(\"Script.Mod_RevColonization.40\"),\"<0>\",Name(IdToPlanet(planetColonyId)));",
                        "            ChangeGlobalRelationsPlanets(Player(),0,2,20,2+4+8+16);",
                        "            ChangeGlobalRelationsShips(Player(),0,2,20,4+8+16+32,1+2+4+8+16);",
                        "        }",
                        "        else if(curEvent==2) {",
                        "            newsText=Format(CT(\"Script.Mod_RevColonization.39\"),\"<0>\",Name(IdToPlanet(planetColonyId)),\"<1>\",Name(IdToPlanet(planetColonyId)));",
                        "            ChangeGlobalRelationsPlanets(Player(),0,2,10,1+2+4+8+16);",
                        "            ChangeGlobalRelationsShips(Player(),0,2,10,4+8+16+32,1+2+4+8+16);",
                        "        }",
                        "        else if(curEvent==3) {",
                        "            newsText=Format(CT(\"Script.Mod_RevColonization.38\"),\"<0>\",Name(IdToPlanet(planetColonyId)));",
                        "            curRelations=GlobalRelationsShips(Player(),0,4+8+16+32,2);",
                        "            if(curRelations<30) ChangeGlobalRelationsShips(Player(),0,0,10,4+8+16+32,2);",
                        "            else ChangeGlobalRelationsShips(Player(),0,3,20,4+8+16+32,2);",
                        "            curRelations=GlobalRelationsPlanets(Player(),0,2);",
                        "            if(curRelations<30) ChangeGlobalRelationsPlanets(Player(),0,0,10,2);",
                        "            else ChangeGlobalRelationsPlanets(Player(),0,3,20,2);",
                        "            ChangeGlobalRelationsPlanets(Player(),0,2,10,1+4+8+16);",
                        "            ChangeGlobalRelationsShips(Player(),0,2,10,4+8+16+32,1+4+8+16);",
                        "        }",
                        "        else if(curEvent==4) {",
                        "            newsText=Format(CT(\"Script.Mod_RevColonization.127\"),\"<0>\",Name(IdToPlanet(planetColonyId)));",
                        "            curRelations=GlobalRelationsShips(Player(),0,4+8+16+32,8);",
                        "            if(curRelations<30) ChangeGlobalRelationsShips(Player(),0,0,10,4+8+16+32,8);",
                        "            else ChangeGlobalRelationsShips(Player(),0,3,20,4+8+16+32,8);",
                        "            curRelations=GlobalRelationsPlanets(Player(),0,8);",
                        "            if(curRelations<30) ChangeGlobalRelationsPlanets(Player(),0,0,10,8);",
                        "            else ChangeGlobalRelationsPlanets(Player(),0,3,20,8);",
                        "            ChangeGlobalRelationsPlanets(Player(),0,2,10,1+2+4+16);",
                        "            ChangeGlobalRelationsShips(Player(),0,2,10,4+8+16+32,1+2+4+16);",
                        "        }",
                        "        else if(curEvent==5) {",
                        "            newsText=Format(CT(\"Script.Mod_RevColonization.36\"),\"<0>\",Name(IdToPlanet(planetColonyId)),\"<1>\",Name(IdToPlanet(planetColonyId)));",
                        "            curRelations=GlobalRelationsShips(Player(),0,4+8+16+32,1);",
                        "            if(curRelations<30) ChangeGlobalRelationsShips(Player(),0,0,10,4+8+16+32,1);",
                        "            else ChangeGlobalRelationsShips(Player(),0,3,20,4+8+16+32,1);",
                        "            curRelations=GlobalRelationsPlanets(Player(),0,1);",
                        "            if(curRelations<30) ChangeGlobalRelationsPlanets(Player(),0,0,10,1);",
                        "            else ChangeGlobalRelationsPlanets(Player(),0,3,20,1);",
                        "        }",
                        "        else if(curEvent==6) {",
                        "            newsText=Format(CT(\"Script.Mod_RevColonization.35\"),\"<0>\",Name(IdToPlanet(planetColonyId)));",
                        "            curRelations=GlobalRelationsShips(Player(),0,4+8+16+32,8+16);",
                        "            if(curRelations<20) ChangeGlobalRelationsShips(Player(),0,0,10,4+8+16+32,8+16);",
                        "            else ChangeGlobalRelationsShips(Player(),0,3,10,4+8+16+32,8+16);",
                        "            curRelations=GlobalRelationsPlanets(Player(),0,8+16);",
                        "            if(curRelations<20) ChangeGlobalRelationsPlanets(Player(),0,0,10,8+16);",
                        "            else ChangeGlobalRelationsPlanets(Player(),0,3,10,8+16);",
                        "        }",
                        "        else if(curEvent==7) {",
                        "            newsText=Format(CT(\"Script.Mod_RevColonization.34\"),\"<0>\",Name(IdToPlanet(planetColonyId)),\"<1>\",Name(IdToPlanet(planetColonyId)));",
                        "            curRelations=GlobalRelationsShips(Player(),0,4+8+16+32,16);",
                        "            if(curRelations<20) ChangeGlobalRelationsShips(Player(),0,0,10,4+8+16+32,16);",
                        "            else ChangeGlobalRelationsShips(Player(),0,3,10,4+8+16+32,16);",
                        "            curRelations=GlobalRelationsPlanets(Player(),0,8+16);",
                        "            if(curRelations<20) ChangeGlobalRelationsPlanets(Player(),0,0,10,16);",
                        "            else ChangeGlobalRelationsPlanets(Player(),0,3,10,16);",
                        "\t\t\tChangeGlobalRelationsPlanets(Player(),0,2,10,1+2);",
                        "            ChangeGlobalRelationsShips(Player(),0,2,10,4+8+16+32,1+2);",
                        "        }",
                        "        else if(curEvent==8) {",
                        "            newsText=Format(CT(\"Script.Mod_RevColonization.33\"),\"<0>\",Name(IdToPlanet(planetColonyId)));",
                        "            curRelations=GlobalRelationsShips(Player(),0,4+8+16+32,4);",
                        "            if(curRelations<30) ChangeGlobalRelationsShips(Player(),0,0,10,4+8+16+32,4);",
                        "            else ChangeGlobalRelationsShips(Player(),0,3,20,4+8+16+32,4);",
                        "            curRelations=GlobalRelationsPlanets(Player(),0,4);",
                        "            if(curRelations<30) ChangeGlobalRelationsPlanets(Player(),0,0,10,4);",
                        "            else ChangeGlobalRelationsPlanets(Player(),0,3,20,4);",
                        "            ChangeGlobalRelationsPlanets(Player(),0,2,10,1+2+8+16);",
                        "            ChangeGlobalRelationsShips(Player(),0,2,10,4+8+16+32,1+2+8+16);",
                        "            if(prodType==1) {",
                        "                prodOutput=prodOutput+4;    //Бонус к производству минералов",
                        "                addition=Format(CT(\"Script.Mod_RevColonization.25\"),\"<0>\",Name(IdToPlanet(planetColonyId)),\"<1>\",prodStr);",
                        "            }",
                        "       }",
                        "        else if(curEvent==9) {",
                        "            newsText=Format(CT(\"Script.Mod_RevColonization.32\"),\"<0>\",Name(IdToPlanet(planetColonyId)));",
                        "            ChangeGlobalRelationsPlanets(Player(),0,2,15,1+2+4+8+16);",
                        "            ChangeGlobalRelationsShips(Player(),0,2,15,4+8+16+32,1+2+4+8+16);",
                        "        }",
                        "        else if(curEvent==10) {",
                        "            newsText=Format(CT(\"Script.Mod_RevColonization.31\"),\"<0>\",Name(IdToPlanet(planetColonyId)));",
                        "            ChangeGlobalRelationsPlanets(Player(),0,2,10,1+2+4+8+16);",
                        "            ChangeGlobalRelationsShips(Player(),0,2,10,4+8+16+32,1+2+4+8+16);",
                        "        }",
                        "\t\telse if(curEvent==11) {",
                        "            newsText=Format(CT(\"Script.Mod_RevColonization.30\"),\"<0>\",Name(IdToPlanet(planetColonyId)));",
                        "            ChangeGlobalRelationsPlanets(Player(),0,2,10,1+2+4+8+16);",
                        "            ChangeGlobalRelationsShips(Player(),0,2,10,4+8+16+32,1+2+4+8+16);",
                        "\t\t\tif(prodType==5) {",
                        "                prodOutput=prodOutput+1;    //Бонус к производству роскоши",
                        "                addition=Format(CT(\"Script.Mod_RevColonization.25\"),\"<0>\",Name(IdToPlanet(planetColonyId)),\"<1>\",prodStr);",
                        "            }",
                        "        }",
                        "\t\telse if(curEvent==12) {",
                        "            newsText=Format(CT(\"Script.Mod_RevColonization.29\"),\"<0>\",Name(IdToPlanet(planetColonyId)));",
                        "            ChangeGlobalRelationsPlanets(Player(),0,2,10,1);",
                        "            ChangeGlobalRelationsShips(Player(),0,2,10,4+8+16+32,1);",
                        "        }",
                        "\t\telse if(curEvent==13) {",
                        "            newsText=Format(CT(\"Script.Mod_RevColonization.28\"),\"<0>\",Name(IdToPlanet(planetColonyId)));",
                        "            curRelations=GlobalRelationsShips(Player(),0,4+8+16+32,4);",
                        "            if(curRelations<30) ChangeGlobalRelationsShips(Player(),0,0,10,4+8+16+32,4);",
                        "            else ChangeGlobalRelationsShips(Player(),0,3,20,4+8+16+32,4);",
                        "            curRelations=GlobalRelationsPlanets(Player(),0,4);",
                        "            if(curRelations<30) ChangeGlobalRelationsPlanets(Player(),0,0,10,4);",
                        "            else ChangeGlobalRelationsPlanets(Player(),0,3,20,4);",
                        "            ChangeGlobalRelationsPlanets(Player(),0,2,10,8+16);",
                        "            ChangeGlobalRelationsShips(Player(),0,2,10,4+8+16+32,8+16);",
                        "\t\t\tif(prodType==2) {",
                        "                prodOutput=prodOutput+2;    //Бонус к производству продуктов",
                        "                addition=Format(CT(\"Script.Mod_RevColonization.25\"),\"<0>\",Name(IdToPlanet(planetColonyId)),\"<1>\",prodStr);",
                        "            }",
                        "        }",
                        "\t\telse if(curEvent==14) {",
                        "            newsText=Format(CT(\"Script.Mod_RevColonization.27\"),\"<0>\",Name(IdToPlanet(planetColonyId)));",
                        "            curRelations=GlobalRelationsShips(Player(),0,4+8+16+32,1+16);",
                        "            if(curRelations<30) ChangeGlobalRelationsShips(Player(),0,0,10,4+8+16+32,1+16);",
                        "            else ChangeGlobalRelationsShips(Player(),0,3,20,4+8+16+32,1+16);",
                        "            curRelations=GlobalRelationsPlanets(Player(),0,1+16);",
                        "            if(curRelations<30) ChangeGlobalRelationsPlanets(Player(),0,0,10,1+16);",
                        "            else ChangeGlobalRelationsPlanets(Player(),0,3,20,1+16);",
                        "            ChangeGlobalRelationsPlanets(Player(),0,2,10,2+4);",
                        "            ChangeGlobalRelationsShips(Player(),0,2,10,4+8+16+32,2+4);",
                        "\t\t\tif(prodType==4) {",
                        "                prodOutput=prodOutput+2;    //Бонус к производству алкоголя",
                        "                addition=Format(CT(\"Script.Mod_RevColonization.25\"),\"<0>\",Name(IdToPlanet(planetColonyId)),\"<1>\",prodStr);",
                        "            }",
                        "        }",
                        "\t\telse {",
                        "            newsText=Format(CT(\"Script.Mod_RevColonization.26\"),\"<0>\",Name(IdToPlanet(planetColonyId)),\"<1>\",Name(IdToPlanet(planetColonyId)));",
                        "            ChangeGlobalRelationsPlanets(Player(),0,2,10,2);",
                        "            ChangeGlobalRelationsShips(Player(),0,2,10,4+8+16+32,2);",
                        "\t\t\tif(prodType==3) {",
                        "                prodOutput=prodOutput+2;    //Бонус к производству медикаментов",
                        "                addition=Format(CT(\"Script.Mod_RevColonization.25\"),\"<0>\",Name(IdToPlanet(planetColonyId)),\"<1>\",prodStr);",
                        "            }",
                        "        }",
                        "        AddPlanetNews(newsText);",
                        "        NewsAdd(newsText);",
                        "        if(addition!='') NewsAdd(addition);",
                        "        eventsArray[curEvent]=1;",
                        "    }",
                        "    ArrayClear(tempArray);",
                        "}",
                        "//Функция выдачи случайной награды игроку",
                        "function CreateReward() {",
                        "    int i;",
                        "    dword curReward, tempItem, ship;",
                        "    for(i=1;i<ArrayDim(rewardsArray);i=i+1) {",
                        "        if(!rewardsArray[i]) ArrayAdd(tempArray,i);",
                        "    }",
                        "    if(ArrayDim(tempArray)<=1) curReward=0;",
                        "    else {",
                        "        curReward=tempArray[Rnd(1,ArrayDim(tempArray)-1)];",
                        "        tempItem=GetItemFromVault('RevColonization_Vault_'+curReward);",
                        "        if(!GroupCount(DeliveryGroup)) BuyDelivery(planetHabitableId);",
                        "        LinkItemToScript(tempItem,itemToDrop);",
                        "        ship=GroupToShip(DeliveryGroup);",
                        "        AddItemToShip(ship,tempItem);",
                        "        ShipCalcParam(ship);",
                        "\t    if(ShipFreeSpace(ship)<0) {",
                        "    \t\tItemSize(ShipItems(ship,0),ItemSize(ShipItems(ship,0))+abs(ShipFreeSpace(ship))+Rnd(1,5));",
                        "    \t\tHullHP(ship,ItemSize(ShipItems(ship,0)));",
                        "    \t}",
                        "        rewardName=Name(tempItem);",
                        "        rewardStatus=1;",
                        "        Sound('Sound.UserMsgAdd');",
                        "        Ether(3,'4DD640F7-23DD-4A45-82F1-D5F7D32A877B',Format(CT(\"Script.Mod_RevColonization.24\"),\"<0>\",Name(IdToPlanet(planetColonyId)),\"<1>\",rewardName));",
                        "        rewardsArray[curReward]=1;",
                        "    }",
                        "    ArrayClear(tempArray);",
                        "}",
                        "//Если колонизация завершилась преждевременно",
                        "//Очищаем массивы, убираем все предметы из хранилища, делаем систему захватываемой",
                        "function FreeRes() {",
                        "    int i;",
                        "    dword tempItem, tSystem;",
                        "    for(i=1;i<ArrayDim(rewardsArray);i=i+1) {",
                        "        tempItem=GetItemFromVault('RevColonization_Vault_'+i);",
                        "        if(tempItem) FreeItem(tempItem);",
                        "    }",
                        "    tSystem=GalaxyStar(systemId-1);",
                        "    if(NoComeKlingToStar(tSystem)) NoComeKlingToStar(tSystem,0);",
                        "    ArrayClear(tempArray);",
                        "    ArrayClear(eventsArray);",
                        "    ArrayClear(rewardsArray);",
                        "}",
                        "//Функция изъятия у корабля-доставщика скиптового предмета. Изымает предмет и помещает его на склад игрока",
                        "//Первй параметр - корабль, второй - скриптовый предмет, третий - Id планеты, на склад которой поместить предмет",
                        "function GetScriptItem(dword ship, dword scriptItem, dword planetId) {",
                        "    dword tempItem, planet;",
                        "    planet=IdToPlanet(planetId);",
                        "    if(rewardStatus==1) {",
                        "        if(ItemIn(scriptItem,ship)) {",
                        "            tempItem=ScriptItemToItem(scriptItem);",
                        "            ReleaseItemFromScript(scriptItem);",
                        "            if(ItemType(tempItem)>=t_Artefact && ItemType(tempItem)<=t_ArtFastRacks) GetArtFromShip(ship,tempItem);",
                        "            else GetItemFromShip(ship,tempItem);",
                        "            AddItemToStorage(planet,tempItem);",
                        "            Ether(4,'4DD640F7-23DD-4A45-82F1-D5F7D32A877B',Format(CT(\"Script.Mod_RevColonization.24\"),\"<0>\",Name(IdToPlanet(planetColonyId)),\"<1>\",rewardName));",
                        "            NewsAdd(Format(CT(\"Script.Mod_RevColonization.120\"),\"<0>\",Name(GroupToShip(DeliveryGroup)),\"<1>\",rewardName,\"<2>\",Name(IdToPlanet(planetHabitableId))));",
                        "        }",
                        "    }",
                        "}"
                    ],
                    "#": 52,
                    "Type": "Top",
                    "Parent": -1,
                    "Pos.x": 60,
                    "Pos.y": 810
                },
                {
                    "Name": "",
                    "Code.Type": "Turn",
                    "Code": [
                        "//Выбор системы для старта",
                        "if(!scrStatus) {",
                        "  system=SelectSystem();",
                        "  if(system) {    //Запоминаем Id нужных планет, меняем статус скрипта, создаем новости",
                        "    systemId=Id(system);",
                        "//    NoComeKlingToStar(system,1);",
                        "    planetColonyId=Id(FindPlanet(system,'NotMaloc,NotPeleng,NotPeople,NotFei,NotGaal,NotKling,NotPirateClan',0,0));",
                        "    planetHabitableId=Id(FindPlanet(system,'NotNone,NotKling,NotPirateClan',0,0));",
                        "    strMCName=ShortName(StarRuins(system,'MC'));",
                        "    tStr=Format(CT(\"Script.Mod_RevColonization.114\"),\"<0>\",Name(IdToPlanet(planetColonyId)),\"<1>\",Name(system),\"<2>\",strMCName);",
                        "    AddPlanetNews(tStr);",
                        "    NewsAdd(tStr);",
                        "    scrStatus=1;",
                        "  }",
                        "}",
                        "if(scrStatus==2) {    //Завершаем скрипт, если МЦ был уничтожен до приземления на планету мензолов",
                        "  if(!GroupCount(GroupMC)) scrStatus=100;",
                        "}",
                        "else if(scrStatus==3) {    //Если колонизация состоялась",
                        "wasDialog=0;",
                        "  if(CurTurn()>=clnzEndTimer) {    //Таймер до завершения колонизации",
                        "\tscrStatus=100;",
                        "\tAddPlanetNews(Format(CT(\"Script.Mod_RevColonization.44\"),\"<0>\",Name(IdToPlanet(planetColonyId)),\"<1>\",strMCName));",
                        "\tEther(4,'5DBE0D43-E810-429D-A7F6-2365EE7B95EE',Format(CT(\"Script.Mod_RevColonization.44\"),\"<0>\",Name(IdToPlanet(planetColonyId)),\"<1>\",Name(GroupToShip(GroupMC))));",
                        "  }",
                        "  if(!rewardStatus) {",
                        "    if(CurTurn()>=rewardTimer) {    //Таймер до следующей находки",
                        "      CreateReward();",
                        "    }",
                        "  }",
                        "  if(CurTurn()>=eventTimer) {    //Таймер до следующего события",
                        "    CreateEvent();",
                        "    eventTimer=CurTurn()+Rnd(30,90);",
                        "  }",
                        "  if(CurTurn()>=serviceTimer) {    //Таймер до списания денег за обслуживание",
                        "    Ether(0,'0D35F817-56DD-42B1-BD90-F1CE3DE1FDA5',Format(CT(\"Script.Mod_RevColonization.118\"),\"<0>\",serviceCost,\"<1>\",Name(IdToPlanet(planetColonyId))));",
                        "    ShipMoney(Player(),(ShipMoney(Player())-serviceCost));",
                        "    Sound('Sound.Buy');",
                        "    serviceTimer=CurTurn()+60;",
                        "  }",
                        "  //Производство",
                        "  if(prodOutput!=0) {",
                        "    if(prodTotal==whCap) {",
                        "      if(!whSellPercent) {",
                        "        Sound('Sound.UserMsgAdd');",
                        "        Ether(0,'0D35F817-56DD-42B1-BD90-F1CE3DE1FDA5',Format(CT(\"Script.Mod_RevColonization.43\"),\"<0>\",Name(IdToPlanet(planetColonyId)),\"<1>\",prodStr));",
                        "      }",
                        "      else {",
                        "        if(CurTurn()>=prodSellTimer) {",
                        "          prodCost=FindOutPrices(systemId,prodType);",
                        "          sum=((prodTotal*whSellPercent)/100)*((prodCost*prodProfit)/100);",
                        "          ShipMoney(Player(),ShipMoney(Player())+sum);",
                        "          prodTotal=whCap-(whCap*whSellPercent/100);",
                        "          prodSellTimer=CurTurn()+60;",
                        "          Sound('Sound.Buy');",
                        "          Ether(0,'C456704F-8445-45A4-8FD5-0534AF0896E7',Format(CT(\"Script.Mod_RevColonization.119\"),\"<0>\",Name(IdToPlanet(planetColonyId)),\"<1>\",whCap-prodTotal,\"<2>\",prodStr,\"<3>\",whSellPercent,\"<4>\",sum));",
                        "        }",
                        "        else {",
                        "          if(((prodSellTimer-CurTurn())%10)==1) tStr=' день';",
                        "          else if(((prodSellTimer-CurTurn())%10)>1 && ((prodSellTimer-CurTurn())%10)<5) tStr=' дня';",
                        "          else tStr=' дней';",
                        "          Sound('Sound.UserMsgAdd');",
                        "          Ether(0,'0D35F817-56DD-42B1-BD90-F1CE3DE1FDA5',Format(CT(\"Script.Mod_RevColonization.41\"),\"<0>\",Name(IdToPlanet(planetColonyId)),\"<1>\",prodStr,\"<2>\",(prodSellTimer-CurTurn()),\"<3>\",tStr));",
                        "        }",
                        "      }",
                        "    }",
                        "    if(whCap>prodTotal) {",
                        "      prodTotal=prodTotal+prodOutput;",
                        "      if(prodTotal+prodOutput>whCap) {",
                        "        prodTotal=whCap;",
                        "      }",
                        "    }",
                        "  }",
                        "}",
                        "//Завершаем скрипт при досрочном завершении колонизации",
                        "else if(scrStatus==100) {",
                        "  if(!GroupCount(GroupMC)) {",
                        "    if(!GroupCount(DeliveryGroup)) {",
                        "      FreeRes();",
                        "      AllShipOut();",
                        "    }",
                        "  }",
                        "}"
                    ],
                    "#": 53,
                    "Type": "Top",
                    "Parent": -1,
                    "Pos.x": 120,
                    "Pos.y": 810
                },
                {
                    "Name": "",
                    "Code.Type": "DialogBegin",
                    "Code": [
                        "//Диалог о колонизации",
                        "curRuin=GetShipRuins(Player());",
                        "if(curRuin) {",
                        "  if(!PlayerBridge()) {",
                        "    if(ShipType(curRuin)=='MC') {",
                        "      if(Id(ShipStar(curRuin))==systemId) {",
                        "        if(scrStatus==1) AddDialogInject('DialogColonization',Format(CT(\"Script.Mod_RevColonization.2\"),\"<0>\",Name(IdToPlanet(planetColonyId))),CT(\"Script.Mod_RevColonization.1\"),2);",
                        "      }",
                        "    }",
                        "  }",
                        "}",
                        "//Диалог о продаже юзлессов на планете",
                        "if(scrStatus>=3) {",
                        "  if(GetShipPlanet(Player())) {",
                        "    if(Id(GetShipPlanet(Player()))==planetHabitableId) {",
                        "      AddDialogInject('DialogGov','',CT(\"Script.Mod_RevColonization.121\"),2);",
                        "    }",
                        "  }",
                        "}"
                    ],
                    "#": 54,
                    "Type": "Top",
                    "Parent": -1,
                    "Pos.x": 180,
                    "Pos.y": 810
                },
                {
                    "Name": "",
                    "Code.Type": "Turn",
                    "Code": [
                        "if(!OrderLock(CurShip)) OrderLock(CurShip,1);",
                        "if(!GetShipPlanet(CurShip)) {    //Столько условий именно для того, чтобы станция приземлилась 1 раз",
                        "    if(!ShipIsTakeoff(CurShip)) OrderLanding(CurShip,IdToPlanet(planetColonyId));",
                        "}",
                        "if(GetShipPlanet(CurShip)) {",
                        "  ChangeGlobalRelationsShips(Player(),0,1,13,2+4+8+16+32,1+2+4+8+16);",
                        "  ChangeGlobalRelationsPlanets(Player(),0,1,15,1+2+4+8+16);",
                        "  AddPlanetNews(Format(CT(\"Script.Mod_RevColonization.45\"),\"<0>\",ShortName(Player),\"<1>\",Name(IdToPlanet(planetColonyId))));",
                        "  scrStatus=3;",
                        "  InitArrays();                                //Инициализация массивов",
                        "  BuyDelivery(planetHabitableId);                //Корабль-доставщик",
                        "  clnzEndTimer=CurTurn()+365*3+Rnd(-30,180);    //Таймер окончания колонизации",
                        "  rewardTimer=CurTurn()+Rnd(50,100);            //Таймер для находок",
                        "  eventTimer=CurTurn()+Rnd(30,90);            //Таймер для случайных событий",
                        "  serviceTimer=CurTurn()+60;                   //Таймер до списания денег за обслуживание",
                        "  TransferShipsToPlanet(CurShip,planetHabitableId);    //Переносим все корабли со станции на планету",
                        "  NoComeKlingToStar(ShipStar(CurShip),1);",
                        "  ChangeState(2);",
                        "  exit;",
                        "}"
                    ],
                    "#": 167,
                    "Type": "Top",
                    "Parent": -1,
                    "Pos.x": 80
                },
                {
                    "Name": "",
                    "Code.Type": "Turn",
                    "Code": [
                        "if(!wasDialog) {",
                        "    if(Dist(Player(),IdToPlanet(planetColonyId))<300) {",
                        "        if(ItemIn(satellite,GalaxyStar(systemId-1))) {",
                        "            Dialog(DialogColony,CurShip);",
                        "        }",
                        "    }",
                        "}",
                        "if(scrStatus==100) {",
                        "  ChangeState(4);",
                        "  exit;",
                        "}"
                    ],
                    "#": 168,
                    "Type": "Top",
                    "Parent": -1,
                    "Pos.x": 160
                },
                {
                    "Name": "",
                    "Code.Type": "Turn",
                    "Code": [
                        "if(rewardStatus==2) {",
                        "    if(!OrderLock(CurShip)) OrderLock(CurShip,1);",
                        "    if(GetShipPlanet(CurShip)) OrderTakeOff(CurShip);",
                        "    else if(ShipInNormalSpace(CurShip)) {",
                        "        if(ItemIn(itemToDrop,CurShip)) {",
                        "            OrderFollowShip(CurShip,Player());",
                        "            if((Dist(CurShip,Player())<150) || (ShipStar(Player())!=ShipStar(CurShip))) {",
                        "                DropScriptItem(CurShip,itemToDrop);",
                        "                ReleaseItemFromScript(itemToDrop);",
                        "                rewardStatus=0;",
                        "                rewardTimer=CurTurn()+Rnd(50,100);",
                        "                Ether(4,'4DD640F7-23DD-4A45-82F1-D5F7D32A877B',Format(CT(\"Script.Mod_RevColonization.24\"),\"<0>\",Name(IdToPlanet(planetColonyId)),\"<1>\",rewardName));",
                        "            }",
                        "        }",
                        "    }",
                        "}",
                        "else if(!rewardStatus) {",
                        "    if(!GetShipPlanet(CurShip)) OrderLanding(CurShip,IdToPlanet(planetHabitableId));",
                        "}",
                        "if(scrStatus>=100) {",
                        "  if(rewardStatus!=2) {",
                        "    ChangeState(5);",
                        "    exit;",
                        "  }",
                        "}"
                    ],
                    "#": 169,
                    "Type": "Top",
                    "Parent": -1,
                    "Pos.x": 240
                },
                {
                    "Name": "",
                    "Code.Type": "Turn",
                    "Code": [
                        "TransferShipsToPlanet(CurShip,planetHabitableId); //Кто-то мог приземлиться на МЦ, когда тот уже был на планете",
                        "if(prodTotal) { //Продажа остатков товара со склада",
                        "    prodCost=FindOutPrices(systemId,prodType);",
                        "    sum=prodTotal*(prodCost*prodProfit)/100;",
                        "    ShipMoney(Player(),ShipMoney(Player())+sum);",
                        "    prodTotal=0;",
                        "    Sound('Sound.Buy');",
                        "    Ether(0,'C456704F-8445-45A4-8FD5-0534AF0896E7',Format(CT(\"Script.Mod_RevColonization.128\"),\"<0>\",Name(IdToPlanet(planetColonyId)),\"<1>\",sum));",
                        "}",
                        "if(GetShipPlanet(CurShip)) OrderTakeOff(CurShip);",
                        "else if(ShipInNormalSpace(CurShip)) {",
                        "    if(OrderLock(CurShip)) OrderLock(CurShip,0);",
                        "    ShipOut(CurShip);",
                        "}"
                    ],
                    "#": 170,
