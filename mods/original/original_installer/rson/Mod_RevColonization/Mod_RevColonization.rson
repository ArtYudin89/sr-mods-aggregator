                        "  \telse tStr1=tStr1+CT(\"Script.Mod_RevColonization.84\");",
                        "  }",
                        "  tStr=tStr+tStr1;",
                        "  DChange(14);",
                        "  exit;",
                        "}",
                        "if(CurTurn()<prodEnhTimer) {",
                        "  if((prodEnhTimer-CurTurn())==1) tStr=' день';",
                        "  else if((prodEnhTimer-CurTurn())<5) tStr=' дня';",
                        "  else tStr=' дней';",
                        "  wasDialog=1;",
                        "  DChange(13);",
                        "  exit;",
                        "}"
                    ],
