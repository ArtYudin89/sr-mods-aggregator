            "Operations": [
                {
                    "Name": "",
                    "Code.Type": "Global",
                    "Code": [
                        "GRun();"
                    ],
                    "#": 53,
                    "Type": "Top",
                    "Parent": -1,
                    "Pos.x": 0,
                    "Pos.y": 810
                },
                {
                    "Name": "",
                    "Code.Type": "Init",
                    "Code": [
                        "if(CapitalShipStats(ShipItems(Player(),0))<1) {",
                        "  //Если на корабле игрока нет мостика, добавляется мостик под номером 2 из Main мода Девкита",
                        "  CapitalShipStats(ShipItems(Player(),0),2);",
                        "  ",
                        "  function RaceSetDefine(race_str, split_type)",
                        "  {",
                        "  \t//Определяем сет рас",
                        "  \tint race_set = 0;",
                        "  ",
                        "  \tif(race_str == '' || race_str == 'Any')",
                        "  \t{",
                        "  \t\tif(split_type != 'Acryn')race_set = 1951; //По умолчанию все расы, кроме неизвестной (1 + 2 + 4 + 8 + 16 + 128 + 256 + 512 + 1024)",
                        "  \t\telse race_set = 159; //По умолчанию все расы, кроме неизвестной и доминаторов (1 + 2 + 4 + 8 + 16 + 128)",
                        "  \t}",
                        "  \telse",
                        "  \t{",
                        "  \t\tint dom_race_restrict = 0;",
                        "  \t\t//Для акринов по умолчанию не добавляем в сет доминаторские расы",
                        "  \t\tif(split_type == 'Acryn')dom_race_restrict = 1;",
                        "  \t\tint cycle_count = 0;",
                        "  ",
                        "  \t\tstr par_str = 'begin';",
                        "  \t\twhile(par_str != '')",
                        "  \t\t{",
                        "  \t\t\tpar_str = GetParFromString(race_str, ',', cycle_count, 1);",
                        "  ",
                        "  \t\t\tif(par_str == 'Maloc')",
                        "  \t\t\t{",
                        "  \t\t\t\tif(!(race_set & 1))race_set = race_set + 1;",
                        "  \t\t\t}",
                        "  \t\t\telse if(par_str == 'Peleng')",
                        "  \t\t\t{",
                        "  \t\t\t\tif(!(race_set & 2))race_set = race_set + 2;",
                        "  \t\t\t}",
                        "  \t\t\telse if(par_str == 'People')",
                        "  \t\t\t{",
                        "  \t\t\t\tif(!(race_set & 4))race_set = race_set + 4;",
                        "  \t\t\t}",
                        "  \t\t\telse if(par_str == 'Fei')",
                        "  \t\t\t{",
                        "  \t\t\t\tif(!(race_set & 8))race_set = race_set + 8;",
                        "  \t\t\t}",
                        "  \t\t\telse if(par_str == 'Gaal')",
                        "  \t\t\t{",
                        "  \t\t\t\tif(!(race_set & 16))race_set = race_set + 16;",
                        "  \t\t\t}",
                        "  \t\t\telse if(par_str == 'None')",
                        "  \t\t\t{",
                        "  \t\t\t\tif(!(race_set & 64))race_set = race_set + 64;",
                        "  \t\t\t}",
                        "  \t\t\telse if(par_str == 'PirateClan')",
                        "  \t\t\t{",
                        "  \t\t\t\tif(!(race_set & 128))race_set = race_set + 128;",
                        "  \t\t\t}",
                        "  \t// Не используется в оригинальной игре! /////////////",
                        "  \t\t\telse if(par_str == 'Kling')",
                        "  \t\t\t{",
                        "  \t\t\t\tif(!(race_set & 256))race_set = race_set + 256;",
                        "  \t\t\t\tif(!(race_set & 512))race_set = race_set + 512;",
                        "  \t\t\t\tif(!(race_set & 1024))race_set = race_set + 1024;",
                        "  \t\t\t\tdom_race_restrict = 1;",
                        "  \t\t\t}",
                        "  \t////////////////////////////////////////////////////",
                        "  \t\t\telse if(par_str == 'Blazer')",
                        "  \t\t\t{",
                        "  \t\t\t\tif(!(race_set & 256))race_set = race_set + 256;",
                        "  \t\t\t\tdom_race_restrict = 1;",
                        "  \t\t\t}",
                        "  \t\t\telse if(par_str == 'Keller')",
                        "  \t\t\t{",
                        "  \t\t\t\tif(!(race_set & 512))race_set = race_set + 512;",
                        "  \t\t\t\tdom_race_restrict = 1;",
                        "  \t\t\t}",
                        "  \t\t\telse if(par_str == 'Terron')",
                        "  \t\t\t{",
                        "  \t\t\t\tif(!(race_set & 1024))race_set = race_set + 1024;",
                        "  \t\t\t\tdom_race_restrict = 1;",
                        "  \t\t\t}",
                        "  \t\t\telse if(par_str == 'NonKling')",
                        "  \t\t\t{",
                        "  \t\t\t\tdom_race_restrict = 2;",
                        "  \t\t\t}",
                        "  ",
                        "  \t\t\tcycle_count = cycle_count + 1;",
                        "  \t\t}",
                        "  ",
                        "  \t\tif(!dom_race_restrict)race_set = race_set + 1792; //По умолчанию добавляем в сет все доминаторские серии",
                        "  \t\t//Удаляем все доминаторские серии, если был установлен параметр NonKling",
                        "  \t\telse if(dom_race_restrict == 2)",
                        "  \t\t{",
                        "  \t\t\tif((race_set & 256))race_set = race_set - 256;",
                        "  \t\t\tif((race_set & 512))race_set = race_set - 512;",
                        "  \t\t\tif((race_set & 1024))race_set = race_set - 1024;",
                        "  \t\t}",
                        "  \t}",
                        "  ",
                        "  \tresult = race_set;",
                        "  }",
                        "  ",
                        "  //SetBaseType('' + t_Engine, '', 8, 1);",
                        "  function SetBaseType(str type, str custom_type, GTL, param)",
                        "  {",
                        "  \tstr dam_type = 'NotWeapon';",
                        "  \tstr param_type;",
                        "  ",
                        "  \tint shots_count = 0;",
                        "  \tint attacks_count = 0;",
                        "  \tint shot_type_check = 0;",
                        "  ",
                        "  \tif(type==t_Hull)",
                        "  \t{",
                        "  \t\ttype='Hull';",
                        "  ",
                        "          //Броня",
                        "          if(param == 1)",
                        "          {",
                        "              tstr=CT('Items.Hull.mAlloy');",
                        "              param=4 + GetParFromString(tstr, ',', GTL-1, 1);",
                        "  ",
                        "  \t\t\tparam_type = 'Hull armor';",
                        "          }",
                        "          else if(param == 2)",
                        "          {",
                        "              param=0;",
                        "  \t\t\tparam_type = 'Hull mass';",
                        "          }",
                        "  \t}",
                        "  \telse if(type>=t_Weapon1 && type<=t_CustomWeapon)",
                        "  \t{",
                        "  \t\tif(type <= t_Weapon9)custom_type='W0'+(0+type-(t_Weapon1-1));",
                        "  \t\telse if(type != t_CustomWeapon)custom_type='W'+(0+type-(t_Weapon1-1));",
                        "  ",
                        "  \t\tif(type != t_CustomWeapon)tint = GetCustomWeaponData(0+type, 'DamageType');",
                        "  \t\telse tint = GetCustomWeaponData(custom_type, 'DamageType');",
                        "  ",
                        "  \t\tif((tint & 1))dam_type='WEnergy';",
                        "  \t\telse if((tint & 2))dam_type='WSplinter';",
                        "  \t\telse if((tint & 3))dam_type='WMissile';",
                        "  ",
                        "          //Максимальный урон (на минимальный бонусы не применяются)",
                        "          if(param == 1)",
                        "          {",
                        "              if(type != t_CustomWeapon)",
                        "              {",
                        "                  tint = CT('Items.Weapon.Stats.'+(0+type-(t_Weapon1-1))+'.MaxDamage');",
                        "                  param = round((0.0 + GetParFromString(CT('Items.Weapon.Stats.'+(0+type-(t_Weapon1-1))+'.mWeaponDamage'), ',', GTL-1, 1)) * tint);",
                        "              }",
                        "              else",
                        "              {",
                        "                  tint = CT('Items.Weapon.Stats.'+custom_type+'.MaxDamage');",
                        "                  param = round((0.0 + GetParFromString(CT('Items.Weapon.Stats.'+custom_type+'.mWeaponDamage'), ',', GTL-1, 1)) * tint);",
                        "              }",
                        "              param = round(0.12 * param + 0.40 * tint + 3 + param);",
                        "  ",
                        "  \t\t\tparam_type = 'Max damage';",
                        "          }",
                        "          //Дальность",
                        "          else if(param == 2)",
                        "          {",
                        "              if(type != t_CustomWeapon)param = GetCustomWeaponData(0+type, 'AverageRadius');",
                        "              else param = GetCustomWeaponData(custom_type, 'AverageRadius');",
                        "              tint = param;",
                        "  ",
                        "              if(GTL == 1)param = round(0.90 * param);",
                        "              else if(GTL == 2)param = round(0.95 * param);",
                        "              else if(GTL == 3)param = round(0.95 * param);",
                        "              else if(GTL == 4)param = round(1.00 * param);",
                        "              else if(GTL == 5)param = round(1.00 * param);",
                        "              else if(GTL == 6)param = round(1.05 * param);",
                        "              else if(GTL == 7)param = round(1.05 * param);",
                        "              else if(GTL == 8)param = round(1.10 * param);",
                        "  ",
                        "              param = round(0.07 * param + 0.11 * tint + param);",
                        "  ",
                        "  \t\t\tparam_type = 'Weapon range';",
                        "          }",
                        "          //Максимальный урон, наносимый за один ход или DPD",
                        "          else if(param == 3)",
                        "          {",
                        "              //Вычисляем максимальный урон",
                        "              if(type != t_CustomWeapon)",
                        "              {",
                        "                  tint = CT('Items.Weapon.Stats.' + (0 + type - (t_Weapon1 - 1)) + '.MaxDamage');",
                        "                  param = round((0.0 + GetParFromString(CT('Items.Weapon.Stats.' + (0 + type - (t_Weapon1 - 1)) + '.mWeaponDamage'), ',', GTL - 1, 1)) * tint);",
                        "              }",
                        "              else",
                        "              {",
                        "                  tint = CT('Items.Weapon.Stats.' + custom_type + '.MaxDamage');",
                        "                  param = round((0.0 + GetParFromString(CT('Items.Weapon.Stats.' + custom_type + '.mWeaponDamage'), ',', GTL - 1, 1)) * tint);",
                        "              }",
                        "              param = round(0.12 * param + 0.40 * tint + 3 + param);",
                        "  ",
                        "              //Учитываем число залпов в выстреле",
                        "              if(type != t_CustomWeapon)shots_count = GetCustomWeaponData(0 + type, 'ShotCount');",
                        "              else shots_count = GetCustomWeaponData(custom_type, 'ShotCount');",
                        "  ",
                        "              //Учитываем число выстрелов в ходу",
                        "              if(type != t_CustomWeapon)attacks_count = GetCustomWeaponData(0 + type, 'AttackCount');",
                        "              else attacks_count = GetCustomWeaponData(custom_type, 'AttackCount');",
                        "  ",
                        "  \t\t\t//Проверяем тип выстрела",
                        "              if(type != t_CustomWeapon)tstr = TrimNumbers(GetCustomWeaponData(0 + type, 'ShotType'));",
                        "              else tstr = TrimNumbers(GetCustomWeaponData(custom_type, 'ShotType'));",
                        "  ",
                        "  \t\t\tif(tstr == 'Rocket' || tstr == 'Missile')shot_type_check = 1;",
                        "  ",
                        "  \t\t\tparam_type = 'Max damage per turn';",
                        "          }",
                        "  ",
                        "  \t\ttype = custom_type;",
                        "  \t}",
                        "  \telse if(type == t_Engine)",
                        "  \t{",
                        "  \t\ttype = 'Engine';",
                        "  ",
                        "          //Скорость",
                        "          if(param == 1)",
                        "          {",
                        "              tstr=CT('Items.Engine.mSpeed');",
                        "              param=round(0.07 * GetParFromString(tstr, ',', GTL-1, 1) + 80 + GetParFromString(tstr, ',', GTL-1, 1));",
                        "  ",
                        "  \t\t\tparam_type = 'Engine speed';",
                        "          }",
                        "          //Прыжок",
                        "          else if(param == 2)",
                        "          {",
                        "              tstr=CT('Items.Engine.mJump');",
                        "              param=12 + GetParFromString(tstr, ',', GTL-1, 1);",
                        "  ",
                        "  \t\t\tparam_type = 'Jump range';",
                        "          }",
                        "  \t}",
                        "  \telse if(type==t_FuelTanks)",
                        "  \t{",
                        "  \t\ttype='FuelTank';",
                        "  ",
                        "          //Ёмкость",
                        "          if(param == 1)",
                        "          {",
                        "              tstr=CT('Items.FuelTanks.mCapacity');",
                        "              param=round(0.20 * GetParFromString(tstr, ',', GTL-1, 1) + 5 + GetParFromString(tstr, ',', GTL-1, 1));",
                        "  ",
                        "  \t\t\tparam_type = 'Fuel capacity';",
                        "          }",
                        "  \t}",
                        "  \telse if(type==t_Radar)",
                        "  \t{",
                        "  \t\ttype='Radar';",
                        "  ",
                        "          //Дальность",
                        "          if(param == 1)",
                        "          {",
                        "              tstr=CT('Items.Radar.mRadius');",
                        "              param=round(0.10 * GetParFromString(tstr, ',', GTL-1, 1) + 500 + GetParFromString(tstr, ',', GTL-1, 1));",
                        "  ",
                        "  \t\t\tparam_type = 'Radar range';",
                        "          }",
                        "  \t}",
                        "  \telse if(type==t_Scaner)",
                        "  \t{",
                        "  \t\ttype='Scaner';",
                        "  ",
                        "          //Дальность",
                        "          if(param == 1)",
                        "          {",
                        "              tstr=CT('Items.DefGenerator.mDef');",
                        "              param=round(0.10 * (1 + GetParFromString(tstr, ',', GTL-1, 1)) + 7 + (1 + GetParFromString(tstr, ',', GTL-1, 1)));",
                        "  ",
                        "  \t\t\tparam_type = 'Scanner power';",
                        "          }",
                        "  \t}",
                        "  \telse if(type==t_RepairRobot)",
                        "  \t{",
                        "  \t\ttype='Droid';",
                        "  ",
                        "          //Эффективность",
                        "          if(param == 1)",
                        "          {",
                        "              tstr=CT('Items.RepairRobot.mRepair');",
                        "              param=round(0.12 * GetParFromString(tstr, ',', GTL-1, 1) + 10 + GetParFromString(tstr, ',', GTL-1, 1));",
                        "  ",
                        "  \t\t\tparam_type = 'Droid efficiency';",
                        "          }",
                        "  \t}",
                        "  \telse if(type==t_CargoHook)",
                        "  \t{",
                        "  \t\ttype='Hook';",
                        "  ",
                        "          //Размер объектов",
                        "          if(param == 1)",
                        "          {",
                        "              tstr=CT('Items.CargoHook.mMass');",
                        "              param=round(0.12 * GetParFromString(tstr, ',', GTL-1, 1) + 20 + GetParFromString(tstr, ',', GTL-1, 1));",
                        "  ",
                        "  \t\t\tparam_type = 'Hook max object size';",
                        "          }",
                        "          //Дальность",
                        "          else if(param == 2)",
                        "          {",
                        "              tstr=CT('Items.CargoHook.mRadius');",
                        "              param=25 + GetParFromString(tstr, ',', GTL-1, 1);",
                        "  ",
                        "  \t\t\tparam_type = 'Hook range';",
                        "          }",
                        "          //Макс. скорость (вблизи)",
                        "          else if(param == 3)",
                        "          {",
                        "              param=CT('Items.CargoHook.mSpeedClose');",
                        "  ",
                        "  \t\t\tparam_type = 'Hook close (max) speed';",
                        "          }",
                        "          //Мин. скорость (на удалении)",
                        "          else if(param == 4)",
                        "          {",
                        "              param=CT('Items.CargoHook.mSpeedFar');",
                        "  ",
                        "  \t\t\tparam_type = 'Hook far (min) speed';",
                        "          }",
                        "  \t}",
                        "  \telse if(type==t_DefGenerator)",
                        "  \t{",
                        "  \t\ttype='DefGenerator';",
                        "  ",
                        "          //Процент защиты",
                        "          if(param == 1)",
                        "          {",
                        "              tstr=CT('Items.DefGenerator.mDef');",
                        "              param=100.0 * GetParFromString(tstr, ',', GTL-1, 1) + 5;",
                        "  ",
                        "  \t\t\tparam_type = 'Defence percent';",
                        "          }",
                        "  \t}",
                        "  ",
                        "  \tresult='' + type + ',' + dam_type + ',' + param + ',' + param_type + ',' + shots_count + ',' + attacks_count + ',' + shot_type_check;",
                        "  }",
                        "  ",
                        "  //Функция для проверки максимального/минимального значения бонусов/штрафов (выводит собранную информацию в игровой лог)",
                        "  //Для применения, вставьте в исполняемую строку следующую команду (переносы строк убирать не обязательно):",
                        "  // str itemType = t_DefGenerator;",
                        "  // str customWeaponType = '';",
                        "  // int parameterType = 1;",
                        "  // int parameterMaxValue = 50;",
                        "  // int parameterMinValue = 0;",
                        "  // int bonusType = bonDef;",
                        "  // int galaxyTechLevel = 8;",
                        "  // int isInstallMMs = 4;",
                        "  // int isInstallUniqueMMs = 1;",
                        "  // int isInstallAcrynator = 1;",
                        "  // int isInstallArtefacts = 1;",
                        "  // int isAppliedStimulantsAndDiseases = 1;",
                        "  // str skipAcrynsList = '*ExpTC_Lifeboat*ExpAcryn_DomAcryn*';",
                        "  // CheckParamRangeSingle(itemType, customWeaponType, galaxyTechLevel, parameterType, bonusType, parameterMaxValue, parameterMinValue, isInstallMMs, isInstallUniqueMMs, isInstallAcrynator, isInstallArtefacts, isAppliedStimulantsAndDiseases, skipAcrynsList);",
                        "  function CheckParamRangeSingle(str type, str custom_type, GTL, param, bonus, param_max_value, param_min_value, InstallMM, InstallUniqueMM, InstallAcrynator, InstallArtefacts, InstallStimulants, skipAcrynsList)",
                        "  {",
                        "  \t//Определяем базовый параметр оборудки с учётом максимального улучшения на НБ для указанного ГТУ",
                        "  \ttype=SetBaseType(type, custom_type, GTL, param);",
                        "  ",
                        "  \tstr dam_type = GetParFromString(type, ',', 1, 1);",
                        "  \tparam = GetParFromString(type, ',', 2, 1);",
                        "  \tstr param_type = GetParFromString(type, ',', 3, 0);",
                        "  \tint shots_count = GetParFromString(type, ',', 4, 0);",
                        "  \tint attacks_count = GetParFromString(type, ',', 5, 0);",
                        "  \tint shot_type_check = GetParFromString(type, ',', 6, 0);",
                        "  \ttype = GetParFromString(type, ',', 0, 1);",
                        "  ",
                        "      SFT('###########################');",
                        "      SFT('###########################');",
                        "      SFT('###########################');",
                        "  \tSFT(' ');",
                        "  ",
                        "  \tint excess_count=0;",
                        "      int highest_value=0;",
                        "  \tif(!param_max_value) highest_value=1000000000;",
                        "      str highest_value_name='None';",
                        "  \tstr numInCfg;",
                        "  \tstr numInCfgMM;",
                        "  \tint acrynat_value = 0;",
                        "  \tint max_MM_value = 0;",
                        "  \tint end_value = 0;",
                        "  \tint check = 0;",
                        "  \tint acryn_race_set = 0;",
                        "  \tint MM_race_set = 0;",
                        "  ",
                        "  \tstr checkedMM = '*';",
                        "  ",
                        "  \tfor(i = 0; i < BonusCount(); i = i + 1)",
                        "  \t{",
                        "  \t\tend_value = 0;",
                        "  \t\tacrynat_value = 0;",
                        "  ",
                        "  \t\tnumInCfg=BonusNumInCfg(i);",
                        "  \t\t//Пропускаем Акринатор",
                        "  \t\tif(numInCfg == '498')continue;",
                        "  \t\t//Исключаем не акрины",
                        "  \t\tif(!BonusIsSpecial(i))continue;",
                        "  \t\t//Исключаем уникальные микромодули",
                        "  \t\tif(CT('MicroModuls.'+numInCfg+'.UniqueMM'))continue;",
                        "  ",
                        "  \t\tstr equipOn=CT('MicroModuls.'+numInCfg+'.Equipments');",
                        "  ",
                        "  \t\t//Исключаем бонусы, неподходящие для указанного ГТУ",
                        "  \t\tif(GTL < 8.0 * (0.01 * CT('MicroModuls.'+numInCfg+'.Priority')))continue;",
                        "  ",
                        "  \t\t//Пропускаем скипнутые акрины",
                        "  \t\tif(findsubstr(skipAcrynsList, '*' + numInCfg + '*') > -1)continue;",
                        "  ",
                        "  \t\tint uniqueMM_check = 0;",
                        "  ",
                        "  \t\t//Переходим к проверке значения указанного параметра бонуса",
                        "  \t\t//Если для проверки выбрано максимальное значение параметра",
                        "  \t\tif(param_max_value)",
                        "  \t\t{",
                        "  \t\t\t//Исключаем акрины, значение искомого бонуса в которых не положительно",
                        "  \t\t\tif(param_type != 'Max damage per turn')",
                        "  \t\t\t{",
                        "  \t\t\t\tif(BonusValue(i, bonus) <= 0)continue;",
                        "  \t\t\t}",
                        "  \t\t\telse",
                        "  \t\t\t{",
                        "  \t\t\t\tif(BonusValue(i, bonus) <= 0 && ((BonusValue(i, bonShots) <= 0 && shot_type_check) || !shot_type_check) && BonusValue(i, bonAttacks) <= 0)continue;",
                        "  \t\t\t}",
                        "  ",
                        "  \t\t\tif(CT('MicroModuls.'+numInCfg+'.BlockMM') != 1)",
                        "  \t\t\t{",
                        "  \t\t\t\t//Чистое значение данного акрина, без доп. бонусов",
                        "  \t\t\t\tcheck = 0;",
                        "  \t\t\t\tif(dam_type == 'NotWeapon')check = 1;",
                        "  \t\t\t\telse",
                        "  \t\t\t\t{",
                        "  \t\t\t\t\ttstr = CT('MicroModuls.'+numInCfg+'.Equipments');",
                        "  \t\t\t\t\tif(tstr == '')check = 1;",
                        "  \t\t\t\t\telse if(findsubstr(tstr, type) > -1 || findsubstr(tstr, dam_type) > -1 || tstr == 'Any')check = 1;",
                        "  \t\t\t\t}",
                        "  \t\t\t\tif(check)",
                        "  \t\t\t\t{",
                        "  \t\t\t\t\tif(param_type != 'Max damage per turn')",
                        "  \t\t\t\t\t{",
                        "  \t\t\t\t\t\tend_value = param + BonusValue(i, bonus);",
                        "  ",
                        "  \t\t\t\t\t\tif(end_value > param_max_value)",
                        "  \t\t\t\t\t\t{",
                        "  \t\t\t\t\t\t\tSFT(numInCfg);",
                        "  \t\t\t\t\t\t\tSFT('Higher on: ' + (end_value - param_max_value));",
                        "  \t\t\t\t\t\t\tSFT('---------------------');",
                        "  ",
                        "  \t\t\t\t\t\t\tif(end_value > highest_value)",
                        "  \t\t\t\t\t\t\t{",
                        "  \t\t\t\t\t\t\t\thighest_value=end_value;",
                        "  \t\t\t\t\t\t\t\thighest_value_name=numInCfg;",
                        "  \t\t\t\t\t\t\t}",
                        "  ",
                        "  \t\t\t\t\t\t\texcess_count=excess_count+1;",
                        "  \t\t\t\t\t\t}",
                        "  \t\t\t\t\t}",
                        "  \t\t\t\t\telse",
                        "  \t\t\t\t\t{",
                        "  \t\t\t\t\t\tend_value = param + BonusValue(i, bonus);",
                        "  \t\t\t\t\t\tif(shot_type_check) end_value = end_value * (shots_count + BonusValue(i, bonShots));",
                        "  \t\t\t\t\t\tend_value = end_value * (attacks_count + BonusValue(i, bonAttacks));",
                        "  ",
                        "  \t\t\t\t\t\tif(end_value > param_max_value)",
                        "  \t\t\t\t\t\t{",
                        "  \t\t\t\t\t\t\tSFT(numInCfg);",
                        "  \t\t\t\t\t\t\tSFT('Higher on: ' + (end_value - param_max_value));",
                        "  \t\t\t\t\t\t\tSFT('---------------------');",
                        "  ",
                        "  \t\t\t\t\t\t\tif(end_value > highest_value)",
                        "  \t\t\t\t\t\t\t{",
                        "  \t\t\t\t\t\t\t\thighest_value=end_value;",
                        "  \t\t\t\t\t\t\t\thighest_value_name=numInCfg;",
                        "  \t\t\t\t\t\t\t}",
                        "  ",
                        "  \t\t\t\t\t\t\texcess_count=excess_count+1;",
                        "  \t\t\t\t\t\t}",
                        "  \t\t\t\t\t}",
                        "  \t\t\t\t}",
                        "  ",
                        "  \t\t\t\t//\"Вставляем\" Акринатор",
                        "  \t\t\t\tif(InstallAcrynator && CT('MicroModuls.'+numInCfg+'.BlockMM') != 1)",
                        "  \t\t\t\t{",
                        "  \t\t\t\t\t//Если проверка не была запущена для корпуса или оружия",
                        "  \t\t\t\t\tif(type != 'Hull' && dam_type == 'NotWeapon')",
                        "  \t\t\t\t\t{",
                        "  \t\t\t\t\t\tif(findsubstr(equipOn, 'WEnergy') > -1)check = 1;",
                        "  \t\t\t\t\t\telse if(findsubstr(equipOn, 'WSplinter') > -1)check = 1;",
                        "  \t\t\t\t\t\telse if(findsubstr(equipOn, 'WMissile') > -1)check = 1;",
                        "  ",
                        "  \t\t\t\t\t\tif(!check)",
                        "  \t\t\t\t\t\t{",
                        "  \t\t\t\t\t\t\tfor(k=1; k<=18; k=k+1)",
                        "  \t\t\t\t\t\t\t{",
                        "  \t\t\t\t\t\t\t\tif(k <= 9)tstr='W0'+k;",
                        "  \t\t\t\t\t\t\t\telse tstr='W'+k;",
                        "  ",
                        "  \t\t\t\t\t\t\t\tif(findsubstr(equipOn, tstr) > -1)",
                        "  \t\t\t\t\t\t\t\t{",
                        "  \t\t\t\t\t\t\t\t\tcheck=1;",
                        "  \t\t\t\t\t\t\t\t\tbreak;",
                        "  \t\t\t\t\t\t\t\t}",
                        "  \t\t\t\t\t\t\t}",
                        "  \t\t\t\t\t\t\tif(!check)",
                        "  \t\t\t\t\t\t\t{",
                        "  \t\t\t\t\t\t\t\tfor(k=0; k<CustomWeaponTypes(); k=k+1)",
                        "  \t\t\t\t\t\t\t\t{",
                        "  \t\t\t\t\t\t\t\t\ttstr=CustomWeaponTypes(k);",
                        "  ",
                        "  \t\t\t\t\t\t\t\t\tif(findsubstr(equipOn, tstr) > -1)",
                        "  \t\t\t\t\t\t\t\t\t{",
                        "  \t\t\t\t\t\t\t\t\t\tcheck=1;",
                        "  \t\t\t\t\t\t\t\t\t\tbreak;",
                        "  \t\t\t\t\t\t\t\t\t}",
                        "  \t\t\t\t\t\t\t\t}",
                        "  \t\t\t\t\t\t\t}",
                        "  \t\t\t\t\t\t}",
                        "  \t\t\t\t\t\tif(findsubstr(equipOn, 'Hull') == -1 && !check)",
                        "  \t\t\t\t\t\t{",
                        "  \t\t\t\t\t\t\tacrynat_value = param + (3 * BonusValue(i, bonus));",
                        "  \t\t\t\t\t\t}",
                        "  ",
                        "  \t\t\t\t\t\t//Проверяем, не превышает ли бонус акрина лимитное значение с установленным Акринатором",
                        "  \t\t\t\t\t\tif(acrynat_value > param_max_value && (3 * BonusValue(i, bonus)))",
                        "  \t\t\t\t\t\t{",
                        "  \t\t\t\t\t\t\tSFT(numInCfg + ' + Acrynator');",
                        "  \t\t\t\t\t\t\tSFT('Higher on: ' + (acrynat_value - param_max_value));",
                        "  \t\t\t\t\t\t\tSFT('---------------------');",
                        "  ",
                        "  \t\t\t\t\t\t\tif(acrynat_value > highest_value)",
                        "  \t\t\t\t\t\t\t{",
                        "  \t\t\t\t\t\t\t\thighest_value = acrynat_value;",
                        "  \t\t\t\t\t\t\t\thighest_value_name = numInCfg + ' + Acrynator';",
                        "  \t\t\t\t\t\t\t}",
                        "  ",
                        "  \t\t\t\t\t\t\texcess_count=excess_count+1;",
                        "  \t\t\t\t\t\t}",
                        "  \t\t\t\t\t}",
                        "  \t\t\t\t}",
                        "  ",
                        "  \t\t\t\t//Перебор ММ",
                        "  \t\t\t\tif(InstallMM && CT('MicroModuls.'+numInCfg+'.BlockMM') != 1)",
                        "  \t\t\t\t{",
                        "  \t\t\t\t\tfor(k=0; k<BonusCount(); k=k+1)",
                        "  \t\t\t\t\t{",
                        "  \t\t\t\t\t\tmax_MM_value = 0;",
                        "  \t\t\t\t\t\tnumInCfgMM=BonusNumInCfg(k);",
                        "  ",
                        "  \t\t\t\t\t\t//Исключаем ММ, значение искомого бонуса в которых не положительно",
                        "  \t\t\t\t\t\tif(param_type != 'Max damage per turn')",
                        "  \t\t\t\t\t\t{",
                        "  \t\t\t\t\t\t\tif(BonusValue(k, bonus) <= 0)continue;",
                        "  \t\t\t\t\t\t}",
                        "  \t\t\t\t\t\telse",
                        "  \t\t\t\t\t\t{",
                        "  \t\t\t\t\t\t\tif(BonusValue(k, bonus) <= 0 && ((BonusValue(k, bonShots) <= 0 && shot_type_check) || !shot_type_check) && BonusValue(k, bonAttacks) <= 0)continue;",
                        "  \t\t\t\t\t\t}",
                        "  ",
                        "  \t\t\t\t\t\t//Исключаем акрины",
                        "  \t\t\t\t\t\tuniqueMM_check = CT('MicroModuls.'+numInCfgMM+'.UniqueMM');",
                        "  \t\t\t\t\t\tif(BonusIsSpecial(k))",
                        "  \t\t\t\t\t\t{",
                        "  \t\t\t\t\t\t\tif(uniqueMM_check)",
                        "  \t\t\t\t\t\t\t{",
                        "  \t\t\t\t\t\t\t\tif(!InstallUniqueMM)continue;",
                        "  \t\t\t\t\t\t\t}",
                        "  \t\t\t\t\t\t\telse continue;",
                        "  \t\t\t\t\t\t}",
                        "  ",
                        "  \t\t\t\t\t\t//Пропускаем уровни ММ, которые были отсечены фильтром",
                        "  \t\t\t\t\t\tif(!uniqueMM_check)",
                        "  \t\t\t\t\t\t{",
                        "  \t\t\t\t\t\t\t//Оставляем только ММ первого уровня",
                        "  \t\t\t\t\t\t\tif(InstallMM == 1)",
                        "  \t\t\t\t\t\t\t{",
                        "  \t\t\t\t\t\t\t\tif(BonusPriority(k) > 30)continue;",
                        "  \t\t\t\t\t\t\t}",
                        "  \t\t\t\t\t\t\t//Оставляем только ММ второго уровня",
                        "  \t\t\t\t\t\t\telse if(InstallMM == 2)",
                        "  \t\t\t\t\t\t\t{",
                        "  \t\t\t\t\t\t\t\tif(BonusPriority(k) < 31 || BonusPriority(k) > 69)continue;",
                        "  \t\t\t\t\t\t\t}",
                        "  \t\t\t\t\t\t\t//Оставляем только ММ третьего уровня",
                        "  \t\t\t\t\t\t\telse if(InstallMM == 3)",
                        "  \t\t\t\t\t\t\t{",
                        "  \t\t\t\t\t\t\t\tif(BonusPriority(k) < 70)continue;",
                        "  \t\t\t\t\t\t\t}",
                        "  \t\t\t\t\t\t}",
                        "  ",
                        "  \t\t\t\t\t\t//Проверяем на предмет совместимости с объектом поиска (оборудкой, имеющей подходящие параметры) сперва сам ММ",
                        "  \t\t\t\t\t\ttstr = CT('MicroModuls.'+numInCfgMM+'.Equipments');",
                        "  \t\t\t\t\t\tif(findsubstr(tstr, type) == -1 && findsubstr(tstr, dam_type) == -1 && tstr != 'Any' && tstr != '')continue;",
                        "  ",
                        "  \t\t\t\t\t\t//После чего проверяем, не превышает ли собственный бонус данного ММ лимитное значение даже без учёта акрина",
                        "  \t\t\t\t\t\tif(findsubstr(checkedMM, '*' + numInCfgMM + '*') == -1)",
                        "  \t\t\t\t\t\t{",
                        "  \t\t\t\t\t\t\tif(param_type != 'Max damage per turn')",
                        "  \t\t\t\t\t\t\t{",
                        "  \t\t\t\t\t\t\t\tmax_MM_value = param + BonusValue(k, bonus);",
                        "  \t\t\t\t\t\t\t}",
                        "  \t\t\t\t\t\t\telse",
                        "  \t\t\t\t\t\t\t{",
                        "  \t\t\t\t\t\t\t\tmax_MM_value = param + BonusValue(k, bonus);",
                        "  \t\t\t\t\t\t\t\tif(shot_type_check) max_MM_value = max_MM_value * (shots_count + BonusValue(k, bonShots));",
                        "  \t\t\t\t\t\t\t\tmax_MM_value = max_MM_value * (attacks_count + BonusValue(k, bonAttacks));",
                        "  \t\t\t\t\t\t\t}",
                        "  ",
                        "  \t\t\t\t\t\t\tif(max_MM_value > param_max_value)",
                        "  \t\t\t\t\t\t\t{",
                        "  \t\t\t\t\t\t\t\tSFT('None + ' + numInCfgMM);",
                        "  \t\t\t\t\t\t\t\tSFT('Higher on: ' + (max_MM_value - param_max_value));",
                        "  \t\t\t\t\t\t\t\tSFT('---------------------');",
                        "  ",
                        "  \t\t\t\t\t\t\t\tif(max_MM_value > highest_value)",
                        "  \t\t\t\t\t\t\t\t{",
                        "  \t\t\t\t\t\t\t\t\thighest_value = max_MM_value;",
                        "  \t\t\t\t\t\t\t\t\thighest_value_name = 'None + ' + numInCfgMM;",
                        "  \t\t\t\t\t\t\t\t}",
                        "  ",
                        "  \t\t\t\t\t\t\t\tcheckedMM = checkedMM + numInCfgMM + '*';",
                        "  \t\t\t\t\t\t\t\texcess_count=excess_count+1;",
                        "  \t\t\t\t\t\t\t}",
                        "  \t\t\t\t\t\t}",
                        "  ",
                        "  \t\t\t\t\t\t//А затем и акрин",
                        "  \t\t\t\t\t\ttstr = CT('MicroModuls.'+numInCfg+'.Equipments');",
                        "  \t\t\t\t\t\tif(findsubstr(tstr, type) == -1 && findsubstr(tstr, dam_type) == -1 && tstr != 'Any' && tstr != '')continue;",
                        "  ",
                        "  \t\t\t\t\t\t//Затем делаем общую проверку на соответствие типа акрина типу ММ",
                        "  \t\t\t\t\t\ttstr = CT('MicroModuls.'+numInCfgMM+'.Equipments');",
                        "  \t\t\t\t\t\tif(findsubstr(tstr, type) == -1 && findsubstr(tstr, dam_type) == -1 && tstr != 'Any' && tstr != '')continue;",
                        "  ",
                        "  \t\t\t\t\t\t//Далее переходим к проверке соответствия конкретных рас бонусов",
                        "  \t\t\t\t\t\t//Определяем сет рас для акрина",
                        "  \t\t\t\t\t\tacryn_race_set = RaceSetDefine(CT('MicroModuls.'+numInCfg+'.Owner'), 'Acryn');",
                        "  ",
                        "  \t\t\t\t\t\t//Определяем сет рас для ММ",
                        "  \t\t\t\t\t\tMM_race_set = RaceSetDefine(CT('MicroModuls.'+numInCfgMM+'.Owner'), 'MM');",
                        "  ",
                        "  \t\t\t\t\t\t//Сравниваем полученные сеты",
                        "  \t\t\t\t\t\tif(!(acryn_race_set & MM_race_set))continue;",
                        "  ",
                        "  \t\t\t\t\t\tif(param_type != 'Max damage per turn')",
                        "  \t\t\t\t\t\t{",
                        "  \t\t\t\t\t\t\tmax_MM_value = param + BonusValue(i, bonus) + BonusValue(k, bonus);",
                        "  \t\t\t\t\t\t}",
                        "  \t\t\t\t\t\telse",
                        "  \t\t\t\t\t\t{",
                        "  \t\t\t\t\t\t\tmax_MM_value = param + BonusValue(i, bonus) + BonusValue(k, bonus);",
                        "  \t\t\t\t\t\t\tif(shot_type_check) max_MM_value = max_MM_value * (shots_count + BonusValue(i, bonShots) + BonusValue(k, bonShots));",
                        "  \t\t\t\t\t\t\tmax_MM_value = max_MM_value * (attacks_count + BonusValue(i, bonAttacks) + BonusValue(k, bonAttacks));",
                        "  \t\t\t\t\t\t}",
                        "  ",
                        "  \t\t\t\t\t\tif(max_MM_value > param_max_value)",
                        "  \t\t\t\t\t\t{",
                        "  \t\t\t\t\t\t\tSFT(numInCfg + ' + ' + numInCfgMM);",
                        "  \t\t\t\t\t\t\tSFT('Higher on: ' + (max_MM_value - param_max_value));",
                        "  \t\t\t\t\t\t\tSFT('---------------------');",
                        "  ",
                        "  \t\t\t\t\t\t\tif(max_MM_value > highest_value)",
                        "  \t\t\t\t\t\t\t{",
                        "  \t\t\t\t\t\t\t\thighest_value = max_MM_value;",
                        "  \t\t\t\t\t\t\t\thighest_value_name = numInCfg + ' + ' + numInCfgMM;",
                        "  \t\t\t\t\t\t\t}",
                        "  ",
                        "  \t\t\t\t\t\t\texcess_count = excess_count + 1;",
                        "  \t\t\t\t\t\t}",
                        "  \t\t\t\t\t}",
                        "  \t\t\t\t}",
                        "  \t\t\t}",
                        "  \t\t}",
                        "  \t\t//Если для проверки выбрано минимальное значение параметра",
                        "  \t\telse",
                        "  \t\t{",
                        "  \t\t\t//Исключаем акрины, значение искомого бонуса в которых не отрицательно",
                        "  \t\t\tif(param_type != 'Max damage per turn')",
                        "  \t\t\t{",
                        "  \t\t\t\tif(BonusValue(i, bonus) >= 0)continue;",
                        "  \t\t\t}",
                        "  \t\t\telse",
                        "  \t\t\t{",
                        "  \t\t\t\tif(BonusValue(i, bonus) >= 0 && ((BonusValue(i, bonShots) >= 0 && shot_type_check) || !shot_type_check) && BonusValue(i, bonAttacks) >= 0)continue;",
                        "  \t\t\t}",
                        "  ",
                        "  \t\t\tif(CT('MicroModuls.' + numInCfg + '.BlockMM') != 1)",
                        "  \t\t\t{",
                        "  \t\t\t\t//Чистое значение данного акрина, без доп. бонусов",
                        "  \t\t\t\tcheck = 0;",
                        "  \t\t\t\tif(dam_type == 'NotWeapon') check = 1;",
                        "  \t\t\t\telse",
                        "  \t\t\t\t{",
                        "  \t\t\t\t\ttstr = CT('MicroModuls.' + numInCfg + '.Equipments');",
                        "  \t\t\t\t\tif(tstr == '') check = 1;",
                        "  \t\t\t\t\telse if(findsubstr(tstr, type) > -1 || findsubstr(tstr, dam_type) > -1 || tstr == 'Any')check = 1;",
                        "  \t\t\t\t}",
                        "  \t\t\t\tif(check)",
                        "  \t\t\t\t{",
                        "  \t\t\t\t\tif(param_type != 'Max damage per turn')",
                        "  \t\t\t\t\t{",
                        "  \t\t\t\t\t\tend_value = param + BonusValue(i, bonus);",
                        "  \t\t\t\t\t}",
                        "  \t\t\t\t\telse",
                        "  \t\t\t\t\t{",
                        "  \t\t\t\t\t\tend_value = param + BonusValue(i, bonus);",
                        "  \t\t\t\t\t\tif(shot_type_check)",
                        "  \t\t\t\t\t\t{",
                        "  \t\t\t\t\t\t\ttint = shots_count + BonusValue(i, bonShots);",
                        "  \t\t\t\t\t\t\tif(tint < 1) tint = 1;",
                        "  \t\t\t\t\t\t\tend_value = end_value * tint;",
                        "  \t\t\t\t\t\t}",
                        "  \t\t\t\t\t\ttint = shots_count + BonusValue(i, bonAttacks);",
                        "  \t\t\t\t\t\tif(tint < 1) tint = 1;",
                        "  \t\t\t\t\t\tend_value = end_value * tint;",
                        "  \t\t\t\t\t}",
                        "  ",
                        "  \t\t\t\t\tif(end_value < param_min_value)",
                        "  \t\t\t\t\t{",
                        "  \t\t\t\t\t\tSFT(numInCfg);",
                        "  \t\t\t\t\t\tSFT('Lower on: ' + abs(abs(param_min_value) - abs(end_value)));",
                        "  \t\t\t\t\t\tSFT('---------------------');",
                        "  ",
                        "  \t\t\t\t\t\tif(end_value < highest_value)",
                        "  \t\t\t\t\t\t{",
                        "  \t\t\t\t\t\t\thighest_value=end_value;",
                        "  \t\t\t\t\t\t\thighest_value_name=numInCfg;",
                        "  \t\t\t\t\t\t}",
                        "  ",
                        "  \t\t\t\t\t\texcess_count = excess_count + 1;",
                        "  \t\t\t\t\t}",
                        "  \t\t\t\t}",
                        "  ",
                        "  \t\t\t\t//Перебор ММ",
                        "  \t\t\t\tif(InstallMM && CT('MicroModuls.' + numInCfg + '.BlockMM') != 1)",
                        "  \t\t\t\t{",
                        "  \t\t\t\t\tfor(k = 0; k < BonusCount(); k = k + 1)",
                        "  \t\t\t\t\t{",
                        "  \t\t\t\t\t\tmax_MM_value = 0;",
                        "  \t\t\t\t\t\tnumInCfgMM = BonusNumInCfg(k);",
                        "  ",
                        "  \t\t\t\t\t\t//Исключаем ММ, значение искомого бонуса которых не отрицательно",
                        "  \t\t\t\t\t\tif(param_type != 'Max damage per turn')",
                        "  \t\t\t\t\t\t{",
                        "  \t\t\t\t\t\t\tif(BonusValue(k, bonus) >= 0)continue;",
                        "  \t\t\t\t\t\t}",
                        "  \t\t\t\t\t\telse",
                        "  \t\t\t\t\t\t{",
                        "  \t\t\t\t\t\t\tif(BonusValue(k, bonus) >= 0 && ((BonusValue(k, bonShots) >= 0 && shot_type_check) || !shot_type_check) && BonusValue(k, bonAttacks) >= 0)continue;",
                        "  \t\t\t\t\t\t}",
                        "  ",
                        "  \t\t\t\t\t\t//Исключаем акрины",
                        "  \t\t\t\t\t\tuniqueMM_check = CT('MicroModuls.'+numInCfgMM+'.UniqueMM');",
                        "  \t\t\t\t\t\tif(BonusIsSpecial(k))",
                        "  \t\t\t\t\t\t{",
                        "  \t\t\t\t\t\t\tif(uniqueMM_check)",
                        "  \t\t\t\t\t\t\t{",
                        "  \t\t\t\t\t\t\t\tif(!InstallUniqueMM)continue;",
                        "  \t\t\t\t\t\t\t}",
                        "  \t\t\t\t\t\t\telse continue;",
                        "  \t\t\t\t\t\t}",
                        "  ",
                        "  \t\t\t\t\t\t//Пропускаем уровни ММ, которые были отсечены фильтром",
                        "  \t\t\t\t\t\tif(!uniqueMM_check)",
                        "  \t\t\t\t\t\t{",
                        "  \t\t\t\t\t\t\t//Оставляем только ММ первого уровня",
                        "  \t\t\t\t\t\t\tif(InstallMM == 1)",
                        "  \t\t\t\t\t\t\t{",
                        "  \t\t\t\t\t\t\t\tif(BonusPriority(k) > 30)continue;",
                        "  \t\t\t\t\t\t\t}",
                        "  \t\t\t\t\t\t\t//Оставляем только ММ второго уровня",
                        "  \t\t\t\t\t\t\telse if(InstallMM == 2)",
                        "  \t\t\t\t\t\t\t{",
                        "  \t\t\t\t\t\t\t\tif(BonusPriority(k) < 31 || BonusPriority(k) > 69)continue;",
                        "  \t\t\t\t\t\t\t}",
                        "  \t\t\t\t\t\t\t//Оставляем только ММ третьего уровня",
                        "  \t\t\t\t\t\t\telse if(InstallMM == 3)",
                        "  \t\t\t\t\t\t\t{",
                        "  \t\t\t\t\t\t\t\tif(BonusPriority(k) < 70)continue;",
                        "  \t\t\t\t\t\t\t}",
                        "  \t\t\t\t\t\t}",
                        "  ",
                        "  \t\t\t\t\t\t//Проверяем на предмет совместимости с объектом поиска (оборудкой, имеющей подходящие параметры) сперва сам ММ",
                        "  \t\t\t\t\t\ttstr = CT('MicroModuls.' + numInCfgMM + '.Equipments');",
                        "  \t\t\t\t\t\tif(findsubstr(tstr, type) == -1 && findsubstr(tstr, dam_type) == -1 && tstr != 'Any' && tstr != '')continue;",
                        "  ",
                        "  \t\t\t\t\t\t//После чего проверяем, не превышает ли собственный бонус данного ММ лимитное значение даже без учёта акрина",
                        "  \t\t\t\t\t\tif(findsubstr(checkedMM, '*' + numInCfgMM + '*') == -1)",
                        "  \t\t\t\t\t\t{",
                        "  \t\t\t\t\t\t\tif(param_type != 'Max damage per turn')",
                        "  \t\t\t\t\t\t\t{",
                        "  \t\t\t\t\t\t\t\tmax_MM_value = param + BonusValue(k, bonus);",
                        "  \t\t\t\t\t\t\t}",
                        "  \t\t\t\t\t\t\telse",
                        "  \t\t\t\t\t\t\t{",
                        "  \t\t\t\t\t\t\t\tmax_MM_value = param + BonusValue(k, bonus);",
                        "  \t\t\t\t\t\t\t\tif(shot_type_check)",
                        "  \t\t\t\t\t\t\t\t{",
                        "  \t\t\t\t\t\t\t\t\ttint = shots_count + BonusValue(k, bonShots);",
                        "  \t\t\t\t\t\t\t\t\tif(tint < 1) tint = 1;",
                        "  \t\t\t\t\t\t\t\t\tmax_MM_value = max_MM_value * tint;",
                        "  \t\t\t\t\t\t\t\t}",
                        "  \t\t\t\t\t\t\t\ttint = shots_count + BonusValue(k, bonAttacks);",
                        "  \t\t\t\t\t\t\t\tif(tint < 1) tint = 1;",
                        "  \t\t\t\t\t\t\t\tmax_MM_value = max_MM_value * tint;",
                        "  \t\t\t\t\t\t\t}",
                        "  ",
                        "  \t\t\t\t\t\t\tif(max_MM_value < param_min_value)",
                        "  \t\t\t\t\t\t\t{",
                        "  \t\t\t\t\t\t\t\tSFT('None + ' + numInCfgMM);",
                        "  \t\t\t\t\t\t\t\tSFT('Lower on: ' + abs(abs(param_min_value) - abs(max_MM_value)));",
                        "  \t\t\t\t\t\t\t\tSFT('---------------------');",
                        "  ",
                        "  \t\t\t\t\t\t\t\tif(max_MM_value < highest_value)",
                        "  \t\t\t\t\t\t\t\t{",
                        "  \t\t\t\t\t\t\t\t\thighest_value = max_MM_value;",
                        "  \t\t\t\t\t\t\t\t\thighest_value_name = 'None + ' + numInCfgMM;",
                        "  \t\t\t\t\t\t\t\t}",
                        "  ",
                        "  \t\t\t\t\t\t\t\tcheckedMM = checkedMM + numInCfgMM + '*';",
                        "  \t\t\t\t\t\t\t\texcess_count=excess_count+1;",
                        "  \t\t\t\t\t\t\t}",
                        "  \t\t\t\t\t\t}",
                        "  ",
                        "  \t\t\t\t\t\t//А затем и акрин",
                        "  \t\t\t\t\t\ttstr = CT('MicroModuls.'+numInCfg+'.Equipments');",
                        "  \t\t\t\t\t\tif(findsubstr(tstr, type) == -1 && findsubstr(tstr, dam_type) == -1 && tstr != 'Any' && tstr != '')continue;",
                        "  ",
                        "  \t\t\t\t\t\t//Затем делаем общую проверку на соответствие типа акрина типу ММ",
                        "  \t\t\t\t\t\ttstr = CT('MicroModuls.'+numInCfgMM+'.Equipments');",
                        "  \t\t\t\t\t\tif(findsubstr(tstr, type) == -1 && findsubstr(tstr, dam_type) == -1 && tstr != 'Any' && tstr != '')continue;",
                        "  ",
                        "  \t\t\t\t\t\t//Далее переходим к проверке соответствия конкретных рас бонусов",
                        "  \t\t\t\t\t\t//Определяем сет рас для акрина",
                        "  \t\t\t\t\t\tacryn_race_set = RaceSetDefine(CT('MicroModuls.'+numInCfg+'.Owner'), 'Acryn');",
                        "  ",
                        "  \t\t\t\t\t\t//Определяем сет рас для ММ",
                        "  \t\t\t\t\t\tMM_race_set = RaceSetDefine(CT('MicroModuls.'+numInCfgMM+'.Owner'), 'MM');",
                        "  ",
                        "  \t\t\t\t\t\t//Сравниваем полученные сеты",
                        "  \t\t\t\t\t\tif(!(acryn_race_set & MM_race_set))continue;",
                        "  ",
                        "  ",
                        "  \t\t\t\t\t\tif(param_type != 'Max damage per turn')",
                        "  \t\t\t\t\t\t{",
                        "  \t\t\t\t\t\t\tmax_MM_value = param + BonusValue(i, bonus) + BonusValue(k, bonus);",
                        "  \t\t\t\t\t\t}",
                        "  \t\t\t\t\t\telse",
                        "  \t\t\t\t\t\t{",
                        "  \t\t\t\t\t\t\tmax_MM_value = param + BonusValue(i, bonus) + BonusValue(k, bonus);",
                        "  \t\t\t\t\t\t\tif(shot_type_check)",
                        "  \t\t\t\t\t\t\t{",
                        "  \t\t\t\t\t\t\t\ttint = shots_count + BonusValue(i, bonShots) + BonusValue(k, bonShots);",
                        "  \t\t\t\t\t\t\t\tif(tint < 1) tint = 1;",
                        "  \t\t\t\t\t\t\t\tmax_MM_value = max_MM_value * tint;",
                        "  \t\t\t\t\t\t\t}",
                        "  \t\t\t\t\t\t\ttint = shots_count + BonusValue(i, bonAttacks) + BonusValue(k, bonAttacks);",
                        "  \t\t\t\t\t\t\tif(tint < 1) tint = 1;",
                        "  \t\t\t\t\t\t\tmax_MM_value = max_MM_value * tint;",
                        "  \t\t\t\t\t\t}",
                        "  ",
                        "  \t\t\t\t\t\tif(max_MM_value < param_min_value)",
                        "  \t\t\t\t\t\t{",
                        "  \t\t\t\t\t\t\tSFT(numInCfg + ' + ' + numInCfgMM);",
                        "  \t\t\t\t\t\t\tSFT('Lower on: ' + abs(abs(param_min_value) - abs(max_MM_value)));",
                        "  \t\t\t\t\t\t\tSFT('---------------------');",
                        "  ",
                        "  \t\t\t\t\t\t\tif(max_MM_value < highest_value)",
                        "  \t\t\t\t\t\t\t{",
                        "  \t\t\t\t\t\t\t\thighest_value = max_MM_value;",
                        "  \t\t\t\t\t\t\t\thighest_value_name = numInCfg + ' + ' + numInCfgMM;",
                        "  \t\t\t\t\t\t\t}",
                        "  ",
                        "  \t\t\t\t\t\t\texcess_count=excess_count+1;",
                        "  \t\t\t\t\t\t}",
                        "  \t\t\t\t\t}",
                        "  \t\t\t\t}",
                        "  \t\t\t}",
                        "  \t\t}",
                        "  \t}",
                        "  ",
                        "  \tSFT(' ');",
                        "  \tSFT('Galaxy tech level: ' + GTL);",
                        "  \tSFT('Param type: ' + param_type);",
                        "  \tSFT('Base value: ' + param);",
                        "      if(param_max_value) SFT('The highest value: ' + highest_value_name + ' (' + highest_value + ')');",
                        "      else SFT('The lowest value: ' + highest_value_name + ' (' + highest_value + ')');",
                        "  \tSFT('Total excesses: ' + excess_count);",
                        "  ",
                        "  \tSFT(' ');",
                        "      SFT('###########################');",
                        "      SFT('###########################');",
                        "      SFT('###########################');",
                        "  }",
                        "  ",
                        "  //Функция для проверки максимального/минимального значения бонусов/штрафов в составе всех возможных наборов оборудки (выводит собранную информацию в игровой лог)",
                        "  //Для применения, вставьте в исполняемую строку следующую команду (переносы строк убирать не обязательно):",
                        "  // str itemType = t_DefGenerator;",
                        "  // str customWeaponType = '';",
                        "  // int parameterType = 1;",
                        "  // int bonusType = bonDef;",
                        "  // int galaxyTechLevel = 8;",
                        "  // int isInstallMMs = 2;",
                        "  // int isInstallUniqueMMs = 1;",
                        "  // int isInstallAcrynator = 1;",
                        "  // int isInstallArtefacts = 1;",
                        "  // int isAppliedStimulantsAndDiseases = 1;",
                        "  // str skipAcrynsList = '*ExpTC_Lifeboat*ExpAcryn_DomAcryn*ShuMiniBoss_DreadnoughtMaloc*ShuMiniBoss_DreadnoughtPeleng*ShuMiniBoss_DreadnoughtPeople*ShuMiniBoss_DreadnoughtFei*ShuMiniBoss_DreadnoughtGaal*ShuKlissan_Potentia*ShuKlissan_Bubble*ShuKlissan_Chasia*ShuKlissan_Velhmust*ShuKlissan_Nivelia*ShuKlissan_Askia*ShuKlissan_Fungusia*ShuKlissan_Plasmalemma*ShuKlissan_Regenerative*ShuKlissan_Combishell*ShuKlissan_Recapacit*';",
                        "  // CheckParamRangeInSet(itemType, customWeaponType, galaxyTechLevel, parameterType, bonusType, isInstallMMs, isInstallUniqueMMs, isInstallAcrynator, isInstallArtefacts, isAppliedStimulantsAndDiseases, skipAcrynsList);",
                        "  function CheckParamRangeInSet(str type, str custom_type, GTL, param, bonus, InstallMM, InstallUniqueMM, InstallAcrynator, InstallArtefacts, InstallStimulants, skipAcrynsList)",
                        "  {",
                        "  \t//Определяем базовый параметр оборудки с учётом максимального улучшения на НБ для указанного ГТУ",
                        "  \ttype=SetBaseType(type, custom_type, GTL, param);",
                        "  ",
                        "  \tstr dam_type = GetParFromString(type, ',', 1, 1);",
                        "  \tparam = GetParFromString(type, ',', 2, 1);",
                        "  \tstr param_type = GetParFromString(type, ',', 3, 0);",
                        "  \tint shots_count = GetParFromString(type, ',', 4, 0);",
                        "  \tint attacks_count = GetParFromString(type, ',', 5, 0);",
                        "  \tint shot_type_check = GetParFromString(type, ',', 6, 0);",
                        "  \ttype = GetParFromString(type, ',', 0, 1);",
                        "  ",
                        "  \tstr cur_search_type = type;",
                        "  ",
                        "  \tstr w_type;",
                        "  \t//Проверяем, ищем ли мы информацию по оружию",
                        "  \tif(type=='Hull')w_type = 'None';",
                        "  \telse if(type=='Engine')w_type = 'None';",
                        "  \telse if(type=='FuelTank')w_type = 'None';",
                        "  \telse if(type=='Radar')w_type = 'None';",
                        "  \telse if(type=='Scaner')w_type = 'None';",
                        "  \telse if(type=='Droid')w_type = 'None';",
                        "  \telse if(type=='Hook')w_type = 'None';",
                        "  \telse if(type=='DefGenerator')w_type = 'None';",
                        "  \telse w_type = type;",
                        "  ",
                        "      SFT('###########################');",
                        "      SFT('###########################');",
                        "      SFT('###########################');",
                        "  \tSFT(' ');",
                        "  ",
                        "      int highest_hull = 0;",
                        "      str highest_hull_name = 'None';",
                        "  \tint hull_best_MM = -1;",
                        "  ",
                        "      int highest_gun1 = 0;",
                        "      str highest_gun1_name = 'None';",
                        "  \tint gun1_best_MM = -1;",
                        "  ",
                        "      int highest_gun2 = 0;",
                        "      str highest_gun2_name = 'None';",
                        "  \tint gun2_best_MM = -1;",
                        "  ",
                        "  \tint highest_gun3 = 0;",
                        "      str highest_gun3_name = 'None';",
                        "  \tint gun3_best_MM = -1;",
                        "  ",
                        "      int highest_gun4 = 0;",
                        "      str highest_gun4_name = 'None';",
                        "  \tint gun4_best_MM = -1;",
                        "  ",
                        "      int highest_gun5 = 0;",
                        "      str highest_gun5_name = 'None';",
                        "  \tint gun5_best_MM = -1;",
                        "  ",
                        "      int highest_engine = 0;",
                        "      str highest_engine_name = 'None';",
                        "  \tint engine_best_MM = -1;",
                        "  ",
                        "      int highest_fuel = 0;",
                        "      str highest_fuel_name = 'None';",
                        "  \tint fuel_best_MM = -1;",
                        "  ",
                        "      int highest_radar = 0;",
                        "      str highest_radar_name = 'None';",
                        "  \tint radar_best_MM = -1;",
                        "  ",
                        "      int highest_scanner = 0;",
                        "      str highest_scanner_name = 'None';",
                        "  \tint scanner_best_MM = -1;",
                        "  ",
                        "      int highest_droid = 0;",
                        "      str highest_droid_name = 'None';",
                        "  \tint droid_best_MM = -1;",
                        "  ",
                        "      int highest_hook = 0;",
                        "      str highest_hook_name = 'None';",
                        "  \tint hook_best_MM = -1;",
                        "  ",
                        "      int highest_def = 0;",
                        "      str highest_def_name = 'None';",
                        "  \tint def_best_MM = -1;",
                        "  ",
                        "  \tint check;",
                        "  \tint excess_count=0;",
                        "      int highest_value;",
                        "      str highest_value_name;",
                        "      str temp_w_type = 'None';",
                        "      str end_w_type = 'None';",
                        "  \tint acryn_param = 0;",
                        "  \tint best_MM = -1;",
                        "  \tint best_MM_end = -1;",
                        "  \tint best_MM_value;",
                        "  \tstr numInCfgMM;",
                        "  \tstr uniqueMM_list = '*';",
                        "  \tint acryn_race_set = 0;",
                        "  \tint MM_race_set = 0;",
                        "  \tint trion_count = 0;",
                        "  \tstr numInCfg;",
                        "  \tint roll_counts;",
                        "  ",
                        "  \tfor(j=1; j<=9; j=j+1)",
                        "  \t{",
                        "  \t\troll_counts = 1;",
                        "  ",
                        "  \t\tif(j == 1)type='Hull';",
                        "  \t\telse if(j == 2)",
                        "  \t\t{",
                        "  \t\t\ttype='Weapon';",
                        "  \t\t\tif(w_type == 'None')roll_counts = 5;",
                        "  \t\t}",
                        "  \t\telse if(j == 3)type='Engine';",
                        "  \t\telse if(j == 4)type='FuelTank';",
                        "  \t\telse if(j == 5)type='Radar';",
                        "  \t\telse if(j == 6)type='Scaner';",
                        "  \t\telse if(j == 7)type='Droid';",
                        "  \t\telse if(j == 8)type='Hook';",
                        "  \t\telse if(j == 9)type='DefGenerator';",
                        "  ",
                        "  \t\twhile(roll_counts)",
                        "  \t\t{",
                        "  \t\t\thighest_value = 0;",
                        "  \t\t\thighest_value_name = 'None';",
                        "  \t\t\tbest_MM = -1;",
                        "  \t\t\tbest_MM_end = -1;",
                        "  \t\t\tbest_MM_value = 0;",
                        "  ",
                        "  \t\t\tfor(i=0; i<BonusCount(); i=i+1)",
                        "  \t\t\t{",
                        "  \t\t\t\tnumInCfg=BonusNumInCfg(i);",
                        "  \t\t\t\t//Пропускаем Акринатор",
                        "  \t\t\t\tif(numInCfg == '498')continue;",
                        "  \t\t\t\t//Пропускаем ММ",
                        "  \t\t\t\tif(!BonusIsSpecial(i))continue;",
                        "  \t\t\t\t//Исключаем уникальные микромодули",
                        "  \t\t\t\tif(CT('MicroModuls.'+numInCfg+'.UniqueMM'))continue;",
                        "  ",
                        "  \t\t\t\t//Пропускаем скипнутые акрины",
                        "  \t\t\t\tif(findsubstr(skipAcrynsList, '*' + numInCfg + '*') > -1)continue;",
                        "  ",
                        "  \t\t\t\t//Исключаем бонусы, неподходящие для указанного ГТУ",
                        "  \t\t\t\tif(GTL < 8.0*(0.01*CT('MicroModuls.'+numInCfg+'.Priority')))continue;",
                        "  ",
                        "  \t\t\t\t//Исключаем бонусы, неподходящие для текущего оборудования/оружия",
                        "  \t\t\t\tstr equipOn=CT('MicroModuls.'+numInCfg+'.Equipments');",
                        "  \t\t\t\tif(equipOn != 'Any' && equipOn != '')",
                        "  \t\t\t\t{",
                        "  \t\t\t\t\tif(type != 'Weapon')",
                        "  \t\t\t\t\t{",
                        "  \t\t\t\t\t\tif(findsubstr(equipOn, type) == -1)continue;",
                        "  \t\t\t\t\t}",
                        "  \t\t\t\t\t//Перебираем все возможные типы орудий",
                        "  \t\t\t\t\telse",
                        "  \t\t\t\t\t{",
                        "  \t\t\t\t\t\tcheck=0;",
                        "  ",
                        "  \t\t\t\t\t\t//Если проверяем случайный оружейный акрин в поисках бонуса для оборудки",
                        "  \t\t\t\t\t\tif(w_type == 'None')",
                        "  \t\t\t\t\t\t{",
                        "  \t\t\t\t\t\t\ttemp_w_type = 'None';",
                        "  ",
                        "  \t\t\t\t\t\t\tif(findsubstr(equipOn, 'WEnergy') > -1)",
                        "  \t\t\t\t\t\t\t{",
                        "  \t\t\t\t\t\t\t\tdam_type = 'WEnergy';",
                        "  \t\t\t\t\t\t\t\tcheck = 1;",
                        "  \t\t\t\t\t\t\t}",
                        "  \t\t\t\t\t\t\telse if(findsubstr(equipOn, 'WSplinter') > -1)",
                        "  \t\t\t\t\t\t\t{",
                        "  \t\t\t\t\t\t\t\tdam_type = 'WSplinter';",
                        "  \t\t\t\t\t\t\t\tcheck = 1;",
                        "  \t\t\t\t\t\t\t}",
                        "  \t\t\t\t\t\t\telse if(findsubstr(equipOn, 'WMissile') > -1)",
                        "  \t\t\t\t\t\t\t{",
                        "  \t\t\t\t\t\t\t\tdam_type = 'WMissile';",
                        "  \t\t\t\t\t\t\t\tcheck = 1;",
                        "  \t\t\t\t\t\t\t}",
                        "  ",
                        "  \t\t\t\t\t\t\tif(!check)",
                        "  \t\t\t\t\t\t\t{",
                        "  \t\t\t\t\t\t\t\tfor(k=1; k<=18; k=k+1)",
                        "  \t\t\t\t\t\t\t\t{",
                        "  \t\t\t\t\t\t\t\t\tif(k <= 9)temp_w_type='W0'+k;",
                        "  \t\t\t\t\t\t\t\t\telse temp_w_type='W'+k;",
                        "  ",
                        "  \t\t\t\t\t\t\t\t\tif(findsubstr(equipOn, temp_w_type) > -1)",
                        "  \t\t\t\t\t\t\t\t\t{",
                        "  \t\t\t\t\t\t\t\t\t\tcheck=1;",
                        "  \t\t\t\t\t\t\t\t\t\tbreak;",
                        "  \t\t\t\t\t\t\t\t\t}",
                        "  \t\t\t\t\t\t\t\t}",
                        "  \t\t\t\t\t\t\t\tif(!check)",
                        "  \t\t\t\t\t\t\t\t{",
                        "  \t\t\t\t\t\t\t\t\tfor(k=0; k<CustomWeaponTypes(); k=k+1)",
                        "  \t\t\t\t\t\t\t\t\t{",
                        "  \t\t\t\t\t\t\t\t\t\ttemp_w_type=CustomWeaponTypes(k);",
                        "  ",
                        "  \t\t\t\t\t\t\t\t\t\tif(findsubstr(equipOn, temp_w_type) > -1)",
                        "  \t\t\t\t\t\t\t\t\t\t{",
                        "  \t\t\t\t\t\t\t\t\t\t\tcheck=1;",
                        "  \t\t\t\t\t\t\t\t\t\t\tbreak;",
                        "  \t\t\t\t\t\t\t\t\t\t}",
                        "  \t\t\t\t\t\t\t\t\t}",
                        "  \t\t\t\t\t\t\t\t}",
                        "  \t\t\t\t\t\t\t}",
                        "  \t\t\t\t\t\t}",
                        "  \t\t\t\t\t\t//Если проверяем акрин конкретного оружия в поисках бонуса для оружия",
                        "  \t\t\t\t\t\telse",
                        "  \t\t\t\t\t\t{",
                        "  \t\t\t\t\t\t\tif(findsubstr(equipOn, w_type) > -1)check=1;",
                        "  \t\t\t\t\t\t\telse if(findsubstr(equipOn, dam_type) > -1)check=1;",
                        "  \t\t\t\t\t\t}",
                        "  ",
                        "  \t\t\t\t\t\tif(!check)continue;",
                        "  \t\t\t\t\t}",
                        "  \t\t\t\t}",
                        "  ",
                        "  \t\t\t\t//Если в сете применено уже как минимум три трионки, пропускаем все остальные",
                        "  \t\t\t\tif(trion_count >= 3)",
                        "  \t\t\t\t{",
                        "  \t\t\t\t\tif(!findsubstr(numInCfg, 'ExpAcryn_'))continue;",
                        "  \t\t\t\t}",
                        "  ",
                        "  \t\t\t\t//Перебор ММ",
                        "  \t\t\t\tif(InstallMM && CT('MicroModuls.'+numInCfg+'.BlockMM') != 1)",
                        "  \t\t\t\t{",
                        "  \t\t\t\t\tint uniqueMM_check = 0;",
                        "  \t\t\t\t\tint uniqueMM_end_check = 0;",
                        "  \t\t\t\t\tfor(k=0; k<BonusCount(); k=k+1)",
                        "  \t\t\t\t\t{",
                        "  \t\t\t\t\t\tnumInCfgMM = BonusNumInCfg(k);",
                        "  ",
                        "  \t\t\t\t\t\t//Исключаем акрины и уникальные ММ (если стоит маркер)",
                        "  \t\t\t\t\t\tuniqueMM_check = 0;",
                        "  \t\t\t\t\t\tuniqueMM_check = CT('MicroModuls.'+numInCfgMM+'.UniqueMM');",
                        "  \t\t\t\t\t\t//А если маркер на исключение уникальных ММ не стоит, то запоминаем, является ли данный ММ уникальным",
                        "  \t\t\t\t\t\tif(InstallUniqueMM)",
                        "  \t\t\t\t\t\t{",
                        "  \t\t\t\t\t\t\tif(BonusIsSpecial(k))continue;",
                        "  \t\t\t\t\t\t\t//Пропускаем уникальные ММ, которые уже были использованы в данном сете",
                        "  \t\t\t\t\t\t\telse if(uniqueMM_check == 1)",
                        "  \t\t\t\t\t\t\t{",
                        "  \t\t\t\t\t\t\t\tif(findsubstr(uniqueMM_list, '*' + numInCfgMM + '*') > -1)continue;",
                        "  \t\t\t\t\t\t\t}",
                        "  \t\t\t\t\t\t}",
                        "  \t\t\t\t\t\telse",
                        "  \t\t\t\t\t\t{",
                        "  \t\t\t\t\t\t\tif(BonusIsSpecial(k))",
                        "  \t\t\t\t\t\t\t{",
                        "  \t\t\t\t\t\t\t\tif(uniqueMM_check)continue;",
                        "  \t\t\t\t\t\t\t}",
                        "  \t\t\t\t\t\t}",
                        "  ",
                        "  \t\t\t\t\t\t//Пропускаем уровни ММ, которые были отсечены фильтром",
                        "  \t\t\t\t\t\tif(!uniqueMM_check)",
                        "  \t\t\t\t\t\t{",
                        "  \t\t\t\t\t\t\t//Оставляем только ММ первого уровня",
                        "  \t\t\t\t\t\t\tif(InstallMM == 1)",
                        "  \t\t\t\t\t\t\t{",
                        "  \t\t\t\t\t\t\t\tif(BonusPriority(k) > 30)continue;",
                        "  \t\t\t\t\t\t\t}",
                        "  \t\t\t\t\t\t\t//Оставляем только ММ второго уровня",
                        "  \t\t\t\t\t\t\telse if(InstallMM == 2)",
                        "  \t\t\t\t\t\t\t{",
                        "  \t\t\t\t\t\t\t\tif(BonusPriority(k) < 31 || BonusPriority(k) > 69)continue;",
                        "  \t\t\t\t\t\t\t}",
                        "  \t\t\t\t\t\t\t//Оставляем только ММ третьего уровня",
                        "  \t\t\t\t\t\t\telse if(InstallMM == 3)",
                        "  \t\t\t\t\t\t\t{",
                        "  \t\t\t\t\t\t\t\tif(BonusPriority(k) < 70)continue;",
                        "  \t\t\t\t\t\t\t}",
                        "  \t\t\t\t\t\t}",
                        "  ",
                        "  \t\t\t\t\t\t//Проверяем возможность установки ММ на данный акрин оборудки",
                        "  \t\t\t\t\t\tif(type != 'Weapon')",
                        "  \t\t\t\t\t\t{",
                        "  \t\t\t\t\t\t\ttstr = CT('MicroModuls.'+numInCfgMM+'.Equipments');",
                        "  ",
                        "  \t\t\t\t\t\t\t//Сперва делаем общую проверку на соответствие типа акрина типу ММ",
                        "  \t\t\t\t\t\t\tif(findsubstr(tstr, type) == -1 && tstr != 'Any' && tstr != '')continue;",
                        "  \t\t\t\t\t\t\t//Далее переходим к проверке соответствия конкретных рас бонусов",
                        "  \t\t\t\t\t\t\telse",
                        "  \t\t\t\t\t\t\t{",
                        "  \t\t\t\t\t\t\t\t//Определяем сет рас для акрина",
                        "  \t\t\t\t\t\t\t\tacryn_race_set = RaceSetDefine(CT('MicroModuls.'+numInCfg+'.Owner'), 'Acryn');",
                        "  ",
                        "  \t\t\t\t\t\t\t\t//Определяем сет рас для ММ",
                        "  \t\t\t\t\t\t\t\tMM_race_set = RaceSetDefine(CT('MicroModuls.'+numInCfgMM+'.Owner'), 'MM');",
                        "  ",
                        "  \t\t\t\t\t\t\t\t//Сравниваем полученные сеты",
                        "  \t\t\t\t\t\t\t\tif(!(acryn_race_set & MM_race_set))continue;",
                        "  \t\t\t\t\t\t\t}",
                        "  \t\t\t\t\t\t}",
                        "  \t\t\t\t\t\t//Проверяем возможность установки ММ на данный акрин оружия",
                        "  \t\t\t\t\t\telse",
                        "  \t\t\t\t\t\t{",
                        "  \t\t\t\t\t\t\ttstr = CT('MicroModuls.'+numInCfgMM+'.Equipments');",
                        "  \t\t\t\t\t\t\t//Сперва делаем общую проверку на соответствие типа акрина типу ММ",
                        "  \t\t\t\t\t\t\tcheck = 0;",
                        "  \t\t\t\t\t\t\tif(findsubstr(tstr, temp_w_type) == -1 && findsubstr(tstr, 'dam_type') == -1 && tstr != 'Any' && tstr != '')",
                        "  \t\t\t\t\t\t\t{",
                        "  \t\t\t\t\t\t\t\t//Если конкретное оружие мы не ищем, то подойдёт ММ на любую пушку",
                        "  \t\t\t\t\t\t\t\tif(temp_w_type != 'None')continue;",
                        "  \t\t\t\t\t\t\t\telse if(findsubstr(tstr, 'WEnergy') == -1 && findsubstr(tstr, 'WSplinter') == -1 && findsubstr(tstr, 'WMissile') == -1)continue;",
                        "  \t\t\t\t\t\t\t\telse check = 1;",
                        "  \t\t\t\t\t\t\t}",
                        "  \t\t\t\t\t\t\t//Далее переходим к проверке соответствия конкретных рас бонусов",
                        "  \t\t\t\t\t\t\tif(check)",
                        "  \t\t\t\t\t\t\t{",
                        "  \t\t\t\t\t\t\t\t//Определяем сет рас для акрина",
                        "  \t\t\t\t\t\t\t\tacryn_race_set = RaceSetDefine(CT('MicroModuls.'+numInCfg+'.Owner'), 'Acryn');",
                        "  ",
                        "  \t\t\t\t\t\t\t\t//Определяем сет рас для ММ",
                        "  \t\t\t\t\t\t\t\tMM_race_set = RaceSetDefine(CT('MicroModuls.'+numInCfgMM+'.Owner'), 'MM');",
                        "  ",
                        "  \t\t\t\t\t\t\t\t//Сравниваем полученные сеты",
                        "  \t\t\t\t\t\t\t\tif(!(acryn_race_set & MM_race_set))continue;",
                        "  \t\t\t\t\t\t\t}",
                        "  \t\t\t\t\t\t}",
                        "  ",
                        "  \t\t\t\t\t\ttint = BonusValue(k, bonus);",
                        "  \t\t\t\t\t\tif(tint > best_MM_value)",
                        "  \t\t\t\t\t\t{",
                        "  \t\t\t\t\t\t\tbest_MM_value = tint;",
                        "  \t\t\t\t\t\t\tbest_MM = k;",
                        "  ",
                        "  \t\t\t\t\t\t\tif(uniqueMM_check == 1)uniqueMM_end_check = 1;",
                        "  \t\t\t\t\t\t\telse uniqueMM_end_check = 0;",
                        "  \t\t\t\t\t\t}",
                        "  \t\t\t\t\t}",
                        "  ",
                        "  \t\t\t\t\t//Делаем пометку, что уникальный микромодуль уже был применён в данном сете оборудки",
                        "  \t\t\t\t\tif(uniqueMM_end_check)uniqueMM_list = uniqueMM_list + numInCfgMM + '*';",
                        "  \t\t\t\t}",
                        "  ",
                        "  \t\t\t\ttint = BonusValue(i, bonus);",
                        "  \t\t\t\tif(!InstallAcrynator || type == 'Hull' || type == 'Weapon' || CT('MicroModuls.'+numInCfg+'.BlockMM') == 1)",
                        "  \t\t\t\t{",
                        "  \t\t\t\t\tif((tint + best_MM_value) > highest_value)",
                        "  \t\t\t\t\t{",
                        "  \t\t\t\t\t\tif(tint > 0)",
                        "  \t\t\t\t\t\t{",
                        "  \t\t\t\t\t\t\thighest_value = tint;",
                        "  \t\t\t\t\t\t\thighest_value_name = numInCfg;",
                        "  \t\t\t\t\t\t\tif(type == 'Weapon')",
                        "  \t\t\t\t\t\t\t{",
                        "  \t\t\t\t\t\t\t\tif(temp_w_type != 'None')end_w_type = temp_w_type;",
                        "  \t\t\t\t\t\t\t\telse end_w_type = w_type;",
                        "  \t\t\t\t\t\t\t}",
                        "  \t\t\t\t\t\t}",
                        "  \t\t\t\t\t\tbest_MM_end = best_MM;",
                        "  \t\t\t\t\t}",
                        "  \t\t\t\t}",
                        "  \t\t\t\t//Вставляем Акринатор, если был выставлен соответствующий маркер",
                        "  \t\t\t\telse",
                        "  \t\t\t\t{",
                        "  \t\t\t\t\tif((3 * tint) > highest_value)",
                        "  \t\t\t\t\t{",
                        "  \t\t\t\t\t\t//Даже если акрин с ММ окажется лучше акрина с акринатором, запоминаем значение бонуса с акринатором на случай подстановки акринатора в другой акрин",
                        "  \t\t\t\t\t\tif((3 * tint) > (tint + best_MM_value) || type != cur_search_type)",
                        "  \t\t\t\t\t\t{",
                        "  \t\t\t\t\t\t\tif(tint)",
                        "  \t\t\t\t\t\t\t{",
                        "  \t\t\t\t\t\t\t\thighest_value = (3 * tint);",
                        "  \t\t\t\t\t\t\t\thighest_value_name = numInCfg + ' + Acrynator';",
                        "  \t\t\t\t\t\t\t}",
                        "  \t\t\t\t\t\t\tbest_MM_end = best_MM;",
                        "  \t\t\t\t\t\t}",
                        "  \t\t\t\t\t\telse",
                        "  \t\t\t\t\t\t{",
                        "  \t\t\t\t\t\t\tif(tint)",
                        "  \t\t\t\t\t\t\t{",
                        "  \t\t\t\t\t\t\t\thighest_value = tint;",
                        "  \t\t\t\t\t\t\t\thighest_value_name = numInCfg;",
                        "  \t\t\t\t\t\t\t}",
                        "  \t\t\t\t\t\t\tbest_MM_end = best_MM;",
                        "  \t\t\t\t\t\t}",
                        "  \t\t\t\t\t}",
                        "  \t\t\t\t}",
                        "  ",
                        "  \t\t\t\tbest_MM_value = 0;",
                        "  \t\t\t}",
                        "  ",
                        "  \t\t\t//Считаем трионку, попавшую в сет",
                        "  \t\t\tif(!findsubstr(highest_value_name, 'ExpAcryn_'))",
                        "  \t\t\t{",
                        "  \t\t\t\ttrion_count = trion_count + 1;",
                        "  \t\t\t}",
                        "  ",
                        "  \t\t\tif(j == 1)",
                        "  \t\t\t{",
                        "  \t\t\t\thighest_hull=highest_value;",
                        "  \t\t\t\thighest_hull_name=highest_value_name;",
                        "  \t\t\t\thull_best_MM = best_MM_end;",
                        "  \t\t\t}",
                        "  \t\t\telse if(j == 2)",
                        "  \t\t\t{",
                        "  \t\t\t\tif(roll_counts == 5)",
                        "  \t\t\t\t{",
                        "  \t\t\t\t\thighest_gun5=highest_value;",
                        "  \t\t\t\t\thighest_gun5_name=highest_value_name;",
                        "  \t\t\t\t\tgun5_best_MM = best_MM_end;",
                        "  \t\t\t\t}",
                        "  \t\t\t\telse if(roll_counts == 4)",
                        "  \t\t\t\t{",
                        "  \t\t\t\t\thighest_gun4=highest_value;",
                        "  \t\t\t\t\thighest_gun4_name=highest_value_name;",
                        "  \t\t\t\t\tgun4_best_MM = best_MM_end;",
                        "  \t\t\t\t}",
                        "  \t\t\t\telse if(roll_counts == 3)",
                        "  \t\t\t\t{",
                        "  \t\t\t\t\thighest_gun3=highest_value;",
                        "  \t\t\t\t\thighest_gun3_name=highest_value_name;",
                        "  \t\t\t\t\tgun3_best_MM = best_MM_end;",
                        "  \t\t\t\t}",
                        "  \t\t\t\telse if(roll_counts == 2)",
                        "  \t\t\t\t{",
                        "  \t\t\t\t\thighest_gun2=highest_value;",
                        "  \t\t\t\t\thighest_gun2_name=highest_value_name;",
                        "  \t\t\t\t\tgun2_best_MM = best_MM_end;",
                        "  \t\t\t\t}",
                        "  \t\t\t\telse if(roll_counts == 1)",
                        "  \t\t\t\t{",
                        "  \t\t\t\t\thighest_gun1=highest_value;",
                        "  \t\t\t\t\thighest_gun1_name=highest_value_name;",
                        "  \t\t\t\t\tgun1_best_MM = best_MM_end;",
                        "  \t\t\t\t}",
                        "  \t\t\t}",
                        "  \t\t\telse if(j == 3)",
                        "  \t\t\t{",
                        "  \t\t\t\thighest_engine=highest_value;",
                        "  \t\t\t\thighest_engine_name=highest_value_name;",
                        "  \t\t\t\tengine_best_MM = best_MM_end;",
                        "  \t\t\t}",
                        "  \t\t\telse if(j == 4)",
                        "  \t\t\t{",
                        "  \t\t\t\thighest_fuel=highest_value;",
                        "  \t\t\t\thighest_fuel_name=highest_value_name;",
                        "  \t\t\t\tfuel_best_MM = best_MM_end;",
                        "  \t\t\t}",
                        "  \t\t\telse if(j == 5)",
                        "  \t\t\t{",
                        "  \t\t\t\thighest_radar=highest_value;",
                        "  \t\t\t\thighest_radar_name=highest_value_name;",
                        "  \t\t\t\tradar_best_MM = best_MM_end;",
                        "  \t\t\t}",
                        "  \t\t\telse if(j == 6)",
                        "  \t\t\t{",
                        "  \t\t\t\thighest_scanner=highest_value;",
                        "  \t\t\t\thighest_scanner_name=highest_value_name;",
                        "  \t\t\t\tscanner_best_MM = best_MM_end;",
                        "  \t\t\t}",
                        "  \t\t\telse if(j == 7)",
                        "  \t\t\t{",
                        "  \t\t\t\thighest_droid=highest_value;",
                        "  \t\t\t\thighest_droid_name=highest_value_name;",
                        "  \t\t\t\tdroid_best_MM = best_MM_end;",
                        "  \t\t\t}",
                        "  \t\t\telse if(j == 8)",
                        "  \t\t\t{",
                        "  \t\t\t\thighest_hook=highest_value;",
                        "  \t\t\t\thighest_hook_name=highest_value_name;",
                        "  \t\t\t\thook_best_MM = best_MM_end;",
                        "  \t\t\t}",
                        "  \t\t\telse if(j == 9)",
                        "  \t\t\t{",
                        "  \t\t\t\thighest_def=highest_value;",
                        "  \t\t\t\thighest_def_name=highest_value_name;",
                        "  \t\t\t\tdef_best_MM = best_MM_end;",
                        "  \t\t\t}",
                        "  ",
                        "  \t\t\troll_counts = roll_counts - 1;",
                        "  \t\t}",
                        "  \t}",
                        "  ",
                        "  \t//Определяем, какой акрин получает наибольший плюс от установки Акринатора",
                        "  \tint acr_check = 0;",
                        "  ",
                        "  \tint t_highest_engine = 0;",
                        "  \tint t_highest_fuel = 0;",
                        "  \tint t_highest_radar = 0;",
                        "  \tint t_highest_scanner = 0;",
                        "  \tint t_highest_droid = 0;",
                        "  \tint t_highest_hook = 0;",
                        "  \tint t_highest_def = 0;",
                        "  ",
                        "  \tif(findsubstr(highest_engine_name, ' + Acrynator') > -1)t_highest_engine = highest_engine;",
                        "  \tif(findsubstr(highest_fuel_name, ' + Acrynator') > -1)t_highest_fuel = highest_fuel;",
                        "  \tif(findsubstr(highest_radar_name, ' + Acrynator') > -1)t_highest_radar = highest_radar;",
                        "  \tif(findsubstr(highest_scanner_name, ' + Acrynator') > -1)t_highest_scanner = highest_scanner;",
                        "  \tif(findsubstr(highest_droid_name, ' + Acrynator') > -1)t_highest_droid = highest_droid;",
                        "  \tif(findsubstr(highest_hook_name, ' + Acrynator') > -1)t_highest_hook = highest_hook;",
                        "  \tif(findsubstr(highest_def_name, ' + Acrynator') > -1)t_highest_def = highest_def;",
                        "  ",
                        "  \thighest_value = max(t_highest_engine, t_highest_fuel, t_highest_radar, t_highest_scanner, t_highest_droid, t_highest_hook, t_highest_def);",
                        "  \tif(!highest_value)highest_value = -1;",
                        "  ",
                        "  \tSFT('Galaxy tech level: ' + GTL);",
                        "  \tSFT('Parameter type: ' + param_type);",
                        "  \tSFT('Base parameter value: ' + param);",
                        "  \tSFT(' ');",
                        "  ",
                        "  \t//Корпус",
                        "  \tif(hull_best_MM > -1 && cur_search_type == 'Hull')",
                        "  \t{",
                        "  \t\tSFT('Hull: '+highest_hull_name+' + '+BonusNumInCfg(hull_best_MM)+' ('+(highest_hull + BonusValue(hull_best_MM, bonus))+')');",
                        "  \t\tparam = param + BonusValue(hull_best_MM, bonus);",
                        "  \t}",
                        "  \telse SFT('Hull: '+highest_hull_name+' ('+highest_hull+')');",
                        "  \tparam = param + highest_hull;",
                        "  \t//Пушки",
                        "  \tif(w_type == 'None')",
                        "  \t{",
                        "  \t\t// if(gun1_best_MM > -1)",
                        "  \t\t// {",
                        "  \t\t\t// SFT('Weapon 1: '+highest_gun1_name+' + '+BonusNumInCfg(gun1_best_MM)+' ('+(highest_gun1 + BonusValue(gun1_best_MM, bonus))+')');",
                        "  \t\t\t// param = param + BonusValue(gun1_best_MM, bonus);",
                        "  \t\t// }",
                        "  \t\t// else",
                        "  \t\tSFT('Weapon 1: '+highest_gun1_name+' ('+highest_gun1+')');",
                        "  \t\tparam = param + highest_gun1;",
                        "  ",
                        "  \t\t// if(gun2_best_MM > -1)",
                        "  \t\t// {",
                        "  \t\t\t// SFT('Weapon 2: '+highest_gun2_name+' + '+BonusNumInCfg(gun2_best_MM)+' ('+(highest_gun2 + BonusValue(gun2_best_MM, bonus))+')');",
                        "  \t\t\t// param = param + BonusValue(gun2_best_MM, bonus);",
                        "  \t\t// }",
                        "  \t\t// else",
                        "  \t\tSFT('Weapon 2: '+highest_gun2_name+' ('+highest_gun2+')');",
                        "  \t\tparam = param + highest_gun2;",
                        "  ",
                        "  \t\t// if(gun3_best_MM > -1)",
                        "  \t\t// {",
                        "  \t\t\t// SFT('Weapon 3: '+highest_gun3_name+' + '+BonusNumInCfg(gun3_best_MM)+' ('+(highest_gun3 + BonusValue(gun3_best_MM, bonus))+')');",
                        "  \t\t\t// param = param + BonusValue(gun3_best_MM, bonus);",
                        "  \t\t// }",
                        "  \t\t// else",
                        "  \t\tSFT('Weapon 3: '+highest_gun3_name+' ('+highest_gun3+')');",
                        "  \t\tparam = param + highest_gun3;",
                        "  ",
                        "  \t\t// if(gun4_best_MM > -1)",
                        "  \t\t// {",
                        "  \t\t\t// SFT('Weapon 4: '+highest_gun4_name+' + '+BonusNumInCfg(gun4_best_MM)+' ('+(highest_gun4 + BonusValue(gun4_best_MM, bonus))+')');",
                        "  \t\t\t// param = param + BonusValue(gun4_best_MM, bonus);",
                        "  \t\t// }",
                        "  \t\t// else",
                        "  \t\tSFT('Weapon 4: '+highest_gun4_name+' ('+highest_gun4+')');",
                        "  \t\tparam = param + highest_gun4;",
                        "  ",
                        "  \t\t// if(gun5_best_MM > -1)",
                        "  \t\t// {",
                        "  \t\t\t// SFT('Weapon 5: '+highest_gun5_name+' + '+BonusNumInCfg(gun5_best_MM)+' ('+(highest_gun5 + BonusValue(gun5_best_MM, bonus))+')');",
                        "  \t\t\t// param = param + BonusValue(gun5_best_MM, bonus);",
                        "  \t\t// }",
                        "  \t\t// else",
                        "  \t\tSFT('Weapon 5: '+highest_gun5_name+' ('+highest_gun5+')');",
                        "  \t\tparam = param + highest_gun5;",
                        "  \t}",
                        "  \telse",
                        "  \t{",
                        "  \t\tif(gun1_best_MM > -1)",
                        "  \t\t{",
                        "  \t\t\tSFT('Weapon '+end_w_type+': '+highest_gun1_name+' + '+BonusNumInCfg(gun1_best_MM)+' ('+(highest_gun1 + BonusValue(gun1_best_MM, bonus))+')');",
                        "  \t\t\tparam = param + BonusValue(gun1_best_MM, bonus);",
                        "  \t\t}",
                        "  \t\telse SFT('Weapon '+end_w_type+': '+highest_gun1_name+' ('+highest_gun1+')');",
                        "  \t\tparam = param + highest_gun1;",
                        "  \t}",
                        "  \t//Двигатель",
                        "  \tif(!acr_check && highest_engine == highest_value)",
                        "  \t{",
                        "  \t\ttint = 0;",
                        "  \t\tif(engine_best_MM > -1)tint = BonusValue(engine_best_MM, bonus);",
                        "  ",
                        "  \t\tif(findsubstr(highest_engine_name, ' + Acrynator') > -1)",
                        "  \t\t{",
                        "  \t\t\tif(highest_engine > (highest_engine / 3 + tint))",
                        "  \t\t\t{",
                        "  \t\t\t\tSFT('Engine: '+highest_engine_name+' ('+highest_engine+')');",
                        "  \t\t\t\tacr_check = 1;",
                        "  \t\t\t}",
                        "  \t\t\t//Если значение акрина с ММ выше, чем значение акрина с Акринатором",
                        "  \t\t\telse",
                        "  \t\t\t{",
                        "  \t\t\t\thighest_engine_name = substr(highest_engine_name, 0, findsubstr(highest_engine_name, ' + Acrynator'));",
                        "  \t\t\t\thighest_engine = highest_engine / 3;",
                        "  ",
                        "  \t\t\t\tif(engine_best_MM > -1 && cur_search_type == 'Engine')",
                        "  \t\t\t\t{",
                        "  \t\t\t\t\tSFT('Engine: '+highest_engine_name+' + '+BonusNumInCfg(engine_best_MM)+' ('+(highest_engine + tint)+')');",
                        "  \t\t\t\t\tparam = param + tint;",
                        "  \t\t\t\t}",
                        "  \t\t\t\telse SFT('Engine: '+highest_engine_name+' ('+highest_engine+')');",
                        "  \t\t\t}",
                        "  \t\t}",
                        "  \t\telse",
                        "  \t\t{",
                        "  \t\t\tif(engine_best_MM > -1 && cur_search_type == 'Engine')",
                        "  \t\t\t{",
                        "  \t\t\t\tSFT('Engine: '+highest_engine_name+' + '+BonusNumInCfg(engine_best_MM)+' ('+(highest_engine + tint)+')');",
                        "  \t\t\t\tparam = param + tint;",
                        "  \t\t\t}",
