                        "        else tdwd=NearCivilPlanet(Player());",
                        "    }",
                        "}",
                        "else tdwd=NearCivilPlanet(Player());",
                        "AddItemToStorage(tdwd,temp_gift);",
                        "DChange(0);",
                        "exit;"
