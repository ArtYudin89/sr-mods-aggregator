                {
                    "Name": "",
                    "Code.Type": "Turn",
                    "Code": [
                        "for(i=0;i<GalaxyStars();i=i+1)",
                        "\t{",
                        "\ttemp_dword=GalaxyStar(i);",
                        "\tif(StarOwner(temp_dword)!=2)continue;",
                        "\tif(StarRuins(temp_dword,'CB')>0)",
                        "\t\t{",
                        "\t\ttemp_dword2=StarRuins(temp_dword,'CB');",
                        "\t\tShipDestroy(temp_dword2,1);",
                        "\t\t}",
                        "\tfor(j=0;j<StarPlanets(temp_dword);j=j+1)",
                        "\t\t{",
                        "\t\ttemp_dword2=StarPlanets(temp_dword,j);",
                        "\t\tif(PlanetOwner(temp_dword2)==6)continue;",
                        "\t\tPlanetOwner(temp_dword2,PlanetRace(temp_dword2));",
                        "\t\tBuyWarrior(temp_dword2);",
                        "\t\t}",
                        "\tfor(j=0;j<StarShips(temp_dword);j=j+1)",
                        "\t\t{",
                        "\t\ttemp_dword2=StarShips(temp_dword,j);",
                        "\t\tif(ShipTypeN(temp_dword2)!=t_Pirate)continue;",
                        "\t\tOrderNone(temp_dword2);",
                        "\t\tOrderLock(temp_dword2,1);",
                        "\t\tShipDestroy(temp_dword2,1);",
                        "\t\t}",
                        "\t}",
                        "PirateWin(3);",
                        "DChange(13);",
                        "exit;"
                    ],
