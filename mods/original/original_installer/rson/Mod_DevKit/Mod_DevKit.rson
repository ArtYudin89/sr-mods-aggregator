                        "  \t\t\t\t}",
                        "  \t\t\t\telse SFT('DefGenerator: '+highest_def_name+' ('+highest_def+')');",
                        "  \t\t\t}",
                        "  \t\t}",
                        "  \t\telse",
                        "  \t\t{",
                        "  \t\t\tif(def_best_MM > -1 && cur_search_type == 'DefGenerator')",
                        "  \t\t\t{",
                        "  \t\t\t\tSFT('DefGenerator: '+highest_def_name+' + '+BonusNumInCfg(def_best_MM)+' ('+(highest_def + tint)+')');",
                        "  \t\t\t\tparam = param + tint;",
                        "  \t\t\t}",
                        "  \t\t\telse SFT('DefGenerator: '+highest_def_name+' ('+highest_def+')');",
                        "  \t\t}",
                        "  \t}",
                        "  \telse",
                        "  \t{",
                        "  \t\tif(findsubstr(highest_def_name, ' + Acrynator') > -1)",
                        "  \t\t{",
                        "  \t\t\thighest_def_name = substr(highest_def_name, 0, findsubstr(highest_def_name, ' + Acrynator'));",
                        "  \t\t\thighest_def = highest_def / 3;",
                        "  ",
                        "  \t\t\tif(def_best_MM > -1 && cur_search_type == 'DefGenerator')",
                        "  \t\t\t{",
                        "  \t\t\t\tSFT('DefGenerator: '+highest_def_name+' + '+BonusNumInCfg(def_best_MM)+' ('+(highest_def + BonusValue(def_best_MM, bonus))+')');",
                        "  \t\t\t\tparam = param + BonusValue(def_best_MM, bonus);",
                        "  \t\t\t}",
                        "  \t\t\telse SFT('DefGenerator: '+highest_def_name+' ('+highest_def+')');",
                        "  \t\t}",
                        "  \t\telse",
                        "  \t\t{",
                        "  \t\t\tif(def_best_MM > -1 && cur_search_type == 'DefGenerator')",
                        "  \t\t\t{",
                        "  \t\t\t\tSFT('DefGenerator: '+highest_def_name+' + '+BonusNumInCfg(def_best_MM)+' ('+(highest_def + BonusValue(def_best_MM, bonus))+')');",
                        "  \t\t\t\tparam = param + BonusValue(def_best_MM, bonus);",
                        "  \t\t\t}",
                        "  \t\t\telse SFT('DefGenerator: '+highest_def_name+' ('+highest_def+')');",
                        "  \t\t}",
                        "  \t}",
                        "  \tparam = param + highest_def;",
                        "  ",
                        "      SFT(' ');",
                        "  ",
                        "  \t//Применяем бонусы от артефактов",
                        "  \tint art_dam_bon = 0;",
                        "  \tif(InstallArtefacts)",
                        "  \t{",
                        "  \t\tif(param_type == 'Hull armor')",
                        "  \t\t{",
                        "  \t\t\ttint = 0 + CT('Artefacts.NumericValues.kArtefactHull') + CT('Artefacts.NumericValues.kArtefactHullEx');",
                        "  \t\t\tSFT('Iron Zoopie max bonus: ' + tint);",
                        "  \t\t\tparam = param + tint;",
                        "  \t\t}",
                        "  \t\telse if(param_type == 'Hull mass')",
                        "  \t\t{",
                        "  \t\t\ttint = 0 + CT('Artefacts.NumericValues.kArtefactAntigrav') + CT('Artefacts.NumericValues.kArtefactAntigravEx');",
                        "  \t\t\tSFT('Antigravitazer max bonus: -' + tint + '%');",
                        "  \t\t\tparam = param + tint;",
                        "  \t\t}",
                        "  \t\telse if(param_type == 'Max damage')",
                        "  \t\t{",
                        "  \t\t\tif(dam_type == 'WEnergy')",
                        "  \t\t\t{",
                        "  \t\t\t\ttint = round(100.0 * CT('Artefacts.NumericValues.kArtDefToEnergyUp') + CT('Artefacts.NumericValues.kArtDefToEnergyUpEx'));",
                        "  \t\t\t\tSFT('Proportionar max bonus: ' + (tint - 100) + '% (applied AFTER passing through a target\\\\\\'s shield)');",
                        "  \t\t\t\tart_dam_bon = tint - 100;",
                        "  \t\t\t}",
                        "  \t\t\telse if(dam_type == 'WSplinter')",
                        "  \t\t\t{",
                        "  \t\t\t\ttint = round(100.0 * CT('Artefacts.NumericValues.kArtefactSpeed') + CT('Artefacts.NumericValues.kArtefactSpeedEx'));",
                        "  \t\t\t\tSFT('Screw-on max bonus: ' + (tint - 100) + '% (applied AFTER passing through a target\\\\\\'s shield)');",
                        "  \t\t\t\tart_dam_bon = tint - 100;",
                        "  \t\t\t}",
                        "  \t\t}",
                        "  \t\telse if(param_type == 'Max damage per turn')",
                        "  \t\t{",
                        "  \t\t\tif(dam_type == 'WMissile')",
                        "  \t\t\t{",
                        "  \t\t\t\tSFT('Rals max bonus: ~30% (in total)');",
                        "  \t\t\t\tparam = (param * 30)/100;",
                        "  \t\t\t}",
                        "  \t\t}",
                        "  \t\telse if(param_type == 'Engine speed')",
                        "  \t\t{",
                        "  \t\t\t//Сопланатор (применяет свой бонус до пси-ускорителя)",
                        "  \t\t\ttint = 0 + CT('Artefacts.NumericValues.kArtWeaponToSpeed') + CT('Artefacts.NumericValues.kArtWeaponToSpeedEx');",
                        "  \t\t\tSFT('Nozzlenator max bonus: ' + tint);",
                        "  \t\t\tparam = param + tint;",
                        "  ",
                        "  \t\t\t//Пси-ускоритель",
                        "  \t\t\ttint = round(100.0 * CT('Artefacts.NumericValues.kArtefactSpeed') + CT('Artefacts.NumericValues.kArtefactSpeedEx'));",
                        "  \t\t\tSFT('Matter Psi-Accelerator max bonus: ' + (tint - 100) + '%');",
                        "  \t\t\tparam = (param * tint)/100;",
                        "  \t\t}",
                        "  \t\telse if(param_type == 'Radar range')",
                        "  \t\t{",
                        "  \t\t\ttint = 0 + CT('Artefacts.NumericValues.kArtefactRadar') + CT('Artefacts.NumericValues.kArtefactRadarEx');",
                        "  \t\t\tSFT('Prolonger max bonus: ' + tint);",
                        "  \t\t\tparam = param + tint;",
                        "  \t\t}",
                        "  \t\telse if(param_type == 'Scanner power')",
                        "  \t\t{",
                        "  \t\t\ttint = 0 + CT('Artefacts.NumericValues.kArtefactScaner') + CT('Artefacts.NumericValues.kArtefactScanerEx');",
                        "  \t\t\tSFT('Scanner Cache max bonus: ' + tint);",
                        "  \t\t\tparam = param + tint;",
                        "  \t\t}",
                        "  \t\telse if(param_type == 'Droid efficiency')",
                        "  \t\t{",
                        "  \t\t\ttint = 0 + CT('Artefacts.NumericValues.kArtefactDroid') + CT('Artefacts.NumericValues.kArtefactDroidEx');",
                        "  \t\t\tSFT('Junior Droid max bonus: ' + tint);",
                        "  \t\t\tparam = param + tint;",
                        "  \t\t}",
                        "  \t\telse if(param_type == 'Hook max object size')",
                        "  \t\t{",
                        "  \t\t\ttint = 0 + CT('Artefacts.NumericValues.kArtefactHook') + CT('Artefacts.NumericValues.kArtefactHookEx');",
                        "  \t\t\tSFT('Erimeter max bonus: ' + tint);",
                        "  \t\t\tparam = param + tint;",
                        "  \t\t}",
                        "  \t\telse if(param_type == 'Hook range')",
                        "  \t\t{",
                        "  \t\t\ttint = 0 + CT('Artefacts.NumericValues.kArtefactHookRaduis') + CT('Artefacts.NumericValues.kArtefactHookRaduisEx');",
                        "  \t\t\tSFT('Erimeter max bonus: ' + tint);",
                        "  \t\t\tparam = param + tint;",
                        "  \t\t}",
                        "  \t\telse if(param_type == 'Hook close (max) speed' || param_type == 'Hook far (min) speed')",
                        "  \t\t{",
                        "  \t\t\ttint = 0 + CT('Artefacts.NumericValues.kArtefactHookSpeed') + CT('Artefacts.NumericValues.kArtefactHookSpeedEx');",
                        "  \t\t\tSFT('Erimeter max bonus: ' + tint);",
                        "  \t\t\tparam = param + tint;",
                        "  \t\t}",
                        "  \t}",
                        "  ",
                        "  \t//Применяем бонусы от стимуляторов и болезней",
                        "  \tif(InstallStimulants)",
                        "  \t{",
                        "  \t\t// if(param_type == 'Hull mass')",
                        "  \t\t// {",
                        "  \t\t\t// SFT('Grand Malosausus debuff: +20%');",
                        "  \t\t\t// param = param + 20;",
                        "  \t\t// }",
                        "  \t\tif(param_type == 'Engine speed')",
                        "  \t\t{",
                        "  \t\t\t//Гаалистра времени",
                        "  \t\t\tSFT('Gaalian Alacrity bonus: +30%');",
                        "  \t\t\tparam = round(1.3 * param);",
                        "  \t\t}",
                        "  \t\telse if(param_type == 'Radar range')",
                        "  \t\t{",
                        "  \t\t\t//Психотропный кэш",
                        "  \t\t\tSFT('Psychotropic Cache bonus: +100%');",
                        "  \t\t\tparam = param * 2;",
                        "  \t\t}",
                        "  \t\telse if(param_type == 'Scanner power')",
                        "  \t\t{",
                        "  \t\t\t//Психотропный кэш",
                        "  \t\t\tSFT('Psychotropic Cache bonus: +12');",
                        "  \t\t\tparam = param + 12;",
                        "  \t\t}",
                        "  \t}",
                        "  ",
                        "  \tif(!art_dam_bon)SFT('Total parameter value: ' + param);",
                        "  \telse SFT('Total parameter value: ' + param + ' ' + art_dam_bon + '% (after passing through a target\\\\\\'s shield)');",
                        "  ",
                        "  \tSFT(' ');",
                        "      SFT('###########################');",
                        "      SFT('###########################');",
                        "      SFT('###########################');",
                        "  }",
