                    "#": 260,
                    "Type": "Top",
                    "Parent": -1,
                    "Pos.x": 820,
                    "Pos.y": 690
                },
                {
                    "Name": "",
                    "Code.Type": "Turn",
                    "Code": [
                        "for(i=1;i<=4;i=i+1) { //Артефакты",
                        "\ttstr=CT('Artefacts.CustomArtefacts.RNDart_0'+i+'.Size');",
                        "\ttint=tstr;",
                        "\ttint=tint+Rnd(-4,4);",
                        "\ttdwd=CreateCustomArt('RNDart_0'+i,tint,1000,Rnd(0,4));",
                        "\tAddItemToShip(Player(),tdwd);",
                        "}",
                        "for(i=1;i<=15;i=i+1) { //Кустарные модификации",
                        "    tstr=CT('UselessItems.RNDmoditem_'+i+'.Size');",
                        "    tint=tstr;",
                        "    tint=tint+Rnd(-4,4);",
                        "    tdwd=CreateQuestItem('RNDmoditem_'+i,Rnd(0,4));",
                        "    ItemSize(tdwd,tint);",
                        "    ItemCost(tdwd,ItemCost(tdwd)+(ItemCost(tdwd)*Rnd(10,20))/100);",
                        "    AddItemToShip(Player(),tdwd);",
                        "}",
                        "for(i=1;i<=5;i=i+1) { //Контейнеры с кустарными модификациями",
                        "    tdwd=CreateQuestItem('RNDmodbox',PirateClan);",
                        "\tItemSize(tdwd,ItemSize(tdwd)+Rnd(-2,2));",
                        "\tItemCost(tdwd,Rnd(500,2500)*GalaxyTechLevel()+Rnd(-500,-1000));",
                        "\tUselessItemData(tdwd,1,Rnd(4,14));",
                        "    AddItemToShip(Player(),tdwd);",
                        "}",
                        "for(i=1;i<=3;i=i+1) { //Бомбы",
                        "\ttdwd=CreateQuestItem('RNDtimer',PirateClan);",
                        "\tAddItemToShip(Player(),tdwd);",
                        "\ttstr=CT('UselessItems.RNDbomb_'+i+'.Size');",
                        "\ttint=tstr;",
                        "\ttint=tint+Rnd(-4,4);",
                        "\ttdwd=CreateQuestItem('RNDbomb_'+i);",
                        "\tItemSize(tdwd,tint);",
                        "\tItemCost(tdwd,ItemCost(tdwd)+(ItemCost(tdwd)*Rnd(10,20))/100);",
                        "\tAddItemToShip(Player(),tdwd);",
                        "}",
                        "for(i=1;i<=5;i=i+1) { //Контейнеры с бомбами",
                        "    tdwd=CreateQuestItem('RNDbombbox',PirateClan);",
                        "\tItemSize(tdwd,ItemSize(tdwd)+Rnd(-4,4));",
                        "\tItemCost(tdwd,Rnd(500,2500)*GalaxyTechLevel()+Rnd(-200,200));",
                        "\tUselessItemData(tdwd,1,Rnd(1,100));",
                        "\tUselessItemData(tdwd,2,Rnd(1,100));",
                        "\ttstr='';",
                        "\tj=4;",
                        "\twhile(j>0) {",
                        "\t\tif(Rnd(1,100)<=20) tint=1;",
                        "\t\telse {",
                        "\t\t\tif(Rnd(1,100)>50) tint=2;",
                        "\t\t\telse tint=3;",
                        "\t\t}",
                        "\t\ttstr=tstr+''+tint;",
                        "\t\tj=j-1;",
                        "\t}",
                        "\ttint=tstr;",
                        "\tUselessItemData(tdwd,3,tint);",
                        "    AddItemToShip(Player(),tdwd);",
                        "}",
                        "Sound('Sound.Buy');",
                        "DChange(0);",
                        "exit;"
                    ],
                    "#": 261,
                    "Type": "Top",
                    "Parent": -1,
                    "Pos.x": 1060,
                    "Pos.y": 690
                },
                {
                    "Name": "",
                    "Code.Type": "Turn",
                    "Code": [
                        "//Старый вариант",
                        "//if(PlayerBridge()) PlayerBridge(0);",
                        "//TransferShip(Player(), GAnswerData);",
                        "//PlayerBridge(2);",
                        "//PlayerBridge(0);",
                        "//ShipChangeStar(Player(), GAnswerData);",
                        "",
                        "for(temp_int = 0; temp_int < GalaxySectors(); temp_int = temp_int + 1)",
                        "{",
                        "    if(!SectorVisible(GalaxySectors(temp_int))) SectorVisible(GalaxySectors(temp_int), 1);",
                        "}",
                        "RunChildForm('Galaxy');",
                        "if(ShipOrder(Player()) == 7)",
                        "{",
                        "    tdwd = ShipOrderObj(Player());",
                        "    OrderNone(Player());",
                        "    if(PlayerBridge()) PlayerBridge(0);",
                        "    TransferShip(Player(), tdwd);",
                        "    PlayerBridge(2);",
                        "    PlayerBridge(0);",
                        "    ShipChangeStar(Player(), tdwd);",
                        "}",
                        "DChange(13);",
                        "exit;",
