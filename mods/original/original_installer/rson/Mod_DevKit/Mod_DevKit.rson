                {
                    "Name": "",
                    "Code.Type": "Turn",
                    "Code": [
                        "tdwd=BuyTranclucator(StarPlanets(ShipStar(Player()),0));",
                        "NoTargetToShip(tdwd,3);",
                        "ShipSkill(tdwd,1,0);",
                        "ItemSize(ShipItems(tdwd,0),2000);",
                        "ItemOwner(ShipItems(tdwd,0),6);",
                        "ShipRepairEq(tdwd);",
                        "TransferShip(tdwd,ShipStar(Player()));",
                        "temp_dword2=ShipEqInSlot(tdwd,t_DefGenerator);",
                        "if(temp_dword2==0) {",
                        "    temp_dword2=CreateEquipment(t_DefGenerator,Rnd(35,60),GalaxyTechLevel(),4);",
                        "    AddItemToShip(tdwd,temp_dword2);",
                        "    ItemIsInUse(temp_dword2,tdwd,1);",
                        "}",
                        "SetEquipmentStats(temp_dword2,0,0);",
                        "ItemLevel(ShipItems(tdwd,0),6);",
                        "SetEquipmentStats(ShipItems(tdwd,0),0,0);",
                        "ShipSetCoords(tdwd,CoordX(Player()),CoordY(Player())-150);",
                        "ShipJoin(TestTranc,tdwd);",
                        "ShipAddCustomShipInfo(tdwd,'DMeter_infos','NoShow');",
                        "InterfaceState('StarMap','InfoShipTranc',1);",
                        "for(i=1;i<6;i=i+1) {",
                        "\ttemp_dword2=ShipEqInSlot(tdwd,t_Weapon1,i);",
                        "\tif(temp_dword2>0)FreeItem(GetItemFromShip(tdwd,FindItemInShip(tdwd,temp_dword2)));",
                        "}",
                        "ShipSetBad(tdwd,Player());",
                        "DChange(13);",
                        "exit;"
