                        "if(ShipMoney(Player()) >= cost) {",
                        "  urine = urine + 1;",
                        "  CurMed = CurMed + 1;",
                        "  cost = 0.8 * GalaxyMoney(2, ShipOwner(GetShipRuins(Player())));",
