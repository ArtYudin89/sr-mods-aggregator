                        "  //ItemSize(item, 1);",
                        "  item = CreateCustomArt('UrineTincture', 1, 1, None);",
                        "  AddItemToShip(Player(), item);",
                        "  ShipMoney(Player(), ShipMoney(Player()) - cost);",
                        "  Sound('Sound.Buy');",
                        "  DChange(3);",
                        "  exit;",
                        "}",
                        "if(cost > ShipMoney(Player())) {",
                        "  DChange(0);",
                        "  exit;",
                        "}"
