            "Items": [],
            "Operations": [
                {
                    "Name": "",
                    "Code.Type": "Global",
                    "Code": [
                        "GRun();"
                    ],
                    "#": 22,
                    "Type": "Top",
                    "Parent": -1,
                    "Pos.x": 0,
                    "Pos.y": 610
                },
                {
                    "Name": "",
                    "Code.Type": "Init",
                    "Code": [
                        "drugs=newarray(18);",
                        "drugs[0]='Usl_Urine';",
                        "drugs[1]='Usl_Drug01';",
                        "drugs[2]='Usl_Drug02';",
                        "drugs[3]='Usl_Drug03';",
                        "drugs[4]='Usl_Drug04';",
                        "drugs[5]='Usl_Drug05';",
                        "drugs[6]='Usl_Drug06';",
                        "drugs[7]='Usl_Drug07';",
                        "drugs[8]='Usl_Drug08';",
                        "drugs[9]='Usl_Drug09';",
                        "drugs[10]='Usl_Drug10';",
                        "drugs[11]='Usl_Drug11';",
                        "drugs[12]='Usl_Drug12';",
                        "drugs[13]='Usl_Drug13';",
                        "drugs[14]='Usl_Drug14';",
                        "drugs[15]='Usl_Drug15';",
                        "drugs[16]='Usl_Drug16';",
                        "drugs[17]='Usl_Drug17';"
                    ],
                    "#": 23,
                    "Type": "Top",
                    "Parent": -1,
                    "Pos.x": 60,
                    "Pos.y": 610
                },
                {
                    "Name": "",
                    "Code.Type": "Turn",
                    "Code": [
                        "//Через каждые 30 ходов доступные для покупки медикаменты меняются на случайные",
                        "vDays = vDays + 1;",
                        "if(vDays > 30)",
                        "{",
                        "    variable1 = Rnd(1, 5);",
                        "    variable2 = Rnd(1, 6);",
                        "    variable3 = Rnd(1, 6);",
                        "    urine = 0;",
                        "    vDays = 0;",
                        "}",
                        "//Обнуляем счётчик купленных медикаментов",
                        "if(!findsubstr(GameDateTxtByTurn(CurTurn()), CT(\"Script.Mod_EvoMC.141\"))) CurMed = 0;"
                    ],
                    "#": 24,
                    "Type": "Top",
                    "Parent": -1,
                    "Pos.x": 120,
                    "Pos.y": 610
                },
                {
                    "Name": "",
                    "Code.Type": "DialogBegin",
                    "Code": [
                        "if(GetShipRuins(Player())) {",
                        "  if(ShipType(GetShipRuins(Player()))=='MC') {",
                        "    MaxMed=1+ShipRank(Player())/2;",
                        "    TotalMed=MaxMed-CurMed;",
                        "    AddDialogInject('DialogMC','',CT(\"Script.Mod_EvoMC.126\"),5);",
                        "  }",
                        "}"
                    ],
                    "#": 25,
                    "Type": "Top",
                    "Parent": -1,
                    "Pos.x": 180,
                    "Pos.y": 610
                },
                {
                    "Name": "",
                    "Code.Type": "Turn",
                    "Code": [
                        "if(PlayerMedPolicy() && MaxMed==CurMed) {",
                        "  DChange(2);",
                        "  exit;",
                        "}",
                        "if(PlayerMedPolicy()>0 && (MaxMed-CurMed)>0) {",
                        "  kov=substr(CT('UselessItems.Usl_Urine.Name'),18,1);",
                        "  input='';//Очищаем строковую переменную",
                        "  if(urine==0)input=input+CT(\"Script.Mod_EvoMC.120\")+'<clrEnd>---'+CT(\"Script.Mod_EvoMC.120\")+Format(CT('UselessItems.Usl_Urine.Name'),kov,'<clr>')+'<clrEnd><clrEnd>'+CT(\"Script.Mod_EvoMC.120\")+CT('UselessItems.Usl_Urine.Text');//Настойка урины",
                        "  if(variable1>0)input=input+CT(\"Script.Mod_EvoMC.120\")+'<clrEnd>---'+CT(\"Script.Mod_EvoMC.120\");//Разделитель перед списком болезней",
                        "  if(variable1==1)input=input+Format(CT('UselessItems.Usl_Drug01.Name'),kov,'<clr>')+'<clrEnd><clrEnd>'+CT(\"Script.Mod_EvoMC.120\")+CT('UselessItems.Usl_Drug01.Text');//Чекумаш",
                        "  if(variable1==2)input=input+Format(CT('UselessItems.Usl_Drug02.Name'),kov,'<clr>')+'<clrEnd><clrEnd>'+CT(\"Script.Mod_EvoMC.120\")+CT('UselessItems.Usl_Drug02.Text');//Святой фанатизм",
                        "  if(variable1==3)input=input+Format(CT('UselessItems.Usl_Drug03.Name'),kov,'<clr>')+'<clrEnd><clrEnd>'+CT(\"Script.Mod_EvoMC.120\")+CT('UselessItems.Usl_Drug03.Text');//Загадочая луатанация",
                        "  if(variable1==4)input=input+Format(CT('UselessItems.Usl_Drug04.Name'),kov,'<clr>')+'<clrEnd><clrEnd>'+CT(\"Script.Mod_EvoMC.120\")+CT('UselessItems.Usl_Drug04.Text');//Великий малосус",
                        "  if(variable1==5)input=input+Format(CT('UselessItems.Usl_Drug05.Name'),kov,'<clr>')+'<clrEnd><clrEnd>'+CT(\"Script.Mod_EvoMC.120\")+CT('UselessItems.Usl_Drug05.Text');//Новый молизон",
                        "  if(variable2>0)input=input+CT(\"Script.Mod_EvoMC.120\")+'<clrEnd>---'+CT(\"Script.Mod_EvoMC.120\");//Разделитель перед списком стимуляторов №1",
                        "  if(variable2==1)input=input+Format(CT('UselessItems.Usl_Drug06.Name'),kov,'<clr>')+'<clrEnd><clrEnd>'+CT(\"Script.Mod_EvoMC.120\")+CT('UselessItems.Usl_Drug06.Text');//Малокская сижа",
                        "  if(variable2==2)input=input+Format(CT('UselessItems.Usl_Drug07.Name'),kov,'<clr>')+'<clrEnd><clrEnd>'+CT(\"Script.Mod_EvoMC.120\")+CT('UselessItems.Usl_Drug07.Text');//Одноглазый Хамас",
                        "  if(variable2==3)input=input+Format(CT('UselessItems.Usl_Drug08.Name'),kov,'<clr>')+'<clrEnd><clrEnd>'+CT(\"Script.Mod_EvoMC.120\")+CT('UselessItems.Usl_Drug08.Text');//Звездная пыль",
                        "  if(variable2==4)input=input+Format(CT('UselessItems.Usl_Drug09.Name'),kov,'<clr>')+'<clrEnd><clrEnd>'+CT(\"Script.Mod_EvoMC.120\")+CT('UselessItems.Usl_Drug09.Text');//Супер техник",
                        "  if(variable2==5)input=input+Format(CT('UselessItems.Usl_Drug10.Name'),kov,'<clr>')+'<clrEnd><clrEnd>'+CT(\"Script.Mod_EvoMC.120\")+CT('UselessItems.Usl_Drug10.Text');//Гаалистра времени",
                        "  if(variable2==6)input=input+Format(CT('UselessItems.Usl_Drug11.Name'),kov,'<clr>')+'<clrEnd><clrEnd>'+CT(\"Script.Mod_EvoMC.120\")+CT('UselessItems.Usl_Drug11.Text');//Кровяной джогар",
                        "  if(variable3>0)input=input+CT(\"Script.Mod_EvoMC.120\")+'<clrEnd>---'+CT(\"Script.Mod_EvoMC.120\");//Разделитель перед списком стимуляторов №2",
                        "  if(variable3==1)input=input+Format(CT('UselessItems.Usl_Drug12.Name'),kov,'<clr>')+'<clrEnd><clrEnd>'+CT(\"Script.Mod_EvoMC.120\")+CT('UselessItems.Usl_Drug12.Text');//Рагобамский шепот",
                        "  if(variable3==2)input=input+Format(CT('UselessItems.Usl_Drug13.Name'),kov,'<clr>')+'<clrEnd><clrEnd>'+CT(\"Script.Mod_EvoMC.120\")+CT('UselessItems.Usl_Drug13.Text');//Ведущий Шахманду",
                        "  if(variable3==3)input=input+Format(CT('UselessItems.Usl_Drug14.Name'),kov,'<clr>')+'<clrEnd><clrEnd>'+CT(\"Script.Mod_EvoMC.120\")+CT('UselessItems.Usl_Drug14.Text');//Психотропный кэш",
                        "  if(variable3==4)input=input+Format(CT('UselessItems.Usl_Drug15.Name'),kov,'<clr>')+'<clrEnd><clrEnd>'+CT(\"Script.Mod_EvoMC.120\")+CT('UselessItems.Usl_Drug15.Text');//Торговая маркировка",
                        "  if(variable3==5)input=input+Format(CT('UselessItems.Usl_Drug16.Name'),kov,'<clr>')+'<clrEnd><clrEnd>'+CT(\"Script.Mod_EvoMC.120\")+CT('UselessItems.Usl_Drug16.Text');//Дубльплекс",
                        "  if(variable3==6)input=input+Format(CT('UselessItems.Usl_Drug17.Name'),kov,'<clr>')+'<clrEnd><clrEnd>'+CT(\"Script.Mod_EvoMC.120\")+CT('UselessItems.Usl_Drug17.Text');//Абсолютный статус",
                        "  if(urine==0 && variable1>0 && variable2>0 && variable3>0)",
                        "  {",
                        "      unknown1=0;",
                        "      unknown2=0;",
                        "      unknown3=0;",
                        "  }",
                        "  if(!urine || variable1 > 0 || variable2 > 0 || variable3 > 0) {",
                        "    DChange(1);",
                        "    exit;",
                        "  }",
                        "  if(urine==1 && variable1==-1 && variable2==-1 && variable3==-1) {",
                        "    DChange(5);",
                        "    exit;",
                        "  }",
                        "}",
                        "if(!PlayerMedPolicy()) {",
                        "  DChange(4);",
                        "  exit;",
                        "}"
                    ],
                    "#": 43,
                    "Type": "Top",
                    "Parent": -1,
                    "Pos.x": -20,
                    "Pos.y": 400
                },
                {
                    "Name": "",
                    "Code.Type": "Turn",
                    "Code": [
                        "DAdd(5);"
                    ],
                    "#": 44,
                    "Type": "Top",
                    "Parent": -1,
                    "Pos.x": -20,
                    "Pos.y": 470
                },
                {
                    "Name": "",
                    "Code.Type": "Turn",
                    "Code": [
                        "if(!urine || urine == 1) {",
                        "  cost = 0.8 * GalaxyMoney(2, ShipOwner(GetShipRuins(Player())));",
                        "  //input = '</color>' + Format(CT('UselessItems.Usl_Urine.Name'), kov, '<color=0,50,200>') + '</color> (<cost> cr.)';",
                        "  input = '</color>' + CT('Artefacts.CustomArtefacts.UrineTincture.NameDialog') + Format(' (<0> cr.)',\"<0>\",cost);",
                        "  if(!urine) {",
                        "    DAdd(0);",
                        "  }",
                        "  if(urine == 1) {",
                        "    DAdd(7);",
                        "  }",
                        "}",
                        "if(variable1>0 || unknown1>0) {",
                        "  cost=0.81*GalaxyMoney(2,ShipOwner(GetShipRuins(Player())));",
                        "  if(variable1==1 || unknown1==1)input='</color>'+Format(CT('UselessItems.Usl_Drug01.Name'),kov,'<color=0,50,200>')+Format('</color></color> (<0> </color> cr.)',\"<0>\",cost);//Чекумаш",
                        "  if(variable1==2 || unknown1==2)input='</color>'+Format(CT('UselessItems.Usl_Drug02.Name'),kov,'<color=0,50,200>')+Format('</color></color> (<0> </color> cr.)',\"<0>\",cost);//Святой фанатизм",
                        "  if(variable1==3 || unknown1==3)input='</color>'+Format(CT('UselessItems.Usl_Drug03.Name'),kov,'<color=0,50,200>')+Format('</color></color> (<0> </color> cr.)',\"<0>\",cost);//Загадочая луатанация",
                        "  if(variable1==4 || unknown1==4)input='</color>'+Format(CT('UselessItems.Usl_Drug04.Name'),kov,'<color=0,50,200>')+Format('</color></color> (<0> </color> cr.)',\"<0>\",cost);//Великий малосус",
                        "  if(variable1==5 || unknown1==5)input='</color>'+Format(CT('UselessItems.Usl_Drug05.Name'),kov,'<color=0,50,200>')+Format('</color></color> (<0> </color> cr.)',\"<0>\",cost);//Новый молизон;",
                        "  if(variable1>0) {",
                        "    DAdd(1);",
                        "  }",
                        "  if(unknown1>0) {",
                        "    DAdd(7);",
                        "  }",
                        "}",
                        "if(variable2>0 || unknown2>0) {",
                        "  cost=0.815*GalaxyMoney(2,ShipOwner(GetShipRuins(Player())));",
                        "  if(variable2==1 || unknown2==1)input='</color>'+Format(CT('UselessItems.Usl_Drug06.Name'),kov,'<color=0,50,200>')+Format('</color></color> (<0> </color> cr.)',\"<0>\",cost);//Малокская сижа",
                        "  if(variable2==2 || unknown2==2)input='</color>'+Format(CT('UselessItems.Usl_Drug07.Name'),kov,'<color=0,50,200>')+Format('</color></color> (<0> </color> cr.)',\"<0>\",cost);//Одноглазый Хамас",
                        "  if(variable2==3 || unknown2==3)input='</color>'+Format(CT('UselessItems.Usl_Drug08.Name'),kov,'<color=0,50,200>')+Format('</color></color> (<0> </color> cr.)',\"<0>\",cost);//Звездная пыль",
                        "  if(variable2==4 || unknown2==4)input='</color>'+Format(CT('UselessItems.Usl_Drug09.Name'),kov,'<color=0,50,200>')+Format('</color></color> (<0> </color> cr.)',\"<0>\",cost);//Супер техник",
                        "  if(variable2==5 || unknown2==5)input='</color>'+Format(CT('UselessItems.Usl_Drug10.Name'),kov,'<color=0,50,200>')+Format('</color></color> (<0> </color> cr.)',\"<0>\",cost);//Гаалистра времени",
                        "  if(variable2==6 || unknown2==6)input='</color>'+Format(CT('UselessItems.Usl_Drug11.Name'),kov,'<color=0,50,200>')+Format('</color></color> (<0> </color> cr.)',\"<0>\",cost);//Кровяной джогар;",
                        "  if(unknown2>0) {",
                        "    DAdd(7);",
                        "  }",
                        "  if(variable2>0) {",
                        "    DAdd(2);",
                        "  }",
                        "}",
                        "if(variable3>0 || unknown3>0) {",
                        "  cost=0.813*GalaxyMoney(2,ShipOwner(GetShipRuins(Player())));",
                        "  if(variable3==1 || unknown3==1)input='</color>'+Format(CT('UselessItems.Usl_Drug12.Name'),kov,'<color=0,50,200>')+Format('</color></color> (<0> </color> cr.)',\"<0>\",cost);//Рагобамский шепот",
                        "  if(variable3==2 || unknown3==2)input='</color>'+Format(CT('UselessItems.Usl_Drug13.Name'),kov,'<color=0,50,200>')+Format('</color></color> (<0> </color> cr.)',\"<0>\",cost);//Ведущий Шахманду",
                        "  if(variable3==3 || unknown3==3)input='</color>'+Format(CT('UselessItems.Usl_Drug14.Name'),kov,'<color=0,50,200>')+Format('</color></color> (<0> </color> cr.)',\"<0>\",cost);//Психотропный кэш",
                        "  if(variable3==4 || unknown3==4)input='</color>'+Format(CT('UselessItems.Usl_Drug15.Name'),kov,'<color=0,50,200>')+Format('</color></color> (<0> </color> cr.)',\"<0>\",cost);//Торговая маркировка",
                        "  if(variable3==5 || unknown3==5)input='</color>'+Format(CT('UselessItems.Usl_Drug16.Name'),kov,'<color=0,50,200>')+Format('</color></color> (<0> </color> cr.)',\"<0>\",cost);//Дубльплекс",
                        "  if(variable3==6 || unknown3==6)input='</color>'+Format(CT('UselessItems.Usl_Drug17.Name'),kov,'<color=0,50,200>')+Format('</color></color> (<0> </color> cr.)',\"<0>\",cost);//Абсолютный статус;",
                        "  if(unknown3>0) {",
                        "    DAdd(7);",
                        "  }",
                        "  if(variable3>0) {",
                        "    DAdd(3);",
                        "  }",
                        "}",
                        "DAdd(5);"
