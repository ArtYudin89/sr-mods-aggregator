                        "GRun();"
                    ],
                    "#": 13,
                    "Type": "Top",
                    "Parent": -1,
                    "Pos.x": 0,
                    "Pos.y": 510
                },
                {
                    "Name": "",
                    "Code.Type": "Init",
                    "Code": [
                        "ArrayClear(piratePlanets);"
                    ],
                    "#": 14,
                    "Type": "Top",
                    "Parent": -1,
                    "Pos.x": 60,
                    "Pos.y": 510
                },
                {
                    "Name": "",
                    "Code.Type": "Turn",
                    "Code": [
                        "if (timer<=CurTurn())",
                        "{",
                        "    //Определяем максимальное число контрабандистов",
                        "    maxSmugglers=3+ControlledSystems(2)*1.2;",
                        "    if (ControlledSystems(2)<=3) maxSmugglers=3;",
                        "    else if (ControlledSystems(2)<=4) maxSmugglers=5;",
                        "    if (PirateWin()==1) maxSmugglers=maxSmugglers*1.25;",
                        "    if (PirateWin()==5) maxSmugglers=maxSmugglers*1.5;",
                        "    if (PirateWin()==3) maxSmugglers=maxSmugglers*0.7;",
                        "    if (GroupCount(Smugglers)<maxSmugglers)",
                        "    {",
                        "        ArrayClear(piratePlanets);",
                        "        //Перебираем системы в галактике",
                        "        tmp=GalaxyStars();",
                        "        for(i=0;i<tmp;i=i+1)",
                        "        {",
                        "            tmp2=GalaxyStar(i);",
                        "            //Пропускаем пиратский сектор",
                        "            if (tmp2==PlanetToStar(PlanetPirateClan()) || tmp2==GalaxyStar(71)) continue;",
                        "            //Ищем пиратские планеты и заносим в массив",
                        "            if (StarOwner(tmp2)==2)",
                        "                //Пропускаем оспариваемые системы",
                        "                if(!StarBattle(tmp2))",
                        "                {",
                        "                    tmp3=StarPlanets(tmp2);",
                        "                    for (j=0;j<tmp3;j=j+1)",
                        "                    {",
                        "                        spawnPlanet=StarPlanets(tmp2,j);",
                        "                        if (PlanetOwner(spawnPlanet)==PirateClan) ArrayAdd(piratePlanets,spawnPlanet);",
                        "                    }",
                        "                }",
                        "        }",
                        "        //Если подходящих планет слишком мало, никого не спавним",
                        "        if(ArrayDim(piratePlanets)<=1) exit;",
                        "        spawnPlanet=piratePlanets[Rnd(1,ArrayDim(piratePlanets)-1)];",
                        "        //Создаем транспорт",
                        "        tmp=BuyTransport(spawnPlanet,0,Rnd(125,200));",
                        "        //Прокачиваем торговлю и обаяние",
                        "        ShipSkill(tmp,3,Rnd(3,6));",
                        "        ShipSkill(tmp,4,Rnd(3,6));",
                        "        //Слегка обновляем оборудование на корабле",
                        "        for(i=0;i<Rnd(2,3);i=i+1)",
                        "            ShipRefit(tmp);",
                        "        //Применеяем к корпусу особый акрин и выставляем соответствующий внешний вид",
                        "        if (!PlanetRace(spawnPlanet)) tmp2=FindBonusByNameInCfg('ShuSmugglers_SmugglerMaloc');",
                        "        else if (PlanetRace(spawnPlanet)==1) tmp2=FindBonusByNameInCfg('ShuSmugglers_SmugglerPeleng');",
                        "        else if (PlanetRace(spawnPlanet)==2) tmp2=FindBonusByNameInCfg('ShuSmugglers_SmugglerPeople');",
                        "        else if (PlanetRace(spawnPlanet)==3) tmp2=FindBonusByNameInCfg('ShuSmugglers_SmugglerFei');",
                        "        else tmp2=FindBonusByNameInCfg('ShuSmugglers_SmugglerGaal');",
                        "        SpecialToEquipment(tmp2,ShipEqInSlot(tmp,t_Hull));",
                        "        Chameleon(tmp);",
                        "        //Если в корпусе открыт слот дроида, но самого дроида нет - выдаем",
                        "        if(GetEquipmentStats(ShipItems(tmp,0),5)) {",
                        "            if(!ShipEqInSlot(tmp,t_RepairRobot)) {",
                        "                tmp2=CreateEquipment(t_RepairRobot,Rnd(30,60),GalaxyTechLevel(),7);",
                        "                AddItemToShip(tmp,tmp2);",
                        "                ItemIsInUse(tmp2,tmp,1);",
                        "            }",
                        "        }",
                        "        //Аналогично для ГЗП",
                        "        if(GetEquipmentStats(ShipItems(tmp,0),7))  {",
                        "            if(!ShipEqInSlot(tmp,t_DefGenerator)) {",
                        "                tmp2=CreateEquipment(t_DefGenerator,Rnd(30,60),GalaxyTechLevel(),7);",
                        "                AddItemToShip(tmp,tmp2);",
                        "                ItemIsInUse(tmp2,tmp,1);",
                        "            }",
                        "        }",
                        "        //Присоединяем корабль к отдельной группе",
                        "        ShipJoin(Smugglers,tmp);",
                        "        //Прописываем уникальный тип",
                        "        ShipType(tmp,'Smuggler');",
                        "        //Выдаем маску анонимуса, если подключен мод на ЧР",
                        "        if(IsScriptActive('Mod_ExpBlackMarket_2')) GiveRewardByNom(tmp,48);",
                        "        //Присоединяем корабль к клану",
                        "        ShipJoinsClan(tmp);",
                        "        //Выставляем начальное отношение к игроку, равное общему отношению клана к игроку",
                        "        tmp2=RelationToRanger(PlanetPirateClan(),Player());",
                        "        RelationToRanger(tmp,Player(),tmp2);",
                        "    }",
                        "    //Обновляем таймер появления",
                        "    timer=CurTurn()+round(1.0*GroupCount(Smugglers)/maxSmugglers*(Rnd(30,90)));",
                        "}",
                        "//Если контрабандисты существуют, перебираем все галактические события",
                        "if(GroupCount(Smugglers))",
                        "{",
                        "    for(i=GalaxyEvents()-1;i>=0;i=i-1)",
                        "    {",
                        "        //Перебираем все сегодняшние ивенты, в которых игрок или его напарник уничтожает или помогает в уничтожении корабля",
                        "    \tif(GalaxyEventDate(i)<CurTurn()) break;",
                        "    \tif(GalaxyEventType(i)=='PlayerKillsShip' || GalaxyEventType(i)=='PlayerAssistKillsShip' || GalaxyEventType(i)=='PlayerCompanionKillsShip' || GalaxyEventType(i)=='PlayerCompanionAssistKillsShip')",
                        "        {",
                        "            //Пропускаем все, что не относится к контрабандистам",
                        "            if(GalaxyEventsTextData(i,2)!='Smuggler') continue;",
                        "            //Если игрок уничтожал контрабандистов, ухудшаем отношения с кланом",
                        "            tmp=RelationToRanger(PlanetPirateClan(),Player());",
                        "            //Если игрок сам состоит в клане - штраф к отношениям будет гораздо меньше",
                        "            if(ShipOnSidePirateClan(Player())) RelationToRanger(PlanetPirateClan(),Player(),tmp-3);",
                        "            else RelationToRanger(PlanetPirateClan(),Player(),tmp-10);",
                        "            break;",
                        "        }",
                        "        //Аналогично для транклюкаторов игрока, отличается только номер параметра",
                        "        if(GalaxyEventType(i)=='PlayerTranclucatorKillsShip' || GalaxyEventType(i)=='PlayerTranclucatorAssistKillsShip')",
                        "        {",
                        "            if(GalaxyEventsTextData(i,3)!='Smuggler') continue;",
                        "            tmp=RelationToRanger(PlanetPirateClan(),Player());",
                        "            if(ShipOnSidePirateClan(Player())) RelationToRanger(PlanetPirateClan(),Player(),tmp-3);",
                        "            else RelationToRanger(PlanetPirateClan(),Player(),tmp-10);",
                        "            break;",
                        "        }",
                        "        //Если игрок выбил из контрабандиста деньги или груз, отношения также ухудшатся",
                        "        if(GalaxyEventType(i)=='PlayerExtortsMoney' || 'PlayerExtortsGoods')",
                        "        {",
                        "            //Тип корабля текстом в это событие не завезли, поэтому выясняем его отдельно",
                        "            tmp2=IdToShip(GalaxyEventData(i,3));",
                        "            //Обязательная проверка на существование корабля, без нее может возникнуть краш",
                        "            if(tmp2)",
                        "            {",
                        "                if(ShipType(tmp2)!='Smuggler') continue;",
                        "                //Если игрок грабил контрабандистов, незначительно ухудшаем отношения с кланом",
                        "                tmp=RelationToRanger(PlanetPirateClan(),Player());",
                        "                //Если игрок сам состоит в клане - ухудшение отношений будет минимальным",
                        "                if(ShipOnSidePirateClan(Player())) RelationToRanger(PlanetPirateClan(),Player(),tmp-1);",
                        "                else RelationToRanger(PlanetPirateClan(),Player(),tmp-3);",
                        "                break;",
                        "            }",
                        "        }",
                        "    }",
                        "}"
                    ],
                    "#": 15,
                    "Type": "Top",
                    "Parent": -1,
                    "Pos.x": 120,
                    "Pos.y": 510
                },
                {
                    "Name": "",
                    "Code.Type": "Turn",
                    "Code": [
                        "//Принудительно мирим пиратов с контрабандистами",
                        "tmp=CurShip;",
                        "tmp2=StarShips(ShipStar(tmp));",
                        "for (i=0;i<tmp2;i=i+1)",
                        "{",
                        "    tmp3=StarShips(ShipStar(tmp),i);",
                        "    if (ShipGetBad(tmp3)==tmp && ShipInNormalSpace(tmp3) && ShipInNormalSpace(tmp) && tmp3!=tmp && !IsPlayer(tmp3))",
                        "    {",
                        "        if (ShipTypeN(tmp3)==t_Pirate && ShipOnSidePirateClan(tmp3)) TruceBetweenShips(tmp3,tmp);",
                        "    }",
                        "}"
                    ],
                    "#": 17,
                    "Type": "Top",
                    "Parent": -1,
                    "Pos.x": 80
                }
            ],
