                },
                {
                    "Name": "    if(vHoleFly==20) {\r\n      ChangeState(21);\r\n      exit;\r\n    }\r\n    if(vHoleFly==19) {\r\n      ChangeState(16);\r\n      exit;\r\n    }\r\n    if(vHoleFly==18) {\r\n      ChangeState(18);\r\n      exit;\r\n    }\r\n    if(vHoleFly==17) {\r\n      ChangeState(17);\r\n      exit;\r\n    }\r\n    if(vHoleFly==16) {\r\n      ChangeState(20);\r\n      exit;\r\n    }\r\n    if(vHoleFly==15) {\r\n      ChangeState(19);\r\n      exit;\r\n    }\r\n    if(vHoleFly==14) {\r\n      ChangeState(22);\r\n      exit;\r\n    }\r\n    if(vHoleFly==13) {\r\n      ChangeState(11);\r\n      exit;\r\n    }\r\n    if(vHoleFly==12) {\r\n      ChangeState(10);\r\n      exit;\r\n    }\r\n    if(vHoleFly==11) {\r\n      ChangeState(14);\r\n      exit;\r\n    }\r\n    if(vHoleFly==10) {\r\n      ChangeState(5);\r\n      exit;\r\n    }\r\n    if(vHoleFly==9) {\r\n      ChangeState(6);\r\n      exit;\r\n    }\r\n    if(vHoleFly==8) {\r\n      ChangeState(12);\r\n      exit;\r\n    }\r\n    if(vHoleFly==7) {\r\n      ChangeState(13);\r\n      exit;\r\n    }\r\n    if(vHoleFly==6) {\r\n      ChangeState(7);\r\n      exit;\r\n    }\r\n    if(vHoleFly==5) {\r\n      ChangeState(8);\r\n      exit;\r\n    }\r\n    if(vHoleFly==4) {\r\n      ChangeState(9);\r\n      exit;\r\n    }\r\n    if(vHoleFly==3) {\r\n      ChangeState(4);\r\n      exit;\r\n    }\r\n    if(vHoleFly==2) {\r\n      ChangeState(3);\r\n      exit;\r\n    }\r\n    if(vHoleFly==1) {\r\n      ChangeState(2);\r\n      exit;\r\n    }\r\n    if(vHoleFly==-1) {\r\n      ChangeState(44);\r\n      exit;\r\n    }\r\n    if(!order_land && GetShipPlanet(CurShip)) {\r\n      vHoleFly=0;\r\n      if (OrderLock(CurShip)) OrderLock(CurShip,0);\r\n      if (GetShipPlanet(CurShip))\r\n      {\r\n      OrderTakeOff(CurShip);\r\n      OrderLock(CurShip,1);\r\n      }\r\n      if(!GetShipPlanet(CurShip)) {\r\n        ChangeState(0);\r\n        exit;\r\n      }\r\n    }\r\n    if(order_land) {\r\n      vHoleFly=0;\r\n      OrderLock(CurShip,0);\r\n      if (!GetShipPlanet(CurShip)) OrderLanding(CurShip,NearCivilPlanet(CurShip));\r\n      else OrderNone(CurShip); \r\n      OrderLock(CurShip,1);\r\n      if(!order_land && GetShipPlanet(CurShip)) {\r\n        vHoleFly=0;\r\n        if (OrderLock(CurShip)) OrderLock(CurShip,0);\r\n        if (GetShipPlanet(CurShip))\r\n        {\r\n        OrderTakeOff(CurShip);\r\n        OrderLock(CurShip,1);\r\n        }\r\n        if(!GetShipPlanet(CurShip)) {\r\n          ChangeState(0);\r\n          exit;\r\n        }\r\n      }\r\n    }\r\n    if(vHoleFly>20) {\r\n      if(vHoleFly==41) {\r\n        ChangeState(42);\r\n        exit;\r\n      }\r\n      if(vHoleFly==40) {\r\n        ChangeState(38);\r\n        exit;\r\n      }\r\n      if(vHoleFly==39) {\r\n        ChangeState(39);\r\n        exit;\r\n      }\r\n      if(vHoleFly==38) {\r\n        ChangeState(40);\r\n        exit;\r\n      }\r\n      if(vHoleFly==37) {\r\n        ChangeState(41);\r\n        exit;\r\n      }\r\n      if(vHoleFly==36) {\r\n        ChangeState(35);\r\n        exit;\r\n      }\r\n      if(vHoleFly==35) {\r\n        ChangeState(27);\r\n        exit;\r\n      }\r\n      if(vHoleFly==34) {\r\n        ChangeState(32);\r\n        exit;\r\n      }\r\n      if(vHoleFly==33) {\r\n        ChangeState(33);\r\n        exit;\r\n      }\r\n      if(vHoleFly==32) {\r\n        ChangeState(29);\r\n        exit;\r\n      }\r\n      if(vHoleFly==31) {\r\n        ChangeState(28);\r\n        exit;\r\n      }\r\n      if(vHoleFly==30) {\r\n        ChangeState(31);\r\n        exit;\r\n      }\r\n      if(vHoleFly==29) {\r\n        ChangeState(25);\r\n        exit;\r\n      }\r\n      if(vHoleFly==28) {\r\n        ChangeState(34);\r\n        exit;\r\n      }\r\n      if(vHoleFly==27) {\r\n        ChangeState(26);\r\n        exit;\r\n      }\r\n      if(vHoleFly==26) {\r\n        ChangeState(30);\r\n        exit;\r\n      }\r\n      if(vHoleFly==25) {\r\n        ChangeState(37);\r\n        exit;\r\n      }\r\n      if(vHoleFly==24) {\r\n        ChangeState(36);\r\n        exit;\r\n      }\r\n      if(vHoleFly==23) {\r\n        ChangeState(24);\r\n        exit;\r\n      }\r\n      if(vHoleFly==22) {\r\n        ChangeState(23);\r\n        exit;\r\n      }\r\n      if(vHoleFly==42) {\r\n        ChangeState(43);\r\n        exit;\r\n      }\r\n      if(vHoleFly==21) {\r\n        ChangeState(15);\r\n        exit;\r\n      }\r\n    }\r",
