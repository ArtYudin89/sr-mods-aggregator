                    "_orig_danswer": "DAnswer(CT(\"Script.Mod_RevElection.130\"))"
                },
                {
                    "Name": "",
                    "Pos.x": 1560,
                    "Pos.y": 790,
                    "Type": "TDialogAnswer",
                    "Parent": -1,
                    "#": 254,
                    "Msg": "Мало. Я требую в шесть раз больше!",
