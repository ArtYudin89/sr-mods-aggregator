            "Operations": [
                {
                    "Name": "",
                    "Code.Type": "Global",
                    "Code": [
                        "if(vRunScrElection==0) {",
                        "  if((CurTurn()+1)>1890) {",
                        "    if(GlobalRelationsPlanets(Player(),0,56)>60) {",
                        "      GRun();",
                        "    }",
                        "  }",
                        "}"
                    ],
                    "#": 60,
                    "Type": "Top",
                    "Parent": -1,
                    "Pos.x": 0,
                    "Pos.y": 985
                },
                {
                    "Name": "",
                    "Code.Type": "Init",
                    "Code": [
                        "vSearchD=Rnd(55,99);",
                        "vSerachStr=vSearchD;",
                        "vFeiV=Rnd(1,3);",
                        "vPass=Rnd(1,6);",
                        "vBegin=CurTurn();"
                    ],
                    "#": 61,
                    "Type": "Top",
                    "Parent": -1,
                    "Pos.x": 60,
                    "Pos.y": 985
                },
                {
                    "Name": "",
                    "Code.Type": "Turn",
                    "Code": [
                        "NoTargetToShip(GroupToShip(People),2);",
                        "NoTargetToShip(GroupToShip(Gaal),2);",
                        "NoTargetToShip(GroupToShip(Maloc),2);",
                        "NoTargetToShip(GroupToShip(Peleng),2);",
                        "NoTargetToShip(GroupToShip(Fei),2);",
                        "NoTargetToShip(GroupToShip(Agit),1);",
                        "if(vState==5) {",
                        "  ShipOut(GroupToShip(GroupWar));",
                        "  AllShipOut();",
                        "}",
                        "if(vState>0) {",
                        "  if(!CountIn(GroupToShip(Agit))) {",
                        "    if(vTalkAgit<4) {",
                        "      Ether(3,'D0AD413D-F7EB-4A95-B7BE-AC13208343F1',Format(CT(\"Script.Mod_RevElection.450\"),\"<0>\",vName,\"<1>\",Name(PlanetS),\"<2>\",GameDateTxtByTurn(vBegin+vSerachStr)));",
                        "    }",
                        "  }",
                        "}",
                        "if(vBegin+vSerachStr==CurTurn()) {",
