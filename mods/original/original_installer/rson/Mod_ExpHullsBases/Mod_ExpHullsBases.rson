                },
                {
                    "Name": "",
                    "Code.Type": "Turn",
                    "Code": [
                        "//Добавляем опции для установки акриновых улучшений и портального генератора",
                        "if(ruin_str_type == 'WB' || ruin_str_type == 'PlayerMB')",
                        "{",
                        "    TextCorr2 = '</color>' + CT(\"Script.Mod_ExpHullsBases.451\");",
                        "    TextCorr3 = '</color>' + CT(\"Script.Mod_ExpHullsBases.470\");",
                        "}",
                        "else",
                        "{",
                        "    TextCorr2 = '</color>' + CT(\"Script.Mod_ExpHullsBases.416\");",
                        "    TextCorr3 = '</color>' + CT(\"Script.Mod_ExpHullsBases.464\");",
                        "}",
                        "",
                        "if(int(GetGameOptions('FontDialog')) > 1) TextCorr = '</color>' + CT(\"Script.Mod_ExpHullsBases.444\");",
                        "else TextCorr = '</color>' + CT(\"Script.Mod_ExpHullsBases.443\");",
                        "if(GetGameOptions('FontDialog') == '0') DefSplt = '</color>----------------------------------------------------';",
                        "else if(GetGameOptions('FontDialog') == '1') DefSplt = '</color>------------------------------------------';",
                        "else if(GetGameOptions('FontDialog') == '2') DefSplt = '</color>-----------------------------------------';",
                        "else DefSplt = '</color>-------------------------------------';",
                        "",
                        "//Запоминаем наличие инфошек портального генератора и доп. энергоядер на станции",
                        "i = ShipFindCustomShipInfoByType(cur_ruin, 'Teleport_Generator');",
                        "k = ShipFindCustomShipInfoByType(cur_ruin, 'Extra_Powercores');",
                        "if(~k) tempInt3 = ShipCustomShipInfoData(cur_ruin, k, 1);",
                        "else tempInt3 = 1;",
                        "",
                        "//Убеждаемся, что для установки ядра на станции имеется хотя бы один свободный слот (оружия или артефакта)",
                        "tempInt1 = 0;",
                        "tempInt2 = 0;",
                        "if(~i)",
                        "{",
                        "    if((GetEquipmentStats(ShipItems(cur_ruin, 0), 1) + ShipSpecialBonuses(cur_ruin, bonSlotWeapon)) > 1) tempInt1 = 1;",
                        "    if((GetEquipmentStats(ShipItems(cur_ruin, 0), 2) + ShipSpecialBonuses(cur_ruin, bonSlotArt)) > 0) tempInt2 = 1;",
                        "}",
                        "",
                        "if(ruin_str_type != 'PlayerMB')",
                        "{",
                        "    tempStr1 = '</color>' + CT(\"Script.Mod_ExpHullsBases.1033\");",
                        "    tempStr2 = '</color>' + CT(\"Script.Mod_ExpHullsBases.1032\");",
                        "    tempStr3 = '</color>' + CT(\"Script.Mod_ExpHullsBases.1031\");",
                        "}",
                        "else",
                        "{",
                        "    tempStr1 = '</color>' + CT('Script.Mod_ExpHullsBases.DialogsPlayerMB.PlayerAskGSOM');",
                        "    tempStr2 = '</color>' + CT('Script.Mod_ExpHullsBases.DialogsPlayerMB.PlayerAskHurricane');",
                        "    tempStr3 = '</color>' + CT('Script.Mod_ExpHullsBases.DialogsPlayerMB.PlayerAskPolyxen');",
                        "}",
                        "",
                        "//Добавляем опции для улучшения статов станции",
                        "//Увеличение размера",
                        "if(cur_ruin_size < max_ruin_size)",
                        "{",
                        "    if(ruin_str_type != 'PlayerMB') tstr1 = '</color>' + Format(CT(\"Script.Mod_ExpHullsBases.164\"),\"<0>\",size_augment_str,\"<1>\",size_upgrade_cost_str);",
                        "    else tstr1 = '</color>' + Format(CT('Script.Mod_ExpHullsBases.DialogsPlayerMB.PlayerAskHullStructureIncrease'), '<Count' + '>', size_augment_str, '<Cost' + '>', size_upgrade_cost_str);",
                        "",
                        "    if(player_money < size_upgrade_cost)",
                        "    {",
                        "        tstr1 = DeleteTags(tstr1);",
                        "        AddDialogBlock(tstr1, 1);",
                        "    }",
                        "    InjectAnswer('RuinImproveDone', tstr1, 1);",
                        "}",
                        "//Усиление брони",
                        "if(cur_ruin_armor < max_ruin_armor)",
                        "{",
                        "    if(ruin_str_type != 'PlayerMB') tstr1 = '</color>' + Format(CT(\"Script.Mod_ExpHullsBases.166\"),\"<0>\",armor_augment_str,\"<1>\",armor_upgrade_cost_str);",
