                    "Code": [
                        "upgrade_cost_hurricane = 1.0 * (80000 + 60000 * (GalaxyDiffLevels(4) - 100) / 400) * (0.5 + (0.25 * (GalaxyTechLevel() - 1)));",
                        "",
