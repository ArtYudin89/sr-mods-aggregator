                        "        else tstr1 = '</color>' + Format(CT('Script.Mod_ExpHullsBases.DialogsPlayerMB.PlayerAskHullLevelIncrease'), '<Cost' + '>', level_upgrade_cost_str);",
                        "",
                        "        if(player_money < level_upgrade_cost)",
                        "        {",
                        "            tstr1 = DeleteTags(tstr1);",
                        "            AddDialogBlock(tstr1, 1);",
                        "        }",
                        "        InjectAnswer('RuinImproveDone', tstr1, 3);",
                        "    }",
                        "}",
                        "if(ShipType(cur_ruin) != 'WB') {",
                        "  if(tempInt1 || tempInt2) {",
                        "    if(tempInt3 < 4) {",
                        "      if(tempInt3 < 2 || (tempInt3 > 1 && cur_ruin_techlevel > 4)) {",
                        "        if(k <= -1) tempStr1 = '</color>' + CT(\"Script.Mod_ExpHullsBases.744\");",
