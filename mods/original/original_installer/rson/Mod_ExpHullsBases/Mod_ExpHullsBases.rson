                },
                {
                    "Name": "",
                    "Code.Type": "Turn",
                    "Code": [
                        "if(ShipOrder(cur_ruin)!=7)",
                        "{",
                        "    if(j==-1)j=Player();",
                        "    else j=IdToPlanet(j);",
                        "    if(ShipInScript(cur_ruin,0))ShipOut(cur_ruin);",
                        "    OrderTeleport(cur_ruin,cur_star,CoordX(j),CoordY(j));",
                        "    ShipAddCustomShipInfo(cur_ruin, 'ExpHullsBases_TeleportCoords', 'NoShow', CoordX(j), CoordY(j));",
                        "    //Задаём число дней на совершение скачка",
                        "    ShipOrderData1(cur_ruin,0);",
                        "}",
                        "DChange(61);",
                        "exit;"
                    ],
