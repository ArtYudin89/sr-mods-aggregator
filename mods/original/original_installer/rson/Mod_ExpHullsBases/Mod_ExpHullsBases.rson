            "Groups": [
                {
                    "Name": "PlayerGroup",
                    "Owner": 62,
                    "Group.Type": 126,
                    "CntShipMin": 1,
                    "CntShipMax": 1,
                    "SpeedMin": 100,
                    "SpeedMax": 10000,
                    "Weapon": 0,
                    "CargoHook": 0,
                    "EmptySpace": 0,
                    "AddPlayer": true,
                    "StatusTraderMin": 0,
                    "StatusTraderMax": 100,
                    "StatusWarriorMin": 0,
                    "StatusWarriorMax": 100,
                    "StatusPirateMin": 0,
                    "StatusPirateMax": 100,
                    "DistSearch": 10000,
                    "Dialog": -1,
                    "StrengthMin": "0",
                    "StrengthMax": "0",
                    "Ruins": "",
                    "+Planet": "PlanetNew",
                    "+State": 0,
                    "Type": "TGroup",
                    "Pos.x": 0,
                    "Pos.y": 400,
                    "Parent": -1,
                    "#": 69
                }
            ],
            "Items": [],
            "Operations": [
                {
                    "Name": "",
                    "Code.Type": "Global",
                    "Code": [
                        "GRun();"
                    ],
                    "#": 70,
                    "Type": "Top",
                    "Parent": -1,
                    "Pos.x": 0,
                    "Pos.y": 1035
                },
                {
                    "Name": "",
                    "Code.Type": "Init",
                    "Code": [
                        "//Для определения \"кошелька\" из которого игрок совершает платёж при улучшении своего штаба",
                        "function PlayerHQPayCheck(dword cost)",
                        "{",
                        "    //Вызываем подтверждение перед платежом",
                        "    if(ShipMoney(Player()) >= cost)",
                        "    {",
                        "        str text = CT('Script.Mod_ShuMercs.PlayerHQMainDialog.PlayerAccountPaymentOffer');",
                        "        if(PlayerHQMainArray['Finance', 'CurrentBalance'] >= cost) text = text + ' ' + CT('Script.Mod_ShuMercs.PlayerHQMainDialog.PlayerAccountPaymentOfferAdd');",
                        "",
                        "        if(MessageBoxYesNo(text))",
                        "        {",
                        "            ShipMoney(Player(), ShipMoney(Player()) - cost);",
                        "            result = 2;",
                        "        }",
                        "        else if(PlayerHQMainArray['Finance', 'CurrentBalance'] >= cost)",
                        "        {",
                        "            PlayerHQMainArray['Finance', 'CurrentBalance'] = PlayerHQMainArray['Finance', 'CurrentBalance'] - cost;",
                        "            PlayerHQMainArray['Finance', 'StatsOutExpenses'] = PlayerHQMainArray['Finance', 'StatsOutExpenses'] + cost;",
                        "            result = 1;",
                        "        }",
                        "        else",
                        "        {",
                        "            result = 0;",
                        "        }",
                        "    }",
                        "    else",
                        "    {",
                        "        PlayerHQMainArray['Finance', 'CurrentBalance'] = PlayerHQMainArray['Finance', 'CurrentBalance'] - cost;",
                        "        PlayerHQMainArray['Finance', 'StatsOutExpenses'] = PlayerHQMainArray['Finance', 'StatsOutExpenses'] + cost;",
                        "        result = 1;",
                        "    }",
                        "}"
                    ],
                    "#": 71,
                    "Type": "Top",
                    "Parent": -1,
                    "Pos.x": 60,
                    "Pos.y": 1035
                },
                {
                    "Name": "",
                    "Code.Type": "Turn",
                    "Code": [
                        "if(R_next_repair_turn <= CurTurn()) {",
                        "  R_next_repair_turn = CurTurn() + R_next_repair_delay;",
                        "  //Плановый ремонт станций на 10% каждый месяц (чинятся в т.ч. и пиратские станции)",
                        "  for(i = 0; i < GalaxyStars(); i = i + 1)",
                        "  {",
                        "      cur_star = GalaxyStar(i);",
                        "      if(StarOwner(cur_star) == 1) continue;",
                        "      if(StarCustomFaction(cur_star) != '') continue;",
                        "      if(!StarRuins(cur_star)) continue;",
                        "      for(j = 0; j < StarRuins(cur_star); j = j + 1)",
                        "      {",
                        "          cur_ruin = StarRuins(cur_star, j);",
                        "          cur_item = ShipItems(cur_ruin, 0);",
                        "          if(HullHP(cur_item) == ItemSize(cur_item)) continue;",
                        "          if((HullHP(cur_item) + ItemSize(cur_item) / 10) > ItemSize(cur_item)) HullHP(cur_item, HullHP(cur_item) + (ItemSize(cur_item) - HullHP(cur_item)));",
                        "          else HullHP(cur_item, HullHP(cur_item) + ItemSize(cur_item) / 10);",
                        "      }",
                        "  }",
                        "}",
                        "//Включение/отключение звёздного ветра для движущейся ВБ",
                        "if(GetShipRuins(Player()) && !PlayerBridge())",
                        "{",
                        "    if(ShipOrder(GetShipRuins(Player())) == 1 && InterfaceState('RuinsTalk', 'StarFieldWB') != 1)",
                        "    {",
                        "        InterfaceState('RuinsTalk', 'StarFieldWB', 1);",
                        "    }",
                        "    if(ShipOrder(GetShipRuins(Player())) != 1 && InterfaceState('RuinsTalk', 'StarFieldWB') == 1)",
                        "    {",
                        "        InterfaceState('RuinsTalk', 'StarFieldWB', -1);",
                        "    }",
                        "}"
                    ],
                    "#": 72,
                    "Type": "Top",
                    "Parent": -1,
                    "Pos.x": 120,
                    "Pos.y": 1035
                },
                {
                    "Name": "",
                    "Code.Type": "DialogBegin",
                    "Code": [
                        "if(GetShipRuins(Player())) {",
                        "  if(!PlayerBridge()) {",
                        "    cur_ruin = GetShipRuins(Player());",
                        "    ruin_str_type = Format(ShipType(cur_ruin), '_licensed', '', '');",
                        "    ",
                        "    cur_star = ShipStar(cur_ruin);",
                        "    ",
                        "    //Если игрок находится на военной базе",
                        "    if(ruin_str_type == 'WB')",
                        "    {",
                        "        //Добавляем диалог для приказа смены дислокации ВБ (игрока могут позже послать, если его звание недостаточно высоко)",
                        "        if(!StarOwner(cur_star))",
                        "        {",
                        "            if(!ShipOnSidePirateClan(Player()))",
                        "            {",
                        "                if(ShipTurnBeforeEndOrder(cur_ruin) - 1 > 1) TextCorr3 = '</color>' + CT(\"Script.Mod_ExpHullsBases.556\");",
                        "                else TextCorr3 = '</color>' + CT(\"Script.Mod_ExpHullsBases.555\");",
                        "    ",
                        "                if(~ShipFindCustomShipInfoByType(cur_ruin, 'WB_move')) AddDialogInject('ruin_movement', Format(CT(\"Script.Mod_ExpHullsBases.659\"),\"<0>\",StarName(cur_star),\"<1>\",ShipSpeed(cur_ruin),\"<2>\",ShipTurnBeforeEndOrder(cur_ruin),\"<3>\",TextCorr3),CT(\"Script.Mod_ExpHullsBases.654\"), 0);",
                        "                else AddDialogInject('ruin_movement', '', CT(\"Script.Mod_ExpHullsBases.553\"), 1);",
                        "            }",
                        "        }",
                        "        else",
                        "        {",
                        "            AddDialogOverride('OnSystemAttack', 1000);",
                        "        }",
                        "    ",
                        "        if(ShipOwner(Player()) <= 4)",
                        "        {",
                        "            //Добавляем стандартные диалоги для улучшения базы",
                        "            if(RuinsAllowModernization(cur_ruin))",
                        "            {",
                        "                if(ruin_str_type != 'PB' && ruin_str_type != 'CB')",
                        "                {",
                        "                    AddDialogInject('ruinhull_upgrade_talk', '', CT(\"Script.Mod_ExpHullsBases.479\"), 0);",
                        "                }",
                        "    ",
                        "                AddDialogInject('ruin_modernization_negation', '', CT(\"Script.Mod_ExpHullsBases.213\"), 0);",
                        "            }",
                        "            else",
                        "            {",
                        "                AddDialogInject('ruinhull_upgrade_talk', '', CT(\"Script.Mod_ExpHullsBases.478\"), 0);",
                        "            }",
                        "        }",
                        "        //Если игрок на стороне клана, то улучшить ВБ он не сможет",
                        "        else if(ShipOnSidePirateClan(Player()))",
                        "        {",
                        "            AddDialogBlock(CT('FormRuins.GN.Modern.PlayerAsk'), 2);",
                        "            RuinsAllowModernization(cur_ruin, 0);",
                        "        }",
                        "    }",
                        "    //Если игрок находится на какой-то другой станции",
                        "    else if(",
                        "            ruin_str_type == 'SB' ||",
                        "            ruin_str_type == 'RC' ||",
                        "            ruin_str_type == 'MC' ||",
                        "            ruin_str_type == 'BK' ||",
                        "            ruin_str_type == 'TC' ||",
                        "            ruin_str_type == 'PB' ||",
                        "            ruin_str_type == 'CB'",
                        "        )",
                        "    {",
                        "        //Добавляем диалог в случае нахождения станции в гипере (и если игрок в этот момент сидит на ней же)",
                        "        if(ShipInHyperSpace(cur_ruin)) AddDialogOverride('Hyper', 3000);",
                        "        if(jumpCheck != '') AddDialogOverride(jumpCheck, 3001);",
                        "    ",
                        "        //Добавляем диалог для использования портального генератора (если он уже установлен на базе)",
                        "        if(~ShipFindCustomShipInfoByType(cur_ruin, 'Teleport_Generator')) AddDialogInject('TeleportRun', '', CT(\"Script.Mod_ExpHullsBases.1001\"), 0);",
                        "    ",
                        "        //Добавляем стандартные диалоги для улучшения базы",
                        "        if(RuinsAllowModernization(cur_ruin))",
                        "        {",
                        "            if(ruin_str_type != 'PB' && ruin_str_type != 'CB') AddDialogInject('ruinhull_upgrade_talk', '', CT(\"Script.Mod_ExpHullsBases.479\"), 0);",
                        "            else if((ruin_str_type == 'PB' || ruin_str_type == 'CB') && ShipOnSidePirateClan(Player())) AddDialogInject('ruinhull_upgrade_talk', '', CT(\"Script.Mod_ExpHullsBases.479\"), 0);",
                        "            AddDialogInject('ruin_modernization_negation', '', CT(\"Script.Mod_ExpHullsBases.213\"), 0);",
                        "        }",
                        "        else",
                        "        {",
                        "            AddDialogInject('ruinhull_upgrade_talk', '', CT(\"Script.Mod_ExpHullsBases.478\"), 0);",
                        "        }",
                        "    }",
                        "    else if(ruin_str_type == 'PlayerMB')",
                        "    {",
                        "        if(RuinsAllowModernization(cur_ruin))",
                        "        {",
                        "            //Если игрок повысил уровень штаба, но пока что не прожал \"Отлично!\" (т.к. этот ответ как раз и повышает уровень)",
                        "            if(ruin_str_type == 'PlayerMB' && GotoGov())",
                        "            {",
                        "                AddDialogOverride('RuinImproveDone', 4000, 10);",
                        "            }",
                        "        }",
                        "    }",
                        "  }",
                        "  if(PlayerBridge() == 1 || PlayerBridge() == 2 || PlayerBridge() == 3) {",
                        "    if(ShipInNormalSpace(Player()))",
                        "    {",
                        "        //Добавляем диалоги на мостик",
                        "        cur_star = ShipStar(Player());",
                        "        if(jumpCheck != '') AddDialogOverride(jumpCheck, 3001);",
                        "        else",
                        "        {",
                        "            for(i = 0; i < StarRuins(cur_star); i = i + 1)",
                        "            {",
                        "                cur_ruin = StarRuins(cur_star, i);",
                        "                if(!ShipInNormalSpace(cur_ruin)) continue;",
                        "                if(Dist(Player(), cur_ruin) > ShipRadarRange(Player())) continue;",
                        "    ",
                        "                ruin_str_type = ShipType(cur_ruin);",
                        "                if(ruin_str_type == 'WB')",
                        "                {",
                        "                    AddDialogInject('bridge_ruin_control', '', Format(CT(\"Script.Mod_ExpHullsBases.603\"),\"<0>\",ShipName(cur_ruin)), 5);",
                        "                }",
                        "                else if(ruin_str_type == 'SB' || ruin_str_type == 'RC' || ruin_str_type == 'MC' || ruin_str_type == 'BK' || ruin_str_type == 'TC' || ruin_str_type == 'PB')",
                        "                {",
                        "                    if(~ShipFindCustomShipInfoByType(cur_ruin, 'Teleport_Generator'))",
                        "                    {",
                        "                        if(ShipOrder(cur_ruin) != 7)",
                        "                        {",
                        "                            if(ruin_str_type == 'SB') AddDialogInject('TeleportBridge', '', Format(CT(\"Script.Mod_ExpHullsBases.801\"),\"<0>\",ShipName(cur_ruin)), 0, 0, cur_ruin);",
                        "                            else if(ruin_str_type == 'RC') AddDialogInject('TeleportBridge', '', Format(CT(\"Script.Mod_ExpHullsBases.800\"),\"<0>\",ShipName(cur_ruin)), 0, 0, cur_ruin);",
                        "                            else if(ruin_str_type == 'MC') AddDialogInject('TeleportBridge', '', Format(CT(\"Script.Mod_ExpHullsBases.799\"),\"<0>\",ShipName(cur_ruin)), 0, 0, cur_ruin);",
                        "                            else if(ruin_str_type == 'BK') AddDialogInject('TeleportBridge', '', Format(CT(\"Script.Mod_ExpHullsBases.798\"),\"<0>\",ShipName(cur_ruin)), 0, 0, cur_ruin);",
                        "                            else if(ruin_str_type == 'TC') AddDialogInject('TeleportBridge', '', Format(CT(\"Script.Mod_ExpHullsBases.797\"),\"<0>\",ShipName(cur_ruin)), 0, 0, cur_ruin);",
                        "                            else if(ruin_str_type == 'PB') AddDialogInject('TeleportBridge', '', Format(CT(\"Script.Mod_ExpHullsBases.1046\"),\"<0>\",ShipName(cur_ruin)), 0, 0, cur_ruin);",
                        "                        }",
                        "                        }",
                        "                    }",
                        "                }",
                        "            }",
                        "        }",
                        "        cur_ruin = 0;",
                        "    }",
                        "  }",
                        "}"
                    ],
                    "#": 73,
                    "Type": "Top",
                    "Parent": -1,
                    "Pos.x": 180,
                    "Pos.y": 1035
                },
                {
                    "Name": "",
                    "Code.Type": "Turn",
                    "Code": [
                        "HullReport = '';",
                        "TextCorr = '';",
                        "TextCorr2 = '';",
                        "TextCorr3 = '';",
                        "DefSplt = '';",
                        "",
                        "ruin_hull = ShipItems(cur_ruin, 0);",
                        "cur_module = EqModule(ruin_hull);",
                        "cur_hitpoints = HullHP(cur_ruin);",
                        "cur_ruin_techlevel = ItemLevel(ruin_hull);",
                        "",
                        "//Запоминаем число доступных средств игрока для удобства всех последующих проверок",
                        "if(ruin_str_type != 'PlayerMB') player_money = ShipMoney(Player());",
                        "else player_money = max(ShipMoney(Player()), int(PlayerHQMainArray['Finance', 'CurrentBalance']));",
                        "",
                        "ModuleToEquipment(-1, ruin_hull);",
                        "if(ruin_str_type == 'WB')",
                        "{",
                        "    if(GetEquipmentStats(ruin_hull) < cur_ruin_techlevel * 2 + 4) cur_ruin_armor = GetEquipmentStats(ruin_hull);",
                        "    else cur_ruin_armor = cur_ruin_techlevel * 2 + 4;",
                        "}",
                        "else",
                        "{",
                        "    if(GetEquipmentStats(ruin_hull) < cur_ruin_techlevel * 2 + 1) cur_ruin_armor = GetEquipmentStats(ruin_hull);",
                        "    else cur_ruin_armor = cur_ruin_techlevel * 2 + 1;",
                        "    if(cur_ruin_armor >= 17) cur_ruin_armor = 16;",
                        "}",
                        "ModuleToEquipment(cur_module, ruin_hull);",
                        "HullHP(cur_ruin, cur_hitpoints);",
                        "",
                        "if((HullHP(cur_ruin) + ItemSize(ruin_hull) / 10) > ItemSize(ruin_hull))",
                        "{",
                        "    HullRepCount = ItemSize(ruin_hull) - HullHP(cur_ruin);",
                        "}",
                        "else",
                        "{",
                        "    HullRepCount = HullHP(cur_ruin) / 10;",
                        "}",
                        "",
                        "if(HullHP(cur_ruin) < ItemSize(ruin_hull))",
                        "{",
                        "    PlanRep = CT(\"Script.Mod_ExpHullsBases.1034\") + '</color>' + Format(CT(\"Script.Mod_ExpHullsBases.1043\"),\"<0>\",HullRepCount) + CT(\"Script.Mod_ExpHullsBases.1034\") + Format(CT(\"Script.Mod_ExpHullsBases.1042\"),\"<0>\",R_next_repair_turn - CurTurn());",
                        "}",
                        "else",
                        "{",
                        "    PlanRep = '';",
                        "}",
                        "",
                        "cur_ruin_size = ItemSize(ruin_hull);",
                        "cur_ruin_cost = ItemCost(ruin_hull);",
                        "if(ruin_str_type == 'WB') max_ruin_size = ((cur_ruin_techlevel * 400 + 800) * 3) / 2;",
                        "else max_ruin_size = cur_ruin_techlevel * 400 + 800;",
                        "//Расширяем лимит размера станций для мода EvoArmada",
                        "if(IsScriptActive('Mod_EvoArmada')) max_ruin_size = round(1.0 * max_ruin_size * (1.0 + (1.0 * (GalaxyDiffLevels() / 50))));",
                        "",
                        "if(max_ruin_size < ItemSize(ruin_hull)) max_ruin_size = ItemSize(ruin_hull);",
                        "",
                        "if(ruin_str_type == 'WB') max_ruin_armor = cur_ruin_techlevel * 2 + 4;",
                        "else",
                        "{",
                        "    max_ruin_armor = cur_ruin_techlevel * 2 + 1;",
                        "    if(max_ruin_armor >= 17) max_ruin_armor = 16;",
                        "}",
                        "",
                        "if((ItemSize(ruin_hull) + max_ruin_size / 20) > max_ruin_size) size_augmentFloat = max_ruin_size - ItemSize(ruin_hull);",
                        "else size_augmentFloat = max_ruin_size / 20;",
                        "if(max_ruin_size - (ItemSize(ruin_hull) + size_augmentFloat) <= (cur_ruin_techlevel * 10)) size_augmentFloat = max_ruin_size - ItemSize(ruin_hull);",
                        "armor_augment = '1';",
                        "armor_augment_str = armor_augment;",
                        "",
                        "if(~findsubstr(ItemFullName(ruin_hull), CT(\"Script.Mod_ExpHullsBases.1041\")) || ~findsubstr(ItemFullName(ruin_hull), CT(\"Script.Mod_ExpHullsBases.1040\")) || ~findsubstr(ItemFullName(ruin_hull), CT(\"Script.Mod_ExpHullsBases.1039\")))",
                        "{",
                        "    if(~findsubstr(ItemFullName(ruin_hull), CT(\"Script.Mod_ExpHullsBases.1041\"))) ruin_hull_name = CT(\"Script.Mod_ExpHullsBases.1041\");",
                        "    if(~findsubstr(ItemFullName(ruin_hull), CT(\"Script.Mod_ExpHullsBases.1040\"))) ruin_hull_name = CT(\"Script.Mod_ExpHullsBases.1040\");",
                        "    if(~findsubstr(ItemFullName(ruin_hull), CT(\"Script.Mod_ExpHullsBases.1039\"))) ruin_hull_name = CT(\"Script.Mod_ExpHullsBases.1039\");",
                        "}",
                        "else ruin_hull_name = substr(ItemFullName(ruin_hull), 0, findsubstr(ItemFullName(ruin_hull), ' '));",
                        "",
                        "armor_upgrade_cost = (cur_ruin_cost / 22) * (100 - 4 * ShipSkill(Player(), 2)) / 100;",
                        "armor_upgrade_cost = armor_upgrade_cost * (100 - 3 * ShipSkill(Player(), 3)) / 100;",
                        "",
                        "size_upgrade_cost = (cur_ruin_cost / 80) * (100 - 4 * ShipSkill(Player(), 2)) / 100;",
                        "size_upgrade_cost = size_upgrade_cost * (100 - 3 * ShipSkill(Player(), 3)) / 100;",
                        "",
                        "if(size_augmentFloat != max_ruin_size / 20 && size_augmentFloat) size_upgrade_cost = size_augmentFloat / (0.01 * (max_ruin_size / 20)) * (0.01 * size_upgrade_cost);",
                        "size_augment = size_augmentFloat;",
                        "size_augment_str = size_augment;",
                        "",
                        "level_upgrade_cost = (cur_ruin_cost / 10) * (100 - 4 * ShipSkill(Player(), 2)) / 100;",
                        "level_upgrade_cost = level_upgrade_cost * (100 - 3 * ShipSkill(Player(), 3)) / 100;",
                        "",
                        "if(ruin_str_type == 'WB') armor_upgrade_cost = armor_upgrade_cost * 70 / 100;",
                        "if(ruin_str_type == 'SB' || ruin_str_type == 'TC') level_upgrade_cost = level_upgrade_cost * 60 / 100;",
                        "",
                        "armor_upgrade_cost = armor_upgrade_cost + armor_upgrade_cost * (GalaxyDiffLevels(4) - 175) / 400;",
                        "armor_upgrade_cost_str = armor_upgrade_cost;",
                        "size_upgrade_cost = size_upgrade_cost + size_upgrade_cost * (GalaxyDiffLevels(4) - 175) / 300;",
                        "size_upgrade_cost_str = size_upgrade_cost;",
                        "level_upgrade_cost = level_upgrade_cost + level_upgrade_cost * (GalaxyDiffLevels(4) - 175) / 400;",
                        "level_upgrade_cost_str = level_upgrade_cost;",
                        "",
                        "if(player_money < size_upgrade_cost)",
                        "{",
                        "    size_augment_str = '</color>' + size_augment;",
                        "    size_upgrade_cost_str = '</color>' + size_upgrade_cost;",
                        "}",
                        "if(player_money < armor_upgrade_cost)",
                        "{",
                        "    armor_augment_str = '</color>' + armor_augment;",
                        "    armor_upgrade_cost_str = '</color>' + armor_upgrade_cost;",
                        "}",
                        "if(player_money < level_upgrade_cost)",
                        "{",
                        "    level_upgrade_cost_str = '</color>' + level_upgrade_cost;",
                        "}",
                        "",
                        "TextCorr4 = '';",
                        "tempInt3 = ShipFindCustomShipInfoByType(cur_ruin, 'Teleport_Generator');",
                        "if(~tempInt3)",
                        "{",
                        "    TextCorr4 = '</color>' + Format(CT(\"Script.Mod_ExpHullsBases.1038\"),\"<0>\",ShipCustomShipInfoData(cur_ruin, tempInt3, 1),\"<1>\",ShipCustomShipInfoTextData(cur_ruin, tempInt3, 1));",
                        "}",
                        "",
                        "if(GetGameOptions('FontDialog') == 3) TextCorr = '</color>'+CT(\"Script.Mod_ExpHullsBases.1037\");",
                        "else TextCorr = '</color>' + CT(\"Script.Mod_ExpHullsBases.1036\");",
                        "HullReport = '</color>' + Format(CT('Script.Mod_ExpHullsBases.RuinHullReport'),",
                        "                        '<HullName' + '>', ruin_hull_name,",
                        "                        '<CurrentHitPoints' + '>', HullHP(cur_ruin),",
                        "                        '<FullHitPoints' + '>', cur_ruin_size,",
                        "                        '<ScheduledRepair' + '>', PlanRep,",
                        "                        '<MaxHitPointsText' + '>', TextCorr,",
                        "                        '<MaxHitPoints' + '>', max_ruin_size,",
                        "                        '<CurrentArmor' + '>', cur_ruin_armor,",
                        "                        '<AdditionalArmor' + '>', ShipArmor(cur_ruin) - cur_ruin_armor,",
                        "                        '<MaxArmor' + '>', max_ruin_armor,",
                        "                        '<HullCost' + '>', cur_ruin_cost,",
                        "                        '<AddText' + '>', TextCorr4",
                        "                       );",
                        "if(ruin_str_type == 'PlayerMB') HullReport = HullReport + CT(\"Script.Mod_ExpHullsBases.1034\") + Format(CT('Script.Mod_ExpHullsBases.DialogsPlayerMB.RuinHullReportHQLevel'), '<Level' + '>', PlayerHQMainArray['Main', 'HQLevel']);",
                        "if(!RuinsAllowModernization(cur_ruin)) {",
                        "  tstr1 = '</color>' + Format(CT('Script.Mod_ExpHullsBases.Dialogs' + ruin_str_type + '.GreetingNotImprove'), '<HullReport' + '>', HullReport, '');",
                        "  DChange(28);",
                        "  exit;",
                        "}",
                        "if(RuinsAllowModernization(cur_ruin)) {",
                        "  if(ruin_str_type != 'PlayerMB') tstr1 = '</color>' + Format(CT('Script.Mod_ExpHullsBases.Dialogs' + ruin_str_type + '.GreetingImprove'), '<HullReport' + '>', HullReport, '');",
                        "  else tstr1 = '</color>' + Format(CT('Script.Mod_ExpHullsBases.Dialogs' + ruin_str_type + '.GreetingImprove'), '<HullReport' + '>', HullReport, '<CurrentBalance' + '>', '<color=0,50,200>' + int(PlayerHQMainArray['Finance', 'CurrentBalance']) + '</color>', '');",
                        "  DChange(29);",
                        "  exit;",
                        "}"
                    ],
                    "#": 248,
                    "Type": "Top",
                    "Parent": -1,
                    "Pos.x": -20,
                    "Pos.y": 525
                },
                {
                    "Name": "",
                    "Code.Type": "Turn",
                    "Code": [
                        "if(ruin_str_type == 'WB') {",
                        "  DChange(27);",
                        "  exit;",
                        "}",
                        "if(ruin_str_type == 'SB' ||",
                        "ruin_str_type == 'RC' ||",
                        "ruin_str_type == 'MC' ||",
                        "ruin_str_type == 'BK' ||",
                        "ruin_str_type == 'TC') {",
                        "  DChange(3);",
                        "  exit;",
                        "}",
                        "if(ruin_str_type == 'PB' ||",
                        "ruin_str_type == 'CB') {",
                        "  //Фразы будут немного отличаться, в зависимости от того, проиграли пираты или нет",
                        "  if(!PirateWin() || PirateWin() == 1 || PirateWin() == 2 || PirateWin() == 5) TextCorr = '</color>' + CT(\"Script.Mod_ExpHullsBases.1019\");",
                        "  else TextCorr = '</color>' + CT(\"Script.Mod_ExpHullsBases.1018\");",
                        "  DChange(48);",
                        "  exit;",
                        "}"
                    ],
                    "#": 249,
                    "Type": "Top",
                    "Parent": -1,
                    "Pos.x": 280,
                    "Pos.y": 525
                },
                {
                    "Name": "",
                    "Code.Type": "Turn",
                    "Code": [
                        "if(ShipInGameEvent(cur_ruin)) {",
                        "  if(StarOwner(cur_star) == 0) {",
                        "    DChange(11);",
                        "    exit;",
                        "  }",
                        "}",
                        "if(!ShipInGameEvent(cur_ruin)) {",
                        "  if(ShipRank(Player()) >= (6 - ShipSkill(Player(), 5) / 2)) {",
                        "    if(ShipTurnBeforeEndOrder(cur_ruin) > 1) TextCorr3 = '</color>' + CT(\"Script.Mod_ExpHullsBases.556\");",
                        "    else if(ShipTurnBeforeEndOrder(cur_ruin) == 1) TextCorr3 = '</color>' + CT(\"Script.Mod_ExpHullsBases.555\");",
                        "    if(ShipOrder(cur_ruin) == 1) {",
                        "      DChange(9);",
                        "      exit;",
                        "    }",
                        "    if(ShipOrder(cur_ruin) != 1) {",
                        "      DChange(5);",
                        "      exit;",
                        "    }",
                        "  }",
                        "  if(ShipRank(Player()) < (6 - ShipSkill(Player(), 5) / 2)) {",
                        "    DChange(4);",
                        "    exit;",
                        "  }",
                        "}"
                    ],
                    "#": 250,
                    "Type": "Top",
                    "Parent": -1,
                    "Pos.x": 670,
                    "Pos.y": 525
                },
                {
                    "Name": "",
                    "Code.Type": "Turn",
                    "Code": [
                        "cur_ruin=StarRuins(cur_star,'WB');",
                        "if(RelationToRanger(cur_ruin, Player()) >= 30) {",
                        "  if(StarOwner(cur_star) > 0) {",
                        "    if(ShipOnSidePirateClan(Player())) {",
                        "      DChange(26);",
                        "      exit;",
                        "    }",
                        "    if(!ShipOnSidePirateClan(Player())) {",
                        "      DChange(30);",
                        "      exit;",
                        "    }",
                        "  }",
                        "  if(!StarOwner(cur_star)) {",
                        "    if(ShipOrder(cur_ruin) != 7) {",
                        "      if(!ShipOnSidePirateClan(Player())) {",
                        "        DChange(17);",
                        "        exit;",
                        "      }",
                        "      if(ShipOnSidePirateClan(Player())) {",
                        "        DChange(26);",
                        "        exit;",
                        "      }",
                        "    }",
                        "    if(ShipOrder(cur_ruin) == 7) {",
                        "      DChange(18);",
                        "      exit;",
                        "    }",
                        "  }",
                        "}",
                        "if(RelationToRanger(cur_ruin, Player()) < 30) {",
                        "  if(RelationToRanger(cur_ruin, Player()) >= 10 && ShipGetBad(cur_ruin) != Player()) {",
                        "    DChange(26);",
                        "    exit;",
                        "  }",
                        "  if(RelationToRanger(cur_ruin, Player()) < 10 || ShipGetBad(cur_ruin) == Player()) {",
                        "    DChange(24);",
                        "    exit;",
                        "  }",
                        "}"
                    ],
                    "#": 251,
                    "Type": "Top",
                    "Parent": -1,
                    "Pos.x": 880,
                    "Pos.y": 525
                },
                {
                    "Name": "",
                    "Code.Type": "Turn",
                    "Code": [
                        "cur_star = ShipStar(cur_ruin);",
                        "cur_con = StarToCon(cur_star);",
                        "",
                        "if(ShipInNormalSpace(Player())) TextCorr = '</color>' + CT(\"Script.Mod_ExpHullsBases.629\");",
                        "else",
                        "{",
                        "    TextCorr = '</color>' + CT(\"Script.Mod_ExpHullsBases.656\");",
                        "    if(~ShipFindCustomShipInfoByType(cur_ruin, 'WB_move')) TextCorr2 = '</color>' + CT(\"Script.Mod_ExpHullsBases.612\");",
                        "    else TextCorr2 = '</color>' + CT(\"Script.Mod_ExpHullsBases.581\");",
                        "}",
                        "",
                        "if(~ShipFindCustomShipInfoByType(cur_ruin, 'WB_move')) TextCorr4 = '</color>' + CT(\"Script.Mod_ExpHullsBases.647\");",
                        "else TextCorr4 = '</color>' + CT(\"Script.Mod_ExpHullsBases.648\");",
                        "DChange(7);",
                        "exit;"
                    ],
                    "#": 252,
                    "Type": "Top",
                    "Parent": -1,
                    "Pos.x": 1150,
                    "Pos.y": 525
                },
                {
                    "Name": "",
                    "Code.Type": "Turn",
                    "Code": [
                        "OrderNone(cur_ruin);",
                        "OrderLock(cur_ruin, 0);",
                        "ShipDeleteCustomShipInfo(cur_ruin, 'WB_move');",
                        "if(!ShipInNormalSpace(Player()))",
                        "{",
                        "    InterfaceState('RuinsTalk', 'StarFieldWB', -1);",
                        "    Sound('Sound.ForsageOff');",
                        "}",
                        "DChange(10);",
                        "exit;"
                    ],
                    "#": 253,
                    "Type": "Top",
                    "Parent": -1,
                    "Pos.x": 1270,
                    "Pos.y": 525
                },
                {
                    "Name": "",
                    "Code.Type": "Turn",
                    "Code": [
                        "if(ShipFindCustomShipInfoByType(cur_ruin, 'WB_move') > -1)",
                        "{",
                        "    OrderLock(cur_ruin, 0);",
                        "    ShipDeleteCustomShipInfo(cur_ruin, 'WB_move');",
                        "}",
                        "",
                        "//Выгоняем с базы все корабли перед прыжком",
                        "for(i = 0; i < StarShips(cur_star); i = i + 1)",
