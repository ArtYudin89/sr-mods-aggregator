                    ],
                    "#": 377,
                    "Type": "Top",
                    "Parent": -1,
                    "Pos.x": 1660,
                    "Pos.y": 915
                },
                {
                    "Name": "",
                    "Code.Type": "Turn",
                    "Code": [
                        "HullReport = '';",
                        "TextCorr = '';",
                        "TextCorr2 = '';",
                        "TextCorr3 = '';",
                        "DefSplt = '';",
                        "",
                        "ruin_hull = ShipItems(cur_ruin, 0);",
                        "cur_module = EqModule(ruin_hull);",
                        "cur_hitpoints = HullHP(cur_ruin);",
                        "cur_ruin_techlevel = ItemLevel(ruin_hull);",
                        "",
                        "//Запоминаем число доступных средств игрока для удобства всех последующих проверок",
                        "if(ruin_str_type != 'PlayerMB') player_money = ShipMoney(Player());",
                        "else player_money = max(ShipMoney(Player()), int(PlayerHQMainArray['Finance', 'CurrentBalance']));",
                        "",
                        "ModuleToEquipment(-1, ruin_hull);",
                        "if(ruin_str_type == 'WB')",
                        "{",
                        "    if(GetEquipmentStats(ruin_hull) < cur_ruin_techlevel * 2 + 4) cur_ruin_armor = GetEquipmentStats(ruin_hull);",
                        "    else cur_ruin_armor = cur_ruin_techlevel * 2 + 4;",
                        "}",
                        "else",
                        "{",
                        "    if(GetEquipmentStats(ruin_hull) < cur_ruin_techlevel * 2 + 1) cur_ruin_armor = GetEquipmentStats(ruin_hull);",
                        "    else cur_ruin_armor = cur_ruin_techlevel * 2 + 1;",
                        "    if(cur_ruin_armor >= 17) cur_ruin_armor = 16;",
                        "}",
                        "ModuleToEquipment(cur_module, ruin_hull);",
                        "HullHP(cur_ruin, cur_hitpoints);",
                        "",
                        "if((HullHP(cur_ruin) + ItemSize(ruin_hull) / 10) > ItemSize(ruin_hull))",
                        "{",
                        "    HullRepCount = ItemSize(ruin_hull) - HullHP(cur_ruin);",
                        "}",
                        "else",
                        "{",
                        "    HullRepCount = HullHP(cur_ruin) / 10;",
                        "}",
                        "",
                        "if(HullHP(cur_ruin) < ItemSize(ruin_hull))",
                        "{",
                        "    PlanRep = CT(\"Script.Mod_ExpHullsBases.1034\") + '</color>' + Format(CT(\"Script.Mod_ExpHullsBases.1043\"),\"<0>\",HullRepCount) + CT(\"Script.Mod_ExpHullsBases.1034\") + Format(CT(\"Script.Mod_ExpHullsBases.1042\"),\"<0>\",R_next_repair_turn - CurTurn());",
                        "}",
                        "else",
                        "{",
                        "    PlanRep = '';",
                        "}",
                        "",
                        "cur_ruin_size = ItemSize(ruin_hull);",
                        "cur_ruin_cost = ItemCost(ruin_hull);",
                        "if(ruin_str_type == 'WB') max_ruin_size = ((cur_ruin_techlevel * 400 + 800) * 3) / 2;",
                        "else max_ruin_size = cur_ruin_techlevel * 400 + 800;",
                        "//Расширяем лимит размера станций для мода EvoArmada",
                        "if(IsScriptActive('Mod_EvoArmada')) max_ruin_size = round(1.0 * max_ruin_size * (1.0 + (1.0 * (GalaxyDiffLevels() / 50))));",
                        "",
                        "if(max_ruin_size < ItemSize(ruin_hull)) max_ruin_size = ItemSize(ruin_hull);",
                        "",
                        "if(ruin_str_type == 'WB') max_ruin_armor = cur_ruin_techlevel * 2 + 4;",
                        "else",
                        "{",
                        "    max_ruin_armor = cur_ruin_techlevel * 2 + 1;",
                        "    if(max_ruin_armor >= 17) max_ruin_armor = 16;",
                        "}",
                        "",
                        "if((ItemSize(ruin_hull) + max_ruin_size / 20) > max_ruin_size) size_augmentFloat = max_ruin_size - ItemSize(ruin_hull);",
                        "else size_augmentFloat = max_ruin_size / 20;",
                        "if(max_ruin_size - (ItemSize(ruin_hull) + size_augmentFloat) <= (cur_ruin_techlevel * 10)) size_augmentFloat = max_ruin_size - ItemSize(ruin_hull);",
                        "armor_augment = '1';",
                        "armor_augment_str = armor_augment;",
                        "",
                        "if(~findsubstr(ItemFullName(ruin_hull), CT(\"Script.Mod_ExpHullsBases.1041\")) || ~findsubstr(ItemFullName(ruin_hull), CT(\"Script.Mod_ExpHullsBases.1040\")) || ~findsubstr(ItemFullName(ruin_hull), CT(\"Script.Mod_ExpHullsBases.1039\")))",
                        "{",
                        "    if(~findsubstr(ItemFullName(ruin_hull), CT(\"Script.Mod_ExpHullsBases.1041\"))) ruin_hull_name = CT(\"Script.Mod_ExpHullsBases.1041\");",
                        "    if(~findsubstr(ItemFullName(ruin_hull), CT(\"Script.Mod_ExpHullsBases.1040\"))) ruin_hull_name = CT(\"Script.Mod_ExpHullsBases.1040\");",
                        "    if(~findsubstr(ItemFullName(ruin_hull), CT(\"Script.Mod_ExpHullsBases.1039\"))) ruin_hull_name = CT(\"Script.Mod_ExpHullsBases.1039\");",
                        "}",
                        "else ruin_hull_name = substr(ItemFullName(ruin_hull), 0, findsubstr(ItemFullName(ruin_hull), ' '));",
                        "",
                        "armor_upgrade_cost = (cur_ruin_cost / 22) * (100 - 4 * ShipSkill(Player(), 2)) / 100;",
                        "armor_upgrade_cost = armor_upgrade_cost * (100 - 3 * ShipSkill(Player(), 3)) / 100;",
                        "",
                        "size_upgrade_cost = (cur_ruin_cost / 80) * (100 - 4 * ShipSkill(Player(), 2)) / 100;",
                        "size_upgrade_cost = size_upgrade_cost * (100 - 3 * ShipSkill(Player(), 3)) / 100;",
                        "",
                        "if(size_augmentFloat != max_ruin_size / 20 && size_augmentFloat) size_upgrade_cost = size_augmentFloat / (0.01 * (max_ruin_size / 20)) * (0.01 * size_upgrade_cost);",
                        "size_augment = size_augmentFloat;",
                        "size_augment_str = size_augment;",
                        "",
                        "level_upgrade_cost = (cur_ruin_cost / 10) * (100 - 4 * ShipSkill(Player(), 2)) / 100;",
                        "level_upgrade_cost = level_upgrade_cost * (100 - 3 * ShipSkill(Player(), 3)) / 100;",
                        "",
                        "if(ruin_str_type == 'WB') armor_upgrade_cost = armor_upgrade_cost * 70 / 100;",
                        "if(ruin_str_type == 'SB' || ruin_str_type == 'TC') level_upgrade_cost = level_upgrade_cost * 60 / 100;",
                        "",
                        "armor_upgrade_cost = armor_upgrade_cost + armor_upgrade_cost * (GalaxyDiffLevels(4) - 175) / 400;",
                        "armor_upgrade_cost_str = armor_upgrade_cost;",
                        "size_upgrade_cost = size_upgrade_cost + size_upgrade_cost * (GalaxyDiffLevels(4) - 175) / 300;",
                        "size_upgrade_cost_str = size_upgrade_cost;",
                        "level_upgrade_cost = level_upgrade_cost + level_upgrade_cost * (GalaxyDiffLevels(4) - 175) / 400;",
                        "level_upgrade_cost_str = level_upgrade_cost;",
                        "",
                        "if(player_money < size_upgrade_cost)",
                        "{",
                        "    size_augment_str = '</color>' + size_augment;",
                        "    size_upgrade_cost_str = '</color>' + size_upgrade_cost;",
                        "}",
                        "if(player_money < armor_upgrade_cost)",
                        "{",
                        "    armor_augment_str = '</color>' + armor_augment;",
                        "    armor_upgrade_cost_str = '</color>' + armor_upgrade_cost;",
                        "}",
                        "if(player_money < level_upgrade_cost)",
                        "{",
                        "    level_upgrade_cost_str = '</color>' + level_upgrade_cost;",
                        "}",
                        "",
                        "TextCorr4 = '';",
                        "tempInt3 = ShipFindCustomShipInfoByType(cur_ruin, 'Teleport_Generator');",
                        "if(~tempInt3)",
                        "{",
                        "    TextCorr4 = '</color>' + Format(CT(\"Script.Mod_ExpHullsBases.1038\"),\"<0>\",ShipCustomShipInfoData(cur_ruin, tempInt3, 1),\"<1>\",ShipCustomShipInfoTextData(cur_ruin, tempInt3, 1));",
                        "}",
                        "",
                        "if(GetGameOptions('FontDialog') == 3) TextCorr = '</color>'+CT(\"Script.Mod_ExpHullsBases.1037\");",
                        "else TextCorr = '</color>' + CT(\"Script.Mod_ExpHullsBases.1036\");",
                        "HullReport = '</color>' + Format(CT('Script.Mod_ExpHullsBases.RuinHullReport'),",
                        "                        '<HullName' + '>', ruin_hull_name,",
                        "                        '<CurrentHitPoints' + '>', HullHP(cur_ruin),",
                        "                        '<FullHitPoints' + '>', cur_ruin_size,",
                        "                        '<ScheduledRepair' + '>', PlanRep,",
                        "                        '<MaxHitPointsText' + '>', TextCorr,",
                        "                        '<MaxHitPoints' + '>', max_ruin_size,",
                        "                        '<CurrentArmor' + '>', cur_ruin_armor,",
                        "                        '<AdditionalArmor' + '>', ShipArmor(cur_ruin) - cur_ruin_armor,",
                        "                        '<MaxArmor' + '>', max_ruin_armor,",
                        "                        '<HullCost' + '>', cur_ruin_cost,",
                        "                        '<AddText' + '>', TextCorr4",
                        "                       );",
                        "if(ruin_str_type == 'PlayerMB') HullReport = HullReport + CT(\"Script.Mod_ExpHullsBases.1034\") + Format(CT('Script.Mod_ExpHullsBases.DialogsPlayerMB.RuinHullReportHQLevel'), '<Level' + '>', PlayerHQMainArray['Main', 'HQLevel']);",
                        "if(!RuinsAllowModernization(cur_ruin)) {",
                        "  tstr1 = '</color>' + Format(CT('Script.Mod_ExpHullsBases.Dialogs' + ruin_str_type + '.GreetingNotImprove'), '<HullReport' + '>', HullReport, '');",
                        "  DChange(28);",
                        "  exit;",
                        "}",
                        "if(RuinsAllowModernization(cur_ruin)) {",
                        "  if(ruin_str_type != 'PlayerMB') tstr1 = '</color>' + Format(CT('Script.Mod_ExpHullsBases.Dialogs' + ruin_str_type + '.GreetingImprove'), '<HullReport' + '>', HullReport, '');",
                        "  else tstr1 = '</color>' + Format(CT('Script.Mod_ExpHullsBases.Dialogs' + ruin_str_type + '.GreetingImprove'), '<HullReport' + '>', HullReport, '<CurrentBalance' + '>', '<color=0,50,200>' + int(PlayerHQMainArray['Finance', 'CurrentBalance']) + '</color>', '');",
                        "  DChange(29);",
                        "  exit;",
                        "}"
                    ],
