                    "Code": [
                        "upgrade_cost_portalGen = 1.0 * (60000 + 60000 * (GalaxyDiffLevels(4) - 100) / 400) * (0.5 + (0.25 * (GalaxyTechLevel() - 1)));",
                        "if(GetGameOptions('FontDialog') < 1) TextCorr4 = '</color>' + CT(\"Script.Mod_ExpHullsBases.726\");",
                        "else TextCorr4 = '</color>' + CT(\"Script.Mod_ExpHullsBases.725\");",
