                    "Pos.x": 1060,
                    "Pos.y": 890
                },
                {
                    "Name": "",
                    "Code.Type": "Turn",
                    "Code": [
                        "if(Dist(Player(),ShipStar(Player()))>PlanetOrbitRadius(StarPlanets(ShipStar(Player()),StarPlanets(ShipStar(Player()))-1))+800) {",
                        "  DChange(32);",
                        "  exit;",
                        "}",
                        "if(Dist(Player(),ShipStar(Player()))<600) {",
                        "  DChange(22);",
                        "  exit;",
                        "}",
                        "if(Dist(Player(), cur_star) >= 600 && Dist(Player(), cur_star) <= PlanetOrbitRadius(StarPlanets(cur_star, StarPlanets(cur_star) - 1)) + 800) {",
                        "  destination_planet = Player();",
                        "  DaysLeft = Dist(cur_ruin, destination_planet) / ShipSpeed(cur_ruin);",
                        "  if(DaysLeft <= 0) DaysLeft = 1;",
                        "  if(DaysLeft == 1) TextCorr3 = '</color>' + CT(\"Script.Mod_ExpHullsBases.555\");",
                        "  else TextCorr3 = '</color>' + CT(\"Script.Mod_ExpHullsBases.556\");",
                        "  DChange(21);",
                        "  exit;",
                        "}"
                    ],
                    "#": 371,
                    "Type": "Top",
                    "Parent": -1,
                    "Pos.x": 1180,
                    "Pos.y": 890
                },
                {
                    "Name": "",
                    "Code.Type": "Turn",
                    "Code": [
                        "if(ShipInGameEvent(cur_ruin)) {",
                        "  if(StarOwner(cur_star) == 0) {",
                        "    DChange(11);",
                        "    exit;",
                        "  }",
                        "}",
                        "if(!ShipInGameEvent(cur_ruin)) {",
                        "  if(ShipRank(Player()) >= (6 - ShipSkill(Player(), 5) / 2)) {",
                        "    if(ShipTurnBeforeEndOrder(cur_ruin) > 1) TextCorr3 = '</color>' + CT(\"Script.Mod_ExpHullsBases.556\");",
                        "    else if(ShipTurnBeforeEndOrder(cur_ruin) == 1) TextCorr3 = '</color>' + CT(\"Script.Mod_ExpHullsBases.555\");",
                        "    if(ShipOrder(cur_ruin) == 1) {",
                        "      DChange(9);",
                        "      exit;",
                        "    }",
                        "    if(ShipOrder(cur_ruin) != 1) {",
                        "      DChange(5);",
                        "      exit;",
                        "    }",
                        "  }",
                        "  if(ShipRank(Player()) < (6 - ShipSkill(Player(), 5) / 2)) {",
                        "    DChange(4);",
                        "    exit;",
                        "  }",
                        "}"
                    ],
                    "#": 372,
                    "Type": "Top",
                    "Parent": -1,
                    "Pos.x": 1420,
                    "Pos.y": 890
                },
                {
                    "Name": "",
                    "Code.Type": "Turn",
                    "Code": [
                        "if(ShipFindCustomShipInfoByType(cur_ruin, 'WB_move') == -1) {",
                        "  cur_star = ShipStar(cur_ruin);",
                        "  cur_con = StarToCon(cur_star);",
                        "  ",
                        "  if(ShipInNormalSpace(Player())) TextCorr = '</color>' + CT(\"Script.Mod_ExpHullsBases.629\");",
                        "  else",
                        "  {",
                        "      TextCorr = '</color>' + CT(\"Script.Mod_ExpHullsBases.656\");",
                        "      if(~ShipFindCustomShipInfoByType(cur_ruin, 'WB_move')) TextCorr2 = '</color>' + CT(\"Script.Mod_ExpHullsBases.612\");",
                        "      else TextCorr2 = '</color>' + CT(\"Script.Mod_ExpHullsBases.581\");",
                        "  }",
                        "  ",
                        "  if(~ShipFindCustomShipInfoByType(cur_ruin, 'WB_move')) TextCorr4 = '</color>' + CT(\"Script.Mod_ExpHullsBases.647\");",
                        "  else TextCorr4 = '</color>' + CT(\"Script.Mod_ExpHullsBases.648\");",
                        "  DChange(7);",
                        "  exit;",
                        "}",
                        "if(~ShipFindCustomShipInfoByType(cur_ruin, 'WB_move')) {",
                        "  DChange(9);",
                        "  exit;",
                        "}"
                    ],
