                    "_orig_danswer": "DAnswer('restart~'+CT(\"Script.Mod_ExpHullsBases.834\"))"
                },
                {
                    "Name": "",
                    "Pos.x": 1560,
                    "Pos.y": 940,
                    "Type": "TDialogAnswer",
                    "Parent": -1,
                    "#": 235,
                    "Msg": "Скачок!",
                    "AMsg.Num": "58",
                    "_orig_danswer": "DAnswer(CT(\"Script.Mod_ExpHullsBases.974\"))"
                },
                {
                    "Name": "",
                    "Pos.x": 1680,
                    "Pos.y": 940,
                    "Type": "TDialogAnswer",
                    "Parent": -1,
                    "#": 236,
                    "Msg": "Расслабиться и наслаждаться полётом",
                    "AMsg.Num": "59",
                    "_orig_danswer": "DAnswer(CT(\"Script.Mod_ExpHullsBases.972\"))"
                },
                {
                    "Name": "hangar",
                    "Pos.x": 0,
                    "Pos.y": 965,
                    "Type": "TDialogAnswer",
                    "Parent": -1,
                    "#": 237,
                    "Msg": "Вы правы, лучше я укажу координаты <color=0,50,200>своим кораблём</color> (в ангар)",
                    "AMsg.Num": "60",
                    "_orig_danswer": "DAnswer('hangar~'+CT(\"Script.Mod_ExpHullsBases.942\"))"
                },
                {
                    "Name": "",
                    "Pos.x": 120,
                    "Pos.y": 965,
                    "Type": "TDialogAnswer",
                    "Parent": -1,
                    "#": 238,
                    "Msg": "Я передумал, смена позиции вам сейчас ни к чему",
                    "AMsg.Num": "61",
                    "_orig_danswer": "DAnswer(CT(\"Script.Mod_ExpHullsBases.903\"))"
                },
                {
                    "Name": "",
                    "Pos.x": 240,
                    "Pos.y": 965,
                    "Type": "TDialogAnswer",
                    "Parent": -1,
                    "#": 239,
                    "Msg": "Скачок подтверждаю, приступайте",
                    "AMsg.Num": "62",
                    "_orig_danswer": "DAnswer(CT(\"Script.Mod_ExpHullsBases.869\"))"
                },
                {
                    "Name": "",
                    "Pos.x": 360,
                    "Pos.y": 965,
                    "Type": "TDialogAnswer",
                    "Parent": -1,
                    "#": 240,
                    "Msg": "Отмена перемещения, сдувайте ваш пузырь",
                    "AMsg.Num": "63",
                    "_orig_danswer": "DAnswer(CT(\"Script.Mod_ExpHullsBases.870\"))"
                },
                {
                    "Name": "",
                    "Pos.x": 480,
                    "Pos.y": 965,
                    "Type": "TDialogAnswer",
                    "Parent": -1,
                    "#": 241,
                    "Msg": "Скачок!",
                    "AMsg.Num": "64",
                    "_orig_danswer": "DAnswer(CT(\"Script.Mod_ExpHullsBases.974\"))"
                },
                {
                    "Name": "restart",
                    "Pos.x": 600,
                    "Pos.y": 965,
                    "Type": "TDialogAnswer",
                    "Parent": -1,
                    "#": 242,
                    "Msg": "Далее",
                    "AMsg.Num": "65",
                    "_orig_danswer": "DAnswer('restart~'+CT(\"Script.Mod_ExpHullsBases.834\"))"
                },
                {
                    "Name": "restart",
                    "Pos.x": 720,
                    "Pos.y": 965,
                    "Type": "TDialogAnswer",
                    "Parent": -1,
                    "#": 243,
                    "Msg": "Конец связи",
                    "AMsg.Num": "66",
                    "_orig_danswer": "DAnswer('restart~'+CT(\"Script.Mod_ExpHullsBases.314\"))"
                },
                {
                    "Name": "exit",
                    "Pos.x": 840,
                    "Pos.y": 965,
                    "Type": "TDialogAnswer",
                    "Parent": -1,
                    "#": 244,
                    "Msg": "",
                    "AMsg.Num": "67",
