                        "//Разряжаем портальный генератор на одну треть",
                        "ShipCustomShipInfoData(cur_ruin,k,3,round(ShipCustomShipInfoData(cur_ruin,k,2)/3));",
                        "ShipCustomShipInfoTextData(cur_ruin,k,1,''+ShipCustomShipInfoData(cur_ruin,k,3)+CT(\"Script.Mod_ExpHullsBases.742\"));",
