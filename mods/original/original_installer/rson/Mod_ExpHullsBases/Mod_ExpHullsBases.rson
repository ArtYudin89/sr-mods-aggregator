                        "          temp_ruin = StarRuins(cur_star, k);",
                        "          if (temp_ruin == cur_ruin) continue;",
                        "          if (Dist(Player(), StarRuins(cur_star, k)) < 300) {",
                        "              check = 1;",
                        "              break;",
                        "          } else if (ShipOrder(temp_ruin) == 7) {",
                        "              tempInt1 = round(sqrt(sqr(CoordX(Player()) - ShipCustomShipInfoData(temp_ruin, 'ExpHullsBases_TeleportCoords', 1)) +  sqr(CoordY(Player()) - ShipCustomShipInfoData(temp_ruin, 'ExpHullsBases_TeleportCoords', 2))));",
                        "              if (tempInt1 < 300) {",
                        "                  check = 2;",
                        "                  break;",
                        "              }",
                        "          }",
                        "      }",
                        "  }",
                        "  if(!check) {",
                        "    if(j == -1)",
                        "    {",
                        "        TextCorr = CT(\"Script.Mod_ExpHullsBases.907\");",
                        "    }",
                        "    else",
                        "    {",
                        "        TextCorr = '</color>' + Format(CT(\"Script.Mod_ExpHullsBases.906\"),\"<0>\",PlanetName(j));",
                        "        j = Id(j);",
                        "    }",
                        "    if(ShipType(cur_ruin)=='SB')TextCorr2='</color>'+Format(CT(\"Script.Mod_ExpHullsBases.951\"),\"<0>\",ShipName(cur_ruin))+' '+CT(\"Script.Mod_ExpHullsBases.905\");",
                        "    else if(ShipType(cur_ruin)=='RC')TextCorr2='</color>'+Format(CT(\"Script.Mod_ExpHullsBases.950\"),\"<0>\",ShipName(cur_ruin))+' '+CT(\"Script.Mod_ExpHullsBases.904\");",
                        "    else if(ShipType(cur_ruin)=='MC')TextCorr2='</color>'+Format(CT(\"Script.Mod_ExpHullsBases.949\"),\"<0>\",ShipName(cur_ruin))+' '+CT(\"Script.Mod_ExpHullsBases.904\");",
                        "    else if(ShipType(cur_ruin)=='BK')TextCorr2='</color>'+Format(CT(\"Script.Mod_ExpHullsBases.948\"),\"<0>\",ShipName(cur_ruin))+' '+CT(\"Script.Mod_ExpHullsBases.904\");",
                        "    else if(ShipType(cur_ruin)=='TC')TextCorr2='</color>'+Format(CT(\"Script.Mod_ExpHullsBases.947\"),\"<0>\",ShipName(cur_ruin))+' '+CT(\"Script.Mod_ExpHullsBases.904\");",
                        "    else if(ShipType(cur_ruin)=='PB')TextCorr2='</color>'+Format(CT(\"Script.Mod_ExpHullsBases.1048\"),\"<0>\",ShipName(cur_ruin))+' '+CT(\"Script.Mod_ExpHullsBases.905\");",
                        "    if(!PlayerBridge())Sound('Sound.PG_Activation');",
                        "    jumpCheck='ShortJumpReady';",
                        "    tempInt2=Id(cur_ruin);",
                        "    GotoGov(2);",
                        "    DChange(60);",
                        "    exit;",
                        "  }",
                        "  if(check == 1) {",
                        "    DChange(72);",
                        "    exit;",
                        "  }",
                        "  if(check == 2) {",
                        "    DChange(73);",
                        "    exit;",
                        "  }",
                        "}"
                    ],
                    "#": 269,
                    "Type": "Top",
                    "Parent": -1,
                    "Pos.x": 1720,
                    "Pos.y": 550
                },
                {
                    "Name": "",
                    "Code.Type": "Turn",
                    "Code": [
                        "DChange(59);",
                        "exit;"
                    ],
                    "#": 270,
                    "Type": "Top",
                    "Parent": -1,
                    "Pos.x": -20,
                    "Pos.y": 575
                },
                {
                    "Name": "",
                    "Code.Type": "Turn",
                    "Code": [
                        "cur_ruin = IdToShip(tempInt2);",
                        "SkipGreeting();",
                        "DChange(60);",
                        "exit;"
                    ],
                    "#": 271,
                    "Type": "Top",
                    "Parent": -1,
                    "Pos.x": 100,
                    "Pos.y": 575
                },
                {
                    "Name": "",
                    "Code.Type": "Turn",
                    "Code": [
                        "cur_ruin=IdToShip(tempInt2);",
                        "SkipGreeting();",
                        "DChange(50);",
                        "exit;"
                    ],
                    "#": 272,
                    "Type": "Top",
                    "Parent": -1,
                    "Pos.x": 310,
                    "Pos.y": 575
                },
                {
                    "Name": "",
                    "Code.Type": "Turn",
                    "Code": [
                        "cur_ruin=IdToShip(tempInt2);",
                        "SkipGreeting();",
                        "DChange(43);",
                        "exit;"
                    ],
                    "#": 273,
                    "Type": "Top",
                    "Parent": -1,
                    "Pos.x": 520,
                    "Pos.y": 575
                },
                {
                    "Name": "",
                    "Code.Type": "Turn",
                    "Code": [
                        "if(!cur_ruin)cur_ruin=GAnswerData;",
                        "if(ShipType(cur_ruin)=='SB')TextCorr='</color>'+Format(CT(\"Script.Mod_ExpHullsBases.918\"),\"<0>\",ShipName(cur_ruin));",
                        "else if(ShipType(cur_ruin)=='RC')TextCorr='</color>'+Format(CT(\"Script.Mod_ExpHullsBases.917\"),\"<0>\",ShipName(cur_ruin));",
                        "else if(ShipType(cur_ruin)=='MC')TextCorr='</color>'+Format(CT(\"Script.Mod_ExpHullsBases.916\"),\"<0>\",ShipName(cur_ruin));",
                        "else if(ShipType(cur_ruin)=='BK')TextCorr='</color>'+Format(CT(\"Script.Mod_ExpHullsBases.915\"),\"<0>\",ShipName(cur_ruin));",
                        "else if(ShipType(cur_ruin)=='TC')TextCorr='</color>'+Format(CT(\"Script.Mod_ExpHullsBases.914\"),\"<0>\",ShipName(cur_ruin));",
                        "else if(ShipType(cur_ruin)=='PB')TextCorr='</color>'+Format(CT(\"Script.Mod_ExpHullsBases.1047\"),\"<0>\",ShipName(cur_ruin));",
                        "if(RelationToRanger(cur_ruin,Player())>=30) {",
                        "  if(StarBattle(cur_star)) {",
                        "    DChange(65);",
                        "    exit;",
                        "  }",
                        "  if(!StarBattle(cur_star)) {",
                        "    DChange(64);",
                        "    exit;",
                        "  }",
                        "}",
                        "if(RelationToRanger(cur_ruin,Player())<30) {",
                        "  if(RelationToRanger(cur_ruin,Player())>=10 && ShipGetBad(cur_ruin)!=Player())",
                        "  {",
                        "      TextCorr2='</color>'+Format(CT(\"Script.Mod_ExpHullsBases.999\"),\"<0>\",TextCorr);",
                        "  }",
                        "  else",
                        "  {",
                        "      TextCorr2='</color>'+Format(CT(\"Script.Mod_ExpHullsBases.922\"),\"<0>\",TextCorr);",
                        "  }",
                        "  DChange(63);",
                        "  exit;",
                        "}"
                    ],
                    "#": 274,
                    "Type": "Top",
                    "Parent": -1,
                    "Pos.x": 730,
                    "Pos.y": 575
                },
                {
                    "Name": "",
                    "Code.Type": "Turn",
                    "Code": [
                        "check = 1; //Маркер для вывода реплики собеседника",
                        "",
                        "//Увеличение размера",
                        "if(GAnswerData == 1)",
                        "{",
                        "    if(ruin_str_type == 'PlayerMB')",
                        "    {",
                        "        check = PlayerHQPayCheck(size_upgrade_cost);",
                        "        if(!check)",
                        "        {",
                        "            //В реплике собеседника подставлена именно эта переменная, поэтому возвращаем в неё исходное значение",
                        "            tstr1 = '</color>' + Format(CT('Script.Mod_ExpHullsBases.Dialogs' + ruin_str_type + '.GreetingImprove'), '<HullReport' + '>', HullReport, '');",
                        "            exit;",
                        "        }",
                        "    }",
                        "    else ShipMoney(Player(), ShipMoney(Player()) - size_upgrade_cost);",
                        "",
                        "    ItemSize(ShipItems(cur_ruin, 0), cur_ruin_size + size_augment);",
                        "    HullHP(cur_ruin, HullHP(cur_ruin) + size_augment);",
                        "    ItemCost(ShipItems(cur_ruin, 0), cur_ruin_cost + cur_ruin_cost / 7);",
                        "",
                        "    if(ruin_str_type == 'WB') tstr1 = '</color>' + CT(\"Script.Mod_ExpHullsBases.407\");",
                        "    else if(ruin_str_type == 'PlayerMB')",
                        "    {",
                        "        tstr1 = '</color>' + CT('Script.Mod_ExpHullsBases.DialogsPlayerMB.HullStructureIncreased');",
                        "    }",
                        "    else tstr1 = '</color>' + CT(\"Script.Mod_ExpHullsBases.404\");",
                        "    tstr2 = '</color>' + CT(\"Script.Mod_ExpHullsBases.179\");",
                        "",
                        "    Sound('Sound.Repair');",
                        "}",
                        "//Усиление брони",
                        "else if(GAnswerData == 2)",
                        "{",
                        "    if(ruin_str_type == 'PlayerMB')",
                        "    {",
                        "        check = PlayerHQPayCheck(armor_upgrade_cost);",
                        "        if(!check)",
                        "        {",
                        "            //В реплике собеседника подставлена именно эта переменная, поэтому возвращаем в неё исходное значение",
                        "            tstr1 = '</color>' + Format(CT('Script.Mod_ExpHullsBases.Dialogs' + ruin_str_type + '.GreetingImprove'), '<HullReport' + '>', HullReport, '');",
                        "            exit;",
                        "        }",
                        "    }",
                        "    else ShipMoney(Player(), ShipMoney(Player()) - armor_upgrade_cost);",
                        "",
                        "    SetEquipmentStats(ShipItems(cur_ruin, 0), GetEquipmentStats(ShipItems(cur_ruin, 0)) + armor_augment);",
                        "    ItemCost(ShipItems(cur_ruin, 0), cur_ruin_cost + cur_ruin_cost * 4 / 10);",
                        "",
                        "    if(ruin_str_type == 'WB') tstr1 = '</color>' + CT(\"Script.Mod_ExpHullsBases.472\");",
                        "    else if(ruin_str_type == 'PlayerMB')",
                        "    {",
                        "        tstr1 = '</color>' + CT('Script.Mod_ExpHullsBases.DialogsPlayerMB.HullArmorIncreased');",
                        "    }",
                        "    else tstr1 = '</color>' + CT(\"Script.Mod_ExpHullsBases.487\");",
                        "    tstr2 = '</color>' + CT(\"Script.Mod_ExpHullsBases.179\");",
                        "",
                        "    Sound('Sound.Repair');",
                        "}",
                        "//Повышение ТУ корпуса",
                        "else if(GAnswerData == 3)",
                        "{",
                        "    if(ruin_str_type == 'PlayerMB')",
                        "    {",
                        "        check = PlayerHQPayCheck(level_upgrade_cost);",
                        "        if(!check)",
                        "        {",
                        "            //В реплике собеседника подставлена именно эта переменная, поэтому возвращаем в неё исходное значение",
                        "            tstr1 = '</color>' + Format(CT('Script.Mod_ExpHullsBases.Dialogs' + ruin_str_type + '.GreetingImprove'), '<HullReport' + '>', HullReport, '');",
                        "            exit;",
                        "        }",
                        "    }",
                        "    else ShipMoney(Player(), ShipMoney(Player()) - level_upgrade_cost);",
                        "",
                        "    ItemLevel(ShipItems(cur_ruin, 0), ItemLevel(ShipItems(cur_ruin, 0)) + 1);",
                        "    ItemCost(ShipItems(cur_ruin, 0), cur_ruin_cost + cur_ruin_cost / 3);",
                        "",
                        "    if(ruin_str_type == 'WB') tstr1 = '</color>' + CT(\"Script.Mod_ExpHullsBases.475\");",
                        "    else if(ruin_str_type == 'PlayerMB')",
                        "    {",
                        "        tstr1 = '</color>' + CT('Script.Mod_ExpHullsBases.DialogsPlayerMB.HullLevelIncreased');",
                        "    }",
                        "    else tstr1 = '</color>' + CT(\"Script.Mod_ExpHullsBases.484\");",
                        "    tstr2 = '</color>' + CT(\"Script.Mod_ExpHullsBases.179\");",
                        "",
                        "    Sound('Sound.Repair');",
                        "}",
                        "//Установка ГСОМ",
                        "else if(GAnswerData == 4)",
                        "{",
                        "    if(ruin_str_type == 'PlayerMB')",
                        "    {",
                        "        check = PlayerHQPayCheck(upgrade_cost_gsom);",
                        "        if(!check)",
                        "        {",
                        "            exit;",
                        "        }",
                        "    }",
                        "    else ShipMoney(Player(), ShipMoney(Player()) - upgrade_cost_gsom);",
                        "",
                        "    EqSpecial(ShipItems(cur_ruin, 0), FindBonusByCustomTag('ExpHullsBases_GSOM'));",
                        "    if(ruin_str_type == 'WB') tstr1 = '</color>' + CT(\"Script.Mod_ExpHullsBases.493\");",
                        "    else if(ruin_str_type == 'PlayerMB')",
                        "    {",
                        "        tstr1 = '</color>' + CT('Script.Mod_ExpHullsBases.DialogsPlayerMB.GSOMInstalled');",
                        "    }",
                        "    else tstr1 = '</color>' + CT(\"Script.Mod_ExpHullsBases.492\");",
                        "    tstr2 = '</color>' + CT(\"Script.Mod_ExpHullsBases.179\");",
                        "",
                        "    Sound('Sound.Repair');",
                        "}",
                        "//Установка \"Урагана\"",
                        "else if(GAnswerData == 5)",
                        "{",
                        "    if(ruin_str_type == 'PlayerMB')",
                        "    {",
                        "        check = PlayerHQPayCheck(upgrade_cost_hurricane);",
                        "        if(!check)",
                        "        {",
                        "            exit;",
                        "        }",
                        "    }",
                        "    else ShipMoney(Player(), ShipMoney(Player()) - upgrade_cost_hurricane);",
                        "",
                        "    EqSpecial(ShipItems(cur_ruin, 0), FindBonusByCustomTag('ExpHullsBases_Hurricane'));",
                        "    if(ruin_str_type == 'WB') tstr1 = '</color>' + CT(\"Script.Mod_ExpHullsBases.463\");",
                        "    else if(ruin_str_type == 'PlayerMB')",
                        "    {",
                        "        tstr1 = '</color>' + CT('Script.Mod_ExpHullsBases.DialogsPlayerMB.HurricaneInstalled');",
                        "    }",
                        "    else tstr1 = '</color>' + CT(\"Script.Mod_ExpHullsBases.491\");",
                        "    tstr2 = '</color>' + CT(\"Script.Mod_ExpHullsBases.179\");",
                        "",
                        "    Sound('Sound.Repair');",
                        "}",
                        "//Установка поликсенатной брони",
                        "else if(GAnswerData == 6)",
                        "{",
                        "    if(ruin_str_type == 'PlayerMB')",
                        "    {",
                        "        check = PlayerHQPayCheck(upgrade_cost_polyxen);",
                        "        if(!check)",
                        "        {",
                        "            exit;",
                        "        }",
                        "    }",
                        "    else ShipMoney(Player(), ShipMoney(Player()) - upgrade_cost_polyxen);",
                        "",
                        "    EqSpecial(ShipItems(cur_ruin, 0), FindBonusByCustomTag('ExpHullsBases_Polyxen'));",
                        "    ItemCost(ShipItems(cur_ruin, 0), ItemCost(ShipItems(cur_ruin, 0)) / 2);",
                        "",
                        "    if(ruin_str_type == 'WB') tstr1 = '</color>' + CT(\"Script.Mod_ExpHullsBases.468\");",
                        "    else if(ruin_str_type == 'PlayerMB')",
                        "    {",
                        "        tstr1 = '</color>' + CT('Script.Mod_ExpHullsBases.DialogsPlayerMB.PolyxenInstalled');",
                        "    }",
                        "    else tstr1 = '</color>' + CT(\"Script.Mod_ExpHullsBases.490\");",
                        "    tstr2 = '</color>' + CT(\"Script.Mod_ExpHullsBases.179\");",
                        "",
                        "    Sound('Sound.Repair');",
                        "}",
                        "//Установка портального генератора",
                        "else if(GAnswerData == 7)",
                        "{",
                        "    if(ruin_str_type == 'PlayerMB')",
                        "    {",
                        "        check = PlayerHQPayCheck(upgrade_cost_portalGen);",
                        "        if(!check)",
                        "        {",
                        "            exit;",
                        "        }",
                        "    }",
                        "    else ShipMoney(Player(), ShipMoney(Player()) - upgrade_cost_portalGen);",
                        "",
                        "    //Data1 - дальность скачка",
                        "    //Data2 - время до полной зарядки",
                        "    //Data3 - осталось дней до зарядки",
                        "    //TextData1 - вывод оставшихся до зарядки дней в строку",
                        "    //TextData2 - режим поведения станции при атаке (по умолчанию '')",
                        "    //TextData3 - отметка 'InHyper', пока станция находится в гиперпространстве (во всё остальное время '')",
                        "    if(ruin_str_type == 'BK') ShipAddCustomShipInfo(cur_ruin, 'Teleport_Generator', '', 12, 45, 45, '45' + CT(\"Script.Mod_ExpHullsBases.742\"), '50');",
                        "    else ShipAddCustomShipInfo(cur_ruin, 'Teleport_Generator', '', 12, 45, 45, '45' + CT(\"Script.Mod_ExpHullsBases.742\"), '');",
                        "    i = ShipFindCustomShipInfoByType(cur_ruin, 'Teleport_Generator');",
                        "    ShipCustomShipInfoDescription(cur_ruin, i, CT(\"Script.Mod_ExpHullsBases.759\") + CT('FormInfo.br') + CT(\"Script.Mod_ExpHullsBases.774\") + CT('FormInfo.br') + '<clr><clrEnd>' + CT('FormInfo.br') + CT(\"Script.Mod_ExpHullsBases.726\") + ' <' + 'Data1' + '> ' + CT(\"Script.Mod_ExpHullsBases.757\") + CT('FormInfo.br') + CT(\"Script.Mod_ExpHullsBases.762\") + ' <' + 'TextData1' + '>');",
                        "",
                        "    if(ruin_str_type == 'PlayerMB')",
                        "    {",
                        "        tstr1 = '</color>' + Format(CT('Script.Mod_ExpHullsBases.DialogsPlayerMB.PortalGeneratorInstalled'), '<Days' + '>', ShipCustomShipInfoData(cur_ruin, i, 2));",
                        "    }",
                        "    else tstr1 = '</color>' + Format(CT(\"Script.Mod_ExpHullsBases.1028\"),\"<0>\",ShipCustomShipInfoData(cur_ruin, i, 2));",
                        "    tstr2 = '</color>' + CT(\"Script.Mod_ExpHullsBases.179\");",
                        "",
                        "    Sound('Sound.Repair');",
                        "}",
                        "//Установка доп. энергоядра",
                        "else if(GAnswerData == 8 || GAnswerData == 9)",
                        "{",
                        "    if(ruin_str_type == 'PlayerMB')",
                        "    {",
                        "        check = PlayerHQPayCheck(upgrade_cost_portalGen);",
                        "        if(!check)",
                        "        {",
                        "            exit;",
                        "        }",
                        "    }",
                        "    else ShipMoney(Player(), ShipMoney(Player()) - upgrade_cost_portalGen);",
                        "",
                        "    if(GAnswerData == 8)",
                        "    {",
                        "        //Закрываем орудийный слот",
                        "        ShipSpecialBonuses(cur_ruin, bonSlotWeapon, ShipSpecialBonuses(cur_ruin, bonSlotWeapon) - 1);",
                        "    }",
                        "    else",
                        "    {",
                        "        //Закрываем артефактный слот",
                        "        ShipSpecialBonuses(cur_ruin, bonSlotArt, ShipSpecialBonuses(cur_ruin, bonSlotArt) - 1);",
                        "    }",
                        "",
                        "    //Улучшаем параметры портального генератора",
                        "    ShipCustomShipInfoData(cur_ruin, i, 1, ShipCustomShipInfoData(cur_ruin, i, 1) + 12);",
                        "    if(ShipCustomShipInfoData(cur_ruin, i, 3))",
                        "    {",
                        "        tempFloat1 = (1.0 * ShipCustomShipInfoData(cur_ruin, i, 3)) / (0.01 * ShipCustomShipInfoData(cur_ruin, i, 2));",
                        "        ShipCustomShipInfoData(cur_ruin, i, 2, ShipCustomShipInfoData(cur_ruin, i, 2) - 10);",
                        "        ShipCustomShipInfoData(cur_ruin, i, 3, round(tempFloat1 * (0.01 * ShipCustomShipInfoData(cur_ruin, i, 2))));",
                        "        if(ShipCustomShipInfoData(cur_ruin, i, 3)) ShipCustomShipInfoTextData(cur_ruin, i, 1, '' + ShipCustomShipInfoData(cur_ruin, i, 3) + CT(\"Script.Mod_ExpHullsBases.742\"));",
                        "        else ShipCustomShipInfoTextData(cur_ruin, i, 1, CT(\"Script.Mod_ExpHullsBases.765\"));",
                        "    }",
                        "    else",
                        "    {",
                        "        ShipCustomShipInfoData(cur_ruin, i, 2, ShipCustomShipInfoData(cur_ruin, i, 2) - 10);",
                        "        ShipCustomShipInfoData(cur_ruin, i, 3, 0);",
                        "        ShipCustomShipInfoTextData(cur_ruin, i, 1, CT(\"Script.Mod_ExpHullsBases.765\"));",
                        "    }",
                        "",
                        "    //Улучшаем общие параметры станции",
                        "    ShipSpecialBonuses(cur_ruin, bonWEnergy, ShipSpecialBonuses(cur_ruin, bonWEnergy) + 7);",
                        "    ShipSpecialBonuses(cur_ruin, bonRadar, ShipSpecialBonuses(cur_ruin, bonRadar) + 250);",
                        "    ShipSpecialBonuses(cur_ruin, bonScan, ShipSpecialBonuses(cur_ruin, bonScan) + 5);",
                        "    ShipSpecialBonuses(cur_ruin, bonHook, ShipSpecialBonuses(cur_ruin, bonHook) + 25);",
                        "    ShipSpecialBonuses(cur_ruin, bonHookMaxSpeed, ShipSpecialBonuses(cur_ruin, bonHookMaxSpeed) + 3);",
                        "    ShipSpecialBonuses(cur_ruin, bonHookMinSpeed, ShipSpecialBonuses(cur_ruin, bonHookMinSpeed) + 3);",
                        "    ShipSpecialBonuses(cur_ruin, bonHookRadius, ShipSpecialBonuses(cur_ruin, bonHookRadius) + 25);",
                        "    ShipSpecialBonuses(cur_ruin, bonDef, ShipSpecialBonuses(cur_ruin, bonDef) + 5);",
                        "",
                        "    //Обновляем (или добавляем) энергоядерную инфошку",
                        "    if(k <= -1)",
                        "    {",
                        "        ShipAddCustomShipInfo(cur_ruin, 'Extra_Powercores', CT(\"Script.Mod_ExpHullsBases.772\") + Format(CT(\"Script.Mod_ExpHullsBases.1027\"),\"<0>\",tempInt3 * 7,\"<1>\",tempInt3 * 250,\"<2>\",tempInt3 * 5,\"<3>\",tempInt3 * 25,\"<4>\",tempInt3 * 25,\"<5>\",tempInt3 * 3,\"<6>\",tempInt3 * 5), 1);",
                        "        k = ShipFindCustomShipInfoByType(cur_ruin, 'Extra_Powercores');",
                        "    }",
                        "    else",
                        "    {",
                        "        tempInt3 = tempInt3 + 1;",
                        "        ShipCustomShipInfoData(cur_ruin, k, 1, tempInt3);",
                        "        ShipCustomShipInfoDescription(cur_ruin, k, Format(CT(\"Script.Mod_ExpHullsBases.777\"),\"<0>\",tempInt3) + Format(CT(\"Script.Mod_ExpHullsBases.1027\"),\"<0>\",tempInt3 * 7,\"<1>\",tempInt3 * 250,\"<2>\",tempInt3 * 5,\"<3>\",tempInt3 * 25,\"<4>\",tempInt3 * 25,\"<5>\",tempInt3 * 3,\"<6>\",tempInt3 * 5), 1);",
                        "    }",
                        "",
                        "    if(ruin_str_type == 'PlayerMB')",
                        "    {",
                        "        tstr2 = '</color>' + CT('Script.Mod_ExpHullsBases.DialogsPlayerMB.PowerCore' + ShipCustomShipInfoData(cur_ruin, k, 1));",
                        "        tstr1 = '</color>' + Format(CT('Script.Mod_ExpHullsBases.DialogsPlayerMB.PortalGeneratorInstalled'), '<AddText' + '>', tstr2);",
                        "    }",
                        "    else",
                        "    {",
                        "        if(ShipCustomShipInfoData(cur_ruin, k, 1) == 1) TextCorr2 = '</color> ' + CT(\"Script.Mod_ExpHullsBases.712\");",
                        "        else if(ShipCustomShipInfoData(cur_ruin, k, 1) == 2) TextCorr2 = '</color>' + CT(\"Script.Mod_ExpHullsBases.1029\");",
                        "        else if(ShipCustomShipInfoData(cur_ruin, k, 1) == 3) TextCorr2 = '</color> ' + CT(\"Script.Mod_ExpHullsBases.783\");",
                        "        else if(ShipCustomShipInfoData(cur_ruin, k, 1) == 4) TextCorr2 = '</color>' + CT(\"Script.Mod_ExpHullsBases.781\");",
                        "",
                        "        tstr1 = '</color>' + Format(CT(\"Script.Mod_ExpHullsBases.780\"),\"<0>\",TextCorr2);",
                        "    }",
                        "    tstr2 = '</color>' + CT(\"Script.Mod_ExpHullsBases.179\");",
                        "",
                        "    Sound('Sound.Repair');",
                        "}",
                        "//Повышение уровня штаба игрока для мода ShuMercs",
                        "else if(GAnswerData == 10)",
                        "{",
                        "    if(!GotoGov())",
                        "    {",
                        "        check = PlayerHQPayCheck(cost);",
                        "        if(check)",
                        "        {",
                        "            tstr1 = '</color>' + CT('Script.Mod_ExpHullsBases.DialogsPlayerMB.HQLevelUp' + (PlayerHQMainArray['Main', 'HQLevel'] + 1));",
                        "            tstr2 = '</color>' + CT('Script.Mod_ExpHullsBases.DialogsPlayerMB.PlayerHQLevelUp');",
                        "",
                        "            //Лочим игрока на этом диалоге, пока не нажмёт ответ \"Отлично!\"",
                        "            //Нужно, чтобы уровень штаба реально повысился, а это происходит только в скрипте ShuMercs (здесь только выводим реплики и списываем деньги)",
                        "            GotoGov(2);",
                        "",
                        "            Sound('Sound.Repair');",
                        "            Sound('Sound.QuestOk');",
                        "        }",
                        "        else",
                        "        {",
                        "            //В реплике собеседника подставлена именно эта переменная, поэтому возвращаем в неё исходное значение",
                        "            tstr1 = '</color>' + Format(CT('Script.Mod_ExpHullsBases.Dialogs' + ruin_str_type + '.GreetingImprove'), '<HullReport' + '>', HullReport, '<CurrentBalance' + '>', '<color=0,50,200>' + int(PlayerHQMainArray['Finance', 'CurrentBalance']) + '</color>', '');",
                        "        }",
                        "    }",
                        "    else",
                        "    {",
                        "        tstr1 = '</color>' + CT('Script.Mod_ExpHullsBases.DialogsPlayerMB.HQLevelUp' + (PlayerHQMainArray['Main', 'HQLevel'] + 1));",
                        "        tstr2 = '</color>' + CT('Script.Mod_ExpHullsBases.DialogsPlayerMB.PlayerHQLevelUp');",
                        "    }",
                        "}",
                        "if(check) {",
                        "  DChange(71);",
                        "  exit;",
                        "}"
                    ],
