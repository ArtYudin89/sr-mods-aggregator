                        "   if (has_arm>arm_plan) has_arm=arm_plan; //Если кол-во превысило план, занижаем до плана",
                        " ",
                        "   //Ниже мы рождаем корабли по одному",
                        "   if (GroupCount(Insurgents)==0 && rev_date>CurTurn())",
                        "   {",
                        "   korsar=BuyWarrior(pl2,Rnd(300,400));",
