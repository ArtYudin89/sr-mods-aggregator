                        "  if (CountTurn(CurShip,pl2)>1) OrderForsage(CurShip,1);",
                        "  else OrderForsage(CurShip,0);",
                        "  OrderLanding(CurShip,pl2,1);",
                        "}",
                        "if(HullDamage(CurShip)<=50) {",
                        "  korsar=CurShip;",
                        "  ShipOut(korsar);",
                        "  ShipJoin(Insurgents,korsar);",
                        "}"
