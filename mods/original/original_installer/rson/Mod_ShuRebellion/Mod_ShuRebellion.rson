                        "if (GetData(1,CurShip)>0 && GetData(1,CurShip)<100000) ItemSize(ShipItems(CurShip,0),GetData(1,CurShip));",
                        "if(state_rev==0) {",
                        "  ShipOut(CurShip);",
                        "}",
