                        "   if (PlanetRace(pl2)==1) path='RPE';",
                        "   if (PlanetRace(pl2)==2) path='RPP';",
                        "   if (PlanetRace(pl2)==3) path='RF';",
                        "   if (PlanetRace(pl2)==4) path='RG';",
