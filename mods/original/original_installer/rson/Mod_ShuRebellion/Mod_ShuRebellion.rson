                        "    OrderLanding(CurShip,pl2,1);",
                        "  }",
                        "}",
                        "if(GetShipPlanet(CurShip)>0) {",
                        "  TransferShip(CurShip,StarPlanets(StarNearbyStars(ShipStar(Player()),20),1));",
                        "  ShipDestroy(CurShip);",
                        "}"
