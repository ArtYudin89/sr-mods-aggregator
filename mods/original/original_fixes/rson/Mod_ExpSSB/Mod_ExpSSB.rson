                },
                {
                    "Name": "",
                    "Code.Type": "Turn",
                    "Code": [
                        "temp_str='';",
                        "if(CurTurn()<=CustomArtData(cur_bh_item,2))temp_str=CT(\"Script.Mod_ExpSSB.239\");",
                        "if(CurTurn()>CustomArtData(cur_bh_item,2) && CustomArtData(cur_bh_item,1)<100)temp_str=CT(\"Script.Mod_ExpSSB.238\");",
                        "if(CustomArtData(cur_bh_item,1)>=100)",
                        "{",
                        "    CustomArtData(cur_bh_item,1,0);",
                        "    CustomArtData(cur_bh_item,3,CurTurn()+11);",
                        "    id_base=0;",
                        "    for(i=0;i<GalaxyStars();i=i+1)",
                        "    {",
                        "        if(id_base!=0)break;",
                        "        if(SectorVisible(StarToCon(GalaxyStar(i)))==1)",
                        "        {",
                        "            if(ShipStar(Player()) != GalaxyStar(i))",
                        "            {",
                        "                temp_dword = BuildRuins(GalaxyStar(i), t_PB);",
                        "                ShipType(temp_dword, 'SSB');",
                        "                ShipJoin(SSBGroup, temp_dword);",
                        "                ChangeState(1, temp_dword);",
                        "                ShipAddCustomShipInfo(temp_dword, 'Immortal','NoShow');",
                        "                id_base=Id(temp_dword);",
                        "                Chameleon(temp_dword, 'Ruins.SSB');",
                        "                SetName(temp_dword, 'X24 - 0.547');",
                        "                NoTargetToShip(temp_dword, 1);",
                        "                ShipOwner(temp_dword, 4);",
                        "",
                        "                //ShipSetCoords(temp_dword,CoordX(Player()),CoordY(Player()));",
                        "                ShipSetCoords(temp_dword, 10000, 0);",
                        "            }",
                        "        }",
                        "    }",
                        "    NoShopUpdate(temp_dword,1);",
                        "    for(i = ShopItems(temp_dword) - 1; i >= 0; i = i - 1) FreeItem(GetItemFromShop(temp_dword, i));",
                        "    for(i = 0; i <= 7; i = i + 1)",
                        "    {",
                        "        temp_int = GoodsAdd(temp_dword, i, 0);",
                        "        GoodsAdd(temp_dword, i, -temp_int);",
                        "    }",
                        "    temp_dword_2 = HoleCreate2(ShipStar(Player()), ShipStar(temp_dword));",
                        "    HoleTurnCreate(temp_dword_2, HoleTurnCreate(temp_dword_2) - 198);",
                        "    HoleMap(temp_dword_2,'SkipAB');",
                        "    HoleX1(temp_dword_2,CoordX(Player())-100);",
                        "    HoleY1(temp_dword_2,CoordY(Player())+Rnd(-100,100));",
                        "    HoleX2(temp_dword_2,CoordX(temp_dword));",
                        "    HoleY2(temp_dword_2,CoordY(temp_dword));",
                        "    if(CoordX(Player())>=-300 && CoordX(Player())<=300 && CoordY(Player())>=-300 && CoordY(Player())<=300)",
                        "    {",
                        "        HoleX1(temp_dword_2,CoordX(Player())-300);",
                        "        HoleY1(temp_dword_2,CoordY(Player())+300);",
                        "    }",
                        "    OrderJumpHole(temp_dword,temp_dword_2,10);",
                        "    ShipOrderData1(temp_dword,50);",
                        "    OrderLock(temp_dword,1);",
                        "    4d_turn=CurTurn()+2;",
                        "    temp_str=CT(\"Script.Mod_ExpSSB.272\");",
                        "}",
                        "DChange(19);",
                        "exit;"
