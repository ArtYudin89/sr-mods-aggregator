                        "        }",
                        "    }",
                        "    temp_int_1=temp_int_1/11;",
                        "    if(gift==0 && temp_int_1>=33)gift=1;",
                        "    if(gift==2 && temp_int_1>=66)gift=3;",
                        "    if(gift==4 && temp_int_1==100)gift=5;",
                        "}",
                        "if(gift==1 || gift==3 || gift==5) {",
                        "  DAdd(10);",
                        "}",
                        "temp_int_2 = 0;",
                        "temp_int_3 = FindBonusByName('Fragility_20_plus');",
                        "for(i = 0; i < ShipArts(Player()); i = i + 1)",
                        "{",
                        "    cur_bh_item = ShipArts(Player(), i);",
                        "    //Исключаем скриптовые артефакты",
                        "    if(ItemInScript(cur_bh_item)==1)",
                        "    {",
                        "        if(~EqSpecial(cur_bh_item))",
                        "        {",
                        "            //Но добавляем в список на сдачу артефакты с особым параметров в акрине (на них можно повесить акрин, да)",
                        "            if(!CT('MicroModuls.' + BonusNumInCfg(EqSpecial(cur_bh_item)) + '.ScriptItemIgnore')) continue;",
                        "        }",
                        "        else continue;",
                        "    }",
                        "    if(ItemType(cur_bh_item) == t_ArtefactTranclucator || ItemType(cur_bh_item) == t_ArtefactBomb || ItemType(cur_bh_item) < t_ArtefactHull || ItemType(cur_bh_item) == t_ArtefactTransmitter || ItemType(cur_bh_item) == t_ArtBlackHole || ItemType(cur_bh_item) == t_ArtDefToArms1 || ItemType(cur_bh_item) == t_ArtDefToArms2 || ItemType(cur_bh_item) == t_ArtArtefactor) continue;",
                        "    if(ItemExtraSpecialsCountByType(cur_bh_item, temp_int_3)) continue;",
                        "    temp_int_2 = 1;",
                        "    break;",
                        "}",
