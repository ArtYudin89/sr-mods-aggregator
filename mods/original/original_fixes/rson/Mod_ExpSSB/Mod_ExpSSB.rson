            "Operations": [
                {
                    "Name": "",
                    "Code.Type": "Global",
                    "Code": [
                        "GRun();"
                    ],
                    "#": 43,
                    "Type": "Top",
                    "Parent": -1,
                    "Pos.x": 0,
                    "Pos.y": 735
                },
                {
                    "Name": "",
                    "Code.Type": "Init",
                    "Code": [
                        "//temp_dword = CreateCustomArt('pulsar', Rnd(15, 35), Rnd(2000, 8000) * GalaxyTechLevel(), 4);",
                        "//AddItemToShip(Player(), temp_dword);",
                        "//crush_ok = 8;",
                        "//temp_dword = CreateCustomArt('ppb_caller_art', Rnd(1, 2) * GalaxyTechLevel(), Rnd(2000, 8000) * GalaxyTechLevel(), 4);",
                        "//CustomArtData(temp_dword, 1, 99);",
                        "//CustomArtData(temp_dword, 3, CurTurn() - 1);",
                        "//AddItemToShip(Player(), temp_dword);",
                        "",
                        "cur_art_sb2 = newarray(31);",
                        "cur_art_sb2_srch = newarray(31);",
                        "cur_art_sb2_srch_type_name = newarray(12);",
                        "cur_art_sb2_srch_type = newarray(11);",
                        "",
                        "for(i = 0; i < 11; i = i + 1) cur_art_sb2_srch_type[i] = 0;",
                        "temp_int = 0;",
                        "for(i = t_ArtefactHull; i < t_Hull; i = i + 1)",
                        "{",
                        "    temp_dword = CreateArt(i, 0);",
                        "    if(ItemType(temp_dword) != t_ArtefactBomb && ItemType(temp_dword) != t_ArtBlackHole)",
                        "    {",
                        "        cur_art_sb2[temp_int] = i;",
                        "        cur_art_sb2_srch[temp_int] = 0;",
                        "        temp_int = temp_int + 1;",
                        "    }",
                        "    FreeItem(temp_dword);",
                        "}",
                        "",
                        "cur_art_sb2_srch_type_name[0] = CT(\"Script.Mod_ExpSSB.293\");",
                        "cur_art_sb2_srch_type_name[1] = CT(\"Script.Mod_ExpSSB.292\");",
                        "cur_art_sb2_srch_type_name[2] = CT(\"Script.Mod_ExpSSB.291\");",
                        "cur_art_sb2_srch_type_name[3] = CT(\"Script.Mod_ExpSSB.290\");",
                        "cur_art_sb2_srch_type_name[4] = CT(\"Script.Mod_ExpSSB.289\");",
                        "cur_art_sb2_srch_type_name[5] = CT(\"Script.Mod_ExpSSB.288\");",
                        "cur_art_sb2_srch_type_name[6] = CT(\"Script.Mod_ExpSSB.287\");",
                        "cur_art_sb2_srch_type_name[7] = CT(\"Script.Mod_ExpSSB.286\");",
                        "cur_art_sb2_srch_type_name[8] = CT(\"Script.Mod_ExpSSB.285\");",
                        "cur_art_sb2_srch_type_name[9] = CT(\"Script.Mod_ExpSSB.284\");",
                        "cur_art_sb2_srch_type_name[10] = CT(\"Script.Mod_ExpSSB.283\");",
                        "cur_art_sb2_srch_type_name[11] = CT(\"Script.Mod_ExpSSB.282\");"
                    ],
                    "#": 44,
                    "Type": "Top",
                    "Parent": -1,
                    "Pos.x": 60,
                    "Pos.y": 735
                },
                {
                    "Name": "",
                    "Code.Type": "Turn",
                    "Code": [
                        "if(crush_ok==8 && CurTurn()-back_4d>10)crush_ok=9;",
                        "if(crush_ok!=7 && crush_ok!=-1 && crush_ok!=8)",
                        "{",
                        "    if(crush_ok==0)",
                        "    {",
                        "        if(HullSpecial(Player())>-1)",
                        "        {",
                        "            temp_int=HullSpecial(Player());",
                        "            if(findsubstr(BonusCustomTag(temp_int),'ExpScienceRanks_Tick')==0)",
                        "            {",
                        "                if(ShipOrder(Player())==4 && ShipInHole(Player()))",
                        "                {",
                        "                    if(crush_ok==0 && HoleStar1(ShipOrderObj(Player()))!=HoleStar2(ShipOrderObj(Player())))",
                        "                    {",
                        "                        HoleMap(ShipOrderObj(Player()),'SkipAB');",
                        "                        for(i=0;i<=8;i=i+1)",
                        "                        {",
                        "                            if(crush_ok==0)",
                        "                            {",
                        "                                crush_ok=1;",
                        "                                temp_dword=CreateQuestItem('Zond');",
                        "                                LinkItemToScript(temp_dword,Zond_take);",
                        "                                CreateABShip('Ship.Unknown.Zond',0,100,20,'',temp_dword);",
                        "                            }",
                        "                            if(crush_ok==1)CreateABShip('Ship.Unknown.Zond',0,100,20);",
                        "                        }",
                        "                        StartAB('ABMap.map_2',2);",
                        "                    }",
                        "                }",
                        "            }",
                        "        }",
                        "    }",
                        "    if(crush_ok==1)",
                        "    {",
                        "        if(ShipInNormalSpace(Player()))",
                        "        {",
                        "            crush_ok=2;",
                        "            Ether(3,'040EDD5D-C8F8-4E10-B3BA-0C8B0AB0FFED',CT(\"Script.Mod_ExpSSB.165\"));",
                        "        }",
                        "    }",
                        "    if(crush_ok==3)",
                        "    {",
                        "        if(search_day==CurTurn())",
                        "        {",
                        "            if(IdToShip(id_base))Ether(3,'SSB_Q_T',Format(CT(\"Script.Mod_ExpSSB.164\"),\"<0>\",ruin_name));",
                        "        }",
                        "        if(!IdToShip(id_base))",
                        "        {",
                        "            crush_ok=-1;",
                        "            Ether(5,'SSB_Q_T_C',Format(CT(\"Script.Mod_ExpSSB.163\"),\"<0>\",ruin_name));",
                        "        }",
                        "    }",
                        "    if(crush_ok==4)",
                        "    {",
                        "        if(search_day<=CurTurn())",
                        "        {",
                        "            crush_ok=-1;",
                        "            Ether(5,'C4958375-3412-4E34-9D2D-1DF4A436F608',CT(\"Script.Mod_ExpSSB.162\")+CT(\"Script.Mod_ExpSSB.142\")+CT(\"Script.Mod_ExpSSB.161\")+CT(\"Script.Mod_ExpSSB.142\")+Format(CT(\"Script.Mod_ExpSSB.294\"),\"<0>\",StarName(GalaxyStar(temp_star)),\"<1>\",ShipName(Player()))+CT(\"Script.Mod_ExpSSB.142\")+'Будь я на вашем месте, обязательно бы посетил эту звездную систему, пока срок не подошел к концу. Что бы там не находилось, это наверняка представляет огромную научную важность!');",
                        "        }",
                        "    }",
                        "    if(crush_ok==4)",
                        "    {",
                        "        if(Id(ShipStar(Player()))==temp_star && ShipInNormalSpace(Player()))",
                        "        {",
                        "            crush_ok=5;",
                        "            for(i=0;i<StarHoles(ShipStar(Player()));i=i+1)",
                        "            {",
                        "                temp_dword=StarHoles(ShipStar(Player()),i);",
                        "                if(Id(temp_dword)==hole_id)OrderMove(Player(),HoleX1(temp_dword),HoleY1(temp_dword));",
                        "            }",
                        "        }",
                        "    }",
                        "    if(crush_ok==5)",
                        "    {",
                        "        if(ShipOrder(Player())==4)",
                        "        {",
                        "            if(Id(ShipOrderObj(Player()))==hole_id && ShipInHole(Player()))",
                        "            {",
                        "                if(crush_ok==5)",
                        "                {",
                        "                    for(i=0;i<=2;i=i+1)",
                        "                    {",
                        "                        CreateABShip('Ship.X.0',0,100,30);",
                        "                        CreateABShip('Ship.X.1',0,100,50);",
                        "                    }",
                        "                    //OrderJumpHole(Player(),ShipOrderObj(Player()),2);",
                        "                    CreateABShip('Ship.X.2',0,100,75);",
                        "                    CreateABShip('Ruins.SSB',1,300,100,'SSB');",
                        "                    StartAB('ABMap.map_2',2);",
                        "                    crush_ok=4;",
                        "                }",
                        "                if(crush_ok == 4)",
                        "                {",
                        "                    temp_dword = ShipOrderObj(Player());",
                        "                    temp_dword_2 = BuildRuins(GalaxyStar(temp_star - 1), t_PB);",
                        "                    ShipType(temp_dword_2, 'SSB');",
                        "                    ShipJoin(SSBGroup, temp_dword_2);",
                        "                    ChangeState(1, temp_dword_2);",
                        "                    ShipAddCustomShipInfo(temp_dword_2, 'Immortal', 'NoShow');",
                        "                    ShipSetCoords(temp_dword_2, HoleX1(temp_dword), HoleY1(temp_dword));",
                        "                    id_base = Id(temp_dword_2);",
                        "                    Chameleon(temp_dword_2, 'Ruins.SSB');",
                        "                    SetName(temp_dword_2, 'X24 - 0.547');",
                        "                    NoTargetToShip(temp_dword_2, 1);",
                        "                    ShipOwner(temp_dword_2, 4);",
                        "",
                        "                    //Запрещаем автообновление магазинов ППБ",
                        "                    NoShopUpdate(temp_dword_2, 1);",
                        "                    //Очищаем магазины",
                        "                    for(i = ShopItems(temp_dword_2) - 1; i >= 0; i = i - 1) FreeItem(GetItemFromShop(temp_dword_2, i));",
                        "                    for(i = 0; i <= 7; i = i + 1)",
                        "                    {",
                        "                        temp_int = GoodsAdd(temp_dword_2, i, 0);",
                        "                        GoodsAdd(temp_dword_2, i, -temp_int);",
                        "                    }",
                        "",
                        "                    OrderJumpHole(temp_dword_2, temp_dword, 10);",
                        "                    ShipOrderData1(temp_dword_2, 1);",
                        "                    crush_ok = 6;",
                        "                }",
                        "            }",
                        "        }",
                        "    }",
                        "    if(crush_ok == 6)",
                        "    {",
                        "        if(AB_base == 0)",
                        "        {",
                        "            for(i=GalaxyEvents()-1;i>=0;i=i-1)",
                        "            {",
                        "                if(GalaxyEventDate(i)<CurTurn()-4) break;",
                        "                if(GalaxyEventType(i)=='LabeledShipKilledInAB')",
                        "                {",
                        "                    if(GalaxyEventsTextData(i,0)=='SSB')AB_base=1;",
                        "                }",
                        "            }",
                        "            if(AB_base==1)",
                        "            {",
                        "                Ether(5,'C4958375-3412-4E34-9D2D-1DF4A436F608',CT(\"Script.Mod_ExpSSB.162\")+CT(\"Script.Mod_ExpSSB.142\")+CT(\"Script.Mod_ExpSSB.161\")+CT(\"Script.Mod_ExpSSB.142\")+Format('Последние координаты указывают на систему <0>, в то время как привязанный к ним временной интервал подходит к концу через несколько недель. Больше мы ничего сообщить вам, <1>, не можем.',\"<0>\",StarName(GalaxyStar(temp_star)),\"<1>\",ShipName(Player()))+CT(\"Script.Mod_ExpSSB.142\")+'Будь я на вашем месте, обязательно бы посетил эту звездную систему, пока срок не подошел к концу. Что бы там не находилось, это наверняка представляет огромную научную важность!');",
                        "                ShipDestroy(IdToShip(id_base),1);",
                        "                crush_ok=-1;",
                        "            }",
                        "        }",
                        "    }",
                        "    if(crush_ok==6)",
                        "    {",
                        "        if(IdToShip(id_base))",
                        "        {",
                        "            temp_dword_2=IdToShip(id_base);",
                        "            if(ShipInNormalSpace(Player()) && ShipInNormalSpace(temp_dword_2) && AB_base==0)",
                        "            {",
                        "                while(ShipFreeSpace(Player())<0)",
                        "                {",
                        "                    temp_float=(Rnd(0,360)*pi)/180.0;",
                        "                    temp_dword=GetItemFromShip(Player(),ShipItems(Player())-1);",
                        "                    DropItemInSystem(ShipStar(Player()),temp_dword,CoordX(Player()),CoordY(Player()),CoordX(Player())+100.0*sin(temp_float),CoordY(Player())-100.0*cos(temp_float));",
                        "                    ShipCalcParam(Player());",
                        "                }",
                        "                OrderLanding(Player(),temp_dword_2,10);",
                        "                OrderLock(Player(),1);",
                        "                back_4d=CurTurn()+5;",
                        "                crush_ok=7;",
                        "            }",
                        "        }",
                        "    }",
                        "}",
                        "if(crush_ok==8)",
                        "{",
                        "    if(IdToShip(id_base))",
                        "    {",
                        "        temp_dword_2=IdToShip(id_base);",
                        "        if(CurTurn()==back_4d)",
                        "        {",
                        "            temp_dword=HoleCreate2(ShipStar(temp_dword_2),StarNearbyStars(ShipStar(temp_dword_2),1));",
