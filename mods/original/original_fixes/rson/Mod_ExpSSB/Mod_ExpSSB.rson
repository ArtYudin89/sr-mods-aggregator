                        "{",
                        "    for(i=ItemExtraSpecials(ShipItems(Player(),0))-1; i>=0; i=i-1)",
                        "    {",
                        "        temp_int=ItemExtraSpecials(ShipItems(Player(),0),i);",
                        "        ItemExtraSpecialsDeleteByType(ShipItems(Player(),0),temp_int);",
                        "    }",
                        "}",
