                    "_orig_danswer": "DAnswer('exit')"
                },
                {
                    "Name": "",
                    "Pos.x": 1680,
                    "Pos.y": 1115,
                    "Type": "TDialogAnswer",
                    "Parent": -1,
                    "#": 379,
                    "Msg": "Все системы",
                    "AMsg.Num": "74",
