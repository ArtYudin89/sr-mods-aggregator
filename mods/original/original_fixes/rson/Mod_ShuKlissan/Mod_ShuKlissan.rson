                        "            else if(tRnd <= 37) typeStr = 'klissan_splitter';",
                        "            else if(tRnd <= 55) typeStr = 'klissan_laser';",
                        "            else if(tRnd <= 80) typeStr = 'klissan_moldikvink';",
                        "            else typeStr = 'klissan_burster';",
                        "        }",
                        "        else if(danger <= 60)",
                        "        {",
                        "            if(tRnd <= 25) typeStr = 'klissan_antimatter';",
                        "            else if(tRnd <= 40) typeStr = 'klissan_splitter';",
                        "            else if(tRnd <= 50) typeStr = 'klissan_laser';",
                        "            else if(tRnd <= 75) typeStr = 'klissan_moldikvink';",
                        "            else typeStr = 'klissan_burster';",
                        "        }",
                        "        else if(danger <= 80)",
                        "        {",
                        "            if(tRnd <= 30) typeStr = 'klissan_antimatter';",
                        "            else if(tRnd <= 45) typeStr = 'klissan_splitter';",
                        "            else if(tRnd <= 50) typeStr = 'klissan_laser';",
                        "            else if(tRnd <= 70) typeStr = 'klissan_moldikvink';",
                        "            else typeStr = 'klissan_burster';",
                        "        }",
                        "        else",
                        "        {",
                        "            if(tRnd <= 35) typeStr = 'klissan_antimatter';",
                        "            else if(tRnd <= 55) typeStr = 'klissan_splitter';",
                        "            else if(tRnd <= 60) typeStr = 'klissan_laser';",
                        "            else if(tRnd <= 75) typeStr = 'klissan_moldikvink';",
                        "            else typeStr = 'klissan_burster';",
                        "        }",
                        "        if(typeStr == 'klissan_laser') size = Rnd(12, 25);",
                        "        if(typeStr == 'klissan_splitter') size = Rnd(18, 30);",
                        "        if(typeStr == 'klissan_antimatter') size = Rnd(27, 40);",
                        "        if(typeStr == 'klissan_moldikvink') size = Rnd(22, 32);",
                        "        if(typeStr == 'klissan_burster') size = Rnd(25, 35);",
                        "    }",
                        "    if(danger <= 15) techlvl = Rnd(2, 3);",
                        "    else if(danger <= 30) techlvl = Rnd(2, 3);",
                        "    else if(danger <= 45) techlvl = Rnd(3, 4);",
                        "    else if(danger <= 60) techlvl = Rnd(4, 5);",
                        "    else if(danger <= 75) techlvl = Rnd(5, 6);",
                        "    else if(danger <= 90) techlvl = Rnd(6, 8);",
                        "    else techlvl = 8;",
                        "    if(eq_type != t_CustomWeapon)",
                        "    {",
                        "        if(GTL <= 5) size = Rnd(15, 25);",
                        "        else if(GTL <= 7) size = Rnd(15, 30);",
                        "        else size = Rnd(15, 35);",
                        "        if(eq_type == t_Radar || eq_type == t_Scaner) size = size * 75 / 100;",
                        "    }",
                        "",
                        "    if(eq_type != t_CustomWeapon) item = CreateEquipment(eq_type, size, techlvl, None);",
                        "    else item = CreateCustomWeapon(typeStr, size, techlvl, None);",
                        "    if(typeStr == 'klissan_moldikvink') {",
                        "        LinkItemToScript(item);",
                        "        ItemOnActCode(item, GenerateCodeStringFromBlock('ActCodeBlocksList.ShuKlissan_KvinkgunShot'));",
                        "    }",
                        "",
                        "    if(Rnd(0, 2))",
                        "    {",
                        "        if(ItemType(item) == t_CustomWeapon || ItemType(item) == t_Engine || ItemType(item) == t_CargoHook) ItemImprovement(item, 0, 0);",
                        "        else ItemImprovement(item, 0);",
                        "    }",
                        "",
                        "    EqCustomFaction(item, 'Klissan');",
                        "    AddItemToShip(ship, item);",
                        "    result = item;",
                        "}",
                        "",
