                        "//Ошмётки сдаются дороже, чем оборудка",
                        "if(ItemType(cur_item) == t_UselessItem) cost = ItemCost(cur_item) * 2;",
                        "else cost = ItemCost(cur_item);",
                        "",
                        "//Сдаём на ментальный коммуникатор",
                        "if(num == 1)",
                        "{",
                        "    comm = comm - ItemSize(cur_item);",
                        "    //Если сдали уже достаточно",
                        "    if(comm <= 0)",
                        "    {",
                        "        comm = 0;",
                        "        num = 3;",
                        "        //Заводим таймер до завершения исследования",
                        "        comm_timer = CurTurn() + Rnd(474, 547);",
                        "        tstr1 = '</color>' + Format(CT(\"Script.Mod_ShuKlissan.134\"),\"<0>\",GameDateTxtByTurn(comm_timer));",
                        "    }",
                        "    else tstr1 = '</color>' + Format(CT(\"Script.Mod_ShuKlissan.135\"),\"<0>\",ItemSize(cur_item),\"<1>\",cost,\"<2>\",comm);",
                        "}",
                        "//Сдаём на Z-трансмиттер",
                        "else if(num == 2)",
                        "{",
                        "    trans = trans - ItemSize(cur_item);",
                        "    //Если сдали уже достаточно",
                        "    if(trans <= 0)",
                        "    {",
                        "        trans = 0;",
                        "        num = 3;",
                        "        //Заводим таймер до завершения исследования",
                        "        trans_timer = CurTurn() + Rnd(292, 438);",
                        "        tstr1 = '</color>' + Format(CT(\"Script.Mod_ShuKlissan.134\"),\"<0>\",GameDateTxtByTurn(trans_timer));",
                        "    }",
                        "    else tstr1 = '</color>' + Format(CT(\"Script.Mod_ShuKlissan.135\"),\"<0>\",ItemSize(cur_item),\"<1>\",cost,\"<2>\",trans);",
                        "}",
                        "",
                        "if(num == 3) Sound('Sound.QuestOk');",
                        "else Sound('Sound.Sell');",
                        "",
