                    "#": 372,
                    "Msg": "Z-трансмиттер МК II",
                    "AMsg.Num": "67",
                    "_orig_danswer": "DAnswer(CT(\"Script.Mod_ShuKlissan.228\"))"
                },
                {
                    "Name": "restart",
                    "Pos.x": 960,
                    "Pos.y": 1115,
                    "Type": "TDialogAnswer",
                    "Parent": -1,
                    "#": 373,
                    "Msg": "На моем корабле нет материала для сдачи",
                    "AMsg.Num": "68",
                    "_orig_danswer": "DAnswer('restart~'+CT(\"Script.Mod_ShuKlissan.200\"))"
                },
                {
                    "Name": "",
                    "Pos.x": 1080,
                    "Pos.y": 1115,
                    "Type": "TDialogAnswer",
                    "Parent": -1,
                    "#": 374,
                    "Msg": "К основному исследованию",
                    "AMsg.Num": "69",
                    "_orig_danswer": "DAnswer(CT(\"Script.Mod_ShuKlissan.229\"))"
                },
                {
                    "Name": "",
                    "Pos.x": 1200,
                    "Pos.y": 1115,
                    "Type": "TDialogAnswer",
                    "Parent": -1,
                    "#": 375,
                    "Msg": "Отлично!",
                    "AMsg.Num": "70",
                    "_orig_danswer": "DAnswer(CT(\"Script.Mod_ShuKlissan.173\"))"
                },
                {
                    "Name": "restart",
                    "Pos.x": 1320,
