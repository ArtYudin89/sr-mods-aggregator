                        "            else if(tRnd <= 57) typeStr = 'klissan_moldikvink';",
                        "            else if(tRnd <= 70) typeStr = 'klissan_cluster';",
                        "            else typeStr = 'klissan_emitter';",
                        "        }",
                        "        else",
                        "        {",
                        "            if(tRnd <= 33) typeStr = 'klissan_antimatter';",
                        "            else if(tRnd <= 38) typeStr = 'klissan_burster';",
                        "            else if(tRnd <= 55) typeStr = 'klissan_moldikvink';",
                        "            else if(tRnd <= 67) typeStr = 'klissan_cluster';",
                        "            else typeStr = 'klissan_emitter';",
                        "        }",
                        "        if(typeStr == 'klissan_antimatter')size = Rnd(35, 57);",
                        "        else if(typeStr == 'klissan_burster')size = Rnd(30, 55);",
                        "        else if(typeStr == 'klissan_moldikvink')size = Rnd(30, 50);",
                        "        else if(typeStr == 'klissan_cluster')size = Rnd(38, 62);",
                        "        else if(typeStr == 'klissan_emitter')size = Rnd(40, 65);",
                        "    }",
                        "    if(danger <= 15) techlvl = Rnd(2, 3);",
                        "    else if(danger <= 30) techlvl = Rnd(2, 4);",
                        "    else if(danger <= 45) techlvl = Rnd(4, 5);",
                        "    else if(danger <= 60) techlvl = Rnd(5, 6);",
                        "    else if(danger <= 75) techlvl = Rnd(6, 7);",
                        "    else if(danger <= 90) techlvl = 8;",
                        "    else techlvl = 8;",
                        "    if(eq_type != t_CustomWeapon)",
                        "    {",
                        "        if(GTL <= 5) size = Rnd(35, 50);",
                        "        else if(GTL <= 7) size = Rnd(37, 57);",
                        "        else size = Rnd(40, 65);",
                        "        if(eq_type == t_Radar || eq_type == t_Scaner) size = size * 75 / 100;",
                        "    }",
