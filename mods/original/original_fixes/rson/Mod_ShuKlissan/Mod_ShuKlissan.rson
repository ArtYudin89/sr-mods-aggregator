                        "        {",
                        "            if(ItemType(item) == t_CustomWeapon || ItemType(item) == t_Engine || ItemType(item) == t_CargoHook) ItemImprovement(item, 2, 0);",
                        "            else ItemImprovement(item, 2);",
                        "        }",
                        "        else",
                        "        {",
                        "            if(ItemType(item) == t_CustomWeapon || ItemType(item) == t_Engine || ItemType(item) == t_CargoHook) ItemImprovement(item, 1, 0);",
                        "            else ItemImprovement(item, 1);",
                        "        }",
                        "    }",
                        "",
                        "    EqCustomFaction(item, 'Klissan');",
