                    "Code": [
                        "coal_ships=0;",
                        "domik_ships=0;",
                        "pirate_ships=0;",
                        "klissan_ships=0;",
                        "for(i=0;i<GalaxyStars();i=i+1)",
                        "{",
                        "    s=GalaxyStar(i);",
                        "    if(StarCustomFaction(s)=='')",
                        "    {",
                        "        if(StarOwner(s)==1)domik_ships=domik_ships+1;",
                        "        if(StarOwner(s)==2)pirate_ships=pirate_ships+1;",
                        "    }",
                        "    else if(StarCustomFaction(s)=='Klissan')klissan_ships=klissan_ships+1;",
                        "}",
                        "i=GalaxyStars();",
                        "pirate_ships=pirate_ships*100/i;",
                        "domik_ships=domik_ships*100/i;",
                        "klissan_ships=klissan_ships*100/i;",
                        "coal_ships=100-(pirate_ships+domik_ships+klissan_ships);",
                        "if(coal_ships>=100)i=1;",
                        "else if(coal_ships>=90)i=2;",
                        "else if(coal_ships>=70)i=3;",
                        "else if(coal_ships>=50)i=4;",
                        "else if(coal_ships>=30)i=5;",
                        "else if(coal_ships>=10)i=6;",
                        "else i=7;",
                        "s=ShipStar(Player());",
                        "for(it=1;it<GalaxyStars();it=it+1)",
                        "{",
                        "    k=StarNearbyStars(s,it);",
                        "    if(StarOwner(k)>0)",
                        "    {",
                        "        Star=StarName(k);",
                        "        Sector=ConName(StarToCon(s));",
                        "        break;",
                        "    }",
                        "}",
                        "str5='';",
                        "if(CurTurn()>GShuKlissanFirstStart+5)",
                        "{",
                        "    if(i==1)str5='</color>'+Format(CT(\"Script.Mod_ShuKlissan.160\"),\"<0>\",coal_ships,\"<1>\",domik_ships,\"<2>\",pirate_ships,\"<3>\",klissan_ships);",
                        "    else if(i==2)str5='</color>'+Format(CT(\"Script.Mod_ShuKlissan.161\"),\"<0>\",coal_ships,\"<1>\",domik_ships,\"<2>\",pirate_ships,\"<3>\",klissan_ships);",
                        "    else if(i==3)str5='</color>'+Format(CT(\"Script.Mod_ShuKlissan.162\"),\"<0>\",coal_ships,\"<1>\",domik_ships,\"<2>\",pirate_ships,\"<3>\",klissan_ships,\"<4>\",Star,\"<5>\",Sector);",
                        "    else if(i==4)str5='</color>'+Format(CT(\"Script.Mod_ShuKlissan.163\"),\"<0>\",coal_ships,\"<1>\",domik_ships,\"<2>\",pirate_ships,\"<3>\",klissan_ships,\"<4>\",Star,\"<5>\",Sector);",
                        "    else if(i==5)str5='</color>'+Format(CT(\"Script.Mod_ShuKlissan.164\"),\"<0>\",coal_ships,\"<1>\",domik_ships,\"<2>\",pirate_ships,\"<3>\",klissan_ships,\"<4>\",Star,\"<5>\",Sector);",
                        "    else if(i==6)str5='</color>'+Format(CT(\"Script.Mod_ShuKlissan.165\"),\"<0>\",coal_ships,\"<1>\",domik_ships,\"<2>\",pirate_ships,\"<3>\",klissan_ships,\"<4>\",Star);",
                        "    else if(i==7)str5='</color>'+Format(CT(\"Script.Mod_ShuKlissan.166\"),\"<0>\",coal_ships,\"<1>\",domik_ships,\"<2>\",pirate_ships,\"<3>\",klissan_ships,\"<4>\",Star);",
                        "}",
                        "else",
                        "{",
                        "    if(i==1)str5='</color>'+Format(CT(\"Script.Mod_ShuKlissan.153\"),\"<0>\",coal_ships,\"<1>\",domik_ships,\"<2>\",pirate_ships);",
                        "    else if(i==2)str5='</color>'+Format(CT(\"Script.Mod_ShuKlissan.154\"),\"<0>\",coal_ships,\"<1>\",domik_ships,\"<2>\",pirate_ships);",
