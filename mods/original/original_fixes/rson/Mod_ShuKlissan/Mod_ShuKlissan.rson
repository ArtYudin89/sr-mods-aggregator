                    "Type": "TDialogAnswer",
                    "Parent": -1,
                    "#": 376,
                    "Msg": "Был рад помочь",
                    "AMsg.Num": "71",
                    "_orig_danswer": "DAnswer('restart~'+CT(\"Script.Mod_ShuKlissan.230\"))"
                },
                {
                    "Name": "restart",
                    "Pos.x": 1440,
                    "Pos.y": 1115,
                    "Type": "TDialogAnswer",
                    "Parent": -1,
                    "#": 377,
                    "Msg": "Был рад помочь",
                    "AMsg.Num": "72",
                    "_orig_danswer": "DAnswer('restart~'+CT(\"Script.Mod_ShuKlissan.230\"))"
                },
                {
