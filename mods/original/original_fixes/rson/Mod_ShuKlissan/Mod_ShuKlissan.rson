                {
                    "Name": "",
                    "Code.Type": "Turn",
                    "Code": [
                        "cur_item = ShipItems(Player(), GAnswerData);",
                        "//Ошмётки стоят в два раза дороже, чем оборудка",
                        "if(ItemType(cur_item) == t_UselessItem) cost = ItemCost(cur_item) * 2;",
                        "else cost = ItemCost(cur_item);",
                        "",
                        "research = research - ItemSize(cur_item);",
                        "//Исследование завершено",
                        "if(research <= 0) research = 0;",
                        "//Исследование ещё не завершено",
                        "else",
                        "{",
                        "    tstr1 = '</color>' + Format(CT(\"Script.Mod_ShuKlissan.62\"),\"<0>\",ItemSize(cur_item),\"<1>\",cost,\"<2>\",research);",
                        "    Sound('Sound.Sell');",
                        "}",
                        "",
                        "FreeItem(GetItemFromShip(Player(), ShipItems(Player(), GAnswerData)));",
                        "ShipMoney(Player(), ShipMoney(Player()) + cost);",
                        "if(!research) {",
                        "  research_cnt = research_cnt + 1;",
                        "  if(research_cnt < 4) {",
                        "    //Перезапускаем счётчик основного исследования клисан",
                        "    //Счётчик постепенно сам \"тикает\" из терна, но сдача обломков клисан ускоряет его",
                        "    //соответственно весу сданных обломков",
                        "    if(research_cnt == 1)",
                        "    {",
                        "        research = 1000;",
                        "        tstr1 = '</color>' + CT(\"Script.Mod_ShuKlissan.61\");",
                        "    }",
                        "    else if(research_cnt == 2)",
                        "    {",
                        "        research = 2000;",
                        "        tstr1 = '</color>' + Format(CT(\"Script.Mod_ShuKlissan.94\"),\"<0>\",ShortName(GetShipRuins(Player())));",
                        "    }",
                        "    else if(research_cnt == 3)",
                        "    {",
                        "        research = 4000;",
                        "        tstr1 = '</color>' + CT(\"Script.Mod_ShuKlissan.95\");",
                        "    }",
                        "    ",
                        "    Sound('Sound.QuestOk');",
                        "    DChange(1);",
                        "    exit;",
                        "  }",
                        "  if(research_cnt >= 4) {",
                        "    //Ставим маркер о завершении основного исследования клисан (игроку необходимо будет ещё прочитать финальный текст)",
                        "    research_cnt = research_cnt + 1;",
                        "    Sound('Sound.QuestOk');",
                        "    DChange(3);",
                        "    exit;",
                        "  }",
                        "}",
                        "if(research) {",
                        "  DChange(2);",
                        "  exit;",
                        "}"
