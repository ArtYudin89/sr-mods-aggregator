            "Operations": [
                {
                    "Name": "",
                    "Code.Type": "Global",
                    "Code": [
                        "GRun();"
                    ],
                    "#": 145,
                    "Type": "Top",
                    "Parent": -1,
                    "Pos.x": 0,
                    "Pos.y": 1235
                },
                {
                    "Name": "",
                    "Code.Type": "Init",
                    "Code": [
                        "KlissanDiffLevel = max(50, 50 * GetParFromTxt('SpaceRangersHD\\\\ModsCFG.txt', 'KlissanDiffLevel')); //Запоминаем уровень сложности клисан",
                        "ScientistsIntelligence = PortionInDiapason(GalaxyDiffLevels(2) / 50, 1, 10, 10, 1); //Запоминаем уровень интеллекта учёных (сложность)",
                        "comm = min(1000, 2 * (GalaxyDiffLevels(2) + KlissanDiffLevel));",
                        "trans = min(1000, 4 * (GalaxyDiffLevels(2) + KlissanDiffLevel));",
                        "max_kl = PortionInDiapason(KlissanDiffLevel, 50, 500, 20, 42); //Максимальный лимит кораблей клисан в одной системе зависит от уровня сложности",
                        "klissanStars[0] = 0; //Кол-во систем под контролем клисан. klissanStars[1+] - Id-1 системы под контролем.",
                        "//Ранее в коде повсеместно встречалась куча дебильных переборов, выполняющих в итоге подобное присвоение",
                        "//free_koef = PortionInDiapason(GroupCount(NestNormal), 0, 33, 40, -50);",
                        "//Таких переборов было штук 10 в разных местах, но кроме присвоения данная переменная больше нигде не использовалась",
                        "",
                        "//Создаём кастомные орудия",
                        "InventShuKlissanCustomGuns();",
                        "gunUpdateCheck = CT('Items.Weapon.CustomWeapon.StatsVersion.ShuKlissan');",
                        "//Функция для объявления и обновления кастомных орудий",
                        "function InventShuKlissanCustomGuns()",
                        "{",
                        "    for(i = 1; i <= CT('Items.Weapon.CustomWeapon.ShuKlissan.Count'); i = i + 1)",
                        "    {",
                        "        //По очереди выбираем системное название каждой новой пушки из Lang",
                        "        tstr1 = CT('Items.Weapon.CustomWeapon.ShuKlissan.' + i);",
                        "        tstr2 = 'Items.Weapon.CustomWeapon.';",
                        "        //Прописываем пушку/сбрасываем уже прописанную пушку до уровня базовой из оригинальной игры",
                        "        cur_item = InventNewCustomWeapon(tstr1, t_Weapon1 - 1 + CT('Items.Weapon.OriginalWeaponType.' + CT(tstr2 + tstr1 + '.BaseGun')));",
                        "        //Задаём характеристики оружия",
                        "        SetCustomWeaponShotData(cur_item, CT(tstr2 + tstr1 + '.ShotType'), CT(tstr2 + tstr1 + '.Speed'), CT(tstr2 + tstr1 + '.AverageRadius'), CT(tstr2 + tstr1 + '.SecondaryDamageRadius'), CT(tstr2 + tstr1 + '.MiningFactor'), CT(tstr2 + tstr1 + '.ShotsPerTurn'));",
                        "        SetCustomWeaponDamageData(cur_item, CT(tstr2 + tstr1 + '.MinDamage'), CT(tstr2 + tstr1 + '.MaxDamage'), CT(tstr2 + tstr1 + '.DamageSet'), CT(tstr2 + tstr1 + '.mWeaponDamage'));",
                        "        SetCustomMissileWeaponStats(cur_item, CT(tstr2 + tstr1 + '.MissileRadius'), CT(tstr2 + tstr1 + '.MissileMaxSpeed'), CT(tstr2 + tstr1 + '.MissileMinSpeed'), CT(tstr2 + tstr1 + '.MissileChanceToBeHit'));",
                        "        SetCustomWeaponPrimaryData(cur_item, CT(tstr2 + tstr1 + '.TechLevel'), t_Weapon1 - 1 + CT('Items.Weapon.OriginalWeaponType.' + CT(tstr2 + tstr1 + '.InventTechLevel')), t_Weapon1 - 1 + CT('Items.Weapon.OriginalWeaponType.' + CT(tstr2 + tstr1 + '.ArcadeType')));",
                        "        SetCustomWeaponSizeAndCost(cur_item, CT(tstr2 + tstr1 + '.kCost'), CT(tstr2 + tstr1 + '.AverageSize'));",
                        "        SetCustomWeaponAvailability(cur_item, CT(tstr2 + tstr1 + '.StoreAvailability'));",
                        "        SetCustomWeaponSE(cur_item, CT(tstr2 + tstr1 + '.ShotEffectPath'), CT(tstr2 + tstr1 + '.SplashEffectPath'), CT(tstr2 + tstr1 + '.MissileExplosionEffectPath'), CT(tstr2 + tstr1 + '.ShotEffectPalette'));",
                        "    }",
                        "}",
                        "",
                        "//Записываем текущий ГТУ в локальную переменную",
                        "GTL = GalaxyTechLevel();",
                        "//Записываем номера Тортугаца и Нифигаца (для удобной читаемости в коде)",
                        "TortugatzId = 70;",
                        "NifigatzId = 71;",
                        "",
                        "//GShuKlissanFirstStart - хранит в себе номер хода, в который состоялось первое появление клисан",
                        "//Выставляем его в зависимости от настройки уровня сложности клисан.",
                        "//Кроме случаев, когда к моменту запуска скрипта один из доминаторских боссов был уничтожен,",
                        "//либо игрок получил в клане звание не ниже \"Атамана\",",
                        "//время появления клисан \"инициализируется\" почти мгновенно (через 15-30 ходов).",
                        "if(DomiksDefeated(0) || DomiksDefeated(1) || DomiksDefeated(2) || GetShipPirateRank(Player()) >= 5)",
                        "{",
                        "    GShuKlissanFirstStart = CurTurn() + Rnd(15, 30);",
                        "}",
                        "//Иначе запускаем стандартный рандомизатор с модификатором от сложности клисан",
                        "//Рандомим дату от 4 до 7 лет, после чего умножаем её на модификатор сложности (чем сложнее, тем раньше)",
                        "else GShuKlissanFirstStart = CurTurn() + round(PortionInDiapason(KlissanDiffLevel, 500, 50, 0.4, 1.6) * (Rnd(1460, 2555)));",
                        "",
                        "hit_list = newarray(1);",
                        "first = newarray(1);",
                        "second = newarray(1);",
                        "third = newarray(1);",
                        "function CountEqByType(ship, type)",
                        "{",
                        "    if(0)",
                        "    {",
                        "        if(MessageBoxYesNo('Выполнение функции не поддерживается для неклисан. Все равно хотите продолжить?')) EndGame(0);",
                        "    }",
                        "    else",
                        "    {",
                        "        if(type == 'Weapon')",
                        "        {",
                        "            if(ShipPilotRace(ship) == 0 || ShipPilotRace(ship) == 1)",
                        "            {",
                        "                if(danger <= 20) num = Rnd(2, 3);",
                        "                else if(danger <= 40) num = Rnd(2, 4);",
                        "                else if(danger <= 60) num = Rnd(3, 4);",
                        "                else if(danger <= 80) num = Rnd(3, 5);",
                        "                else num = Rnd(4, 5);",
                        "            }",
                        "            if(ShipPilotRace(ship) == 2 || ShipPilotRace(ship) == 3 || ShipPilotRace(ship) == 4)",
                        "            {",
                        "                if(danger <= 25) num = Rnd(2, 4);",
                        "                else if(danger <= 50) num = Rnd(3, 4);",
                        "                else if(danger <= 75) num = Rnd(4, 5);",
                        "                else num = 5;",
                        "            }",
                        "        }",
                        "        if(type == 'Def')",
                        "        {",
                        "            rand = Rnd(1, 100);",
                        "            if(ShipPilotRace(ship) == 0)",
                        "            {",
                        "                if(danger <= 25 && rand <= 55) num = 1;",
                        "                else if(danger > 25 && danger <= 50 && rand <= 70) num = 1;",
                        "                else if(danger > 50 && danger <= 75 && rand <= 77) num = 1;",
                        "                else if(danger > 75 && rand <= 85) num = 1;",
                        "                else num = 0;",
                        "            }",
                        "            if(ShipPilotRace(ship) == 1)",
                        "            {",
                        "                if(danger <= 25 && rand <= 60) num = 1;",
                        "                else if(danger > 25 && danger <= 50 && rand <= 72) num = 1;",
                        "                else if(danger > 50 && danger <= 75 && rand <= 80) num = 1;",
                        "                else if(danger > 75 && rand <= 87) num = 1;",
                        "                else num = 0;",
                        "            }",
                        "            if(ShipPilotRace(ship) == 2)",
                        "            {",
                        "                if(danger <= 25 && rand <= 65) num = 1;",
                        "                else if(danger > 25 && danger <= 50 && rand <= 75) num = 1;",
                        "                else if(danger > 50 && danger <= 75 && rand <= 82) num = 1;",
                        "                else if(danger > 75 && rand <= 90) num = 1;",
                        "                else num = 0;",
                        "            }",
                        "            if(ShipPilotRace(ship) == 3)",
                        "            {",
                        "                if(danger <= 25 && rand <= 67) num = 1;",
                        "                else if(danger > 25 && danger <= 50 && rand <= 77) num = 1;",
                        "                else if(danger > 50 && danger <= 75 && rand <= 83) num = 1;",
                        "                else if(danger > 75 && rand <= 91) num = 1;",
                        "                else num = 0;",
                        "            }",
                        "            if(ShipPilotRace(ship) == 4)",
                        "            {",
                        "                if(danger <= 25 && rand <= 70) num = 1;",
                        "                else if(danger > 25 && danger <= 50 && rand <= 80) num = 1;",
                        "                else if(danger > 50 && danger <= 75 && rand <= 85) num = 1;",
                        "                else if(danger > 75 && rand <= 92) num = 1;",
                        "            }",
                        "        }",
                        "        if(type == 'Other')",
                        "        {",
                        "            rand = Rnd(1, 100);",
                        "            if(ShipPilotRace(ship) == 0 && rand <= 40) num = 1;",
                        "            else if(ShipPilotRace(ship) == 1 && rand <= 50) num = 1;",
                        "            else if(ShipPilotRace(ship) == 2 && rand <= 60) num = 1;",
                        "            else if(ShipPilotRace(ship) == 3 && rand <= 65) num = 1;",
                        "            else if(ShipPilotRace(ship) == 4 && rand <= 70) num = 1;",
                        "            else num = 0;",
                        "        }",
                        "        result = num;",
                        "    }",
                        "}",
                        "//Основная функция спавна случайного корабля клисан",
                        "function BuyKlissan(dword planet, int sub_type) {",
                        "    //Определяем шанс на появление определенных типов клисан:",
                        "    //1 - мутенок",
                        "    //2 - рогит",
                        "    //3 - катаури",
                        "    //4 - нондус",
                        "    //5 - эгемон",
                        "    dword ship;",
                        "    if(danger <= 40) { //Уровень угрозы <= 40",
                        "        klissanSpawnChance[0] = 46;",
                        "        klissanSpawnChance[1] = 27;",
                        "        klissanSpawnChance[2] = 15;",
                        "        klissanSpawnChance[3] = 8;",
                        "        klissanSpawnChance[4] = 4;",
                        "    }",
                        "    else if(danger <= 69) { //Уровень угрозы 41-69",
                        "        klissanSpawnChance[0] = 43;",
                        "        klissanSpawnChance[1] = 27;",
                        "        klissanSpawnChance[2] = 17;",
                        "        klissanSpawnChance[3] = 9;",
                        "        klissanSpawnChance[4] = 4;",
                        "    }",
                        "    else { //Уровень угрозы 70-100",
                        "        klissanSpawnChance[0] = 42;",
                        "        klissanSpawnChance[1] = 26;",
                        "        klissanSpawnChance[2] = 17;",
                        "        klissanSpawnChance[3] = 9;",
                        "        klissanSpawnChance[4] = 6;",
                        "    }",
                        "    if(turn_egemon) {",
                        "        turn_egemon = 0;",
                        "        klissanSpawnChance[0] = 0;",
                        "        klissanSpawnChance[1] = 0;",
                        "        klissanSpawnChance[2] = 0;",
                        "        klissanSpawnChance[3] = 0;",
                        "        klissanSpawnChance[4] = 100;",
                        "    }",
                        "    if(sub_type == -1) { //Определяется тип будущего клисана",
                        "        sub_type = Rnd(1, 100);",
                        "        if(sub_type <= klissanSpawnChance[0]) { //Мутенок",
                        "          sub_type = 5;",
                        "          ship = BuyDomikExtremal(planet, 5);",
                        "        }",
                        "        else if(sub_type <= klissanSpawnChance[0] + klissanSpawnChance[1]) { //Рогит",
                        "          sub_type = 4;",
                        "          ship = BuyDomikExtremal(planet, 4);",
                        "        }",
                        "        else if(sub_type <= klissanSpawnChance[0] + klissanSpawnChance[1] + klissanSpawnChance[2]) { //Катаури",
                        "          sub_type = 3;",
                        "          ship = BuyDomikExtremal(planet, 3);",
                        "        }",
                        "        else if(sub_type <= klissanSpawnChance[0] + klissanSpawnChance[1] + klissanSpawnChance[2] + klissanSpawnChance[3]) { //Нондус",
                        "          sub_type = 2;",
                        "          ship = BuyDomikExtremal(planet, 2);",
                        "        }",
                        "        else { //Эгемон",
                        "          sub_type = 1;",
                        "          ship = BuyDomikExtremal(planet, 1);",
                        "        }",
                        "    }",
                        "    else ship = BuyDomikExtremal(planet, sub_type);",
                        "    dword hull = ShipItems(ship, 0);",
                        "    //???",
                        "    int alpha = 0;",
                        "    if(Rnd(1, 100) < 0) alpha = 1;",
                        "",
                        "    int egemon_mod = 0;",
                        "    if(klissanSpawnChance[4] < 100)",
                        "    {",
                        "        if(Rnd(1, 100) <= 5 && ShipSubType(ship) == 1) egemon_mod = 1;",
                        "    }",
                        "",
                        "    ShipSpecialBonuses(ship, bonJump, -1000);",
                        "    int rndInt = CT('ShipName.Klissan.CntNames');",
                        "    str tempStr = CT('ShipName.Klissan.' + Rnd(1, rndInt)) + ' -' + Rnd(1, 100) + '-';",
                        "",
                        "    if(egemon_mod) tempStr = tempStr + CT(\"Script.Mod_ShuKlissan.248\");",
                        "    else if(alpha) tempStr = tempStr + ' Альфа';",
                        "",
                        "    SetName(ship, tempStr);",
                        "    ShipOwner(ship, None);",
                        "    NoScanToShip(ship, 1);",
                        "    NoTalkToShip(ship, 1);",
                        "    ShipFreeExp(ship, 0);",
                        "",
                        "    for(int i = ShipItems(ship) - 1; i > 0; i = i - 1) //Удаляем все оборудование, кроме корпуса",
                        "    {",
                        "        FreeItem(GetItemFromShip(ship, i));",
                        "    }",
                        "",
                        "    //Приступаем к определению типа клисана и соответствующему его снаряжению",
                        "    ArrayClear(hit_list);",
                        "    rndInt = CT('Script.Mod_ShuKlissan.KlissanRemainsCount');",
                        "    for(i = 0; i < rndInt; i = i + 1) ArrayAdd(hit_list, 'KlissanRemains' + (i + 1));",
                        "",
                        "    rndInt = Rnd(1, 100);",
                        "    if(sub_type == 5) { //Мутенок",
                        "        ShipType(ship, 'Klissan5');",
                        "        a = CreateCustomCountableItem('kProtoplasm', Rnd(1, 15), 1);",
                        "        EqCustomFaction(a, 'Klissan');",
                        "        ItemCost(a, ItemSize(a) * 30);",
                        "        ShipAddDropItem(ship, a);",
                        "        if(rndInt <= 30) knum = 0;",
                        "        else if(rndInt <= 90) knum = 1;",
                        "        else knum = 2;",
                        "        ShipPilotRace(ship, 0);",
                        "        if(alpha) {",
                        "            ShipSkill(ship, 0, 6);",
                        "            ShipSkill(ship, 1, 6);",
                        "        }",
                        "        else {",
                        "            if(danger < 40) {",
                        "                ShipSkill(ship, 0, Rnd(0, 2));",
                        "                ShipSkill(ship, 1, Rnd(0, 2));",
                        "            }",
                        "            else if(danger < 65) {",
                        "                ShipSkill(ship, 0, Rnd(0, 3));",
                        "                ShipSkill(ship, 1, Rnd(0, 3));",
                        "            }",
                        "            else if(danger < 85) {",
                        "                ShipSkill(ship, 0, Rnd(0, 4));",
                        "                ShipSkill(ship, 1, Rnd(0, 4));",
                        "            }",
                        "            else {",
                        "                ShipSkill(ship, 0, Rnd(1, 4));",
                        "                ShipSkill(ship, 1, Rnd(1, 4));",
                        "            }",
                        "        }",
                        "        ShipSkill(ship, 2, 6);",
                        "        ShipSkill(ship, 5, 0);",
                        "        if(GTL <= 5) ItemSize(hull, Rnd(75, 175));",
                        "        else if(GTL <= 7) ItemSize(hull, Rnd(100, 200));",
                        "        else ItemSize(hull, Rnd(125, 250));",
                        "        SpecialToEquipment(FindBonusByCustomTag('Mutenok'), hull);",
                        "        Chameleon(ship);",
                        "        ItemOwner(hull, None);",
                        "        ItemLevel(hull, Rnd(1, 3));",
                        "        HullHP(hull, ItemSize(hull));",
                        "        ItemDurability(hull, 100);",
                        "        GiveMutenokEq(ship, t_Engine);",
                        "        GiveMutenokEq(ship, t_FuelTanks);",
                        "        if(CountEqByType(ship, 'Def')) GiveMutenokEq(ship, t_RepairRobot);",
                        "        if(CountEqByType(ship, 'Def')) GiveMutenokEq(ship, t_DefGenerator);",
                        "        if(CountEqByType(ship, 'Other')) GiveMutenokEq(ship, t_CargoHook);",
                        "        if(CountEqByType(ship, 'Other')) GiveMutenokEq(ship, t_Radar);",
                        "        if(CountEqByType(ship, 'Other')) GiveMutenokEq(ship, t_Scaner);",
                        "        num = CountEqByType(ship, 'Weapon');",
                        "        for(int j = 0; j < num; j = j + 1) GiveMutenokEq(ship, t_CustomWeapon);",
                        "        AddItemToShip(ship, CreateArt(t_ArtDefToEnergy, None));",
                        "        AddItemToShip(ship, CreateArt(t_ArtEnergyPulse, None));",
                        "    }",
                        "    else if(sub_type == 4) { //Рогит",
                        "        ShipType(ship, 'Klissan4');",
                        "        a = CreateCustomCountableItem('kProtoplasm', Rnd(3, 25), 1);",
                        "        EqCustomFaction(a, 'Klissan');",
                        "        ItemCost(a, ItemSize(a) * 30);",
                        "        ShipAddDropItem(ship, a);",
                        "        if(rndInt <= 25) knum = 0;",
                        "        else if(rndInt <= 80) knum = 1;",
                        "        else knum = 2;",
                        "        ShipPilotRace(ship, 1);",
                        "        ShipAddCustomShipInfo(ship, 'Rogit_damage', 'NoShow');",
                        "        if(alpha) {",
                        "            ShipSkill(ship, 0, 6);",
                        "            ShipSkill(ship, 1, 6);",
                        "        }",
                        "        if(danger < 40) {",
                        "            ShipSkill(ship, 0, Rnd(0, 3));",
                        "            ShipSkill(ship, 1, Rnd(0, 3));",
                        "        }",
                        "        else if(danger < 65) {",
                        "            ShipSkill(ship, 0, Rnd(0, 4));",
                        "            ShipSkill(ship, 1, Rnd(0, 4));",
                        "        }",
                        "        else if(danger < 85) {",
                        "            ShipSkill(ship, 0, Rnd(0, 5));",
                        "            ShipSkill(ship, 1, Rnd(0, 5));",
                        "        }",
                        "        else {",
                        "            ShipSkill(ship, 0, Rnd(1, 5));",
                        "            ShipSkill(ship, 1, Rnd(1, 5));",
                        "        }",
                        "        ShipSkill(ship, 2, 6);",
                        "        if(GTL <= 5) ItemSize(hull, Rnd(125, 250));",
                        "        else if(GTL <= 7) ItemSize(hull, Rnd(150, 300));",
                        "        else ItemSize(hull, Rnd(175, 350));",
                        "        SpecialToEquipment(FindBonusByCustomTag('Rogit'), hull);",
                        "        Chameleon(ship);",
                        "        ItemOwner(hull, None);",
                        "        ItemLevel(hull, Rnd(3, 4));",
                        "        HullHP(hull, ItemSize(hull));",
                        "        ItemDurability(hull, 100);",
                        "        GiveRogitEq(ship, t_Engine);",
                        "        GiveRogitEq(ship, t_FuelTanks);",
                        "        if(CountEqByType(ship, 'Def')) GiveRogitEq(ship, t_RepairRobot);",
                        "        if(CountEqByType(ship, 'Def')) GiveRogitEq(ship, t_DefGenerator);",
                        "        if(CountEqByType(ship, 'Other')) GiveRogitEq(ship, t_CargoHook);",
                        "        if(CountEqByType(ship, 'Other')) GiveRogitEq(ship, t_Radar);",
                        "        if(CountEqByType(ship, 'Other')) GiveRogitEq(ship, t_Scaner);",
                        "        num = CountEqByType(ship, 'Weapon');",
                        "        for(j = 0; j < num; j = j + 1) GiveRogitEq(ship, t_CustomWeapon);",
                        "        AddItemToShip(ship, CreateArt(t_ArtSplinter, None));",
                        "        AddItemToShip(ship, CreateArt(t_ArtEnergyPulse, None));",
                        "    }",
                        "    else if(sub_type == 3) { //Катаури",
                        "        ShipType(ship, 'Klissan3');",
                        "        a = CreateCustomCountableItem('kProtoplasm', Rnd(5, 45), 1);",
                        "        EqCustomFaction(a, 'Klissan');",
                        "        ItemCost(a, ItemSize(a) * 30);",
                        "        ShipAddDropItem(ship, a);",
                        "        if(rndInt <= 15) knum = 0;",
                        "        else if(rndInt <= 50) knum = 1;",
                        "        else if(rndInt <= 85) knum = 2;",
                        "        else knum = 3;",
                        "        ShipPilotRace(ship, 2);",
                        "        ShipAddCustomShipInfo(ship, 'Katauri_attack', 'NoShow');",
                        "        if(alpha) {",
                        "            ShipSkill(ship, 0, 6);",
                        "            ShipSkill(ship, 1, 6);",
                        "        }",
                        "        if(danger < 40) {",
                        "            ShipSkill(ship, 0, Rnd(1, 3));",
                        "            ShipSkill(ship, 1, Rnd(1, 2));",
                        "        }",
                        "        else if(danger < 65) {",
                        "            ShipSkill(ship, 0, Rnd(1, 4));",
                        "            ShipSkill(ship, 1, Rnd(1, 3));",
                        "        }",
                        "        else if(danger < 85) {",
                        "            ShipSkill(ship, 0, Rnd(1, 5));",
                        "            ShipSkill(ship, 1, Rnd(1, 4));",
                        "        }",
                        "        else {",
                        "            ShipSkill(ship, 0, Rnd(2, 5));",
                        "            ShipSkill(ship, 1, Rnd(2, 4));",
                        "        }",
                        "        ShipSkill(ship, 2, 6);",
                        "        if(GTL <= 5) ItemSize(hull, Rnd(175, 300));",
                        "        else if(GTL <= 7) ItemSize(hull, Rnd(200, 365));",
                        "        else ItemSize(hull, Rnd(250, 430));",
                        "        SpecialToEquipment(FindBonusByCustomTag('Katauri'), hull);",
                        "        Chameleon(ship);",
                        "        ItemOwner(hull, None);",
                        "        ItemLevel(hull, Rnd(4, 5));",
                        "        HullHP(hull, ItemSize(hull));",
                        "        ItemDurability(hull, 100);",
                        "        GiveKatauriEq(ship, t_Engine);",
                        "        GiveKatauriEq(ship, t_FuelTanks);",
                        "        if(CountEqByType(ship, 'Def')) GiveKatauriEq(ship, t_RepairRobot);",
                        "        if(CountEqByType(ship, 'Def')) GiveKatauriEq(ship, t_DefGenerator);",
                        "        if(CountEqByType(ship, 'Other')) GiveKatauriEq(ship, t_CargoHook);",
                        "        if(CountEqByType(ship, 'Other')) GiveKatauriEq(ship, t_Radar);",
                        "        if(CountEqByType(ship, 'Other')) GiveKatauriEq(ship, t_Scaner);",
                        "        num = CountEqByType(ship, 'Weapon');",
                        "        for(j = 0; j < num; j = j + 1) GiveKatauriEq(ship, t_CustomWeapon);",
                        "        AddItemToShip(ship, CreateArt(t_ArtDecelerate, None));",
                        "        AddItemToShip(ship, CreateArt(t_ArtFastRacks, None));",
                        "    }",
                        "    else if(sub_type == 2) { //Нондус",
                        "        ShipType(ship, 'Klissan2');",
                        "        a = CreateCustomCountableItem('kProtoplasm', Rnd(15, 60), 1);",
                        "        EqCustomFaction(a, 'Klissan');",
                        "        ItemCost(a, ItemSize(a) * 30);",
                        "        ShipAddDropItem(ship, a);",
                        "        if(rndInt <= 10) knum = 0;",
                        "        else if(rndInt <= 30) knum = 1;",
                        "        else if(rndInt <= 65) knum = 2;",
                        "        else knum = 3;",
                        "        ShipPilotRace(ship, 3);",
                        "        if(alpha) {",
                        "            ShipSkill(ship, 0, 6);",
                        "            ShipSkill(ship, 1, 6);",
                        "        }",
                        "        if(danger < 40) {",
                        "            ShipSkill(ship, 0, Rnd(2, 3));",
                        "            ShipSkill(ship, 1, Rnd(1, 2));",
                        "        }",
                        "        else if(danger < 65) {",
                        "            ShipSkill(ship, 0, Rnd(2, 4));",
                        "            ShipSkill(ship, 1, Rnd(1, 3));",
                        "        }",
                        "        else if(danger < 85) {",
                        "            ShipSkill(ship, 0, Rnd(2, 5));",
                        "            ShipSkill(ship, 1, Rnd(1, 4));",
                        "        }",
                        "        else {",
                        "            ShipSkill(ship, 0, Rnd(3, 5));",
                        "            ShipSkill(ship, 1, Rnd(2, 4));",
                        "        }",
                        "        ShipSkill(ship, 2, 6);",
                        "        if(GTL <= 5) ItemSize(hull, Rnd(400, 600));",
                        "        else if(GTL <= 7) ItemSize(hull, Rnd(450, 700));",
                        "        else ItemSize(hull, Rnd(500, 800));",
                        "        SpecialToEquipment(FindBonusByCustomTag('Nondus'), hull);",
                        "        ShipAddCustomShipInfo(ship, 'Nondus_shield', 'NoShow');",
                        "        Chameleon(ship);",
                        "        ItemOwner(hull, None);",
                        "        ItemLevel(hull, Rnd(4, 7));",
                        "        HullHP(hull, ItemSize(hull));",
                        "        ItemDurability(hull, 100);",
                        "        ItemImprovement(hull, 1);",
                        "        GiveNondusEq(ship, t_Engine);",
                        "        GiveNondusEq(ship, t_FuelTanks);",
                        "        if(CountEqByType(ship, 'Def')) GiveNondusEq(ship, t_RepairRobot);",
                        "        if(CountEqByType(ship, 'Def')) GiveNondusEq(ship, t_DefGenerator);",
                        "        if(CountEqByType(ship, 'Other')) GiveNondusEq(ship, t_CargoHook);",
                        "        if(CountEqByType(ship, 'Other')) GiveNondusEq(ship, t_Radar);",
                        "        if(CountEqByType(ship, 'Other')) GiveNondusEq(ship, t_Scaner);",
                        "        num = CountEqByType(ship, 'Weapon');",
                        "        for(j = 0; j < num; j = j + 1) GiveNondusEq(ship, t_CustomWeapon);",
                        "        if(!Rnd(0, 2)) AddItemToShip(ship, CreateArt(t_ArtefactDef, None));",
                        "        AddItemToShip(ship, CreateArt(t_ArtefactMiniExpl, None));",
                        "    }",
                        "    else { //Эгемон",
                        "        ShipType(ship, 'Klissan1');",
                        "        if(egemon_mod) knum = Rnd(9, 12);",
                        "        else knum = 1;",
                        "        for(i = 0; i < knum; i = i + 1) {",
                        "            a = CreateCustomCountableItem('kProtoplasm', Rnd(20, 90), 1);",
                        "            EqCustomFaction(a, 'Klissan');",
                        "            ItemCost(a, ItemSize(a) * 30);",
                        "            ShipAddDropItem(ship, a);",
                        "        }",
                        "        if(egemon_mod) {",
                        "            if(rndInt <= 15) knum = 2;",
                        "            else if(rndInt <= 45) knum = 3;",
                        "            else if(rndInt <= 90) knum = 4;",
                        "            else knum = 5;",
                        "        }",
                        "        else {",
                        "            if(rndInt <= 5) knum = 0;",
                        "            else if(rndInt <= 20) knum = 1;",
                        "            else if(rndInt <= 50) knum = 2;",
                        "            else if(rndInt <= 90) knum = 3;",
                        "            else knum = 4;",
                        "        }",
                        "        ShipPilotRace(ship, 4);",
                        "        ShipAddCustomShipInfo(ship, 'Egemon_armor', 'NoShow');",
                        "        if(alpha) {",
                        "            ShipSkill(ship, 0, 6);",
                        "            ShipSkill(ship, 1, 6);",
                        "        }",
                        "        if(danger < 40) {",
                        "            ShipSkill(ship, 0, Rnd(2, 4));",
                        "            ShipSkill(ship, 1, Rnd(1, 3));",
                        "        }",
                        "        else if(danger < 65) {",
                        "            ShipSkill(ship, 0, Rnd(2, 5));",
                        "            ShipSkill(ship, 1, Rnd(1, 4));",
                        "        }",
                        "        else if(danger < 85) {",
                        "            ShipSkill(ship, 0, Rnd(2, 6));",
                        "            ShipSkill(ship, 1, Rnd(1, 5));",
                        "        }",
                        "        else {",
                        "            ShipSkill(ship, 0, Rnd(3, 6));",
                        "            ShipSkill(ship, 1, Rnd(2, 5));",
                        "        }",
                        "        ShipSkill(ship, 2, 6);",
                        "        if(egemon_mod) {",
                        "            if(GTL <= 5) ItemSize(hull, Rnd(2750, 4250));",
                        "            else if(GTL <= 7) ItemSize(hull, Rnd(3125, 5000));",
                        "            else ItemSize(hull, Rnd(3500, 6000));",
                        "            SpecialToEquipment(FindBonusByCustomTag('Gigas'), hull);",
                        "        }",
                        "        else {",
                        "            if(GTL <= 5) ItemSize(hull, Rnd(550, 850));",
                        "            else if(GTL <= 7) ItemSize(hull, Rnd(625, 1000));",
                        "            else ItemSize(hull, Rnd(700, 1200));",
                        "            SpecialToEquipment(FindBonusByCustomTag('Egemon'), hull);",
                        "        }",
                        "        Chameleon(ship);",
                        "        ItemOwner(hull, None);",
                        "        ItemLevel(hull, Rnd(4, 7));",
                        "        HullHP(hull, ItemSize(hull));",
                        "        ItemImprovement(hull, Rnd(1, 2));",
                        "        GiveEgemonEq(ship, t_Engine);",
                        "        GiveEgemonEq(ship, t_FuelTanks);",
                        "        if(CountEqByType(ship, 'Def')) GiveEgemonEq(ship, t_RepairRobot);",
                        "        if(CountEqByType(ship, 'Def')) GiveEgemonEq(ship, t_DefGenerator);",
                        "        if(CountEqByType(ship, 'Other')) GiveEgemonEq(ship, t_CargoHook);",
                        "        if(CountEqByType(ship, 'Other')) GiveEgemonEq(ship, t_Radar);",
                        "        if(CountEqByType(ship, 'Other')) GiveEgemonEq(ship, t_Scaner);",
                        "        num = CountEqByType(ship, 'Weapon');",
                        "        for(j = 0; j < num; j = j + 1) GiveEgemonEq(ship, t_CustomWeapon);",
                        "        AddItemToShip(ship, CreateArt(t_ArtEnergyPulse, None));",
                        "    }",
                        "    if(egemon_mod) {",
                        "        ShipSpecialBonuses(ship, bonRadar, 2010); //Раньше использовалось в качестве \"маркера\" для ингибитора, что этот корабль не должен быть перенаправлен при гиперпрыжке (больше не используется)",
                        "        ShipSpecialBonuses(ship, bonSpeed, (KlissanDiffLevel / 9) * GTL);",
                        "        ShipSpecialBonuses(ship, bonWEnergy, (KlissanDiffLevel / 75) * GTL);",
                        "        ShipSpecialBonuses(ship, bonWSplinter, (KlissanDiffLevel / 60) * GTL);",
                        "        ShipSpecialBonuses(ship, bonWMissile, (KlissanDiffLevel / 60) * GTL);",
                        "        ShipSpecialBonuses(ship, bonScan, 100);",
                        "    }",
                        "//    else if(alpha) {",
                        "//        ShipSpecialBonuses(ship, bonSpeed, (KlissanDiffLevel / 9) * GTL);",
                        "//        ShipSpecialBonuses(ship, bonWEnergy, (KlissanDiffLevel / 75) * GTL);",
                        "//        ShipSpecialBonuses(ship, bonWSplinter, (KlissanDiffLevel / 60) * GTL);",
                        "//        ShipSpecialBonuses(ship, bonWMissile, (KlissanDiffLevel / 60) * GTL);",
                        "//        ShipSpecialBonuses(ship, bonDef, (KlissanDiffLevel / 150) * GTL);",
                        "//        ShipSpecialBonuses(ship, bonHull, (KlissanDiffLevel / 300) * GTL);",
                        "//        ShipSpecialBonuses(ship, bonDroid, (KlissanDiffLevel / 60) * GTL);",
                        "//        ShipSpecialBonuses(ship, bonScan, 100);",
                        "//    }",
                        "    EqCustomFaction(hull, 'Klissan'); //Вешаем на корпус клисанскую фракцию",
                        "    if(ShipPilotRace(ship) == Peleng) ShipFace(ship, 24);",
                        "    else if(ShipPilotRace(ship) == People) ShipFace(ship, 45);",
                        "    else if(ShipPilotRace(ship) == Gaal) ShipFace(ship, 27);",
                        "    else ShipFace(ship, 26);",
                        "    ArrangeItems(ship);",
                        "    if(ruchnik_bonus) ShipAddCustomShipInfo(ship, 'Dodge_bonus', 'NoShow', HullHP(ship));",
                        "    else ShipAddCustomShipInfo(ship, 'Dodge', 'NoShow', HullHP(ship)); //Акткод на уклонение",
                        "    if(!ShipEqInSlot(ship, t_Radar)) ShipSpecialBonuses(ship, bonSlotRadar, -1);",
                        "    if(!ShipEqInSlot(ship, t_Scaner)) ShipSpecialBonuses(ship, bonSlotScaner, -1);",
                        "    if(!ShipEqInSlot(ship, t_RepairRobot)) ShipSpecialBonuses(ship, bonSlotDroid, -1);",
                        "    if(!ShipEqInSlot(ship, t_DefGenerator)) ShipSpecialBonuses(ship, bonSlotDef, -1);",
                        "    ShipSpecialBonuses(ship, bonSlotHook, -1);",
                        "    s = 5 - ShipCntWeapon(ship);",
                        "    ShipSpecialBonuses(ship, bonSlotWeapon, -s);",
                        "    for(i = 1; i < ShipItems(ship); i = i + 1) {",
                        "        s = ShipItems(ship, i);",
                        "        NoDropItem(s, 0);",
                        "    }",
                        "    for(i = 0; i < ShipArts(ship); i = i + 1) {",
                        "        s = ShipArts(ship, i);",
                        "        NoDropItem(s, 1);",
                        "    }",
                        "    for(i = 0; i < knum; i = i + 1) {",
                        "        int rand = Rnd(1, ArrayDim(hit_list) - 1);",
                        "        rndInt = CreateQuestItem(hit_list[rand], None);",
                        "        if(egemon_mod) ItemCost(rndInt, ItemCost(rndInt) * 4 + GalaxyMoney(1));",
                        "        EqCustomFaction(rndInt, 'Klissan');",
                        "        ShipAddDropItem(ship, rndInt);",
                        "        ArrayDelete(hit_list, rand);",
                        "    }",
                        "",
                        "    //Выдаём клисанам споры",
                        "    ShipImproveItems(ship, Rnd(0, 7));",
                        "    if(Rnd(1, 100) <= 4)",
                        "    {",
                        "        cur_item = CreateMM(FindBonusByNameInCfg(CT('Script.Mod_ShuKlissan.SporesGiveList.' + Rnd(1, 0 + CT('Script.Mod_ShuKlissan.SporesGiveList.Count')))));",
                        "        ShipAddDropItem(ship, cur_item);",
                        "    }",
                        "",
                        "    result = ship;",
                        "}",
                        "",
                        "function GiveMutenokEq(dword ship, int eq_type)",
                        "{",
                        "    dword item, techlvl, size; int tRnd; str typeStr;",
                        "    if(eq_type == t_CustomWeapon)",
                        "    {",
                        "        tRnd = Rnd(1, 100);",
                        "        if(danger <= 20)",
                        "        {",
                        "            if(tRnd <= 30) typeStr = 'klissan_laser';",
                        "            else if(tRnd <= 40) typeStr = 'klissan_splitter';",
                        "            else if(tRnd <= 85) typeStr = 'klissan_capacer';",
                        "            else typeStr = 'klissan_stunner';",
                        "        }",
                        "        else if(danger <= 40)",
                        "        {",
                        "            if(tRnd <= 33) typeStr = 'klissan_laser';",
                        "            else if(tRnd <= 40) typeStr = 'klissan_splitter';",
                        "            else if(tRnd <= 80) typeStr = 'klissan_capacer';",
                        "            else typeStr = 'klissan_stunner';",
                        "        }",
                        "        else if(danger <= 60)",
                        "        {",
                        "            if(tRnd <= 35) typeStr = 'klissan_laser';",
                        "            else if(tRnd <= 42) typeStr = 'klissan_splitter';",
                        "            else if(tRnd <= 70) typeStr = 'klissan_capacer';",
                        "            else typeStr = 'klissan_stunner';",
                        "        }",
                        "        else if(danger <= 80)",
                        "        {",
                        "            if(tRnd <= 42) typeStr = 'klissan_laser';",
                        "            else if(tRnd <= 47) typeStr = 'klissan_splitter';",
                        "            else if(tRnd <= 60) typeStr = 'klissan_capacer';",
                        "            else typeStr = 'klissan_stunner';",
                        "        }",
                        "        else",
                        "        {",
                        "            if(tRnd <= 42) typeStr = 'klissan_laser';",
                        "            else if(tRnd <= 48) typeStr = 'klissan_splitter';",
                        "            else if(tRnd <= 54) typeStr = 'klissan_capacer';",
                        "            else typeStr = 'klissan_stunner';",
                        "        }",
                        "        if(typeStr == 'klissan_laser') size = Rnd(10, 20);",
                        "        if(typeStr == 'klissan_splitter') size = Rnd(13, 25);",
                        "        if(typeStr == 'klissan_capacer') size = Rnd(10, 22);",
                        "        if(typeStr == 'klissan_stunner') size = Rnd(15, 30);",
                        "    }",
                        "    if(danger <= 15) techlvl = Rnd(2, 3);",
                        "    else if(danger <= 30) techlvl = Rnd(2, 3);",
                        "    else if(danger <= 45) techlvl = Rnd(3, 4);",
                        "    else if(danger <= 60) techlvl = Rnd(4, 5);",
                        "    else if(danger <= 75) techlvl = Rnd(5, 6);",
                        "    else if(danger <= 90) techlvl = Rnd(6, 7);",
                        "    else techlvl = Rnd(7, 8);",
                        "    if(eq_type != t_CustomWeapon)",
                        "    {",
                        "        if(GTL <= 5) size = Rnd(10, 20);",
                        "        else if(GTL <= 7) size = Rnd(10, 25);",
                        "        else size = Rnd(10, 30);",
                        "        if(eq_type == t_Radar || eq_type == t_Scaner) size = size * 75 / 100;",
                        "    }",
                        "    if(eq_type != t_CustomWeapon) item = CreateEquipment(eq_type, size, techlvl, None);",
                        "    else item = CreateCustomWeapon(typeStr, size, techlvl, None);",
                        "",
                        "    if(!Rnd(0, 4))",
                        "    {",
                        "        if(ItemType(item) == t_CustomWeapon || ItemType(item) == t_Engine || ItemType(item) == t_CargoHook) ItemImprovement(item, 0, 0);",
                        "        else ItemImprovement(item, 0);",
                        "    }",
                        "",
                        "    EqCustomFaction(item, 'Klissan');",
                        "    AddItemToShip(ship, item);",
                        "    result = item;",
                        "}",
                        "",
                        "function GiveRogitEq(dword ship, int eq_type)",
                        "{",
                        "    dword item, techlvl, size; int tRnd; str typeStr;",
                        "    if(eq_type == t_CustomWeapon)",
                        "    {",
                        "        tRnd = Rnd(1, 100);",
                        "        if(danger <= 20)",
                        "        {",
                        "            if(tRnd <= 15) typeStr = 'klissan_antimatter';",
                        "            else if(tRnd <= 40) typeStr = 'klissan_splitter';",
                        "            else if(tRnd <= 60) typeStr = 'klissan_laser';",
                        "            else if(tRnd <= 80) typeStr = 'klissan_moldikvink';",
                        "            else typeStr = 'klissan_burster';",
