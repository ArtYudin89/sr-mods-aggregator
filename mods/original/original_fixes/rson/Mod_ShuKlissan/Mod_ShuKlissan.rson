                        "    result = item;",
                        "}",
                        "function GiveEgemonEq(dword ship, int eq_type)",
                        "{",
                        "    dword item, techlvl, size; int tRnd; str typeStr;",
                        "    if(eq_type == t_CustomWeapon)",
                        "    {",
                        "        tRnd = Rnd(1, 100);",
                        "        if(danger <= 20)",
                        "        {",
                        "            if(tRnd <= 35) typeStr = 'klissan_nihiler';",
                        "            else if(tRnd <= 57) typeStr = 'klissan_emitter';",
                        "            else if(tRnd <= 85) typeStr = 'klissan_nargun';",
                        "            else typeStr = 'klissan_hellwave';",
                        "        }",
                        "        else if(danger <= 40)",
                        "        {",
                        "            if(tRnd <= 30) typeStr = 'klissan_nihiler';",
                        "            else if(tRnd <= 55) typeStr = 'klissan_emitter';",
                        "            else if(tRnd <= 80) typeStr = 'klissan_nargun';",
                        "            else typeStr = 'klissan_hellwave';",
                        "        }",
                        "        else if(danger <= 60)",
                        "        {",
                        "            if(tRnd <= 25) typeStr = 'klissan_nihiler';",
                        "            else if(tRnd <= 52) typeStr = 'klissan_emitter';",
                        "            else if(tRnd <= 75) typeStr = 'klissan_nargun';",
                        "            else typeStr = 'klissan_hellwave';",
                        "        }",
                        "        else if(danger <= 80)",
                        "        {",
                        "            if(tRnd <= 20) typeStr = 'klissan_nihiler';",
                        "            else if(tRnd <= 50) typeStr = 'klissan_emitter';",
                        "            else if(tRnd <= 73) typeStr = 'klissan_nargun';",
                        "            else typeStr = 'klissan_hellwave';",
                        "        }",
                        "        else",
                        "        {",
                        "            if(tRnd <= 15) typeStr = 'klissan_nihiler';",
                        "            else if(tRnd <= 35) typeStr = 'klissan_emitter';",
                        "            else if(tRnd <= 70) typeStr = 'klissan_nargun';",
                        "            else typeStr = 'klissan_hellwave';",
                        "        }",
                        "        if(typeStr == 'klissan_nihiler') size = Rnd(40, 75);",
                        "        if(typeStr == 'klissan_emitter') size = Rnd(60, 85);",
                        "        if(typeStr == 'klissan_nargun') size = Rnd(110, 130);",
                        "        if(typeStr == 'klissan_hellwave') size = Rnd(130, 160);",
                        "    }",
                        "    if(danger <= 15) techlvl = Rnd(2, 3);",
                        "    else if(danger <= 30) techlvl = Rnd(3, 4);",
                        "    else if(danger <= 45) techlvl = Rnd(4, 5);",
                        "    else if(danger <= 60) techlvl = Rnd(5, 7);",
                        "    else if(danger <= 75) techlvl = Rnd(7, 8);",
                        "    else if(danger <= 90) techlvl = 8;",
                        "    else techlvl = 8;",
                        "    if(eq_type != t_CustomWeapon)",
                        "    {",
                        "        if(GTL <= 5) size = Rnd(50, 75);",
                        "        else if(GTL <= 7) size = Rnd(60, 90);",
                        "        else size = Rnd(70, 110);",
                        "        if(eq_type == t_Radar || eq_type == t_Scaner) size = size * 75 / 100;",
                        "    }",
                        "    if(eq_type != t_CustomWeapon) item = CreateEquipment(eq_type, size, techlvl, None);",
                        "    else item = CreateCustomWeapon(typeStr, size, techlvl, None);",
                        "",
                        "    if(Rnd(0, 7))",
                        "    {",
                        "        if(ItemType(item) == t_CustomWeapon || ItemType(item) == t_Engine || ItemType(item) == t_CargoHook) ItemImprovement(item, 0, 0);",
                        "        else ItemImprovement(item, 0);",
                        "    }",
                        "",
                        "    EqCustomFaction(item, 'Klissan');",
                        "    AddItemToShip(ship, item);",
                        "    result = item;",
                        "}",
                        "//Функция постройки нейролинка. Первый параметр - группа, к которой он будет присоединен.",
                        "//Возвращает указатель на созданный нейролинк.",
                        "function BuyNeurolink(dword group) {",
                        "    dword ruins = BuildRuins(PlanetToStar(PlanetPirateClan()), t_UB);",
                        "    int i = Rnd(200 + 60 * GalaxyTechLevel(), 300 + 65 * GalaxyTechLevel());",
                        "    HullHP(ruins, i);",
                        "    ItemSize(ShipItems(ruins, 0), i);",
                        "    ShipSpecialBonuses(ruins, bonDef, -150);",
                        "    ShipSpecialBonuses(ruins, bonMass, 300);",
                        "    SetName(ruins, '#' + Rnd(1, 500));",
                        "    NoLanding(ruins, 1);",
                        "    ShipOwner(ruins, PirateClan);",
                        "    ShipType(ruins, 'KB');",
                        "    Chameleon(ruins, 'Ruins.KB');",
                        "    ArrangeItems(ruins);",
                        "    ClearRuinsShop(ruins);",
                        "    ShipJoin(group, ruins);",
                        "    result=ruins;",
                        "}",
                        "//Функции создания Хандлера и Махпеллы. Первый параметр - группа для присоединения.",
                        "//Возвращают указатель на созденный корабль (станцию).",
                        "function BuyHandler(dword group) {",
                        "    dword ship = BuildRuins(PlanetToStar(PlanetPirateClan()), t_CB);",
                        "    SetName(ship, CT(\"Script.Mod_ShuKlissan.358\"));",
                        "    ItemSize(ShipItems(ship, 0), Rnd(2500, 3000));",
                        "    HullHP(ship, 'To100');",
                        "    NoLanding(ship, 1);",
                        "    ShipOwner(ship, PirateClan);",
                        "    ShipPilotRace(ship, Fei);",
                        "    ShipType(ship, 'Handler');",
                        "    Chameleon(ship, 'Ruins.Handler');",
                        "    ClearRuinsShop(ship);",
                        "    ShipJoin(group, ship);",
                        "}",
                        "function BuyMachpella(dword group) {",
                        "    dword ship, item; int i;",
                        "    ship = BuildRuins(PlanetToStar(PlanetPirateClan()), t_CB);",
                        "    SetName(ship, CT(\"Script.Mod_ShuKlissan.357\"));",
                        "    ItemSize(ShipItems(ship, 0), Rnd(2500 + GalaxyDiffLevels() * 5, 3000 + GalaxyDiffLevels() * 6));",
                        "    HullHP(ship, 'To100');",
                        "    NoLanding(ship, 1);",
                        "    ShipOwner(ship, PirateClan);",
                        "    ShipType(ship, 'Machpella');",
                        "    Chameleon(ship, 'Ruins.Machpella');",
                        "    ClearRuinsShop(ship);",
                        "    for(i = 0; i <= 2; i = i + 1) ShipSkill(ship, i, 6);",
                        "    danger = 100;",
                        "    for(i = ShipItems(ship) - 1; i > 0; i = i - 1) FreeItem(GetItemFromShip(ship, i));",
                        "    for(i = t_FuelTanks; i <= t_DefGenerator; i = i + 1) GiveEgemonEq(ship, i);",
                        "    for(i = 0; i < 4; i = i + 1) GiveEgemonEq(ship, t_CustomWeapon);",
                        "    item = CreateCustomWeapon('klissan_hellwave', 150, 8, 6);",
                        "    SetName(item, '<color=0,191,255>' + CT(\"Script.Mod_ShuKlissan.356\") + '</color>');",
                        "    EqCustomFaction(item, 'Klissan');",
                        "    SpecialToEquipment(FindBonusByCustomTag('MachpellaGun'), item);",
                        "    NoDropItem(item, 1);",
                        "    SetEquipmentStats(item, 140, 0);",
                        "    SetEquipmentStats(item, 140, 1);",
                        "    SetEquipmentStats(item, 400, 2);",
                        "    AddItemToShip(ship, item);",
                        "    for(i = 1; i < ShipItems(ship); i = i + 1) NoDropItem(ShipItems(ship, i), 1);",
                        "    item = CreateCustomWeapon('klissan_hellwave', 150, 8, 6);",
                        "    SetName(item, '<color=0,191,255>' + CT(\"Script.Mod_ShuKlissan.356\") + '</color>');",
                        "    EqCustomFaction(item, 'Klissan');",
                        "    SpecialToEquipment(FindBonusByCustomTag('MachpellaGun'), item);",
                        "    SetEquipmentStats(item, 140, 0);",
                        "    SetEquipmentStats(item, 140, 1);",
                        "    SetEquipmentStats(item, 400, 2);",
                        "    ShipAddDropItem(ship, item);",
                        "    ShipSpecialBonuses(ship, bonWEnergy, 15 + KlissanDiffLevel / 3);",
                        "    ShipSpecialBonuses(ship, bonWSplinter, 15 + KlissanDiffLevel / 3);",
                        "    ShipSpecialBonuses(ship, bonWMissile, 15 + KlissanDiffLevel / 3);",
                        "    ShipSpecialBonuses(ship, bonMass, 500);",
                        "    ShipSpecialBonuses(ship, bonSpeed, -300);",
                        "    ShipSpecialBonuses(ship, bonDroid, 100);",
                        "    ShipJoin(group, ship);",
                        "}",
                        "//Функция удаления всех товаров и оборудования из магазина. Параметр - указатель на станцию.",
                        "function ClearRuinsShop(dword ruins) {",
                        "    int i, goods;",
                        "    for(i = t_Food ; i <= t_Narcotics ; i = i + 1) {",
                        "        goods = GoodsAdd(ruins, i, 0);",
                        "        GoodsAdd(ruins, i, -goods);",
                        "    }",
                        "    for(i = ShopItems(ruins) - 1; i >= 0; i = i - 1) FreeItem(GetItemFromShop(ruins, i));",
                        "    NoShopUpdate(ruins, 1);",
                        "}",
                        "//Функция уничтожения клисан в ЧД. Первый параметр - указатель на систему, второй - указатель на ЧД.",
                        "function DestroyKlissansBH(dword system, dword hole) {",
                        "    int i; dword ship;",
                        "    for(i=0; i<StarShips(system); i=i+1) {",
                        "        ship=StarShips(system, i);",
                        "        if(!ShipInHole(ship))  continue;",
                        "        if(ShipOrderObj(ship)!=hole) continue;",
                        "        if(ShipType(ship)=='Machpella') continue;",
                        "        if(ShipType(ship)=='KB') ShipDestroy(ship);",
                        "        if(ShipCustomFaction(ship)=='Klissan') ShipDestroy(ship);",
                        "    }",
                        "}",
                        "//Функция передачи клисанской системы под контроль пиратов по ивенту. Параметр - указатель на систему.",
                        "function ForcedSystemTake(dword system) {",
                        "    int i; dword ship, planet, tempStar1, tempStar2; str newsStr;",
                        "    for(i = 0; i < StarShips(system); i = i + 1) {",
                        "        ship = StarShips(system, i);",
                        "        if(ShipType(ship) == 'Machpella') continue;",
                        "        if(ShipType(ship) == 'KB') ShipDestroy(ship);",
                        "        if(ShipType(ship) == 'Klissan1' || ShipType(ship) == 'Klissan2' || ShipType(ship) == 'Klissan3' || ShipType(ship) == 'Klissan4' || ShipType(ship) == 'Klissan5') ShipDestroy(ship);",
                        "    }",
                        "    for(i = 0; i < StarPlanets(system); i = i + 1) {",
                        "        planet = StarPlanets(system, i);",
                        "        if(PlanetOwner(planet) != None) {",
                        "            PlanetOwner(planet, PirateClan);",
                        "            BuyWarrior(planet);",
                        "        }",
                        "    }",
                        "    planet = FindPlanet(system, 'NotKling,NotNone', 0, 0);",
                        "    newsStr = CT('GalaxyNews.Global.PiratesTakeSystemFromKlissan' + Rnd(1, 2));",
                        "    newsStr = Format(newsStr, '<Star' + '>', Name(system), '<Sector' + '>', Name(StarToCon(system)), '<Planet' + '>', Name(planet));",
                        "    NewsAdd(newsStr);",
                        "    AddPlanetNews(newsStr, 67);",
                        "    StarOwner(system, 2);",
                        "    StarCustomFaction(system, '');",
                        "    for(i = 0; i < Rnd(1, 5); i = i + 1) { //Несколько пиратов появляются в Нифигаце и отправляются в \"освобождённую\" систему",
                        "        if(PlanetOwner(PlanetPirateClan()) == PirateClan) {",
                        "            ship = BuyWarrior(PlanetPirateClan());",
                        "            MakeShipEnterStar(ship, system, GalaxyStar(NifigatzId), Rnd(5, 8));",
                        "        }",
                        "        else {",
                        "            ship = BuyPirate(PlanetPirateClan());",
                        "            MakeShipEnterStar(ship, system, GalaxyStar(NifigatzId), Rnd(5, 8));",
                        "        }",
                        "    }",
                        "    for(i = 1; i <= klissanStars[0]; i = i + 1) {",
                        "        tempStar1 = klissanStars[i];",
                        "        tempStar2 = Id(system) - 1;",
                        "        if(tempStar1 == tempStar2) {",
                        "            ArrayDelete(klissanStars, i);",
                        "            klissanStars[0] = klissanStars[0] - 1;",
                        "            break;",
                        "        }",
                        "    }",
                        "}",
                        "//Функция выдачи награды за освобождение системы от клисан. Параметр - указатель на планету награждения.",
                        "//Возвращает текст для подстановки в диалог правительства.",
                        "function GiveLiberationAward(dword planet) {",
                        "    dword owner, awardType, experience, rewardChance, artChance, progChance;",
                        "    int i, j, tRnd, award, number, beginPriority, endPriority;",
                        "    str awardName, dialogText, addStr, tempStr;",
                        "    owner=PlanetOwner(planet);",
                        "    GotoGov(0);",
                        "    experience=round(ln(0.2*enemiesCnt+1)*1000+(PortionInDiapason(GalaxyTechLevel(), 1, 8, 250, 500)*Rnd(1,2)), 10);",
                        "    ShipFreeExp(Player(),ShipFreeExp(Player()) + experience);",
                        "    star_reward=0;",
                        "    planet_reward=0;",
                        "    //Определение доп. награды",
                        "    number=0;",
                        "    for(i=0; i<=5; i=i+1) number=number+CountReward(Player(), i);",
                        "    rewardChance=25-min(15, number);",
                        "    artChance=rewardChance+25-int(min(2.5*ShipArts(Player()), 15));",
                        "    number=0;",
                        "    for(i=5; i<=11; i=i+1) number=number+GetProgramm(i);",
                        "    if(!DomiksDefeated()) progChance=artChance+25-int(min(1.5*number, 15));",
                        "    else progChance=0;",
                        "    tRnd=Rnd(1, 100);",
                        "    if(tRnd<=rewardChance) awardType=0;",
                        "    else if(tRnd<=artChance) awardType=1;",
                        "    else if(tRnd<=progChance) awardType=2;",
                        "    else awardType=3;",
                        "    if(!awardType) { //Медаль",
                        "        number=GiveReward(Player(), PlanetRace(planet), Rnd(0, 1));",
                        "        GiveRewardByNom(Player(), number);",
                        "        awardName=CT('Reward.' + number + '.Name');",
                        "    }",
                        "    else if(awardType==1) { //Артефакт",
                        "        for(i=t_ArtefactHull; i<=t_ArtFastRacks; i=i+1) ArrayAdd(tempArr, i); //Копируем все артефакты в массив",
                        "        for(i=0; i<ShipArts(Player()); i=i+1) { //Убираем из выдачи имеющиеся у игрока",
                        "            award=ShipArts(Player(), i);",
                        "            for(j=1; j<ArrayDim(tempArr); j=j+1) {",
                        "                if(ItemType(award)==tempArr[j]) ArrayDelete(tempArr, j);",
                        "            } //Выдаем один случайный",
                        "            if(ArrayDim(tempArr)>1) number=tempArr[Rnd(1, ArrayDim(tempArr)-1)];",
                        "            else number=Rnd(t_ArtefactHull, t_ArtFastRacks);",
                        "            award=CreateArt(number, owner);",
                        "        }",
                        "        ArrayClear(tempArr);",
                        "        AddItemToShip(Player(), award);",
                        "        awardName=Name(award);",
                        "        tempStr=CT('Script.Mod_ShuKlissan.AwardsList.Artifacts.' + number);",
                        "        tempStr=CT('Artefacts.' + tempStr + '.Description');",
                        "    }",
                        "    else if(awardType==2) { //Программа",
                        "        if(HaveProgramm(5)) number=Rnd(6, 11); //У игрока есть интерком",
                        "        else number=5;",
                        "        tRnd=Rnd(1, 3);",
                        "        SetProgramm(number, GetProgramm(number) + tRnd);",
                        "        tempStr=CT('Script.Mod_ShuKlissan.AwardsList.Programs.' + number);",
                        "        awardName=CT('Programms.' + tempStr + '.Name');",
                        "    }",
                        "    else { //Микромодуль",
                        "        beginPriority=PortionInDiapason(GalaxyTechLevel(), 1, 8, 100, 50);",
                        "        endPriority=PortionInDiapason(GalaxyTechLevel(), 1, 8, 65, 15);",
                        "        BuildListOfMMByPriority(tempArr, beginPriority, endPriority, 1);",
                        "        for(number=ArrayDim(tempArr)-1; number>=0; number=number-1) {",
                        "            if(number==-1) break;",
                        "            tempStr='';",
                        "            tempStr=CT('MicroModuls.'+BonusNumInCfg(tempArr[number])+'.Owner');",
                        "            if(tempStr=='' || findsubstr(tempStr,'Kling')==0 || findsubstr(tempStr,'Keller')==0 || findsubstr(tempStr,'Blazer')==0 || findsubstr(tempStr,'Terron')==0) ArrayDelete(tempArr, number);",
                        "            else continue;",
                        "        }",
                        "        if(ArrayDim(tempArr)-1>1) {",
                        "            number=tempArr[Rnd(1, ArrayDim(tempArr)-1)];",
                        "            award=CreateMM(number);",
                        "            ItemOwner(award, owner);",
                        "        }",
                        "        ArrayClear(tempArr);",
                        "        AddItemToShip(Player(), award);",
                        "        awardName=CT('MicroModuls.' + BonusNumInCfg(number) + '.Name');",
                        "        tempStr=BonusText(number);",
                        "    }",
                        "    if(owner==PirateClan) {",
                        "        addStr='LiberationAwardPirateClan';",
                        "        dialogText='</color>'+CT('PlanetCongratulations.LiberationStarPirateClanFromKlisan.PirateClanText' + Rnd(1, int(CT('PlanetCongratulations.LiberationStarPirateClanFromKlisan.CongratulationsCount'))));",
                        "    }",
                        "    else {",
                        "        addStr='LiberationAwardNormals';",
                        "        if(owner==Maloc) dialogText='</color>'+CT('PlanetCongratulations.LiberationStarNormalsFromKlisan.MalocText');",
                        "        else if(owner==Peleng) dialogText='</color>'+CT('PlanetCongratulations.LiberationStarNormalsFromKlisan.PelengText');",
                        "        else if(owner==People) dialogText='</color>'+CT('PlanetCongratulations.LiberationStarNormalsFromKlisan.PeopleText');",
                        "        else if(owner==Fei) dialogText='</color>'+CT('PlanetCongratulations.LiberationStarNormalsFromKlisan.FeiText');",
                        "        else dialogText='</color>'+CT('PlanetCongratulations.LiberationStarNormalsFromKlisan.GaalText');",
                        "        dialogText=Format(dialogText, '<Planet'+'>', Name(planet), '<Star'+'>', Name(PlanetToStar(planet)));",
                        "    }",
                        "    if(!awardType) dialogText=dialogText + CT(\"Script.Mod_ShuKlissan.351\") + Format(CT('PlanetCongratulations.' + addStr + '.AddReward'), '<Reward'+'>', awardName) + CT(\"Script.Mod_ShuKlissan.351\");",
                        "    else if(awardType==1) dialogText=dialogText + CT(\"Script.Mod_ShuKlissan.351\") + Format(CT('PlanetCongratulations.' + addStr + '.AddArtefact'), '<Artefact'+'>', awardName) + CT(\"Script.Mod_ShuKlissan.351\") + tempStr + CT(\"Script.Mod_ShuKlissan.351\");",
                        "    else if(awardType==2) dialogText=dialogText + CT(\"Script.Mod_ShuKlissan.351\") + Format(CT('PlanetCongratulations.' + addStr + '.AddProgramms'), '<Programm'+'>', awardName, '<Count'+'>', tRnd) + CT(\"Script.Mod_ShuKlissan.351\");",
                        "    else dialogText=dialogText + CT(\"Script.Mod_ShuKlissan.351\") + Format(CT('PlanetCongratulations.' + addStr + '.AddNod'), '<Nod'+'>', awardName) + CT(\"Script.Mod_ShuKlissan.351\") + tempStr + CT(\"Script.Mod_ShuKlissan.351\");",
                        "    dialogText=dialogText + CT(\"Script.Mod_ShuKlissan.351\") + '<color=45,105,45>' + Format(CT('PlanetCongratulations.' + addStr + '.AddPoints'), '<Points'+'>', experience, '45,105,45') +'</color>';",
                        "    result=dialogText;",
                        "}",
                        "//Функция устранения перевеса. Параметр - указатель на корабль.",
                        "function GiveFreeSpace(dword ship) {",
                        "    ShipCalcParam(ship);",
                        "    if(ShipFreeSpace(ship) < 0) {",
                        "        ItemSize(ShipItems(ship, 0), ItemSize(ShipItems(ship, 0)) + abs(ShipFreeSpace(ship)) + Rnd(1, 5));",
                        "        HullHP(ship, 'To100');",
                        "    }",
                        "}"
                    ],
                    "#": 146,
                    "Type": "Top",
                    "Parent": -1,
                    "Pos.x": 60,
                    "Pos.y": 1235
                },
                {
                    "Name": "",
                    "Code.Type": "Turn",
                    "Code": [
                        "if(!ShipIsTakeoff(Player())) {",
                        "  //Автоматическое обновление характеристик кастомных орудий",
                        "  //Срабатывает, только если параметр StatsVersion для ShuKlissan был изменён",
                        "  if(gunUpdateCheck != CT('Items.Weapon.CustomWeapon.StatsVersion.ShuKlissan'))",
                        "  {",
                        "      InventShuKlissanCustomGuns();",
                        "      gunUpdateCheck = CT('Items.Weapon.CustomWeapon.StatsVersion.ShuKlissan');",
                        "  }",
                        "}",
                        "//Записываем текущий ГТУ в локальную переменную",
                        "GTL = GalaxyTechLevel();",
                        "",
                        "//Пока что хз что это и зачем",
                        "//Вероятно, выставление пиратской концовки в случае получения игроком одной из концовок клисан",
                        "if(EndState2)",
                        "{",
                        "    if(!GroupCount(Machpella) && !GroupCount(Handler))",
                        "    {",
                        "        PirateWin(3);",
                        "        NoJump(0);",
                        "    }",
                        "}",
                        "",
                        "//Выводится уведомление о победе над махпеллой (видимо), хотя на самом деле я хз",
                        "if(!KlissanEther)",
                        "{",
                        "    if(!GroupCount(Machpella))",
                        "    {",
                        "        if(KlissanState == 1 || KlissanState == 2)",
                        "        {",
                        "            KlissanEther = 1;",
                        "            Ether(0, '', CT(\"Script.Mod_ShuKlissan.300\"));",
                        "            if(PirateWin() != 3)",
                        "            {",
                        "                ShipJoinsClan(Player());",
                        "                RelationToRanger(PlanetPirateClan(), Player(), 100);",
                        "                Ether(4, 'ClanAlakayDestroy', CT(\"Script.Mod_ShuKlissan.299\"));",
                        "            }",
                        "            else Ether(4, 'ClanSpecagentDestroy', CT(\"Script.Mod_ShuKlissan.299\"));",
                        "            NoJump(0);",
                        "        }",
                        "    }",
                        "}",
                        "",
                        "//Код спавна военной базы с кучей HP при завершении игроком клисанской сюжетки силовым путём",
                        "if(ShipInNormalSpace(Player())) {",
                        "    if(!was_was) {",
                        "        if(EndState2 == 1) {",
                        "            was_was = 1;",
                        "            NoJump(1);",
                        "            ArrayClear(hit_list);",
                        "            ShipOwner(Player(), ShipPilotRace(Player()));",
                        "            for(i = 0; i < GalaxyStars(); i = i + 1) {",
                        "                cur_star = GalaxyStar(i);",
                        "                if(StarOwner(cur_star) == 0) ArrayAdd(hit_list, cur_star);",
                        "            }",
                        "            if(!CoalitionDefeated()) {",
                        "                cur_star = hit_list[Rnd(1, ArrayDim(hit_list) - 1)];",
                        "                for(i = 0; i < StarPlanets(cur_star); i = i + 1) {",
                        "                    sh = StarPlanets(cur_star, i);",
                        "                    if(PlanetOwner(sh) < 5) break;",
                        "                }",
                        "            }",
                        "            else",
                        "            {",
                        "                cur_star = GalaxyStar(71);",
                        "                sh = StarPlanets(s, Rnd(0, 4));",
                        "                PlanetOwner(sh, PlanetRace(sh));",
                        "            }",
                        "            cur_ship = BuildRuins(cur_star, t_WB);",
                        "            SetName(cur_ship, CT(\"Script.Mod_ShuKlissan.280\"));",
                        "            ShipOwner(cur_ship, Maloc);",
                        "            ItemSize(ShipItems(cur_ship, 0), Rnd(25000, 30000) + GalaxyTechLevel() * 5000);",
                        "            HullHP(cur_ship, 'To100');",
                        "            for(i = 0; i <= 2; i = i + 1) ShipSkill(cur_ship, i, 6);",
                        "            cur_item = CreateEquipment(t_RepairRobot, Rnd(80, 100), GalaxyTechLevel(), Maloc);",
                        "            AddItemToShip(cur_ship, cur_item);",
                        "            ItemIsInUse(cur_item, cur_ship, 1);",
                        "            cur_item = CreateEquipment(t_DefGenerator, Rnd(80, 100), GalaxyTechLevel(), Maloc);",
                        "            AddItemToShip(cur_ship, cur_item);",
                        "            ItemIsInUse(cur_item, cur_ship, 1);",
                        "            ShipImproveItems(cur_ship, Rnd(10, 20));",
                        "            NoLanding(cur_ship, 1);",
                        "            ShipSpecialBonuses(cur_ship, bonDroid, 10000);",
                        "            ShipSpecialBonuses(cur_ship, bonHull, 25);",
                        "            ShipJoin(WarriorsWB, cur_ship);",
                        "            MakeShipEnterStar(cur_ship, PlanetToStar(PlanetPirateClan()), cur_star, 7);",
                        "            for(i = 0; i < Rnd(15, 25); i = i + 1) {",
                        "                cur_ship = BuyWarrior(sh, 1000);",
                        "                for(j = 0; j <= 2; j = j + 1) ShipSkill(cur_ship, j, Rnd(3, 6));",
                        "                ShipSkill(cur_ship, 1, 6);",
                        "                for(j = 0; j < 10; j = j + 1) ShipRefit(cur_ship);",
                        "                ShipImproveItems(cur_ship, Rnd(3, 15));",
                        "                MakeShipEnterStar(cur_ship, PlanetToStar(PlanetPirateClan()), cur_star, Rnd(6, 8));",
                        "            }",
                        "            for(i = 0; i < Rnd(10, 15); i = i + 1) {",
                        "                cur_ship = BuyWarrior(PlanetPirateClan(), 1000);",
                        "                RelationToRanger(cur_ship, Player(), 0);",
                        "                for(j = 0; j <= 2; j = j + 1) ShipSkill(cur_ship, j, Rnd(0, 5));",
                        "                for(j = 0; j < 10; j = j + 1) ShipRefit(cur_ship);",
                        "                ShipImproveItems(cur_ship, Rnd(0, 3));",
                        "            }",
                        "            for(i = 0; i < Rnd(3, 5); i = i + 1)",
                        "            {",
                        "                cur_ship = BuyWarrior(PlanetPirateClan(), 1000);",
                        "                RelationToRanger(cur_ship, Player(), 0);",
                        "                for(j = 0; j <= 2; j = j + 1) ShipSkill(cur_ship, j, Rnd(0, 5));",
                        "                for(j = 0; j < 10; j = j + 1) ShipRefit(cur_ship);",
                        "                ShipImproveItems(cur_ship, Rnd(0, 3));",
                        "                MakeShipEnterStar(cur_ship, PlanetToStar(PlanetPirateClan()), StarNearbyStars(PlanetToStar(PlanetPirateClan()), Rnd(55, 67)), Rnd(10, 20));",
                        "            }",
                        "            for(i = 0; i < Rnd(3, 5); i = i + 1)",
                        "            {",
                        "                cur_ship = BuyWarrior(PlanetPirateClan(), 1000);",
                        "                RelationToRanger(cur_ship, Player(), 0);",
                        "                for(j = 0; j <= 2; j = j + 1) ShipSkill(cur_ship, j, Rnd(0, 5));",
                        "                for(j = 0; j < 10; j = j + 1) ShipRefit(cur_ship);",
                        "                ShipImproveItems(cur_ship, Rnd(0, 3));",
                        "                MakeShipEnterStar(cur_ship, PlanetToStar(PlanetPirateClan()), GalaxyStar(71), Rnd(3, 5));",
                        "            }",
                        "",
                        "            SetRelationGroup(Handler, PlayerGroup, 0);",
                        "            SetRelationGroup(Machpella, PlayerGroup, 0);",
                        "            EndState2 = 2;",
                        "            RelationToRanger(GroupToShip(Handler), Player(), 0);",
                        "            RelationToRanger(GroupToShip(Machpella), Player(), 0);",
                        "            FreeItem(GetItemFromShip(Player(), FindItemInShip(Player(), kBlackHole)));",
                        "            ShipDeleteCustomShipInfo(GroupToShip(Handler), 'ShuKlissan_ImmortalInfo');",
                        "            ShipDeleteCustomShipInfo(GroupToShip(Machpella), 'ShuKlissan_ImmortalInfo');",
                        "            if(CoalitionDefeated())",
                        "            {",
                        "                PlanetOwner(sh, PirateClan);",
                        "                Ether(0, '', Format(CT(\"Script.Mod_ShuKlissan.282\"),\"<0>\",Name(PlanetToStar(PlanetPirateClan()))));",
                        "            }",
                        "            else Ether(0, '', Format(CT(\"Script.Mod_ShuKlissan.281\"),\"<0>\",Name(PlanetToStar(PlanetPirateClan()))));",
                        "        }",
                        "    }",
                        "}",
                        "",
                        "//В случае если игрок находится в Тортугаце и нанёс Хандлеру повреждение, либо если здоровье Хандлера опустилось ниже 50%",
                        "//Спавнится \"защита\" Хандлера во главе с очередным ёбапиладжером",
                        "if(!was_guard)",
                        "{",
                        "    if(ShipInStar(Player(), GalaxyStar(TortugatzId)))",
                        "    {",
                        "        if(GroupCount(Handler))",
                        "        {",
                        "            if(HullDamage(GroupToShip(Handler)) > 50 || Hit(GroupToShip(Handler), 0))",
                        "            {",
                        "                for(i = 0; i < 5; i = i + 1)",
                        "                {",
                        "                    cur_ship = BuyPirate(PlanetPirateClan(), 5000);",
                        "                    NoScanToShip(cur_ship, 1);",
                        "                    NoTalkToShip(cur_ship, 1);",
                        "                    Chameleon(cur_ship, 'Ship.Akrin.FeiGuard');",
                        "                    TransferShip(cur_ship, GroupToShip(Handler));",
                        "                    for(j = ShipItems(cur_ship) - 1; j > 0; j = j - 1) FreeItem(GetItemFromShip(cur_ship, j));",
                        "                    for(j = 0; j < 15; j = j + 1) ShipRefit(cur_ship);",
                        "                    ShipImproveItems(cur_ship, Rnd(2*GTL, 3*GTL));",
                        "                    ShipJoin(FeiGuard, cur_ship);",
                        "                }",
                        "                cur_ship = BuyPirate(PlanetPirateClan(), 5000);",
                        "                SetName(cur_ship, CT(\"Script.Mod_ShuKlissan.349\"));",
                        "                ShipType(cur_ship, 'Pillager');",
                        "                Chameleon(cur_ship, 'Ship.HS.0');",
                        "                NoScanToShip(cur_ship, 1);",
                        "                ShipPilotRace(cur_ship, Peleng);",
                        "                for(i = 0; i <= 2; i = i + 1) ShipSkill(cur_ship, i, 6);",
                        "                ItemSize(ShipItems(cur_ship, 0), 2000);",
                        "                HullHP(cur_ship, 2000);",
                        "                ShipSpecialBonuses(cur_ship, bonJump, 150);",
                        "                ShipSpecialBonuses(cur_ship, bonSpeed, 750);",
                        "                ShipSpecialBonuses(cur_ship, bonMass, -30);",
                        "                ShipSpecialBonuses(cur_ship, bonWEnergy, 45);",
                        "                ShipSpecialBonuses(cur_ship, bonWSplinter, 70);",
                        "                ShipSpecialBonuses(cur_ship, bonWMissile, 57);",
                        "                ShipSpecialBonuses(cur_ship, bonMissileSpeed, 300);",
                        "                ShipSpecialBonuses(cur_ship, bonDef, 25);",
                        "                ShipSpecialBonuses(cur_ship, bonHull, 5);",
                        "                ShipSpecialBonuses(cur_ship, bonDroid, 60);",
                        "                ShipSpecialBonuses(cur_ship, bonWRadius, 200);",
                        "                danger = 100;",
                        "                for(i = t_FuelTanks; i <= t_DefGenerator; i = i + 1) GiveEgemonEq(cur_ship, i);",
                        "                GiveEgemonEq(cur_ship, t_CustomWeapon);",
                        "                GiveNondusEq(cur_ship, t_CustomWeapon);",
                        "                GiveNondusEq(cur_ship, t_CustomWeapon);",
                        "                GiveKatauriEq(cur_ship, t_CustomWeapon);",
                        "                GiveKatauriEq(cur_ship, t_CustomWeapon);",
                        "                cur_item = CreateArt(t_ArtPDTurret, PirateClan);",
                        "                AddItemToShip(cur_ship, cur_item);",
                        "                cur_item = CreateArt(t_ArtEnergyPulse, PirateClan);",
                        "                AddItemToShip(cur_ship, cur_item);",
                        "                cur_item = CreateArt(t_ArtDefToEnergy, PirateClan);",
                        "                AddItemToShip(cur_ship, cur_item);",
                        "                cur_item = CreateArt(t_ArtefactDef, PirateClan);",
                        "                AddItemToShip(cur_ship, cur_item);",
                        "                ArrangeItems(cur_ship);",
                        "                ShipImproveItems(cur_ship, Rnd(20, 30));",
                        "                TransferShip(cur_ship, GroupToShip(Handler));",
                        "                ShipJoin(FeiGuard, cur_ship);",
                        "                was_guard = 1;",
                        "            }",
                        "        }",
                        "    }",
                        "}",
                        "",
                        "if(CurTurn() >= bhShipsAttackTimer) {",
                        "    if(ShipInNormalSpace(Player())) {",
                        "        cur_star = ShipStar(Player());",
                        "        if(cur_star != GalaxyStar(cstar_id-1)) {",
                        "            if(StarToCon(ShipStar(Player())) != StarToCon(PlanetToStar(PlanetPirateClan()))) {",
                        "                if(StarOwner(ShipStar(Player())) != 1) {",
                        "                    bhShipsAttackTimer = CurTurn() + Rnd(1250, 2000);",
                        "                    cur_hole=HoleCreate2(ShipStar(Player()), ShipStar(Player()));",
                        "                    HoleTurnCreate(cur_hole, CurTurn()-185); //ЧД существует 15 дней",
                        "                    for(i = 0; i < Rnd(3, 6); i = i + 1) {",
                        "                        cur_ship = BuyDomikExtremal(PlanetPirateClan(), Rnd(1, 5));",
                        "                        ShipJoin(BhShips, cur_ship);",
                        "                        ShipCustomFaction(cur_ship, 'Nones');",
                        "                        RelationToRanger(cur_ship, Player(), 0);",
                        "                        ShipSetBad(cur_ship, Player());",
                        "                        ItemSize(ShipItems(cur_ship, 0), Rnd(185 + GalaxyTechLevel() * 30, 150 + GalaxyTechLevel() * 150));",
                        "                        HullHP(cur_ship, 'To100');",
                        "                        NoScanToShip(cur_ship, 1);",
                        "                        NoTalkToShip(cur_ship, 1);",
                        "                        for(j = 0; j <= 2; j = j + 1) ShipSkill(cur_ship, j, Rnd(0, 6));",
                        "                        ShipOwner(cur_ship, None);",
                        "                        ShipType(cur_ship, 'None');",
                        "                        SetName(cur_ship, CT(\"Script.Mod_ShuKlissan.348\"));",
                        "                        SpecialToEquipment(FindBonusByNameInCfg('368'), ShipItems(cur_ship, 0)); //Миоплазменный корпус IV",
                        "                        Chameleon(cur_ship, 'Ship.X.' + Rnd(0, 2));",
                        "                        for(j = ShipItems(cur_ship) - 1; j > 0; j = j - 1) FreeItem(GetItemFromShip(cur_ship, j));",
                        "                        for(j = t_FuelTanks; j <= t_DefGenerator; j = j + 1) {",
                        "                            cur_item = CreateEquipment(j, Rnd(20, 80), GTL, None);",
                        "                            AddItemToShip(cur_ship, cur_item);",
                        "                            ItemIsInUse(cur_item, cur_ship, 1);",
                        "                        }",
                        "                        for(j = 0; j < Rnd(3, 5); j = j + 1) {",
                        "                            if(GTL < 5) cur_item = CreateEquipment(Rnd(t_Weapon1, t_Weapon4), Rnd(20, 80), GTL, None);",
                        "                            else if(GTL < 7) cur_item = CreateEquipment(Rnd(t_Weapon5, t_Weapon8), Rnd(20, 80), GTL, None);",
                        "                            else cur_item = CreateEquipment(Rnd(t_Weapon9, t_Weapon12), Rnd(20, 80), GTL, None);",
                        "                            AddItemToShip(cur_ship, cur_item);",
                        "                            ItemIsInUse(cur_item, cur_ship, 1);",
                        "                        }",
                        "                        GiveFreeSpace(cur_ship);",
                        "                        MakeShipEnterStar(cur_ship, cur_star, PlanetToStar(PlanetPirateClan()), Rnd(1, 3));",
                        "                        OrderJumpHole(cur_ship, cur_hole);",
                        "                        ShipSetCoords(cur_ship, HoleX1(cur_hole), HoleY1(cur_hole));",
                        "                    }",
                        "                    AddPlanetNews(Format(CT(\"Script.Mod_ShuKlissan.347\"),\"<0>\",Name(cur_star)));",
                        "                }",
                        "            }",
                        "        }",
                        "    }",
                        "}",
                        "",
                        "//Удалить после того, как все клисаны будут в KlissanNormal",
                        "for(j = 0; j < GroupCount(Klissan1); j = j + 1)",
                        "{",
                        "    s = GroupShip(Klissan1, j);",
                        "    sh = ShipGetBad(s);",
                        "    if(!sh) continue;",
                        "    if(!ShipInScript(sh)) continue;",
                        "    if(IsPlayer(sh)) continue;",
                        "    if(ShipCustomFaction(sh) == 'Klissan') TruceBetweenShips(s, sh);",
                        "}",
                        "",
                        "for(j = 0; j < GroupCount(Klissan3); j = j + 1)",
                        "{",
                        "    s = GroupShip(Klissan3, j);",
                        "    sh = ShipGetBad(s);",
                        "    if(!sh) continue;",
                        "    if(!ShipInScript(sh)) continue;",
                        "    if(IsPlayer(sh)) continue;",
                        "    if(ShipCustomFaction(sh) == 'Klissan') TruceBetweenShips(s, sh);",
                        "}",
                        "",
                        "for(j = 0; j < GroupCount(KlissanNormal); j = j + 1)",
                        "{",
                        "    s = GroupShip(KlissanNormal, j);",
                        "    sh = ShipGetBad(s);",
                        "    if(!sh) continue;",
                        "    if(!ShipInScript(sh)) continue;",
                        "    if(IsPlayer(sh)) continue;",
                        "    if(ShipCustomFaction(sh) == 'Klissan') TruceBetweenShips(s, sh);",
                        "}",
                        "if(PirateWin() != 3)",
                        "{",
                        "    if(klissanStars[0] > 5)",
                        "    {",
                        "        //Этот кусок параши отвечает за рандомный переход клисанской системы в руки пиратов",
                        "        //С вероятностью 1 к 800, но, тем не менее, оно время от времени таки срабатывает",
                        "        if(ControlledSystems(2) < 5 )",
                        "        {",
                        "            for(i = 1; i < 70; i = i + 1)",
                        "            {",
                        "                cur_star = StarNearbyStars(PlanetToStar(PlanetPirateClan()), i);",
                        "                if(StarCustomFaction(cur_star) == 'Klissan' && !Rnd(0, 800) && cur_star != ShipStar(Player())) ForcedSystemTake(cur_star);",
                        "            }",
                        "        }",
                        "        //А эта хуита срабатывает ещё чаще, также отдавая пиратам систему без боя, но уже с вероятностью 1 к 30",
                        "        //Здесь правда есть условие, что система должна быть очень недалеко от скрытого сектора",
                        "        for(i = 1; i < 4; i = i + 1)",
                        "        {",
                        "            cur_star = StarNearbyStars(PlanetToStar(PlanetPirateClan()), i);",
                        "            if(StarCustomFaction(cur_star) == 'Klissan' && !Rnd(0, 30)) ForcedSystemTake(cur_star);",
                        "        }",
                        "    }",
                        "}",
                        "",
                        "//Вывод сообщения о том, что игрок начал чёто активное делать по клисанскому сюжету (вероятно)",
                        "if(!klissan_msg)",
                        "{",
                        "    if(agent_counter >= 3)",
                        "    {",
                        "        if(CurTurn() > GShuKlissanFirstStart + 5)",
                        "        {",
                        "            if(ShipInNormalSpace(Player()))",
                        "            {",
                        "                if(GetShipPirateRank(Player()) == 6)",
                        "                {",
                        "                    klissan_msg = 1;",
                        "                    Ether(0, '', CT(\"Script.Mod_ShuKlissan.331\"));",
                        "                }",
                        "            }",
                        "        }",
                        "    }",
                        "}",
                        "",
                        "//Вероятно, отключает маркера начавшейся атаки клисан по истечении 150 дней с начала атаки",
                        "if(CurTurn() > start_date + 150)",
                        "{",
                        "    ShipDestroy(GroupToShip(Nest1));",
                        "    cur_star = 0;",
                        "    attack_state = 0;",
                        "}",
                        "if(CurTurn() > start_date3 + 150)",
                        "{",
                        "    cur_star3 = 0;",
                        "    attack_state3 = 0;",
                        "}",
                        "",
                        "if(!GroupCount(Klissan1))",
                        "{",
                        "    attack_state = 0;",
                        "    cur_star = 0;",
                        "    if(!attack_status) attack_status = 2;",
                        "}",
                        "if(!GroupCount(Klissan3))",
                        "{",
                        "    attack_state3 = 0;",
                        "    cur_star3 = 0;",
                        "    if(!attack_status) attack_status = 2;",
                        "}",
                        "if(!GroupCount(Nest1)) cur_ruins = 0;",
                        "//костыль, который нужно будет потом убрать",
                        "if(attack_state3)",
                        "{",
                        "    cur_star3 = GalaxyStar(cstar_id3 - 1);",
                        "    for(i = 0; i < StarShips(cur_star3); i = i + 1)",
                        "    {",
                        "        s = StarShips(cur_star3, i);",
                        "        if(ShipType(s) == 'Klissan1' && !ShipInScript(s)) ShipJoin(Klissan3, s);",
                        "    }",
                        "}",
                        "//костыль, который нужно будет потом убрать",
                        "if(attack_state)",
                        "{",
                        "    cur_star = GalaxyStar(cstar_id - 1);",
                        "    if(GroupCount(Nest1)) cur_ruins = GroupToShip(Nest1);",
                        "    for(i = 0; i < StarShips(cur_star); i = i + 1)",
                        "    {",
                        "        s = StarShips(cur_star, i);",
                        "        if(ShipType(s) == 'Klissan1' && !ShipInScript(s)) ShipJoin(Klissan1, s);",
                        "    }",
                        "}",
                        "",
                        "//Ебацикл",
                        "//Строит нейролинки во всех клисанских системах, в которых их нет (тоже полный идиотизм)",
                        "for(i = 0; i < GalaxyStars(); i = i + 1)",
                        "{",
                        "    cur_star = GalaxyStar(i);",
                        "    if(StarCustomFaction(cur_star) != 'Klissan') continue;",
                        "    if(!StarRuins(cur_star, 'KB')) {",
                        "        cur_ruins=BuyNeurolink(NestNormal);",
                        "        MakeShipEnterStar(cur_ruins, cur_star, PlanetToStar(PlanetPirateClan()), Rnd(30, 40));",
                        "    }",
                        "}",
                        "",
                        "//На старте игры (на первом ходу) создаётся Махпелла и Хандлер",
                        "if(!MCreate)",
                        "{",
                        "    MCreate = 1;",
                        "    BuyHandler(Handler);",
                        "    BuyMachpella(Machpella);",
                        "}",
                        "",
                        "//Здесь Махпелла и Хандлер пересоздаются заново, если игрок ещё не близок к концовке EndState2",
                        "if(!KlissanState)",
                        "{",
                        "    if(!EndState2)",
                        "    {",
                        "        if(GetShipPirateRank(Player()) != 7)",
                        "        {",
                        "            if(!GroupCount(Machpella) && !GroupCount(Handler))",
                        "            {",
                        "                MCreate = 1;",
                        "                BuyHandler(Handler);",
                        "                BuyMachpella(Machpella);",
                        "            }",
                        "        }",
                        "    }",
                        "}",
                        "//Обработчик клисанских ЧД",
                        "if(ShipInHole(Player())) {",
                        "  if(GroupCount(Machpella) && KlissanState!=4) {",
                        "    cur_hole = ShipOrderObj(Player());",
                        "    BlackHoleKlissanBattle=0;",
                        "    if(!BlackHoleKlissanBattle) {",
                        "      if(!GABStatus) {",
                        "        if(holeId!=Id(cur_hole)) {",
                        "          if(HoleStar2(cur_hole) == PlanetToStar(PlanetPirateClan()) || HoleStar1(cur_hole) == PlanetToStar(PlanetPirateClan())) {  //Вход или выход ведет в Тортугац",
                        "            BlackHoleKlissanBattle=1;",
                        "            if((!ItemIn(kBlackHole, Player())) || (ShipOnSidePirateClan(Player()) && GetShipPirateRank(Player()) < 7)) { //Если у игрока с собой нет \"пропуска\", либо он не является бароном",
                        "              if(!ShipOrderData2(Player())) { //Игрок влетел со стороны входа в ЧД",
                        "                MakeShipEnterStar(Player(), HoleStar1(cur_hole), HoleStar2(cur_hole), ShipOrderData1(Player()));",
                        "                OrderJumpHole(Player(), cur_hole); //Отправляем игрока обратно",
                        "                ShipOrderData2(Player(), 1);",
                        "              }",
                        "              else { //Игрок влетел со стороны выхода из ЧД",
                        "                MakeShipEnterStar(Player(), HoleStar2(cur_hole), HoleStar1(cur_hole), ShipOrderData1(Player()));",
                        "                OrderJumpHole(Player(), cur_hole); //Отправляем игрока обратно",
                        "                ShipOrderData2(Player(), 0);",
                        "              }",
                        "              if(!hole_fight) {",
                        "                for(i = 0; i < Rnd(5, 10); i = i + 1) { //Спавним на Роджерии клисан",
                        "                  cur_ship = BuyKlissan(PlanetPirateClan(), -1);",
                        "                  tint1 = Rnd(-1, 1);",
                        "                  if(~tint1) {",
                        "                    if(!tint1) tint1 = CreateCustomCountableItem('kProtoplasm', Rnd(25, 50), 1);",
                        "                    else tint1 = CreateQuestItem('KlissanRemains' + Rnd(1, CT('Script.Mod_ShuKlissan.KlissanRemainsCount')), None);",
                        "                    EqCustomFaction(tint1, 'Klissan');",
                        "                  }",
                        "                  ConvertToABShip(cur_ship, 0, 100, 100, '', tint1);",
                        "                  TransferShip(cur_ship, StarPlanets(GalaxyStar(2), 0)); //Отправляем ненужных более клисан на Меркурий и там же их по-тихому убиваем",
                        "                  ShipDestroy(cur_ship, 1);",
                        "                }",
                        "                //Выбор карты АБ",
                        "                for(i=1; i<=14; i=i+1) ArrayAdd(tempArr, i); //Стандартные карты",
                        "                if(ResourceExist('ABMap.Tachanka')) { //Карты из RevAB",
                        "                  for(i=15; i<=20; i=i+1) ArrayAdd(tempArr, i);",
                        "                }",
                        "                if(ResourceExist('ABMap.02_1_V02')) { //Карты из SR1ABMaps",
                        "                  for(i=21; i<=23; i=i+1) ArrayAdd(tempArr, i);",
                        "                }",
                        "                if(ResourceExist('ABMap.endless')) { //Карты из AdvancedABMaps",
                        "                  for(i=24; i<=27; i=i+1) ArrayAdd(tempArr, i);",
                        "                }",
                        "                rand=tempArr[Rnd(1,ArrayDim(tempArr)-1)];",
                        "                ArrayClear(tempArr);",
                        "                if(rand<=14) StartAB('ABMap.map_'+rand);",
                        "                else {",
                        "                  if(rand == 15) StartAB('ABMap.Nonsense');",
                        "                  else if(rand == 16) StartAB('ABMap.Pulsar');",
                        "                  else if(rand == 17) StartAB('ABMap.Strolocobs');",
                        "                  else if(rand == 18) StartAB('ABMap.Tachanka');",
                        "                  else if(rand == 19) StartAB('ABMap.Fifth_Dimension');",
                        "                  else if(rand == 20) StartAB('ABMap.Spider\\\\\\'s_Lair');",
                        "                  else if(rand == 21) StartAB('ABMap.02_1_V02');",
                        "                  else if(rand == 22) StartAB('ABMap.04_2_V01');",
                        "                  else if(rand == 23) StartAB('ABMap.04_3_V03');",
                        "                  else if(rand == 24) StartAB('ABMap.curvature');",
                        "                  else if(rand == 25) StartAB('ABMap.trap');",
                        "                  else if(rand == 26) StartAB('ABMap.endless');",
                        "                  else if(rand == 27) StartAB('ABMap.polygons');",
                        "                }",
                        "              }",
                        "            }",
                        "            else { //Начинаем скриптовое сражение",
                        "              SectorVisible(StarToCon(PlanetToStar(PlanetPirateClan())), 1); //Делаем скрытый пиратский сектор видимым для игрока",
                        "              //Если игрок попал в скрытый сектор и Коалиция ещё не побеждена, выставляем флаг приближения к концовке EndState2",
                        "              if(!CoalitionDefeated()) {",
                        "                NoLanding(PlanetPirateClan(), 1);",
                        "                ShipOwner(Player(), ShipPilotRace(Player()));",
                        "                EndState2 = 1;",
                        "              }",
                        "              ShipOrderData1(Player(), ShipOrderData1(Player()) + 1); //Увеличиваем число дней, которые игрок проведёт в ЧД до вылета из неё на 1",
                        "              if(!hole_fight) {",
                        "                //Спавнится 12 клисан для охраны(?) Тортугаца",
                        "                danger = 100;",
                        "                for(i = 0; i < 12; i = i + 1) {",
                        "                  cur_ship = BuyKlissan(PlanetPirateClan(), -1);",
                        "                  TransferShip(cur_ship, GroupToShip(Handler));",
                        "                  ShipJoin(FeiGuard, cur_ship);",
                        "                  ShipCustomFaction(cur_ship, 'Klissan');",
                        "                }",
                        "                for(i = 0; i < Rnd(5, 10); i = i + 1) { //Спавним на Роджерии клисан",
                        "                  cur_ship = BuyKlissan(PlanetPirateClan(), -1);",
                        "                  rand = ShipSubType(cur_ship);",
                        "                  ConvertToABShip(cur_ship, 0, 100, 100); //Делаем из них аркадных противников",
                        "                  TransferShip(cur_ship, StarPlanets(GalaxyStar(2), 0)); //Отправляем ненужных более клисан на меркурий и там же их убиваем",
                        "                  ShipDestroy(cur_ship, 1);",
                        "                }",
                        "                 hole_fight = 1; //Ставим маркер о сюжетном посещении Тортугаца через ЧД",
                        "                 StartAB('ABMap.map_14', 1); //Начинаем аркадный бой",
                        "              }",
                        "            }",
                        "            holeId=Id(cur_hole);",
                        "          }",
                        "        }",
                        "      }",
                        "      else if(GABStatus == 2) {",
                        "        cur_hole = ShipOrderObj(Player());",
                        "        if(HoleStar2(cur_hole) == PlanetToStar(PlanetPirateClan()) || HoleStar1(cur_hole) == PlanetToStar(PlanetPirateClan())) {",
                        "          DestroyKlissansBH(HoleStar1(cur_hole), cur_hole);",
                        "          DestroyKlissansBH(HoleStar2(cur_hole), cur_hole);",
                        "        }",
                        "      }",
                        "    }",
                        "  }",
                        "}",
                        "else if(holeId) holeId=0; //Обнуление Id посещенной ЧД",
                        "",
                        "if(!KlissanState)",
                        "{",
                        "    //Эта хуита в итоге переводит Махпеллу в стейт MStage5",
                        "    //Остаётся, правда, вопрос, нахуя? machpella_fly использована только лишь исключительно здесь",
                        "    if(!machpella_fly)",
                        "    {",
                        "        if(CurTurn() >= 4000 && StarCustomFaction(ShipStar(Player())) == 'Klissan')",
                        "        {",
                        "            machpella_state = 1;",
                        "            machpella_fly = 1;",
                        "            machpella_star = Id(ShipStar(Player())) - 1;",
                        "            machpella_date = CurTurn() + 70;",
                        "        }",
                        "    }",
                        "",
                        "    //Если у игрока на борту имеется генератор макрофазового сдвига (получен за исследование клисанских ошмётков)",
                        "    //Активируется финальный этап силовой концовки клисан, генератор время от времени создаёт ЧД в Тортугац,",
                        "    //а также в систему игрока слетаются клисане, чтобы его уничтожить",
                        "    if(ItemIn(kBlackHole, Player()))",
                        "    {",
                        "        //Если игрок ещё не посещал Тортугац через клисанскую ЧД (сюжетное)",
                        "        if(!hole_fight)",
                        "        {",
                        "            //Если \"заряд\" генератора полный",
                        "            if(CurTurn() >= shift_cd)",
                        "            {",
                        "                //Если игрок не находится в скрытом пиратском секторе",
                        "                cur_star = ShipStar(Player());",
                        "                if(cur_star != GalaxyStar(NifigatzId) && cur_star != GalaxyStar(TortugatzId))",
                        "                {",
                        "                    shift_cd = CurTurn() + Rnd(90, 180);",
                        "                    Ether(0, '', Format(CT(\"Script.Mod_ShuKlissan.253\"),\"<0>\",shift_cd - CurTurn()));",
                        "",
                        "                    god = CurTurn() / 365;",
                        "                    god = god * 75 / 100;",
                        "                    danger = god + KlissanDiffLevel * 10 / 50;",
                        "",
                        "                    danger = danger + PortionInDiapason(GTL, 1, 8, -15, 15);",
                        "                    if(danger > 75 && GTL < 8) danger = 75;",
                        "",
                        "                    if(klissanStars[0] <= 0.1 * max_stars) danger = 2.35 * danger;",
                        "                    else if(klissanStars[0] <= 0.2 * max_stars) danger = 2.10 * danger;",
                        "                    else if(klissanStars[0] <= 0.3 * max_stars) danger = 1.80 * danger;",
                        "                    else if(klissanStars[0] <= 0.42 * max_stars) danger = 1.65 * danger;",
                        "                    else if(klissanStars[0] <= 0.55 * max_stars) danger = 1.50 * danger;",
                        "                    else if(klissanStars[0] <= 0.67 * max_stars) danger = 1.35 * danger;",
                        "                    else if(klissanStars[0] <= 0.8 * max_stars) danger = 1.20 * danger;",
                        "                    else danger = 1.20 * danger;",
                        "",
                        "                    if(CurTurn() <= GShuKlissanFirstStart + 340) danger = danger * 40 / 100;",
                        "                    else if(CurTurn() <= GShuKlissanFirstStart + 820) danger = danger * 55 / 100;",
                        "                    else if(CurTurn() <= GShuKlissanFirstStart + 1500) danger = danger * 80 / 100;",
                        "                    else danger = danger;",
                        "",
                        "                    if(ruchnik_bonus) danger = danger * 1.25;",
                        "                    start_date3 = CurTurn();",
                        "                    attack_state3 = 1;",
                        "                    attack_status = 0;",
                        "",
                        "                    //Форсируем определение уровня угрозы",
                        "                    //Высылаем подкрепление",
                        "                    //Определяем количество клисан в составе основной волны",
                        "                    if(danger <= 20) attack_count3 = Rnd(3, 12);",
                        "                    else if(danger <= 40) attack_count3 = Rnd(3, 13);",
                        "                    else if(danger <= 60) attack_count3 = Rnd(4, 14);",
                        "                    else if(danger <= 80) attack_count3 = Rnd(4, 15);",
                        "                    else attack_count3 = Rnd(4, 16);",
                        "",
                        "                    attack_count3 = round(PortionInDiapason(KlissanDiffLevel, 50, 500, 0.6, 2.6) * attack_count3);",
                        "                    attack_count3 = round(1.35 * attack_count3);",
                        "",
                        "                    //Запускаем цикл по рождению клисан",
                        "                    for(i = 0; i < attack_count3; i = i + 1)",
                        "                    {",
                        "                        cur_ship = BuyKlissan(PlanetPirateClan(), -1);",
                        "                        MakeShipEnterStar(cur_ship, cur_star, GalaxyStar(TortugatzId), Rnd(1, 2));",
                        "                        ShipJoin(KlissanNormal, cur_ship);",
                        "                        ShipCustomFaction(cur_ship, 'Klissan');",
                        "                    }",
                        "                    //Фазы атаки",
                        "                    //0 - атаки нет, 1 - подготовка к атаке, 2 - атака, 3 - угасание, 4 - возврат",
                        "                    ruchnik_bonus = 0;",
                        "                    cur_hole = HoleCreate2(cur_star, GalaxyStar(TortugatzId));",
                        "                    HoleTurnCreate(cur_hole, CurTurn() - Rnd(180, 185));",
                        "                    HoleMap(cur_hole, 'SkipAB');",
                        "                }",
                        "            }",
                        "        }",
                        "    }",
                        "}",
                        "",
                        "//Если игрок отдал прямой приказ на захват клисанами определённой системы",
                        "//(впрочем, хуй знает. тут какая-то хуян опять написана вместо атаки)",
                        "if(ruchnik == 1)",
                        "{",
                        "    ruchnik = 0;",
                        "    ruchnik_bonus = 1; //Маркер для обработчиков атаки, даёт \"бонус\" клисанам, отправленным по прямому приказу",
                        "    cur_star3 = GalaxyStar(ru1 - 1);",
                        "    last_star3 = Id(cur_star3);",
                        "    god = CurTurn() / 365;",
                        "    god = god * 75 / 100;",
                        "    danger = god + KlissanDiffLevel * 10 / 50;",
                        "",
                        "    danger = danger + PortionInDiapason(GTL, 1, 8, -15, 15);",
                        "    if(danger > 75 && GTL < 8) danger = 75;",
                        "",
                        "    if(klissanStars[0] <= 0.1 * max_stars) danger = 2.35 * danger;",
                        "    else if(klissanStars[0] <= 0.2 * max_stars) danger = 2.10 * danger;",
                        "    else if(klissanStars[0] <= 0.3 * max_stars) danger = 1.80 * danger;",
                        "    else if(klissanStars[0] <= 0.42 * max_stars) danger = 1.65 * danger;",
                        "    else if(klissanStars[0] <= 0.55 * max_stars) danger = 1.50 * danger;",
                        "    else if(klissanStars[0] <= 0.67 * max_stars) danger = 1.35 * danger;",
                        "    else if(klissanStars[0] <= 0.8 * max_stars) danger = 1.20 * danger;",
                        "    else danger = 1.20 * danger;",
                        "",
                        "    if(CurTurn() <= GShuKlissanFirstStart + 340) danger = danger * 40 / 100;",
                        "    else if(CurTurn() <= GShuKlissanFirstStart + 820) danger = danger * 55 / 100;",
                        "    else if(CurTurn() <= GShuKlissanFirstStart + 1500) danger = danger * 80 / 100;",
                        "    else danger = danger;",
                        "",
                        "    if(ruchnik_bonus) danger = round(1.25 * danger);",
                        "    start_date3 = CurTurn();",
                        "    attack_state3 = 1;",
                        "    attack_status = 0;",
                        "    cstar_id3 = Id(cur_star3);",
                        "",
                        "    //Форсируем определение уровня угрозы",
                        "    //Высылаем подкрепление",
                        "    //Определяем количество клисан в составе основной волны",
                        "    if (danger <= 20) attack_count3 = Rnd(3, 12);",
                        "    else if (danger <= 40) attack_count3 = Rnd(3, 13);",
                        "    else if (danger <= 60) attack_count3 = Rnd(4, 14);",
                        "    else if (danger <= 80) attack_count3 = Rnd(4, 15);",
                        "    else attack_count3 = Rnd(4, 16);",
                        "    if (KlissanDiffLevel <= 50) attack_count3 = attack_count3 * 60 / 100;",
                        "    else if (KlissanDiffLevel <= 100) attack_count3 = attack_count3 * 90 / 100;",
                        "    else if (KlissanDiffLevel <= 150) attack_count3 = attack_count3 * 120 / 110;",
                        "    else if (KlissanDiffLevel <= 200) attack_count3 = attack_count3 * 150 / 100;",
                        "    else if (KlissanDiffLevel <= 250) attack_count3 = attack_count3 * 170 / 100;",
                        "    else if (KlissanDiffLevel <= 300) attack_count3 = attack_count3 * 190 / 100;",
                        "    else if (KlissanDiffLevel <= 350) attack_count3 = attack_count3 * 210 / 100;",
                        "    else if (KlissanDiffLevel <= 400) attack_count3 = attack_count3 * 230 / 100;",
                        "    else if (KlissanDiffLevel <= 450) attack_count3 = attack_count3 * 240 / 100;",
                        "    else attack_count3 = attack_count3 * 260 / 100;",
                        "    attack_count3 = attack_count3 * 135 / 100;",
                        "",
                        "    //Запускаем цикл по рождению клисан",
                        "    for (i = 0; i < attack_count3; i = i + 1) {",
                        "        cur_ship = BuyKlissan(PlanetPirateClan(), -1);",
                        "        MakeShipEnterStar(cur_ship, cur_star3, PlanetToStar(PlanetPirateClan()), Rnd(1, 2));",
                        "        ShipJoin(Klissan3, cur_ship);",
                        "        ShipCustomFaction(cur_ship, 'Klissan');",
                        "    }",
                        "    //Фазы атаки",
                        "    //0 - атаки нет, 1 - подготовка к атаке, 2 - атака, 3 - угасание, 4 - возврат",
                        "    ruchnik_bonus = 0;",
                        "}",
                        "",
                        "//Новый цикл по атаке + переходу систем:",
                        "if(CurTurn() >= GShuKlissanFirstStart)",
                        "{",
                        "    //Основной цикл проверки захвата/освобождения систем от клисан (проверяет только те системы, в которых прямо сейчас идёт бой)",
                        "    tdwd1 = ShipStar(Player());",
                        "    for(i = 0; i < GalaxyStars(); i = i + 1)",
                        "    {",
                        "        cur_star = StarNearbyStars(tdwd1, i);",
                        "        if(!StarBattle(cur_star)) continue;",
                        "        if(cur_star == GalaxyStar(TortugatzId) || cur_star == GalaxyStar(NifigatzId)) continue;",
                        "",
                        "        //check == -1 - клисане потеряли систему",
                        "        //check == 0 - статус системы в отношении клисан не изменился",
                        "        //check == 1 - клисане захватили систему",
                        "        check = -1;",
                        "        if(StarCustomFaction(cur_star) != 'Klissan')",
                        "        {",
                        "            //Считаем общее число всех клисанских и не клисанских кораблей в системе",
                        "            tint1 = 0;",
                        "            tint2 = 0;",
                        "            for(j = 0; j < StarShips(cur_star); j = j + 1)",
                        "            {",
                        "                cur_ship = StarShips(cur_star, j);",
                        "                if(ShipInHyperSpace(cur_ship)) continue;",
                        "                if(ShipCustomFaction(cur_ship) == 'Klissan') tint1 = tint1 + 1;",
                        "                else tint2 = tint2 + 1;",
                        "            }",
                        "",
                        "            if(tint1 && !tint2) check = 1;",
                        "            else check = 0;",
                        "        }",
                        "        else",
                        "        {",
                        "            //Проверяем, остался ли в системе хотя бы один живой клисан",
                        "            for(j = 0; j < StarShips(cur_star); j = j + 1)",
                        "            {",
                        "                cur_ship = StarShips(cur_star, j);",
                        "                if(ShipInHyperSpace(cur_ship)) continue;",
                        "                if(ShipCustomFaction(cur_ship) != 'Klissan') continue;",
                        "                check = 0;",
                        "                break;",
                        "            }",
                        "        }",
                        "",
                        "        //Если кроме клисан в системе никого не осталось, то система считается захваченной клисанами",
                        "        if(check == 1)",
                        "        {",
                        "            check = StarOwner(cur_star);",
                        "            if(!check)",
                        "            {",
                        "                tstr1 = Format(CT('GalaxyNews.Global.KlissanTakeSystemFromNormals' + Rnd(1, 3)), '<Star' + '>', Name(cur_star), '<Sector' + '>', Name(StarToCon(cur_star)));",
                        "                NewsAdd(tstr1);",
                        "                AddPlanetNews(tstr1, 64);",
                        "            }",
                        "            else if(check == 2)",
                        "            {",
                        "                tstr1 = Format(CT('GalaxyNews.Global.KlissanTakeSystemFromPirates' + Rnd(1, 3)), '<Star' + '>', Name(cur_star), '<Sector' + '>', Name(StarToCon(cur_star)));",
                        "                NewsAdd(tstr1);",
                        "                AddPlanetNews(tstr1, 65);",
                        "            }",
                        "            for(j = 0; j < StarPlanets(cur_star); j = j + 1) {",
                        "                cur_planet = StarPlanets(cur_star, j);",
                        "                if(PlanetOwner(cur_planet) == None) continue;",
                        "                PlanetOwner(cur_planet, Kling);",
                        "            }",
                        "            StarCustomFaction(cur_star, 'Klissan');",
                        "            klissanStars[0] = klissanStars[0] + 1;",
                        "            ArrayAdd(klissanStars, Id(cur_star) - 1);",
                        "        }",
                        "        //Если всех клисан успешно выбили из системы",
                        "        else if(check == -1)",
                        "        {",
                        "            enemiesCnt = ShipKillFactionInCurSystem(Player(), -1);",
                        "            StarCustomFaction(cur_star, '');",
                        "            //Выясняем, кто конкретно отбил систему у клисан",
                        "            check = StarOwner(cur_star);",
                        "            //Если Коалиция",
                        "            if(!check)",
                        "            {",
                        "                reward_planet = FindPlanet(cur_star, 'NotKling,NotNone', 0, 0);",
                        "                //Выводится новость об освобождении системы от клисан Коалицией",
                        "                tstr1 = Format(CT('GalaxyNews.Global.NormalsTakeSystemFromKlissan' + Rnd(1, 3)), '<Star' + '>', Name(cur_star), '<Sector' + '>', Name(StarToCon(cur_star)), '<Planet' + '>', Name(reward_planet));",
                        "                Ether(0, '', tstr1, reward_planet);",
                        "                AddPlanetNews(tstr1, 66);",
                        "",
                        "                //Если игрок находится в освобождённой системе, то играется звук освобождения",
                        "                if(ShipInStar(Player(), cur_star) && !ShipInHyperSpace(Player()))",
                        "                {",
                        "                    //А если игрок ещё и сбивал клисанские корабли, то получает награду",
                        "                    if(enemiesCnt)",
                        "                    {",
                        "                        for(i = 0; i < StarPlanets(cur_star); i = i + 1)",
                        "                        {",
                        "                            cur_planet = StarPlanets(cur_star, i);",
                        "                            if(PlanetOwner(cur_planet) != None) RelationToRanger(cur_planet, Player(), 100);",
                        "                        }",
                        "                        planet_reward = Id(reward_planet);",
                        "                        star_reward = Id(cur_star) - 1;",
                        "                        ShipStatistic(Player(), 3, ShipStatistic(Player(), 3) + 1);",
                        "                    }",
                        "",
                        "                    Sound('Sound.LiberationSystem');",
                        "                }",
                        "            }",
                        "            //Если пираты",
                        "            else if(check == 2)",
                        "            {",
                        "                reward_planet = FindPlanet(cur_star, 'NotKling,NotNone', 0, 0);",
                        "                //Выводится новость об освобождении системы от клисан пиратами",
                        "                tstr1 = Format(CT('GalaxyNews.Global.PiratesTakeSystemFromKlissan' + Rnd(1, 2)), '<Star' + '>', Name(cur_star), '<Sector' + '>', Name(StarToCon(cur_star)), '<Planet' + '>', Name(reward_planet));",
                        "                Ether(0, '', tstr1, reward_planet);",
                        "                AddPlanetNews(tstr1, 67);",
                        "",
                        "                //Если игрок находится в освобождённой системе, то играется звук освобождения",
                        "                if(ShipInStar(Player(), cur_star) && !ShipInHyperSpace(Player()))",
                        "                {",
                        "                    //А если игрок ещё и сбивал клисанские корабли, то получает награду",
                        "                    if(enemiesCnt)",
                        "                    {",
                        "                        RelationToRanger(PlanetPirateClan(), Player(), RelationToRanger(PlanetPirateClan(), Player()) + 10);",
                        "                        planet_reward = Id(reward_planet);",
                        "                        star_reward = Id(cur_star) - 1;",
                        "                        ShipStatistic(Player(), 3, ShipStatistic(Player(), 3) + 1);",
                        "                    }",
                        "",
                        "                    Sound('Sound.LiberationSystem');",
                        "                }",
                        "            }",
                        "            //Иначе система считается захваченной доминаторами, что нас уже не интересует",
                        "            //else {}",
                        "            for(i = 1; i <= klissanStars[0]; i = i + 1) {",
                        "                tint1 = klissanStars[i];",
                        "                tint2 = Id(cur_star) - 1;",
                        "                if(tint1 == tint2) {",
                        "                    ArrayDelete(klissanStars, i);",
                        "                    klissanStars[0] = klissanStars[0] - 1;",
                        "                    break;",
                        "                }",
                        "            }",
                        "        }",
                        "    }",
                        "    for(i = 1; i <= klissanStars[0]; i = i + 1) {",
                        "        cur_star = GalaxyStar(klissanStars[i]);",
                        "        cur_ruins = StarRuins(cur_star, 'KB');",
                        "        if(cur_ruins) {",
                        "            if(ShipInNormalSpace(cur_ruins)) {",
                        "                if(StarShips(cur_star) < max_kl) {",
                        "                    cur_ship = BuyKlissan(PlanetPirateClan(), -1);",
                        "                    TransferShip(cur_ship, cur_ruins);",
                        "                    ShipJoin(KlissanNormal, cur_ship);",
                        "                    ShipCustomFaction(cur_ship, 'Klissan'); //Кастомную фракцию нужно повесить сразу, чтобы клисан не атаковал нейролинк при взлете",
                        "                }",
                        "            }",
                        "        }",
                        "    }",
                        "    if(KlissanState != 2 && KlissanState != 4)",
                        "    {",
                        "        if(GroupCount(Handler))",
                        "        {",
                        "            i = CurTurn() / 365;",
                        "            max_stars = 3 + i * 90 / 100;",
                        "            max_stars = max_stars + KlissanDiffLevel * 4 / 50;",
                        "            max_stars = max_stars * 45 / 100;",
                        "            was_extermination = 2;",
                        "",
                        "            if(klissanStars[0] < max_stars)",
                        "            {",
                        "                if(!attack_state)",
                        "                {",
                        "                    sh = PortionInDiapason(KlissanDiffLevel, 50, 500, 4, 11);",
                        "",
                        "                    if(attack_status == 1) sh * 80 / 100;",
                        "                    else sh = sh * 120 / 100;",
                        "",
                        "                    sh = round(PortionInDiapason(GroupCount(NestNormal), 0, 11, 3.0, 0.5) * sh);",
                        "",
                        "                    if(CurTurn() < attack_date + 20) sh = sh * 70 / 100;",
                        "                    else if(CurTurn() < attack_date + 35) sh = sh * 85 / 100;",
                        "                    else if(CurTurn() < attack_date + 50) sh = sh * 100 / 100;",
                        "                    else if(CurTurn() < attack_date + 70) sh = sh * 105 / 100;",
                        "                    else if(CurTurn() < attack_date + 90) sh = sh * 110 / 100;",
                        "                    else if(CurTurn() < attack_date + 120) sh = sh * 120 / 100;",
                        "                    else if(CurTurn() < attack_date + 150) sh = sh * 125 / 100;",
                        "                    else if(CurTurn() < attack_date + 180) sh = sh * 130 / 100;",
                        "                    else if(CurTurn() < attack_date + 240) sh = sh * 140 / 100;",
                        "                    else if(CurTurn() < attack_date + 300) sh = sh * 150 / 100;",
                        "                    else sh = sh * 165 / 100;",
                        "",
                        "                    sh = sh * 2;",
                        "                    if(Rnd(1, 1000) <= sh) i = 1;",
                        "                    else i = 0;",
                        "                    if(i)",
                        "                    {",
                        "                        ArrayClear(first);",
                        "                        ArrayClear(second);",
                        "                        ArrayClear(third);",
                        "                        cur_star = 0;",
                        "",
                        "                        for(i = 50; i < GalaxyStars(); i = i + 1)",
                        "                        {",
                        "                            sh = StarNearbyStars(PlanetToStar(PlanetPirateClan()), i);",
                        "                            if(Id(sh) == last_star)",
                        "                            {",
                        "                                if(Attack_count == 2 && Rnd(1, 100) < 25) continue;",
                        "                                if(Attack_count == 3 && Rnd(1, 100) < 50) continue;",
                        "                                if(Attack_count == 4 && Rnd(1, 100) < 80) continue;",
                        "                            }",
                        "                            if(KlissanState == 1 && StarOwner(sh) == 0) continue;",
                        "                            if(StarShips(sh) > 60) continue;",
                        "                            if(StarCustomFaction(sh) == 'Klissan') continue;",
                        "                            if(Terron())",
                        "                            {",
                        "                                if(sh == ShipStar(Terron())) continue;",
                        "                            }",
                        "                            if(!NoComeKlingToStar(sh) && StarOwner(sh) != 2 && sh != cur_star2) ArrayAdd(first, sh);",
                        "                        }",
                        "                        for(i = 26; i < 50; i = i + 1)",
                        "                        {",
                        "                            sh = StarNearbyStars(PlanetToStar(PlanetPirateClan()), i);",
                        "                            if(Id(sh) == last_star)",
                        "                            {",
                        "                                if(Attack_count == 2 && Rnd(1, 100) < 25) continue;",
                        "                                if(Attack_count == 3 && Rnd(1, 100) < 50) continue;",
                        "                                if(Attack_count == 4 && Rnd(1, 100) < 80) continue;",
                        "                            }",
                        "                            if(KlissanState == 1 && StarOwner(sh) == 0) continue;",
                        "                            if(StarShips(sh) > 60) continue;",
                        "                            if(StarCustomFaction(sh) == 'Klissan') continue;",
                        "                            if(Terron())",
                        "                            {",
                        "                                if(sh == ShipStar(Terron())) continue;",
                        "                            }",
                        "                            if(!NoComeKlingToStar(sh) && StarOwner(sh) != 2 && sh != cur_star2) ArrayAdd(second, sh);",
                        "                        }",
                        "                        for(i = 1; i < 26; i = i + 1)",
                        "                        {",
                        "                            sh = StarNearbyStars(PlanetToStar(PlanetPirateClan()), i);",
                        "                            if(Id(sh) == last_star)",
                        "                            {",
                        "                                if(Attack_count == 2 && Rnd(1, 100) < 25) continue;",
                        "                                if(Attack_count == 3 && Rnd(1, 100) < 50) continue;",
                        "                                if(Attack_count == 4 && Rnd(1, 100) < 80) continue;",
                        "                            }",
                        "                            if(KlissanState == 1 && StarOwner(sh) == 0) continue;",
                        "                            if(StarShips(sh) > 60) continue;",
                        "                            if(Terron())",
                        "                            {",
                        "                                if(sh == ShipStar(Terron())) continue;",
                        "                            }",
                        "                            if(StarCustomFaction(sh) == 'Klissan') continue;",
                        "                            if(!NoComeKlingToStar(sh) && StarOwner(sh) != 2 && sh != cur_star2) ArrayAdd(third, sh);",
                        "                        }",
                        "",
                        "                        rand = Rnd(1, 100);",
                        "                        if(rand <= 50 && ArrayDim(first) > 1) cur_star = first[Rnd(1, ArrayDim(first) - 1)];",
                        "                        else if(rand <= 80 && ArrayDim(second) > 1) cur_star = second[Rnd(1, ArrayDim(second) - 1)];",
                        "                        else if(ArrayDim(third) > 1) cur_star = third[Rnd(1, ArrayDim(third) - 1)];",
                        "",
                        "                        if(cur_star)",
                        "                        {",
                        "                            if(Id(cur_star) == last_star) Attack_count = Attack_count + 1;",
                        "                            else Attack_count = 0;",
                        "                        }",
                        "                        else Attack_count = 0;",
                        "",
                        "                        if(cur_star)",
                        "                        {",
                        "                            last_star = Id(cur_star);",
                        "",
                        "                            god = CurTurn() / 365;",
                        "                            god = god * 75 / 100;",
                        "                            danger = god + KlissanDiffLevel * 10 / 50;",
                        "                            danger = danger + PortionInDiapason(GTL, 1, 8, -15, 15);",
                        "                            if(danger > 75 && GalaxyTechLevel() < 8) danger = 75;",
                        "",
                        "                            if(klissanStars[0] <= 0.1 * max_stars) danger = 2.35 * danger;",
                        "                            else if(klissanStars[0] <= 0.2 * max_stars) danger = 2.10 * danger;",
                        "                            else if(klissanStars[0] <= 0.3 * max_stars) danger = 1.80 * danger;",
                        "                            else if(klissanStars[0] <= 0.42 * max_stars) danger = 1.65 * danger;",
                        "                            else if(klissanStars[0] <= 0.55 * max_stars) danger = 1.50 * danger;",
                        "                            else if(klissanStars[0] <= 0.67 * max_stars) danger = 1.35 * danger;",
                        "                            else if(klissanStars[0] <= 0.8 * max_stars) danger = 1.20 * danger;",
                        "                            else danger = 1.20 * danger;",
                        "",
                        "                            if(CurTurn() <= GShuKlissanFirstStart + 340) danger = danger * 40 / 100;",
                        "                            else if(CurTurn() <= GShuKlissanFirstStart + 820) danger = danger * 55 / 100;",
                        "                            else if(CurTurn() <= GShuKlissanFirstStart + 1500) danger = danger * 80 / 100;",
                        "                            else danger = danger;",
                        "",
                        "                            start_date = CurTurn();",
                        "                            attack_state = 1;",
                        "                            attack_status = 0;",
                        "                            cstar_id = Id(cur_star);",
                        "",
                        "                            //Форсируем определение уровня угрозы",
                        "                            //Высылаем подкрепление",
                        "                            sh = danger * GroupCount(NestNormal) / 7;",
                        "                            if(danger < 80 && sh>65) sh = 65;",
                        "                            if(danger >= 80 && sh > 80) sh = 80;",
                        "                            cur_ruins = BuyNeurolink(Nest1); //Строим гнездо",
                        "                            //Определяем количество клисан в составе основной волны",
                        "                            if(danger <= 20) attack_count = Rnd(4, 9);",
                        "                            else if(danger <= 40) attack_count = Rnd(5, 10);",
                        "                            else if(danger <= 60) attack_count = Rnd(6, 12);",
                        "                            else if(danger <= 80) attack_count = Rnd(6, 14);",
                        "                            else attack_count = Rnd(6, 16);",
                        "",
                        "                            attack_count = round(PortionInDiapason(KlissanDiffLevel, 50, 500, 0.6, 2.7) * attack_count);",
                        "                            //В этом месте наблюдаются беды с башкой",
                        "                            attack_count = round(1.5 * attack_count);",
                        "                            if(!Rnd(0, 3)) attack_count = round(1.5 * attack_count);",
                        "",
                        "                            //Запускаем цикл по рождению клисан",
                        "                            for(b = 0; b < attack_count; b = b + 1)",
                        "                            {",
                        "                                k = BuyKlissan(PlanetPirateClan(), -1);",
                        "                                TransferShip(k, cur_ruins);",
                        "                                ShipJoin(Klissan1, k);",
                        "                            }",
                        "                        }",
                        "                    }",
                        "                }",
                        "",
                        "                if(!attack_state3 && KlissanState != 3)",
                        "                {",
                        "                    sh = PortionInDiapason(KlissanDiffLevel, 50, 500, 4, 11);",
                        "",
                        "                    if(attack_status == 1) sh * 85 / 100;",
                        "                    else sh = sh * 125 / 100;",
                        "",
                        "                    if(CurTurn() < attack_date + 20) sh = sh * 70 / 100;",
                        "                    else if(CurTurn() < attack_date + 35) sh = sh * 85 / 100;",
                        "                    else if(CurTurn() < attack_date + 50) sh = sh * 100 / 100;",
                        "                    else if(CurTurn() < attack_date + 70) sh = sh * 105 / 100;",
                        "                    else if(CurTurn() < attack_date + 90) sh = sh * 110 / 100;",
                        "                    else if(CurTurn() < attack_date + 120) sh = sh * 120 / 100;",
                        "                    else if(CurTurn() < attack_date + 150) sh = sh * 125 / 100;",
                        "                    else if(CurTurn() < attack_date + 180) sh = sh * 130 / 100;",
                        "                    else if(CurTurn() < attack_date + 240) sh = sh * 140 / 100;",
                        "                    else if(CurTurn() < attack_date + 300) sh = sh * 150 / 100;",
                        "                    else sh = sh * 165 / 100;",
                        "",
                        "                    sh = sh * 3;",
                        "                    if(Rnd(1, 1000) <= sh) i = 1;",
                        "                    else i = 0;",
                        "                    if(i)",
                        "                    {",
                        "                        ArrayClear(first);",
                        "                        ArrayClear(second);",
                        "                        ArrayClear(third);",
                        "                        cur_star3 = 0;",
                        "",
                        "                        for(i = 1; i < 10; i = i + 1)",
                        "                        {",
                        "                            sh = StarNearbyStars(PlanetToStar(PlanetPirateClan()), i);",
                        "                            if(Id(sh) == last_star3)",
                        "                            {",
                        "                                if(Attack_count3 == 2 && Rnd(1, 100) < 25) continue;",
                        "                                if(Attack_count3 == 3 && Rnd(1, 100) < 50) continue;",
                        "                                if(Attack_count3 == 4 && Rnd(1, 100) < 80) continue;",
                        "                            }",
                        "                            if(KlissanState == 1 && StarOwner(sh) == 0) continue;",
                        "                            if(StarCustomFaction(sh) == 'Klissan' && Rnd(0, 1)) continue;",
                        "                            if(StarCustomFaction(sh) == 'Klissan' && StarShips(sh) > max_kl * 1.25) continue;",
                        "                            if(Terron())",
                        "                            {",
                        "                                if(sh == ShipStar(Terron()))continue;",
                        "                            }",
                        "                            if(!NoComeKlingToStar(sh) && StarOwner(sh) != 2 && sh != cur_star3) ArrayAdd(first, sh);",
                        "                        }",
                        "                        for(i = 11; i < 20; i = i + 1)",
                        "                        {",
                        "                            sh = StarNearbyStars(PlanetToStar(PlanetPirateClan()), i);",
                        "                            if(Id(sh) == last_star3)",
                        "                            {",
                        "                                if(Attack_count3 == 2 && Rnd(1, 100) < 25) continue;",
                        "                                if(Attack_count3 == 3 && Rnd(1, 100) < 50) continue;",
                        "                                if(Attack_count3 == 4 && Rnd(1, 100) < 80) continue;",
                        "                            }",
                        "                            if(KlissanState == 1 && StarOwner(sh) == 0) continue;",
                        "                            if(StarCustomFaction(sh) == 'Klissan' && Rnd(0, 1)) continue;",
                        "                            if(StarCustomFaction(sh) == 'Klissan' && StarShips(sh) > max_kl * 1.25) continue;",
                        "                            if(Terron())",
                        "                            {",
                        "                                if(sh == ShipStar(Terron()))continue;",
                        "                            }",
                        "                            if(!NoComeKlingToStar(sh) && StarOwner(sh) != 2 && sh != cur_star3) ArrayAdd(second, sh);",
                        "                        }",
                        "                        for(i = 21; i < 30; i = i + 1)",
                        "                        {",
                        "                            sh = StarNearbyStars(PlanetToStar(PlanetPirateClan()), i);",
                        "                            if(Id(sh) == last_star3)",
                        "                            {",
                        "                                if(Attack_count3 == 2 && Rnd(1, 100) < 25) continue;",
                        "                                if(Attack_count3 == 3 && Rnd(1, 100) < 50) continue;",
                        "                                if(Attack_count3 == 4 && Rnd(1, 100) < 80) continue;",
                        "                            }",
                        "                            if(KlissanState == 1 && StarOwner(sh) == 0) continue;",
                        "                            if(StarCustomFaction(sh) == 'Klissan' && Rnd(0, 1)) continue;",
                        "                            if(StarCustomFaction(sh) == 'Klissan' && StarShips(sh) > max_kl * 1.25) continue;",
                        "                            if(Terron())",
                        "                            {",
                        "                                if(sh == ShipStar(Terron()))continue;",
                        "                            }",
                        "                            if(!NoComeKlingToStar(sh) && StarOwner(sh) != 2 && sh != cur_star3) ArrayAdd(third, sh);",
                        "                        }",
                        "",
                        "                        rand = Rnd(1, 100);",
                        "                        if(rand <= 50 && ArrayDim(first) > 1) cur_star3 = first[Rnd(1, ArrayDim(first) - 1)];",
                        "                        else if(rand <= 80 && ArrayDim(second) > 1) cur_star3 = second[Rnd(1, ArrayDim(second) - 1)];",
                        "                        else if(ArrayDim(third) > 1) cur_star3 = third[Rnd(1, ArrayDim(third) - 1)];",
                        "",
                        "                        if(cur_star3)",
                        "                        {",
                        "                            if(Id(cur_star3) == last_star3) Attack_count3 = Attack_count3 + 1;",
                        "                            else Attack_count3 = 0;",
                        "                        }",
                        "                        else Attack_count3 = 0;",
                        "                        if(cur_star3)",
                        "                        {",
                        "                            last_star3 = Id(cur_star3);",
                        "",
                        "                            god = CurTurn() / 365;",
                        "                            god = god * 75 / 100;",
                        "                            danger = god + KlissanDiffLevel * 10 / 50;",
                        "                            danger = danger + PortionInDiapason(GTL, 1, 8, -15, 15);",
                        "                            if(danger > 75 && GalaxyTechLevel() < 8) danger = 75;",
                        "",
                        "                            if(klissanStars[0] <= 0.1 * max_stars) danger = 2.35 * danger;",
                        "                            else if(klissanStars[0] <= 0.2 * max_stars) danger = 2.10 * danger;",
                        "                            else if(klissanStars[0] <= 0.3 * max_stars) danger = 1.80 * danger;",
                        "                            else if(klissanStars[0] <= 0.42 * max_stars) danger = 1.65 * danger;",
                        "                            else if(klissanStars[0] <= 0.55 * max_stars) danger = 1.50 * danger;",
                        "                            else if(klissanStars[0] <= 0.67 * max_stars) danger = 1.35 * danger;",
                        "                            else if(klissanStars[0] <= 0.8 * max_stars) danger = 1.20 * danger;",
                        "                            else danger = 1.20 * danger;",
                        "",
                        "                            if(CurTurn() <= GShuKlissanFirstStart + 340) danger = danger * 40 / 100;",
                        "                            else if(CurTurn() <= GShuKlissanFirstStart + 820) danger = danger * 55 / 100;",
                        "                            else if(CurTurn() <= GShuKlissanFirstStart + 1500) danger = danger * 80 / 100;",
                        "                            else danger = danger;",
                        "",
                        "                            if(ruchnik_bonus) danger = danger * 1.25;",
                        "                            start_date3 = CurTurn();",
                        "                            attack_state3 = 1;",
                        "                            attack_status = 0;",
                        "                            cstar_id3 = Id(cur_star3);",
                        "",
                        "                            //Форсируем определение уровня угрозы",
                        "",
                        "                            //Высылаем подкрепление",
                        "                            sh = danger * GroupCount(NestNormal) / 7;",
                        "                            if(danger < 80 && sh>65) sh = 65;",
                        "                            if(danger >= 80 && sh > 80) sh = 80;",
                        "                            rand = Rnd(1, 100);",
                        "                            sh = 150;",
                        "",
                        "                            //Определяем количество клисан в составе основной волны",
                        "                            if(danger <= 20) attack_count3 = Rnd(3, 12);",
                        "                            else if(danger <= 40) attack_count3 = Rnd(3, 13);",
                        "                            else if(danger <= 60) attack_count3 = Rnd(4, 14);",
                        "                            else if(danger <= 80) attack_count3 = Rnd(4, 15);",
                        "                            else attack_count3 = Rnd(4, 16);",
                        "",
                        "                            attack_count3 = round(PortionInDiapason(KlissanDiffLevel, 50, 500, 0.6, 2.6) * attack_count3);",
                        "                            attack_count3 = round(1.35 * attack_count3);",
                        "",
                        "                            //Запускаем цикл по рождению клисан",
                        "                            for(b = 0; b < attack_count3; b = b + 1)",
                        "                            {",
                        "                                k = BuyKlissan(PlanetPirateClan(), -1);",
                        "                                MakeShipEnterStar(k, cur_star3, PlanetToStar(PlanetPirateClan()), Rnd(1, 2));",
                        "                                ShipJoin(Klissan3, k);",
                        "                                ShipCustomFaction(k, 'Klissan');",
                        "                            }",
                        "",
                        "                            //ФАЗЫ АТАКИ",
                        "                            //0 - атаки нет, 1 - подготовка к атаке, 2 - атака, 3 - угасание, 4 - возврат",
                        "                            ruchnik_bonus = 0;",
                        "                        }",
                        "                    }",
                        "                }",
                        "            }",
                        "",
                        "            //Если игрок активировал Z-трансмиттер (который тупо вешает безкодовую маркерную инфошку)",
                        "            //Начинается атака клисан на указанную игроком систему",
                        "            if(~ShipFindCustomShipInfoByType(Player(), 'Transmitter'))",
                        "            {",
                        "                god = CurTurn() / 365;",
                        "                god = god * 75 / 100;",
                        "                danger = god + KlissanDiffLevel * 10 / 50;",
                        "                danger = danger + PortionInDiapason(GTL, 1, 8, -15, 27);",
                        "                if(danger > 75 && GalaxyTechLevel() < 8) danger = 75;",
                        "                if(klissanStars[0] <= 0.1 * max_stars) danger = 2.35 * danger;",
                        "                else if(klissanStars[0] <= 0.2 * max_stars) danger = 2.10 * danger;",
                        "                else if(klissanStars[0] <= 0.3 * max_stars) danger = 1.80 * danger;",
                        "                else if(klissanStars[0] <= 0.42 * max_stars) danger = 1.65 * danger;",
                        "                else if(klissanStars[0] <= 0.55 * max_stars) danger = 1.50 * danger;",
                        "                else if(klissanStars[0] <= 0.67 * max_stars) danger = 1.35 * danger;",
                        "                else if(klissanStars[0] <= 0.8 * max_stars) danger = 1.20 * danger;",
                        "                else danger = 1.20 * danger;",
                        "",
                        "                if(CurTurn() <= GShuKlissanFirstStart + 340) danger = danger * 40 / 100;",
                        "                else if(CurTurn() <= GShuKlissanFirstStart + 820) danger = danger * 55 / 100;",
                        "                else if(CurTurn() <= GShuKlissanFirstStart + 1500) danger = danger * 80 / 100;",
                        "                else danger = danger;",
                        "",
                        "                attack_status = 0;",
                        "",
                        "                cur_star4 = GalaxyStar(ShipCustomShipInfoData(Player(), 'Transmitter', 1));",
                        "                ShipDeleteCustomShipInfo(Player(), 'Transmitter');",
                        "                //Форсируем определение уровня угрозы",
                        "                //Высылаем подкрепление",
                        "                //Определяем количество клисан в составе основной волны",
                        "                if(danger <= 20) attack_count = Rnd(4, 9);",
                        "                else if(danger <= 40) attack_count = Rnd(5, 10);",
                        "                else if(danger <= 60) attack_count = Rnd(6, 12);",
                        "                else if(danger <= 80) attack_count = Rnd(6, 14);",
                        "                else attack_count = Rnd(6, 16);",
                        "",
                        "                attack_count = round(PortionInDiapason(KlissanDiffLevel, 50, 500, 0.6, 2.7) * attack_count);",
                        "                //Беды с башкой",
                        "                attack_count = round(attack_count * 1.5);",
                        "                if(!Rnd(0, 3)) attack_count = round(attack_count * 1.5);",
                        "",
                        "                //Запускаем цикл по рождению клисан",
                        "                for(b = 0; b < attack_count3; b = b + 1)",
                        "                {",
                        "                    k = BuyKlissan(PlanetPirateClan(), -1);",
                        "                    MakeShipEnterStar(k, cur_star4, PlanetToStar(PlanetPirateClan()), Rnd(1, 3));",
                        "                    ShipJoin(KlissanNormal, k);",
                        "                    ShipCustomFaction(k, 'Klissan');",
                        "                }",
                        "                //ФАЗЫ АТАКИ",
                        "                //0 - атаки нет, 1 - подготовка к атаке, 2 - атака, 3 - угасание, 4 - возврат;",
                        "            }",
                        "        }",
                        "    }",
                        "}",
                        "",
                        "//Если Махпелла или Хандлер попали в Нифигац, то с них снимается инфошка неуязвимости? Чего, блять?",
                        "//А хули им вообще там делать-то?",
                        "if(GroupCount(Machpella))",
                        "{",
                        "    if(ShipInStar(GroupToShip(Machpella), GalaxyStar(NifigatzId))) ShipDeleteCustomShipInfo(GroupToShip(Machpella), 'ShuKlissan_ImmortalInfo');",
                        "}",
                        "if(GroupCount(Handler))",
                        "{",
                        "    if(EndState2 > 1 || ShipInStar(GroupToShip(Handler), GalaxyStar(NifigatzId))) ShipDeleteCustomShipInfo(GroupToShip(Handler), 'ShuKlissan_ImmortalInfo');",
                        "}",
                        "",
                        "if(!EndState2)",
                        "{",
                        "    //Если пиратским скриптом PC_final игроку было выдано задание (вешается уведомление) с вот таким идентификатором",
                        "    if(EtherState('BABB37FE-1007-4A51-A103-DB9EBEAA4C10') == 3)",
                        "    {",
                        "        //За каким-то хреном шу превращает уведомление о задании в уведомление о провале задания (тип 5)",
                        "        //<PlayerFull>, вам надлежит срочно прибыть на ближайшую работоспособную  пиратскую станцию.",
                        "        if(PirateWin() != 3) Ether(5, 'BABB37FE-1007-4A51-A103-DB9EBEAA4C10', CT('Script.PC_final.186'));",
                        "        //<PlayerFull>, вам надлежит срочно прибыть в ближайший центр рейнджеров. Форма одежды - штатская, парадная.",
                        "        else Ether(5, 'BABB37FE-1007-4A51-A103-DB9EBEAA4C10', CT('Script.PC_final.250'));",
                        "    }",
                        "}",
                        "if(GVideoStatus > 1)",
                        "{",
                        "    GVideoStatus = 0;",
                        "    if(video == 1)",
                        "    {",
                        "        CustomWin(CT(\"Script.Mod_ShuKlissan.251\"));",
                        "    }",
                        "    else if(video == 2)",
                        "    {",
                        "        CustomWin(CT(\"Script.Mod_ShuKlissan.250\"), 1);",
                        "    }",
                        "    else if(video == 3)",
                        "    {",
                        "        CustomWin(Format(CT(\"Script.Mod_ShuKlissan.302\"),\"<0>\",ShipName(Player())), 13);",
                        "    }",
                        "    else if(video == 4)",
                        "    {",
                        "        CustomWin(CT(\"Script.Mod_ShuKlissan.296\"), 3 + ShipPilotRace(Player()));",
                        "    }",
                        "    else if(video == 5)",
                        "    {",
                        "        CustomWin(CT(\"Script.Mod_ShuKlissan.295\"), 1);",
                        "    }",
                        "    else if(video == 6)",
                        "    {",
                        "        CustomWin(CT(\"Script.Mod_ShuKlissan.295\"));",
                        "    }",
                        "    else if(video == 7)",
                        "    {",
                        "        CustomWin(Format(CT(\"Script.Mod_ShuKlissan.301\"),\"<0>\",ShipName(Player())), 2);",
                        "    }",
                        "    else if(video == 8)",
                        "    {",
                        "        CustomWin(CT(\"Script.Mod_ShuKlissan.294\"), 2);",
                        "    }",
                        "}",
                        "",
                        "//Если игрок покинул освобождённую от клисан систему, так и не получив награду за освобождение",
                        "if(star_reward)",
                        "{",
                        "    if(!ShipInStar(Player(), GalaxyStar(star_reward)))",
                        "    {",
                        "        star_reward = 0;",
                        "        planet_reward = 0;",
                        "    }",
                        "}",
                        "//Перекидываем игрока в правительство при освобождении системы",
                        "if(GetShipPlanet(Player()))",
                        "{",
                        "    if(Id(GetShipPlanet(Player())) == planet_reward)",
                        "    {",
                        "        GotoGov(1);",
                        "    }",
                        "}",
                        "",
                        "//Видимо это для кастомных концовок",
                        "if(alakayrip == 1) { //Коалиция",
                        "    if(!GroupCount(Machpella) && !GroupCount(Handler)) {",
                        "        alakayrip = 0;",
                        "        cometo = 1;",
                        "    }",
                        "}",
                        "else if(alakayrip == 2) { //Пираты",
                        "    if(!GroupCount(Machpella) && !GroupCount(Handler)) {",
                        "        alakayrip = 0;",
                        "        cometo = 2;",
                        "    }",
                        "}",
                        "",
                        "//Видимо, нужно для концовки",
                        "if(HandlerDead == 2)",
                        "{",
                        "    if(!GroupCount(HandlerMove))",
                        "    {",
                        "        HandlerDead = 1;",
                        "        Ether(3, 'Brutal', 'Срочно прибыть в ближайший Центр рейнджеров.');",
                        "        shudiagnosis = 1;",
                        "        NoJump(0);",
                        "        ShipSpecialBonuses(GroupToShip(WarriorsWB), bonDroid, 20);",
                        "        NoLanding(GroupToShip(WarriorsWB), 0);",
                        "        ShipOut(GroupToShip(WarriorsWB));",
                        "    }",
                        "}",
                        "",
                        "//Выставляет флаг клисанской пиратской концовки (типа всё захвачено)",
                        "if(shudiagnosis == 3)",
                        "{",
                        "    //Если у Коалиции не осталось подконтрольных систем",
                        "    if(!ControlledSystems(0))",
                        "    {",
                        "        //Если у доминаторов также не осталось подконтрольных систем",
                        "        if(!ControlledSystems(1))",
                        "        {",
                        "            Ether(4, 'Conqueror', CT(\"Script.Mod_ShuKlissan.330\"));",
                        "            Ether(3, 'Conqueror1', CT(\"Script.Mod_ShuKlissan.329\"));",
                        "            shudiagnosis = 0;",
                        "            KlissanPirateEndingFlag = 1;",
                        "        }",
                        "    }",
                        "}",
                        "",
                        "//Хуй пойми как, но связано с маркерами концовок",
                        "if(shudiagnosis != 2)",
                        "{",
                        "    if(specagent == 1)",
                        "    {",
                        "        if(DomiksDefeated())",
                        "        {",
                        "            shudiagnosis = 2;",
                        "        }",
                        "    }",
                        "}",
                        "",
                        "if(specagent == 2)",
                        "{",
                        "    if(!GroupCount(Machpella))",
                        "    {",
                        "        specagent = 3;",
                        "    }",
                        "}",
                        "if(specagent == 4)",
                        "{",
                        "    if(!ControlledSystems(2))",
                        "    {",
                        "        specagent = 0;",
                        "    }",
                        "}",
                        "",
                        "//Уебанский счётчик числа сданных ошмётков",
                        "//С шансом 1 к 33 может рандомно прокрутиться на 1-2 единицы, но не может полностью обнулиться таким образом",
                        "//Также прокрутка этого счётчика происходит за счёт сдачи клисанских обломков на НБ,",
                        "//в раздел основных исследований (1 ед. за 1 т.)",
                        "if(TurnCodeIsDone != CurTurn())",
                        "{",
                        "    if(research > 1)",
                        "    {",
                        "        //Имеется зависимость от уровня сложности настройки учёных (ScientistsIntelligence)",
                        "        if(Rnd(1, 100) <= (ScientistsIntelligence * 4)) research = max(1, research - Rnd(1, 2));",
                        "    }",
                        "}",
                        "",
                        "//Всегда оставлять в самом низу всех обработчиков терна!",
                        "//Нужно, чтобы код некоторых счётчиков в терне не срабатывал по нескольку раз за ход",
                        "//Дерьмовая реализация, но пока поставлю такой костыль, а то переделывать капитально шусчётчики не охота",
                        "TurnCodeIsDone = CurTurn();"
                    ],
                    "#": 147,
                    "Type": "Top",
                    "Parent": -1,
                    "Pos.x": 120,
                    "Pos.y": 1235
                },
                {
                    "Name": "",
                    "Code.Type": "DialogBegin",
                    "Code": [
                        "cur_planet = GetShipPlanet(Player());",
                        "if(!cur_planet) cur_ruin = GetShipRuins(Player());",
                        "if(cur_planet) { //Игроку выводится диалог освобождении системы от клисан",
                        "    if(Id(cur_planet) == planet_reward) AddDialogOverride('PlanetLiberation', 500);",
                        "}",
                        "else if(cur_ruin) {",
                        "    if(PlayerBridge()) {",
                        "        if(PlayerBridge()==3) { //Добавляем диалог управления клисанами только на стартовый экран мостика",
                        "            if(CurTurn() > GShuKlissanFirstStart + 5) {",
                        "                if(KlissanState == 1 || KlissanState == 3) AddDialogInject('KlissanControl', '', CT(\"Script.Mod_ShuKlissan.286\"), 1);",
                        "            }",
                        "        }",
                        "    }",
                        "    else {",
                        "        str5 = ShipType(cur_ruin);",
                        "        if(str5 == 'SB') {",
                        "            if(GShuKlissanFirstStart + 5 <= CurTurn()) {",
                        "                if(!was_comm) { //Диалог о завершении исследования ментального коммуникатора",
                        "                    if(comm_timer) {",
                        "                        if(comm_timer <= CurTurn()) AddDialogOverride('ResearchComm', 1000);",
                        "                    }",
                        "                }",
                        "                if(!was_trans) {  //Диалог о завершении исследования Z-трансмиттера",
                        "                    if(trans_timer) {",
                        "                        if(trans_timer <= CurTurn()) AddDialogOverride('ResearchTrans', 1000);",
                        "                    }",
                        "                }",
                        "                if(!KlissanState) {",
                        "                    if(!sb_first) AddDialogInject('RemainsBegin', '', CT(\"Script.Mod_ShuKlissan.283\"), 1);",
                        "                    else {",
                        "                        if(research_cnt < 5) AddDialogInject('Remains', '', CT(\"Script.Mod_ShuKlissan.283\"), 1);",
                        "                        //Добавляем оверрайд, чтобы игрок точно не пропустил мимо текст завершения основного исследования",
                        "                        else if(research_cnt == 5) AddDialogOverride('RemainsReady', 3000);",
                        "                        else if(trans || comm) AddDialogInject('RemainsAdd', '', CT(\"Script.Mod_ShuKlissan.283\"), 1);",
                        "                    }",
                        "                }",
                        "            }",
                        "        }",
                        "        else if(str5 == 'RC')  {",
                        "            if(!KlissanState) { //Начальные диалоги в ЦР и сдача протоплазмы",
                        "                AddDialogInject('KlissanBegin', '', CT(\"Script.Mod_ShuKlissan.285\"), 1);",
                        "                it = 0;",
                        "                for(i = 0; i < ShipItems(Player()); i = i + 1) {",
                        "                    s = ShipItems(Player(), i);",
                        "                    if(EqCustomFaction(s) == 'Klissan' && ItemType(s) == t_UselessCountableItem) it = it + ItemSize(s);",
                        "                }",
                        "                if(it) AddDialogInject('Protoplasm', '', Format(CT(\"Script.Mod_ShuKlissan.284\"),\"<0>\",it,\"<1>\",it * 3), 1);",
                        "            }",
                        "            if(cometo == 1 && !clan_win_choice) {",
                        "                AddDialogOverride('KlissanSpecagentAlakayRip', 500);",
                        "            }",
                        "            else if(shudiagnosis == 1 && !clan_win_choice) {",
                        "                AddDialogOverride('KlissanBrutalEnding', 500);",
                        "            }",
                        "            else if(DomiksDefeated() && PirateWin()==3 && clan_win_choice) AddDialogOverride('DialogRCWin3',10); //игрок победил клисан, отказался уходить на покой, затем победил домиков",
                        "            else if(KlissanState == 1 && DomiksDefeated() && GroupCount(Machpella) && specagent < 2) {",
                        "                AddDialogOverride('KlissanSpecagentPreEnding', 500);",
                        "            }",
                        "            else if(KlissanState==4) {",
                        "                if(!clan_win_choice && !DomiksDefeated()) AddDialogOverride('KlissanSpecagentAlakayExiled', 500);",
                        "                else if(clan_win_choice && DomiksDefeated()) AddDialogOverride('KlissanSpecagentAlakayExiledWin', 500);",
                        "            }",
                        "            else if(KlissanState!=4) {",
                        "                if(!EndState2) { //НЕ силовая концовка",
                        "                    if(PirateWin() == 3) {",
                        "                        if(!GroupCount(Machpella) && specagent < 4) {",
                        "                            AddDialogOverride('KlissanSpecagentEnding', 500);",
                        "                        }",
                        "                        if(!DomiksDefeated() && !clan_win_choice) {",
                        "                            AddDialogOverride('DialogRCWin5', 10);",
                        "                        }",
                        "                    }",
                        "                }",
                        "            }",
                        "        }",
                        "        else if(str5 == 'PB') {",
                        "            //Клисанская пиратская концовка (вся Галактика полностью захвачена пиратами/клисанами)",
                        "            if(KlissanPirateEndingFlag) {",
                        "                AddDialogOverride('KlissanPirateEnding', 500);",
                        "            }",
                        "            if(!GroupCount(Handler) && KlissanState == 2) {",
                        "                if(cometo == 2) {",
                        "                    AddDialogOverride('KlissanPirateAlakayRip', 500);",
                        "                }",
                        "            }",
                        "            if(!clan_win_choice && KlissanState != 3) {",
                        "                if(PirateWin() == 1) {",
                        "                    if(!DomiksDefeated()) AddDialogOverride('DialogPBWin2', 10);",
                        "                }",
                        "                else if(PirateWin() == 2) {",
                        "                    if(!DomiksDefeated()) AddDialogOverride('DialogPBWin4', 10);",
                        "                }",
                        "            }",
                        "        }",
                        "        else if(str5 == 'WB') {",
                        "            AddDialogBlock(CT('FormRuins.WB.WarWithKlingAndPirates.PlayerSend'), 2);",
                        "            AddDialogInject('WB_talk', '', CT(\"Script.Mod_ShuKlissan.287\"), 1);",
                        "        }",
                        "        else if(str5 == 'CB') {",
                        "            AddDialogInject('CB_talk', '', CT(\"Script.Mod_ShuKlissan.288\"), 1);",
                        "        }",
                        "        else if(str5 == 'Handler') {",
                        "            if(CurTurn() > GShuKlissanFirstStart + 5) {",
                        "                AddDialogOverride('HandlerDialog', 300);",
                        "            }",
                        "        }",
                        "    }",
                        "}"
                    ],
