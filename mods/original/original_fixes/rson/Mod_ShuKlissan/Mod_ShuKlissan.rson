                {
                    "Name": "",
                    "Code.Type": "Turn",
                    "Code": [
                        "if(ShipInNormalSpace(CurShip)) {",
                        "  if(ShipStar(CurShip) == PlanetToStar(PlanetPirateClan())) NoTargetToShip(CurShip, 1);",
                        "  else NoTargetToShip(CurShip, 0);",
                        "  OrderLock(CurShip,0);",
                        "  if(!ShipSpeed(CurShip))ShipDestroy(CurShip);",
                        "  if(ShipInStar(CurShip,PlanetToStar(PlanetPirateClan())))",
                        "  {",
                        "      ShipCustomFaction(CurShip,'');",
                        "      ShipOwner(CurShip,7);",
                        "      if(ShipType(CurShip)=='KB') RuinsChangeType(CurShip,'CB');",
                        "  }",
                        "  else",
                        "  {",
                        "      ShipOwner(CurShip,6);",
                        "      ShipCustomFaction(CurShip,'Klissan');",
                        "      if(ShipType(CurShip)=='KB') RuinsChangeType(CurShip,'UB');",
                        "  }",
                        "  if((StarCustomFaction(ShipStar(CurShip))!='Klissan' && (ShipInHole(CurShip) || ShipInHyperSpace(CurShip))) || (ShipInHyperSpace(CurShip) && StarOwner(ShipStar(CurShip))!=1))",
                        "  {",
                        "      ShipDestroy(CurShip);",
                        "  }",
                        "  if(!GroupCount(Machpella) || KlissanState==4) ShipDestroy(CurShip);",
                        "  if(StarBattle(ShipStar(CurShip)) && HullDamage(CurShip)>50) {",
                        "    ChangeState(27);",
                        "    exit;",
                        "  }",
                        "}"
                    ],
                    "#": 408,
