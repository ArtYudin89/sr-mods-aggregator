                        "if(ShipStar(CurShip) == PlanetToStar(PlanetPirateClan())) NoTargetToShip(CurShip, 1);",
                        "else NoTargetToShip(CurShip, 0);",
                        "ShipOwner(CurShip, None);",
                        "if(!OrderLock(CurShip))",
                        "{",
                        "    k=HoleCreate2(cur_star,PlanetToStar(PlanetPirateClan()));",
                        "    HoleX1(k,Rnd(CoordX(CurShip)-50,CoordX(CurShip)+50));",
                        "    HoleY1(k,Rnd(CoordY(CurShip)-50,CoordY(CurShip)+50));",
                        "    HoleMap(k,'SkipAB');",
                        "    HoleTurnCreate(k,CurTurn()-Rnd(190,195));",
                        "",
                        "    OrderJumpHole(CurShip,k);",
                        "    OrderLock(CurShip,1);",
                        "    ShipSpecialBonuses(CurShip,bonSpeed,500);",
                        "}",
                        "if(!ShipSpeed(CurShip))ShipDestroy(CurShip);",
