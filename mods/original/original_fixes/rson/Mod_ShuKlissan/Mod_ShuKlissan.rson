                        "    else if(i==5)str5='</color>'+Format(CT(\"Script.Mod_ShuKlissan.157\"),\"<0>\",coal_ships,\"<1>\",domik_ships,\"<2>\",pirate_ships,\"<3>\",Star,\"<4>\",Sector);",
                        "    else if(i==6)str5='</color>'+Format(CT(\"Script.Mod_ShuKlissan.158\"),\"<0>\",coal_ships,\"<1>\",domik_ships,\"<2>\",pirate_ships,\"<3>\",Star);",
