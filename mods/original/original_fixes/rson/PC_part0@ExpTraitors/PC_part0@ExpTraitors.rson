    "Visual.Objects": [
        {
            "ConstellationCount": 0,
            "DialogAnswers": [
                {
                    "Name": "",
                    "Pos.x": 0,
                    "Pos.y": 540,
                    "Type": "TDialogAnswer",
                    "Parent": -1,
                    "#": 35,
                    "Msg": "Я - охотник!",
                    "AMsg.Num": "0",
                    "_orig_danswer": "DAnswer(CT(\"Script.PC_part0.32\"))"
                },
                {
                    "Name": "",
                    "Pos.x": 120,
                    "Pos.y": 540,
                    "Type": "TDialogAnswer",
                    "Parent": -1,
                    "#": 36,
                    "Msg": "Я скорее хитрая дичь, чем глупый охотник.",
                    "AMsg.Num": "1",
                    "_orig_danswer": "DAnswer(CT(\"Script.PC_part0.33\"))"
                },
                {
                    "Name": "hangar",
                    "Pos.x": 240,
                    "Pos.y": 540,
                    "Type": "TDialogAnswer",
                    "Parent": -1,
                    "#": 37,
                    "Msg": "Уже ушел.",
                    "AMsg.Num": "2",
                    "_orig_danswer": "DAnswer('hangar~'+CT(\"Script.PC_part0.75\"))"
                },
                {
                    "Name": "",
                    "Pos.x": 360,
                    "Pos.y": 540,
                    "Type": "TDialogAnswer",
                    "Parent": -1,
                    "#": 38,
                    "Msg": "Конечно, соответствую!",
                    "AMsg.Num": "3",
                    "_orig_danswer": "DAnswer(CT(\"Script.PC_part0.35\"))"
                },
                {
                    "Name": "",
                    "Pos.x": 480,
                    "Pos.y": 540,
                    "Type": "TDialogAnswer",
                    "Parent": -1,
                    "#": 39,
                    "Msg": "Пожалуй, нет.",
                    "AMsg.Num": "4",
                    "_orig_danswer": "DAnswer(CT(\"Script.PC_part0.36\"))"
                },
                {
                    "Name": "",
                    "Pos.x": 600,
                    "Pos.y": 540,
                    "Type": "TDialogAnswer",
                    "Parent": -1,
                    "#": 40,
                    "Msg": "Я точно в этом уверен, и жалеть о своем решении не буду.",
                    "AMsg.Num": "5",
                    "_orig_danswer": "DAnswer(CT(\"Script.PC_part0.37\"))"
                },
                {
                    "Name": "",
                    "Pos.x": 720,
                    "Pos.y": 540,
                    "Type": "TDialogAnswer",
                    "Parent": -1,
                    "#": 41,
                    "Msg": "Мне надо немного подумать.",
                    "AMsg.Num": "6",
                    "_orig_danswer": "DAnswer(CT(\"Script.PC_part0.38\"))"
                },
                {
                    "Name": "",
                    "Pos.x": 840,
                    "Pos.y": 540,
                    "Type": "TDialogAnswer",
                    "Parent": -1,
                    "#": 42,
                    "Msg": "И это все?",
                    "AMsg.Num": "7",
                    "_orig_danswer": "DAnswer(CT(\"Script.PC_part0.39\"))"
                },
                {
                    "Name": "",
                    "Pos.x": 960,
                    "Pos.y": 540,
                    "Type": "TDialogAnswer",
                    "Parent": -1,
                    "#": 43,
                    "Msg": "Каким образом я могу повысить свой рейтинг пирата?",
                    "AMsg.Num": "8",
                    "_orig_danswer": "DAnswer(CT(\"Script.PC_part0.40\"))"
                },
                {
                    "Name": "restart",
                    "Pos.x": 1080,
                    "Pos.y": 540,
                    "Type": "TDialogAnswer",
                    "Parent": -1,
                    "#": 44,
                    "Msg": "Все понял. Принимаюсь за дело.",
                    "AMsg.Num": "9",
                    "_orig_danswer": "DAnswer('restart~'+CT(\"Script.PC_part0.41\"))"
                },
                {
                    "Name": "",
                    "Pos.x": 1200,
                    "Pos.y": 540,
                    "Type": "TDialogAnswer",
                    "Parent": -1,
                    "#": 45,
                    "Msg": "Да, уверен!",
                    "AMsg.Num": "10",
                    "_orig_danswer": "DAnswer(CT(\"Script.PC_part0.47\"))"
                },
                {
                    "Name": "",
                    "Pos.x": 1320,
                    "Pos.y": 540,
                    "Type": "TDialogAnswer",
                    "Parent": -1,
                    "#": 46,
                    "Msg": "Ой! Начальник, тут, типа, ошибочка вышла... Я передумал.",
                    "AMsg.Num": "11",
                    "_orig_danswer": "DAnswer(CT(\"Script.PC_part0.84\"))"
                },
                {
                    "Name": "hangar",
                    "Pos.x": 1440,
                    "Pos.y": 540,
                    "Type": "TDialogAnswer",
                    "Parent": -1,
                    "#": 47,
                    "Msg": "Считай, что меня уже здесь нет.",
                    "AMsg.Num": "12",
                    "_orig_danswer": "DAnswer('hangar~'+CT(\"Script.PC_part0.50\"))"
                },
                {
                    "Name": "",
                    "Pos.x": 1560,
                    "Pos.y": 540,
                    "Type": "TDialogAnswer",
                    "Parent": -1,
                    "#": 48,
                    "Msg": "Знаю. Я тогда полетел?",
                    "AMsg.Num": "13",
                    "_orig_danswer": "DAnswer(CT(\"Script.PC_part0.51\"))"
                },
                {
                    "Name": "",
                    "Pos.x": 1680,
                    "Pos.y": 540,
                    "Type": "TDialogAnswer",
                    "Parent": -1,
                    "#": 49,
                    "Msg": "Не знаю.",
                    "AMsg.Num": "14",
                    "_orig_danswer": "DAnswer(CT(\"Script.PC_part0.52\"))"
                },
                {
                    "Name": "restart",
                    "Pos.x": 0,
                    "Pos.y": 565,
                    "Type": "TDialogAnswer",
                    "Parent": -1,
                    "#": 50,
                    "Msg": "Точно!",
                    "AMsg.Num": "15",
                    "_orig_danswer": "DAnswer('restart~'+CT(\"Script.PC_part0.53\"))"
                }
            ],
            "DialogMessages": [
                {
                    "Name": "",
                    "Pos.x": 0,
                    "Pos.y": 445,
                    "Type": "TDialogMsg",
                    "Parent": -1,
                    "#": 21,
                    "Msg": "Как тебе наверно известно, обитатели этого мира делятся на две категории: охотников и дичь. К какой из них ты относишь себя?",
                    "DMsg.Num": "0",
                    "_orig_dtext": "DText(CT(\"Script.PC_part0.21\"))"
                },
                {
                    "Name": "",
                    "Pos.x": 150,
                    "Pos.y": 445,
                    "Type": "TDialogMsg",
                    "Parent": -1,
                    "#": 22,
                    "Msg": "А ты умнее, чем кажешься на первый взгляд. Это хорошо. Наше специальное предложение не для трусливых стадоподобных обывателей. Оно для тех, кто смел, отважен, силен духовно и физически, хорошо владеет разными видами оружия, является отличным пилотом, умеет подчиняться старшим, но при этом готов в любой момент сам стать лидером. От себя добавлю: желательно, чтобы у этого кандидата было все в порядке на \"чердаке\". У идиотов плохие перспективы для карьерного роста в нашем предприятии. \r\nПодумай, соответствуешь ли ты всем этим высоким стандартам?",
                    "DMsg.Num": "1",
                    "_orig_dtext": "DText(CT(\"Script.PC_part0.81\"))"
                },
                {
                    "Name": "",
                    "Pos.x": 300,
                    "Pos.y": 445,
                    "Type": "TDialogMsg",
                    "Parent": -1,
                    "#": 23,
                    "Msg": "Тогда беги отсюда, пока сезон охоты еще не открыт!",
                    "DMsg.Num": "2",
                    "_orig_dtext": "DText(CT(\"Script.PC_part0.24\"))"
                },
                {
                    "Name": "",
                    "Pos.x": 450,
                    "Pos.y": 445,
                    "Type": "TDialogMsg",
                    "Parent": -1,
                    "#": 24,
                    "Msg": "Тогда без лишних сантиментов <clr>предлагаю тебе присоединиться к нашему пиратскому братству<clrEnd>. Конечно, после этого на тебя будут косо смотреть твои сослуживцы и некоторые правители планет. Я уже не говорю про смену приоритетов. На первом месте у тебя всегда должны стоять идеалы нашей организации, а уж потом где-то в конце списка - личные интересы.\r\nЗато подумай о том, что ты получишь взамен. Теперь любая пиратская база станет для тебя родным домом. Ты получишь новые возможности для профессионального и карьерного роста. Тебе откроется новый источник для личного самообогащения. А сколько новых друзей у тебя появится... \r\nРешайся! Но помни: решив однажды присоединиться к нам, ты уже никогда не сможешь \"соскочить\". А за предательство мы караем быстро и беспощадно. Подумай хорошенько, ты точно уверен в том, что хочешь стать одним из нас, то есть - пиратом?",
                    "DMsg.Num": "3",
                    "_orig_dtext": "DText(CT(\"Script.PC_part0.110\"))"
                },
                {
                    "Name": "",
                    "Pos.x": 600,
                    "Pos.y": 445,
                    "Type": "TDialogMsg",
                    "Parent": -1,
                    "#": 25,
                    "Msg": "Тогда вали отсюда, и не трать мое время!",
                    "DMsg.Num": "4",
                    "_orig_dtext": "DText(CT(\"Script.PC_part0.26\"))"
                },
                {
                    "Name": "",
                    "Pos.x": 750,
                    "Pos.y": 445,
                    "Type": "TDialogMsg",
                    "Parent": -1,
                    "#": 26,
                    "Msg": "Тогда ты принят! Поздравляю со вступлением в семью! Тебе присваивается почетное стартовое звание <clr>салаги<clrEnd>. Небольшой <clr>подарок<clrEnd> по этому поводу уже ждет тебя на складе.",
                    "DMsg.Num": "5",
                    "_orig_dtext": "DText(CT(\"Script.PC_part0.115\"))"
                },
                {
                    "Name": "",
                    "Pos.x": 900,
                    "Pos.y": 445,
                    "Type": "TDialogMsg",
                    "Parent": -1,
                    "#": 27,
                    "Msg": "ЧТО? Мне казалось, что ты уже принял решение... Ладно, думай. Охрана, проводите моего собеседника на выход. Постарайтесь не уронить его по дороге. Он еще может нам понадобиться.",
                    "DMsg.Num": "6",
                    "_orig_dtext": "DText(CT(\"Script.PC_part0.111\"))"
                },
                {
                    "Name": "",
                    "Pos.x": 1050,
                    "Pos.y": 445,
                    "Type": "TDialogMsg",
                    "Parent": -1,
                    "#": 28,
                    "Msg": "А чего ты хотел? Ящик вина да фейерверков в свою честь? Извиняй, брателло, не завезли. Залетай через недельку...\r\nВ нашем деле ты - никто! Обычный зеленый новичок, у которого втыкилла на губах еще не обсохла! Типичный салага, который не заслуживает ни доверия, ни уважения. Хочешь это изменить? Тогда покажи, на что способен. Докажи, что действительно являешься истинным пиратом, а не жалкой пародией на благородного корсара. Повысь свой пиратский рейтинг!",
                    "DMsg.Num": "7",
                    "_orig_dtext": "DText(CT(\"Script.PC_part0.112\"))"
                },
                {
                    "Name": "",
                    "Pos.x": 1200,
                    "Pos.y": 445,
                    "Type": "TDialogMsg",
                    "Parent": -1,
                    "#": 29,
                    "Msg": "Вот наш прейскурант:\r\n<0>",
                    "DMsg.Num": "8",
                    "_orig_dtext": "DText(Format(CT(\"Script.PC_part0.119\"),\"<0>\",points))"
                },
                {
                    "Name": "",
                    "Pos.x": 1350,
                    "Pos.y": 445,
                    "Type": "TDialogMsg",
                    "Parent": -1,
                    "#": 30,
                    "Msg": "Просто для проформы спрошу: ты уверен, что хочешь присоединиться к нам и стать настоящим пиратом, а не мелким хулиганом из утилизатора?",
                    "DMsg.Num": "9",
                    "_orig_dtext": "DText(CT(\"Script.PC_part0.42\"))"
                },
                {
                    "Name": "",
                    "Pos.x": 1500,
                    "Pos.y": 445,
                    "Type": "TDialogMsg",
                    "Parent": -1,
                    "#": 31,
                    "Msg": "Все, ты принят. Поздравляю! Тебе присваивается почетное стартовое звание салаги. Небольшой подарок по этому поводу уже ждет тебя на складе. Что дальше делать, знаешь?",
                    "DMsg.Num": "10",
                    "_orig_dtext": "DText(CT(\"Script.PC_part0.43\"))"
                },
                {
                    "Name": "",
                    "Pos.x": 1650,
                    "Pos.y": 445,
                    "Type": "TDialogMsg",
                    "Parent": -1,
                    "#": 32,
                    "Msg": "Ну и лети отсюда, неженка! А еще пирата из себя изображает...",
                    "DMsg.Num": "11",
                    "_orig_dtext": "DText(CT(\"Script.PC_part0.44\"))"
                },
                {
                    "Name": "",
                    "Pos.x": 0,
                    "Pos.y": 470,
                    "Type": "TDialogMsg",
                    "Parent": -1,
                    "#": 33,
                    "Msg": "Вот это по-нашему! Оформился  и за дело! Пускай теперь дрожат все жизненно важные места у торгашей и прочих обывателей!",
                    "DMsg.Num": "12",
                    "_orig_dtext": "DText(CT(\"Script.PC_part0.114\"))"
                },
                {
                    "Name": "",
                    "Pos.x": 150,
                    "Pos.y": 470,
                    "Type": "TDialogMsg",
                    "Parent": -1,
                    "#": 34,
                    "Msg": "Чтобы стать кем-то уважаемым в нашей среде, тебе нужно показать себя, подтвердить свою репутацию.  А для этого надо поработать на благо нашего братства, повышать свой рейтинг. Тогда мы про тебя тоже не забудем.",
                    "DMsg.Num": "13",
                    "_orig_dtext": "DText(CT(\"Script.PC_part0.46\"))"
                }
            ],
