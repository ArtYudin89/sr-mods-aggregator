                    "#": 70,
                    "Type": "Top",
                    "Parent": -1,
                    "Pos.x": 460,
                    "Pos.y": 540
                },
                {
                    "Name": "",
                    "Code.Type": "Turn",
                    "Code": [
                        "ShipJoinsClan(Player());",
                        "ShipType(Player(),'RangerPiratePlayer');",
                        "hull_gift=CreateQuestItem('ExpTraitors_PirateParrot');",
                        "ItemSize(hull_gift,1);",
                        "UselessItemData(hull_gift,1,0);",
                        "UselessItemData(hull_gift,2,1);",
                        "UselessItemData(hull_gift,3,-2);",
                        "AddItemToStorage(GetShipRuins(Player()),hull_gift);",
                        "",
                        "//Сразу проваливаем задание флагмана из мода ExpAcryn, если игрок уже успел его взять",
                        "if(IsScriptActive('Mod_ExpAcryn'))",
                        "{",
                        "    //Игрок взял задание у флагмана, а потом вступил в пиратский клан - все задания провалены до конца партии",
                        "    if(ExpAcrynQuestStatus<6)",
                        "    {",
                        "\t\tif(EtherState('ExpAcryn_quest_'+ExpAcrynQuestStatus)>-1)",
                        "\t\t{",
                        "\t\t\tif(GetValueFromScript('Mod_ExpAcryn','fl_array',ExpAcrynQuestStatus,1)==1)points='';",
                        "\t\t\telse points='2';",
                        "\t\t\tif(ExpAcrynQuestStatus==0)Ether(5,'ExpAcryn_quest_0',CT('Script.Mod_ExpAcryn.MissionFailed')+Format(CT('Script.Mod_ExpAcryn.MalocMission'+points),'#ItemName#',GetValueFromScript('Mod_ExpAcryn','addItemName')));",
                        "\t\t\telse if(ExpAcrynQuestStatus==1)Ether(5,'ExpAcryn_quest_1',CT('Script.Mod_ExpAcryn.MissionFailed')+Format(CT('Script.Mod_ExpAcryn.PelengMission'+points),'#ItemName#',GetValueFromScript('Mod_ExpAcryn','addItemName')));",
                        "\t\t\telse if(ExpAcrynQuestStatus==2)",
                        "            {",
                        "                Ether(5,'ExpAcryn_quest_2',CT('Script.Mod_ExpAcryn.MissionFailed')+Format(CT('Script.Mod_ExpAcryn.PeopleMission'+points),'#ItemName#',GetValueFromScript('Mod_ExpAcryn','addItemName')));",
                        "                ShipDeleteCustomShipInfo(Player(),'ExpAcryn_mimi_player_infos');",
                        "            }",
                        "            else if(ExpAcrynQuestStatus==3)Ether(5,'ExpAcryn_quest_3',CT('Script.Mod_ExpAcryn.MissionFailed')+Format(CT('Script.Mod_ExpAcryn.FeiMission'+points),'#ItemName#',GetValueFromScript('Mod_ExpAcryn','addItemName')));",
                        "\t\t\telse if(ExpAcrynQuestStatus==4)Ether(5,'ExpAcryn_quest_4',CT('Script.Mod_ExpAcryn.MissionFailed')+Format(CT('Script.Mod_ExpAcryn.GaalMission'+points),'#ItemName#',GetValueFromScript('Mod_ExpAcryn','addItemName')));",
                        "\t\t}",
                        "\t\t//Также понижаем его репутацию на всех планетах соответствующей расы",
                        "\t\tfor(i=0;i<GalaxyStars();i=i+1)",
                        "\t\t{",
                        "\t\t\thull_gift=GalaxyStar(i);",
                        "\t\t\tif(StarOwner(hull_gift)!=0)continue;",
                        "\t\t\tfor(j=0;j<StarPlanets(hull_gift);j=j+1)",
                        "\t\t\t{",
                        "\t\t\t\ttemp_dwd=StarPlanets(hull_gift,j);",
                        "\t\t\t\tif(PlanetOwner(temp_dwd)!=ExpAcrynQuestStatus)continue;",
                        "\t\t\t\tRelationToRanger(temp_dwd,Player(),RelationToRanger(temp_dwd,Player())-30);",
                        "\t\t\t\tif(RelationToRanger(temp_dwd,Player())<10)RelationToRanger(temp_dwd,Player(),10);",
                        "\t\t\t}",
                        "\t\t}",
                        "        ReleaseItemFromScript(GetValueFromScript('Mod_ExpAcryn','Q_item'));",
                        "\t    ExpAcrynQuestStatus=7;",
                        "    }",
                        "}",
                        "points='';",
                        "hull_gift=0;",
                        "temp_dwd=0;",
                        "DChange(5);",
                        "exit;"
                    ],
                    "#": 71,
                    "Type": "Top",
                    "Parent": -1,
                    "Pos.x": 580,
                    "Pos.y": 540
                },
