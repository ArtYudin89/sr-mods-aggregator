                        "                        if(tempDwd3!=PlanetPirateClan())TextCorr8='<color=45,105,45>'+CT('Talk.Tranclucator.Options.LandYes')+'</color> <color=0,50,200>'+CT('Talk.Tranclucator.Options.ToPlanet')+' '+PlanetName(tempDwd3)+'</color>';",
                        "                        else TextCorr8='<color=45,105,45>'+CT('Talk.Tranclucator.Options.LandYes')+'</color> <color=0,50,200>'+CT('Talk.Tranclucator.Options.ToPiratePlanet')+'</color>';",
                        "",
                        "                    }",
