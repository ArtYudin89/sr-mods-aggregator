                    "#": 184,
                    "Type": "Top",
                    "Parent": -1,
                    "Pos.x": 310,
                    "Pos.y": 525
                },
                {
                    "Name": "",
                    "Code.Type": "Turn",
                    "Code": [
                        "tempDwd=GAnswerData;",
                        "tempDwd2=GetShipRuins(Player());",
                        "temp_int_6=-1;",
                        "if(EqModule(tempDwd)>-1)",
                        "{",
                        "    temp_int_6=EqModule(tempDwd);",
                        "    EqModule(tempDwd,-1);",
                        "}",
                        "TextCorr=DeleteTags(Name(tempDwd));",
                        "if(temp_int_6>-1)EqModule(tempDwd,temp_int_6);",
                        "temp_int_3=0;",
                        "//Стоимость в кредитах",
                        "temp_int=round(0.5*ItemCost(tempDwd));",
                        "if(ItemOwner(tempDwd)!=5 && EqCustomFaction(tempDwd)!='Klissan')",
                        "{",
                        "    //Вычитаем стоимость в кредитах",
                        "    ShipMoney(Player(),ShipMoney(Player())-temp_int);",
                        "}",
                        "else if(EqCustomFaction(tempDwd)=='Klissan')",
                        "{",
                        "    //Вычитаем стоимость в кредитах",
                        "    ShipMoney(Player(),ShipMoney(Player())-temp_int);",
                        "    //Вычитаем стоимость в протоплазме",
                        "    temp_int_2=round(1.0*temp_int/100);",
                        "    for(i=0;i<ShipItems(Player());i=i+1)",
                        "    {",
                        "        cur_item=ShipItems(Player(),i);",
                        "        if(ItemType(cur_item)==t_UselessCountableItem)",
                        "        {",
                        "            if(EquipmentImageName(cur_item)=='kProtoplasm')",
                        "            {",
                        "                if(ItemSize(cur_item)>temp_int_2)",
                        "                {",
                        "                    ItemSize(cur_item,ItemSize(cur_item)-temp_int_2);",
                        "                    temp_int_2=0;",
                        "                }",
                        "                else",
                        "                {",
                        "                    temp_int_2=temp_int_2-ItemSize(cur_item);",
                        "                    FreeItem(GetItemFromShip(Player(),i));",
                        "                }",
                        "            }",
                        "        }",
                        "        if(!temp_int_2)break;",
                        "    }",
                        "    if(temp_int_2)while(temp_int_2)",
                        "    {",
                        "        cur_item=StorageItems(temp_int_3);",
                        "        if(StorageItemLocation(temp_int_3)==tempDwd2)",
                        "        {",
                        "            if(ItemType(cur_item)==t_UselessCountableItem)",
                        "            {",
                        "                if(EquipmentImageName(cur_item)=='kProtoplasm')",
                        "                {",
                        "                    if(ItemSize(cur_item)>temp_int_2)",
                        "                    {",
                        "                        ItemSize(cur_item,ItemSize(cur_item)-temp_int_2);",
                        "                        temp_int_2=0;",
                        "                    }",
                        "                    else",
                        "                    {",
                        "                        temp_int_2=temp_int_2-ItemSize(cur_item);",
                        "                        FreeItem(GetItemFromStorage(temp_int_3));",
                        "                        //Откатываем счётчик, чтобы позволить скрипту ещё раз пройтись по номеру удалённой вещи",
                        "                        temp_int_3=temp_int_3-1;",
                        "                    }",
                        "                }",
                        "            }",
                        "        }",
                        "        temp_int_3=temp_int_3+1;",
                        "    }",
                        "}",
                        "else",
                        "{",
                        "    //Вычитаем стоимость в кредитах",
                        "    ShipMoney(Player(),ShipMoney(Player())-temp_int);",
                        "    //Стоимость в нодах",
                        "    temp_int_2=round(1.0*temp_int/100);",
                        "    if(temp_int_2>GetNodesFromShip(Player()))",
                        "    {",
                        "        temp_int_2=temp_int_2-GetNodesFromShip(Player());",
                        "        GetNodesFromShip(Player(),GetNodesFromShip(Player()));",
                        "        GetNodesFromStorage(tempDwd2,temp_int_2);",
                        "    }",
                        "    else GetNodesFromShip(Player(),temp_int_2);",
                        "}",
                        "ItemSize(tempDwd,ItemSize(tempDwd)/2);",
                        "//Вещь не должна получится легче одной тонны, ни при каких условиях",
                        "if(!ItemSize(tempDwd))ItemSize(tempDwd,1);",
                        "//Добавляем быстро изнашивающий вещь спецакрин",
                        "if(ItemType(tempDwd)>=t_FuelTanks && ItemType(tempDwd)<=t_DefGenerator)ItemExtraSpecialsAddByType(tempDwd,FindBonusByCustomTag('EvoTranc_TrancItemAcrin'),1);",
                        "else ItemExtraSpecialsAddByType(tempDwd,FindBonusByCustomTag('EvoTranc_TrancWeaponAcrin'),1);",
                        "temp_int_6=-1;",
                        "if(EqModule(tempDwd)>-1)",
                        "{",
                        "    temp_int_6=EqModule(tempDwd);",
                        "    EqModule(tempDwd,-1);",
                        "}",
                        "SetName(tempDwd,Name(tempDwd)+CT('Script.Mod_EvoTranc.ForTrancs'));",
                        "if(temp_int_6>-1)EqModule(tempDwd,temp_int_6);",
                        "Sound('Sound.Repair');",
                        "if(findsubstr(Name(tempDwd),CT(\"Script.Mod_EvoTranc.697\"))>-1 || findsubstr(Name(tempDwd),CT(\"Script.Mod_EvoTranc.696\"))>-1 || findsubstr(Name(tempDwd),CT(\"Script.Mod_EvoTranc.695\"))>-1)TextCorr3='</color>'+Format(CT(\"Script.Mod_EvoTranc.694\"),\"<0>\",TextCorr,\"<1>\",ItemSize(tempDwd));",
                        "else if(findsubstr(Name(tempDwd),CT(\"Script.Mod_EvoTranc.693\"))>-1 || findsubstr(Name(tempDwd),CT(\"Script.Mod_EvoTranc.692\"))>-1 || findsubstr(Name(tempDwd),CT(\"Script.Mod_EvoTranc.691\"))>-1)TextCorr3='</color>'+Format(CT(\"Script.Mod_EvoTranc.690\"),\"<0>\",TextCorr,\"<1>\",ItemSize(tempDwd));",
                        "else TextCorr3='</color>'+Format(CT(\"Script.Mod_EvoTranc.689\"),\"<0>\",TextCorr,\"<1>\",ItemSize(tempDwd));",
                        "if(ArrayDim(items)>2 || ArrayDim(items2)>2 || (ArrayDim(items)==2 && ArrayDim(items2)==2))TextCorr11='</color>'+Format(CT(\"Script.Mod_EvoTranc.872\"),\"<0>\",TextCorr3)+CT(\"Script.Mod_EvoTranc.86\")+CT(\"Script.Mod_EvoTranc.873\");",
                        "else TextCorr11='</color>'+Format(CT(\"Script.Mod_EvoTranc.872\"),\"<0>\",TextCorr3)+CT(\"Script.Mod_EvoTranc.86\")+CT(\"Script.Mod_EvoTranc.875\");",
                        "DChange(15);",
                        "exit;"
                    ],
