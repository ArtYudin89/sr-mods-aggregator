                        "    if(temp_int)temp_str=temp_str+CT(\"Script.Mod_EvoTranc.86\");",
                        "    temp_int=temp_int+1;",
                        "    if(ShipCustomShipInfoTextData(cur_Tranc,temp_int_2,3)=='Lock')",
                        "    {",
                        "        temp_str=temp_str+temp_int+CT(\"Script.Mod_EvoTranc.563\");",
                        "        TextCorr3='<color=45,105,45>'+CT(\"Script.Mod_EvoTranc.583\");",
                        "    }",
                        "    else",
                        "    {",
                        "        temp_str=temp_str+temp_int+CT(\"Script.Mod_EvoTranc.562\");",
                        "        TextCorr3='<color=255,0,0>'+CT(\"Script.Mod_EvoTranc.582\");",
                        "    }",
                        "}",
                        "if(ShipFindCustomShipInfoByType(cur_Tranc,'TrancInvincibilityInfo')>-1)",
                        "{",
                        "    temp_int_2=ShipFindCustomShipInfoByType(cur_Tranc,'TrancInvincibilityInfo');",
                        "    if(temp_int)temp_str=temp_str+CT(\"Script.Mod_EvoTranc.86\");",
                        "    temp_int=temp_int+1;",
                        "    if(ShipCustomShipInfoTextData(cur_Tranc,temp_int_2,3)=='Lock')",
                        "    {",
                        "        temp_str=temp_str+temp_int+CT(\"Script.Mod_EvoTranc.561\");",
                        "        TextCorr4='<color=45,105,45>'+CT(\"Script.Mod_EvoTranc.581\");",
                        "    }",
                        "    else",
