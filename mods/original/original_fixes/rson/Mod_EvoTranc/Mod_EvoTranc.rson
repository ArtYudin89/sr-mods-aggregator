                    "Pos.x": 100,
                    "Pos.y": 550
                },
                {
                    "Name": "",
                    "Code.Type": "Turn",
                    "Code": [
                        "temp_int_4=Rnd(1,3);",
                        "if(temp_int_4==1)TextCorr='</color>'+Format(CT(\"Script.Mod_EvoTranc.837\"),\"<0>\",ShipName(tempDwd));",
                        "else if(temp_int_4==2)TextCorr='</color>'+Format(CT(\"Script.Mod_EvoTranc.841\"),\"<0>\",ShipName(tempDwd),\"<1>\",substr(0.0001*(10-ItemLevel(ShipItems(cur_Tranc,0))),0,6));",
                        "else TextCorr='</color>'+Format(CT(\"Script.Mod_EvoTranc.843\"),\"<0>\",ShipName(tempDwd));",
                        "DChange(31);",
                        "exit;"
                    ],
                    "#": 195,
