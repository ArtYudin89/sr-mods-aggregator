                    "Parent": -1,
                    "Pos.x": 610,
                    "Pos.y": 400
                },
                {
                    "Name": "",
                    "Code.Type": "Turn",
                    "Code": [
                        "if(ShipMoney(Player()) >= cost_sponsor && (GetNodesFromStorage(GetShipRuins(Player())) >= cost_sponsor_node || GetNodesFromShip(Player()) >= cost_sponsor_node)) {",
                        "  DAdd(7);",
                        "}",
                        "DAdd(8);"
                    ],
                    "#": 50,
                    "Type": "Top",
                    "Parent": -1,
                    "Pos.x": -20,
                    "Pos.y": 470
                },
                {
                    "Name": "",
                    "Code.Type": "Turn",
                    "Code": [
                        "ShipMoney(Player(), ShipMoney(Player()) - cost);",
                        "Sound('Sound.Buy');",
                        "state = 4;",
                        "",
                        "hull = CreateHull(",
                        "    2,",
                        "    hull_size_good,",
                        "    GalaxyTechLevel(),",
                        "    None,",
                        "    -1,",
                        "    0",
                        ");",
                        "int bonus_num = FindBonusByName(good_special_name);",
                        "if (bonus_num > -1) {",
                        "    SpecialToEquipment(bonus_num, hull);",
                        "} else {",
                        "    SFT('[Cat_StarWanderer] Акрин '+good_special_name+' не найден. Возможны дальнейшие проблемы');",
                        "}",
                        "",
                        "ItemSize(hull, hull_size_good);",
                        "ItemCost(hull, hull_cost_1);",
                        "HullHP(hull, ItemSize(hull));",
                        "AddItemToStorage(GetShipRuins(Player()), hull);",
                        "LinkItemToScript(hull, hull_good);",
                        "CanSellItem(hull_good, 0);",
                        "DAdd(0);"
                    ],
