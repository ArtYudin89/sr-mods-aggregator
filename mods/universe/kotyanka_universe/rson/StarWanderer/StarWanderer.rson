                    ],
                    "#": 59,
                    "Type": "Top",
                    "Parent": -1,
                    "Pos.x": 460,
                    "Pos.y": 540
                },
                {
                    "Name": "",
                    "Code.Type": "Turn",
                    "Code": [
                        "ShipMoney(Player(), ShipMoney(Player()) - cost_sponsor);",
                        "if(GetNodesFromShip(Player())>=cost_sponsor_node) GetNodesFromShip(Player(), cost_sponsor_node);",
                        "else GetNodesFromStorage(GetShipRuins(Player()), cost_sponsor_node);",
                        "Sound('Sound.Buy');",
                        "research_time = Rnd(0.8 * research_time_fast, 1.2 * research_time_fast);",
                        "base_id = Id(GetShipRuins(Player()));",
                        "base_name = ShipName(GetShipRuins(Player()));",
                        "research_start_date = CurTurn();",
                        "",
                        "state = 1;",
                        "DChange(7);",
                        "exit;"
                    ],
