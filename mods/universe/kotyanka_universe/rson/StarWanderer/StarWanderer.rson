            "Operations": [
                {
                    "Name": "",
                    "Code.Type": "Global",
                    "Code": [
                        "if(ShipRank(Player()) >= 4) {",
                        "  GRun();",
                        "}"
                    ],
                    "#": 18,
                    "Type": "Top",
                    "Parent": -1,
                    "Pos.x": 0,
                    "Pos.y": 610
                },
                {
                    "Name": "",
                    "Code.Type": "Init",
                    "Code": [
                        "good_special_name = CT('Script.StarWanderer.Settings.good_special_name');",
                        "",
                        "hull_cost_1 = CT('Script.StarWanderer.Settings.hull_cost_1');",
                        "",
                        "hull_size_good = CT('Script.StarWanderer.Settings.hull_size_good');",
                        "",
                        "research_time_fast = CT('Script.StarWanderer.Settings.research_time_fast');"
                    ],
                    "#": 19,
                    "Type": "Top",
                    "Parent": -1,
                    "Pos.x": 60,
                    "Pos.y": 610
                },
                {
                    "Name": "",
                    "Code.Type": "Turn",
                    "Code": [
                        "if(state == 1) {",
                        "  if(CurTurn() >= research_start_date + research_time) {",
                        "    if(IdToShip(base_id)) {",
                        "      Ether(0, '', Format(CT(\"Script.StarWanderer.188\"),\"<0>\",base_name));",
                        "      state = 2;",
                        "    }",
                        "  }",
                        "  if(!IdToShip(base_id)) {",
                        "    Ether(0, '', Format(CT(\"Script.StarWanderer.187\"),\"<0>\",base_name));",
                        "    state = -1;",
                        "  }",
                        "}"
                    ],
                    "#": 20,
                    "Type": "Top",
                    "Parent": -1,
                    "Pos.x": 120,
                    "Pos.y": 610
                },
                {
                    "Name": "",
                    "Code.Type": "DialogBegin",
                    "Code": [
                        "if(!PlayerBridge()) {",
                        "  if(GetShipRuins(Player())) {",
                        "    if(state == 0) {",
                        "      if(ShipType(GetShipRuins(Player())) == 'SB') {",
                        "        AddDialogInject('DialogSB1', '', CT(\"Script.StarWanderer.205\"), 1);",
                        "      }",
                        "    }",
                        "    if(state == 1) {",
                        "      if(Id(GetShipRuins(Player())) == base_id) {",
                        "        AddDialogInject('DialogSB1.5', '', CT(\"Script.StarWanderer.189\"), 1);",
                        "      }",
                        "      if(Id(GetShipRuins(Player())) != base_id) {",
                        "        if(ShipType(GetShipRuins(Player())) == 'SB') {",
                        "          AddDialogInject('WrongBase1.5', '', CT(\"Script.StarWanderer.189\"), 1);",
                        "        }",
                        "      }",
                        "    }",
                        "    if(state == 2) {",
                        "      if(Id(GetShipRuins(Player())) == base_id) {",
                        "        AddDialogInject('DialogSB2', '', CT(\"Script.StarWanderer.189\"), 1);",
                        "      }",
                        "      if(Id(GetShipRuins(Player())) != base_id) {",
                        "        if(ShipType(GetShipRuins(Player())) == 'SB') {",
                        "          AddDialogInject('WrongBase2', '', CT(\"Script.StarWanderer.189\"), 1);",
                        "        }",
                        "      }",
                        "    }",
                        "  }",
                        "}"
                    ],
                    "#": 21,
                    "Type": "Top",
                    "Parent": -1,
                    "Pos.x": 180,
                    "Pos.y": 610
                },
