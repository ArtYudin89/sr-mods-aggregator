                {
                    "Name": "restart",
                    "Pos.x": 0,
                    "Pos.y": 515,
                    "Type": "TDialogAnswer",
                    "Parent": -1,
                    "#": 12,
                    "Msg": "Ну-ка, давай посмотрим, на чём он там летал.",
                    "AMsg.Num": "0",
                    "_orig_danswer": "DAnswer('restart~'+CT(\"Script.Excalibur.189\"))"
                }
            ],
            "DialogMessages": [
                {
                    "Name": "",
                    "Pos.x": 0,
                    "Pos.y": 445,
                    "Type": "TDialogMsg",
                    "Parent": -1,
                    "#": 11,
                    "Msg": "Та-а-а-акс...\r\n\r\nПолучается, ты теперь Верховный барон, верно?\r\nЯ был главным советником и правой рукой у прежнего барона.\r\nОн позаботился о распоряжениях на случай его смерти, так что вот - это ключи от его личного корабля, теперь они ваши, равно как и корабль.",
                    "DMsg.Num": "0",
                    "_orig_dtext": "DText(CT(\"Script.Excalibur.188\"))"
                }
            ],
            "Dialogs": [
                {
                    "Name": "GetHull",
                    "Type": "TDialog",
                    "Pos.x": 0,
                    "Pos.y": 375,
                    "Parent": -1,
                    "#": 10
                }
            ],
