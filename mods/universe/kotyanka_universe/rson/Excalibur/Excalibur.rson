                    "Code": [
                        "GRun();"
                    ],
                    "#": 7,
                    "Type": "Top",
                    "Parent": -1,
                    "Pos.x": 0,
                    "Pos.y": 585
                },
                {
                    "Name": "",
                    "Code.Type": "DialogBegin",
                    "Code": [
                        "if(state==1) {",
                        "  if(PirateWin()==1 || PirateWin()==2 || PirateWin()==5) {",
                        "    curPlanet=GetShipPlanet(Player());",
                        "    if(curPlanet) {",
                        "        if(curPlanet==PlanetPirateClan()) {",
                        "            if(PlanetOwner(PlanetPirateClan())==PirateClan) {",
                        "                if(ShipOwner(Player())==PirateClan && GetShipPirateRank(Player())>=7) {",
                        "                    AddDialogOverride('GetHull',23);",
                        "                }",
                        "            }",
                        "        }",
                        "    }",
                        "  }",
                        "}"
                    ],
                    "#": 8,
                    "Type": "Top",
                    "Parent": -1,
                    "Pos.x": 180,
                    "Pos.y": 585
                },
                {
                    "Name": "",
                    "Code.Type": "Turn",
                    "Code": [
                        "DChange(0);",
                        "exit;"
                    ],
                    "#": 13,
                    "Type": "Top",
                    "Parent": -1,
                    "Pos.x": -20,
                    "Pos.y": 375
                },
                {
                    "Name": "",
                    "Code.Type": "Turn",
                    "Code": [
                        "DAdd(0);"
                    ],
                    "#": 14,
                    "Type": "Top",
                    "Parent": -1,
                    "Pos.x": -20,
                    "Pos.y": 445
                },
                {
                    "Name": "",
                    "Code.Type": "Turn",
                    "Code": [
                        "hull = CreateHull(",
                        "    2,",
                        "    500,",
                        "    GalaxyTechLevel(),",
                        "    People,",
                        "    -1,",
                        "    1",
                        ");",
                        "int bonus_num = FindBonusByName('Экскалибур');",
                        "SpecialToEquipment(bonus_num, hull);",
                        "ItemSize(hull, 500);",
                        "ItemCost(hull, 1000000);",
                        "HullHP(hull, 500);",
                        "AddItemToStorage(GetShipPlanet(Player()), hull);",
                        "CanSellItem(hull, 0);",
                        "state=2;"
                    ],
                    "#": 15,
                    "Type": "Top",
                    "Parent": -1,
                    "Pos.x": -20,
                    "Pos.y": 515
                }
