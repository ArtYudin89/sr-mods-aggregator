            "Operations": [
                {
                    "Name": "",
                    "Code.Type": "Global",
                    "Code": [
                        "if(",
                        "    !IsScriptActive('Mod_ExpPilotBridge') ||",
                        "    !IsScriptActive('Mod_ExpArts') ||",
                        "    !IsScriptActive('Mod_ExpAcryn') ||",
                        "    !IsScriptActive('Mod_ExpTC') ||",
                        "    !IsScriptActive('Mod_ExpScienceRanks') ||",
                        "    !IsScriptActive('Mod_EvoSB')",
                        ") exit;",
                        "if(CurrentMods('OtherMods\\\\ArtiUniqueShipsPackPlus') && !IsScriptActive('Mod_EvoArmada')) exit;",
                        "",
                        "GRun();"
                    ],
                    "#": 65,
                    "Type": "Top",
                    "Parent": -1,
                    "Pos.x": 0,
                    "Pos.y": 985
                },
                {
                    "Name": "",
                    "Code.Type": "Init",
                    "Code": [
                        "//Стартовый перебор с запоминанием числа доминионов в Галактике",
                        "for(i = 0; i < GalaxyStars(); i = i + 1)",
                        "{",
                        "    cur_star = GalaxyStar(i);",
                        "    if(StarRuins(cur_star, 'PB')) TotalPBCount = TotalPBCount + 1;",
                        "    if(StarRuins(cur_star, 'CB')) TotalCBCount = TotalCBCount + 1;",
                        "}"
                    ],
                    "#": 66,
                    "Type": "Top",
                    "Parent": -1,
                    "Pos.x": 60,
                    "Pos.y": 985
                },
                {
                    "Name": "",
                    "Code.Type": "Turn",
                    "Code": [
                        "if(!ShipIsTakeoff(Player())) {",
                        "  //Значения переменной ArtimisEventStatus:",
                        "  //-3 - событие завершилось уничтожением сферы, получением корпуса, либо уничтожением ТЦ, на котором изучали сферу;",
                        "  //-2 - стартовое значение переменной, скрипт запущен, но условия для закапывания сферы ещё не выполнены;",
                        "  //-1 - игрок засел на какой-то планете, ждём пока взлетит;",
                        "  //(5 или выше ГТУ, научное звание не ниже кандидата наук и 30 полностью исследованных незаселёнок, также необходимо находиться на расстоянии не ближе 50 парсек от родной системы)",
                        "  // 0 - сфера была закопана и ждёт игрока на планете, либо уже раскопана игроком и должна быть доставлена в ТЦ;",
                        "  // 1+ - сфера сдана на ЦР и начата постройка корпуса, значение переменной превращается в таймер (CurTurn() + N) вплоть до завершения постройки;",
                        "  if(ArtimisEventStatus == -2 || ArtimisEventStatus == -1)",
                        "  {",
                        "  \tif(ArtimisEventStatus == -2)",
                        "  \t{",
                        "  \t\tif(GalaxyTechLevel() >= 5)",
                        "  \t\t{",
                        "  \t\t    cur_planet = GetShipPlanet(Player());",
                        "  \t\t\tif(cur_planet)",
                        "  \t\t\t{",
                        "                  //Ставим маркер о посещении планеты игроком, чтобы не перепроверять её по 100500 раз, пока игрок сидит и скипает ходы",
                        "                  ArtimisEventStatus = -1;",
                        "  ",
                        "                  //Если игрок сел именно на незаселёнку",
                        "  \t\t\t\tif(PlanetOwner(cur_planet) == 6)",
                        "  \t\t\t\t{",
                        "  \t\t\t        //Научное звание не ниже кандидата наук",
                        "  \t\t\t\t\tif(PlayerScienceRank['CurrentRank'] >= 5)",
                        "  \t\t\t\t\t{",
                        "  \t\t\t\t        //Полностью исследовано не менее 30 незаселёнок",
                        "  \t\t\t\t\t\tif(GetValueFromScript('Mod_EvoSB', 'UninhabitedPlanetsExplored') >= 20)",
                        "  \t\t\t\t\t\t{",
                        "  \t\t\t\t\t\t\t//Если расстояние до родной системы составляет не менее 50 парсек",
                        "  \t\t\t\t\t\t\tif(sqrt(Dist2Star(PlanetToStar(cur_planet), PlanetToStar(GetShipHomePlanet(Player())))) >= 50)",
                        "  \t\t\t\t\t\t\t{",
                        "  \t\t\t\t\t\t\t\t//Проверяем, полностью ли исследована незаселённая планета (должна быть не полностью)",
                        "  \t\t\t\t\t\t\t\tif(PlanetTerrain(cur_planet, 0) != PlanetTerrainExplored(cur_planet, 0) || PlanetTerrain(cur_planet, 1) != PlanetTerrainExplored(cur_planet, 1) || PlanetTerrain(cur_planet, 2) != PlanetTerrainExplored(cur_planet, 2))",
                        "  \t\t\t\t\t\t\t\t{",
                        "  \t\t\t\t\t\t\t\t\t//С некоторым шансом прячем сферу на планете",
                        "  \t\t\t\t\t\t\t\t\tif(Rnd(1, 100) <= 75)",
                        "  \t\t\t\t\t\t\t\t\t{",
                        "  \t\t\t\t\t\t\t\t\t\tcur_item = CreateQuestItem('ArtiUniqueShipsPack_UnknownSphere', 6);",
                        "  \t\t\t\t\t\t\t\t\t\tCanSellItem(cur_item, 1);",
                        "  \t\t\t\t\t\t\t\t\t\tAddItemToPlanet(cur_planet, cur_item);",
                        "  \t\t\t\t\t\t\t\t\t\t//Заносим сферу в скрипт",
                        "  \t\t\t\t\t\t\t\t\t\tLinkItemToScript(cur_item, UnknownSphere);",
                        "  \t\t\t\t\t\t\t\t\t\t//И вешаем на неё акткод, который завершит квест в случае уничтожения (в том числе и продажи) сферы",
                        "  \t\t\t\t\t\t\t\t\t\tItemOnActCode(cur_item, 'if(ScriptItemActionType(t_OnItemDestroy)) ArtimisEventStatus = -3;');",
                        "  ",
                        "  \t\t\t\t\t\t\t\t\t\t//Обновляем статус квеста по поиску корпуса",
                        "  \t\t\t\t\t\t\t\t\t\tArtimisEventStatus = 0;",
                        "  \t\t\t\t\t\t\t\t\t}",
                        "  \t\t\t\t\t\t\t\t}",
                        "  \t\t\t\t\t\t\t}",
                        "  \t\t\t\t\t\t}",
                        "  \t\t\t\t\t}",
                        "  \t\t\t\t}",
                        "  \t\t\t}",
                        "  \t\t}",
                        "  \t}",
                        "  \telse if(ShipInNormalSpace(Player())) ArtimisEventStatus = -2;",
                        "  }",
                        "  //Завершаем квест если ТЦ, на который игрок стал сферу, был уничтожен",
                        "  else if(ArtimisEventStatus > 0)",
                        "  {",
                        "      cur_ruin = IdToShip(ArtimisStationId);",
                        "      if(!cur_ruin) ArtimisEventStatus = -2;",
                        "      else if(ArtimisEventStatus == CurTurn()) NewsAdd(Format(CT('Script.Mod_ArtiUniqueShipsPack.ArtimisHullReadyEther'), '<Base' + '>', ShipName(cur_ruin), '<Star' + '>', Name(ShipStar(cur_ruin))));",
                        "  }",
                        "  ",
                        "  //Перебираем все последние галактические эвенты, ловим события уничтожения дредноутов игроком",
                        "  for(i = GalaxyEvents() - 1; i >= 0; i = i - 1)",
                        "  {",
                        "  \tif(GalaxyEventDate(i) < CurTurn()) break;",
                        "  ",
                        "      tstr1 = GalaxyEventType(i);",
                        "  \tif(tstr1 == 'RuinsCreated')",
                        "  \t{",
                        "          tint1 = GalaxyEventData(i, 0);",
                        "          if(tint1 == t_PB)",
                        "          {",
                        "              if(GalaxyEventsTextData(i, 1) == '') TotalPBCount = TotalPBCount + 1;",
                        "          }",
                        "          else if(tint1 == t_CB)",
                        "          {",
                        "              if(GalaxyEventsTextData(i, 1) == '') TotalCBCount = TotalCBCount + 1;",
                        "          }",
                        "      }",
                        "      else if(tstr1 == 'RuinsDestroyed')",
                        "  \t{",
                        "          tint1 = GalaxyEventData(i, 0);",
                        "          if(tint1 == t_PB)",
                        "          {",
                        "              if(GalaxyEventsTextData(i, 1) == '') TotalPBCount = max(TotalPBCount - 1, 0);",
                        "          }",
                        "          else if(tint1 == t_CB)",
                        "          {",
                        "              if(GalaxyEventsTextData(i, 1) == '') TotalCBCount = max(TotalCBCount - 1, 0);",
                        "          }",
                        "      }",
                        "  }",
                        "  ",
                        "  //Отметка, что игрок первый раз попал в список рейнджеров как \"Отличившийся воин\"",
                        "  if(!EminentWarrior)",
                        "  {",
                        "      if(RangerStatus(Player(), 'EminentWarrior')) EminentWarrior = 1;",
                        "  }",
                        "  ",
                        "  //Считаем число дней подряд, когда торговый рейтинг игрока выше или равен 90",
                        "  if(!AscalonWasBought)",
                        "  {",
                        "      if(ShipStatus(Player(), 0) >= CT('Script.Mod_ArtiUniqueShipsPack.AscalonParamsList.TradeRatingToHold'))",
                        "      {",
                        "          AscalonDaysOfHighTrade = AscalonDaysOfHighTrade + 1;",
                        "      }",
                        "      else AscalonDaysOfHighTrade = 0;",
                        "  }",
                        "}"
                    ],
                    "#": 67,
                    "Type": "Top",
                    "Parent": -1,
                    "Pos.x": 120,
                    "Pos.y": 985
                },
                {
                    "Name": "",
                    "Code.Type": "DialogBegin",
                    "Code": [
                        "cur_ruin = GetShipRuins(Player());",
                        "if(cur_ruin)",
                        "{",
                        "\ttstr1 = Format(ShipType(cur_ruin), '_licensed', '', '');",
                        "\t//Если игрок находится в технологическом центре",
                        "    if(tstr1 == 'WB')",
                        "\t{",
                        "        if(!PlayerBridge())",
                        "        {",
                        "\t\t    //Если игрок ещё не покупал этот корпус",
                        "\t\t    if(!FistOfBroggWasBought)",
                        "\t\t    {",
                        "                if(ShipPilotRace(cur_ruin) == Maloc && ShipPilotRace(Player()) == Maloc && !ShipOnSidePirateClan(Player()))",
                        "                {",
                        "                    //Военное звание не ниже капитана",
                        "\t\t\t        if(ShipRank(Player()) >= 3)",
                        "\t\t\t        {",
                        "                        //Игрок уничтожил не менее 100 доминаторов",
                        "                        if(ShipStatistic(Player(), 2) >= 100)",
                        "                        {",
                        "                            //Если у игрока есть хоть один \"Калкитовый наконечник\", \"Убойный удар\" или \"Табель воина\"",
                        "                            if(CountRewardByNom(Player(), 1) || CountRewardByNom(Player(), 2) || CountRewardByNom(Player(), 3))",
                        "                            {",
                        "\t\t\t\t                tstr1 = CT('Script.Mod_ArtiUniqueShipsPack.FistOfBrogg.BuyOffer');",
                        "\t\t\t\t\t            tstr2 = CT('Script.Mod_ArtiUniqueShipsPack.FistOfBrogg.BuyStart');",
                        "\t\t\t\t\t            AddDialogInject('FistOfBroggBuyDialog', tstr1, tstr2, 2);",
                        "                            }",
                        "                        }",
                        "\t\t\t        }",
                        "                }",
                        "\t\t    }",
                        "",
                        "\t\t    //Если игрок ещё не покупал этот корпус",
                        "\t\t    if(!SaberWasBought)",
                        "\t\t    {",
                        "                if(ShipPilotRace(Player()) == People && !ShipOnSidePirateClan(Player()))",
                        "                {",
                        "                    //Военное звание не ниже капитана",
                        "\t\t\t        if(ShipRank(Player()) >= 3)",
                        "\t\t\t        {",
                        "                        //Захватил не менее 6 систем для Коалиции",
                        "                        if(GetValueFromScript('Mod_ExpPilotBridge', 'sys_coal') >= 6)",
                        "                        {",
                        "                            //Выполнил не менее 3 ПБ",
                        "                            if(PlayerPlanetaryBattlesCompleted() >= 3)",
                        "                            {",
                        "                                //Если игрок хотя бы раз за игру бывал \"Отличившимся воином\"",
                        "                                if(EminentWarrior)",
                        "                                {",
                        "\t\t\t\t                    tstr1 = CT('Script.Mod_ArtiUniqueShipsPack.Saber.BuyOffer');",
                        "\t\t\t\t\t                tstr2 = CT('Script.Mod_ArtiUniqueShipsPack.Saber.BuyStart');",
                        "\t\t\t\t\t                AddDialogInject('SaberBuyDialog', tstr1, tstr2, 2);",
                        "                                }",
                        "                            }",
                        "                        }",
                        "\t\t\t        }",
                        "                }",
                        "\t\t    }",
                        "            //Иначе у игрока есть возможность установить на данный корпус улучшения",
                        "            else if(ShipPilotRace(Player()) == People && !ShipOnSidePirateClan(Player()))",
                        "            {",
                        "                //Если игрок в данный момент использует как раз нужный корпус",
                        "                if(ShipItems(Player(), 0) == ScriptItemToItem(SaberHull))",
                        "                {",
                        "                    //Если установлено ещё не максимальное число улучшений",
                        "                    if(ScriptItemData(SaberHull, 2) < CT('Script.Mod_ArtiUniqueShipsPack.SaberParamsList.MaxUpgradesCount'))",
                        "                    {",
                        "\t\t\t            tstr1 = Format(CT('Script.Mod_ArtiUniqueShipsPack.Saber.BuyUpgradeOffer'), '<HullName' + '>', CT('MicroModuls.ArtiUniqueShipsPack_SaberHull.ShortName'));",
                        "\t\t\t\t\t    tstr2 = CT('Script.Mod_ArtiUniqueShipsPack.Saber.BuyUpgradeStart');",
                        "\t\t\t\t\t    AddDialogInject('SaberUpgradeBuyDialog', tstr1, tstr2, 2);",
                        "                    }",
                        "                }",
                        "            }",
                        "        }",
                        "    }",
                        "    else if(tstr1 == 'TC')",
                        "\t{",
                        "\t\tif(ArtimisEventStatus >= 0)",
                        "\t\t{",
                        "\t\t\t//Если событие на поиск сферы и получение корпуса \"Артимида\" ещё не было завершено ни одним из способов",
                        "\t\t\tif(!ArtimisEventStatus)",
                        "\t\t\t{",
                        "\t\t\t\ttstr1 = CT('Script.Mod_ArtiUniqueShipsPack.SphereFoundStart');",
                        "\t\t\t\tif(ItemIn(UnknownSphere, Player())) AddDialogInject('UnknownSphereFoundDialog', '', tstr1, 1);",
                        "\t\t\t}",
                        "\t\t\telse if(ArtimisEventStatus <= CurTurn() && Id(cur_ruin) == ArtimisStationId)",
                        "\t\t\t{",
                        "\t\t\t\ttstr1 = CT('Script.Mod_ArtiUniqueShipsPack.ArtimisBuyStart');",
                        "\t\t\t\tAddDialogInject('ArtimisBuyDialog', '', tstr1, 2);",
                        "\t\t\t}",
                        "\t\t}",
                        "",
                        "\t\t//Если игрок ещё не изучил корпус \"Зион\" (надо сдавать на ТЦ пушки)",
                        "\t\tif(!ZionWasBought)",
                        "\t\t{",
                        "            if(GalaxyTechLevel() >= 6)",
                        "            {",
                        "                //Только для пеленгов",
                        "\t\t\t    if(ShipPilotRace(Player()) == Peleng && !ShipOnSidePirateClan(Player()))",
                        "\t\t\t    {",
                        "                    //Звание не ниже истребителя",
                        "\t\t\t        if(ShipRank(Player()) >= 4)",
                        "\t\t\t\t    {",
                        "                        //Игрок уничтожил не менее 150 доминаторов и 50 пиратов",
                        "\t\t\t\t\t    if(ShipStatistic(Player(), 2) >= 150 && ShipStatistic(Player(), 1) >= 50)",
                        "\t\t\t\t\t    {",
                        "\t\t\t\t\t        tstr1 = CT('Script.Mod_ArtiUniqueShipsPack.Zion.UnlockOffer');",
                        "\t\t\t\t\t\t    tstr2 = CT('Script.Mod_ArtiUniqueShipsPack.Zion.PlayerAskUnlock');",
                        "\t\t\t\t\t\t    AddDialogInject('ZionUnlockDialog', tstr1, tstr2, 2);",
                        "\t\t\t\t\t    }",
                        "\t\t\t\t    }",
                        "\t\t\t    }",
                        "            }",
                        "\t\t}",
                        "        //Если игрок ещё не приобрёл \"Зион\"",
                        "\t\telse if(ZionWasBought == 1)",
                        "\t\t{",
                        "            if(GalaxyTechLevel() >= 6)",
                        "            {",
                        "\t\t\t    if(ShipPilotRace(Player()) == Peleng && !ShipOnSidePirateClan(Player()))",
                        "\t\t\t    {",
                        "\t\t\t\t    tstr1 = CT('Script.Mod_ArtiUniqueShipsPack.Zion.BuyOffer');",
                        "\t\t\t\t\ttstr2 = CT('Script.Mod_ArtiUniqueShipsPack.Zion.BuyStart');",
                        "\t\t\t\t\tAddDialogInject('ZionBuyDialog', tstr1, tstr2, 2);",
                        "\t\t\t\t}",
                        "\t\t\t}",
                        "\t\t}",
                        "\t\t//Если игрок уже купил \"Зион\", но ещё не выбрал к нему модификацию",
                        "\t\telse if(ZionWasBought > 0)",
                        "\t\t{",
                        "\t\t    if(ShipPilotRace(Player()) == Peleng && !ShipOnSidePirateClan(Player()))",
                        "\t\t    {",
                        "\t\t\t    if(ItemIn(ZionHull, Player()))",
                        "\t\t\t    {",
                        "\t\t\t        tstr1 = CT('Script.Mod_ArtiUniqueShipsPack.Zion.ModsOffer');",
                        "\t\t\t\t    tstr2 = CT('Script.Mod_ArtiUniqueShipsPack.Zion.ModsStart');",
                        "\t\t\t\t    AddDialogInject('ZionModsBuyDialog', tstr1, tstr2, 2);",
                        "                }",
                        "            }",
                        "\t\t}",
                        "",
                        "\t\tif(CurrentMods('OtherMods\\\\ArtiUniqueShipsPackPlus'))",
                        "\t\t{",
                        "\t\t\t//Если игрок ещё не изучил корпус \"Аскалон\"",
                        "\t\t\tif(!AscalonWasBought)",
                        "\t\t\t{",
                        "\t\t\t\tif(GalaxyTechLevel() >= 5)",
                        "\t\t\t\t{",
                        "\t\t\t\t\t//Только для пеленгов",
                        "\t\t\t\t\tif(ShipPilotRace(Player()) == Fei && !ShipOnSidePirateClan(Player()))",
                        "\t\t\t\t\t{",
                        "\t\t\t\t\t\t//Не менее 20 выполненных правительственных заданий",
                        "\t\t\t\t\t\tif(PlayerQuestsCompleted() >= 20)",
                        "\t\t\t\t\t\t{",
                        "\t\t\t\t\t\t\t//\"Торговец года\"",
                        "\t\t\t\t\t\t\tif(AscalonDaysOfHighTrade >= CT('Script.Mod_ArtiUniqueShipsPack.AscalonParamsList.HowMuchToHoldTradeRating'))",
                        "\t\t\t\t\t\t\t{",
                        "\t\t\t\t\t\t\t\ttint1 = 0;",
                        "\t\t\t\t\t\t\t\tfor(i = 0; i < StorageItems(); i = i + 1)",
                        "\t\t\t\t\t\t\t\t{",
                        "\t\t\t\t\t\t\t\t\tif(StorageItemLocation(i) != cur_ruin) continue;",
                        "\t\t\t\t\t\t\t\t\tcur_item = StorageItems(i);",
                        "\t\t\t\t\t\t\t\t\tif(ItemType(cur_item) != t_Minerals) continue;",
                        "\t\t\t\t\t\t\t\t\ttint1 = tint1 + ItemSize(cur_item);",
                        "\t\t\t\t\t\t\t\t}",
                        "",
                        "\t\t\t\t\t\t\t\t//Не менее 10.000 минералов на складе ТЦ",
                        "\t\t\t\t\t\t\t\tif(tint1 >= CT('Script.Mod_ArtiUniqueShipsPack.AscalonParamsList.MineralsOnStock'))",
                        "\t\t\t\t\t\t\t\t{",
                        "\t\t\t\t\t\t\t\t\ttstr1 = CT('Script.Mod_ArtiUniqueShipsPack.Ascalon.BuyOffer');",
                        "\t\t\t\t\t\t\t\t\ttstr2 = CT('Script.Mod_ArtiUniqueShipsPack.Ascalon.BuyStart');",
                        "\t\t\t\t\t\t\t\t\tAddDialogInject('AscalonBuyDialog', tstr1, tstr2, 2);",
                        "\t\t\t\t\t\t\t\t}",
                        "\t\t\t\t\t\t\t}",
                        "\t\t\t\t\t\t}",
                        "\t\t\t\t\t}",
                        "\t\t\t\t}",
                        "\t\t\t}",
                        "\t\t}",
                        "\t}",
                        "\t//Если игрок находится на доминионе",
                        "\telse if(tstr1 == 'CB')",
                        "\t{",
                        "\t\t//Если игрок ещё не покупал корпус \"Торнадо\"",
                        "\t\tif(!TornadoWasBought)",
                        "\t\t{",
                        "\t\t\t//Игрок должен состоять в пиратском клане, иметь звание барона, а также должен уничтожить не менее 5 дредноутов из EvoArmada",
                        "\t\t\tif(ShipOnSidePirateClan(Player()))",
                        "\t\t\t{",
                        "\t\t\t\tif(GetShipPirateRank(Player()) >= 7)",
                        "\t\t\t\t{",
                        "\t\t\t\t\t//Игрок уничтожил 3 бертора и 3 линкора, либо 3 фрегата",
                        "\t\t\t\t\tif(GDomBerStat >= 3 && (GWarFlagStat >= 3 || GPirFrigStat >= 3))",
                        "\t\t\t\t\t{",
                        "\t\t\t\t\t\tif(TornadoDreadnoughtKills >= 5)",
                        "\t\t\t\t\t\t{",
                        "\t\t\t\t\t\t\ttstr1 = CT('Script.Mod_ArtiUniqueShipsPack.TornadoBuyOffer');",
                        "\t\t\t\t\t\t\ttstr2 = CT('Script.Mod_ArtiUniqueShipsPack.TornadoBuyStart');",
                        "\t\t\t\t\t\t\tAddDialogInject('TornadoBuyDialog', tstr1, tstr2, 2);",
                        "\t\t\t\t\t\t}",
                        "\t\t\t\t\t}",
                        "\t\t\t\t}",
                        "\t\t\t}",
                        "\t\t}",
                        "",
                        "\t\t//Если игрок ещё не покупал корпус \"Друг\"",
                        "\t\tif(!FriendWasBought)",
                        "\t\t{",
                        "            if(GalaxyTechLevel() >= 5)",
                        "            {",
                        "\t\t\t    if(ShipOnSidePirateClan(Player()))",
                        "\t\t\t    {",
                        "                    //Звание не ниже атамана",
                        "\t\t\t\t    if(GetShipPirateRank(Player()) >= 5)",
                        "\t\t\t\t    {",
                        "                        //Игрок освободил не менее 5 систем",
                        "                        if(ShipStatistic(Player(), 3) >= 5)",
                        "                        {",
                        "                            //Игрок уничтожил не менее 100 доминаторов и 20 военных",
                        "\t\t\t\t\t        if(ShipStatistic(Player(), 2) >= 100 && ShipStatistic(Player(), 5) >= 20)",
                        "\t\t\t\t\t        {",
                        "\t\t\t\t\t\t        tstr1 = CT('Script.Mod_ArtiUniqueShipsPack.FriendBuyOffer');",
                        "\t\t\t\t\t\t        tstr2 = CT('Script.Mod_ArtiUniqueShipsPack.FriendBuyStart');",
                        "\t\t\t\t\t\t        AddDialogInject('FriendBuyDialog', tstr1, tstr2, 2);",
                        "\t\t\t\t\t        }",
                        "                        }",
                        "\t\t\t\t    }",
                        "\t\t\t    }",
                        "            }",
                        "\t\t}",
                        "",
                        "\t\tif(CurrentMods('OtherMods\\\\ArtiUniqueShipsPackPlus'))",
                        "\t\t{",
                        "\t\t\t//Значения сета в переменной BulwarkWasBought:",
                        "\t\t\t//BulwarkWasBought == 0 - \"Оплот\" не куплен;",
                        "\t\t\t//1 - \"Оплот\" куплен;",
                        "\t\t\t//2 - куплен \"Оплот\" и дополнительный акрин к нему;",
                        "\t\t\t//4 - куплен \"Оплот\" и первый апгрейд дополнительных выстрелов к нему;",
                        "\t\t\t//5 - куплен \"Оплот\" и второй апгрейд дополнительных выстрелов к нему (суммируется к сету первого);",
                        "\t\t\t//Максимальное значение переменной - 15;",
                        "\t\t\t//Если игрок ещё не покупал корпус \"Оплот\"",
                        "\t\t\tif(!BulwarkWasBought)",
                        "\t\t\t{",
                        "\t\t\t\tif(ShipOnSidePirateClan(Player()))",
                        "\t\t\t\t{",
                        "\t\t\t\t\t//Звание не ниже хана",
                        "\t\t\t\t\tif(GetShipPirateRank(Player()) >= 6)",
                        "\t\t\t\t\t{",
                        "\t\t\t\t\t\t//Игрок уничтожил не менее 200 доминаторов и освободил не менее 10 систем",
                        "\t\t\t\t\t\tif(ShipStatistic(Player(), 2) >= 200 && ShipStatistic(Player(), 3) >= 10)",
                        "\t\t\t\t\t\t{",
                        "\t\t\t\t\t\t\ttstr1 = CT('Script.Mod_ArtiUniqueShipsPack.BulwarkBuyOffer');",
                        "\t\t\t\t\t\t\ttstr2 = CT('Script.Mod_ArtiUniqueShipsPack.BulwarkBuyStart');",
                        "\t\t\t\t\t\t\tAddDialogInject('BulwarkBuyDialog', tstr1, tstr2, 2);",
                        "\t\t\t\t\t\t}",
                        "\t\t\t\t\t}",
                        "\t\t\t\t}",
                        "\t\t\t}",
                        "\t\t\t//Если игрок уже купил \"Оплот\", но ещё не скупил все модификации к нему",
                        "\t\t\telse if(BulwarkWasBought < 15)",
                        "\t\t\t{",
                        "\t\t\t\tif(ShipOnSidePirateClan(Player()))",
                        "\t\t\t\t{",
                        "\t\t\t\t\t//\"Оплот\" должен быть \"одет\" на игрока",
                        "\t\t\t\t\tif(ItemIn(BulwarkHull, Player()))",
                        "\t\t\t\t\t{",
                        "\t\t\t\t\t\ttstr1 = CT('Script.Mod_ArtiUniqueShipsPack.BulwarkModsOffer');",
                        "\t\t\t\t\t\ttstr2 = CT('Script.Mod_ArtiUniqueShipsPack.BulwarkModsStart');",
                        "\t\t\t\t\t\tAddDialogInject('BulwarkModsDialog', tstr1, tstr2, 2);",
                        "\t\t\t\t\t}",
                        "\t\t\t\t}",
                        "\t\t\t}",
                        "\t\t}",
                        "",
                        "\t\t//Если игрок ещё не покупал корпус \"Технотрон\"",
                        "\t\tif(!TechnotronWasBought)",
                        "\t\t{",
                        "\t\t\tif(ShipOnSidePirateClan(Player()))",
                        "\t\t\t{",
                        "                //Звание не ниже головореза",
                        "\t\t\t    if(GetShipPirateRank(Player()) >= 4)",
                        "\t\t\t\t{",
                        "                    //Игрок завершил не менее 3 ПБ и освободил не менее 5 систем",
                        "\t\t\t\t\tif(PlayerPlanetaryBattlesCompleted() >= 3 && ShipStatistic(Player(), 3) >= 5)",
                        "\t\t\t\t\t{",
                        "                        //Если квест на сбитие астероида в моде ExpPhysGun провален (астероид врезался в планету, либо игрок набрал ZAWARUDO)",
                        "                        if(GExpPhysGunGlobalState == -4)",
                        "                        {",
                        "                            //Если игрок сдал пиратам секретный кейс в моде ExpAcryn",
                        "                            if(GetValueFromScript('Mod_ExpAcryn', 'fl_array', 5, 1) > 0)",
                        "                            {",
                        "\t\t\t\t\t            tstr1 = CT('Script.Mod_ArtiUniqueShipsPack.TechnotronBuyOffer');",
                        "\t\t\t\t\t\t        tstr2 = CT('Script.Mod_ArtiUniqueShipsPack.TechnotronBuyStart');",
                        "\t\t\t\t\t\t        AddDialogInject('TechnotronBuyDialog', tstr1, tstr2, 2);",
                        "                            }",
                        "                        }",
                        "\t\t\t\t\t}",
                        "\t\t\t\t}",
                        "\t\t\t}",
                        "\t\t}",
                        "\t}",
                        "    //Выдача корпусов в штабе в моде ShuMercsHQ",
                        "    else if(tstr1 == 'PlayerMB')",
                        "    {",
                        "        //Коалиционные корпуса",
                        "        if((PlayerMBHullsGiveAwaySet & 1))",
                        "        {",
                        "            PlayerMBHullsGiveAwaySet = PlayerMBHullsGiveAwaySet - 1;",
                        "            AddDialogOverride('SaberGetDialog', 50000000);",
                        "        }",
                        "        if((PlayerMBHullsGiveAwaySet & 2))",
                        "        {",
                        "            PlayerMBHullsGiveAwaySet = PlayerMBHullsGiveAwaySet - 2;",
                        "            AddDialogOverride('ZionGetDialog', 50000000);",
                        "        }",
                        "        if((PlayerMBHullsGiveAwaySet & 4))",
                        "        {",
                        "            PlayerMBHullsGiveAwaySet = PlayerMBHullsGiveAwaySet - 4;",
                        "            AddDialogOverride('FistOfBroggGetDialog', 50000000);",
                        "        }",
                        "",
                        "        //Пиратские корпуса",
                        "        if((PlayerMBHullsGiveAwaySet & 8))",
                        "        {",
                        "            PlayerMBHullsGiveAwaySet = PlayerMBHullsGiveAwaySet - 8;",
                        "            AddDialogOverride('FriendGetDialog', 50000000);",
                        "        }",
                        "        if((PlayerMBHullsGiveAwaySet & 16))",
                        "        {",
                        "            PlayerMBHullsGiveAwaySet = PlayerMBHullsGiveAwaySet - 16;",
                        "            AddDialogOverride('TechnotronGetDialog', 50000000);",
                        "        }",
                        "        if((PlayerMBHullsGiveAwaySet & 32))",
                        "        {",
                        "            PlayerMBHullsGiveAwaySet = PlayerMBHullsGiveAwaySet - 32;",
                        "            AddDialogOverride('BulwarkGetDialog', 50000000);",
                        "        }",
                        "    }",
                        "}",
                        "else",
                        "{",
                        "\tcur_ruin = GetShipPlanet(Player());",
                        "",
                        "\tif(CurrentMods('OtherMods\\\\ArtiUniqueShipsPackPlus'))",
                        "\t{",
                        "\t\t//Планета Гаалдок",
                        "\t\tif(Name(cur_ruin) == CT('PlanetName.Gaal.02'))",
                        "\t\t{",
                        "\t\t\t//Если игрок ещё не изучил корпус \"Игнирув\" (надо сдавать на Гаалдок шмотки)",
                        "\t\t\tif(IgniruvWasBought >= 0)",
                        "\t\t\t{",
                        "\t\t\t\tif(GalaxyTechLevel() >= 4)",
                        "\t\t\t\t{",
                        "\t\t\t\t\t//Только для гаальцев",
                        "\t\t\t\t\tif(ShipPilotRace(Player()) == Gaal && !ShipOnSidePirateClan(Player()))",
                        "\t\t\t\t\t{",
                        "\t\t\t\t\t\t//Учёное звание не ниже магистра",
                        "\t\t\t\t\t\ttint1 = PlayerScienceRank['CurrentRank'];",
                        "\t\t\t\t\t\tif(tint1 >= 3)",
                        "\t\t\t\t\t\t{",
                        "\t\t\t\t\t\t\ttstr1 = CT('Script.Mod_ArtiUniqueShipsPack.Igniruv.UnlockOffer');",
                        "\t\t\t\t\t\t\ttstr2 = Format(CT('Script.Mod_ArtiUniqueShipsPack.Igniruv.PlayerAskUnlock'), '<ScienceRank' + '>', CT('RankScientific.' + tint1 + '.Name'));",
                        "\t\t\t\t\t\t\tAddDialogInject('IgniruvUnlockDialog', tstr1, tstr2, 2);",
                        "\t\t\t\t\t\t}",
                        "\t\t\t\t\t}",
                        "\t\t\t\t}",
                        "\t\t\t}",
                        "\t\t\t//Если игрок уже исследовал, но ещё не приобрёл \"Игнирув\"",
                        "\t\t\telse if(IgniruvWasBought < -1)",
                        "\t\t\t{",
                        "                if(abs(IgniruvWasBought) <= CurTurn())",
                        "                {",
                        "    \t\t\t\t//Только для гаальцев",
                        "    \t\t\t\tif(ShipPilotRace(Player()) == Gaal && !ShipOnSidePirateClan(Player()))",
                        "    \t\t\t\t{",
                        "    \t\t\t\t\ttstr1 = CT('Script.Mod_ArtiUniqueShipsPack.Igniruv.BuyOffer');",
                        "    \t\t\t\t\ttstr2 = CT('Script.Mod_ArtiUniqueShipsPack.Igniruv.BuyStart');",
                        "    \t\t\t\t\tAddDialogInject('IgniruvBuyDialog', tstr1, tstr2, 2);",
                        "    \t\t\t\t}",
                        "                }",
                        "\t\t\t}",
                        "\t\t}",
                        "\t}",
                        "}"
                    ],
                    "#": 68,
                    "Type": "Top",
                    "Parent": -1,
                    "Pos.x": 180,
                    "Pos.y": 985
                },
                {
                    "Name": "",
                    "Code.Type": "Turn",
                    "Code": [
                        "if(GetData() <= CurTurn())",
                        "{",
                        "    ShipSpecialBonuses(CurShip, bonFuel, ShipSpecialBonuses(CurShip, bonFuel) + 10000);",
                        "    ShipOut(CurShip);",
                        "}"
                    ],
                    "#": 219,
                    "Type": "Top",
                    "Parent": -1,
                    "Pos.x": 80
                },
                {
                    "Name": "",
                    "Code.Type": "Turn",
                    "Code": [
                        "//Определяем цену корпуса \"Артимида\"",
                        "//Размер корпуса берём из Lang",
                        "tint1 = CT('Script.Mod_ArtiUniqueShipsPack.ArtimisParamsList.HullSize');",
                        "tint2 = GetValueFromScript('', CT('Script.Mod_ArtiUniqueShipsPack.ArtimisParamsList.HullRace'));",
                        "cur_item = CreateHull(6, tint1, 8, tint2, -1, CT('Script.Mod_ArtiUniqueShipsPack.ArtimisParamsList.PirateClanAssembly'));",
                        "//Выставляем корпусу значение брони из Lang",
                        "SetEquipmentStats(cur_item, CT('Script.Mod_ArtiUniqueShipsPack.ArtimisParamsList.HullArmor'), 0);",
                        "bonus_num = FindBonusByNameInCfg('ArtiUniqueShipsPack_ArtimisHull');",
                        "SpecialToEquipment(bonus_num, cur_item);",
                        "cost = ItemCost(cur_item);",
                        "//Если в Lang стоимость не задана \"по умолчанию\", то подгружаем её напрямую оттуда",
                        "if(CT('Script.Mod_ArtiUniqueShipsPack.ArtimisParamsList.HullCost') != '-1') cost = abs(0 + CT('Script.Mod_ArtiUniqueShipsPack.ArtimisParamsList.HullCost'));",
                        "",
                        "//Удаляем \"расчётный\" корпус во избежание утечки памяти",
                        "FreeItem(cur_item);",
                        "",
                        "tstr1 = '</color>' + Format(CT('Script.Mod_ArtiUniqueShipsPack.ArtimisBuy'), '<Cost' + '>', cost);",
                        "tstr2 = '</color>' + CT('Script.Mod_ArtiUniqueShipsPack.ArtimisBuyPlayerYes');",
                        "tstr3 = '</color>' + CT('Script.Mod_ArtiUniqueShipsPack.ArtimisBuyPlayerNo');",
                        "DChange(0);",
                        "exit;"
                    ],
                    "#": 220,
                    "Type": "Top",
                    "Parent": -1,
                    "Pos.x": -20,
                    "Pos.y": 500
                },
                {
                    "Name": "",
                    "Code.Type": "Turn",
                    "Code": [
                        "tstr1 = '</color>' + CT('Script.Mod_ArtiUniqueShipsPack.SphereFound');",
                        "tstr2 = '</color>' + CT('Script.Mod_ArtiUniqueShipsPack.SphereFoundPlayerYes');",
                        "tstr3 = '</color>' + CT('Script.Mod_ArtiUniqueShipsPack.SphereFoundPlayerNo');",
                        "DChange(3);",
                        "exit;"
                    ],
                    "#": 221,
                    "Type": "Top",
                    "Parent": -1,
                    "Pos.x": 220,
                    "Pos.y": 500
                },
                {
                    "Name": "",
                    "Code.Type": "Turn",
                    "Code": [
                        "cur_item = CreateHull(6, CT('Script.Mod_ArtiUniqueShipsPack.TornadoParamsList.HullSize'), 8, GetValueFromScript('', CT('Script.Mod_ArtiUniqueShipsPack.TornadoParamsList.HullRace')), -1, CT('Script.Mod_ArtiUniqueShipsPack.TornadoParamsList.PirateClanAssembly'));",
                        "//Выставляем корпусу значение брони из Lang",
                        "SetEquipmentStats(cur_item, CT('Script.Mod_ArtiUniqueShipsPack.TornadoParamsList.HullArmor'), 0);",
                        "bonus_num = FindBonusByNameInCfg('ArtiUniqueShipsPack_TornadoHullNormal');",
                        "SpecialToEquipment(bonus_num, cur_item);",
                        "//Запоминаем полученную цену",
                        "cost = ItemCost(cur_item);",
                        "//Если в Lang стоимость не задана \"по умолчанию\", то подгружаем её напрямую оттуда",
                        "if(CT('Script.Mod_ArtiUniqueShipsPack.TornadoParamsList.HullCost') != '-1') cost = abs(0 + CT('Script.Mod_ArtiUniqueShipsPack.TornadoParamsList.HullCost'));",
                        "",
                        "//Удаляем \"расчётный\" корпус во избежание утечки памяти",
                        "FreeItem(cur_item);",
                        "",
                        "tstr1 = '</color>' + Format(CT('Script.Mod_ArtiUniqueShipsPack.TornadoBuy'), '<Cost' + '>', cost);",
                        "tstr2 = '</color>' + CT('Script.Mod_ArtiUniqueShipsPack.TornadoBuyPlayerYes');",
                        "tstr3 = '</color>' + CT('Script.Mod_ArtiUniqueShipsPack.TornadoBuyPlayerNo');",
                        "DChange(6);",
                        "exit;"
                    ],
                    "#": 222,
                    "Type": "Top",
                    "Parent": -1,
                    "Pos.x": 580,
                    "Pos.y": 500
                },
                {
                    "Name": "",
                    "Code.Type": "Turn",
                    "Code": [
                        "cur_item = CreateHull(6, CT('Script.Mod_ArtiUniqueShipsPack.FriendParamsList.HullSize'), 8, GetValueFromScript('', CT('Script.Mod_ArtiUniqueShipsPack.FriendParamsList.HullRace')), -1, CT('Script.Mod_ArtiUniqueShipsPack.FriendParamsList.PirateClanAssembly'));",
                        "//Выставляем корпусу значение брони из Lang",
                        "SetEquipmentStats(cur_item, CT('Script.Mod_ArtiUniqueShipsPack.FriendParamsList.HullArmor'), 0);",
                        "bonus_num = FindBonusByNameInCfg('ArtiUniqueShipsPack_FriendHull');",
                        "SpecialToEquipment(bonus_num, cur_item);",
                        "//Маркер на запрет автоспавна пиратов из корпуса",
