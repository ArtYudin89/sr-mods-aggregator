                    ],
                    "#": 332,
                    "Type": "Top",
                    "Parent": -1,
                    "Pos.x": 580,
                    "Pos.y": 890
                },
                {
                    "Name": "",
                    "Code.Type": "Turn",
                    "Code": [
                        "//\"Списываем\" со склада минералы",
                        "tint1 = CT('Script.Mod_ArtiUniqueShipsPack.AscalonParamsList.MineralsOnStock');",
                        "for(i = 0; i < StorageItems(); i = i + 1)",
                        "{",
                        "    if(StorageItemLocation(i) != GetShipRuins(Player())) continue;",
                        "    cur_item = StorageItems(i);",
                        "    if(ItemType(cur_item) != t_Minerals) continue;",
                        "",
                        "    if(ItemSize(cur_item) == tint1)",
                        "    {",
                        "        FreeItem(GetItemFromStorage(i));",
                        "        tint1 = 0;",
                        "    }",
                        "    else if(ItemSize(cur_item) > tint1)",
                        "    {",
                        "        ItemSize(cur_item, ItemSize(cur_item) - tint1);",
                        "        tint1 = 0;",
                        "    }",
                        "    else //if(ItemSize(cur_item) < tint1)",
                        "    {",
                        "        tint1 = tint1 - ItemSize(cur_item);",
                        "        FreeItem(GetItemFromStorage(i));",
                        "    }",
                        "",
                        "    if(!tint1) break;",
                        "}",
                        "//Типа отдают \"бесплатно\", только за минералы",
                        "//ShipMoney(Player(), ShipMoney(Player()) - cost);",
                        "",
                        "cur_item = CreateHull(6, CT('Script.Mod_ArtiUniqueShipsPack.AscalonParamsList.HullSize'), 8, GetValueFromScript('', CT('Script.Mod_ArtiUniqueShipsPack.AscalonParamsList.HullRace')), -1, CT('Script.Mod_ArtiUniqueShipsPack.AscalonParamsList.PirateClanAssembly'));",
                        "//Выставляем корпусу значение брони из Lang",
                        "SetEquipmentStats(cur_item, CT('Script.Mod_ArtiUniqueShipsPack.AscalonParamsList.HullArmor'), 0);",
                        "SpecialToEquipment(bonus_num, cur_item);",
                        "//На всякий случай выставляем пересозданному корпусу уже подсчитанную ранее цену",
                        "ItemCost(cur_item, cost);",
                        "//Заносим корпус в скрипт и вешаем на него необходимые обработчики",
                        "LinkItemToScript(cur_item, AscalonHull);",
                        "ItemOnActCode(cur_item, GenerateCodeStringFromBlock('ActCodeBlocksList.ArtiUniqueShipsPack_AscalonHullActCode'));",
                        "ItemOnUseCode(cur_item, GenerateCodeStringFromBlock('UseCodeBlocksList.ArtiUniqueShipsPack_AscalonHullUseCode'));",
                        "CanSellItem(cur_item, 1);",
                        "AddItemToStorage(cur_ruin, cur_item);",
                        "Sound('Sound.Buy');",
                        "",
                        "//Ставим маркер, что данный корпус купить повторно уже не выйдет",
                        "AscalonWasBought = 1;",
                        "",
                        "tstr1 = '</color>' + CT('Script.Mod_ArtiUniqueShipsPack.Ascalon.BuyYes');",
                        "DChange(40);",
                        "exit;"
                    ],
