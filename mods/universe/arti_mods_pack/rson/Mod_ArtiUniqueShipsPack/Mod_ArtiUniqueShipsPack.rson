                    "Code": [
                        "//Если игрок ещё не установил дополнительный акрин",
                        "if(!(BulwarkWasBought & 2))",
                        "{",
                        "    cost = abs(0 + CT('Script.Mod_ArtiUniqueShipsPack.BulwarkParamsList.ModAcrynsCost'));",
                        "    tstr1 = '</color>' + Format(CT('Script.Mod_ArtiUniqueShipsPack.BulwarkModsBuyAcrynInstall'), '<Acryn' + '>', CT('MicroModuls.ArtiUniqueShipsPack_BulwarkHullFearlessMod.AddName'), '<Cost' + '>', cost);",
                        "    tstr2 = '</color>' + Format(CT('Script.Mod_ArtiUniqueShipsPack.BulwarkModsBuyAcrynInstall'), '<Acryn' + '>', CT('MicroModuls.ArtiUniqueShipsPack_BulwarkHullProtectiveMod.AddName'), '<Cost' + '>', cost);",
                        "    tstr3 = '</color>' + Format(CT('Script.Mod_ArtiUniqueShipsPack.BulwarkModsBuyAcrynInstall'), '<Acryn' + '>', CT('MicroModuls.ArtiUniqueShipsPack_BulwarkHullAMLMod.AddName'), '<Cost' + '>', cost);",
                        "",
                        "    if(ShipMoney(Player()) < cost)",
                        "    {",
                        "        AddDialogBlock(tstr1, 1);",
                        "        AddDialogBlock(tstr2, 1);",
                        "        AddDialogBlock(tstr3, 1);",
                        "    }",
                        "",
                        "    InjectAnswer('BulwarkModsBuyDialog', tstr1, 1);",
                        "    InjectAnswer('BulwarkModsBuyDialog', tstr2, 2);",
                        "    InjectAnswer('BulwarkModsBuyDialog', tstr3, 3);",
                        "}",
                        "",
                        "//Если игрок ещё не установил первый апгрейд дополнительных выстрелов",
                        "if(!(BulwarkWasBought & 4))",
                        "{",
                        "    cost = abs(0 + CT('Script.Mod_ArtiUniqueShipsPack.BulwarkParamsList.ModAddShotsFirstUpgradeCost'));",
                        "    tstr1 = '</color>' + Format(CT('Script.Mod_ArtiUniqueShipsPack.BulwarkModsBuyShotsInstall'), '<Count' + '>', CT('Script.Mod_ArtiUniqueShipsPack.BulwarkParamsList.ModAddShotsFirstUpgrade'), '<Cost' + '>', cost);",
                        "",
                        "    if(ShipMoney(Player()) < cost) AddDialogBlock(tstr1, 1);",
                        "    InjectAnswer('BulwarkModsBuyDialog', tstr1, 4);",
                        "}",
                        "//Если игрок ещё не установил второй апгрейд дополнительных выстрелов",
                        "else if(!(BulwarkWasBought & 8))",
                        "{",
                        "    cost = abs(0 + CT('Script.Mod_ArtiUniqueShipsPack.BulwarkParamsList.ModAddShotsSecondUpgradeCost'));",
                        "    tstr1 = '</color>' + Format(CT('Script.Mod_ArtiUniqueShipsPack.BulwarkModsBuyShotsInstall'), '<Count' + '>', CT('Script.Mod_ArtiUniqueShipsPack.BulwarkParamsList.ModAddShotsSecondUpgrade'), '<Cost' + '>', cost);",
                        "",
                        "    if(ShipMoney(Player()) < cost) AddDialogBlock(tstr1, 1);",
                        "    InjectAnswer('BulwarkModsBuyDialog', tstr1, 5);",
                        "}",
                        "",
                        "//Для реплики выхода",
                        "tstr1 = '</color>' + CT('Script.Mod_ArtiUniqueShipsPack.BulwarkModsBuyPlayerNo');",
                        "DAdd(20);"
