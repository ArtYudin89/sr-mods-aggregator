                        "cur_item = CreateHull(6, CT('Script.Mod_ArtiUniqueShipsPack.TornadoParamsList.HullSize'), 8, GetValueFromScript('', CT('Script.Mod_ArtiUniqueShipsPack.TornadoParamsList.HullRace')), -1, CT('Script.Mod_ArtiUniqueShipsPack.TornadoParamsList.PirateClanAssembly'));",
                        "//Выставляем корпусу значение брони из Lang",
                        "SetEquipmentStats(cur_item, CT('Script.Mod_ArtiUniqueShipsPack.TornadoParamsList.HullArmor'), 0);",
                        "SpecialToEquipment(FindBonusByNameInCfg('ArtiUniqueShipsPack_TornadoHullNormal'), cur_item);",
                        "//Если в Lang стоимость не задана \"по умолчанию\", то подгружаем её напрямую оттуда",
                        "cost = CT('Script.Mod_ArtiUniqueShipsPack.TornadoParamsList.HullCost');",
                        "if(~cost) ItemCost(cur_item, cost);",
                        "//Заносим корпус в скрипт и вешаем на него необходимые обработчики",
                        "LinkItemToScript(cur_item, TornadoHull);",
                        "ItemOnActCode(cur_item, GenerateCodeStringFromBlock('ActCodeBlocksList.ArtiUniqueShipsPack_TornadoHullActCode'));",
                        "ItemOnUseCode(cur_item, GenerateCodeStringFromBlock('UseCodeBlocksList.ArtiUniqueShipsPack_TornadoHullUseCode'));",
                        "CanSellItem(cur_item, 1);",
                        "",
                        "AddItemToStorage(cur_ruin, cur_item);",
                        "",
                        "//Ставим маркер, что данный корпус купить повторно уже не выйдет",
                        "TornadoWasBought = 1;",
                        "DChange(56);",
                        "exit;"
                    ],
