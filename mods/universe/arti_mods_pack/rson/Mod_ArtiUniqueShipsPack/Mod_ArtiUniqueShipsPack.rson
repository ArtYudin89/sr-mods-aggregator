                {
                    "Name": "",
                    "Code.Type": "Turn",
                    "Code": [
                        "//Игрок сдал сферу для постройки и дальнейшей покупки корпуса \"Артимида\"",
                        "//Заводим таймер до завершения постройки корпуса и запоминаем нужный ТЦ",
                        "ArtimisEventStatus = CurTurn() + 63 + round(32 / GalaxyTechLevel());",
                        "ArtimisStationId = Id(cur_ruin);",
                        "",
                        "//Удаляем из трюма сферу",
                        "cur_item = ScriptItemToItem(UnknownSphere);",
                        "//Сперва выводим сферу из скрипта, чтобы не сработало её событие",
                        "ReleaseItemFromScript(UnknownSphere);",
                        "FreeItem(GetItemFromShip(Player(), cur_item));",
                        "",
                        "tstr1 = '</color>' + CT('Script.Mod_ArtiUniqueShipsPack.SphereFoundYes');",
                        "DChange(5);",
                        "exit;"
