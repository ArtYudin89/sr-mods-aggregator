                },
                {
                    "Name": "",
                    "Code.Type": "Turn",
                    "Code": [
                        "tstr1 = '</color>' + CT('Script.Mod_ArtiUniqueShipsPack.BulwarkModsBuy');",
                        "//Добавляем дополнительную информацию о модулях, если игрок ещё не выбрал себе один",
                        "if(!(BulwarkWasBought & 2))",
                        "{",
                        "    tstr1 = tstr1 + CT(\"Script.Mod_ArtiUniqueShipsPack.2\") + CT('Script.Mod_ArtiUniqueShipsPack.BulwarkModsBuyAcryn');",
                        "    tstr1 = tstr1 + CT(\"Script.Mod_ArtiUniqueShipsPack.2\") + CT(\"Script.Mod_ArtiUniqueShipsPack.2\") + BonusText(FindBonusByNameInCfg('ArtiUniqueShipsPack_BulwarkHullFearlessMod'));",
                        "    tstr1 = tstr1 + CT(\"Script.Mod_ArtiUniqueShipsPack.2\") + CT(\"Script.Mod_ArtiUniqueShipsPack.2\") + BonusText(FindBonusByNameInCfg('ArtiUniqueShipsPack_BulwarkHullProtectiveMod'));",
                        "    tstr1 = tstr1 + CT(\"Script.Mod_ArtiUniqueShipsPack.2\") + CT(\"Script.Mod_ArtiUniqueShipsPack.2\") + BonusText(FindBonusByNameInCfg('ArtiUniqueShipsPack_BulwarkHullAMLMod'));",
                        "}",
                        "DChange(15);",
                        "exit;"
                    ],
                    "#": 225,
                    "Type": "Top",
                    "Parent": -1,
                    "Pos.x": 1270,
                    "Pos.y": 500
                },
                {
                    "Name": "",
                    "Code.Type": "Turn",
                    "Code": [
                        "tint1 = GAnswerData;",
                        "cur_item = ShipItems(Player(), 0);",
                        "",
                        "//Устанавливаем модуль \"Бесстрашный\"",
                        "if(tint1 == 1)",
                        "{",
                        "    ItemExtraSpecialsAddByType(cur_item, FindBonusByNameInCfg('ArtiUniqueShipsPack_BulwarkHullFearlessMod'));",
                        "",
                        "    BulwarkWasBought = BulwarkWasBought + 2;",
                        "    cost = abs(0 + CT('Script.Mod_ArtiUniqueShipsPack.BulwarkParamsList.ModAcrynsCost'));",
                        "}",
                        "//Устанавливаем модуль \"Защитный\"",
                        "else if(tint1 == 2)",
                        "{",
                        "    ItemExtraSpecialsAddByType(cur_item, FindBonusByNameInCfg('ArtiUniqueShipsPack_BulwarkHullProtectiveMod'));",
                        "",
                        "    BulwarkWasBought = BulwarkWasBought + 2;",
                        "    cost = abs(0 + CT('Script.Mod_ArtiUniqueShipsPack.BulwarkParamsList.ModAcrynsCost'));",
                        "}",
                        "//Устанавливаем модуль \"ПРК\"",
                        "else if(tint1 == 3)",
                        "{",
                        "    ItemExtraSpecialsAddByType(cur_item, FindBonusByNameInCfg('ArtiUniqueShipsPack_BulwarkHullAMLMod'));",
                        "    ItemOnActCode(cur_item, GenerateCodeStringFromBlock('ActCodeBlocksList.ArtiUniqueShipsPack_BulwarkHullAMLModActCode'));",
                        "    //Вешаем на игрока инфошку, имитирующую аЭгис",
                        "    ShipAddCustomShipInfo(Player(), 'ArtiUniqueShipsPack_kPDTurretInfos', 'NoShow', 5, CT('Script.Mod_ArtiUniqueShipsPack.BulwarkParamsList.ModPDTurretRange'));",
                        "",
                        "    BulwarkWasBought = BulwarkWasBought + 2;",
                        "    cost = abs(0 + CT('Script.Mod_ArtiUniqueShipsPack.BulwarkParamsList.ModAcrynsCost'));",
                        "}",
                        "//Устанавливаем первый апгрейд с дополнительными выстрелами",
                        "else if(tint1 == 4)",
                        "{",
                        "    tint2 = CT('Script.Mod_ArtiUniqueShipsPack.BulwarkParamsList.ModAddShotsFirstUpgrade');",
                        "    ShipSpecialBonuses(Player(), bonAttacks, tint2 - 1);",
                        "    if(ShipFindCustomShipInfoByType(Player(), 'EvoArmada_CapitalShipInfos') == -1) ShipAddCustomShipInfo(Player(), 'EvoArmada_CapitalShipInfos', 'NoShow', tint2 - 1);",
                        "    else ShipCustomShipInfoData(Player(), 'EvoArmada_CapitalShipInfos', 1, tint2 - 1);",
                        "    if(ItemOnActCode(cur_item) == '') ItemOnActCode(cur_item, GenerateCodeStringFromBlock('ActCodeBlocksList.ArtiUniqueShipsPack_BulwarkHullExtraShotsActCode'));",
                        "",
                        "    BulwarkWasBought = BulwarkWasBought + 4;",
                        "    cost = abs(0 + CT('Script.Mod_ArtiUniqueShipsPack.BulwarkParamsList.ModAddShotsFirstUpgradeCost'));",
                        "}",
                        "//Устанавливаем второй апгрейд с дополнительными выстрелами",
                        "else",
                        "{",
                        "    tint2 = CT('Script.Mod_ArtiUniqueShipsPack.BulwarkParamsList.ModAddShotsSecondUpgrade');",
                        "    ShipSpecialBonuses(Player(), bonAttacks, tint2 - 1);",
                        "    if(ShipFindCustomShipInfoByType(Player(), 'EvoArmada_CapitalShipInfos') == -1) ShipAddCustomShipInfo(Player(), 'EvoArmada_CapitalShipInfos', 'NoShow', tint2 - 1);",
                        "    else ShipCustomShipInfoData(Player(), 'EvoArmada_CapitalShipInfos', 1, tint2 - 1);",
                        "    if(ItemOnActCode(cur_item) == '') ItemOnActCode(cur_item, GenerateCodeStringFromBlock('ActCodeBlocksList.ArtiUniqueShipsPack_BulwarkHullExtraShotsActCode'));",
                        "",
                        "    BulwarkWasBought = BulwarkWasBought + 8;",
                        "    cost = abs(0 + CT('Script.Mod_ArtiUniqueShipsPack.BulwarkParamsList.ModAddShotsSecondUpgradeCost'));",
                        "}",
                        "",
                        "ItemCost(cur_item, ItemCost(cur_item) + cost);",
                        "ShipMoney(Player(), ShipMoney(Player()) - cost);",
                        "Sound('Sound.Buy');",
                        "",
                        "tstr1 = '</color>' + CT('Script.Mod_ArtiUniqueShipsPack.BulwarkModsBuyYes');",
                        "DChange(16);",
                        "exit;"
                    ],
