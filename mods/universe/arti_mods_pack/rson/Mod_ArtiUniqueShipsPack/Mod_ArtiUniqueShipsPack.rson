                    "Code": [
                        "cur_item = CreateHull(6, CT('Script.Mod_ArtiUniqueShipsPack.ZionParamsList.HullSize'), 8, GetValueFromScript('', CT('Script.Mod_ArtiUniqueShipsPack.ZionParamsList.HullRace')), -1, CT('Script.Mod_ArtiUniqueShipsPack.ZionParamsList.PirateClanAssembly'));",
                        "//Выставляем корпусу значение брони из Lang",
                        "SetEquipmentStats(cur_item, CT('Script.Mod_ArtiUniqueShipsPack.ZionParamsList.HullArmor'), 0);",
                        "SpecialToEquipment(bonus_num, cur_item);",
                        "//Добавляем первый базовый спецакрин улучшения (первый улучшением не считается)",
                        "ItemExtraSpecialsAddByType(cur_item, FindBonusByNameInCfg('ArtiUniqueShipsPack_ZionHullNoMods'));",
                        "//На всякий случай выставляем пересозданному корпусу уже подсчитанную ранее цену",
                        "ItemCost(cur_item, cost);",
                        "//Заносим корпус в скрипт и вешаем на него необходимые обработчики",
                        "LinkItemToScript(cur_item, ZionHull);",
                        "ItemOnActCode(cur_item, GenerateCodeStringFromBlock('ActCodeBlocksList.ArtiUniqueShipsPack_ZionHullActCode'));",
                        "ItemOnUseCode(cur_item, GenerateCodeStringFromBlock('UseCodeBlocksList.ArtiUniqueShipsPack_ZionHullUseCode'));",
                        "CanSellItem(cur_item, 1);",
                        "",
                        "AddItemToStorage(cur_ruin, cur_item);",
                        "ShipMoney(Player(), ShipMoney(Player()) - cost);",
                        "Sound('Sound.Buy');",
                        "",
                        "//Ставим маркер, что данный корпус купить повторно уже не выйдет",
