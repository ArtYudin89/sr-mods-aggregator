                },
                {
                    "Name": "",
                    "Code.Type": "Turn",
                    "Code": [
                        "//Значения сета:",
                        "//Рапторизатор блазероидов - 1",
                        "//Турбийон келероидов - 2",
                        "//Репродуктор терроноидов - 4",
                        "//Нанитоиды неизвестной расы - 8",
                        "//5 рефлекторов любой расы - 16, 32, 64, 128, 256",
                        "//Всего: 511",
                        "for(i = 0; i < ShipItems(Player()); i = i + 1)",
                        "{",
                        "    cur_item = ShipItems(Player(), i);",
                        "    if(ItemInScript(cur_item)) continue;",
                        "    if(ItemType(cur_item) != t_UselessItem) continue;",
                        "    if(ItemOwner(cur_item) != Kling) continue;",
                        "",
                        "    if(",
                        "       EquipmentImageName(cur_item) == 'Remains_13' && !ItemSubrace(cur_item) && !(IgniruvWasBought & 1) ||",
                        "       EquipmentImageName(cur_item) == 'Remains_2' && ItemSubrace(cur_item) == 1 && !(IgniruvWasBought & 2) ||",
                        "       EquipmentImageName(cur_item) == 'Remains_20' && ItemSubrace(cur_item) == 2 && !(IgniruvWasBought & 4)",
                        "      )",
                        "    {",
                        "        //Лолкек",
                        "    }",
                        "    else continue;",
                        "",
                        "    //cost = round(1.5 * ItemCost(cur_item));",
                        "    tstr1 = DeleteTags(ItemFullName(cur_item));",
                        "    //tstr1 = Format(CT('Script.Mod_ArtiUniqueShipsPack.Igniruv.PlayerMaterialsGive'), '<ItemName' + '>', tstr1, '<Cost' + '>', cost);",
                        "    tstr1 = Format(CT('Script.Mod_ArtiUniqueShipsPack.Igniruv.PlayerMaterialsGive'), '<ItemName' + '>', tstr1);",
                        "    InjectAnswer('IgniruvUnlockDoneDialog', tstr1, cur_item);",
                        "}",
                        "",
                        "for(i = 0; i < ShipArts(Player()); i = i + 1)",
                        "{",
                        "    cur_item = ShipArts(Player(), i);",
                        "    if(ItemInScript(cur_item)) continue;",
                        "    if(ItemType(cur_item) != t_ArtefactNano && ItemType(cur_item) != t_Artefact) continue;",
                        "    if(ItemType(cur_item) == t_ArtefactNano)",
                        "    {",
                        "        if(ItemOwner(cur_item) != None) continue;",
                        "        if((IgniruvWasBought & 8)) continue;",
                        "    }",
                        "    else",
                        "    {",
                        "         if(EquipmentImageName(cur_item) != 'RNDart_02') continue;",
                        "         //16+32+64+128+256",
                        "         if((IgniruvWasBought & 496) == 496) continue;",
                        "    }",
                        "",
                        "    //cost = round(1.5 * ItemCost(cur_item));",
                        "    tstr1 = DeleteTags(ItemFullName(cur_item));",
                        "    //tstr1 = Format(CT('Script.Mod_ArtiUniqueShipsPack.Igniruv.PlayerMaterialsGive'), '<ItemName' + '>', tstr1, '<Cost' + '>', cost);",
                        "    tstr1 = Format(CT('Script.Mod_ArtiUniqueShipsPack.Igniruv.PlayerMaterialsGive'), '<ItemName' + '>', tstr1);",
                        "    InjectAnswer('IgniruvUnlockDoneDialog', tstr1, cur_item);",
                        "}",
                        "",
                        "tstr1 = '</color>' + CT('Script.Mod_ArtiUniqueShipsPack.Igniruv.PlayerMaterialsNone');",
                        "tstr2 = '</color>' + CT('Script.Mod_ArtiUniqueShipsPack.Igniruv.UnlockNone');",
                        "DAdd(59);"
