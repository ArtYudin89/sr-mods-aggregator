                {
                    "Name": "",
                    "Code.Type": "Turn",
                    "Code": [
                        "cur_item = CreateHull(6, tint1, 8, tint2, -1, CT('Script.Mod_ArtiUniqueShipsPack.ArtimisParamsList.PirateClanAssembly'));",
                        "//Выставляем корпусу значение брони из Lang",
                        "SetEquipmentStats(cur_item, CT('Script.Mod_ArtiUniqueShipsPack.ArtimisParamsList.HullArmor'), 0);",
                        "SpecialToEquipment(bonus_num, cur_item);",
                        "//На всякий случай выставляем пересозданному корпусу уже подсчитанную ранее цену",
                        "ItemCost(cur_item, cost);",
                        "//Заносим корпус в скрипт и вешаем на него необходимые обработчики",
                        "LinkItemToScript(cur_item, ArtimisHull);",
                        "ItemOnActCode(cur_item, GenerateCodeStringFromBlock('ActCodeBlocksList.ArtiUniqueShipsPack_ArtimisHullActCode'));",
                        "ItemOnUseCode(cur_item, GenerateCodeStringFromBlock('UseCodeBlocksList.ArtiUniqueShipsPack_ArtimisHullUseCode'));",
                        "CanSellItem(cur_item, 1);",
                        "",
                        "AddItemToStorage(cur_ruin, cur_item);",
                        "",
                        "//Создаём и заносим в хранилище ракетомёт, который будет имитировать реилган",
                        "cur_item = CreateEquipment(t_Weapon4, 1, GalaxyTechLevel(), tint2);",
                        "SpecialToEquipment(FindBonusByNameInCfg('ArtiUniqueShipsPack_Railgun'), cur_item);",
                        "LinkItemToScript(cur_item, RailgunWeapon);",
                        "PutItemInVault('ArtiUniqueShipsPack_RailgunWeapon', cur_item);",
                        "",
                        "ShipMoney(Player(), ShipMoney(Player()) - cost);",
                        "Sound('Sound.Buy');",
                        "",
                        "//Завершаем событие с поиском сферы и получением корпуса \"Артимида\"",
                        "ArtimisEventStatus = -3;",
                        "",
                        "tstr1 = '</color>' + CT('Script.Mod_ArtiUniqueShipsPack.ArtimisBuyYes');",
                        "DChange(1);",
                        "exit;"
