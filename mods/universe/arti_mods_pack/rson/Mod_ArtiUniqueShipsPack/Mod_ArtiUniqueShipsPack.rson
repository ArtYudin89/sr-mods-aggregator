                    "Pos.x": -20,
                    "Pos.y": 550
                },
                {
                    "Name": "",
                    "Code.Type": "Turn",
                    "Code": [
                        "cur_item = CreateHull(6, CT('Script.Mod_ArtiUniqueShipsPack.IgniruvParamsList.HullSize'), 8, GetValueFromScript('', CT('Script.Mod_ArtiUniqueShipsPack.IgniruvParamsList.HullRace')), -1, CT('Script.Mod_ArtiUniqueShipsPack.IgniruvParamsList.PirateClanAssembly'));",
                        "//Выставляем корпусу значение брони из Lang",
                        "SetEquipmentStats(cur_item, CT('Script.Mod_ArtiUniqueShipsPack.IgniruvParamsList.HullArmor'), 0);",
                        "bonus_num = FindBonusByNameInCfg('ArtiUniqueShipsPack_IgniruvHull');",
                        "SpecialToEquipment(bonus_num, cur_item);",
                        "//Запоминаем полученную цену",
                        "cost = ItemCost(cur_item);",
                        "//Если в Lang стоимость не задана \"по умолчанию\", то подгружаем её напрямую оттуда",
                        "if(CT('Script.Mod_ArtiUniqueShipsPack.IgniruvParamsList.HullCost') != '-1') cost = abs(0 + CT('Script.Mod_ArtiUniqueShipsPack.IgniruvParamsList.HullCost'));",
                        "",
                        "//Удаляем \"расчётный\" корпус во избежание утечки памяти",
                        "FreeItem(cur_item);",
                        "",
                        "tstr1 = '</color>' + Format(CT('Script.Mod_ArtiUniqueShipsPack.Igniruv.Buy'), '<HullName' + '>', CT('MicroModuls.ArtiUniqueShipsPack_IgniruvHull.ShortName'), '<Cost' + '>', cost);",
                        "tstr2 = '</color>' + CT('Script.Mod_ArtiUniqueShipsPack.Igniruv.BuyPlayerYes');",
                        "tstr3 = '</color>' + CT('Script.Mod_ArtiUniqueShipsPack.Igniruv.BuyPlayerNo');",
                        "DChange(42);",
                        "exit;"
                    ],
                    "#": 236,
                    "Type": "Top",
                    "Parent": -1,
                    "Pos.x": 220,
                    "Pos.y": 550
                },
                {
                    "Name": "",
                    "Code.Type": "Turn",
                    "Code": [
                        "if(GetGameOptions('FontDialog') == '0') tstr5 = '-----------------------------------------------------------';",
                        "else if(GetGameOptions('FontDialog') == '1') tstr5 = '------------------------------------------';",
                        "else if(GetGameOptions('FontDialog') == '2') tstr5 = '-------------------------------------------';",
                        "else tstr5 = '--------------------------------------';",
                        "",
                        "tstr1 = '';",
                        "tstr2 = '';",
                        "j = 0;",
                        "for(i = 0; i <= 8; i = i + 1)",
                        "{",
                        "    if(i < 4)",
                        "    {",
                        "        if(!(IgniruvWasBought & 1 << i))",
                        "        {",
                        "            tint1 = tint1 + 1;",
                        "            if(tstr1 != '') tstr1 = tstr1 + CT(\"Script.Mod_ArtiUniqueShipsPack.2\");",
                        "            tstr1 = tstr1 + tint1 + ') ' + CT('Script.Mod_ArtiUniqueShipsPack.Igniruv.MaterialsList.Material' + (i + 1));",
                        "        }",
                        "    }",
                        "    else",
                        "    {",
                        "        if(!(IgniruvWasBought & 1 << i)) j = j + 1;",
                        "    }",
                        "    if(i == 8)",
                        "    {",
                        "        if(j)",
                        "        {",
                        "            tint1 = tint1 + 1;",
                        "            tstr2 = tstr2 + Format(CT('Script.Mod_ArtiUniqueShipsPack.Igniruv.MaterialsList.Material5'), '<Count' + '>', j);",
                        "            if(tstr1 != '') tstr1 = tstr1 + CT(\"Script.Mod_ArtiUniqueShipsPack.2\");",
                        "            tstr1 = tstr1 + tint1 + ') ' + tstr2;",
                        "        }",
                        "    }",
                        "}",
                        "tstr1 = '</color>' + Format(CT('Script.Mod_ArtiUniqueShipsPack.Igniruv.Unlock'), '<MaterialsList' + '>', tstr1, '<SplitLine' + '>', tstr5, '');",
                        "DChange(45);",
                        "exit;"
                    ],
                    "#": 237,
                    "Type": "Top",
                    "Parent": -1,
                    "Pos.x": 460,
                    "Pos.y": 550
                },
                {
                    "Name": "",
                    "Code.Type": "Turn",
                    "Code": [
                        "cur_item = GAnswerData;",
                        "if(ItemType(cur_item) == t_UselessItem)",
                        "{",
                        "    if(EquipmentImageName(cur_item) == 'Remains_13') IgniruvWasBought = IgniruvWasBought + 1;",
                        "    else if(EquipmentImageName(cur_item) == 'Remains_2') IgniruvWasBought = IgniruvWasBought + 2;",
                        "    else IgniruvWasBought = IgniruvWasBought + 4;",
                        "}",
                        "else",
                        "{",
                        "    if(ItemType(cur_item) == t_ArtefactNano) IgniruvWasBought = IgniruvWasBought + 8;",
                        "    else",
                        "    {",
                        "        for(i = 4; i <= 8; i = i + 1)",
                        "        {",
                        "            if(!(IgniruvWasBought & 1 << i))",
                        "            {",
                        "                IgniruvWasBought = IgniruvWasBought + (1 << i);",
                        "                break;",
                        "            }",
                        "        }",
                        "    }",
                        "}",
                        "//cost = round(1.5 * ItemCost(cur_item));",
                        "//ShipMoney(Player(), ShipMoney(Player()) + cost);",
                        "//Sound('Sound.Sell');",
                        "Sound('Sound.Repair');",
                        "if(ItemType(cur_item) >= t_Hull) FreeItem(GetItemFromShip(Player(), cur_item));",
                        "else FreeItem(GetArtFromShip(Player(), cur_item));",
                        "",
                        "if(IgniruvWasBought == 511)",
                        "{",
                        "    IgniruvWasBought = -(CurTurn() + CT('Script.Mod_ArtiUniqueShipsPack.IgniruvParamsList.ResearchDays'));",
                        "    tstr1 = '</color>' + Format(CT('Script.Mod_ArtiUniqueShipsPack.Igniruv.UnlockDone'), '<ResearchDays' + '>', GameDateTxtByTurn(abs(IgniruvWasBought)), '<HullName' + '>', CT('MicroModuls.ArtiUniqueShipsPack_IgniruvHull.ShortName'));",
                        "}",
                        "else",
                        "{",
                        "    tstr1 = '';",
                        "    tstr2 = '';",
                        "    tint1 = 0;",
                        "    j = 0;",
                        "    for(i = 0; i <= 8; i = i + 1)",
                        "    {",
                        "        if(i < 4)",
                        "        {",
                        "            if(!(IgniruvWasBought & 1 << i))",
                        "            {",
                        "                tint1 = tint1 + 1;",
                        "                if(tstr1 != '') tstr1 = tstr1 + CT(\"Script.Mod_ArtiUniqueShipsPack.2\");",
                        "                tstr1 = tstr1 + tint1 + ') ' + CT('Script.Mod_ArtiUniqueShipsPack.Igniruv.MaterialsList.Material' + (i + 1));",
                        "            }",
                        "        }",
                        "        else",
                        "        {",
                        "            if(!(IgniruvWasBought & 1 << i)) j = j + 1;",
                        "        }",
                        "        if(i == 8)",
                        "        {",
                        "            if(j)",
                        "            {",
                        "                tint1 = tint1 + 1;",
                        "                tstr2 = tstr2 + Format(CT('Script.Mod_ArtiUniqueShipsPack.Igniruv.MaterialsList.Material5'), '<Count' + '>', j);",
                        "                if(tstr1 != '') tstr1 = tstr1 + CT(\"Script.Mod_ArtiUniqueShipsPack.2\");",
                        "                tstr1 = tstr1 + tint1 + ') ' + tstr2;",
                        "            }",
                        "        }",
                        "    }",
                        "    tstr1 = '</color>' + Format(CT('Script.Mod_ArtiUniqueShipsPack.Igniruv.Unlock'), '<MaterialsList' + '>', tstr1, '<SplitLine' + '>', tstr5, '');",
                        "}",
                        "if(IgniruvWasBought >= 0) {",
                        "  DChange(45);",
                        "  exit;",
                        "}",
                        "if(IgniruvWasBought < 0) {",
                        "  DChange(46);",
                        "  exit;",
                        "}"
                    ],
                    "#": 238,
                    "Type": "Top",
                    "Parent": -1,
                    "Pos.x": 730,
                    "Pos.y": 550
                },
                {
                    "Name": "",
                    "Code.Type": "Turn",
                    "Code": [
                        "cur_item = CreateHull(6, CT('Script.Mod_ArtiUniqueShipsPack.AscalonParamsList.HullSize'), 8, GetValueFromScript('', CT('Script.Mod_ArtiUniqueShipsPack.AscalonParamsList.HullRace')), -1, CT('Script.Mod_ArtiUniqueShipsPack.AscalonParamsList.PirateClanAssembly'));",
                        "//Выставляем корпусу значение брони из Lang",
                        "SetEquipmentStats(cur_item, CT('Script.Mod_ArtiUniqueShipsPack.AscalonParamsList.HullArmor'), 0);",
                        "SpecialToEquipment(FindBonusByNameInCfg('ArtiUniqueShipsPack_AscalonHull'), cur_item);",
