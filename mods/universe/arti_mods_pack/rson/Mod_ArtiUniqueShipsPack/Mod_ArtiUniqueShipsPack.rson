                        "ItemExtraSpecialsAddByType(cur_item, FindBonusByNameInCfg('ArtiUniqueShipsPack_FriendHullPirateSpawnIsOff'));",
                        "//Если в Lang стоимость не задана \"по умолчанию\", то подгружаем её напрямую оттуда",
