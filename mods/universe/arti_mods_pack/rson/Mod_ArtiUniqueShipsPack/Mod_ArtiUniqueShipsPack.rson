                {
                    "Name": "",
                    "Code.Type": "Turn",
                    "Code": [
                        "for(i = 0; i < ShipItems(Player()); i = i + 1)",
                        "{",
                        "    cur_item = ShipItems(Player(), i);",
                        "    if(ItemInScript(cur_item)) continue;",
                        "    if(ItemType(cur_item) < t_Weapon1 || ItemType(cur_item) > t_CustomWeapon) continue;",
                        "    if((ItemOwner(cur_item) == PirateClan && ZionPirateGuns) || (ItemOwner(cur_item) == Kling && ZionDomikGuns)) continue;",
                        "    {",
                        "        if(GetEquipmentStats(cur_item, 3) < 1) continue;",
                        "        cost = round(1.5 * ItemCost(cur_item));",
                        "        tstr1 = DeleteTags(ItemFullName(cur_item));",
                        "        tstr1 = Format(CT('Script.Mod_ArtiUniqueShipsPack.Zion.PlayerMaterialsGive'), '<GunName' + '>', tstr1, '<Cost' + '>', cost);",
                        "        InjectAnswer('ZionUnlockDoneDialog', tstr1, cur_item);",
                        "    }",
                        "}",
