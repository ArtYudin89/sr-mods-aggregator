                },
                {
                    "Name": "",
                    "Code.Type": "Turn",
                    "Code": [
                        "cur_item = GAnswerData;",
                        "if(ItemOwner(cur_item) == PirateClan) ZionPirateGuns = max(ZionPirateGuns - 1, 0);",
                        "else ZionDomikGuns = max(ZionDomikGuns - 1, 0);",
                        "cost = round(1.5 * ItemCost(cur_item));",
                        "ShipMoney(Player(), ShipMoney(Player()) + cost);",
                        "Sound('Sound.Sell');",
                        "FreeItem(GetItemFromShip(Player(), cur_item));",
                        "",
                        "if(!ZionPirateGuns && !ZionDomikGuns)",
                        "{",
                        "    ZionWasBought = 1;",
                        "    tstr1 = '</color>' + Format(CT('Script.Mod_ArtiUniqueShipsPack.Zion.UnlockDone'), '<HullName' + '>', CT('MicroModuls.ArtiUniqueShipsPack_ZionHull.ShortName'));",
                        "}",
                        "else tstr1 = '</color>' + Format(CT('Script.Mod_ArtiUniqueShipsPack.Zion.Unlock'), '<PirateGunsCount' + '>', ZionPirateGuns, '<DomiksGunsCount' + '>', ZionDomikGuns);",
                        "if(ZionPirateGuns || ZionDomikGuns) {",
                        "  DChange(36);",
                        "  exit;",
                        "}",
                        "if(!ZionPirateGuns && !ZionDomikGuns) {",
                        "  DChange(37);",
                        "  exit;",
                        "}"
                    ],
