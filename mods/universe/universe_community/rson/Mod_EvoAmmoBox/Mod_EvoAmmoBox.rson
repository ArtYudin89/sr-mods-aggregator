            "Items": [],
            "Operations": [
                {
                    "Name": "",
                    "Code.Type": "Global",
                    "Code": [
                        "GRun();"
                    ],
                    "#": 29,
                    "Type": "Top",
                    "Parent": -1,
                    "Pos.x": 0,
                    "Pos.y": 610
                },
                {
                    "Name": "",
                    "Code.Type": "Init",
                    "Code": [
                        "if(GetShipRuins(Player())>0) {",
                        "  if(!PlayerBridge()) {",
                        "    if(ShipType(GetShipRuins(Player()))=='WB') {",
                        "      AddDialogInject('AmmoBox',CT(\"Script.Mod_EvoAmmoBox.48\"),'Приобрести контейнеры с амуницией',1);",
                        "    }",
                        "  }",
                        "}"
                    ],
                    "#": 30,
                    "Type": "Top",
                    "Parent": -1,
                    "Pos.x": 60,
                    "Pos.y": 610
                },
                {
                    "Name": "",
                    "Code.Type": "Turn",
                    "Code": [
                        "if (findsubstr(GameDateTxtByTurn(CurTurn()),'1 января')==0) {",
                        "count1=0;",
                        "count2=0;",
                        "count3=0;",
                        "count4=0;",
                        "}",
                        "total1=3+ShipRank(Player());",
                        "total2=2+ShipRank(Player());",
                        "total3=1+ShipRank(Player());",
                        "total4=ShipRank(Player());",
                        "cost1=1.05*GalaxyMoney(2,ShipOwner(GetShipRuins(Player())));",
                        "cost2=1.2*GalaxyMoney(2,ShipOwner(GetShipRuins(Player())));",
                        "cost3=1.12*GalaxyMoney(2,ShipOwner(GetShipRuins(Player())));",
                        "cost4=1.3*GalaxyMoney(2,ShipOwner(GetShipRuins(Player())));",
                        "cur_count1=total1-count1;",
                        "cur_count2=total2-count2;",
                        "cur_count3=total3-count3;",
                        "cur_count4=total4-count4;",
                        "DChange(0);",
                        "exit;"
                    ],
                    "#": 48,
                    "Type": "Top",
                    "Parent": -1,
                    "Pos.x": -20,
                    "Pos.y": 400
                },
                {
                    "Name": "",
                    "Code.Type": "Turn",
                    "Code": [
                        "//Списываем деньги со счета игрока и пополняем контейнеры",
                        "tdw2=(UselessItemData(GAnswerData,1)-UselessItemData(GAnswerData,2))*rCost;",
                        "ShipMoney(Player(),ShipMoney(Player())-tdw2);",
                        "Sound('Sound.Buy');",
                        "UselessItemData(GAnswerData,2,UselessItemData(GAnswerData,1));",
                        "DChange(3);",
                        "exit;"
                    ],
                    "#": 49,
                    "Type": "Top",
                    "Parent": -1,
                    "Pos.x": 100,
                    "Pos.y": 400
                },
                {
                    "Name": "",
                    "Code.Type": "Turn",
                    "Code": [
                        "if(cur_count1==0)AddDialogBlock('Купить контейнер с боеголовками',1);",
                        "if(cur_count2==0)AddDialogBlock('Купить контейнер с ракетами',1);",
                        "if(cur_count3==0)AddDialogBlock('Купить контейнер со сферами',1);",
                        "if(cur_count4==0)AddDialogBlock('Купить контейнер с торпедами',1);",
                        "DAdd(0);",
                        "DAdd(3);",
                        "DAdd(4);",
                        "DAdd(5);",
                        "tint=0;",
                        "tstr2='';",
                        "if(GetGameOptions('FontDialog')==0)tstr3='<clrEnd>-------------------------------------------------------------';",
                        "else if(GetGameOptions('FontDialog')==1)tstr3='<clrEnd>------------------------------------------';",
                        "else if(GetGameOptions('FontDialog')==2)tstr3='<clrEnd>-----------------------------------------';",
                        "else tstr3='<clrEnd>-------------------------------------';",
                        "//Цена за пополнение",
                        "tdw=GalaxyTechLevel();",
                        "if(tdw<2) tdw=2;",
                        "else if(tdw>7) tdw=7;",
                        "rCost=10+(tdw-2)*18;",
                        "//Если у игрока есть неполные контейнеры - добавляем диалог об их пополнении",
                        "for(i=1;i<ShipItems(Player());i=i+1) {",
                        "    tdw=ShipItems(Player(),i);",
                        "    if(ItemType(tdw)!=t_UselessItem)continue;",
                        "    tstr1=EquipmentImageName(tdw);",
                        "    if(tstr1=='Container_lirekron' || tstr1=='Container_missile' || tstr1=='Container_sphere' || tstr1=='Container_torpedo') {",
                        "        tdw2=UselessItemData(tdw,1)-UselessItemData(tdw,2);",
                        "        if(tdw2) {",
                        "            tint=tint+1;",
                        "            tstr2=tstr2+'</color>'+tint+') '+Name(tdw)+Format(' <0></color>',\"<0>\",UselessItemData(tdw,2))+'/'+Format('<0></color>',\"<0>\",UselessItemData(tdw,1))+Format(' за <0> cr.',\"<0>\",rCost*tdw2)+CT(\"Script.Mod_EvoAmmoBox.64\");",
                        "        }",
                        "    }",
                        "}",
                        "if(tint) {",
                        "  DAdd(7);",
                        "}",
                        "DAdd(1);"
                    ],
                    "#": 50,
                    "Type": "Top",
                    "Parent": -1,
                    "Pos.x": -20,
                    "Pos.y": 470
                },
                {
                    "Name": "",
                    "Code.Type": "Turn",
                    "Code": [
                        "DAdd(2);"
                    ],
                    "#": 51,
                    "Type": "Top",
                    "Parent": -1,
                    "Pos.x": 130,
                    "Pos.y": 470
                },
                {
                    "Name": "",
                    "Code.Type": "Turn",
                    "Code": [
                        "DAdd(6);"
                    ],
                    "#": 52,
                    "Type": "Top",
                    "Parent": -1,
                    "Pos.x": 280,
                    "Pos.y": 470
                },
                {
                    "Name": "",
                    "Code.Type": "Turn",
                    "Code": [
                        "for(i=1;i<ShipItems(Player());i=i+1) {",
                        "    tdw=ShipItems(Player(),i);",
                        "    if(ItemType(tdw)!=t_UselessItem)continue;",
                        "    tstr1=EquipmentImageName(tdw);",
                        "    if(tstr1=='Container_lirekron' || tstr1=='Container_missile' || tstr1=='Container_sphere' || tstr1=='Container_torpedo') {",
                        "        tdw2=UselessItemData(tdw,1)-UselessItemData(tdw,2);",
                        "        if(tdw2) {",
                        "            tstr1=Name(tdw)+Format('  <0> cr.',\"<0>\",rCost*tdw2);",
                        "            if(ShipMoney(Player())<(rCost*tdw2)) AddDialogBlock(tstr1,1);",
                        "            InjectAnswer('RearmAmmoBox',tstr1,tdw);",
                        "        }",
                        "    }",
                        "}",
                        "DAdd(8);"
                    ],
                    "#": 53,
                    "Type": "Top",
                    "Parent": -1,
                    "Pos.x": 430,
                    "Pos.y": 470
                },
                {
                    "Name": "",
                    "Code.Type": "Turn",
                    "Code": [
                        "for(i=1;i<ShipItems(Player());i=i+1) {",
                        "    tdw=ShipItems(Player(),i);",
                        "    if(ItemType(tdw)!=t_UselessItem)continue;",
                        "    tstr1=EquipmentImageName(tdw);",
                        "    if(tstr1=='Container_lirekron' || tstr1=='Container_missile' || tstr1=='Container_sphere' || tstr1=='Container_torpedo') {",
                        "        tdw2=UselessItemData(tdw,1)-UselessItemData(tdw,2);",
                        "        if(tdw2) {",
                        "            tstr1=Name(tdw)+Format('  <0> cr.',\"<0>\",rCost*tdw2);",
                        "            if(ShipMoney(Player())<(rCost*tdw2)) AddDialogBlock(tstr1,1);",
                        "            InjectAnswer('RearmAmmoBox',tstr1,tdw);",
                        "        }",
                        "    }",
                        "}",
                        "DAdd(8);"
                    ],
                    "#": 54,
                    "Type": "Top",
                    "Parent": -1,
                    "Pos.x": 580,
                    "Pos.y": 470
                },
                {
                    "Name": "",
                    "Code.Type": "Turn",
                    "Code": [
                        "if(cost1>ShipMoney(Player())) {",
                        "  DChange(2);",
                        "  exit;",
                        "}",
                        "if(cost1<ShipMoney(Player())) {",
                        "  ammo_box=CreateQuestItem('Container_lirekron');",
                        "  ItemSize(ammo_box,20+GalaxyTechLevel()*2+Rnd(-2,4));",
                        "  UselessItemData(ammo_box,1,ItemSize(ammo_box));",
                        "  UselessItemData(ammo_box,2,ItemSize(ammo_box));",
                        "  UselessItemData(ammo_box,3,Rnd(3,4));//сколько раз можно зарядить этой коробкой",
                        "  AddItemToShip(Player(),ammo_box);",
                        "  ShipMoney(Player(),ShipMoney(Player())-cost1);",
                        "  Sound('Sound.Buy');",
                        "  count1=count1+1;",
                        "  DChange(1);",
                        "  exit;",
                        "}"
                    ],
                    "#": 55,
                    "Type": "Top",
                    "Parent": -1,
                    "Pos.x": -20,
                    "Pos.y": 540
                },
                {
                    "Name": "",
                    "Code.Type": "Turn",
                    "Code": [
                        "if(cost2>ShipMoney(Player())) {",
                        "  DChange(2);",
                        "  exit;",
                        "}",
                        "if(cost2<ShipMoney(Player())) {",
                        "  ammo_box=CreateQuestItem('Container_missile');",
                        "  ItemSize(ammo_box,20+GalaxyTechLevel()*2+Rnd(-2,4));",
                        "  UselessItemData(ammo_box,1,ItemSize(ammo_box));",
                        "  UselessItemData(ammo_box,2,ItemSize(ammo_box));",
                        "  UselessItemData(ammo_box,3,Rnd(3,4));//сколько раз можно зарядить этой коробкой",
                        "  AddItemToShip(Player(),ammo_box);",
                        "  ShipMoney(Player(),ShipMoney(Player())-cost2);",
                        "  Sound('Sound.Buy');",
                        "  count2=count2+1;",
                        "  DChange(1);",
                        "  exit;",
                        "}"
                    ],
