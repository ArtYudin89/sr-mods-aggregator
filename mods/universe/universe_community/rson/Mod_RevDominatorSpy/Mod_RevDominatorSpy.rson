                {
                    "Name": "    if(Hitpoints(CurShip)<200 && Dist(PlaceSB,CurShip)<3000) {\r\n      Dialog(dDiplomat,PelengSpy);\r\n    }\r\n    if(ItemIn(iOP,Player())) {\r\n      ShipSetBad(GroupToShip(PelengSpy),Player());\r\n      ShipOut(GroupToShip(PelengSpy));\r\n    }\r\n    if(vZondDaysPe>=30) {\r\n      ChangeState(5);\r\n      exit;\r\n    }\r\n    if(!ItemExist(iOP)) {\r\n      ShipSetBad(GroupToShip(PelengSpy),Player());\r\n      if(GroupToShip(BigShip))ShipOut(GroupToShip(BigShip));\r\n      if(GroupToShip(SmallShip))\r\n      \t{\r\n      \tfor(i=GroupCount(SmallShip)-1;i>=0;i=i-1)ShipOut(GroupShip(SmallShip,i));\r\n      \t}\r\n      if(GroupToShip(BSB))ShipOut(GroupToShip(BSB));\r\n      if(GroupToShip(PelengSpy))\r\n      \t{\r\n      \tNoTargetToShip(GroupToShip(PelengSpy),0);\r\n      \tShipOut(GroupToShip(PelengSpy));\r\n      \t}\r\n    }\r",
