                {
                    "Name": "",
                    "Code.Type": "Turn",
                    "Code": [
                        "if(!fl_array[owner, 1]) {",
                        "  tstr1 = '</color>' + Format(CT('Script.Mod_ExpAcryn.PelengQuestDialog.FirstQuestExplain'), '<AddIntro'+'>', tstr, '');",
                        "  DChange(3);",
                        "  exit;",
                        "}",
                        "if(fl_array[owner, 1] && fl_array[owner, 1] < 3) {",
