                        "else",
                        "{",
                        "    AddDialogBlock(Format(CT(\"Script.Mod_ExpAcryn.359\"),\"<0>\",tstr,\"<1>\",j),1);",
                        "    InjectAnswer('Flag_cham_2',Format(CT(\"Script.Mod_ExpAcryn.359\"),\"<0>\",tstr,\"<1>\",j),1);",
                        "}",
                        "tstr=CT('FormGalaxy.Boss3');",
                        "if(ShipMoney(Player())>=k)InjectAnswer('Flag_ch_2',Format(CT(\"Script.Mod_ExpAcryn.359\"),\"<0>\",tstr,\"<1>\",k),2);",
                        "else",
                        "{",
                        "    AddDialogBlock(Format(CT(\"Script.Mod_ExpAcryn.359\"),\"<0>\",tstr,\"<1>\",k),1);",
                        "    InjectAnswer('Flag_cham_2',Format(CT(\"Script.Mod_ExpAcryn.359\"),\"<0>\",tstr,\"<1>\",k),2);",
                        "}",
                        "if(GAnswerData<4) {",
                        "  DAdd(16);",
                        "}",
                        "DAdd(36);"
