                },
                {
                    "Name": "",
                    "Code.Type": "Turn",
                    "Code": [
                        "cur_ship = CurShip; //Диалог вызывается из стейта, а, значит, GetTalkShip() вернёт нихуя (спасибо даб)",
                        "",
                        "//Игрок общается со своим же ботом, восполняем ему потраченный \"Интерком\", если таковой был",
                        "if(GetProgramm(5)) SetProgramm(5, GetProgramm(5) + 1);",
                        "if(GFlagFeiTempVar == 2) {",
                        "  //Выставляем длину дефисных разделителей в зависимости от выбранного размера диалогового шрифта",
                        "  if(GetGameOptions('FontDialog') == '0') DefSplt = '</color>------------------------------------------------------------------';",
                        "  else if(GetGameOptions('FontDialog') == '1') DefSplt = '</color>-----------------------------------------------';",
                        "  else if(GetGameOptions('FontDialog') == '2') DefSplt = '</color>-----------------------------------------------';",
                        "  else /*if(GetGameOptions('FontDialog') == '3')*/ DefSplt = '</color>-----------------------------------------';",
                        "  ",
                        "  //Составляем рандомный набор символов на случай, если у игрока на борту нет Р.Д.П.К.",
                        "  tstr3 = '</color>';",
                        "  for(i = 1; i < 50; i = i + 1)",
                        "  {",
                        "      tint = RndObject(1, 100, cur_ship);",
                        "      if(tint <= 50)",
                        "      {",
                        "          if(RndObject(0, 1, cur_ship)) tstr3 = tstr3 + CT('Smb.' + RndObject(1, 30, cur_ship));",
                        "          else tstr3 = tstr3 + uppercase(CT('Smb.' + RndObject(1, 26, cur_ship)));",
                        "      }",
                        "      else tstr3 = tstr3 + RndObject(1, 99, cur_ship);",
                        "      if(tint >= 45 && tint <= 55) tstr3 = tstr3 + '_';",
                        "  }",
                        "  ",
                        "  //Усложнённая система выбора случайного уравнения, чтобы не могли обойти сейвлоадом",
                        "  tint2 = CT('Formuls.Frm_1.count');",
                        "  tint2 = 1 + (GroupToShip(q_ship) / 4) % tint2;",
                        "  tint = RndObject(1, tint2, cur_ship);",
                        "  tstr = CT('Formuls.Frm_1.' + tint);",
                        "  tstr2 = CT('Formuls.Answ_1.' + tint);",
                        "  ",
                        "  //Формируем нормальную строку",
                        "  tstr = DefSplt + Format(CT(\"Script.Mod_ExpAcryn.670\"),\"<0>\",Name(GroupToShip(q_ship)),\"<1>\",tstr) + DefSplt;",
                        "  ",
                        "  //Если на борту нет Р.Д.П.К., то превращаем строку в рандомные символы",
                        "  if(!ItemIn(Q_item, Player())) tstr = DefSplt + Format('<br>') + tstr3 + Format('<br>') + DefSplt;",
                        "  DChange(14);",
                        "  exit;",
                        "}",
                        "if(GFlagFeiTempVar != 2) {",
                        "  if(GFlagFeiTempVar >= 5) {",
                        "    DChange(59);",
                        "    exit;",
                        "  }",
                        "  if(GFlagFeiTempVar < 5) {",
                        "    DChange(26);",
                        "    exit;",
                        "  }",
                        "}"
                    ],
