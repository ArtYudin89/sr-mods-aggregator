                    "Type": "TDialogAnswer",
                    "Parent": -1,
                    "#": 197,
                    "Msg": "Конец связи",
                    "AMsg.Num": "60",
                    "_orig_danswer": "DAnswer('fastexit~'+CT(\"Script.Mod_ExpAcryn.55\"))"
                },
                {
                    "Name": "fastexit",
                    "Pos.x": 120,
                    "Pos.y": 815,
                    "Type": "TDialogAnswer",
                    "Parent": -1,
                    "#": 198,
                    "Msg": "<0>",
                    "AMsg.Num": "61",
                    "_orig_danswer": "DAnswer('fastexit~'+Format(CT(\"Script.Mod_ExpAcryn.266\"),\"<0>\",tstr2))"
                },
                {
                    "Name": "",
                    "Pos.x": 240,
                    "Pos.y": 815,
                    "Type": "TDialogAnswer",
                    "Parent": -1,
                    "#": 199,
                    "Msg": "<0>",
                    "AMsg.Num": "62",
                    "_orig_danswer": "DAnswer(Format(CT(\"Script.Mod_ExpAcryn.266\"),\"<0>\",tstr2))"
                },
                {
                    "Name": "",
                    "Pos.x": 360,
                    "Pos.y": 815,
                    "Type": "TDialogAnswer",
                    "Parent": -1,
                    "#": 200,
                    "Msg": "Да, конечно! Это же будет величайшее открытие со времён изобретения технологии по созданию гиперпространственных пузырей!",
                    "AMsg.Num": "63",
                    "_orig_danswer": "DAnswer(CT(\"Script.Mod_ExpAcryn.806\"))"
                }
            ],
