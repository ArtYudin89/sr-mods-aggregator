                        "}",
                        "if(fl_array[owner, 1] && fl_array[owner, 1] < 3) {",
                        "  if(fl_array[owner, 2] >= StuffRequiredCount && !ItemIn(Q_item, Player())) {",
                        "    DChange(36);",
                        "    exit;",
                        "  }",
                        "  if(fl_array[owner, 2] < StuffRequiredCount) {",
                        "    tint = StuffRequiredCount - fl_array[owner, 2];",
                        "    if(tint == 1) tstr2 = '</color>' + CT(\"Script.Mod_ExpAcryn.802\");",
                        "    else if(tint >= 2 && tint <= 4) tstr2 = '</color>' + CT(\"Script.Mod_ExpAcryn.801\");",
                        "    else if(tint == 5) tstr2 = '</color>' + CT(\"Script.Mod_ExpAcryn.800\");",
                        "    tstr1 = '</color>' + Format(CT(\"Script.Mod_ExpAcryn.834\"),\"<0>\",tint,\"<1>\",tstr2);",
                        "    DChange(16);",
                        "    exit;",
                        "  }",
                        "  if(fl_array[owner, 2] >= StuffRequiredCount && ItemIn(Q_item, Player())) {",
                        "    //Завершаем миссию и выдаём награду",
                        "    EndFlagmanMission();",
                        "    ",
                        "    //Формируются строчки уведомления о награде и о предложении выполнить квесты других флагманов (последнее, если игрок уже выполнил задание текущей расы два раза)",
                        "    //Награда этой расой вручается первый раз",
                        "    if(fl_array[owner, 1] == 2) tstr1 = '</color>' + Format(CT(\"Script.Mod_ExpAcryn.858\"),\"<0>\",lowercase(substr(DeleteTags(Name(tdwd2)),0,1))+substr(DeleteTags(Name(tdwd2)),1));",
                        "    //Награда этой расой вручается уже второй раз",
                        "    else if(fl_array[owner, 1] == 3) tstr1 = '</color>' + Format(CT('Script.Mod_ExpAcryn.GaalQuestDialog.SecondQuestComplete'), '<Reward'+'>', lowercase(substr(DeleteTags(Name(tdwd2)), 0, 1)) + substr(DeleteTags(Name(tdwd2)), 1));",
                        "    ",
                        "    //Награда была вручена первый раз и ещё есть \"место\" под вручение второй награды",
                        "    if(fl_array[owner, 1] == 2 && item_count < 3)",
                        "    {",
                        "        tstr1 = tstr1 + ' ' + Format(CT('Script.Mod_ExpAcryn.GaalQuestDialog.SecondQuestExplain'), '<Reward'+'>', '');",
                        "        CT(\"Script.Mod_ExpAcryn.853\");",
                        "        tstr2 = '</color>' + CT(\"Script.Mod_ExpAcryn.821\");",
                        "    }",
                        "    //Награда этой расой вручена второй раз, направляем игрока к другим флагманам",
                        "    else if(fl_array[owner, 1] == 3 && item_count < 3)",
                        "    {",
                        "        tstr1 = tstr1 + Format('<br>') + CT(\"Script.Mod_ExpAcryn.857\");",
                        "        tstr2 = '</color>' + CT(\"Script.Mod_ExpAcryn.819\");",
                        "    }",
                        "    //Награда этой расой была вручена первый раз, но все награды в партии игроку уже выданы",
                        "    else if(fl_array[owner, 1] == 2 && item_count == 3)",
                        "    {",
                        "        tstr1 = tstr1 + ' ' + CT(\"Script.Mod_ExpAcryn.818\");",
                        "        tstr2 = '</color>' + CT(\"Script.Mod_ExpAcryn.817\");",
                        "    }",
                        "    //Награда этой расой вручена второй раз, но все награды в партии игроку уже выданы",
                        "    else if(fl_array[owner,1]==3 && item_count==3)",
                        "    {",
                        "        tstr1 = tstr1 + '';",
                        "        tstr2 = '</color>' + CT(\"Script.Mod_ExpAcryn.816\");",
                        "    }",
                        "    ",
                        "    //Выводим уведомление об успешном выполнении миссии (первой или второй)",
                        "    if(fl_array[owner, 1] == 2) Ether(4, 'ExpAcryn_quest_4', CT('Script.Mod_ExpAcryn.MissionAccomplished') + CT('Script.Mod_ExpAcryn.GaalMission'));",
                        "    else Ether(4, 'ExpAcryn_quest_4', CT('Script.Mod_ExpAcryn.MissionAccomplished') + Format(CT('Script.Mod_ExpAcryn.GaalMission2'), '<Reward'+'>', addItemName));",
                        "    DChange(17);",
                        "    exit;",
                        "  }",
                        "}"
                    ],
                    "#": 210,
                    "Type": "Top",
                    "Parent": -1,
                    "Pos.x": 880,
                    "Pos.y": 425
                },
                {
                    "Name": "",
                    "Code.Type": "Turn",
                    "Code": [
                        "if(GAnswerData == 1) {",
                        "  DChange(19);",
                        "  exit;",
                        "}",
                        "if(GAnswerData == 2) {",
                        "  tint1 = PirateStuffRequiredCount - fl_array[owner, 2];",
                        "  if(tint1 == 1) tstr1 = CT('Script.Mod_ExpAcryn.PirateClanQuestDialog.QuestRemindQuantityOne');",
                        "  else if(tint1 >= 2 && tint1 <= 4) tstr1 = CT('Script.Mod_ExpAcryn.PirateClanQuestDialog.QuestRemindQuantityTwoPlus');",
                        "  else if(tint1 >= 5) tstr1 = CT('Script.Mod_ExpAcryn.PirateClanQuestDialog.QuestRemindQuantityFivePlus');",
                        "  ",
                        "  tstr1 = '</color>' + Format(CT('Script.Mod_ExpAcryn.PirateClanQuestDialog.QuestRemind'), '<CountLeft'+'>', '<color=0,50,200>' + tint1 + '</color>', '<QuantityDeclination'+'>', tstr1, '');",
                        "  tstr2 = '</color>' + CT('Script.Mod_ExpAcryn.PirateClanQuestDialog.PlayerQuestRemindEnd');",
                        "  DChange(21);",
                        "  exit;",
                        "}",
                        "if(GAnswerData == 3) {",
                        "  //Завершаем миссию и выдаём награду",
                        "  EndFlagmanMission();",
                        "  ",
                        "  //Награда пиратами вручается в первый раз",
                        "  if(fl_array[owner, 1] == 2)",
                        "  {",
                        "      tstr1 = '</color>' + Format(CT('Script.Mod_ExpAcryn.PirateClanQuestDialog.SecondQuestExplain'), '<Reward'+'>', lowercase(substr(DeleteTags(Name(tdwd2)), 0, 1)) + substr(DeleteTags(Name(tdwd2)), 1));",
                        "      tstr2 = '</color>' + CT('Script.Mod_ExpAcryn.PirateClanQuestDialog.PlayerSecondQuestExplain');",
                        "  }",
                        "  //Награда пиратами вручается во второй раз",
                        "  else if(fl_array[owner, 1] == 3)",
                        "  {",
                        "      tstr1 = '</color>' + Format(CT('Script.Mod_ExpAcryn.PirateClanQuestDialog.ThirdQuestExplain'), '<Reward'+'>', lowercase(substr(DeleteTags(Name(tdwd2)), 0, 1)) + substr(DeleteTags(Name(tdwd2)), 1));",
                        "      tstr2 = '</color>' + CT('Script.Mod_ExpAcryn.PirateClanQuestDialog.PlayerThirdQuestExplain');",
                        "  }",
                        "  //Награда пиратами вручается в третий раз",
                        "  else",
                        "  {",
                        "      tstr1 = '</color>' + Format(CT('Script.Mod_ExpAcryn.PirateClanQuestDialog.LastQuestDone'), '<Reward'+'>', lowercase(substr(DeleteTags(Name(tdwd2)), 0, 1)) + substr(DeleteTags(Name(tdwd2)), 1));",
                        "      tstr2 = '</color>' + CT('Script.Mod_ExpAcryn.PirateClanQuestDialog.PlayerLastQuestDone');",
                        "  }",
                        "  ",
                        "  //Повышаем репутацию на всех пиратских планетах (т.к. они все наследуют отношение от Роджерии)",
                        "  if(fl_array[owner, 1] == 2) tint1 = 30;",
                        "  else if(fl_array[owner, 1] == 3) tint1 = 50;",
                        "  else tint1 = 70;",
                        "  ",
                        "  RelationToRanger(PlanetPirateClan(), Player(), RelationToRanger(PlanetPirateClan(), Player()) + tint1);",
                        "  if(RelationToRanger(PlanetPirateClan(), Player()) > 100) RelationToRanger(PlanetPirateClan(), Player(), 100);",
                        "  tdwd2 = GetShipRuins(Player());",
                        "  ",
                        "  //И на текущем доминионе",
                        "  RelationToRanger(tdwd2, Player(), RelationToRanger(tdwd2, Player()) + tint1);",
                        "  if(RelationToRanger(tdwd2, Player()) > 100) RelationToRanger(tdwd2, Player(), 100);",
                        "  ",
                        "  //Выводим уведомление о продлении и об успешном выполнении миссии (если была выполнена уже третья)",
                        "  if(fl_array[owner, 1] == 2) Ether(3, 'ExpAcryn_quest_5', CT('Script.Mod_ExpAcryn.MissionIsActive') + CT('Script.Mod_ExpAcryn.PirateMission2'));",
                        "  else if(fl_array[owner, 1] == 3) Ether(3, 'ExpAcryn_quest_5', CT('Script.Mod_ExpAcryn.MissionIsActive') + CT('Script.Mod_ExpAcryn.PirateMission3'));",
                        "  else Ether(4, 'ExpAcryn_quest_5', CT('Script.Mod_ExpAcryn.MissionAccomplished') + CT('Script.Mod_ExpAcryn.PirateMission3'));",
                        "  DChange(22);",
                        "  exit;",
                        "}",
                        "if(GAnswerData == 4) {",
                        "  DChange(57);",
                        "  exit;",
                        "}"
                    ],
                    "#": 211,
                    "Type": "Top",
                    "Parent": -1,
                    "Pos.x": 1000,
                    "Pos.y": 425
                },
                {
                    "Name": "",
                    "Code.Type": "Turn",
                    "Code": [
                        "if(GAnswerData==1) {",
                        "  DChange(50);",
                        "  exit;",
                        "}",
                        "if(GAnswerData!=1) {",
                        "  tint=max(1000,GalaxyMoney(2,3));",
                        "  tint=round(1.20*tint);",
                        "  tint=tint+(tint*PlayerChameleonCharges(0))/10;",
                        "  ",
                        "  //У пеленгов цена камуфляжа будет всегда выше, а у фэян и гаальцев ниже базовой",
                        "  if(owner==1)tint=round(1.30*tint);",
                        "  else if(owner==3)tint=round(0.75*tint);",
                        "  else if(owner==4)tint=round(0.90*tint);",
                        "  i=tint;",
                        "  tstr='</color>'+Format(CT(\"Script.Mod_ExpAcryn.362\"),\"<0>\",tint);",
                        "  tint=max(1000,GalaxyMoney(2,3));",
                        "  tint=round(1.10*tint);",
                        "  tint=tint+(tint*PlayerChameleonCharges(1))/10;",
                        "  if(owner==1)tint=round(1.30*tint);",
                        "  else if(owner==3)tint=round(0.75*tint);",
                        "  else if(owner==4)tint=round(0.90*tint);",
                        "  j=tint;",
                        "  tstr=tstr+CT(\"Script.Mod_ExpAcryn.147\")+Format(CT(\"Script.Mod_ExpAcryn.361\"),\"<0>\",tint);",
                        "  tint=max(1000,GalaxyMoney(2,3));",
                        "  tint=round(1.30*tint);",
                        "  tint=tint+(tint*PlayerChameleonCharges(2))/10;",
                        "  if(owner==1)tint=round(1.30*tint);",
                        "  else if(owner==3)tint=round(0.75*tint);",
                        "  else if(owner==4)tint=round(0.90*tint);",
                        "  k=tint;",
                        "  tstr=tstr+CT(\"Script.Mod_ExpAcryn.147\")+Format(CT(\"Script.Mod_ExpAcryn.360\"),\"<0>\",tint);",
                        "  ",
                        "  if(GetGameOptions('FontDialog') == '0') DefSplt = '</color>------------------------------------------------------------------';",
                        "  else if(GetGameOptions('FontDialog') == '1') DefSplt = '</color>-----------------------------------------------';",
                        "  else if(GetGameOptions('FontDialog') == '2') DefSplt = '</color>-----------------------------------------------';",
                        "  else /*if(GetGameOptions('FontDialog') == '3')*/ DefSplt = '</color>-----------------------------------------';",
                        "  ",
                        "  tstr2 = '</color>';",
                        "  tstr3 = '</color>' + CT(\"Script.Mod_ExpAcryn.370\");",
                        "  if(GAnswerData)",
                        "  {",
                        "      if(GAnswerData == 2)",
                        "      {",
                        "          //Игрок согласился выполнить первое задание фэян или гаальцев",
                        "          if(ExpAcrynQuestStatus == 3 || ExpAcrynQuestStatus == 4)",
                        "          {",
                        "              tstr2=tstr2+Format(CT(\"Script.Mod_ExpAcryn.730\"),\"<0>\",DefSplt,\"<1>\",tstr,\"<2>\",DefSplt);",
                        "              tstr3='</color>'+CT(\"Script.Mod_ExpAcryn.370\");",
                        "          }",
                        "          //Игрок согласился выполнить первое задание пеленгов или людей",
                        "          else",
                        "          {",
                        "              tstr2=tstr2+Format(CT(\"Script.Mod_ExpAcryn.593\"),\"<0>\",DefSplt,\"<1>\",tstr,\"<2>\",DefSplt);",
                        "              tstr3='</color>'+CT(\"Script.Mod_ExpAcryn.473\");",
                        "          }",
                        "      }",
                        "      else if(GAnswerData == 3)",
                        "      {",
                        "          //Игрок согласился выполнить второе задание пеленгов",
                        "          tstr2=tstr2+Format(CT(\"Script.Mod_ExpAcryn.409\"),\"<0>\",DefSplt,\"<1>\",tstr,\"<2>\",DefSplt);",
                        "          tdwd=ScriptItemToItem(Q_item);",
                        "          UselessItemData(tdwd,2,0);",
                        "          UselessItemData(tdwd,1,0);",
                        "          Ether(3,'ExpAcryn_quest_1',CT('Script.Mod_ExpAcryn.MissionIsActive')+Format(CT('Script.Mod_ExpAcryn.PelengMission2'),'<Reward'+'>',addItemName));",
                        "          tstr3='</color>'+CT(\"Script.Mod_ExpAcryn.473\");",
                        "      }",
                        "      else if(GAnswerData == 4)",
                        "      {",
                        "          //Игрок согласился выполнить второе задание людей",
                        "          tstr2=tstr2+Format(CT(\"Script.Mod_ExpAcryn.602\"),\"<0>\",DefSplt,\"<1>\",tstr,\"<2>\",DefSplt);",
                        "          PlayerChameleonCharges(0, PlayerChameleonCharges(0) + 1);",
                        "          PlayerChameleonCharges(1, PlayerChameleonCharges(1) + 1);",
                        "          PlayerChameleonCharges(2, PlayerChameleonCharges(2) + 1);",
                        "  ",
                        "          //Выдаём три \"Интеркома\"",
                        "          SetProgramm(5, GetProgramm(5) + StuffRequiredCount);",
                        "          Ether(3,'ExpAcryn_quest_2',CT('Script.Mod_ExpAcryn.MissionIsActive')+Format(CT('Script.Mod_ExpAcryn.PeopleMission2'),'<Reward'+'>',addItemName));",
                        "          tstr3='</color>'+CT(\"Script.Mod_ExpAcryn.583\");",
                        "      }",
                        "      else if(GAnswerData == 5)",
                        "      {",
                        "          //Игрок согласился выполнить второе задание фэян или гаальцев",
                        "          tstr2=tstr2+Format(CT(\"Script.Mod_ExpAcryn.718\"),\"<0>\",DefSplt,\"<1>\",tstr,\"<2>\",DefSplt);",
                        "          tstr3='</color>'+CT(\"Script.Mod_ExpAcryn.846\");",
                        "      }",
                        "      else if(GAnswerData == 10) tstr2 = tstr2 + Format(CT(\"Script.Mod_ExpAcryn.402\"),\"<0>\",DefSplt,\"<1>\",tstr,\"<2>\",DefSplt);",
                        "  }",
                        "  else tstr2=tstr2+Format(CT(\"Script.Mod_ExpAcryn.594\"),\"<0>\",DefSplt,\"<1>\",tstr,\"<2>\",DefSplt);",
                        "  DChange(23);",
                        "  exit;",
                        "}"
