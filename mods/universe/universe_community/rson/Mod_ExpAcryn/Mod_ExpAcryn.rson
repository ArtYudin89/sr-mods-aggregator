                        "tstr = '</color>' + CT(\"Script.Mod_ExpAcryn.738\");",
                        "tstr3 = '</color>' + CT(\"Script.Mod_ExpAcryn.748\");",
                        "Ether(3, 'ExpAcryn_quest_3', CT('Script.Mod_ExpAcryn.MissionIsActive') + Format(CT('Script.Mod_ExpAcryn.FeiMission2'), '<Reward'+'>', addItemName));",
                        "DChange(62);",
                        "exit;"
                    ],
                    "#": 315,
                    "Type": "Top",
                    "Parent": -1,
                    "Pos.x": 1420,
                    "Pos.y": 790
                },
                {
                    "Name": "",
                    "Code.Type": "Turn",
                    "Code": [
                        "//Снова можно получать задания у других флагманов",
                        "ExpAcrynQuestStatus=5;",
                        "//Удаляем Р.Д.П.К. из трюма",
                        "tdwd=ScriptItemToItem(Q_item);",
                        "ReleaseItemFromScript(Q_item);",
                        "FreeItem(GetItemFromShip(Player(),FindItemInShip(Player(),tdwd)));",
                        "tstr='</color>'+CT(\"Script.Mod_ExpAcryn.746\");",
                        "tstr3='</color>'+CT(\"Script.Mod_ExpAcryn.55\");",
                        "DChange(62);",
                        "exit;"
                    ],
                    "#": 316,
                    "Type": "Top",
                    "Parent": -1,
                    "Pos.x": 1540,
                    "Pos.y": 790
                },
                {
                    "Name": "",
                    "Code.Type": "Turn",
                    "Code": [
                        "//Снова можно получать задания у других флагманов",
                        "ExpAcrynQuestStatus=5;",
                        "//Удаляем конвектор из трюма",
                        "tdwd=ScriptItemToItem(Q_item);",
                        "ReleaseItemFromScript(Q_item);",
                        "FreeItem(GetItemFromShip(Player(),FindItemInShip(Player(),tdwd)));",
                        "//Игрок отказался от доп. задания - повышаем его репутацию на всех гаальских планетах",
                        "for(i=0; i<GalaxyStars(); i=i+1)",
                        "{",
                        "    tdwd=GalaxyStar(i);",
                        "    if(StarOwner(tdwd)!=0) continue;",
                        "    for(j=0; j<StarPlanets(tdwd); j=j+1)",
                        "    {",
                        "        tdwd2=StarPlanets(tdwd,j);",
                        "        if(PlanetOwner(tdwd2)!=owner) continue;",
                        "        RelationToRanger(tdwd2,Player(),RelationToRanger(tdwd2,Player())+40);",
                        "        if(RelationToRanger(tdwd2,Player())>100) RelationToRanger(tdwd2,Player(),100);",
                        "    }",
                        "}",
                        "tstr='</color>'+CT(\"Script.Mod_ExpAcryn.805\");",
                        "tstr3='</color>'+CT(\"Script.Mod_ExpAcryn.55\");",
                        "DChange(66);",
                        "exit;"
                    ],
                    "#": 317,
                    "Type": "Top",
                    "Parent": -1,
                    "Pos.x": 220,
                    "Pos.y": 815
                },
                {
                    "Name": "",
                    "Code.Type": "Turn",
                    "Code": [
                        "//Обнуляем хранилище памяти в конвекторе",
                        "tdwd = ScriptItemToItem(Q_item);",
                        "UselessItemData(tdwd, 1, 0);",
                        "",
                        "//Выдаём три \"Интеркома\"",
                        "SetProgramm(5, GetProgramm(5) + StuffRequiredCount);",
                        "",
                        "//Начисляем по три камуфляжа каждой серии",
                        "PlayerChameleonCharges(0, PlayerChameleonCharges(0) + 3);",
                        "PlayerChameleonCharges(1, PlayerChameleonCharges(1) + 3);",
                        "PlayerChameleonCharges(2, PlayerChameleonCharges(2) + 3);",
                        "",
                        "tstr = '</color>' + CT(\"Script.Mod_ExpAcryn.854\");",
                        "tstr3 = '</color>' + CT(\"Script.Mod_ExpAcryn.808\");",
                        "Ether(3, 'ExpAcryn_quest_4', CT('Script.Mod_ExpAcryn.MissionIsActive') + Format(CT('Script.Mod_ExpAcryn.GaalMission2'), '<Reward'+'>', addItemName));",
                        "DChange(66);",
                        "exit;"
                    ],
                    "#": 318,
                    "Type": "Top",
                    "Parent": -1,
                    "Pos.x": 340,
                    "Pos.y": 815
                }
            ],
