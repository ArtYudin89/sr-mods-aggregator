                {
                    "Name": "",
                    "Code.Type": "Turn",
                    "Code": [
                        "if(fl_array[owner, 1] == 2 && item_count < 3) {",
                        "  DAdd(63);",
                        "  DAdd(62);",
                        "}",
                        "if(fl_array[owner, 1] != 2 || item_count == 3) {",
                        "  //Снова можно получать задания у других флагманов",
                        "  ExpAcrynQuestStatus=5;",
                        "  //Если уже получил 3 трионки в партии, то задания блокируются",
                        "  if(item_count==3)ExpAcrynQuestStatus=7;",
                        "  //Удаляем конвектор из трюма",
                        "  tdwd=ScriptItemToItem(Q_item);",
                        "  ReleaseItemFromScript(Q_item);",
                        "  FreeItem(GetItemFromShip(Player(),FindItemInShip(Player(),tdwd)));",
                        "  //Выдача трионных бонусов флагману, которому игрок сдал задание",
                        "  //Накладываем бонус на ту оборудку, которая доступна для выдачи данной расой",
                        "  tdwd=ShipEqInSlot(GetTalkShip(),fl_array[owner,7]);",
                        "  if(tdwd)",
                        "  {",
                        "      if(EqSpecial(tdwd)>-1)",
                        "      {",
                        "          //Сперва снимаем имеющийся акрин, если он есть",
                        "          //Но только если бонус не является неснимаемым",
                        "          if(CT('MicroModuls.'+BonusNumInCfg(EqSpecial(tdwd))+'.LockedAcryn')!=1 && CT('MicroModuls.'+BonusNumInCfg(EqSpecial(tdwd))+'.LockedAcryn')!=3)SpecialToEquipment(-1,tdwd);",
                        "          else tdwd=0;",
                        "      }",
                        "      if(tdwd)",
                        "      {",
                        "          NoDropItem(tdwd,1);",
                        "          for(i=0;i<7;i=i+1)",
                        "          {",
                        "              if(!MayAddBonusToEq(FindBonusByCustomTag('Fakrin_'+owner+'_'+i),tdwd))continue;",
                        "              if(fl_array[owner,7]!=t_DefGenerator)EqSpecial(tdwd,FindBonusByCustomTag('Fakrin_'+owner+'_'+i));",
                        "              if(fl_array[owner,7]==t_DefGenerator)",
                        "              {",
                        "                  if(Rnd(0,100)<=50)EqSpecial(tdwd,FindBonusByCustomTag('Fakrin_'+owner+'_'+i));",
                        "                  else EqSpecial(tdwd,FindBonusByCustomTag('Fakrin_'+owner+'_'+i+'_2'));",
                        "              }",
                        "              break;",
                        "          }",
                        "      }",
                        "  }",
                        "  tdwd=ShipEqInSlot(GetTalkShip(),fl_array[owner,8]);",
                        "  if(tdwd)",
                        "  {",
                        "      if(EqSpecial(tdwd)>-1)",
                        "      {",
                        "          //Сперва снимаем имеющийся акрин, если он есть",
                        "          //Но только если бонус не является неснимаемым",
                        "          if(CT('MicroModuls.'+BonusNumInCfg(EqSpecial(tdwd))+'.LockedAcryn')!=1 && CT('MicroModuls.'+BonusNumInCfg(EqSpecial(tdwd))+'.LockedAcryn')!=3)SpecialToEquipment(-1,tdwd);",
                        "          else tdwd=0;",
                        "      }",
                        "      if(tdwd)",
                        "      {",
                        "          NoDropItem(tdwd,1);",
                        "          for(i=0;i<7;i=i+1)",
                        "          {",
                        "              if(EqSpecial(tdwd)>-1)SpecialToEquipment(-1,tdwd);//Сперва снимаем имеющийся акрин, если он есть",
                        "              if(!MayAddBonusToEq(FindBonusByCustomTag('Fakrin_'+owner+'_'+i),tdwd))continue;",
                        "              if(fl_array[owner,8]!=t_DefGenerator)EqSpecial(tdwd,FindBonusByCustomTag('Fakrin_'+owner+'_'+i));",
                        "              if(fl_array[owner,8]==t_DefGenerator)",
                        "              {",
                        "                  if(Rnd(0,100)<=50)EqSpecial(tdwd,FindBonusByCustomTag('Fakrin_'+owner+'_'+i));",
                        "                  else EqSpecial(tdwd,FindBonusByCustomTag('Fakrin_'+owner+'_'+i+'_2'));",
                        "              }",
                        "              break;",
                        "          }",
                        "      }",
                        "  }",
                        "  //Повышаем репутацию игрока на всех гаальских планетах",
                        "  if(fl_array[owner,1]==2)tint=40;",
                        "  else tint=80;",
                        "  for(i=0;i<GalaxyStars();i=i+1)",
                        "  {",
                        "      tdwd=GalaxyStar(i);",
                        "      if(StarOwner(tdwd)!=0)continue;",
                        "      for(j=0;j<StarPlanets(tdwd);j=j+1)",
                        "      {",
                        "          tdwd2=StarPlanets(tdwd,j);",
                        "          if(PlanetOwner(tdwd2)!=owner)continue;",
                        "          RelationToRanger(tdwd2,Player(),RelationToRanger(tdwd2,Player())+tint);",
                        "          if(RelationToRanger(tdwd2,Player())>100)RelationToRanger(tdwd2,Player(),100);",
                        "      }",
                        "  }",
                        "  DAdd(61);",
                        "}"
                    ],
