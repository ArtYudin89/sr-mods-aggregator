                {
                    "Name": "",
                    "Code.Type": "Turn",
                    "Code": [
                        "if(!GAnswerData) {",
                        "  tstr1 = '</color>' + Format(CT('Script.Mod_ExpAcryn.PeopleQuestDialog.FirstQuestExplain'), '<AddIntro'+'>', tstr, '');",
                        "  DChange(6);",
                        "  exit;",
                        "}",
                        "if(GAnswerData) {",
                        "  //Ищем энергоядра, необходимые по заданию людей",
                        "  //Если нашли, то увеличиваем счетчик предметов и удаляем модификацию из трюма",
                        "  tint2=0;",
                        "  for(i=ShipItems(Player())-1;i>0;i=i-1)",
                        "  {",
                        "      tdwd=ShipItems(Player(),i);",
                        "      if(ItemType(tdwd)!=t_UselessItem)continue;",
                        "      if(EquipmentImageName(tdwd)!='Mod_ExpAcryn_mimi')continue;",
                        "      fl_array[2,2]=fl_array[2,2]+1;",
                        "      FreeItem(GetItemFromShip(Player(),i));",
                        "      tint2=1;",
                        "  }",
                        "  if(fl_array[owner, 2] < StuffRequiredCount) {",
                        "    tint = StuffRequiredCount - fl_array[owner, 2];",
                        "    if(tint == 1) tstr2 = '</color>' + CT(\"Script.Mod_ExpAcryn.557\");",
                        "    else if(tint >= 2 && tint <= 4) tstr2 = '</color>' + CT(\"Script.Mod_ExpAcryn.556\");",
                        "    else if(tint == 5) tstr2 = '</color>' + CT(\"Script.Mod_ExpAcryn.555\");",
                        "    if(tint2) tstr1 = '</color>' + Format(CT(\"Script.Mod_ExpAcryn.589\"),\"<0>\",tint,\"<1>\",tstr2);",
                        "    else tstr1 = '</color>' + Format(CT(\"Script.Mod_ExpAcryn.553\"),\"<0>\",tint,\"<1>\",tstr2);",
                        "    DChange(7);",
                        "    exit;",
                        "  }",
                        "  if(fl_array[owner, 2] >= StuffRequiredCount) {",
                        "    //Завершаем миссию и выдаём награду",
                        "    EndFlagmanMission();",
                        "    ",
                        "    //Формируются строчки уведомления о награде и о предложении выполнить квесты других флагманов (последнее, если игрок уже выполнил задание текущей расы два раза)",
                        "    //Награда этой расой вручается первый раз",
                        "    if(fl_array[owner, 1] == 2) tstr1 = '</color>' + Format(CT(\"Script.Mod_ExpAcryn.576\"),\"<0>\",lowercase(substr(DeleteTags(Name(tdwd2)),0,1))+substr(DeleteTags(Name(tdwd2)),1));",
                        "    ",
                        "    //Награда этой расой вручается уже второй раз",
                        "    else if(fl_array[owner, 1] == 3) tstr1 = '</color>' + Format(CT(\"Script.Mod_ExpAcryn.603\"),\"<0>\",lowercase(substr(DeleteTags(Name(tdwd2)),0,1))+substr(DeleteTags(Name(tdwd2)),1));",
                        "    ",
                        "    //Награда была вручена первый раз и ещё есть \"место\" под вручение второй награды",
                        "    if(fl_array[owner, 1] == 2 && item_count < 3)",
                        "    {",
                        "        tint = tint + 1;",
                        "        if(fl_array[owner, tint] == t_FuelTanks) addItemName = CT(\"Script.Mod_ExpAcryn.454\");",
                        "        else if(fl_array[owner, tint] == t_Engine) addItemName = CT(\"Script.Mod_ExpAcryn.453\");",
                        "        else if(fl_array[owner, tint] == t_Radar) addItemName = CT(\"Script.Mod_ExpAcryn.452\");",
                        "        else if(fl_array[owner, tint] == t_Scaner) addItemName = CT(\"Script.Mod_ExpAcryn.451\");",
                        "        else if(fl_array[owner, tint] == t_RepairRobot) addItemName = CT(\"Script.Mod_ExpAcryn.450\");",
                        "        else if(fl_array[owner, tint] == t_CargoHook) addItemName = CT(\"Script.Mod_ExpAcryn.449\");",
                        "        else if(fl_array[owner, tint] == t_DefGenerator) addItemName = CT(\"Script.Mod_ExpAcryn.448\");",
                        "    ",
                        "        tstr1 = tstr1 + Format('<br>') + Format(CT('Script.Mod_ExpAcryn.PeopleQuestDialog.SecondQuestExplain'), '<Reward'+'>', addItemName);",
                        "        tstr2 = '</color>' + CT('Script.Mod_ExpAcryn.PeopleQuestDialog.PlayerSecondQuestExplainYes');",
                        "        tstr3 = '</color>' + CT('Script.Mod_ExpAcryn.PeopleQuestDialog.PlayerSecondQuestExplainNo');",
                        "    }",
                        "    //Награда этой расой вручена второй раз, направляем игрока к другим флагманам",
                        "    else if(fl_array[owner, 1] == 3 && item_count < 3)",
                        "    {",
                        "        tstr1 = tstr1 + Format('<br>') + CT(\"Script.Mod_ExpAcryn.572\");",
                        "        tstr3 = '</color>' + CT(\"Script.Mod_ExpAcryn.571\");",
                        "    }",
                        "    //Награда этой расой была вручена первый раз, но все награды в партии игроку уже выданы",
                        "    else if(fl_array[owner, 1] == 2 && item_count == 3)",
                        "    {",
                        "        tstr1 = tstr1 + Format('<br>') + CT(\"Script.Mod_ExpAcryn.570\");",
                        "        tstr3 = '</color>' + CT(\"Script.Mod_ExpAcryn.604\");",
                        "    }",
                        "    //Награда этой расой вручена второй раз, но все награды в партии игроку уже выданы",
                        "    else if(fl_array[owner, 1] == 3 && item_count == 3)",
                        "    {",
                        "        tstr1 = tstr1 + '';",
                        "        tstr3 = '</color>' + CT(\"Script.Mod_ExpAcryn.568\");",
                        "    }",
                        "    ",
                        "    //Выводим уведомление об успешном выполнении миссии (первой или второй)",
                        "    if(fl_array[owner, 1] == 2) Ether(4, 'ExpAcryn_quest_2', CT('Script.Mod_ExpAcryn.MissionAccomplished') + CT('Script.Mod_ExpAcryn.PeopleMission'));",
                        "    else Ether(4, 'ExpAcryn_quest_2', CT('Script.Mod_ExpAcryn.MissionAccomplished') + Format(CT('Script.Mod_ExpAcryn.PeopleMission2'), '<Reward'+'>', addItemName));",
                        "    DChange(8);",
                        "    exit;",
                        "  }",
                        "}"
