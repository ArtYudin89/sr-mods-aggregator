                        "tstr=CT('FormGalaxy.Boss1');",
                        "if(ShipMoney(Player())>=i)InjectAnswer('Flag_ch_2',Format(CT(\"Script.Mod_ExpAcryn.359\"),\"<0>\",tstr,\"<1>\",i),0);",
                        "else",
