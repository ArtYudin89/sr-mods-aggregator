                        "    //Награда этой расой вручается первый раз",
                        "    if(fl_array[owner, 1] == 2) tstr1 = '</color>' + Format(CT(\"Script.Mod_ExpAcryn.423\"),\"<0>\",lowercase(substr(DeleteTags(Name(tdwd2)),0,1))+substr(DeleteTags(Name(tdwd2)),1));",
                        "    //Награда этой расой вручается уже второй раз",
                        "    else if(fl_array[owner, 1] == 3) tstr1 = '</color>' + Format(CT(\"Script.Mod_ExpAcryn.495\"),\"<0>\",lowercase(substr(DeleteTags(Name(tdwd2)),0,1))+substr(DeleteTags(Name(tdwd2)),1));",
                        "    ",
