                        "    DChange(34);",
                        "    exit;",
                        "  }",
                        "  if(fl_array[owner, 2] < StuffRequiredCount) {",
                        "    tint = StuffRequiredCount - fl_array[owner, 2];",
                        "    if(tint == 1) tstr2 = '</color>' + CT(\"Script.Mod_ExpAcryn.552\");",
                        "    else if(tint >= 2 && tint <= 4) tstr2 = '</color>' + CT(\"Script.Mod_ExpAcryn.551\");",
                        "    else if(tint == 5) tstr2 = '</color>' + CT(\"Script.Mod_ExpAcryn.550\");",
                        "    tstr1 = '</color>' + Format(CT(\"Script.Mod_ExpAcryn.837\"),\"<0>\",tint,\"<1>\",tstr2);",
                        "    DChange(4);",
                        "    exit;",
                        "  }",
                        "  if(fl_array[owner, 2] >= StuffRequiredCount && ItemIn(Q_item, Player())) {",
