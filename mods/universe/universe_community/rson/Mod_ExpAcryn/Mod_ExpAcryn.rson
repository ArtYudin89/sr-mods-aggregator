            "Operations": [
                {
                    "Name": "",
                    "Code.Type": "Global",
                    "Code": [
                        "GRun();"
                    ],
                    "#": 43,
                    "Type": "Top",
                    "Parent": -1,
                    "Pos.x": 0,
                    "Pos.y": 885
                },
                {
                    "Name": "",
                    "Code.Type": "Init",
                    "Code": [
                        "//Значения массива fl_array:",
                        "//fl_array[0], fl_array[1], fl_array[2], fl_array[3], fl_array[4], fl_array[5] - разделы всех коалиционных рас и пиратов",
                        "//   0 - малоки",
                        "//   1 - пеленги",
                        "//   2 - люди",
                        "//   3 - фэяне",
                        "//   4 - гаальцы",
                        "//   5 - пираты",
                        "//Каждый элемент разбит на 11 подразделов:",
                        "//fl_array[owner, 0] - --- (видимо, Хук оставил пустым, чтобы удобнее было переборы делать :|)",
                        "//fl_array[owner, 1] - статус задания данной расы:",
                        "//   0 - не взято",
                        "//   1 - взято",
                        "//   2 - выполнено один раз",
                        "//   3 - выполнено два раза (за второе выполнение доп. награда - набор)",
                        "//   4 - задание выполнено три раза (только для пиратов)",
                        "//fl_array[owner, 2] - число собранных по заданию предметов/данных/кораблей (обычно от 0 до 5, но у пиратов до 6)",
                        "//fl_array[owner, 3] - ---",
                        "//fl_array[owner, 4] - ---",
                        "//fl_array[owner, 5] - переменная в задании гаальцев, в которую записывается время до раскрытия доминаторами намерений игрока после захвата им бертора (CurTurn() + X)",
                        "//fl_array[owner, 6] - переменная в задании фэян, засекает время, которое робот-шпион проводит на борту бертора перед взлётом или перепрограммированием (CurTurn() + 2)",
                        "//fl_array[owner, 7] - тип первого трионного оборудования, которое игрок сможет получить в этой партии у данной расы",
                        "//fl_array[owner, 8] - тип второго трионного оборудования, которое игрок сможет получить в этой партии у данной расы",
                        "//fl_array[owner, 9] - тип третьего трионного оборудования, которое игрок сможет получить в этой партии у данной расы",
                        "//(если задания берутся у флагманов, то третье оборудования всегда получается у другой расы, не первой, к которой обратился игрок)",
                        "//fl_array[owner, 10] - ---",
                        "",
                        "//Значения переменной ExpAcrynQuestStatus:",
                        "//ExpAcrynQuestStatus == 10 - стартовое значение переменной, означает, что игрок может получить кейс при повышении звания на ВБ",
                        "//ExpAcrynQuestStatus == 11 - игрок получил звание \"Капитан\" и вместе с ним кейс - начало цепочки всех дальнейших событий",
                        "//ExpAcrynQuestStatus == 12 - игрок сдал кейс пиратам, задания флагманов более недоступны (хотя фактически они перестают быть доступны уже после вступления игрока в пиратский клан)",
                        "//ExpAcrynQuestStatus == 0 - игрок в настоящий момент выполняет задание для малокского флагмана",
                        "//ExpAcrynQuestStatus == 1 - игрок в настоящий момент выполняет задание для пеленгского флагмана",
                        "//ExpAcrynQuestStatus == 2 - игрок в настоящий момент выполняет задание для человеческого флагмана",
                        "//ExpAcrynQuestStatus == 3 - игрок в настоящий момент выполняет задание для фэянского флагмана",
                        "//ExpAcrynQuestStatus == 4 - игрок в настоящий момент выполняет задание для гаальского флагмана",
                        "//ExpAcrynQuestStatus == 5 - игрок готов получить задание у любого флагмана (кейс уже сдан на флагман и получить пиратское задание больше нельзя)",
                        "//ExpAcrynQuestStatus == 7 - все дальнейшие задания в партии заблокированы, т.к. сработало одно из завершающих условий;",
                        "",
                        "//Значения переменной GFlagFeiTempVar (фэянская переменная):",
                        "//GFlagFeiTempVar == 0 - базовое состояние, задание ещё не взято, либо по квесту пока ничего не происходит",
                        "//GFlagFeiTempVar == 1 - робот-шпион запущен и сейчас направляется к бертору",
                        "//GFlagFeiTempVar == 2 - робот-шпион добрался до бертора и передаёт игроку код для расшифровки",
                        "//GFlagFeiTempVar == 3 - робот-шпион получил от игрока код и тот оказался верным, совершается посадка на бертора",
                        "//GFlagFeiTempVar == 4 - робот-шпион получил от игрока код и тот оказался неверным, совершается посадка на бертора",
                        "//GFlagFeiTempVar == 5 - робот-шпион извлёк данные из бертора, взлетел, и сейчас возвращается к игроку",
                        "//GFlagFeiTempVar == 6 - робот-шпион садится на игрока после возвращения с данными",
                        "//GFlagFeiTempVar == 7 - робот-шпион совершил успешную посадку на игрока после извлечения данных",
                        "//GFlagFeiTempVar == 8 - что-то пошло не так, и робот-шпион возвращается к игроку не долетев до бертора",
                        "//GFlagFeiTempVar == 9 - робот-шпион вернулся на игрока без данных (трансферим его на планету для уничтожения, а если у игрока в трюме нет Р.Д.П.К., то выводим экран смерти)",
                        "//GFlagFeiTempVar == 10 - робот-шпион вернулся на игрока с данными (трансферим его на планету для уничтожения, а если у игрока в трюме нет Р.Д.П.К., то выводим экран смерти)",
                        "",
                        "//Значения переменной GFlagGaalTempVar (гаальская переменная):",
                        "//GFlagGaalTempVar == 0 - задание гаальцев ещё не взято",
                        "//GFlagGaalTempVar == 1 - задание гаальцев взято, но бертор ещё не захвачен (состояние готовности конвектора к захвату бертора)",
                        "//GFlagGaalTempVar == 2 - бертор захвачен конвектором и следует за игроком",
                        "//GFlagGaalTempVar == 3 - захваченный бертор выполняет приказ игрока на прыжок",
                        "//GFlagGaalTempVar == 4 - захваченный бертор прибыл в другую систему или ещё находится в гипере, но уже точно в другой системе",
                        "//GFlagGaalTempVar == 5 - захваченный бертор уничтожен правильно и должен дропнуть блок памяти (это состояние переменной выставляется акткодом костыльной \"семерёнки\")",
                        "",
                        "//Переменная, обозначающая какой расе был сдан кейс с секретными данными",
                        "caseIn = 10;",
                        "",
                        "//Создаём костыльную \"семерёнку\" для занесения кораблей в скриптовые группы непосредственно из акт и юзкода",
                        "tdwd = CreateQuestItem('Usl_62', 0);",
                        "LinkItemToScript(tdwd, Semerenka);",
                        "PutItemInVault('Mod_ExpAcryn_Semerenka', tdwd);",
                        "ItemOnActCode(Semerenka, 'if(ScriptItemActionType(t_OnStep, 0)){ShipJoin(q_ship, ScriptItemActShip());}if(ScriptItemActionType(t_OnStep, 1)){ShipJoin(q_ship2, ScriptItemActShip());}');",
                        "",
                        "//Выставляем маркер о том, что был подключён мод EvoArmada",
                        "if(BlockExist('Script.Mod_EvoArmada')) EvoArmadaInit = 1;",
                        "",
                        "fl_array = newarray(6, 11);",
                        "//ZeroMemory в стиле даба",
                        "for(i = 0; i < 6; i = i + 1)",
                        "{",
                        "    for(j = 1; j < 11; j = j + 1) fl_array[i, j] = 0;",
                        "}",
                        "",
                        "//Запоминаются типы трионки, которые игрок сможет получить в этой партии:",
                        "//Сперва выбираем три типа оборудования, которые игрок сможет получить лишь в качестве первой трионки (наименее ценные в лейте, но более ценные для начала партии);",
                        "//Радар, сканер или топливный бак;",
                        "//Затем выбираем два типа, более полезных в середине партии, но не особо нужных в конце, вторая трионка;",
                        "//Двигатель или захват;",
                        "//Последняя третья трионка выбирается из двух наиболее полезных в конце партии типов;",
                        "//ГЗП или дроид;",
                        "for(i = 0; i < 6; i = i + 1)",
                        "{",
                        "    //Случайно выбирается первый тип из трёх",
                        "    tint1 = Rnd(0, 2);",
                        "    if(!tint1) fl_array[i, 7] = t_FuelTanks;",
                        "    else if(tint1 == 1) fl_array[i, 7] = t_Scaner;",
                        "    else fl_array[i, 7] = t_Radar;",
                        "    //Случайно выбирается второй тип из двух",
                        "    if(!Rnd(0, 1)) fl_array[i, 8] = t_CargoHook;",
                        "    else fl_array[i, 8] = t_Engine;",
                        "    //Случайно выбирается третий тип из двух",
                        "    if(!Rnd(0, 1)) fl_array[i, 9] = t_RepairRobot;",
                        "    else fl_array[i, 9] = t_DefGenerator;",
                        "}",
                        "",
                        "//Неизвестные модификации раскидываются по берторам",
                        "for(j = 0; j < GalaxyStars(); j = j + 1)",
                        "{",
                        "    tdwd = GalaxyStar(j);",
                        "    for(i = 0; i < StarShips(tdwd); i = i + 1)",
                        "    {",
                        "        tdwd2 = StarShips(tdwd, i);",
                        "        if(ShipTypeN(tdwd2) != t_Kling) continue;",
                        "        if(ShipSubType(tdwd2) != 6) continue;",
                        "",
                        "        tint1 = ItemSubrace(ShipItems(tdwd2, 0));",
                        "        if(!ShipEqInSlot(tdwd2, t_RepairRobot))",
                        "        {",
                        "            tdwd3 = CreateEquipment(t_RepairRobot, RndObject(35, 60, tdwd2), GalaxyTechLevel(), Kling);",
                        "            ItemSubrace(tdwd3, tint1);",
                        "            AddItemToShip(tdwd2, tdwd3);",
                        "            ItemIsInUse(tdwd3, tdwd2, 1);",
                        "        }",
                        "        if(!ShipEqInSlot(tdwd2, t_DefGenerator))",
                        "        {",
                        "            tdwd3 = CreateEquipment(t_DefGenerator, RndObject(35, 60, tdwd2), GalaxyTechLevel(), Kling);",
                        "            ItemSubrace(tdwd3, tint1);",
                        "            AddItemToShip(tdwd2, tdwd3);",
                        "            ItemIsInUse(tdwd3, tdwd2, 1);",
                        "        }",
                        "",
                        "        tint1 = 0;",
                        "        while(!tint1)",
                        "        {",
                        "            tdwd3 = ShipEqInSlot(tdwd2, RndObject(t_FuelTanks, t_DefGenerator, tdwd2));",
                        "            if(tdwd3)",
                        "            {",
                        "                tint1 = 1;",
                        "                tstr2 = '<color=255,167,84>' + Name(tdwd3) + '</color>';",
                        "                EqSpecial(tdwd3, FindBonusByCustomTag('Akrin_dom_ship'));",
                        "                SetName(tdwd3, tstr2);",
                        "                NoDropItem(tdwd3, 1);",
                        "            }",
                        "        }",
                        "    }",
                        "}",
                        "last_ship_id = GalaxyShipId() - 1;",
                        "",
                        "//Функция для завершения миссии флагмана/доминиона и выдачи награды",
                        "function EndFlagmanMission()",
                        "{",
                        "    tdwd2 = 0;",
                        "    tdwd3 = 0;",
                        "",
                        "    //Определяем, какую именно трионку получит игрок (типы записаны в массив при инициации скрипта)",
                        "    if(item_count == 0) tint = 7;",
                        "    else if(item_count == 1) tint = 8;",
                        "    else if(item_count == 2) tint = 9;",
                        "",
                        "    //Если типом выпавшей оборудки оказался сканер или радар, то создаём трионку с весом 15",
                        "    if(fl_array[owner, tint] == t_Scaner || fl_array[owner, tint] == t_Radar)",
                        "    {",
                        "        if(owner <= Gaal) tdwd2 = CreateEquipment(fl_array[owner, tint], 15, GalaxyTechLevel(), owner);",
                        "        else /*if(owner == PirateClan)*/ tdwd2 = CreateEquipment(fl_array[owner, tint], 15, GalaxyTechLevel(), 7);",
                        "    }",
                        "",
                        "    //Иначе - с весом 20",
                        "    else if(owner <= Gaal) tdwd2 = CreateEquipment(fl_array[owner, tint], 20, GalaxyTechLevel(), owner);",
                        "    else /*if(owner == PirateClan)*/ tdwd2 = CreateEquipment(fl_array[owner, tint], 20, GalaxyTechLevel(), 7);",
                        "",
                        "    //Ищем корректный тип бонуса для данного типа оборудки",
                        "    for(i = 0; i < 7; i = i + 1)",
                        "    {",
                        "        if(!MayAddBonusToEq(FindBonusByCustomTag('Fakrin_' + owner + '_' + i), tdwd2)) continue;",
                        "        if(fl_array[owner, tint] != t_DefGenerator) EqSpecial(tdwd2, FindBonusByCustomTag('Fakrin_' + owner + '_' + i));",
                        "        //Если оборудка - ГЗП, то с шансом в 50% вешаем на неё альтернативный вариант бонуса",
                        "        else",
                        "        {",
                        "            if(RndObject(0, 1, Player())) EqSpecial(tdwd2, FindBonusByCustomTag('Fakrin_' + owner + '_' + i));",
                        "            else EqSpecial(tdwd2, FindBonusByCustomTag('Fakrin_' + owner + '_' + i + '_2'));",
                        "        }",
                        "        break;",
                        "    }",
                        "",
                        "    //Переносим готовую трионку на корабль игрока и прокручиваем счётчики",
                        "    AddItemToShip(Player(), tdwd2);",
                        "    item_count = item_count + 1;",
                        "",
                        "    //Если заказчик - флагман",
                        "    if(owner <= Gaal)",
                        "    {",
                        "        fl_array[owner, 2] = fl_array[owner, 2] - StuffRequiredCount;",
                        "        tint2 = 3;",
                        "    }",
                        "    //Если заказчик - пираты",
                        "    else //if(owner == PirateClan)",
                        "    {",
                        "        fl_array[owner, 2] = fl_array[owner, 2] - PirateStuffRequiredCount;",
                        "        tint2 = 4;",
                        "    }",
                        "",
                        "    fl_array[owner, 1] = fl_array[owner, 1] + 1;",
                        "",
                        "    //Игрок выполнил второе (если заказчик пираты, то уже третье) задание и вместе с трионкой получил дополнительную награду - набор для замены системы-блокиратора",
                        "    if(fl_array[owner, 1] == tint2)",
                        "    {",
                        "        tdwd3 = CreateQuestItem('Mod_ExpAcryn_item_' + (tint2 - 2));",
                        "        if(owner < 5) ItemOwner(tdwd3, owner);",
                        "        else ItemOwner(tdwd3, 7);",
                        "        AddItemToShip(Player(), tdwd3);",
                        "    }",
                        "}"
                    ],
                    "#": 44,
                    "Type": "Top",
                    "Parent": -1,
                    "Pos.x": 60,
                    "Pos.y": 885
                },
                {
                    "Name": "",
                    "Code.Type": "Turn",
                    "Code": [
                        "if(!ShipIsTakeoff(Player())) {",
                        "  //Выставляем маркер о том, что был подключён мод EvoArmada",
                        "  if(!EvoArmadaInit)",
                        "  {",
                        "      if(BlockExist('Script.Mod_EvoArmada')) EvoArmadaInit = 1;",
                        "  }",
                        "  ",
                        "  if(ExpAcrynQuestStatus!=7)",
                        "  {",
                        "      //Проверка на прибытие игрока на родную планету для получения звания Капитан (работает только вместе с модом ShuHomeland)",
                        "      //Выдаём игроку чемодан даже в столь необычной ситуации",
                        "      if(HomeGiveCaseCheck>-1)",
                        "      {",
                        "          if(IsScriptActive('Mod_ShuHomeland'))",
                        "          {",
                        "              if(GetValueFromScript('Mod_ShuHomeland','MBExist')==0)",
                        "              {",
                        "                  if(GetShipPlanet(Player())==GetShipHomePlanet(Player()))",
                        "                  {",
                        "                      if(PlanetOwner(GetShipPlanet(Player()))>=0 && PlanetOwner(GetShipPlanet(Player()))<=4)",
                        "                      {",
                        "                          if(RelationToRanger(GetShipPlanet(Player()),Player())>=30)",
                        "                          {",
                        "                              if(ShipOwner(Player())>=0 && ShipOwner(Player())<=4)",
                        "                              {",
                        "                                  if(ShipRank(Player())==2)",
                        "                                  {",
                        "                                      if(ShipRankPoints(Player())>=ShipNextRankPoints(Player()))HomeGiveCaseCheck=1;",
                        "                                  }",
                        "                              }",
                        "                          }",
                        "                      }",
                        "                  }",
                        "                  else if(HomeGiveCaseCheck==1)HomeGiveCaseCheck=0;",
                        "              }",
                        "          }",
                        "      }",
                        "      if(ExpAcrynQuestStatus==11 && HomeGiveCaseCheck==1)HomeGiveCaseCheck=-1;//Выключаем проверочную переменную выдачи кейса на родной планете до конца партии",
                        "  ",
                        "      //Игрок взял задание у флагмана, а потом вступил в пиратский клан (либо уничтожил всех доминаторов) - все задания провалены до конца партии",
                        "      if(ExpAcrynQuestStatus < 6 && (ShipInPirateClan(Player()) || DomiksDefeated()))",
                        "      {",
                        "          if(~EtherState('ExpAcryn_quest_'+ExpAcrynQuestStatus))",
                        "          {",
                        "              if(fl_array[ExpAcrynQuestStatus, 1] == 1) tstr = '';",
                        "              else tstr='2';",
                        "              if(ExpAcrynQuestStatus==0)Ether(5,'ExpAcryn_quest_0',CT('Script.Mod_ExpAcryn.MissionFailed')+Format(CT('Script.Mod_ExpAcryn.MalocMission'+tstr),'<Reward'+'>',addItemName));",
                        "              else if(ExpAcrynQuestStatus==1)Ether(5,'ExpAcryn_quest_1',CT('Script.Mod_ExpAcryn.MissionFailed')+Format(CT('Script.Mod_ExpAcryn.PelengMission'+tstr),'<Reward'+'>',addItemName));",
                        "              else if(ExpAcrynQuestStatus==2)",
                        "              {",
                        "                  Ether(5,'ExpAcryn_quest_2',CT('Script.Mod_ExpAcryn.MissionFailed')+Format(CT('Script.Mod_ExpAcryn.PeopleMission'+tstr),'<Reward'+'>',addItemName));",
                        "                  ShipDeleteCustomShipInfo(Player(),'ExpAcryn_mimi_player_infos');",
                        "              }",
                        "              else if(ExpAcrynQuestStatus==3)Ether(5,'ExpAcryn_quest_3',CT('Script.Mod_ExpAcryn.MissionFailed')+Format(CT('Script.Mod_ExpAcryn.FeiMission'+tstr),'<Reward'+'>',addItemName));",
                        "              else if(ExpAcrynQuestStatus==4)Ether(5,'ExpAcryn_quest_4',CT('Script.Mod_ExpAcryn.MissionFailed')+Format(CT('Script.Mod_ExpAcryn.GaalMission'+tstr),'<Reward'+'>',addItemName));",
                        "          }",
                        "  ",
                        "          //Также понижаем его репутацию на всех планетах соответствующей расы",
                        "          for(i = 0;i < GalaxyStars(); i = i + 1)",
                        "          {",
                        "              tdwd = GalaxyStar(i);",
                        "              if(StarOwner(tdwd) != 0) continue;",
                        "              for(j = 0; j < StarPlanets(tdwd); j = j + 1)",
                        "              {",
                        "                  tdwd2 = StarPlanets(tdwd, j);",
                        "                  if(PlanetOwner(tdwd2) != ExpAcrynQuestStatus) continue;",
                        "                  RelationToRanger(tdwd2, Player(),RelationToRanger(tdwd2, Player()) - 30);",
                        "                  if(RelationToRanger(tdwd2, Player()) < 10) RelationToRanger(tdwd2, Player(), 10);",
                        "              }",
                        "          }",
                        "  ",
                        "          ReleaseItemFromScript(Q_item);",
                        "          ExpAcrynQuestStatus = 7;",
                        "      }",
                        "  ",
                        "      //Игрок выполнял задание пиратов, но те победили/проиграли (либо побеждены домики) - все задания провалены до конца партии",
                        "      if(ExpAcrynQuestStatus == 12 && (PirateWin() || DomiksDefeated()))",
                        "      {",
                        "          if(~EtherState('ExpAcryn_quest_5')) Ether(5, 'ExpAcryn_quest_5', CT('Script.Mod_ExpAcryn.MissionFailed') + CT('Script.Mod_ExpAcryn.PirateMission'));",
                        "          ExpAcrynQuestStatus = 7;",
                        "      }",
                        "  ",
                        "      //Код, исполняемый пока игрок выполняет задание малоков",
                        "      if(!ExpAcrynQuestStatus)",
                        "      {",
                        "          //Задание будет провалено, если уничтожен локализатор",
                        "          if(!ItemExist(Q_item))",
                        "          {",
                        "              //Локализатор уничтожен - все задания флагманов провалены до конца партии",
                        "              if(~EtherState('ExpAcryn_quest_0'))",
                        "              {",
                        "                  tstr = '';",
                        "                  if(fl_array[Maloc, 1] != 1) tstr = '2';",
                        "                  Ether(5,'ExpAcryn_quest_0',CT('Script.Mod_ExpAcryn.MissionFailed')+Format(CT('Script.Mod_ExpAcryn.MalocMission'+tstr),'<Reward'+'>',GetValueFromScript('Mod_ExpAcryn','addItemName')));",
                        "              }",
                        "              //Также снижаем репутацию на всех малокских планетах",
                        "              for(i=0; i<GalaxyStars(); i=i+1)",
                        "              {",
                        "                  tdwd=GalaxyStar(i);",
                        "                  if(StarOwner(tdwd)!=0) continue;",
                        "                  for(int j=0; j<StarPlanets(tdwd); j=j+1)",
                        "                  {",
                        "                      tdwd2=StarPlanets(tdwd,j);",
                        "                      if(PlanetOwner(tdwd2)!=ExpAcrynQuestStatus) continue;",
                        "                      RelationToRanger(tdwd2,Player(),RelationToRanger(tdwd2,Player())-75);",
                        "                      if(RelationToRanger(tdwd2,Player())<10)RelationToRanger(tdwd2,Player(),10);",
                        "                  }",
                        "              }",
                        "              ExpAcrynQuestStatus = 7;",
                        "          }",
                        "      }",
                        "      //Код, исполняемый пока игрок выполняет задание пеленгских флагманов (сканирование берторов разведзондом)",
                        "      else if(ExpAcrynQuestStatus == 1)",
                        "      {",
                        "          if(fl_array[Peleng, 2] < StuffRequiredCount)",
                        "          {",
                        "              tdwd=ScriptItemToItem(Q_item);",
                        "              if(tdwd)",
                        "              {",
                        "                  tint = UselessItemData(tdwd, 3);",
                        "                  if(tint != -1)",
                        "                  {",
                        "                      tdwd2 = GalaxyStar(tint - 1);",
                        "                      if(ItemIn(Q_item, tdwd2))",
                        "                      {",
                        "                          for(i = 0; i < StarShips(tdwd2); i = i + 1)",
                        "                          {",
                        "                              tdwd3 = StarShips(tdwd2, i);",
                        "                              if(ShipOwner(tdwd3) != 5) continue;",
                        "                              if(ShipSubType(tdwd3) != 6) continue;",
                        "                              if(ShipFindCustomShipInfoByType(tdwd3,'ExpAcryn_block_infos') != -1) continue;",
                        "                              if(Dist(tdwd3, tdwd) > 250) continue;",
                        "                              if(HullHP(tdwd3) != ItemSize(ShipItems(tdwd3, 0))) continue;",
                        "                              if(ScriptItemData(Q_item, 1) != Id(tdwd3))",
                        "                              {",
                        "                                  ScriptItemData(Q_item, 1, Id(tdwd3));",
                        "                                  UselessItemData(tdwd, 2, 0);",
                        "                              }",
                        "  ",
                        "                              UselessItemData(tdwd, 2, UselessItemData(tdwd, 2) + RndObject(5, 9, tdwd3));",
                        "                              if(UselessItemData(tdwd, 2) >= 100)",
                        "                              {",
                        "                                  UselessItemData(tdwd, 2, 100);",
                        "                                  //При начислении общих процентов всегда округляем остаток к большему",
                        "                                  UselessItemData(tdwd, 1, min(UselessItemData(tdwd, 1) + RoundTo(100.0 / StuffRequiredCount, 1, 1), 100));",
                        "                                  fl_array[Peleng, 2] = fl_array[Peleng, 2] + 1;",
                        "                                  ShipAddCustomShipInfo(tdwd3,'ExpAcryn_block_infos');",
                        "                                  NoTalkToShip(tdwd3, 1);",
                        "                                  NewsAdd(CT(\"Script.Mod_ExpAcryn.397\"));",
                        "                              }",
                        "                              break;",
                        "                          }",
                        "                      }",
                        "                  }",
                        "              }",
                        "          }",
                        "      }",
                        "      //Код, исполняемый пока игрок выполняет задание человеческих флагманов (сбор энергоядер)",
                        "      else if(ExpAcrynQuestStatus == 2)",
                        "      {",
                        "          tdwd = ScriptItemToItem(Q_item);",
                        "          if(tdwd)",
                        "          {",
                        "              if(UselessItemData(tdwd, 1)) UselessItemData(tdwd, 1, UselessItemData(tdwd, 1) - 1);",
                        "              if(!UselessItemData(tdwd, 1) && !ItemIn(Q_item, Player()))",
                        "              {",
                        "                  SetName(tdwd, CT(\"Script.Mod_ExpAcryn.258\"));",
                        "                  UselessItemText(tdwd, CT('UselessItems.Mod_ExpAcryn_mimi.Text') + Format('<br>') + ' ' + Format('<br>') + CT(\"Script.Mod_ExpAcryn.257\"));",
                        "                  tdwd2 = CreateQuestItem('Mod_ExpAcryn_mimi');",
                        "                  LinkItemToScript(tdwd2, Q_item);",
                        "                  FreeItem(tdwd2);",
                        "              }",
                        "          }",
                        "      }",
                        "      //Код, исполняемый пока игрок выполняет задание фэянских флагманов (с Р.Д.П.К.)",
                        "      else if(ExpAcrynQuestStatus == 3)",
                        "      {",
                        "          //Если как-то уничтожили оба корабля в задании фэй, то обнуляется флаг квеста",
                        "          if(!GroupToShip(q_ship) && !GroupToShip(q_ship2)) GFlagFeiTempVar = 0;",
                        "          //Игрок растратил всех роботов-шпионов в Р.Д.П.К., все задания флагманов провалены",
                        "          if(!UselessItemData(Q_item, 2) && !GroupCount(q_ship))",
                        "          {",
                        "              if(fl_array[Fei, 2] < StuffRequiredCount)",
                        "              {",
                        "                  if(~EtherState('ExpAcryn_quest_3'))",
                        "                  {",
                        "                      tstr = '';",
                        "                      if(fl_array[Fei, 1] != 1) tstr = '2';",
                        "                      Ether(5, 'ExpAcryn_quest_3', CT('Script.Mod_ExpAcryn.MissionFailed') + Format(CT('Script.Mod_ExpAcryn.FeiMission' + tstr), '<Reward'+'>', addItemName));",
                        "                  }",
                        "  ",
                        "                  //Также снижаем репутацию на всех фэянских планетах",
                        "                  for(i=0; i<GalaxyStars(); i=i+1)",
                        "                  {",
                        "                      tdwd=GalaxyStar(i);",
                        "                      if(StarOwner(tdwd)!=0) continue;",
                        "                      for(j=0; j<StarPlanets(tdwd); j=j+1)",
                        "                      {",
                        "                          tdwd2=StarPlanets(tdwd,j);",
                        "                          if(PlanetOwner(tdwd2)!=3) continue;",
                        "                          RelationToRanger(tdwd2,Player(),RelationToRanger(tdwd2,Player())-35);",
                        "                          if(RelationToRanger(tdwd2,Player())<10) RelationToRanger(tdwd2,Player(),10);",
                        "                      }",
                        "                  }",
                        "  ",
                        "                  ReleaseItemFromScript(Q_item);",
                        "                  ExpAcrynQuestStatus = 7;",
                        "              }",
                        "          }",
                        "      }",
                        "      //Код, исполняемый пока игрок выполняет задание гаальских флагманов (отправляем берторов на смерть с помощью асинхронного конвектора)",
                        "      else if(ExpAcrynQuestStatus == 4)",
                        "      {",
                        "          if(fl_array[Gaal, 1] < 3)",
                        "          {",
                        "              //Если игрок ещё не захватил бертор конвектором",
                        "              if(GFlagGaalTempVar == 1)",
                        "              {",
                        "                  //Если игрок ещё не собрал нужное число блоков памяти",
                        "                  if(fl_array[Gaal, 2] < StuffRequiredCount)",
                        "                  {",
                        "                      //Если асинхронный конвектор на борту игрока и ни один бертор ещё не захвачен",
                        "                      if(ItemIn(Q_item, Player()) && !GroupCount(q_ship2))",
                        "                      {",
                        "                          //Ищем берторов в системе игрока",
                        "                          tdwd = ShipStar(Player());",
                        "                          for(i = 0; i < StarShips(tdwd); i = i + 1)",
                        "                          {",
                        "                              //У игрока обязательно должен быть включён камуфляж, соответствующий серии бертора",
                        "                              if(PlayerChameleonCurType() == -1) break;",
                        "                              tdwd3 = StarShips(tdwd, i);",
                        "                              if(ShipTypeN(tdwd3) != t_Kling) continue;",
                        "                              //Камуфляж игрока не должен быть разоблачён",
                        "                              if(PlayerChameleonDetected(ItemSubrace(ShipItems(tdwd3, 0)))) break;",
                        "                              if(ShipSubType(tdwd3) != 6) continue;",
                        "                              //Бертор не должен иметь инфошку повышенных протоколов безопасности",
                        "                              if(ShipFindCustomShipInfoByType(tdwd3, 'ExpAcryn_block_infos') != -1) continue;",
                        "                              if(ItemSubrace(ShipItems(tdwd3, 0)) != PlayerChameleonCurType()) continue;",
                        "                              //Расстояние до бертора должно составлять не более 250 млн. км.",
                        "                              if(Dist(tdwd3, Player()) > 250) continue;",
                        "                              //И не должен быть занесён в скриптовую группу",
                        "                              if(ShipInScript(tdwd3)) continue;",
                        "                              //Захватываем бертор конвектором",
                        "                              ShipJoin(q_ship2, tdwd3);",
                        "                              ChangeState(1, tdwd3);",
                        "                              NewsAdd(Format(CT(\"Script.Mod_ExpAcryn.760\"),\"<0>\",ShipName(tdwd3)));",
                        "                              GFlagGaalTempVar = 2;",
                        "                              //Устанавливаем несколько дней, через которые другие доминаторы заметят странное поведение бертора и раскроют камуфляж игрока",
                        "                              tint2 = 2500 / ShipSpeed(tdwd3);",
                        "                              if(tint2 < 4) tint2 = 4;",
                        "                              fl_array[Gaal, 5] = CurTurn() + tint2;",
                        "                              break;",
                        "                          }",
                        "                      }",
                        "                  }",
                        "              }",
                        "  ",
                        "              //Если бертор захвачен игроком, но приказ прыжка ему ещё не отдан",
                        "              if(GFlagGaalTempVar == 2)",
                        "              {",
                        "                  tdwd4 = GroupToShip(q_ship2);",
                        "                  if(CurTurn() < fl_array[Gaal, 5])",
                        "                  {",
                        "                      //Пока захваченный игроком бертор не прыгает, имеется 33% шанс, что время обнаружения доминаторами подвоха продлится на 1 день дольше",
                        "                      if(ShipOrderObj(tdwd4) == Player())",
                        "                      {",
                        "                          if(RndObject(1, 100, tdwd4) <= 33) fl_array[Gaal, 5] = fl_array[Gaal, 5] + 1;",
                        "                      }",
                        "                  }",
                        "              }",
                        "  ",
                        "              //Если захваченный бертор выполняет приказ на прыжок",
                        "              if(GFlagGaalTempVar == 3)",
                        "              {",
                        "                  tdwd4 = GroupToShip(q_ship2);",
                        "                  //Захваченный конвертором бертор вошел в гипер",
                        "                  if(ShipInHyperSpace(tdwd4))",
                        "                  {",
                        "                      //Добавляем инфошку-блокиратор",
                        "                      ShipAddCustomShipInfo(tdwd4, 'ExpAcryn_block_infos');",
                        "                      NoTalkToShip(tdwd4, 1);",
                        "                      //Вешаем на бертор инфошку для дропа блока памяти после его смерти",
                        "                      ShipAddCustomShipInfo(tdwd4, 'ExpAcryn_GaalQuest_BertorInfo', 'NoShow');",
                        "                      //Добавляем маркер, что бертор прибыл в другую систему",
                        "                      GFlagGaalTempVar = 4;",
                        "                      ChangeState(4, tdwd4);",
                        "                      OrderLock(tdwd4, 0);",
                        "                  }",
                        "              }",
                        "  ",
                        "              if(GFlagGaalTempVar == 4)",
                        "              {",
                        "                  tdwd4 = GroupToShip(q_ship2);",
                        "                  //Если прибывший в другую систему бертор был уничтожен неправильно",
                        "                  if(!GroupToShip(q_ship2)) GFlagGaalTempVar = 1;",
                        "                  //Либо если серия доминаторов этой системы совпадает с его собственной серией",
                        "                  else if(StarOwner(ShipStar(tdwd4)) == 1)",
                        "                  {",
                        "                      if(StarSeries(ShipStar(tdwd4)) == ShipSubType(tdwd4))",
                        "                      {",
                        "                          //На всякий случай ещё проверяем, не захвачена ли система кастомной фракцией",
                        "                          if(StarCustomFaction(ShipStar(tdwd4)) == '')",
                        "                          {",
                        "                              //Удаляем инфошку для дропа блока памяти",
                        "                              ShipDeleteCustomShipInfo(tdwd4, 'ExpAcryn_GaalQuest_BertorInfo');",
                        "                              //И переводим задание в состояние готовности к захвату другого бертора",
                        "                              ShipOut(tdwd4);",
                        "                              GFlagGaalTempVar = 1;",
                        "                          }",
                        "                      }",
                        "                  }",
                        "              }",
                        "  ",
                        "              //Если захваченный бертор уничтожен доминаторами противоположной серии",
                        "              if(GFlagGaalTempVar == 5)",
                        "              {",
                        "                  //Сбрасываем маркер задания в состояние готовности к захвату другого бертора",
                        "                  GFlagGaalTempVar = 1;",
                        "              }",
                        "          }",
                        "      }",
                        "      //Код, исполняемый пока игрок выполняет задание доминиона",
                        "      else if(ExpAcrynQuestStatus == 12)",
                        "      {",
                        "          if(fl_array[5, 1] < 4 && fl_array[5, 2] < PirateStuffRequiredCount)",
                        "          {",
                        "              for(i = GalaxyEvents() - 1; i >= 0; i = i - 1)",
                        "              {",
                        "                  if(GalaxyEventDate(i) < CurTurn()) break;",
                        "                  if(fl_array[5, 2] >= PirateStuffRequiredCount) break;",
                        "  ",
                        "                  //Детектим уничтоженные игроком корабли, ищем среди них флагманы и берторы",
                        "                  if(GalaxyEventType(i) == 'PlayerKillsShip')",
                        "                  {",
                        "                      if(GalaxyEventData(i, 0) == t_Warrior)",
                        "                      {",
                        "                          if(GalaxyEventData(i, 5) == 1) fl_array[5, 2] = fl_array[5, 2] + 1;",
                        "                      }",
                        "                      else if(GalaxyEventData(i, 0) == t_Kling)",
                        "                      {",
                        "                          if(GalaxyEventData(i, 5) == 6) fl_array[5, 2] = fl_array[5, 2] + 1;",
                        "                      }",
                        "                  }",
                        "              }",
                        "          }",
                        "      }",
                        "  }",
                        "  ",
                        "  //Выдаём новорождённым берторам и флагманам новые модификации, нужные по заданиям",
                        "  if(GalaxyShipId() > last_ship_id)",
                        "  {",
                        "      i = BuildListOfNewShips(temp_array, last_ship_id, 1+8+16, 1+2+4+8+16+32+128, 1, '', ',Dreadnought,PirateFrigate,PirateGalleon');",
                        "      if(i)//Если был обнаружен хотя бы один новый корабль, подходящий по заданным фильтрам",
                        "      {",
                        "          for(i = 0; i < ArrayDim(temp_array); i = i + 1)",
                        "          {",
                        "              tdwd2 = temp_array[i];",
                        "  ",
                        "              tint2 = ShipOwner(tdwd2);",
                        "              //Выдача неизвестных модификаций берторам (нужно для малокского задания)",
                        "              if(tint2 == Kling)",
                        "              {",
                        "                  //Отсекаем не берторов",
                        "                  if(ShipSubType(tdwd2) != 6) continue;",
                        "  ",
                        "                  tint = ItemSubrace(ShipItems(tdwd2, 0));",
                        "                  if(!ShipEqInSlot(tdwd2, t_RepairRobot))",
                        "                  {",
                        "                      tdwd3 = CreateEquipment(t_RepairRobot, RndObject(35, 60, tdwd2), GalaxyTechLevel(), Kling);",
                        "                      ItemSubrace(tdwd3, tint);",
                        "                      AddItemToShip(tdwd2, tdwd3);",
                        "                      ItemIsInUse(tdwd3, tdwd2, 1);",
                        "                  }",
                        "                  if(!ShipEqInSlot(tdwd2, t_DefGenerator))",
                        "                  {",
                        "                      tdwd3 = CreateEquipment(t_DefGenerator, RndObject(35, 60, tdwd2), GalaxyTechLevel(), Kling);",
                        "                      ItemSubrace(tdwd3, tint);",
                        "                      AddItemToShip(tdwd2, tdwd3);",
                        "                      ItemIsInUse(tdwd3, tdwd2, 1);",
                        "                  }",
                        "  ",
                        "                  tint = 0;",
                        "                  while(!tint)",
                        "                  {",
                        "                      tdwd3 = ShipEqInSlot(tdwd2, RndObject(t_FuelTanks, t_DefGenerator, tdwd2));",
                        "                      if(tdwd3)",
                        "                      {",
                        "                          tint = 1;",
                        "                          tstr2 = '<color=255,167,84>' + Name(tdwd3) + '</color>';",
                        "                          EqSpecial(tdwd3, FindBonusByCustomTag('Akrin_dom_ship'));",
                        "                          SetName(tdwd3, tstr2);",
                        "                          NoDropItem(tdwd3, 1);",
                        "                      }",
                        "                  }",
                        "              }",
                        "              //Раздаём трионку пиратам, если игрок уже выполнил хотя бы одно задание доминиона",
                        "              else if(tint2 == PirateClan)",
                        "              {",
                        "                  if(fl_array[5, 1] < 2) continue;",
                        "  ",
                        "                  //Если подключён мод EvoArmada, то получать трионку будут лишь крупные пиратские корабли",
                        "                  if(EvoArmadaInit)",
                        "                  {",
                        "                      if(ShipType(tdwd2) == 'Pirate') continue;",
                        "                  }",
                        "  ",
                        "                  //Шанс тем выше, чем больше заданий для пиратов выполнил игрок",
                        "                  if(RndObject(1, 100, tdwd2) > (5 * (fl_array[5, 1] - 1))) continue;",
                        "  ",
                        "                  tint = 0;",
                        "                  while(!tint)",
                        "                  {",
                        "                      tdwd3 = ShipEqInSlot(tdwd2, RndObject(t_FuelTanks, t_DefGenerator, tdwd2));",
                        "                      if(tdwd3)",
                        "                      {",
                        "                          tint = 1;",
                        "                          EqSpecial(tdwd3, -1);",
                        "                          NoDropItem(tdwd3, 1);",
                        "                          for(k = 0; k < 7; k = k + 1)",
                        "                          {",
                        "                              if(!MayAddBonusToEq(FindBonusByCustomTag('Fakrin_5_' + k), tdwd3)) continue;",
                        "                              if(ItemType(tdwd3) != t_DefGenerator) SpecialToEquipment(FindBonusByCustomTag('Fakrin_5_' + k), tdwd3);",
                        "                              else",
                        "                              {",
                        "                                  if(RndObject(0, 1, tdwd2)) SpecialToEquipment(FindBonusByCustomTag('Fakrin_5_' + k), tdwd3);",
                        "                                  else SpecialToEquipment(FindBonusByCustomTag('Fakrin_5_' + k + '_2'), tdwd3);",
                        "                              }",
                        "                              break;",
                        "                          }",
                        "                      }",
                        "                  }",
                        "              }",
                        "              //Раздача трионки флагманам (если игрок уже выполнил задания соответствующей расы)",
                        "              else",
                        "              {",
                        "                  //Отсекаем не флагманы",
                        "                  if(ShipSubType(tdwd2) != 1) continue;",
                        "  ",
                        "                  if(ExpAcrynQuestStatus == 10) continue;",
                        "                  j = ShipOwner(tdwd2);",
                        "                  if(fl_array[j, 1] >= 2)",
                        "                  {",
                        "                      tdwd = 0;",
                        "                      tdwd = ShipEqInSlot(tdwd2, fl_array[j, 7]);",
                        "                      if(!tdwd)",
                        "                      {",
                        "                          tdwd = CreateEquipment(fl_array[j, 7], RndObject(40, 60, tdwd2), GalaxyTechLevel(), j);",
                        "                          AddItemToShip(tdwd2,tdwd);",
                        "                          ItemIsInUse(tdwd,tdwd2,1);",
                        "                      }",
                        "                      else",
                        "                      {",
                        "                          if(ItemOwner(tdwd)!=j) ItemOwner(tdwd,j);",
                        "                          NoDropItem(tdwd,1);",
                        "                          for(k=0; k<7; k=k+1)",
                        "                          {",
                        "                              if(!MayAddBonusToEq(FindBonusByCustomTag('Fakrin_'+j+'_'+k),tdwd))continue;",
                        "                              if(fl_array[j,7]!=t_DefGenerator) EqSpecial(tdwd,FindBonusByCustomTag('Fakrin_'+j+'_'+k));",
                        "                              else",
                        "                              {",
                        "                                  if(RndObject(0, 1, tdwd2)) EqSpecial(tdwd,FindBonusByCustomTag('Fakrin_'+j+'_'+k));",
                        "                                  else EqSpecial(tdwd, FindBonusByCustomTag('Fakrin_'+j+'_'+k+'_2'));",
                        "                              }",
                        "                              break;",
                        "                          }",
                        "                      }",
                        "  ",
                        "                      tdwd = 0;",
                        "                      tdwd = ShipEqInSlot(tdwd2, fl_array[j, 8]);",
                        "                      if(!tdwd)",
                        "                      {",
                        "                          tdwd = CreateEquipment(fl_array[j, 8], RndObject(40, 60, tdwd2), GalaxyTechLevel(), j);",
                        "                          AddItemToShip(tdwd2,tdwd);",
                        "                          ItemIsInUse(tdwd,tdwd2,1);",
                        "                      }",
                        "                      else",
                        "                      {",
                        "                          if(ItemOwner(tdwd)!=j) ItemOwner(tdwd,j);",
                        "                          NoDropItem(tdwd,1);",
                        "                          for(k=0; k<7; k=k+1)",
                        "                          {",
                        "                              if(!MayAddBonusToEq(FindBonusByCustomTag('Fakrin_'+j+'_'+k),tdwd))continue;",
                        "                              if(fl_array[j, 8] != t_DefGenerator) EqSpecial(tdwd,FindBonusByCustomTag('Fakrin_'+j+'_'+k));",
                        "                              else",
                        "                              {",
                        "                                  if(RndObject(0, 1, tdwd2)) EqSpecial(tdwd,FindBonusByCustomTag('Fakrin_'+j+'_'+k));",
                        "                                  else EqSpecial(tdwd,FindBonusByCustomTag('Fakrin_'+j+'_'+k+'_2'));",
                        "                              }",
                        "                              break;",
                        "                          }",
                        "                      }",
                        "                  }",
                        "              }",
                        "          }",
                        "      }",
                        "      last_ship_id = GalaxyShipId();",
                        "  }",
                        "}"
                    ],
                    "#": 45,
                    "Type": "Top",
                    "Parent": -1,
                    "Pos.x": 120,
                    "Pos.y": 885
                },
                {
                    "Name": "",
                    "Code.Type": "DialogBegin",
                    "Code": [
                        "if(HomeGiveCaseCheck == 1)",
                        "{",
                        "    if(ExpAcrynQuestStatus != 11)",
                        "    {",
                        "        if(ShipOwner(Player()) >= 0 && ShipOwner(Player()) <= 4)",
                        "        {",
                        "            //Выдача кейса, если игрок получил звание \"Капитан\" на родной планете по моду ShuHomeland",
                        "            //Все сопутствующие диалоги прописаны в том же моде",
                        "            tdwd = CreateQuestItem('Mod_ExpAcryn_case');",
                        "            NoDropItem(tdwd, 1);",
                        "            ItemOwner(tdwd, PlanetOwner(GetShipPlanet(Player())));",
                        "            ItemSize(tdwd, 1);",
                        "            LinkItemToScript(tdwd, Q_item);",
                        "            AddItemToShip(Player(), tdwd);",
                        "            ExpAcrynQuestStatus = 11; //Игрок взял первый квест",
                        "        }",
                        "    }",
                        "}",
                        "cur_ruin = GetShipRuins(Player());",
                        "if(cur_ruin)",
                        "{",
                        "    if(ExpAcrynQuestStatus > 10)",
                        "    {",
                        "        if(ShipType(cur_ruin) == 'CB')",
                        "        {",
                        "            owner = 5;",
                        "            if(item_count < 4)",
                        "            {",
                        "                if(ExpAcrynQuestStatus == 12)",
                        "                {",
                        "                    if(fl_array[5, 1] < 4)",
                        "                    {",
                        "                        //Задание ещё не взято или уже в процессе",
                        "                        if(fl_array[5, 2] < PirateStuffRequiredCount)",
                        "                        {",
                        "                            AddDialogInject('Dom_q', '', CT(\"Script.Mod_ExpAcryn.335\"), 1, 0, 2);",
                        "                            if(!1) AddDialogInject('TestPir', '', CT(\"Script.Mod_ExpAcryn.391\"), 2);",
                        "                        }",
                        "                        //Задание выполнено в первый раз",
                        "                        else if(fl_array[5, 1] == 1) AddDialogInject('Dom_q', '', CT(\"Script.Mod_ExpAcryn.358\"), 2, 0, 3);",
                        "                        //Во второй раз",
                        "                        else if(fl_array[5, 1] == 2) AddDialogInject('Dom_q', '', CT(\"Script.Mod_ExpAcryn.615\"), 2, 0, 3);",
                        "                        //В третий раз",
                        "                        else if(fl_array[5, 1] == 3) AddDialogInject('Dom_q', '', CT(\"Script.Mod_ExpAcryn.625\"), 2, 0, 3);",
                        "                    }",
                        "                }",
                        "                else if(ExpAcrynQuestStatus == 11) AddDialogInject('Dom_q', '', CT(\"Script.Mod_ExpAcryn.322\"), 1, 0, 1);",
                        "            }",
                        "        }",
                        "        else if(ShipType(cur_ruin) == 'PB')",
                        "        {",
                        "            if(!DomiksDefeated())",
                        "            {",
                        "                if(!PirateWin())",
                        "                {",
                        "                    owner = 5;",
                        "                    if(ExpAcrynQuestStatus == 11)",
                        "                    {",
                        "                        if(ShipOnSidePirateClan(Player())) AddDialogInject('Dom_q', '', CT(\"Script.Mod_ExpAcryn.634\"), 1, 0, 4);",
                        "                    }",
                        "                }",
                        "            }",
                        "        }",
                        "    }",
                        "    else if(ExpAcrynQuestStatus == 10)",
                        "    {",
                        "        if(!ShipInPirateClan(Player()))",
                        "        {",
                        "            if(ShipType(cur_ruin) == 'WB')",
                        "            {",
                        "                if(ShipRank(Player()) == 3)",
                        "                {",
                        "                    if(!corVar)",
                        "                    {",
                        "                        tint = 0;",
                        "                        for(i = 1; i < ShipItems(Player()); i = i + 1)",
                        "                        {",
                        "                            tdwd = ShipItems(Player(), i);",
                        "                            if(Id(tdwd) > tint)",
                        "                            {",
                        "                                tint = Id(tdwd);",
                        "                                tstr = Name(tdwd);",
                        "                            }",
                        "                        }",
                        "",
                        "                        corVar = 1;",
                        "                    }",
                        "",
                        "                    AddDialogOverride('WB_q', 100);",
                        "                }",
                        "            }",
                        "        }",
                        "    }",
                        "}",
                        "else",
                        "{",
                        "    cur_ship = GetTalkShip();",
                        "    if(cur_ship)",
                        "    {",
                        "        if(ExpAcrynQuestStatus != 7)",
                        "        {",
                        "            if(ShipTypeN(cur_ship) == t_Kling)",
                        "            {",
                        "                if(ShipSubType(cur_ship) == 6)",
                        "                {",
                        "                    if(ShipCustomFaction(cur_ship) == '')",
                        "                    {",
                        "                        if(ShipScanerPower(Player()) > ShipProtectability(cur_ship))",
                        "                        {",
                        "                            //Добавляется доп. реплика в диалог с бертором",
                        "                            //Помимо инфошки \"Детачера\", у игрока обязательно должна быть копия \"Интеркома\"",
                        "                            if(GetProgramm(5))",
                        "                            {",
                        "                                if(~ShipFindCustomShipInfoByType(Player(), 'ExpAcryn_mimi_player_infos'))",
                        "                                {",
                        "                                    if(ShipFindCustomShipInfoByType(GetTalkShip(), 'ExpAcryn_block_infos') == -1) AddDialogInject('Bertor_mimi', '', CT(\"Script.Mod_ExpAcryn.333\"), 3);",
                        "                                }",
                        "                            }",
                        "                        }",
                        "                    }",
                        "                }",
                        "            }",
                        "            else if(ShipTypeN(cur_ship) == t_Warrior)",
                        "            {",
                        "                if(ShipSubType(cur_ship) == 1)",
                        "                {",
                        "                    if(!StarBattle(ShipStar(cur_ship)))",
                        "                    {",
                        "                        if(PlayerChameleonCurType() == -1)",
                        "                        {",
                        "                            if(!ShipInPirateClan(Player()))",
                        "                            {",
                        "                                if(RelationToRanger(cur_ship, Player()) >= 20 && ShipGetBad(cur_ship) != Player())",
                        "                                {",
                        "                                    flagman = cur_ship;",
                        "                                    owner = ShipOwner(flagman);",
                        "                                    if(ExpAcrynQuestStatus == owner || ExpAcrynQuestStatus == 5)",
                        "                                    {",
                        "                                        if(fl_array[owner, 1] < 3)",
                        "                                        {",
                        "                                            if(!fl_array[owner, 1])",
                        "                                            {",
                        "                                                //Если кейс уже был сдан флагману ранее",
                        "                                                tstr = '';",
                        "                                                if(caseIn < 5)",
                        "                                                {",
                        "                                                    //Ещё не было выполнено ни одного задания флагманов",
                        "                                                    if(!item_count)",
                        "                                                    {",
                        "                                                        //Ранее кейс был сдан флагману этой расы",
                        "                                                        if(caseIn == owner) tstr = '</color>' + CT(\"Script.Mod_ExpAcryn.476\") + CT(\"Script.Mod_ExpAcryn.147\");",
                        "                                                        //Ранее кейс был сдан флагману другой расы",
                        "                                                        else tstr = '</color>' + CT(\"Script.Mod_ExpAcryn.470\") + CT(\"Script.Mod_ExpAcryn.147\");",
                        "                                                    }",
                        "                                                    //Игрок уже выполнил минимум одно задание другого флагмана",
                        "                                                    else tstr = '</color>' + CT(\"Script.Mod_ExpAcryn.475\") + CT(\"Script.Mod_ExpAcryn.147\");",
                        "                                                }",
                        "",
                        "                                                tstr2 = CT(\"Script.Mod_ExpAcryn.326\");",
                        "                                            }",
                        "                                            else",
                        "                                            {",
                        "                                                if(owner == Maloc)",
                        "                                                {",
                        "                                                    //Считаем неизвестные доминаторские модификации, необходимые по заданию малоков",
                        "                                                    //Если нашли нужное количество, то подставляем ответ об окончании задания",
                        "                                                    tint = fl_array[Maloc, 2];",
                        "                                                    for(i = ShipItems(Player()) - 1; i > 0; i = i - 1)",
                        "                                                    {",
                        "                                                        tdwd = ShipItems(Player(), i);",
                        "                                                        if(EqSpecial(tdwd) == -1) continue;",
                        "                                                        if(EqSpecial(tdwd) != FindBonusByCustomTag('ExpAcryn_ship_maloc')) continue;",
                        "                                                        tint = tint + 1;",
                        "                                                    }",
                        "",
                        "                                                    if(tint < StuffRequiredCount)",
                        "                                                    {",
                        "                                                        tstr2 = CT(\"Script.Mod_ExpAcryn.323\");",
                        "                                                        if(!1) AddDialogInject('TestCoal', '', CT(\"Script.Mod_ExpAcryn.391\"), 2);",
                        "                                                    }",
                        "                                                    else",
                        "                                                    {",
                        "                                                        if(fl_array[Maloc, 1] == 1) tstr2 = CT(\"Script.Mod_ExpAcryn.388\");",
                        "                                                        else tstr2 = CT(\"Script.Mod_ExpAcryn.439\");",
                        "                                                    }",
                        "                                                }",
                        "                                                else if(owner == Peleng)",
                        "                                                {",
                        "                                                    //Считаем энергоядра, необходимые по заданию людей",
                        "                                                    //Если нашли нужное количество, то подставляем ответ об окончании задания",
                        "                                                    tint = fl_array[Peleng, 2];",
                        "                                                    for(i = ShipItems(Player()) - 1; i > 0; i = i - 1)",
                        "                                                    {",
                        "                                                        tdwd = ShipItems(Player(), i);",
                        "                                                        if(ItemType(tdwd) != t_UselessItem) continue;",
                        "                                                        if(EquipmentImageName(tdwd) != 'Mod_ExpAcryn_mimi') continue;",
                        "                                                        tint = tint + 1;",
                        "                                                    }",
                        "",
                        "                                                    if(tint < StuffRequiredCount)",
                        "                                                    {",
                        "                                                        tstr2 = CT(\"Script.Mod_ExpAcryn.323\");",
                        "                                                        if(!1) AddDialogInject('TestCoal', '', CT(\"Script.Mod_ExpAcryn.391\"), 2);",
                        "                                                    }",
                        "                                                    else",
                        "                                                    {",
                        "                                                        if(fl_array[Peleng, 1] == 1) tstr2 = CT(\"Script.Mod_ExpAcryn.388\");",
                        "                                                        else tstr2 = CT(\"Script.Mod_ExpAcryn.439\");",
                        "                                                    }",
                        "                                                }",
                        "                                                else if(owner == Gaal)",
                        "                                                {",
                        "                                                    //Считываем, сколько блоков памяти уже загрузил в конвектор игрок",
                        "                                                    tdwd = ScriptItemToItem(Q_item);",
                        "                                                    //При начислении общих процентов прогресса сбора данных, всегда округляем остаток к большему",
                        "                                                    fl_array[Gaal, 2] = round(1.0 * UselessItemData(tdwd, 1) / RoundTo(100.0 / StuffRequiredCount, 1, 1));",
                        "",
                        "                                                    if(fl_array[Gaal, 2] < StuffRequiredCount)",
                        "                                                    {",
                        "                                                        tstr2 = CT(\"Script.Mod_ExpAcryn.323\");",
                        "                                                        if(!1) AddDialogInject('TestCoal', '', CT(\"Script.Mod_ExpAcryn.391\"), 2);",
                        "                                                    }",
                        "                                                    else",
                        "                                                    {",
                        "                                                        if(fl_array[Gaal, 1] == 1) tstr2 = CT('Script.Mod_ExpAcryn.GaalQuestDialog.PlayerFirstQuestComplete');",
                        "                                                        else tstr2 = CT('Script.Mod_ExpAcryn.GaalQuestDialog.PlayerSecondQuestComplete');",
                        "                                                    }",
                        "                                                }",
                        "                                                else",
                        "                                                {",
                        "                                                    if(fl_array[owner, 2] < StuffRequiredCount)",
                        "                                                    {",
                        "                                                        tstr2 = CT(\"Script.Mod_ExpAcryn.323\");",
                        "                                                        if(!1) AddDialogInject('TestCoal', '', CT(\"Script.Mod_ExpAcryn.391\"), 2);",
                        "                                                    }",
                        "                                                    else",
                        "                                                    {",
                        "                                                        if(fl_array[owner, 1] == 1) tstr2 = CT(\"Script.Mod_ExpAcryn.388\");",
                        "                                                        else tstr2 = CT(\"Script.Mod_ExpAcryn.439\");",
                        "                                                    }",
                        "                                                }",
                        "                                            }",
                        "",
                        "                                            if(Dist(flagman, Player()) <= 250) AddDialogInject('Flagm_' + owner, '', tstr2, 3, 0, fl_array[owner, 1]);",
                        "                                            else AddDialogInject('Dist_no', '', tstr2, 3);",
                        "                                        }",
                        "                                    }",
                        "",
                        "                                    if(cham)",
                        "                                    {",
                        "                                        if(ExpAcrynQuestStatus <= 6)",
                        "                                        {",
                        "                                            if(ShipOwner(flagman) > 0)",
                        "                                            {",
                        "                                                if(Dist(flagman, Player()) <= 250) AddDialogInject('Flag_ch', '', CT(\"Script.Mod_ExpAcryn.330\"), 2, 0, 0);",
                        "                                                else AddDialogInject('Dist_no', '', CT(\"Script.Mod_ExpAcryn.330\"), 2, 0, 0);",
                        "                                            }",
                        "                                        }",
                        "                                    }",
                        "",
                        "                                    if(ExpAcrynQuestStatus == 11)",
                        "                                    {",
                        "                                        if(ItemIn(Q_item, Player()))",
                        "                                        {",
                        "                                            if(Dist(flagman, Player()) <= 250) AddDialogInject('Flagm', '', CT(\"Script.Mod_ExpAcryn.484\"), 1);",
                        "                                            else AddDialogInject('Dist_no', '', CT(\"Script.Mod_ExpAcryn.484\"), 1);",
                        "                                        }",
                        "                                    }",
                        "                                }",
                        "                            }",
                        "                        }",
                        "                    }",
                        "                }",
                        "            }",
                        "        }",
                        "    }",
                        "}"
                    ],
                    "#": 46,
                    "Type": "Top",
                    "Parent": -1,
                    "Pos.x": 180,
                    "Pos.y": 885
                },
                {
                    "Name": "",
                    "Code.Type": "Turn",
                    "Code": [
                        "if(GFlagFeiTempVar > 0) {",
                        "  if(GFlagFeiTempVar > 5 && CurTurn() == fl_array[Fei, 6]) //Снимается камуфляж при выполнении задания",
                        "  {",
                        "      if(GFlagFeiTempVar != 10 && GroupToShip(q_ship)) Ether(0, '', CT(\"Script.Mod_ExpAcryn.649\"));",
                        "      else if(GFlagFeiTempVar == 10 || !GroupToShip(q_ship)) Ether(0, '', CT(\"Script.Mod_ExpAcryn.661\"));",
                        "      fl_array[Fei, 6] = 0;",
                        "      PlayerChameleonDetected(ItemSubrace(ShipItems(CurShip, 0)), 1);",
                        "      ShipOut(CurShip);",
                        "  }",
                        "  ",
                        "  if(!GroupToShip(q_ship))",
                        "  {",
                        "      GFlagFeiTempVar = 0;",
                        "      ShipOut(CurShip);",
                        "  }",
                        "}",
                        "if(GFlagGaalTempVar == 2) {",
                        "  if(Dist(CurShip, Player()) <= 250 && ItemIn(Q_item, Player())) {",
                        "    ChangeState(3);",
                        "    exit;",
                        "  }",
                        "}"
                    ],
                    "#": 201,
                    "Type": "Top",
                    "Parent": -1,
                    "Pos.x": 80
                },
                {
                    "Name": "",
                    "Code.Type": "Turn",
                    "Code": [
                        "if(GFlagFeiTempVar > 0) {",
                        "  //Проверка системы",
                        "  //Если шпион не в системе игрока, то группы очищаются и квест обнуляется",
                        "  if(ShipStar(Player()) != ShipStar(CurShip))",
                        "  {",
                        "      GFlagFeiTempVar = 0;",
                        "      ShipOut(CurShip);",
                        "      ShipOut(GroupToShip(q_ship2));",
                        "  }",
                        "  ",
                        "  if(GFlagFeiTempVar == 1 && GroupToShip(q_ship2))",
                        "  {",
                        "      //Если бертор улетел от шпиона, то возвращаем шпиона назад",
                        "      if(ShipStar(GroupToShip(q_ship2)) != ShipStar(CurShip))",
                        "      {",
                        "          Ether(0, '', Format(CT(\"Script.Mod_ExpAcryn.642\"),\"<0>\",0));",
                        "          GFlagFeiTempVar = 8;",
                        "          OrderFollowShip(CurShip, Player());",
                        "          OrderLock(CurShip, 1);",
                        "          ShipOut(GroupToShip(q_ship2));",
                        "      }",
                        "  }",
                        "  ",
                        "  //Провальные варианты",
                        "  if(GFlagFeiTempVar == 1 && (PlayerChameleonCurType() != ItemSubrace(ShipItems(CurShip, 0)) || PlayerChameleonDetected(ItemSubrace(ShipItems(CurShip, 0)))))",
                        "  {",
                        "      //Если камуфляж упал до посадки на бертора, возвращаем шпиона на игрока",
                        "      Ether(0, '', CT(\"Script.Mod_ExpAcryn.647\"));",
                        "      GFlagFeiTempVar = 8;",
                        "      OrderFollowShip(CurShip, Player());",
                        "      OrderLock(CurShip, 1);",
                        "  }",
                        "  ",
                        "  if(GFlagFeiTempVar == 8 && Dist(CurShip, Player()) <= 300 && ItemIn(Q_item, Player()))",
                        "  {",
                        "      //Сажаем шпиона на игрока",
                        "      OrderLanding(CurShip, Player());",
                        "      GFlagFeiTempVar = 9;",
                        "  }",
                        "  ",
                        "  if(GFlagFeiTempVar == 9 && GetShipRuins(CurShip) == Player())",
                        "  {",
                        "      //Шпион вернулся без данных, не увеличиваем счётчик выполнения",
                        "      GFlagFeiTempVar = 0;",
                        "      if(ItemIn(Q_item, Player()))",
                        "      {",
                        "          tdwd=ScriptItemToItem(Q_item);",
                        "          //+1 заряд для запуска шпиона",
                        "          UselessItemData(tdwd, 2, UselessItemData(tdwd, 2) + 1);",
                        "      }",
                        "  ",
                        "      TransferShip(CurShip, StarPlanets(ShipStar(CurShip), 0));",
                        "      OrderNone(CurShip);",
                        "      if(!ItemIn(Q_item, Player()))",
                        "      {",
                        "          for(i = 1; i < ShipItems(Player()); i = i + 1)",
                        "          {",
                        "              tdwd = ShipItems(Player(), i);",
                        "              if(!ItemIsInUse(tdwd)) continue;",
                        "              ItemDurability(tdwd, 0);",
                        "          }",
                        "          OrderNone(Player());",
                        "          OrderLock(Player(), 1);",
                        "          CustomLose(CT(\"Script.Mod_ExpAcryn.652\"));",
                        "      }",
                        "      ShipDestroy(CurShip, 1);",
                        "  }",
                        "  ",
                        "  //Если бертора уничтожили до посадки, возвращаем шпиона на игрока",
                        "  if(GFlagFeiTempVar == 1 && !GroupToShip(q_ship2))",
                        "  {",
                        "      Ether(0, '', Format(CT(\"Script.Mod_ExpAcryn.645\"),\"<0>\",0));",
                        "      GFlagFeiTempVar = 8;",
                        "      OrderFollowShip(CurShip, Player());",
                        "      OrderLock(CurShip, 1);",
                        "  }",
                        "  ",
                        "  //Обычные варианты",
                        "  //Шпион следует за бертором и открывает диалог",
                        "  if(GFlagFeiTempVar == 1 && Dist(CurShip, GroupToShip(q_ship2)) <= 300)",
                        "  {",
                        "      GFlagFeiTempVar = 2;",
                        "      Dialog(Bertor_fei_crack, CurShip);",
                        "  }",
                        "  ",
                        "  //После диалога отдаём приказ на посадку",
                        "  if((GFlagFeiTempVar == 3 || GFlagFeiTempVar == 4) && !fl_array[Fei, 6])",
                        "  {",
                        "      OrderLanding(CurShip, GroupToShip(q_ship2));",
                        "      fl_array[Fei, 6] = CurTurn() + 2;",
                        "      OrderLock(CurShip, 1);",
                        "  }",
                        "  ",
                        "  //После посадки взлёт, если игрок выбрал верный ответ",
                        "  if(GFlagFeiTempVar == 3 && CurTurn() == fl_array[Fei, 6])",
                        "  {",
                        "      OrderTakeOff(CurShip);",
                        "      fl_array[Fei, 6] = CurTurn() + 3;",
                        "      GFlagFeiTempVar = 5;",
                        "  }",
                        "  ",
                        "  //После посадки перепрограммируют клига, если игрок выбрал неверный ответ",
                        "  if(GFlagFeiTempVar == 4 && CurTurn() == fl_array[Fei, 6])",
                        "  {",
                        "      GFlagFeiTempVar = 0;",
                        "      PlayerChameleonDetected(ItemSubrace(ShipItems(CurShip, 0)), 1);",
                        "      Ether(0, '', CT(\"Script.Mod_ExpAcryn.663\"));",
                        "      fl_array[Fei, 6] = 0;",
                        "      OrderLock(CurShip, 0);",
                        "      ShipOut(GroupToShip(q_ship2));",
                        "      OrderTakeOff(CurShip);",
                        "      ShipOut(CurShip);",
                        "  }",
                        "  ",
                        "  //После взлёта с бертора отдаём приказ следовать за игроком",
                        "  if(GFlagFeiTempVar == 5 && ShipInNormalSpace(CurShip))",
                        "  {",
                        "      OrderFollowShip(CurShip, Player());",
                        "      GFlagFeiTempVar = 6;",
                        "  }",
                        "  ",
                        "  //Посадка шпиона на игрока, когда догнал",
                        "  if(GFlagFeiTempVar == 6 && Dist(CurShip, Player()) <= 300 && ItemIn(Q_item, Player()))",
                        "  {",
                        "      OrderLanding(CurShip, Player());",
                        "      GFlagFeiTempVar = 7;",
                        "  }",
                        "  ",
                        "  //Если сел на игрока, то квест засчитан",
                        "  if(GFlagFeiTempVar == 7 && GetShipRuins(CurShip) == Player())",
                        "  {",
                        "      GFlagFeiTempVar = 10;",
                        "      if(ItemIn(Q_item, Player()))",
                        "      {",
                        "          Ether(0, '', CT(\"Script.Mod_ExpAcryn.673\"));",
                        "          tdwd = ScriptItemToItem(Q_item);",
                        "          //При начислении общих процентов прогресса сбора данных, всегда округляем остаток к большему",
                        "          UselessItemData(tdwd, 1, min(UselessItemData(tdwd, 1) + RoundTo(100.0 / StuffRequiredCount, 1, 1), 100));",
                        "          //+1 заряд для запуска шпиона",
                        "          UselessItemData(tdwd, 2, UselessItemData(tdwd, 2) + 1);",
                        "          //Увеличиваем счётчик выполнения задания фэян",
                        "          fl_array[Fei, 2] = fl_array[Fei, 2] + 1;",
                        "      }",
                        "  ",
                        "      TransferShip(CurShip, StarPlanets(ShipStar(CurShip), 0));",
                        "      OrderNone(CurShip);",
                        "      if(!ItemIn(Q_item, Player()))",
                        "      {",
                        "          for(i = 1; i < ShipItems(Player()); i = i + 1)",
                        "          {",
                        "              tdwd = ShipItems(Player(), i);",
                        "              if(!ItemIsInUse(tdwd)) continue;",
                        "              ItemDurability(tdwd, 0);",
                        "          }",
                        "  ",
                        "          OrderNone(Player());",
                        "          OrderLock(Player(), 1);",
                        "          CustomLose(CT(\"Script.Mod_ExpAcryn.652\"));",
                        "      }",
                        "  ",
                        "      ShipDestroy(CurShip, 1);",
                        "  }",
                        "}"
                    ],
                    "#": 202,
                    "Type": "Top",
                    "Parent": -1,
                    "Pos.x": 160
                },
                {
                    "Name": "",
                    "Code.Type": "Turn",
                    "Code": [
                        "//Запрещаем бертору вести огонь по игроку",
                        "for(i = ShipCntWeapon(CurShip); i > 0; i = i - 1)",
                        "{",
                        "    tdwd = ShipWeapon(CurShip, i);",
                        "    if(IsPlayer(WeaponTarget(tdwd))) WeaponTarget(tdwd, 0);",
                        "}",
                        "if(Dist(CurShip, Player()) > 250) {",
                        "  ShipAddCustomShipInfo(CurShip, 'ExpAcryn_block_infos');",
                        "  NoTalkToShip(CurShip, 1);",
                        "  Ether(0, '', CT(\"Script.Mod_ExpAcryn.762\"));",
                        "  GFlagGaalTempVar = 1;",
                        "  if(PlayerChameleonDetected(ItemSubrace(ShipItems(CurShip, 0))) != 1) PlayerChameleonDetected(ItemSubrace(ShipItems(CurShip, 0)), 1);",
                        "  OrderLock(CurShip, 0);",
                        "  ShipOut(CurShip);",
                        "}",
                        "if(!ItemIn(Q_item, Player())) {",
                        "  ShipAddCustomShipInfo(CurShip, 'ExpAcryn_block_infos');",
                        "  NoTalkToShip(CurShip, 1);",
                        "  Ether(0, '', CT(\"Script.Mod_ExpAcryn.758\"));",
                        "  GFlagGaalTempVar = 1;",
                        "  if(PlayerChameleonDetected(ItemSubrace(ShipItems(CurShip, 0))) != 1) PlayerChameleonDetected(ItemSubrace(ShipItems(CurShip, 0)), 1);",
                        "  OrderLock(CurShip, 0);",
                        "  ShipOut(CurShip);",
                        "}",
                        "if(fl_array[Gaal, 5]) {",
                        "  if(CurTurn() >= fl_array[Gaal, 5] && !PlayerChameleonDetected(ItemSubrace(ShipItems(CurShip, 0)))) {",
                        "    fl_array[Gaal, 5] = 0;",
                        "    Ether(0, '', CT(\"Script.Mod_ExpAcryn.756\"));",
                        "    PlayerChameleonDetected(ItemSubrace(ShipItems(CurShip, 0)), 1);",
                        "  }",
                        "}",
                        "if(!1) {",
                        "  ChangeState(4);",
                        "  exit;",
                        "}"
                    ],
                    "#": 203,
                    "Type": "Top",
                    "Parent": -1,
                    "Pos.x": 240
                },
                {
                    "Name": "",
                    "Code.Type": "Turn",
                    "Code": [
                        "if(!GAnswerData) {",
                        "  tstr1 = '</color>' + Format(CT('Script.Mod_ExpAcryn.MalocQuestDialog.FirstQuestExplain'), '<AddIntro'+'>', tstr, '');",
                        "  DChange(0);",
                        "  exit;",
                        "}",
                        "if(GAnswerData) {",
                        "  //Ищем неизвестные доминаторские модификации, необходимые по заданию малоков",
                        "  //Если нашли, то увеличиваем счетчик предметов и удаляем модификацию из трюма",
                        "  tint2 = 0;",
                        "  for(i = ShipItems(Player()) - 1; i > 0; i = i - 1)",
                        "  {",
                        "      tdwd = ShipItems(Player(), i);",
                        "      if(EqSpecial(tdwd) == -1) continue;",
                        "      if(EqSpecial(tdwd) != FindBonusByCustomTag('ExpAcryn_ship_maloc')) continue;",
                        "      fl_array[0, 2] = fl_array[0, 2] + 1;",
                        "      FreeItem(GetItemFromShip(Player(), i));",
                        "      tint2 = 1;",
                        "  }",
                        "  if(fl_array[owner, 2] >= StuffRequiredCount && !ItemIn(Q_item, Player())) {",
                        "    DChange(25);",
                        "    exit;",
                        "  }",
                        "  if(fl_array[owner, 2] < StuffRequiredCount) {",
                        "    tint = StuffRequiredCount - fl_array[owner, 2];",
                        "    if(tint == 1) tstr2 = '</color>' + CT(\"Script.Mod_ExpAcryn.491\");",
                        "    else if(tint >= 2 && tint <= 4) tstr2 = '</color>' + CT(\"Script.Mod_ExpAcryn.490\");",
                        "    else if(tint == 5) tstr2 = '</color>' + CT(\"Script.Mod_ExpAcryn.489\");",
                        "    if(tint2) tstr1 = '</color>' + Format(CT(\"Script.Mod_ExpAcryn.836\"),\"<0>\",tint,\"<1>\",tstr2);",
                        "    else tstr1 = '</color>' + Format(CT(\"Script.Mod_ExpAcryn.835\"),\"<0>\",tint,\"<1>\",tstr2);",
                        "    DChange(1);",
                        "    exit;",
                        "  }",
                        "  if(fl_array[owner, 2] >= StuffRequiredCount && ItemIn(Q_item, Player())) {",
                        "    //Завершаем миссию и выдаём награду",
                        "    EndFlagmanMission();",
                        "    ",
                        "    //Формируются строчки уведомления о награде и о предложении выполнить квесты других флагманов (последнее, если игрок уже выполнил задание текущей расы два раза)",
                        "    //Награда этой расой вручается первый раз",
                        "    if(fl_array[owner, 1] == 2) tstr1 = '</color>' + Format(CT(\"Script.Mod_ExpAcryn.519\"),\"<0>\",lowercase(substr(DeleteTags(Name(tdwd2)),0,1))+substr(DeleteTags(Name(tdwd2)),1));",
                        "    //Награда этой расой вручается уже второй раз",
                        "    else if(fl_array[owner, 1] == 3) tstr1 = '</color>' + Format(CT(\"Script.Mod_ExpAcryn.527\"),\"<0>\",lowercase(substr(DeleteTags(Name(tdwd2)),0,1))+substr(DeleteTags(Name(tdwd2)),1));",
                        "    ",
                        "    //Награда была вручена первый раз и ещё есть \"место\" под вручение второй награды",
                        "    if(fl_array[owner, 1] == 2 && item_count < 3)",
                        "    {",
                        "        tint = tint + 1;",
                        "        if(fl_array[owner, tint] == t_FuelTanks) addItemName = CT(\"Script.Mod_ExpAcryn.512\");",
                        "        else if(fl_array[owner, tint] == t_Engine) addItemName = CT(\"Script.Mod_ExpAcryn.511\");",
                        "        else if(fl_array[owner, tint] == t_Radar) addItemName = CT(\"Script.Mod_ExpAcryn.510\");",
                        "        else if(fl_array[owner, tint] == t_Scaner) addItemName = CT(\"Script.Mod_ExpAcryn.509\");",
                        "        else if(fl_array[owner, tint] == t_RepairRobot) addItemName = CT(\"Script.Mod_ExpAcryn.450\");",
                        "        else if(fl_array[owner, tint] == t_CargoHook) addItemName = CT(\"Script.Mod_ExpAcryn.508\");",
                        "        else if(fl_array[owner, tint] == t_DefGenerator) addItemName = CT(\"Script.Mod_ExpAcryn.507\");",
                        "    ",
                        "        tstr1 = tstr1 + '...' + Format('<br>') + Format(CT('Script.Mod_ExpAcryn.MalocQuestDialog.SecondQuestExplain'), '<Reward'+'>', addItemName);",
                        "        tstr2 = '</color>' + CT(\"Script.Mod_ExpAcryn.531\");",
                        "    }",
                        "    //Награда этой расой вручена второй раз, направляем игрока к другим флагманам",
                        "    else if(fl_array[owner, 1] == 3 && item_count < 3)",
                        "    {",
                        "        tstr1 = tstr1 + Format('<br>') + CT(\"Script.Mod_ExpAcryn.504\");",
                        "        tstr2 = '</color>' + CT(\"Script.Mod_ExpAcryn.503\");",
                        "    }",
                        "    //Награда этой расой была вручена первый раз, но все награды в партии игроку уже выданы",
                        "    else if(fl_array[owner, 1] == 2 && item_count == 3)",
                        "    {",
                        "        tstr1 = tstr1 + '</color>' + CT(\"Script.Mod_ExpAcryn.516\");",
                        "        tstr2 = '</color>' + CT(\"Script.Mod_ExpAcryn.460\");",
                        "    }",
                        "    //Награда этой расой вручена второй раз, но все награды в партии игроку уже выданы",
                        "    else if(fl_array[owner, 1] == 3 && item_count == 3)",
                        "    {",
                        "        tstr1 = tstr1 + Format('<br>') + CT(\"Script.Mod_ExpAcryn.502\");",
                        "        tstr2 = '</color>' + CT(\"Script.Mod_ExpAcryn.501\");",
                        "    }",
                        "    ",
                        "    //Выводим уведомление об успешном выполнении миссии (первой или второй)",
                        "    if(fl_array[owner, 1] == 2) Ether(4, 'ExpAcryn_quest_0', CT('Script.Mod_ExpAcryn.MissionAccomplished') + CT('Script.Mod_ExpAcryn.MalocMission'));",
                        "    else Ether(4, 'ExpAcryn_quest_0', CT('Script.Mod_ExpAcryn.MissionAccomplished') + Format(CT('Script.Mod_ExpAcryn.MalocMission2'), '<Reward'+'>', addItemName));",
                        "    DChange(2);",
                        "    exit;",
                        "  }",
                        "}"
