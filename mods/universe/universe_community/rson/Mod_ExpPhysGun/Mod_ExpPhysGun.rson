                    "Pos.x": 600,
                    "Pos.y": 615,
                    "Type": "TDialogAnswer",
                    "Parent": -1,
                    "#": 100,
                    "Msg": "Рад, что вам тоже понравилось :-)",
                    "AMsg.Num": "20",
