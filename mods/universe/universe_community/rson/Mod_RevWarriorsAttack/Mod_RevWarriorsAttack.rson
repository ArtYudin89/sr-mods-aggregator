                    "Code": [
                        "if((GroupIn(Warriors,RegroupPoint) && GroupIn(BombCarrier,RegroupPoint)) || !GroupCount(BombCarrier)) {",
                        "  ShipOut(CurShip);",
                        "}"
                    ],
