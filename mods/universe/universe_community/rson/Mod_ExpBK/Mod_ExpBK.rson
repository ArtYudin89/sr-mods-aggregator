                {
                    "Name": "",
                    "Code.Type": "Turn",
                    "Code": [
                        "if(!temp_int_3 && !LTradeLicenseCheck) {",
                        "  DChange(11);",
                        "  exit;",
                        "}",
                        "if(temp_int_3 == 1) {",
                        "  temp_int_2 = round(1.6 * GalaxyMoney(2)) * GalaxyDiffLevels(1) / 50;",
                        "  DChange(2);",
