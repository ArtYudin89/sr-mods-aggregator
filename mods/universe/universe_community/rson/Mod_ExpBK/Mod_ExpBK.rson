                },
                {
                    "Name": "",
                    "Code.Type": "Turn",
                    "Code": [
                        "temp_int = NumberBox('Bm.ItemsUseless.2Usl_Elus_s', CT(\"Script.Mod_ExpBK.93\"), 100, PlayerDebt(), ShipMoney(Player()), 'Bm.FormCount2.2KindCredits');",
                        "if(ShipMoney(Player()) - (temp_int + (temp_int * 5) / 100) < 0)",
                        "{",
                        "    MessageBox(CT(\"Script.Mod_ExpBK.89\"));",
                        "}",
                        "else",
                        "{",
                        "    if((PlayerDebt() - temp_int) < 100 && (PlayerDebt() - temp_int))",
                        "    {",
                        "        if(MessageBoxYesNo(CT(\"Script.Mod_ExpBK.92\")) == 1)",
                        "        {",
                        "            if(ShipMoney(Player()) < (temp_int + (PlayerDebt() - temp_int)))",
                        "            {",
                        "                MessageBox(CT(\"Script.Mod_ExpBK.91\"));",
                        "            }",
                        "            else",
                        "            {",
                        "                if(ShipMoney(Player()) - ((temp_int + (PlayerDebt() - temp_int)) + ((temp_int + (PlayerDebt() - temp_int)) * 5) / 100) < 0)",
                        "                {",
                        "                    MessageBox(CT(\"Script.Mod_ExpBK.89\"));",
                        "                }",
                        "                else",
                        "                {",
                        "                    temp_int = temp_int + (PlayerDebt() - temp_int);",
                        "                    ShipMoney(Player(), ShipMoney(Player()) - (temp_int + (temp_int * 5) / 100));",
                        "                    PlayerDebtCnt(0);",
                        "                    PlayerDebtDate(0);",
                        "                    PlayerDebt(0);",
                        "                    Sound('Sound.Sell');",
                        "                    MessageBox(CT(\"Script.Mod_ExpBK.90\"));",
                        "                }",
                        "            }",
                        "        }",
                        "    }",
                        "    if((PlayerDebt() - temp_int) == 0)",
                        "    {",
                        "        ShipMoney(Player(), ShipMoney(Player()) - (temp_int + (temp_int * 5) / 100));",
                        "        PlayerDebtCnt(0);",
                        "        PlayerDebtDate(0);",
                        "        PlayerDebt(0);",
                        "        Sound('Sound.Sell');",
                        "        MessageBox(CT(\"Script.Mod_ExpBK.90\"));",
                        "    }",
                        "    if((PlayerDebt() - temp_int) >= 100 && (PlayerDebt() - temp_int) && temp_int)",
                        "    {",
                        "        ShipMoney(Player(), ShipMoney(Player()) - (temp_int + (temp_int * 5) / 100));",
                        "        PlayerDebt(PlayerDebt() - temp_int);",
                        "        Sound('Sound.Sell');",
                        "    }",
                        "}",
                        "if(PlayerDebt()) {",
                        "  DChange(13);",
                        "  exit;",
                        "}",
                        "if(!PlayerDebt()) {",
