                    "Type": "Top",
                    "Parent": -1,
                    "Pos.x": 970,
                    "Pos.y": 425
                },
                {
                    "Name": "",
                    "Code.Type": "Turn",
                    "Code": [
                        "if(ShipMoney(Player())<cost_variation[0]) {",
                        "  DAdd(10);",
                        "}",
                        "if(ShipMoney(Player())>=cost_variation[0]) {",
                        "  DAdd(1);",
                        "}",
                        "if(ShipMoney(Player())<cost_variation[1]) {",
                        "  DAdd(11);",
                        "}",
                        "if(ShipMoney(Player())>=cost_variation[1]) {",
                        "  DAdd(2);",
                        "}",
                        "if(ShipMoney(Player())<cost_variation[2]) {",
                        "  DAdd(12);",
                        "}",
                        "if(ShipMoney(Player())>=cost_variation[2]) {",
                        "  DAdd(3);",
                        "}",
                        "InjectAnswer('ExitDB',CT(\"Script.Mod_ExpHulls.94\"),-1);"
