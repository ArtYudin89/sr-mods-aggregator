                        "temp_str = '</color>' + Format(CT(\"Script.Mod_ExpHulls.122\"),\"<0>\",temp_str,\"<1>\",DefSplt) + BonusText(bonus_type) + Format(CT(\"Script.Mod_ExpHulls.114\"),\"<0>\",size_variation[0],\"<1>\",cost_variation[0],\"<2>\",size_variation[1],\"<3>\",cost_variation[1],\"<4>\",size_variation[2],\"<5>\",cost_variation[2],\"<6>\",DefSplt);",
