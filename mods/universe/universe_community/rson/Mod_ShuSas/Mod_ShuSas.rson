                },
                {
                    "Name": "    DText(Format(CT(\"Script.Mod_ShuSas.0\"),\"<0>\",ShipName(Player())));    DAdd(1);\r\n    DAdd(2);\r\n    DAdd(5);\r\n",
                    "Pos.x": 1080,
                    "Pos.y": 465,
                    "Type": "TDialogAnswer",
