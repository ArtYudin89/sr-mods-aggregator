            "Items": [],
            "Operations": [
                {
                    "Name": "",
                    "Code.Type": "Global",
                    "Code": [
                        "GRun();"
                    ],
                    "#": 20,
                    "Type": "Top",
                    "Parent": -1,
                    "Pos.x": 0,
                    "Pos.y": 585
                },
                {
                    "Name": "",
                    "Code.Type": "Turn",
                    "Code": [
                        "if(findsubstr(GameDateTxtByTurn(CurTurn()), '1 января') == 0)",
                        "{",
                        "    count1 = 0;",
                        "    count2 = 0;",
                        "    count3 = 0;",
                        "    count4 = 0;",
                        "}"
                    ],
                    "#": 21,
                    "Type": "Top",
                    "Parent": -1,
                    "Pos.x": 120,
                    "Pos.y": 585
                },
                {
                    "Name": "",
                    "Code.Type": "DialogBegin",
                    "Code": [
                        "if(GetShipRuins(Player()))",
                        "{",
                        "    if(ShipType(GetShipRuins(Player())) == 'SB')",
                        "    {",
                        "        AddDialogInject('RepairBox', CT(\"Script.Mod_EvoRepairBox.31\"), 'Купить наборы для ремонта', 1);",
                        "    }",
                        "}"
                    ],
                    "#": 22,
                    "Type": "Top",
                    "Parent": -1,
                    "Pos.x": 180,
                    "Pos.y": 585
                },
                {
                    "Name": "",
                    "Code.Type": "Turn",
                    "Code": [
                        "total1=2+ShipRank(Player());",
                        "total2=1+ShipRank(Player());",
                        "total3=ShipRank(Player());",
                        "total4=1+ShipRank(Player());",
                        "",
                        "cost1=1.1*GalaxyMoney(2,ShipOwner(GetShipRuins(Player())));",
                        "cost2=1.2*GalaxyMoney(2,ShipOwner(GetShipRuins(Player())));",
                        "cost3=1.3*GalaxyMoney(2,ShipOwner(GetShipRuins(Player())));",
                        "cost4=1.0*GalaxyMoney(2,ShipOwner(GetShipRuins(Player())));",
                        "cur_count1=total1-count1;",
                        "cur_count2=total2-count2;",
                        "cur_count3=total3-count3;",
                        "cur_count4=total4-count4;",
                        "DChange(0);",
                        "exit;"
                    ],
                    "#": 35,
                    "Type": "Top",
                    "Parent": -1,
                    "Pos.x": -20,
                    "Pos.y": 375
                },
                {
                    "Name": "",
                    "Code.Type": "Turn",
                    "Code": [
                        "if(cur_count1==0)AddDialogBlock('Купить набор для ремонта Юный техник',1);",
                        "if(cur_count2==0)AddDialogBlock('Купить набор для ремонта Умелый техник',1);",
                        "if(cur_count3==0)AddDialogBlock('Купить набор для ремонта Искусный техник',1);",
                        "if(cur_count4==0)AddDialogBlock('Купить набор Прочность забиратор',1);",
                        "DAdd(0);",
                        "DAdd(3);",
                        "DAdd(4);",
                        "DAdd(5);",
                        "DAdd(1);"
                    ],
                    "#": 36,
                    "Type": "Top",
                    "Parent": -1,
                    "Pos.x": -20,
                    "Pos.y": 445
                },
                {
                    "Name": "",
                    "Code.Type": "Turn",
                    "Code": [
                        "DAdd(2);"
                    ],
                    "#": 37,
                    "Type": "Top",
                    "Parent": -1,
                    "Pos.x": 130,
                    "Pos.y": 445
                },
                {
                    "Name": "",
                    "Code.Type": "Turn",
                    "Code": [
                        "DAdd(6);"
                    ],
                    "#": 38,
                    "Type": "Top",
                    "Parent": -1,
                    "Pos.x": 280,
                    "Pos.y": 445
                },
                {
                    "Name": "",
                    "Code.Type": "Turn",
                    "Code": [
                        "if(cost1<ShipMoney(Player())) {",
                        "  AddItemToShip(Player(),CreateQuestItem('TechJunior'));",
                        "  ShipMoney(Player(),ShipMoney(Player())-cost1);",
                        "  Sound('Sound.Buy');",
                        "  count1=count1+1;",
                        "  DChange(1);",
                        "  exit;",
                        "}",
                        "if(cost1>ShipMoney(Player())) {",
                        "  DChange(2);",
                        "  exit;",
                        "}"
                    ],
                    "#": 39,
                    "Type": "Top",
                    "Parent": -1,
                    "Pos.x": -20,
                    "Pos.y": 515
                },
                {
                    "Name": "",
                    "Code.Type": "Turn",
                    "Code": [
                        "if(cost2<ShipMoney(Player())) {",
                        "  AddItemToShip(Player(),CreateQuestItem('TechSkillful'));",
                        "  ShipMoney(Player(),ShipMoney(Player())-cost2);",
                        "  Sound('Sound.Buy');",
                        "  count2=count2+1;",
                        "  DChange(1);",
                        "  exit;",
                        "}",
                        "if(cost2>ShipMoney(Player())) {",
                        "  DChange(2);",
                        "  exit;",
                        "}"
                    ],
                    "#": 40,
                    "Type": "Top",
                    "Parent": -1,
                    "Pos.x": 340,
                    "Pos.y": 515
                },
                {
                    "Name": "",
                    "Code.Type": "Turn",
                    "Code": [
                        "if(cost3<ShipMoney(Player())) {",
                        "  AddItemToShip(Player(),CreateQuestItem('TechMaster'));",
                        "  ShipMoney(Player(),ShipMoney(Player())-cost3);",
                        "  Sound('Sound.Buy');",
                        "  count3=count3+1;",
                        "  DChange(1);",
                        "  exit;",
                        "}",
                        "if(cost3>ShipMoney(Player())) {",
                        "  DChange(2);",
