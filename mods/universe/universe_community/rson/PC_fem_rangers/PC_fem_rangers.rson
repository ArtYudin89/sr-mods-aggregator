                        "            DChange(104);",
                        "            exit;",
                        "          }",
                        "        }",
                        "        if(quest_status!=10) {",
                        "          if(ShipRank(Player())<3) {",
                        "            DChange(85);",
                        "            exit;",
                        "          }",
                        "          if(ShipRank(Player())>=3) {",
                        "            if(PlayerQuestInProgress()) {",
                        "              DChange(66);",
                        "              exit;",
                        "            }",
                        "            if(!PlayerQuestInProgress()) {",
                        "              if(ControlledSystems(0)>=15) {",
                        "                counter=1;",
                        "                counter2=0;",
                        "                quest_star=0;",
                        "                while (counter<20){",
                        "                if (StarOwner(StarNearbyStars(ShipStar(Player()),counter))==0){",
                        "                quest_star=StarNearbyStars(ShipStar(Player()),counter);",
                        "                counter2=counter2+1;}",
                        "                counter=counter+1;}",
                        "                if(counter2>=10) {",
                        "                  DChange(67);",
