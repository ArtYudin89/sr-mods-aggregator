                    "_orig_danswer": "DAnswer('exit~'+CT(\"Script.PC_fem_rangers.178\"))"
                },
                {
                    "Name": "",
                    "Pos.x": 1440,
                    "Pos.y": 1290,
                    "Type": "TDialogAnswer",
