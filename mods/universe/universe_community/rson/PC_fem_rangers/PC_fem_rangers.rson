                {
                    "Name": "",
                    "Code.Type": "Turn",
                    "Code": [
                        "dword agent = GetTalkShip();",
                        "if(~agent_ship_orig_race) str race = CT('Script.PC_fem_rangers.SecretAgentNames.' + agent_ship_orig_race);",
                        "else race = CT('Script.PC_fem_rangers.SecretAgentNames.' + ShipPilotRace(agent));",
                        "",
                        "//Агентка рвёт контракт по какой-то обычной игровой причине",
                        "if(max_relation >= 10)",
                        "{",
                        "    //Агентка разрывает контракт из-за плохого отношения к игроку",
                        "    if(GAnswerData == TalkBreakPartner)",
                        "    {",
                        "        tstr1 = '</color>' + CT('Script.PC_fem_rangers.PlayerHaveNormalRelationsWithAgents.AgentPartnershipBreak.' + race + '.BadRelations.Agent' + RndObject(1, 2, agent));",
                        "        tstr2 = '</color>' + CT('Script.PC_fem_rangers.PlayerHaveNormalRelationsWithAgents.AgentPartnershipBreak.' + race + '.BadRelations.Player' + RndObject(1, 2, Player()));",
                        "    }",
                        "    //Вышел срок контракта, либо у игрока стало недостаточно лидерства",
                        "    else if(GAnswerData == TalkPartnerTheEnd)",
                        "    {",
                        "        //У игрока недостаточно лидерства (в оригинальном коде проверяется первым)",
                        "        //+1 в проверке нужен, т.к. в момент вызова диалога число партнёров игрока уже сокращено",
                        "        if(ShipPartners(Player()) + PlayerPirates() + 1 > ShipSkill(Player(), 'LeadershipCur'))",
                        "        {",
                        "            tstr1 = '</color>' + CT('Script.PC_fem_rangers.PlayerHaveNormalRelationsWithAgents.AgentPartnershipBreak.' + race + '.LowLeadership.Agent' + RndObject(1, 2, agent));",
                        "            tstr2 = '</color>' + CT('Script.PC_fem_rangers.PlayerHaveNormalRelationsWithAgents.AgentPartnershipBreak.' + race + '.LowLeadership.Player' + RndObject(1, 2, Player()));",
                        "        }",
                        "        //Истёк срок контракта",
                        "        else //if(!ShipIsPartner(CurShip, 1))",
                        "        {",
                        "            tstr1 = '</color>' + CT('Script.PC_fem_rangers.PlayerHaveNormalRelationsWithAgents.AgentPartnershipBreak.' + race + '.ContractExpired.Agent' + RndObject(1, 2, agent));",
                        "            tstr2 = '</color>' + CT('Script.PC_fem_rangers.PlayerHaveNormalRelationsWithAgents.AgentPartnershipBreak.' + race + '.ContractExpired.Player' + RndObject(1, 2, Player()));",
                        "        }",
                        "    }",
                        "    //Агентка разрывает контракт, если по какой-то причине ведёт бой с другим партнёром игрока",
                        "    else //if(GAnswerData == TalkPartnerRiot)",
                        "    {",
                        "        tstr1 = '</color>' + CT('Script.PC_fem_rangers.PlayerHaveNormalRelationsWithAgents.AgentPartnershipBreak.' + race + '.TroublesInTeam.Agent' + RndObject(1, 2, agent));",
                        "        tstr2 = '</color>' + CT('Script.PC_fem_rangers.PlayerHaveNormalRelationsWithAgents.AgentPartnershipBreak.' + race + '.TroublesInTeam.Player' + RndObject(1, 2, Player()));",
                        "    }",
                        "",
                        "    tstr3 = '</color>' + CT('Talk.Exit');",
                        "}",
                        "//Агентка рвёт контракт, поскольку игрок испортил общие отношения со всеми агентками",
                        "else",
                        "{",
                        "    CT('Script.PC_fem_rangers.PlayerHaveBadRelationsWithAgents.AgentPartnershipBreak.' + race);",
                        "",
                        "    tstr1 = '</color>' + CT('Script.PC_fem_rangers.PlayerHaveBadRelationsWithAgents.AgentPartnershipBreak.' + race + '.Agent' + RndObject(1, 2, agent));",
                        "    tstr2 = '</color>' + CT('Script.PC_fem_rangers.PlayerHaveBadRelationsWithAgents.AgentPartnershipBreak.' + race + '.Player' + RndObject(1, 2, Player()));",
                        "    tstr3 = '</color>' + CT('Talk.Exit');",
                        "}",
                        "DChange(63);",
                        "exit;"
                    ],
                    "#": 499,
                    "Type": "Top",
                    "Parent": -1,
                    "Pos.x": 880,
                    "Pos.y": 775
                },
                {
                    "Name": "",
                    "Code.Type": "Turn",
                    "Code": [
                        "cur_talk_ship=GetTalkShip();",
                        "cur_relation=min(max(0,max_relation),RelationToRanger(cur_talk_ship,Player()));",
                        "cur_relation_type=0;",
                        "if (cur_relation>=10){cur_relation_type=1;}",
                        "if (cur_relation>=30){cur_relation_type=2;}",
                        "if (cur_relation>=60){cur_relation_type=3;}",
                        "if (cur_relation>=80){cur_relation_type=4;}",
                        "if(cur_relation_type>=2) {",
                        "  if((GetShipPirateRank(Player())<6) && ((GetShipPirateRank(Player())-agent_counter)<=2)) {",
                        "    if(StarOwner(ShipStar(Player()))==0) {",
                        "      counter=0;",
                        "      quest_ship=0;",
                        "      while (counter<GroupCount(GroupEnemies)){",
                        "      if (ShipInNormalSpace(GroupShip(GroupEnemies,counter)) && (ShipStar(cur_talk_ship)==ShipStar(GroupShip(GroupEnemies,counter)))){",
                        "      if ((ShipGetBad(cur_talk_ship)==GroupShip(GroupEnemies,counter)) || (cur_talk_ship==ShipGetBad(GroupShip(GroupEnemies,counter)))){",
                        "      if (Dist(cur_talk_ship,GroupShip(GroupEnemies,counter))<500){quest_ship=GroupShip(GroupEnemies,counter);}",
                        "      }}",
                        "      counter=counter+1;}",
                        "      if (ShipGetBad(cur_talk_ship)){",
                        "      if (ShipStar(ShipGetBad(cur_talk_ship))==ShipStar(cur_talk_ship)){",
                        "      if (Dist(cur_talk_ship,ShipGetBad(cur_talk_ship))<500){",
                        "      quest_ship=ShipGetBad(cur_talk_ship);",
                        "      }}}",
                        "      if(!quest_ship) {",
                        "        if(quest_status==10) {",
                        "          if(shu_extra_mission) {",
                        "            quest_planet=0;",
                        "            quest_star=0;",
                        "            supply_system_value=3;",
                        "            supply_system=0;",
                        "            counter=BuildListOfQuestPossibleLocations(locations,ShipStar(Player()),1,255);",
                        "            if (counter){",
                        "            counter=0;",
                        "            while (counter<(ArrayDim(locations))){",
                        "            counter2=0;",
                        "            counter3=0;",
                        "            supply_system_value2=0;",
                        "            while (counter2<(ArrayDim(locations))){",
                        "            if (Dist(locations[counter2],locations[counter])<(16+3*GalaxyTechLevel())){counter3=counter3+1;}",
                        "            if (Dist(locations[counter2],locations[counter])<(32+6*GalaxyTechLevel())){supply_system_value2=supply_system_value2+1;}",
                        "            counter2=counter2+1;}",
                        "            if ((counter3==supply_system_value) && (supply_system_value2>6)){ ",
                        "            if (abs(Dist(supply_system,ShipStar(Player()))-60)>abs(Dist(locations[counter],ShipStar(Player()))-60)){",
                        "            supply_system=locations[counter];}}",
                        "            if ((counter3>supply_system_value) && (supply_system_value2>6)){",
                        "            supply_system=locations[counter];",
                        "            supply_system_value=counter3;}",
                        "            counter=counter+1;}",
                        "            }",
                        "            if (supply_system_value>3){quest_star=supply_system;",
                        "            quest_planet=FindPlanet(quest_star,'NotMaloc,NotPeleng,NotPeople,NotFei,NotGaal,NotPirateClan',0,100);}",
                        "            if(!quest_planet) {",
                        "              DChange(130);",
                        "              exit;",
                        "            }",
                        "            if(quest_planet) {",
                        "              DChange(105);",
                        "              exit;",
                        "            }",
                        "          }",
                        "          if(!shu_extra_mission) {",
                        "            DChange(104);",
                        "            exit;",
                        "          }",
                        "        }",
                        "        if(quest_status!=10) {",
                        "          if(ShipRank(Player())<3) {",
                        "            DChange(85);",
                        "            exit;",
                        "          }",
                        "          if(ShipRank(Player())>=3) {",
                        "            if(PlayerQuestInProgress()) {",
                        "              DChange(66);",
                        "              exit;",
                        "            }",
                        "            if(!PlayerQuestInProgress()) {",
                        "              if(ControlledSystems(0)>=15) {",
                        "                counter=1;",
                        "                counter2=0;",
                        "                quest_star=0;",
                        "                while (counter<20){",
                        "                if (StarOwner(StarNearbyStars(ShipStar(Player()),counter))==0){",
                        "                quest_star=StarNearbyStars(ShipStar(Player()),counter);",
                        "                counter2=counter2+1;}",
                        "                counter=counter+1;}",
                        "                if(counter2>=10) {",
                        "                  DChange(67);",
                        "                  exit;",
                        "                }",
                        "                if(counter2<10) {",
                        "                  DChange(86);",
                        "                  exit;",
                        "                }",
                        "              }",
                        "              if(ControlledSystems(0)<15) {",
                        "                DChange(87);",
                        "                exit;",
                        "              }",
                        "            }",
                        "          }",
                        "        }",
                        "      }",
                        "      if(quest_ship) {",
                        "        if(ShipGetBad(quest_ship)==cur_talk_ship) {",
                        "          DChange(83);",
                        "          exit;",
                        "        }",
                        "        if(ShipGetBad(quest_ship)!=cur_talk_ship) {",
                        "          DChange(84);",
                        "          exit;",
                        "        }",
                        "      }",
                        "    }",
                        "    if(StarOwner(ShipStar(Player()))==1) {",
                        "      DChange(80);",
                        "      exit;",
                        "    }",
                        "    if(StarOwner(ShipStar(Player()))==2) {",
                        "      DChange(81);",
                        "      exit;",
                        "    }",
                        "  }",
                        "  if((GetShipPirateRank(Player())>=6) || ((GetShipPirateRank(Player())-agent_counter)>2)) {",
                        "    if(GetShipPirateRank(Player())>agent_counter*2) {",
                        "      if(cur_relation_type==0) {",
                        "        DChange(52);",
                        "        exit;",
                        "      }",
                        "      if(cur_relation_type==1) {",
                        "        DChange(53);",
                        "        exit;",
                        "      }",
                        "      if(cur_relation_type==2) {",
                        "        DChange(54);",
                        "        exit;",
                        "      }",
                        "      if(cur_relation_type==3) {",
                        "        DChange(55);",
                        "        exit;",
                        "      }",
                        "      if(cur_relation_type==4) {",
                        "        DChange(56);",
                        "        exit;",
                        "      }",
                        "    }",
                        "    if(GetShipPirateRank(Player())<=agent_counter*2) {",
                        "      if(cur_relation_type==0) {",
                        "        DChange(57);",
                        "        exit;",
                        "      }",
                        "      if(cur_relation_type==1) {",
                        "        DChange(58);",
                        "        exit;",
                        "      }",
                        "      if(cur_relation_type==2) {",
                        "        DChange(59);",
                        "        exit;",
                        "      }",
                        "      if(cur_relation_type==3) {",
                        "        DChange(60);",
                        "        exit;",
                        "      }",
                        "      if(cur_relation_type==4) {",
                        "        DChange(61);",
                        "        exit;",
                        "      }",
                        "    }",
                        "  }",
                        "}",
                        "if(cur_relation_type<2) {",
                        "  DChange(82);",
                        "  exit;",
                        "}"
