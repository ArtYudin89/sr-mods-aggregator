                },
                {
                    "Name": "",
                    "Code.Type": "Turn",
                    "Code": [
                        "//Диалог, блокирующий любое нормальное взаимодействие с агентами, если те относятся к нему плохо (имеется в виду отношение в max_relation)",
                        "int talk_reason = GAnswerData;",
                        "check = 0;",
                        "",
                        "if(!TalkByAI())",
                        "{",
                        "    if(~agent_ship_orig_race) str race = CT('Script.PC_fem_rangers.SecretAgentNames.' + agent_ship_orig_race);",
                        "    else race = CT('Script.PC_fem_rangers.SecretAgentNames.' + ShipPilotRace(quest_ship));",
                        "",
                        "    if(RelationToRanger(quest_ship, Player()) >= 10)",
                        "    {",
                        "        if(!player_hate) tstr1 = '</color>' + CT('Script.PC_fem_rangers.PlayerHaveBadRelationsWithAgents.PlayerSpeakWithAgent.NormalRelations.' + race + '.TextNormal');",
                        "        else tstr1 = '</color>' + CT('Script.PC_fem_rangers.PlayerHaveBadRelationsWithAgents.PlayerSpeakWithAgent.' + race + '.TextHate');",
                        "        tstr3 = '</color>' + CT('Talk.Exit');",
                        "    }",
                        "    else",
                        "    {",
                        "        if(!player_hate) tstr1 = '</color>' + CT('Script.PC_fem_rangers.PlayerHaveBadRelationsWithAgents.PlayerSpeakWithAgent.AggressiveRelations.' + race + '.TextNormal');",
                        "        else tstr1 = '</color>' + CT('Script.PC_fem_rangers.PlayerHaveBadRelationsWithAgents.PlayerSpeakWithAgent.' + race + '.TextHate');",
                        "        tstr3 = '</color>' + CT('Talk.Exit');",
                        "    }",
                        "}",
                        "else //if(TalkByAI())",
                        "{",
                        "    if(~agent_ship_orig_race) race = CT('Script.PC_fem_rangers.SecretAgentNames.' + agent_ship_orig_race);",
                        "    else race = CT('Script.PC_fem_rangers.SecretAgentNames.' + ShipPilotRace(quest_ship));",
                        "",
                        "    if(talk_reason == TalkMoney || talk_reason == TalkGoods)",
                        "    {",
                        "        int rnd = RndObject(1, 3, quest_ship);",
                        "        tstr1 = '</color>' + CT('Script.PC_fem_rangers.PlayerHaveBadRelationsWithAgents.AgentRacketPlayer.' + race + '.Text' + rnd);",
                        "        tstr3 = '</color>' + CT('Talk.Exit');",
                        "    }",
                        "    else if(talk_reason == TalkAttack)",
                        "    {",
                        "        if(RelationToRanger(quest_ship, Player()) >= 10 && ShipOrderObj(quest_ship))",
                        "        {",
                        "            tstr1 = '</color>' + Format(CT('Script.PC_fem_rangers.PlayerHaveBadRelationsWithAgents.AgentAskPlayerHelpInAttack.' + race + '.TextAskHelp'), '<Target'+'>', Name(ShipOrderObj(quest_ship)) + '<Object=' + ShipOrderObj(quest_ship) + ',23,17,0>');",
                        "            tstr2 = '</color>' + CT('Script.PC_fem_rangers.PlayerHaveBadRelationsWithAgents.AgentAskPlayerHelpInAttack.' + race + '.PlayerYes');",
                        "            tstr3 = '</color>' + CT('Script.PC_fem_rangers.PlayerHaveBadRelationsWithAgents.AgentAskPlayerHelpInAttack.' + race + '.PlayerNo');",
                        "            check = 1;",
                        "        }",
                        "        else",
                        "        {",
                        "            tstr1 = '</color>' + CT('Script.PC_fem_rangers.PlayerHaveBadRelationsWithAgents.AgentAskPlayerHelpInAttack.' + race + '.TextAggressive');",
                        "            tstr3 = '</color>' + CT('Talk.Exit');",
                        "        }",
                        "    }",
                        "    else if(talk_reason == TalkTruce)",
                        "    {",
                        "        money_truce = GalaxyMoney(1);",
                        "        rnd = RndObject(1, 2, quest_ship);",
                        "        tstr1 = '</color>' + Format(CT('Script.PC_fem_rangers.PlayerHaveBadRelationsWithAgents.AgentAskTruceWithPlayer.' + race + '.Text' + rnd), '<Cost'+'>', money_truce);",
                        "        tstr2 = '</color>' + CT('Script.PC_fem_rangers.PlayerHaveBadRelationsWithAgents.AgentAskTruceWithPlayer.' + race + '.PlayerYes' + rnd);",
                        "        tstr3 = '</color>' + CT('Script.PC_fem_rangers.PlayerHaveBadRelationsWithAgents.AgentAskTruceWithPlayer.' + race + '.PlayerNo' + rnd);",
                        "        check = 2;",
                        "    }",
                        "    else",
                        "    {",
                        "        if(RelationToRanger(quest_ship, Player()) >= 10)",
                        "        {",
                        "            if(!player_hate) tstr1 = '</color>' + CT('Script.PC_fem_rangers.PlayerHaveBadRelationsWithAgents.PlayerSpeakWithAgent.NormalRelations.' + race + '.TextNormal');",
                        "            else tstr1 = '</color>' + CT('Script.PC_fem_rangers.PlayerHaveBadRelationsWithAgents.PlayerSpeakWithAgent.' + race + '.TextHate');",
                        "            tstr3 = '</color>' + CT('Talk.Exit');",
                        "        }",
                        "        else",
                        "        {",
                        "            if(!player_hate) tstr1 = '</color>' + CT('Script.PC_fem_rangers.PlayerHaveBadRelationsWithAgents.PlayerSpeakWithAgent.AggressiveRelations.' + race + '.TextNormal');",
                        "            else tstr1 = '</color>' + CT('Script.PC_fem_rangers.PlayerHaveBadRelationsWithAgents.PlayerSpeakWithAgent.' + race + '.TextHate');",
                        "            tstr3 = '</color>' + CT('Talk.Exit');",
                        "        }",
                        "    }",
                        "}",
                        "DChange(131);",
                        "exit;"
                    ],
                    "#": 494,
                    "Type": "Top",
                    "Parent": -1,
                    "Pos.x": -20,
                    "Pos.y": 775
                },
                {
                    "Name": "",
                    "Code.Type": "Turn",
                    "Code": [
                        "if(max_relation < 10) {",
                        "  //Диалог, блокирующий любое нормальное взаимодействие с агентами, если те относятся к нему плохо (имеется в виду отношение в max_relation)",
                        "  int talk_reason = GAnswerData;",
                        "  check = 0;",
                        "  ",
                        "  if(!TalkByAI())",
                        "  {",
                        "      if(~agent_ship_orig_race) str race = CT('Script.PC_fem_rangers.SecretAgentNames.' + agent_ship_orig_race);",
                        "      else race = CT('Script.PC_fem_rangers.SecretAgentNames.' + ShipPilotRace(quest_ship));",
                        "  ",
                        "      if(RelationToRanger(quest_ship, Player()) >= 10)",
                        "      {",
                        "          if(!player_hate) tstr1 = '</color>' + CT('Script.PC_fem_rangers.PlayerHaveBadRelationsWithAgents.PlayerSpeakWithAgent.NormalRelations.' + race + '.TextNormal');",
                        "          else tstr1 = '</color>' + CT('Script.PC_fem_rangers.PlayerHaveBadRelationsWithAgents.PlayerSpeakWithAgent.' + race + '.TextHate');",
                        "          tstr3 = '</color>' + CT('Talk.Exit');",
                        "      }",
                        "      else",
                        "      {",
                        "          if(!player_hate) tstr1 = '</color>' + CT('Script.PC_fem_rangers.PlayerHaveBadRelationsWithAgents.PlayerSpeakWithAgent.AggressiveRelations.' + race + '.TextNormal');",
                        "          else tstr1 = '</color>' + CT('Script.PC_fem_rangers.PlayerHaveBadRelationsWithAgents.PlayerSpeakWithAgent.' + race + '.TextHate');",
                        "          tstr3 = '</color>' + CT('Talk.Exit');",
                        "      }",
                        "  }",
                        "  else //if(TalkByAI())",
                        "  {",
                        "      if(~agent_ship_orig_race) race = CT('Script.PC_fem_rangers.SecretAgentNames.' + agent_ship_orig_race);",
                        "      else race = CT('Script.PC_fem_rangers.SecretAgentNames.' + ShipPilotRace(quest_ship));",
                        "  ",
                        "      if(talk_reason == TalkMoney || talk_reason == TalkGoods)",
                        "      {",
                        "          int rnd = RndObject(1, 3, quest_ship);",
                        "          tstr1 = '</color>' + CT('Script.PC_fem_rangers.PlayerHaveBadRelationsWithAgents.AgentRacketPlayer.' + race + '.Text' + rnd);",
                        "          tstr3 = '</color>' + CT('Talk.Exit');",
                        "      }",
                        "      else if(talk_reason == TalkAttack)",
                        "      {",
                        "          if(RelationToRanger(quest_ship, Player()) >= 10 && ShipOrderObj(quest_ship))",
                        "          {",
                        "              tstr1 = '</color>' + Format(CT('Script.PC_fem_rangers.PlayerHaveBadRelationsWithAgents.AgentAskPlayerHelpInAttack.' + race + '.TextAskHelp'), '<Target'+'>', Name(ShipOrderObj(quest_ship)) + '<Object=' + ShipOrderObj(quest_ship) + ',23,17,0>');",
                        "              tstr2 = '</color>' + CT('Script.PC_fem_rangers.PlayerHaveBadRelationsWithAgents.AgentAskPlayerHelpInAttack.' + race + '.PlayerYes');",
                        "              tstr3 = '</color>' + CT('Script.PC_fem_rangers.PlayerHaveBadRelationsWithAgents.AgentAskPlayerHelpInAttack.' + race + '.PlayerNo');",
                        "              check = 1;",
                        "          }",
                        "          else",
                        "          {",
                        "              tstr1 = '</color>' + CT('Script.PC_fem_rangers.PlayerHaveBadRelationsWithAgents.AgentAskPlayerHelpInAttack.' + race + '.TextAggressive');",
                        "              tstr3 = '</color>' + CT('Talk.Exit');",
                        "          }",
                        "      }",
                        "      else if(talk_reason == TalkTruce)",
                        "      {",
                        "          money_truce = GalaxyMoney(1);",
                        "          rnd = RndObject(1, 2, quest_ship);",
                        "          tstr1 = '</color>' + Format(CT('Script.PC_fem_rangers.PlayerHaveBadRelationsWithAgents.AgentAskTruceWithPlayer.' + race + '.Text' + rnd), '<Cost'+'>', money_truce);",
                        "          tstr2 = '</color>' + CT('Script.PC_fem_rangers.PlayerHaveBadRelationsWithAgents.AgentAskTruceWithPlayer.' + race + '.PlayerYes' + rnd);",
                        "          tstr3 = '</color>' + CT('Script.PC_fem_rangers.PlayerHaveBadRelationsWithAgents.AgentAskTruceWithPlayer.' + race + '.PlayerNo' + rnd);",
                        "          check = 2;",
                        "      }",
                        "      else",
                        "      {",
                        "          if(RelationToRanger(quest_ship, Player()) >= 10)",
                        "          {",
                        "              if(!player_hate) tstr1 = '</color>' + CT('Script.PC_fem_rangers.PlayerHaveBadRelationsWithAgents.PlayerSpeakWithAgent.NormalRelations.' + race + '.TextNormal');",
                        "              else tstr1 = '</color>' + CT('Script.PC_fem_rangers.PlayerHaveBadRelationsWithAgents.PlayerSpeakWithAgent.' + race + '.TextHate');",
                        "              tstr3 = '</color>' + CT('Talk.Exit');",
                        "          }",
                        "          else",
                        "          {",
                        "              if(!player_hate) tstr1 = '</color>' + CT('Script.PC_fem_rangers.PlayerHaveBadRelationsWithAgents.PlayerSpeakWithAgent.AggressiveRelations.' + race + '.TextNormal');",
                        "              else tstr1 = '</color>' + CT('Script.PC_fem_rangers.PlayerHaveBadRelationsWithAgents.PlayerSpeakWithAgent.' + race + '.TextHate');",
                        "              tstr3 = '</color>' + CT('Talk.Exit');",
                        "          }",
                        "      }",
                        "  }",
                        "  DChange(131);",
                        "  exit;",
                        "}",
                        "if(max_relation >= 10) {",
                        "  cur_relation = min(max(0, max_relation), RelationToRanger(CurShip, Player()));",
                        "  cur_relation_type = 0;",
                        "  if(cur_relation >= 80) cur_relation_type = 4;",
                        "  else if(cur_relation >= 60) cur_relation_type = 3;",
                        "  else if(cur_relation >= 30) cur_relation_type = 2;",
                        "  else if(cur_relation >= 10) cur_relation_type = 1;",
                        "  roll = (Id(CurShip) + CurTurn() / 20) % 2;",
                        "  if(StateIs(CurShip, 'FemGuardVsPlayer', 'FemDeliveryVsPlayer')) {",
                        "    DChange(62);",
                        "    exit;",
                        "  }",
                        "  if(!StateIs(CurShip, 'FemGuardVsPlayer', 'FemDeliveryVsPlayer')) {",
                        "    if(second_try != 1) {",
                        "      if(!cur_relation_type) {",
                        "        if(roll) {",
                        "          DChange(0);",
                        "          exit;",
                        "        }",
                        "        if(!roll) {",
                        "          DChange(1);",
                        "          exit;",
                        "        }",
                        "      }",
                        "      if(cur_relation_type == 1) {",
                        "        if(roll) {",
                        "          DChange(2);",
                        "          exit;",
                        "        }",
                        "        if(!roll) {",
                        "          DChange(3);",
                        "          exit;",
                        "        }",
                        "      }",
                        "      if(cur_relation_type == 2) {",
                        "        if(roll) {",
                        "          DChange(4);",
                        "          exit;",
                        "        }",
                        "        if(!roll) {",
                        "          DChange(5);",
                        "          exit;",
                        "        }",
                        "      }",
                        "      if(cur_relation_type == 3) {",
                        "        if(roll) {",
                        "          DChange(6);",
                        "          exit;",
                        "        }",
                        "        if(!roll) {",
                        "          DChange(7);",
                        "          exit;",
                        "        }",
                        "      }",
                        "      if(cur_relation_type == 4) {",
                        "        if(roll) {",
                        "          DChange(8);",
                        "          exit;",
                        "        }",
                        "        if(!roll) {",
                        "          DChange(9);",
                        "          exit;",
                        "        }",
                        "      }",
                        "    }",
                        "    if(second_try == 1) {",
                        "      if(ShipIsPartner(CurShip) ||",
                        "      StarOwner(ShipStar(Player())) ||",
                        "      (GetShipPirateRank(Player()) >= 6) ||",
                        "      (((GetShipPirateRank(Player()) - agent_counter) > 2)) ||",
                        "      (RelationToRanger(quest_ship, Player()) < 30)) {",
                        "        if(!cur_relation_type) {",
                        "          if(roll) {",
                        "            DChange(0);",
                        "            exit;",
                        "          }",
                        "          if(!roll) {",
                        "            DChange(1);",
                        "            exit;",
                        "          }",
                        "        }",
                        "        if(cur_relation_type == 1) {",
                        "          if(roll) {",
                        "            DChange(2);",
                        "            exit;",
                        "          }",
                        "          if(!roll) {",
                        "            DChange(3);",
                        "            exit;",
                        "          }",
                        "        }",
                        "        if(cur_relation_type == 2) {",
                        "          if(roll) {",
                        "            DChange(4);",
                        "            exit;",
                        "          }",
                        "          if(!roll) {",
                        "            DChange(5);",
                        "            exit;",
                        "          }",
                        "        }",
                        "        if(cur_relation_type == 3) {",
                        "          if(roll) {",
                        "            DChange(6);",
                        "            exit;",
                        "          }",
                        "          if(!roll) {",
                        "            DChange(7);",
                        "            exit;",
                        "          }",
                        "        }",
                        "        if(cur_relation_type == 4) {",
                        "          if(roll) {",
                        "            DChange(8);",
                        "            exit;",
                        "          }",
                        "          if(!roll) {",
                        "            DChange(9);",
                        "            exit;",
                        "          }",
                        "        }",
                        "      }",
                        "      if(!ShipIsPartner(CurShip) &&",
                        "      !StarOwner(ShipStar(Player())) &&",
                        "      GetShipPirateRank(Player()) < 6 &&",
                        "      (GetShipPirateRank(Player()) - agent_counter) <= 2 &&",
                        "      RelationToRanger(quest_ship, Player()) >= 30) {",
                        "        DChange(38);",
                        "        exit;",
                        "      }",
                        "    }",
                        "  }",
                        "}"
