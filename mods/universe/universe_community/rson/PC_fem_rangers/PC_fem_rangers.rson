                    "Code": [
                        "bonus_mm = newarray(1);",
                        "",
                        "ModInit();",
                        "mod_init_done = 1;",
                        "function ModInit()",
                        "{",
                        "    free(fem_names);",
                        "    fem_names = newarray(5, 1);",
                        "",
                        "    ArrayDelete(fem_names[0], 0);",
                        "    for(i = 1; i <= CT('Script.PC_fem_rangers.SecretAgentNames.Maloc.Count'); i = i + 1)",
                        "    {",
                        "        ArrayAdd(fem_names[0], CT('Script.PC_fem_rangers.SecretAgentNames.Maloc.' + i));",
                        "    }",
                        "    ArrayDelete(fem_names[2], 0);",
                        "    for(i = 1; i <= CT('Script.PC_fem_rangers.SecretAgentNames.People.Count'); i = i + 1)",
                        "    {",
                        "        ArrayAdd(fem_names[2], CT('Script.PC_fem_rangers.SecretAgentNames.People.' + i));",
                        "    }",
                        "",
                        "    free(hull_names);",
                        "    hull_names = newarray(5, 1);",
                        "",
                        "    ArrayDelete(hull_names[0], 0);",
                        "    ArrayAdd(hull_names[0], 'EvoFemRangers_SecretAgentMaloc1', 'GTL1'); //Корпус \"Ужастик\" II",
                        "    ArrayAdd(hull_names[0], 'EvoFemRangers_SecretAgentMaloc1', 'GTL2');",
                        "    ArrayAdd(hull_names[0], 'EvoFemRangers_SecretAgentMaloc2', 'GTL3');",
                        "    ArrayAdd(hull_names[0], 'EvoFemRangers_SecretAgentMaloc2', 'GTL4'); //Корпус \"Ужастик\" III",
                        "    ArrayAdd(hull_names[0], 'EvoFemRangers_SecretAgentMaloc3', 'GTL5');",
                        "    ArrayAdd(hull_names[0], 'EvoFemRangers_SecretAgentMaloc3', 'GTL6');",
                        "    ArrayAdd(hull_names[0], 'EvoFemRangers_SecretAgentMaloc4', 'GTL7'); //Корпус \"Ужастик\" IV",
                        "    ArrayAdd(hull_names[0], 'EvoFemRangers_SecretAgentMaloc4', 'GTL8');",
                        "",
                        "    ArrayDelete(hull_names[2], 0);",
                        "    ArrayAdd(hull_names[2], '480', 'GTL1'); //Корпус \"Ушастик\" II",
                        "    ArrayAdd(hull_names[2], '480', 'GTL2');",
                        "    ArrayAdd(hull_names[2], '481', 'GTL3');",
                        "    ArrayAdd(hull_names[2], '481', 'GTL4'); //Корпус \"Ушастик\" III",
                        "    ArrayAdd(hull_names[2], '482', 'GTL5');",
                        "    ArrayAdd(hull_names[2], '482', 'GTL6');",
                        "    ArrayAdd(hull_names[2], '483', 'GTL7'); //Корпус \"Ушастик\" IV",
                        "    ArrayAdd(hull_names[2], '483', 'GTL8');",
                        "}",
                        "",
                        "item_names = newarray(1);",
                        "item_names[0] = 'Usl_RandomItem_01';",
                        "ArrayAdd(item_names, 'Usl_RandomItem_02');",
                        "ArrayAdd(item_names,'Usl_RandomItem_03');",
                        "ArrayAdd(item_names, 'Usl_RandomItem_04');",
                        "",
                        "bonus_arts = newarray(1);",
                        "bonus_arts[0] = t_ArtefactHull;",
                        "ArrayAdd(bonus_arts, t_ArtefactFuel);",
                        "ArrayAdd(bonus_arts, t_ArtefactSpeed);",
                        "ArrayAdd(bonus_arts, t_ArtefactPower);",
                        "ArrayAdd(bonus_arts, t_ArtefactRadar);",
                        "ArrayAdd(bonus_arts, t_ArtefactScaner);",
