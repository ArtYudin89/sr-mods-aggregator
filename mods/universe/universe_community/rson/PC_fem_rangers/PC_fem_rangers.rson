                {
                    "Name": "",
                    "Code.Type": "Turn",
                    "Code": [
                        "//try to find new locations",
                        "best_dist = 1000;",
                        "counter = 0;",
                        "while(counter < ArrayDim(planet_list2))",
                        "{",
                        "    planet_list2[counter] = 0;",
                        "    counter = counter + 1;",
                        "}",
                        "",
                        "counter = 0;",
                        "planet_list2[0] = StarPlanets(ShipStar(Player()),0);",
                        "while(counter < num_planets && planet_list2[counter])",
                        "{",
                        "    counter = counter + 1;",
                        "    counter2 = 1;",
                        "    min_dist = 0;",
                        "    quest_planet = 0;",
                        "    while(counter2 < GalaxyStars())",
                        "    {",
                        "        temp_planet = 0;",
                        "        quest_star = StarNearbyStars(ShipStar(Player()), counter2);",
                        "        if(SectorVisible(StarToCon(quest_star))) temp_planet = FindPlanet(quest_star, 'NotMaloc,NotPeleng,NotPeople,NotFei,NotGaal,NotKling,NotPirateClan', 0, 100);",
                        "",
                        "        if(Terron() && temp_planet)",
                        "        {",
                        "            if(ShipStar(Terron()) == PlanetToStar(temp_planet)) temp_planet = 0;",
                        "        }",
                        "",
                        "        if(temp_planet)",
                        "        {",
                        "            counter3 = 0;",
                        "            cur_dist = 1000;",
                        "            while(counter3 < counter)",
                        "            {",
                        "                if(Dist(quest_star, PlanetToStar(planet_list2[counter3])) < cur_dist) cur_dist = Dist(quest_star, PlanetToStar(planet_list2[counter3]));",
                        "                counter3 = counter3 + 1;",
                        "            }",
                        "            cur_dist = cur_dist + StarOwner(quest_star) * 3;",
                        "",
                        "            if(min_dist < cur_dist)",
                        "            {",
                        "                min_dist = cur_dist;",
                        "                quest_planet = temp_planet;",
                        "            }",
                        "        }",
                        "",
                        "        counter2 = counter2 + 1;",
                        "    }",
                        "",
                        "    if(best_dist > min_dist) best_dist = min_dist;",
                        "    planet_list2[counter] = quest_planet;",
                        "}",
                        "if(planet_list2[num_planets] && best_dist >= req_dist) {",
                        "  counter = 0;",
                        "  while(counter < ArrayDim(planet_list))",
                        "  {",
                        "      planet_list[counter] = 0;",
                        "      if(planet_list2[counter]) planet_list[counter] = Id(planet_list2[counter]);",
                        "      counter = counter + 1;",
                        "  }",
                        "  if(!mission_briefing) {",
                        "    DChange(48);",
                        "    exit;",
                        "  }",
                        "  if(mission_briefing) {",
                        "    DChange(49);",
                        "    exit;",
                        "  }",
                        "}",
                        "if(!planet_list2[num_planets] || best_dist < req_dist) {",
                        "  if(!mission_briefing) {",
                        "    DChange(48);",
                        "    exit;",
                        "  }",
                        "  if(mission_briefing) {",
                        "    DChange(49);",
                        "    exit;",
                        "  }",
                        "}"
