                    "Name": "",
                    "Code.Type": "Turn",
                    "Code": [
                        "if(ItemIn(LS,Player()) && vState==0) {",
                        "  Dialog(dPirat,Pirate);",
                        "}",
                        "if(ItemIn(LS,GroupToShip(Pirate))) {",
                        "  ShipOut(CurShip);",
