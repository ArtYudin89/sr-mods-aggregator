            "Operations": [
                {
                    "Name": "",
                    "Code.Type": "Global",
                    "Code": [
                        "if(GRunFrom == 3) {",
                        "  if(CurTurn() > 950) {",
                        "    if(!vRunScrJedi) {",
                        "      GRun();",
                        "    }",
                        "  }",
                        "}"
                    ],
                    "#": 18,
                    "Type": "Top",
                    "Parent": -1,
                    "Pos.x": 0,
                    "Pos.y": 635
                },
                {
                    "Name": "",
                    "Code.Type": "Init",
                    "Code": [
                        "SetName(GroupToShip(Target),'Люкс Небоходов');",
                        "SetName(GroupToShip(Ranger),'Иван Кенобенко');",
                        "AddItemToShip(GroupToShip(Ranger),CreateEquipment(t_RepairRobot,Rnd(30,40),GalaxyTechLevel(),ShipOwner(GroupToShip(Ranger))));",
                        "AddItemToShip(GroupToShip(Ranger),CreateEquipment(t_DefGenerator,Rnd(30,40),GalaxyTechLevel(),ShipOwner(GroupToShip(Ranger))));",
                        "ItemLevel(ShipEqInSlot(GroupToShip(Ranger),t_Engine),GalaxyTechLevel());",
                        "ShipFreeFlight(GroupToShip(Ranger));",
                        "ShipSkill(GroupToShip(Ranger),0,2);",
                        "ShipSkill(GroupToShip(Ranger),1,4);",
                        "ShipSkill(GroupToShip(Ranger),2,1);",
                        "if(Rnd(0,100)>50)Prize_type=t_ArtefactNano;",
                        "else Prize_type=t_ArtefactSpeed;"
                    ],
                    "#": 19,
                    "Type": "Top",
                    "Parent": -1,
                    "Pos.x": 60,
                    "Pos.y": 635
                },
                {
                    "Name": "",
                    "Code.Type": "Turn",
                    "Code": [
                        "if(vState == 2) {",
                        "  ShipOut(GroupToShip(Pirate));",
                        "  AllShipOut();",
                        "}",
                        "if(!vRunScrJedi) {",
                        "  pers = pers + 1;",
                        "}",
                        "if(vState > 0) {",
                        "  vDaysJedi = vDaysJedi + 1;",
                        "}",
                        "if(vDaysJedi<21) {",
                        "  if(!CountIn(Ranger)) {",
                        "    ShipOut(GroupToShip(Pirate));",
                        "    if(vState==2) {",
                        "      ShipOut(CurShip);",
                        "      ShipOut(Player());",
                        "      if(vState==0)ShipDestroy(GroupToShip(Target));",
                        "      AllShipOut();",
                        "      ShipOut(GroupToShip(Target));",
                        "    }",
                        "  }",
                        "}"
                    ],
                    "#": 20,
                    "Type": "Top",
                    "Parent": -1,
                    "Pos.x": 120,
                    "Pos.y": 635
                },
                {
                    "Name": "",
                    "Code.Type": "Turn",
                    "Code": [
                        "if(ShipSlots(CurShip,8))",
                        "\t{",
                        "\tif(ItemDurability(ShipEqInSlot(CurShip,t_Engine))>20 && HullDamage(CurShip)>30 && !OrderForsage(CurShip))OrderForsage(CurShip,1);",
                        "\tif(ItemDurability(ShipEqInSlot(CurShip,t_Engine))<15 && OrderForsage(CurShip))OrderForsage(CurShip,0);",
                        "\t}",
                        "if(Dist(GroupToShip(Pla),CurShip)<200) {",
                        "  vRunScrJedi=1;",
                        "  Dialog(dTalk,Ranger);",
                        "  if(vState>0) {",
                        "    ChangeState(2);",
                        "    exit;",
                        "  }",
                        "}"
                    ],
                    "#": 80,
                    "Type": "Top",
                    "Parent": -1,
                    "Pos.x": 80
                },
                {
                    "Name": "",
                    "Code.Type": "Turn",
                    "Code": [
                        "if(GetShipPlanet(GroupToShip(Ranger))==PlanetNone && vDaysJedi<20) {",
                        "  vDaysJedi=21;",
                        "}",
                        "if(vDaysJedi>49 || GroupCount(Pirate)==0) {",
                        "  ShipDestroy(CurShip);",
                        "}"
                    ],
                    "#": 81,
                    "Type": "Top",
                    "Parent": -1,
                    "Pos.x": 160
                },
                {
                    "Name": "",
                    "Code.Type": "Turn",
                    "Code": [
                        "if(GroupToShip(Ranger)) {",
                        "  if(vDaysJedi>20 && GetShipPlanet(GroupToShip(Ranger))==PlanetNone) {",
                        "    Dialog(dPirat,Pirate);",
                        "  }",
                        "}",
                        "if(vState==0 && !GroupToShip(Ranger)) {",
                        "  ChangeState(5);",
                        "  exit;",
                        "}",
                        "if(vState==6) {",
                        "  ShipOut(CurShip);",
                        "  ShipOut(Player());",
                        "  if(vState==0)ShipDestroy(GroupToShip(Target));",
                        "  AllShipOut();",
                        "}",
                        "if(vState==3) {",
                        "  ChangeState(4);",
                        "  exit;",
                        "}",
                        "if(vState==4) {",
                        "  ChangeState(5);",
                        "  exit;",
                        "}",
                        "if(vDaysJedi>5000) {",
                        "  ShipOut(GroupToShip(Target));",
                        "  ShipOut(CurShip);",
                        "  ShipOut(Player());",
                        "  if(vState==0)ShipDestroy(GroupToShip(Target));",
                        "  AllShipOut();",
                        "}",
                        "if(vState==5) {",
                        "  ShipDestroy(CurShip);",
                        "  ShipOut(CurShip);",
                        "  ShipOut(Player());",
                        "  if(vState==0)ShipDestroy(GroupToShip(Target));",
                        "  AllShipOut();",
                        "}"
                    ],
                    "#": 82,
                    "Type": "Top",
                    "Parent": -1,
                    "Pos.x": 240
                },
                {
                    "Name": "",
                    "Code.Type": "Turn",
                    "Code": [
                        "if(vDaysJedi>300) {",
                        "  ShipOut(CurShip);",
                        "  ShipOut(Player());",
                        "  if(vState==0)ShipDestroy(GroupToShip(Target));",
                        "  AllShipOut();",
                        "}",
                        "ShipSetBad(CurShip,Player());"
                    ],
