{
    "FileID": 573785173,
    "FileVersion": 8,
    "ViewPos.x": -75,
    "ViewPos.y": -186,
    "ScriptName": "Mod_RevJediQuest",
    "ScriptFileOut": "D:\\Mod_RevJediQuest.scr",
    "ScriptTextOut": "D:\\Mod_RevJediQuest.txt",
    "Visual.Objects": [
        {
            "ConstellationCount": 0,
            "DialogAnswers": [
                {
                    "Name": "exit",
                    "Pos.x": 0,
                    "Pos.y": 540,
                    "Type": "TDialogAnswer",
                    "Parent": -1,
                    "#": 55,
                    "Msg": "Не до ваших просьб сейчас. Галактику надо спасать!",
                    "AMsg.Num": "0",
                    "_orig_danswer": "DAnswer('exit~'+CT(\"Script.Mod_RevJediQuest.17\"))"
                },
                {
                    "Name": "",
                    "Pos.x": 120,
                    "Pos.y": 540,
                    "Type": "TDialogAnswer",
                    "Parent": -1,
                    "#": 56,
                    "Msg": "Рассказывай. Что за просьба?",
                    "AMsg.Num": "1",
                    "_orig_danswer": "DAnswer(CT(\"Script.Mod_RevJediQuest.18\"))"
                },
                {
                    "Name": "",
                    "Pos.x": 240,
                    "Pos.y": 540,
                    "Type": "TDialogAnswer",
                    "Parent": -1,
                    "#": 57,
                    "Msg": "И, конечно, сохранить эту штуковину должен буду я? Кстати, что это?",
                    "AMsg.Num": "2",
                    "_orig_danswer": "DAnswer(CT(\"Script.Mod_RevJediQuest.19\"))"
                },
                {
                    "Name": "",
                    "Pos.x": 360,
                    "Pos.y": 540,
                    "Type": "TDialogAnswer",
                    "Parent": -1,
                    "#": 58,
                    "Msg": "Хорошо, я согласен. Давай сюда свою побрякушку, я её сохраню в безопасности",
                    "AMsg.Num": "3",
                    "_orig_danswer": "DAnswer(CT(\"Script.Mod_RevJediQuest.76\"))"
                },
                {
                    "Name": "exit",
                    "Pos.x": 480,
                    "Pos.y": 540,
                    "Type": "TDialogAnswer",
                    "Parent": -1,
                    "#": 59,
                    "Msg": "",
                    "AMsg.Num": "4",
                    "_orig_danswer": "DAnswer('exit')"
                },
                {
                    "Name": "",
                    "Pos.x": 600,
                    "Pos.y": 540,
                    "Type": "TDialogAnswer",
                    "Parent": -1,
                    "#": 60,
                    "Msg": "Было всё прекрасно, пока чья-то немытая морда на экране не появилась. Чего надо?",
                    "AMsg.Num": "5",
                    "_orig_danswer": "DAnswer(CT(\"Script.Mod_RevJediQuest.21\"))"
                },
                {
                    "Name": "",
                    "Pos.x": 720,
                    "Pos.y": 540,
                    "Type": "TDialogAnswer",
                    "Parent": -1,
                    "#": 61,
                    "Msg": "И тебе привет. Жизнь прекрасна, скоро вот с доминаторами покончу. Чего хотел?",
                    "AMsg.Num": "6",
                    "_orig_danswer": "DAnswer(CT(\"Script.Mod_RevJediQuest.59\"))"
                },
                {
                    "Name": "",
                    "Pos.x": 840,
                    "Pos.y": 540,
                    "Type": "TDialogAnswer",
                    "Parent": -1,
                    "#": 62,
                    "Msg": "Я не понял, вы на что вообще намекаете!?",
                    "AMsg.Num": "7",
                    "_orig_danswer": "DAnswer(CT(\"Script.Mod_RevJediQuest.27\"))"
                },
                {
                    "Name": "",
                    "Pos.x": 960,
                    "Pos.y": 540,
                    "Type": "TDialogAnswer",
                    "Parent": -1,
                    "#": 63,
                    "Msg": "Я не понимаю. Вы о чём?",
                    "AMsg.Num": "8",
                    "_orig_danswer": "DAnswer(CT(\"Script.Mod_RevJediQuest.28\"))"
                },
                {
                    "Name": "",
                    "Pos.x": 1080,
                    "Pos.y": 540,
                    "Type": "TDialogAnswer",
                    "Parent": -1,
                    "#": 64,
                    "Msg": "Отдать? Ах, отдать?! *покрыть семиэтажным матом*",
                    "AMsg.Num": "9",
                    "_orig_danswer": "DAnswer(CT(\"Script.Mod_RevJediQuest.29\"))"
                },
                {
                    "Name": "exit",
                    "Pos.x": 1200,
                    "Pos.y": 540,
                    "Type": "TDialogAnswer",
                    "Parent": -1,
                    "#": 65,
                    "Msg": "Нет ее у меня. Продал уже. А теперь - попробуйте догнать",
                    "AMsg.Num": "10",
                    "_orig_danswer": "DAnswer('exit~'+CT(\"Script.Mod_RevJediQuest.70\"))"
                },
                {
                    "Name": "exit",
                    "Pos.x": 1320,
                    "Pos.y": 540,
                    "Type": "TDialogAnswer",
                    "Parent": -1,
                    "#": 66,
                    "Msg": "Я не отдам вам то, что вам не принадлежит. И не смейте мне угрожать, а то ведь я и разозлиться могу",
                    "AMsg.Num": "11",
                    "_orig_danswer": "DAnswer('exit~'+CT(\"Script.Mod_RevJediQuest.77\"))"
                },
                {
                    "Name": "exit",
                    "Pos.x": 1440,
                    "Pos.y": 540,
                    "Type": "TDialogAnswer",
                    "Parent": -1,
                    "#": 67,
                    "Msg": "Ладно, так и быть, забирайте",
                    "AMsg.Num": "12",
                    "_orig_danswer": "DAnswer('exit~'+CT(\"Script.Mod_RevJediQuest.78\"))"
                },
                {
                    "Name": "",
                    "Pos.x": 1560,
                    "Pos.y": 540,
                    "Type": "TDialogAnswer",
                    "Parent": -1,
                    "#": 68,
                    "Msg": "Не знаю такого. Ошибочка вышла",
                    "AMsg.Num": "13",
                    "_orig_danswer": "DAnswer(CT(\"Script.Mod_RevJediQuest.79\"))"
                },
                {
                    "Name": "exit",
                    "Pos.x": 1680,
                    "Pos.y": 540,
                    "Type": "TDialogAnswer",
                    "Parent": -1,
                    "#": 69,
                    "Msg": "",
                    "AMsg.Num": "14",
                    "_orig_danswer": "DAnswer('exit')"
                },
                {
                    "Name": "",
                    "Pos.x": 0,
                    "Pos.y": 565,
                    "Type": "TDialogAnswer",
                    "Parent": -1,
                    "#": 70,
                    "Msg": "Да, это я",
                    "AMsg.Num": "15",
                    "_orig_danswer": "DAnswer(CT(\"Script.Mod_RevJediQuest.80\"))"
                },
                {
                    "Name": "",
                    "Pos.x": 120,
                    "Pos.y": 565,
                    "Type": "TDialogAnswer",
                    "Parent": -1,
                    "#": 71,
                    "Msg": "Кто ты и зачем меня искал?",
                    "AMsg.Num": "16",
                    "_orig_danswer": "DAnswer(CT(\"Script.Mod_RevJediQuest.48\"))"
                },
                {
                    "Name": "",
                    "Pos.x": 240,
                    "Pos.y": 565,
                    "Type": "TDialogAnswer",
                    "Parent": -1,
                    "#": 72,
                    "Msg": "Сочувствую. А я какое отношение к этому имею?",
                    "AMsg.Num": "17",
                    "_orig_danswer": "DAnswer(CT(\"Script.Mod_RevJediQuest.49\"))"
                },
                {
                    "Name": "",
                    "Pos.x": 360,
                    "Pos.y": 565,
                    "Type": "TDialogAnswer",
                    "Parent": -1,
                    "#": 73,
                    "Msg": "Я раскусил твой план. Хочешь тоже выманить у меня эту штуку, ну уж нет, тебе она ни за что не достанется!",
                    "AMsg.Num": "18",
                    "_orig_danswer": "DAnswer(CT(\"Script.Mod_RevJediQuest.50\"))"
                },
                {
                    "Name": "",
                    "Pos.x": 480,
                    "Pos.y": 565,
                    "Type": "TDialogAnswer",
                    "Parent": -1,
                    "#": 74,
                    "Msg": "Понимаешь, я его потерял",
                    "AMsg.Num": "19",
                    "_orig_danswer": "DAnswer(CT(\"Script.Mod_RevJediQuest.81\"))"
                },
                {
                    "Name": "",
                    "Pos.x": 600,
                    "Pos.y": 565,
                    "Type": "TDialogAnswer",
                    "Parent": -1,
                    "#": 75,
                    "Msg": "Сила не обманула тебя. Я тот человек, который тебе нужен. Забирай свой меч!",
                    "AMsg.Num": "20",
                    "_orig_danswer": "DAnswer(CT(\"Script.Mod_RevJediQuest.84\"))"
                },
                {
                    "Name": "exit",
                    "Pos.x": 720,
                    "Pos.y": 565,
                    "Type": "TDialogAnswer",
                    "Parent": -1,
                    "#": 76,
                    "Msg": "",
                    "AMsg.Num": "21",
                    "_orig_danswer": "DAnswer('exit')"
                },
                {
                    "Name": "",
                    "Pos.x": 840,
                    "Pos.y": 565,
                    "Type": "TDialogAnswer",
                    "Parent": -1,
                    "#": 77,
                    "Msg": "Тут такое дело... потерял я её",
                    "AMsg.Num": "22",
                    "_orig_danswer": "DAnswer(CT(\"Script.Mod_RevJediQuest.83\"))"
                },
                {
                    "Name": "",
                    "Pos.x": 960,
                    "Pos.y": 565,
                    "Type": "TDialogAnswer",
                    "Parent": -1,
                    "#": 78,
                    "Msg": "Но я на самом деле её потерял!",
                    "AMsg.Num": "23",
                    "_orig_danswer": "DAnswer(CT(\"Script.Mod_RevJediQuest.63\"))"
                },
                {
                    "Name": "exit",
                    "Pos.x": 1080,
                    "Pos.y": 565,
                    "Type": "TDialogAnswer",
                    "Parent": -1,
                    "#": 79,
                    "Msg": "",
                    "AMsg.Num": "24",
                    "_orig_danswer": "DAnswer('exit')"
                }
            ],
            "DialogMessages": [
                {
                    "Name": "",
                    "Pos.x": 0,
                    "Pos.y": 445,
                    "Type": "TDialogMsg",
                    "Parent": -1,
                    "#": 34,
                    "Msg": "Здравствуй, <0>. Да хранит тебя Сила! Позволь обратиться к тебе c просьбой.",
                    "DMsg.Num": "0",
                    "_orig_dtext": "DText(Format(CT(\"Script.Mod_RevJediQuest.72\"),\"<0>\",ShipName(Player())))"
                },
                {
                    "Name": "",
                    "Pos.x": 150,
                    "Pos.y": 445,
                    "Type": "TDialogMsg",
                    "Parent": -1,
                    "#": 35,
                    "Msg": "Позволь сперва представиться. Меня зовут Иван Кенобенко. Понимаешь, <0>. У меня есть одна вещь, которую я поклялся сохранить в безопасности и передать её подлинному владельцу, когда он будет готов принять её. Но по некоторым причинам я не могу  держать её у себя... И поэтому ищу гуманоида, который смог бы сохранить её.",
                    "DMsg.Num": "1",
                    "_orig_dtext": "DText(Format(CT(\"Script.Mod_RevJediQuest.67\"),\"<0>\",ShipName(Player())))"
                },
                {
                    "Name": "",
                    "Pos.x": 300,
                    "Pos.y": 445,
                    "Type": "TDialogMsg",
                    "Parent": -1,
                    "#": 36,
                    "Msg": "Именно так. Я чувствую, что только ТЫ сможешь сохранить её. Это трудно объяснить, но я ЗНАЮ это. Ничего конкретного сказать о предмете не могу, но, поверь, он очень важен для владельца. Уверен, он оплатит все расходы.",
                    "DMsg.Num": "2",
                    "_orig_dtext": "DText(CT(\"Script.Mod_RevJediQuest.14\"))"
                },
                {
                    "Name": "",
                    "Pos.x": 450,
                    "Pos.y": 445,
                    "Type": "TDialogMsg",
                    "Parent": -1,
                    "#": 37,
                    "Msg": "Сейчас выброшу её за борт. Держи, <0>. И, прошу тебя, сдержи своё обещание.",
                    "DMsg.Num": "3",
                    "_orig_dtext": "DText(Format(CT(\"Script.Mod_RevJediQuest.65\"),\"<0>\",ShipName(Player())))"
                },
                {
                    "Name": "",
                    "Pos.x": 600,
                    "Pos.y": 445,
                    "Type": "TDialogMsg",
                    "Parent": -1,
                    "#": 38,
                    "Msg": "Здорово, <0>! Как жизнь?",
                    "DMsg.Num": "4",
                    "_orig_dtext": "DText(Format(CT(\"Script.Mod_RevJediQuest.16\"),\"<0>\",ShipName(Player())))"
                },
                {
                    "Name": "",
                    "Pos.x": 750,
                    "Pos.y": 445,
                    "Type": "TDialogMsg",
                    "Parent": -1,
                    "#": 39,
                    "Msg": "Зачем так грубо? Мы не хотим открывать огонь. Впрочем, всё сейчас от тебя зависит...",
                    "DMsg.Num": "5",
                    "_orig_dtext": "DText(CT(\"Script.Mod_RevJediQuest.22\"))"
                },
                {
                    "Name": "",
                    "Pos.x": 900,
                    "Pos.y": 445,
                    "Type": "TDialogMsg",
                    "Parent": -1,
                    "#": 40,
                    "Msg": "С доминаторами ты можешь и не покончить. Если умрёшь... из-за какой-нибудь глупости...",
                    "DMsg.Num": "6",
                    "_orig_dtext": "DText(CT(\"Script.Mod_RevJediQuest.73\"))"
                },
                {
                    "Name": "",
                    "Pos.x": 1050,
                    "Pos.y": 445,
                    "Type": "TDialogMsg",
                    "Parent": -1,
                    "#": 41,
                    "Msg": "Спокойно, <0>. Всё будет хорошо. Сейчас ты просто отдашь нам ту вещичку, которую тебе передал некто <clr>Иван Кенобенко<clrEnd>. И тогда никто не пострадает.",
                    "DMsg.Num": "7",
                    "_orig_dtext": "DText(Format(CT(\"Script.Mod_RevJediQuest.24\"),\"<0>\",ShipName(Player())))"
                },
                {
                    "Name": "",
                    "Pos.x": 1200,
                    "Pos.y": 445,
                    "Type": "TDialogMsg",
                    "Parent": -1,
                    "#": 42,
                    "Msg": "Ты всё понимаешь! И у тебя осталось всего пять секунд до возможной гибели. Уже четыре... три... два...",
                    "DMsg.Num": "8",
                    "_orig_dtext": "DText(CT(\"Script.Mod_RevJediQuest.74\"))"
                },
                {
                    "Name": "",
                    "Pos.x": 1350,
                    "Pos.y": 445,
                    "Type": "TDialogMsg",
                    "Parent": -1,
                    "#": 43,
                    "Msg": "Это твой последний шанс, <0>. Лучше отдай её нам. Жизнь ведь дороже...",
                    "DMsg.Num": "9",
                    "_orig_dtext": "DText(Format(CT(\"Script.Mod_RevJediQuest.26\"),\"<0>\",ShipName(Player())))"
                },
                {
                    "Name": "",
                    "Pos.x": 1500,
                    "Pos.y": 445,
                    "Type": "TDialogMsg",
                    "Parent": -1,
                    "#": 44,
                    "Msg": "Здравствуй. Если не ошибаюсь, <0>?",
                    "DMsg.Num": "10",
                    "_orig_dtext": "DText(Format(CT(\"Script.Mod_RevJediQuest.36\"),\"<0>\",ShipName(Player())))"
                },
                {
                    "Name": "",
                    "Pos.x": 1650,
                    "Pos.y": 445,
                    "Type": "TDialogMsg",
                    "Parent": -1,
                    "#": 45,
                    "Msg": "Странно. Тогда прошу прощения за беспокойство.",
                    "DMsg.Num": "11",
                    "_orig_dtext": "DText(CT(\"Script.Mod_RevJediQuest.37\"))"
                },
                {
                    "Name": "",
                    "Pos.x": 0,
                    "Pos.y": 470,
                    "Type": "TDialogMsg",
                    "Parent": -1,
                    "#": 46,
                    "Msg": "Как я рад нашей встрече! Я искал тебя. И я был уверен, что Сила приведёт меня к тебе!",
                    "DMsg.Num": "12",
                    "_orig_dtext": "DText(CT(\"Script.Mod_RevJediQuest.38\"))"
                },
                {
                    "Name": "",
                    "Pos.x": 150,
                    "Pos.y": 470,
                    "Type": "TDialogMsg",
                    "Parent": -1,
                    "#": 47,
                    "Msg": "Ой, прости, забыл совсем представился. Меня зовут Люкс Небоходов. Я совсем недавно в рейнджеры записался. А причина моих поисков... Постараюсь объяснить. Начну издалека. Моей родной планетой правит очень могущественный псих, Дарт Флудиус.  Но он требует, чтобы все называли его Императором. Так вот, все жители планеты очень страдают.",
                    "DMsg.Num": "13",
                    "_orig_dtext": "DText(CT(\"Script.Mod_RevJediQuest.39\"))"
                },
                {
                    "Name": "",
                    "Pos.x": 300,
                    "Pos.y": 470,
                    "Type": "TDialogMsg",
                    "Parent": -1,
                    "#": 48,
                    "Msg": "Дело в том, что... В общем, мне приснился сон... Что только я могу  спасти наш народ. И ещё мне приснилось, что у тебя есть что-то для меня... оружие... мой сверхсветовой меч... Скажи, Сила не обманула меня? Он действительно у тебя?",
                    "DMsg.Num": "14",
                    "_orig_dtext": "DText(CT(\"Script.Mod_RevJediQuest.68\"))"
                },
                {
                    "Name": "",
                    "Pos.x": 450,
                    "Pos.y": 470,
                    "Type": "TDialogMsg",
                    "Parent": -1,
                    "#": 49,
                    "Msg": "Вовсе нет! Я говорю правду! Постой! Не отключай связь! Нет!....",
                    "DMsg.Num": "15",
                    "_orig_dtext": "DText(CT(\"Script.Mod_RevJediQuest.42\"))"
                },
                {
                    "Name": "",
                    "Pos.x": 600,
                    "Pos.y": 470,
                    "Type": "TDialogMsg",
                    "Parent": -1,
                    "#": 50,
                    "Msg": "Теперь мы обречены...",
                    "DMsg.Num": "16",
                    "_orig_dtext": "DText(CT(\"Script.Mod_RevJediQuest.75\"))"
                },
                {
                    "Name": "",
                    "Pos.x": 750,
                    "Pos.y": 470,
                    "Type": "TDialogMsg",
                    "Parent": -1,
                    "#": 51,
                    "Msg": "Благодарю тебя, <0>! Я знал, что могу полностью довериться Силе!... Я чувствую её... Чувствую... Она говорит, что мне следует отдать тебе кое-что... Держи этот артефакт, уверен, он тебе пригодится.  Прощай, <1>! Да пребудет с тобой Сила!",
                    "DMsg.Num": "17",
                    "_orig_dtext": "DText(Format(CT(\"Script.Mod_RevJediQuest.58\"),\"<0>\",ShipName(Player()),\"<1>\",ShipName(Player())))"
                },
                {
                    "Name": "",
                    "Pos.x": 900,
                    "Pos.y": 470,
                    "Type": "TDialogMsg",
                    "Parent": -1,
                    "#": 52,
                    "Msg": "Конечно, я тебе верю. Выкинул, продал, потерял... Ты меня что, за идиота держишь!? А ну давай её сюда!",
                    "DMsg.Num": "18",
                    "_orig_dtext": "DText(CT(\"Script.Mod_RevJediQuest.60\"))"
                },
                {
                    "Name": "",
                    "Pos.x": 1050,
                    "Pos.y": 470,
                    "Type": "TDialogMsg",
                    "Parent": -1,
                    "#": 53,
                    "Msg": "Погодь, сканирую твой корабль.... Так... И правда, нету! Ты что, получается, в натуре не прикидывался!? На самом деле такой болван!? А ну и ладно. Наш заказчик, Дарт Федер... Мейдер... Медвейдер... вобщем, неважно,  приказал не оставлять живых свидетелей.",
                    "DMsg.Num": "19",
                    "_orig_dtext": "DText(CT(\"Script.Mod_RevJediQuest.69\"))"
                },
                {
                    "Name": "",
                    "Pos.x": 1200,
                    "Pos.y": 470,
                    "Type": "TDialogMsg",
                    "Parent": -1,
                    "#": 54,
                    "Msg": "Канай отсюда, рога поотшибаю, редиска!",
                    "DMsg.Num": "20",
                    "_orig_dtext": "DText(CT(\"Script.Mod_RevJediQuest.64\"))"
                }
            ],
