                        "    ChangeGlobalRelationsShips(Player(),0,1,13,2+4+8+16+32,1+2+4+8+16);",
                        "    ChangeGlobalRelationsPlanets(Player(),0,1,15,1+2+4+8+16);",
                        "    AddPlanetNews(Format('Сегодня состоялось открытие медицинского центра имени рейнджера <0> на планете <1>. Благородный рейнджер, узнав о кризисе мензольской цивилизации, не пожалал личных средств и предоставил помощь в строительстве планетарной станции. Данный факт послужит всем нам примером для подражаения, а также поможет лучше понять мензольскую истрию и способ жизни. Мы будем держать наших уважаемых читателей в курсе дела. ',\"<0>\",vplayername,\"<1>\",Name(PlanetColonize)));",
                        "  }",
                        "}"
