                        "NoTargetToShip(GroupToShip(ItemsTo),1);",
                        "NoScanToShip(GroupToShip(ItemsTo),1);",
                        "if(1>2) {",
                        "  Ether(3,'A3D00878-A49D-468C-ACA2-D28EB7CA473C',Format(' <0>   GM1 <1> vtemp <2> vAction <3> vState <4> vCounter <5> vmonthcr <6> vbonusrnd <7> vFlyDrop <8> vActionSend <9> vlastexv <10> vnextexv <11> vbonusrnd <12> <13> <14>  <15> <16> <17> <18> <19> <20>  vNewsNext <21> vNewsLast <22> vNewsText <23> vlastalk <24> vprodcost <25> vprodpercent <26> vgoodsex <27> vsklad <28> vprodstr <29> vprodtype <30> vproduct <31> vinsklad <32> test <33>/<34>',\"<0>\",vGetItem,\"<1>\",vGetMoney,\"<2>\",vtemp,\"<3>\",vAction,\"<4>\",vState,\"<5>\",vCounter,\"<6>\",vmonthcr,\"<7>\",vbonusrnd,\"<8>\",vFlyDrop,\"<9>\",vActionSend,\"<10>\",vlastexv,\"<11>\",vnextexv,\"<12>\",vbonusrnd,\"<13>\",Name(GroupToShip(ItemsTo)),\"<14>\",Name(GroupToShip(Sender)),\"<15>\",vaspeed,\"<16>\",vivert,\"<17>\",vaminiexpl,\"<18>\",vaantigr,\"<19>\",viengine,\"<20>\",vablack,\"<21>\",vNewsNext,\"<22>\",vNewsLast,\"<23>\",vNewsText,\"<24>\",vlastalk,\"<25>\",vprodcost,\"<26>\",vprodpercent,\"<27>\",vgoodsex,\"<28>\",vsklad,\"<29>\",vprodstr,\"<30>\",vprodtype,\"<31>\",vproduct,\"<32>\",vinsklad,\"<33>\",(GalaxyMoney(3)*1.2),\"<34>\",(vprodpercent/60)),GroupToShip(CBase));",
                        "}",
