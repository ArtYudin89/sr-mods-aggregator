                        "}",
                        "vMaxDay=vMaxDay+1;",
                        "if((vTotalItem==13 || vMaxDay==950) && (vColonizeStart==1)) {",
                        "  vAction=1024;",
                        "  vColonizeStart=1;",
                        "  AddPlanetNews(Format('Сегодня состоялось торжественное закрытие планетарного центра им <0> на планете <1>. Сегодня же медицинский центр <2> будет возвращен в космическое пространство и уже с завтрашнего дня сможет принимать больных.',\"<0>\",vplayername,\"<1>\",Name(PlanetColonize),\"<2>\",Name(GroupToShip(CBase))));",
                        "  Ether(4,'5DBE0D43-E810-429D-A7F6-2365EE7B95EE',Format(CT(\"Script.Mod_RevColonization.138\"),\"<0>\",vplayername,\"<1>\",Name(PlanetColonize),\"<2>\",Name(GroupToShip(CBase))));",
                        "}",
                        "if(vCounter>vNewsLast+vNewsNext) {",
                        "  vNewsLast=vCounter;",
                        "  vNewsNext=Rnd(30,90);",
                        "  if(vNewsText==4) {",
                        "    AddPlanetNews(Format('Малокские власти подали иск в Галактический Совет на рейнджера <0>.",
                        "    Известный рейнджер <1>, профинансировавший постройку планетарного медицинского центра на планете <2> может быть осужден.",
                        "    Малокские представители утверждают, что уже начали колонизировать <3>, однако команда рейнджера <4> выбросила малокских колонизаторов в открытый космос, чем и прервала на некоторое время экспансию великой малокской державы. Ведется следствие.',\"<0>\",vplayername,\"<1>\",vplayername,\"<2>\",Name(PlanetColonize),\"<3>\",Name(PlanetColonize),\"<4>\",vplayername));",
                        "    ChangeGlobalRelationsPlanets(Player(),0,0,10,1);",
                        "    ChangeGlobalRelationsShips(Player(),0,0,20,2+4+8+16+32,1);",
                        "  }",
                        "  if(vNewsText==5) {",
                        "    AddPlanetNews(Format('Сегодня на колонизационной базе планеты <0> произошла трагедия: был взорван четвертый энергоблок станции. Есть погибшие как со стороны персонала станции, так и потери среди мензолов. Данное событие значительно ухудшило отношения между аборигенами и представителями Коалиции. ",
                        "    Пеленгские специалисты утверждают, что данную диверсионную операцию провели малокские спецслужбы, однако гаальские и фэянские эксперты придерживаются мнения, что имела место халатность персонала.',\"<0>\",Name(PlanetColonize)));",
                        "    ChangeGlobalRelationsPlanets(Player(),0,0,15,8+16);",
                        "    ChangeGlobalRelationsShips(Player(),0,0,15,2+4+8+16+32,8+16);",
                        "  }",
                        "  if(vNewsText==3) {",
                        "    AddPlanetNews(Format('Мензолы - последняя надежда Галактики. Экспедиция на планете <0> при сотрудничестве с мензольскими мыслителями и учеными разработала очередной алгоритм для новой антидоминаторской программы. Отличие ее от всех других состоит в том, что данная программа передает вполне осмысленные команды бортовому компьютеру доминаторского корабля, который принимает их за подлинные данные и пытается обработать. Мензольские специалисты использовали в качестве логической модели данной программы модель поведения своего народа, которая кардинально отличается от раннее использовавшегося подхода к решению задач подобного типа как у ученых рас Коалиции, так и у самих доминаторов. Однако, среди всех прочих, скептически настроенными оказались ученые с фэянской стороны, которые считают, что мензольская раса еще слишком молода и обладает очень приблизительными знаниями об устройстве логических аппаратов доминаторов, потому программа будет бесполезна в борьбе с кремниевым разумом.',\"<0>\",Name(PlanetColonize)));",
                        "    ChangeGlobalRelationsPlanets(Player(),0,2,10,1+2+4+16);",
                        "    ChangeGlobalRelationsShips(Player(),0,2,10,2+4+8+16+32,1+2+4+16);",
                        "    ChangeGlobalRelationsPlanets(Player(),0,0,10,8);",
                        "    ChangeGlobalRelationsShips(Player(),0,0,10,2+4+8+16+32,8);",
                        "  }",
                        "  if(vNewsText==6) {",
                        "    AddPlanetNews(Format('Гаальское правительство отзывает своих специалистов с колонизационной базы на планете <0>. Гаальские чиновники считают, что влияние на мензольскую культуру извне наносит непоправимый вред культуре аборигенов. В связи с этим сообщением малокское и пеленгское правительство напротив, отправило своих специалистов на планетарную базу, мотивируя это тем, что из-за прихотей гаальцев может провалиться научное исследование века.',\"<0>\",Name(PlanetColonize)));",
                        "    ChangeGlobalRelationsPlanets(Player(),0,0,15,16);",
                        "    ChangeGlobalRelationsShips(Player(),0,0,20,2+4+8+16+32,16);",
                        "  }",
                        "  if(vNewsText==2) {",
                        "    AddPlanetNews(Format('Силами мензольской службой безопасности был найден и обезврежен пеленгский шпионский зонд на планете <0>. Пеленгское правительство пока воздержалось от комментариев. Напомним, что на этой планете располагается планетарная станция, призванная помочь в развитии мензольской расе и изучить древнюю культуру этого народа. По одной из гипотез, мензолы в древности контактировали с представителями других рас, явно не входящих в список известных. Если данная теория верна, перед исследователями открываются огромные перспективы как в культурно-историческом плане, так и в военно-техническом.',\"<0>\",Name(PlanetColonize)));",
                        "    ChangeGlobalRelationsPlanets(Player(),0,2,10,1+4+8+16);",
                        "    ChangeGlobalRelationsShips(Player(),0,2,10,2+4+8+16+32,1+4+8+16);",
                        "    ChangeGlobalRelationsPlanets(Player(),0,0,10,2);",
                        "    ChangeGlobalRelationsShips(Player(),0,0,10,2+4+8+16+32,2);",
                        "  }",
                        "  if(vNewsText==7) {",
                        "    AddPlanetNews(Format('На планете <0> мензольскими силами при содействии планетарной базы налажена добыча редких минеральных солей, которые в будущем будут экспортироваться на планеты Коалиции. Человеческое правительство отнеслось к этой затее скептически, так как поставка руд и минералов всегда была человеческим сегментом экономики.',\"<0>\",Name(PlanetColonize)));",
                        "    ChangeGlobalRelationsPlanets(Player(),0,2,20,1+2+8+16);",
                        "    ChangeGlobalRelationsPlanets(Player(),0,0,25,4);",
                        "    ChangeGlobalRelationsShips(Player(),0,0,25,2+4+8+16+32,4);",
                        "    ChangeGlobalRelationsShips(Player(),0,2,20,2+4+8+16+32,1+2+8+16);",
                        "  }",
                        "  if(vNewsText==8) {",
                        "    AddPlanetNews(Format('Срочная новость!",
                        "    На планете <0> начались потасовки среди представителей мензольской расы. Причины беспорядков до сих пор не выяснены, однако ситуацию удалось стабилизировать персоналу планетарной базы, руководителем которой является рейнджер <1>.',\"<0>\",Name(PlanetColonize),\"<1>\",vplayername));",
                        "    ChangeGlobalRelationsPlanets(Player(),0,2,15,1+2+4+8+16);",
                        "    ChangeGlobalRelationsShips(Player(),0,2,15,2+4+8+16+32,1+2+4+8+16);",
                        "  }",
                        "  if(vNewsText==1) {",
                        "    AddPlanetNews(Format('Торговая экспансия мензольской расы продолжается! ",
                        "    Благодаря усилиям исследователей планетарной базы на планете <0> состоялась сделка между представителями Коалиции и мензольской расы. Напомним, что исследования мензольской культуры были забыты еще в ХХХ веке, мосле смерти главного исследователя мензолов - Рене Маккалистера. И вот теперь, спустя триста лет, исследования возобновлены. Это стало возможно благодаря рейнджеру <1>, меценату, профинансировавшему постройку базы на <2>',\"<0>\",Name(PlanetColonize),\"<1>\",vplayername,\"<2>\",Name(PlanetColonize)));",
                        "    ChangeGlobalRelationsPlanets(Player(),0,2,10,1+2+4+8+16);",
                        "    ChangeGlobalRelationsShips(Player(),0,2,10,2+4+8+16+32,1+2+4+8+16);",
                        "  }",
                        "  if(vNewsText==9) {",
                        "    AddPlanetNews(Format('Статистические исследования показали, что один из наивысших показателей уровня жизни относительно уровня развития зафиксирован на планете <0>. Коренное население - мензолы, проживающие там и по сей день. Несмотря на достаточно малый возраст данной расы, мензолы уже начали контактировать с представителями Коалиции и даже осваивать ближайший космос. ",
                        "    Рывок в технологическом и культурном развитии данной цивилизации стал возможен благодаря постройке рейнджером <1> планетарного центра на данной планете.',\"<0>\",Name(PlanetColonize),\"<1>\",vplayername));",
                        "    ChangeGlobalRelationsPlanets(Player(),0,2,10,1+2+4+8+16);",
                        "    ChangeGlobalRelationsShips(Player(),0,2,10,2+4+8+16+32,1+2+4+8+16);",
                        "  }",
                        "  if(vNewsText==0) {",
                        "    AddPlanetNews(Format('Сегодня на планете <0> был ликвидирован очаг заражения гранэкской чумой, завезенной туда малокской экспедицией. Чудесное спасение сотен мензольских жизней стало возможно благодаря усилиям медицинского персонала планетарной базы, построенной на средства рейнджера <1>.',\"<0>\",Name(PlanetColonize),\"<1>\",vplayername));",
                        "    ChangeGlobalRelationsPlanets(Player(),0,2,20,2+4+8+16);",
                        "    ChangeGlobalRelationsShips(Player(),0,2,20,2+4+8+16+32,1+2+4+8+16);",
                        "  }",
                        "}",
                        "if(vproduct!=0) {",
                        "  if(vgoodsex==vsklad) {",
                        "    if(vprodpercent==0) {",
                        "      Ether(0,'0D35F817-56DD-42B1-BD90-F1CE3DE1FDA5',Format(CT(\"Script.Mod_RevColonization.98\"),\"<0>\",Name(PlanetColonize),\"<1>\",vprodstr));",
                        "    }",
                        "    if(vprodpercent!=0 && vGetMoney>58) {",
                        "      ShipMoney(Player(),(ShipMoney(Player())+(((vgoodsex*(100-vinsklad))/100)*((vprodcost*vprodpercent)/100))));",
                        "      vgoodsex=(vsklad*vinsklad)/100;",
                        "      Sound('Sound.Buy');",
                        "      Ether(0,'C456704F-8445-45A4-8FD5-0534AF0896E7',Format(CT(\"Script.Mod_RevColonization.110\"),\"<0>\",Name(PlanetColonize),\"<1>\",(100-vinsklad),\"<2>\",vprodstr));",
                        "    }",
                        "  }",
                        "  if(vsklad>vgoodsex) {",
                        "    vgoodsex=vgoodsex+vproduct;",
                        "    if(vgoodsex+vproduct>vsklad) {",
                        "      vgoodsex=vsklad;",
                        "    }",
                        "  }",
                        "}"
                    ],
                    "#": 75,
                    "Type": "Top",
                    "Parent": -1,
                    "Pos.x": 120,
                    "Pos.y": 810
                },
