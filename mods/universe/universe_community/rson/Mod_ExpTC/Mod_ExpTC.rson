                    "Pos.x": 310,
                    "Pos.y": 450
                },
                {
                    "Name": "",
                    "Code.Type": "Turn",
                    "Code": [
                        "temp_dword = GAnswerData;",
                        "if(ItemSize(temp_dword_2) >= ItemSize(temp_dword)) temp_int=100;",
                        "else",
                        "{",
                        "    temp_int = (ItemSize(temp_dword) * 100) / ItemSize(temp_dword_2);",
                        "    if(temp_int <= 199) temp_int = 200 - temp_int;",
                        "}",
