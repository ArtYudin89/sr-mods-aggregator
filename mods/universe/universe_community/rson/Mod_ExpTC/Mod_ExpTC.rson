                        "{",
                        "    cur_item = ShipItems(Player(), 0);",
                        "    if(ItemImprovement(cur_item)) break;",
                        "    if(ItemExtraSpecialsCountByType(cur_item, FindBonusByNameInCfg('ExpTC_HullSpraying'))) break;",
                        "",
