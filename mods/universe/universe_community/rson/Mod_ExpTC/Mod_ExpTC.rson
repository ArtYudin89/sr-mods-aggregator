                    "Code": [
                        "if(ShipMoney(Player()) < (ItemCost(temp_dword) * 10) / 100 + GalaxyMoney(0)) AddDialogBlock(Format('Один слой, за <0> cr',\"<0>\",(ItemCost(temp_dword) * 10)/100 + GalaxyMoney(0)), 1);",
                        "if(ShipMoney(Player()) < (ItemCost(temp_dword) * 25) / 100 + GalaxyMoney(0)) AddDialogBlock(Format('Два слоя, за <0> cr',\"<0>\",(ItemCost(temp_dword) * 25)/100 + GalaxyMoney(0)), 1);",
