                {
                    "Name": "",
                    "Code.Type": "Turn",
                    "Code": [
                        "ArrayClear(temp_array);",
                        "",
                        "while(1)",
                        "{",
                        "    //Если физган ещё не был улучшен",
                        "    if(!WasPhysGunAccuracyImprove)",
                        "    {",
                        "        if(CustomWeaponType(temp_dword) == 'PhysGun')",
                        "        {",
                        "            ArrayAdd(temp_array, '</color>' + CT(\"Script.Mod_ExpTC.609\"));",
                        "            break;",
                        "        }",
                        "    }",
                        "",
                        "    //Проверяем, можно ли улучшить данный предмет",
                        "    if(ItemType(temp_dword) == t_Engine)",
                        "    {",
                        "        ArrayAdd(temp_array, '</color>' + CT(\"Script.Mod_ExpTC.608\"));",
                        "        ArrayAdd(temp_array, '</color>' + CT(\"Script.Mod_ExpTC.607\"));",
                        "    }",
                        "    else if(ItemType(temp_dword) == t_CargoHook)",
                        "    {",
                        "        ArrayAdd(temp_array, '</color>' + CT(\"Script.Mod_ExpTC.606\"));",
                        "        ArrayAdd(temp_array, '</color>' + CT(\"Script.Mod_ExpTC.605\"));",
                        "    }",
                        "    else if(ItemType(temp_dword) >= t_Weapon1 && ItemType(temp_dword) <= t_CustomWeapon)",
                        "    {",
                        "        ArrayAdd(temp_array, '</color>' + CT(\"Script.Mod_ExpTC.604\"));",
                        "        ArrayAdd(temp_array, '</color>' + CT(\"Script.Mod_ExpTC.603\"));",
                        "    }",
                        "",
                        "    break;",
                        "}",
