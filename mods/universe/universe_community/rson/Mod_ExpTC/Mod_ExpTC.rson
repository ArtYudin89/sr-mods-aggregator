                        "ItemExtraSpecialsAddByType(curItem, FindBonusByNameInCfg(temp_str_2), 1);",
                        "ItemExtraSpecialsAddByType(curItem, FindBonusByNameInCfg('ExpTC_HullSpraying'), 1);",
                        "",
                        "ShipMoney(Player(), ShipMoney(Player()) - cost);",
                        "Sound('Sound.Repair');",
                        "DChange(7);",
                        "exit;"
