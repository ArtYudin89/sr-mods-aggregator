                    "Parent": -1,
                    "Pos.x": 0,
                    "Pos.y": 635
                },
                {
                    "Name": "",
                    "Code.Type": "Init",
                    "Code": [
                        "pirate_planets = newarray(1);"
                    ],
                    "#": 45,
                    "Type": "Top",
                    "Parent": -1,
                    "Pos.x": 60,
                    "Pos.y": 635
                },
                {
                    "Name": "",
                    "Code.Type": "Turn",
                    "Code": [
                        "if(!massiv_ok)",
                        "{",
                        "    massiv_ok=1;",
                        "    massiv=newarray(1);",
                        "}",
                        "",
                        "if(!block_superdominator)",
                        "{",
                        "    t1=t1+1;",
                        "    if(CurTurn()>upg_day)upg=1;",
                        "    else upg=0;",
                        "    if(t1>=300)",
                        "    {",
                        "        if(GroupCount(HanPirates)<3)",
                        "        {",
                        "            ArrayClear(pirate_planets);",
                        "            st=GalaxyStars();",
                        "            for(st_num=0; st_num<st; st_num=st_num+1)",
                        "            {",
                        "                cur_star=GalaxyStar(st_num);",
                        "                if(StarOwner(cur_star)==1 && StarCustomFaction(cur_star)!='Klissan' && !DomiksDefeated(2))",
                        "                {",
                        "                    if(StarSeries(cur_star)==2)",
                        "                    {",
                        "                        pl=StarPlanets(cur_star);",
                        "                        for(i=0;i<pl;i=i+1)",
                        "                        {",
                        "                            cur_pl=StarPlanets(cur_star,i);",
                        "                            if(PlanetOwner(cur_pl)==5) ArrayAdd(pirate_planets,cur_pl);",
                        "                        }",
                        "                    }",
                        "                }",
                        "            }",
                        "            if (ArrayDim(pirate_planets)<=1) exit;",
                        "            if (ArrayDim(pirate_planets)<=3) rand=Rnd(0,2);",
                        "            if (ArrayDim(pirate_planets)<=6) rand=Rnd(1,3);",
                        "            else if (ArrayDim(pirate_planets)<=10) rand=Rnd(2,6);",
                        "            else if (ArrayDim(pirate_planets)<=20) rand=Rnd(3,10);",
                        "            else if (ArrayDim(pirate_planets)<=30) rand=Rnd(6,15);",
                        "            else if (ArrayDim(pirate_planets)<=45) rand=Rnd(10,20);",
                        "            else rand=Rnd(13,25);",
                        "            if (GalaxyTechLevel()<3) rand=rand*30/100;",
                        "            if (GalaxyTechLevel()==3) rand=rand*45/100;",
                        "            if (GalaxyTechLevel()==4) rand=rand*60/100;",
                        "            if (GalaxyTechLevel()==5) rand=rand*75/100;",
                        "            if (GalaxyTechLevel()==6) rand=rand*90/100;",
                        "            if (GalaxyTechLevel()==7) rand=rand*110/100;",
                        "            if (GalaxyTechLevel()==8) rand=rand*130/100;",
                        "            t1=0;",
                        "            for(i=0; i<rand; i=i+1)",
                        "            {",
                        "                cur_pl=pirate_planets[Rnd(1,ArrayDim(pirate_planets)-1)];",
                        "                s=BuyDomikExtremal(cur_pl);",
                        "                ShipType(s,'Superdominator');",
                        "                shu_shit=ShipSubType(s);",
                        "                //Штип",
                        "                if(shu_shit==5)",
                        "                {",
                        "                    v2=Rnd(1000,1500);",
                        "                    v4=5;",
                        "                    v5=15;",
                        "                    //Навешивание графических акринов из солянки",
                        "                    SpecialToEquipment(FindBonusByNameInCfg('TerronSupDom1'),ShipItems(s,0));",
                        "                }",
                        "                //Менок",
                        "                else if(shu_shit==4)",
                        "                {",
                        "                    v2=Rnd(1500,2250);",
                        "                    v4=10;",
                        "                    v5=30;",
                        "                    //Навешивание графических акринов из солянки",
                        "                    SpecialToEquipment(FindBonusByNameInCfg('TerronSupDom1'),ShipItems(s,0));",
                        "                }",
                        "                //Смерш",
                        "                else if(shu_shit==3)",
                        "                {",
                        "                    v2=Rnd(2250,3250);",
                        "                    v4=13;",
                        "                    v5=45;",
                        "                    //Навешивание графических акринов из солянки",
                        "                    SpecialToEquipment(FindBonusByNameInCfg('TerronSupDom2'),ShipItems(s,0));",
                        "                }",
                        "                //Ургант",
                        "                else if(shu_shit==2)",
                        "                {",
                        "                    v2=Rnd(3250,4500);",
                        "                    v4=16;",
                        "                    v5=60;",
                        "                    //Навешивание графических акринов из солянки",
                        "                    SpecialToEquipment(FindBonusByNameInCfg('TerronSupDom2'),ShipItems(s,0));",
                        "                }",
                        "                //Эквентор",
                        "                else if(shu_shit==1)",
                        "                {",
                        "                    v2=Rnd(4500,6000);",
                        "                    v4=20;",
                        "                    v5=75;",
                        "                    //Навешивание графических акринов из солянки",
                        "                    SpecialToEquipment(FindBonusByNameInCfg('TerronSupDom2'),ShipItems(s,0));",
                        "                }",
                        "                //Бертор",
                        "                else if(shu_shit==6)",
                        "                {",
                        "                    v2=Rnd(6000,7750);",
                        "                    v4=23;",
                        "                    v5=90;",
                        "                    //Навешивание графических акринов из солянки",
                        "                    SpecialToEquipment(FindBonusByNameInCfg('TerronSupDom3'),ShipItems(s,0));",
                        "                }",
                        "                v2=v2*115/100;",
                        "                ItemSize(ShipItems(s,0),v2);",
                        "                HullHP(s,ItemSize(ShipItems(s,0)));",
                        "                Chameleon(s);",
                        "                ShipJoin(HanPirates,s);",
                        "                ArrangeItems(s);",
                        "                v1=Rnd(10,15);",
                        "                for(v3=0; v3<v1; v3=v3+1)",
                        "                {",
                        "                    if (v3==0) v2=CreateNodes(Rnd(v4*3,v5*3),2,1);",
                        "                    else v2=CreateNodes(Rnd(v4,v5),2,1);",
                        "                    ShipAddDropItem(s,v2);",
                        "                }",
                        "                v3=ShipCntWeapon(s);",
                        "                for(v2=v3; v2>0; v2=v2-1)",
                        "                {",
                        "                    v1=ShipWeapon(s,v2);",
                        "                    FreeItem(GetItemFromShip(s,FindItemInShip(s,v1)));",
                        "                }",
                        "                v3=Rnd(2,5);",
                        "                for(v2=0; v2<v3; v2=v2+1)",
                        "                {",
                        "                    v1=CreateCustomWeapon('Dom_minigun',Rnd(55,110),GalaxyTechLevel(),Kling);",
                        "                    LinkItemToScript(v1);",
                        "                    ItemOnActCode(v1, GenerateCodeStringFromBlock('ActCodeBlocksList.ShuDomiksPlus_MinigunShot'));",
                        "                    ItemSubrace(v1,ItemSubrace(ShipItems(s,0)));",
                        "                    SpecialToEquipment(FindBonusByNameInCfg('ShuDomiks_MMBlockAcryn'),v1);",
                        "                    AddItemToShip(s,v1);",
                        "                }",
                        "                if(Rnd(0,1))",
                        "                {",
                        "                    v1=CreateCustomWeapon('Dom_minigun',Rnd(55,110),GalaxyTechLevel(),Kling);",
                        "                    LinkItemToScript(v1);",
                        "                    ItemOnActCode(v1, GenerateCodeStringFromBlock('ActCodeBlocksList.ShuDomiksPlus_MinigunShot'));",
                        "                    ItemSubrace(v1,ItemSubrace(ShipItems(s,0)));",
                        "                    SpecialToEquipment(FindBonusByNameInCfg('ShuDomiks_MMBlockAcryn'),v1);",
                        "                    ShipAddDropItem(s,v1);",
                        "                }",
                        "                ArrangeItems(s);",
                        "                ShipSpecialBonuses(s,bonSpeed,-100);",
                        "                ShipSpecialBonuses(s,bonMass,100);",
                        "            }",
                        "        }",
                        "    }",
                        "}"
                    ],
                    "#": 46,
                    "Type": "Top",
                    "Parent": -1,
                    "Pos.x": 120,
                    "Pos.y": 635
                },
                {
                    "Name": "",
                    "Code.Type": "DialogBegin",
                    "Code": [
                        "if(GetTalkShip())",
                        "{",
                        "    if(!TalkByAI())",
                        "    {",
                        "        if(ShipType(GetTalkShip()) == 'Superdominator')",
                        "        {",
                        "            if(ItemSubrace(ShipItems(GetTalkShip(), 0)) == 2) AddDialogOverride('dialog', 50);",
                        "        }",
                        "    }",
                        "}"
                    ],
