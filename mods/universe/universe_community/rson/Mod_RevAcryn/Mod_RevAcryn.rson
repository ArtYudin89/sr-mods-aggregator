                        "if(!GLastTurnRun(GScriptName)) GRun();"
                    ],
                    "#": 23,
                    "Type": "Top",
                    "Parent": -1,
                    "Pos.x": 0,
                    "Pos.y": 535
                },
                {
                    "Name": "",
                    "Code.Type": "Init",
                    "Code": [
                        "countNOKM = Rnd(32, 45);",
                        "countAssemblyDroids = Rnd(37, 51);",
                        "countBattleDroids = Rnd(41, 63);",
                        "countUbivators = Rnd(51, 83);"
                    ],
                    "#": 24,
                    "Type": "Top",
                    "Parent": -1,
                    "Pos.x": 60,
                    "Pos.y": 535
                },
                {
                    "Name": "",
                    "Code.Type": "Turn",
                    "Code": [
                        "if(!ShipIsTakeoff(Player())) {",
                        "  GTL = GalaxyTechLevel();",
                        "  if(GTL >= 5)",
                        "  {",
                        "      //Раскидываем по магазинам боевых дроидов",
                        "      if(countBattleDroids <= CurTurn())",
                        "      {",
                        "          //Начинаем перебирать все системы и станции в них, ищем подходящие",
                        "          ArrayClear(tarr1);",
                        "          for(i = GalaxyStars() - 1; i >= 0; i = i - 1)",
                        "          {",
                        "              star = GalaxyStar(i);",
                        "              //Пропускаем доминаторские и \"кастомные\" системы",
                        "              if(StarOwner(star) == 1) continue;",
                        "              if(StarCustomFaction(star) != '') continue;",
                        "  ",
                        "              //Ищем среди станций системы подходящие для продажи дроида",
                        "              for(j = StarRuins(star) - 1; j >= 0; j = j - 1)",
                        "              {",
                        "                  place = StarRuins(star, j);",
                        "                  tempStr = ShipType(place);",
                        "  ",
                        "                  check = 0;",
                        "                  if(tempStr == 'WB') check = 1;",
                        "                  else if(tempStr == 'TC') check = 1;",
                        "                  else if(tempStr == 'PB') check = 1;",
                        "                  else if(tempStr == 'CB') check = 1;",
                        "                  else continue;",
                        "  ",
                        "                  //Проверяем, имеется в продаже станции схожий акрин и если да, то удаляем его",
                        "                  //Имеется случайный шанс, что в этот раз на данную станцию акрин добавлен не будет",
                        "                  if(RndObject(1, 100, place) <= 30) continue;",
                        "  ",
                        "                  for(k = ShopItems(place) - 1; k >= 0; k = k - 1)",
                        "                  {",
                        "                      item = ShopItems(place, k);",
                        "  ",
                        "                      check = EqSpecial(item);",
                        "                      if(~check)",
                        "                      {",
                        "                          tempStr = BonusNumInCfg(check);",
                        "                          if(!findsubstr(tempStr, 'RevAcryn_BattleDroid'))",
                        "                          {",
                        "                              FreeItem(GetItemFromShop(place, k));",
                        "                          }",
                        "                      }",
                        "                  }",
                        "  ",
                        "                  ArrayAdd(tarr1, place);",
                        "              }",
                        "          }",
                        "  ",
                        "          //Если нашли, то выбираем из общего числа найденных станций несколько случайных",
                        "          tint1 = ArrayDim(tarr1) - 1;",
                        "          if(tint1)",
                        "          {",
                        "              j = Rnd(2, 4);",
                        "              if(j > tint1) j = tint1;",
                        "              while(j)",
                        "              {",
                        "                  //Случайно определяем станцию, на которую будет добавлен дроид",
                        "                  tint1 = Rnd(1, j);",
                        "                  place = tarr1[tint1];",
                        "                  //После чего удаляем её из списка",
                        "                  ArrayDelete(tarr1, tint1);",
                        "  ",
                        "                  //Определяем ТУ будущего дроида",
                        "                  tint1 = RndObject(1, 6, place);",
                        "                  if(tint1 <= 3) tint1 = 0;",
                        "                  else if(tint1 <= 5) tint1 = 1;",
                        "                  else tint1 = 2;",
                        "                  if(GTL - tint1 < 5) tint1 = 5;",
                        "                  else tint1 = GTL - tint1;",
                        "  ",
                        "                  //Определяем расу",
                        "                  tint2 = PlanetOwner(NearCivilPlanet(place));",
                        "                  if(tint2 > 2 && tint2 != 7)",
                        "                  {",
                        "                      j = j - 1;",
                        "                      continue;",
                        "                  }",
                        "                  //И вес будущего дроида",
                        "                  //Малоки",
                        "                  if(!tint2) i = round(1.6 * CT('Items.RepairRobot.AverageSize')) + RndObject(-5, 4, place);",
                        "                  //Пеленги",
                        "                  else if(tint2 == 1) i = round(1.2 * CT('Items.RepairRobot.AverageSize')) + RndObject(-3, 4, place);",
                        "                  //Люди",
                        "                  else if(tint2 == 2) i = round(1.0 * CT('Items.RepairRobot.AverageSize')) + RndObject(-3, 5, place);",
                        "                  //Пираты",
                        "                  else i = round(1.3 * CT('Items.RepairRobot.AverageSize')) + RndObject(-3, 4, place);",
                        "                  if(j <= 0) i = 1;",
                        "  ",
                        "                  //Создаём, акринируем, после чего, наконец, добавляем дроида в магазин",
                        "                  item = CreateEquipment(t_RepairRobot, i, tint1, tint2);",
                        "                  SetEquipmentStats(item, 0, 0);",
                        "                  SpecialToEquipment(FindBonusByNameInCfg('RevAcryn_BattleDroid' + tint1), item);",
                        "                  AddItemToShop(place, item);",
                        "  ",
                        "                  j = j - 1;",
                        "              }",
                        "          }",
                        "  ",
                        "          countBattleDroids = CurTurn() + Rnd(75, 150);",
                        "      }",
                        "  ",
                        "      //НОКМ начнёт появляться не раньше, чем через 14 лет после начала игры, поскольку НОКМ-3314",
                        "      if(CurTurn() >= 5411)",
                        "      {",
                        "          if(GTL >= 6)",
                        "          {",
                        "              //Закидываем НОКМ в магазины ВБ по всей Галактике (и иногда на Рамгатру)",
                        "              if(countNOKM <= CurTurn())",
                        "              {",
                        "                  bonus = FindBonusByNameInCfg('RevAcryn_NOKM');",
                        "                  //Ищем планету Рамгатру в системе Тарон (может менять номер на разных генерациях)",
                        "  \t\t\t\tplace = 0;",
                        "  \t\t\t\ttstr1 = CT('PlanetName.Maloc.02');",
                        "                  cnt = StarPlanets(GalaxyStar(Maloc));",
                        "                  for(i = 0; i < cnt; i = i + 1)",
                        "                  {",
                        "                      if(PlanetName(StarPlanets(GalaxyStar(Maloc), i)) == tstr1)",
                        "                      {",
                        "                          place = StarPlanets(GalaxyStar(Maloc), i);",
                        "                          break;",
                        "                      }",
                        "                  }",
                        "  ",
                        "                  //Проверяем её магазин на наличие НОКМ",
                        "  \t\t\t\tif(place) //Встретил умника, который сгенерил себе английские названия систем и планет, а затем переключился на русский Lang - это вот как раз защита от подобного",
                        "  \t\t\t\t{",
                        "  \t\t\t\t\tcheck = 0;",
                        "  \t\t\t\t\tfor(i = ShopItems(place) - 1; i >= 0; i = i - 1)",
                        "  \t\t\t\t\t{",
                        "  \t\t\t\t\t\titem = ShopItems(place, i);",
                        "  \t\t\t\t\t\tif(~EqSpecial(item))",
                        "  \t\t\t\t\t\t{",
                        "  \t\t\t\t\t\t\tif(EqSpecial(item) == bonus)",
                        "  \t\t\t\t\t\t\t{",
                        "  \t\t\t\t\t\t\t\tcheck = 1;",
                        "  \t\t\t\t\t\t\t\tbreak;",
                        "  \t\t\t\t\t\t\t}",
                        "  \t\t\t\t\t\t}",
                        "  \t\t\t\t\t}",
                        "  ",
                        "  \t\t\t\t\tif(!check)",
                        "  \t\t\t\t\t{",
                        "  \t\t\t\t\t\tif(RndObject(1, 100, place) <= 25)",
                        "  \t\t\t\t\t\t{",
                        "  \t\t\t\t\t\t\titem = CreateEquipment(t_Engine, RndObject(50, 100, place), 6, 0);",
                        "  \t\t\t\t\t\t\tSetEquipmentStats(item, 0, 0);",
                        "  \t\t\t\t\t\t\tSetEquipmentStats(item, 0, 1);",
                        "  \t\t\t\t\t\t\tSpecialToEquipment(bonus, item);",
                        "  \t\t\t\t\t\t\tAddItemToShop(place, item);",
                        "  \t\t\t\t\t\t}",
                        "  \t\t\t\t\t}",
                        "  \t\t\t\t}",
                        "  ",
                        "                  //Начинаем перебирать все системы и станции в них - ищем ВБ",
                        "                  for(i = GalaxyStars() - 1; i >= 0; i = i - 1)",
                        "                  {",
                        "                      star = GalaxyStar(i);",
                        "                      if(StarOwner(star)) continue;",
                        "                      if(!StarRuins(star, 'WB')) continue;",
                        "  ",
                        "                      place = StarRuins(star, 'WB');",
                        "                      check = 0;",
                        "                      //Нашли ВБ, а теперь проверяем её магазин на наличие НОКМ",
                        "                      for(j = ShopItems(place) - 1; j >= 0; j = j - 1)",
                        "                      {",
                        "                          item = ShopItems(place, j);",
                        "                          if(~EqSpecial(item))",
                        "                          {",
                        "                              if(EqSpecial(item) == bonus)",
                        "                              {",
                        "                                  check = 1;",
                        "                                  break;",
                        "                              }",
                        "                          }",
                        "                      }",
                        "  ",
                        "                      if(!check)",
                        "                      {",
                        "                          if(RndObject(1, 100, place) <= 14)",
                        "                          {",
                        "                              item = CreateEquipment(t_Engine, RndObject(60, 120, place), 6, 0);",
                        "                              SetEquipmentStats(item, 0, 0);",
                        "                              SetEquipmentStats(item, 0, 1);",
                        "                              SpecialToEquipment(bonus, item);",
                        "                              ItemDurability(item, RndObject(69, 100, place));",
                        "                              AddItemToShop(place, item);",
                        "                          }",
                        "                      }",
                        "                  }",
                        "  ",
                        "                  countNOKM = CurTurn() + Rnd(75, 150);",
                        "              }",
                        "          }",
                        "      }",
                        "  ",
                        "      //Закидываем сборочного дроида в магазины ЦР, НБ, ТЦ и МЦ по всей Галактике",
                        "      if(countAssemblyDroids <= CurTurn())",
                        "      {",
                        "          bonus = FindBonusByNameInCfg('RevAcryn_AssemblyDroidNormal');",
                        "          //Начинаем перебирать все системы и станции в них - ищем ЦР, НБ, ТЦ и МЦ",
                        "          for(i = GalaxyStars() - 1; i >= 0; i = i - 1)",
                        "          {",
                        "              star = GalaxyStar(i);",
                        "              if(StarOwner(star)) continue;",
                        "              for(j = StarRuins(star) - 1; j >= 0; j = j - 1)",
                        "              {",
                        "                  place = StarRuins(star, j);",
                        "                  tempStr = ShipType(place);",
                        "                  check = 0;",
                        "                  if(tempStr == 'RC') check = 1;",
                        "                  else if(tempStr == 'SB') check = 1;",
                        "                  else if(tempStr == 'TC') check = 1;",
                        "                  else if(tempStr == 'MC') check = 1;",
                        "                  else continue;",
                        "  ",
                        "                  check = 0;",
                        "                  //Нашли станцию, а теперь проверяем её магазин на наличие сборочного дроида",
                        "                  for(k = ShopItems(place) - 1; k >= 0; k = k - 1)",
                        "                  {",
                        "                      item = ShopItems(place, k);",
                        "                      if(~EqSpecial(item))",
                        "                      {",
                        "                          if(EqSpecial(item) == bonus)",
                        "                          {",
                        "                              check = 1;",
                        "                              break;",
                        "                          }",
                        "                      }",
                        "                  }",
                        "  ",
                        "                  if(!check)",
                        "                  {",
                        "                      if(RndObject(1, 100, place) <= 10)",
                        "                      {",
                        "                          check = RndObject(Peleng, Gaal, place); //Определяем расу-производителя",
                        "                          if(check == Peleng) item = CreateEquipment(t_RepairRobot, RndObject(70, 95, place), GTL, check);",
                        "                          else if(check == People) item = CreateEquipment(t_RepairRobot, RndObject(65, 80, place), GTL, check);",
                        "                          else if(check == Fei) item = CreateEquipment(t_RepairRobot, RndObject(50, 65, place), GTL, check);",
                        "                          else /*if(check == Gaal)*/ item = CreateEquipment(t_RepairRobot, RndObject(60, 75, place), GTL, check);",
                        "  ",
                        "                          //Задаём эффективность ремонта сборочного дроида:",
                        "                          //5 ГТУ - 20 * 5 = 100",
                        "                          //6 ГТУ - 30 * 5 = 150",
                        "                          //7 ГТУ - 40 * 5 = 200",
                        "                          //8 ГТУ - 50 * 5 = 250",
                        "                          SetEquipmentStats(item, (20 + ((GTL - 5) * 10)) * 5, 0);",
                        "  ",
                        "                          SpecialToEquipment(bonus, item);",
                        "                          if(tempStr == 'MC') ItemDurability(item, RndObject(67, 100, place));",
                        "                          LinkItemToScript(item);",
                        "                          //Присваиваем ему акткод",
                        "                          ItemOnActCode(item, GenerateCodeStringFromBlock('ActCodeBlocksList.RevAcrynAssemblyDroidActCode'));",
                        "                          SetName(item, '<color=49,239,255>' + CT('Items.RepairRobot.AssemblyDroidType.' + ItemLevel(item)) + Name(item) + '</color>');",
                        "                          //Разрешаем продажу этого скриптового дроида",
                        "                          CanSellItem(item, 1);",
                        "                          //И добавляем дроида в магазин",
                        "                          AddItemToShop(place, item);",
                        "                      }",
                        "                  }",
                        "              }",
                        "          }",
                        "  ",
                        "          countAssemblyDroids = CurTurn() + Rnd(75, 150);",
                        "      }",
                        "  ",
                        "      //Раскидываем по магазинам \"Убиваторов\"",
                        "      if(GTL >= 7)",
                        "      {",
                        "          if(countUbivators <= CurTurn())",
                        "          {",
                        "              //Начинаем перебирать все системы и станции в них, ищем подходящие",
                        "              ArrayClear(tarr1);",
                        "              for(i = GalaxyStars() - 1; i >= 0; i = i - 1)",
                        "              {",
                        "                  star = GalaxyStar(i);",
                        "                  //Пропускаем доминаторские и \"кастомные\" системы",
                        "                  if(StarOwner(star) == 1) continue;",
                        "                  if(StarCustomFaction(star) != '') continue;",
                        "  ",
                        "                  //Ищем среди станций системы подходящие для продажи Убиватора",
                        "                  for(j = StarRuins(star) - 1; j >= 0; j = j - 1)",
                        "                  {",
                        "                      place = StarRuins(star, j);",
                        "                      tempStr = ShipType(place);",
                        "  ",
                        "                      check = 0;",
                        "                      if(tempStr == 'PB') check = 1;",
                        "                      else if(tempStr == 'WB') check = 1;",
                        "                      else if(tempStr == 'MB') check = 1;",
                        "                      else if(tempStr == 'Manaan') check = 1;",
                        "                      else continue;",
                        "  ",
                        "                      //Проверяем, имеется в продаже станции схожий акрин и если да, то удаляем его",
                        "                      //Имеется случайный шанс, что в этот раз на данную станцию акрин добавлен не будет",
                        "                      if(RndObject(1, 100, place) <= 30) continue;",
                        "  ",
                        "                      for(k = ShopItems(place) - 1; k >= 0; k = k - 1)",
                        "                      {",
                        "                          item = ShopItems(place, k);",
                        "  ",
                        "                          check = EqSpecial(item);",
                        "                          if(~check)",
                        "                          {",
                        "                              tempStr = BonusNumInCfg(check);",
                        "                              if(!findsubstr(tempStr, 'RevAcryn_Ubivator'))",
                        "                              {",
                        "                                  FreeItem(GetItemFromShop(place, k));",
                        "                              }",
                        "                          }",
                        "                      }",
                        "  ",
                        "                      ArrayAdd(tarr1, place);",
                        "                  }",
                        "              }",
                        "  ",
                        "              //Если нашли, то выбираем из общего числа найденных станций несколько случайных",
                        "              tint1 = ArrayDim(tarr1) - 1;",
                        "              if(tint1)",
                        "              {",
                        "                  j = Rnd(2, 4);",
                        "                  if(j > tint1) j = tint1;",
                        "                  while(j)",
                        "                  {",
                        "                      //Случайно определяем станцию, на которую будет добавлен Убиватор",
                        "                      tint1 = Rnd(1, j);",
                        "                      place = tarr1[tint1];",
                        "                      //После чего удаляем её из списка",
                        "                      ArrayDelete(tarr1, tint1);",
                        "  ",
                        "                      //Определяем ТУ будущего Убиватора",
                        "                      if(GTL == 8) tint1 = RndObject(7, 8, place);",
                        "                      else tint1 = 7;",
                        "  ",
                        "                      //Определяем расу",
                        "                      tint2 = PlanetOwner(NearCivilPlanet(place));",
                        "                      if(tint2 == 5 || tint2 == 6)",
                        "                      {",
                        "                          j = j - 1;",
                        "                          continue;",
                        "                      }",
                        "                      //И вес будущего Убиватора",
                        "                      //Малоки",
                        "                      if(!tint2) i = round(1.6 * CT('Items.Radar.AverageSize')) + RndObject(-5, 4, place);",
                        "                      //Пеленги",
                        "                      else if(tint2 == 1) i = round(1.2 * CT('Items.Radar.AverageSize')) + RndObject(-3, 4, place);",
                        "                      //Люди",
                        "                      else if(tint2 == 2) i = round(1.0 * CT('Items.Radar.AverageSize')) + RndObject(-3, 5, place);",
                        "                      //Фэяне",
                        "                      else if(tint2 == 3) i = round(0.6 * CT('Items.Radar.AverageSize')) + RndObject(-1, 6, place);",
                        "                      //Гаальцы",
                        "                      else if(tint2 == 4) i = round(0.8 * CT('Items.Radar.AverageSize')) + RndObject(-2, 6, place);",
                        "                      //Пираты",
                        "                      else i = round(1.3 * CT('Items.Radar.AverageSize')) + RndObject(-3, 4, place);",
                        "  ",
                        "                      if(j <= 0) i = 1;",
                        "  ",
                        "                      //Создаём, акринируем, после чего, наконец, добавляем Убиватора в магазин",
                        "                      item = CreateEquipment(t_Radar, i, tint1, tint2);",
                        "                      SetEquipmentStats(item, 0, 0);",
                        "                      SpecialToEquipment(FindBonusByNameInCfg('RevAcryn_Ubivator' + tint1), item);",
                        "                      AddItemToShop(place, item);",
                        "  ",
                        "                      j = j - 1;",
                        "                  }",
                        "              }",
                        "  ",
                        "              countUbivators = CurTurn() + Rnd(75, 150);",
                        "          }",
                        "      }",
                        "  }",
                        "}"
                    ],
                    "#": 25,
                    "Type": "Top",
                    "Parent": -1,
                    "Pos.x": 120,
                    "Pos.y": 535
                }
            ],
