                },
                {
                    "Name": "",
                    "Code.Type": "Turn",
                    "Code": [
                        "SkipGreeting();",
                        "if(!MS_Begin_FirstOk) {",
                        "  DChange(0);",
                        "  exit;",
                        "}",
                        "if(MS_Begin_FirstOk == 1) {",
                        "  DChange(1);",
