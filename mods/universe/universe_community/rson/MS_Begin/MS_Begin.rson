                        "  counter=GalaxyEvents()-1;",
                        "  while (counter>=0){",
                        "  if (GalaxyEventDate(counter)>dGoodsQuestBegin){",
                        "  if (GalaxyEventType(counter)=='PlayerSellsGoodsToPlanet'){",
                        "  if (GalaxyEventData(counter,0)==t_Medicine){",
                        "  if (GalaxyEventData(counter,3)==Id(otherPlanet)){",
                        "  dGoodsQuestSell=1;}}}}",
