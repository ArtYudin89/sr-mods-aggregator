                        "  if(ShipFuelLow(Player())) {",
                        "    DChange(15);",
                        "    exit;",
                        "  }",
                        "  if(!ShipFuelLow(Player())) {",
                        "    if(!dKillQuestBegin) {",
                        "      if(EtherState('4F6C2F29-4A02-46E9-BF8B-467EC1EC4246')==3) {",
                        "        Ether(4,'4F6C2F29-4A02-46E9-BF8B-467EC1EC4246',Format(CT(\"Script.MS_Begin.15\"),\"<0>\",Name(Star2),\"<1>\",Name(Planet2)));",
