                        "Sound('Sound.Sell');",
                        "str0 = '';",
                        "",
                        "if(mmTake > 24)",
                        "{",
                        "    k = int(mmTake / 25);",
                        "    mmTake = mmTake - (25 * k);",
                        "    str3 = '';",
                        "    for(k = k; k > 0; k = k - 1)",
