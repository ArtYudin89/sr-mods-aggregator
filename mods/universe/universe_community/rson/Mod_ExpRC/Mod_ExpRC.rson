                        "str0 = '</color>' + Format(CT('FormRuins.RC.TakeNod.RCAfterPlayerOk'), '<NodCnt' + '>', int2, '<Name' + '>', BonusName(array0[2]));",
                        "DChange(20);",
                        "exit;"
                    ],
