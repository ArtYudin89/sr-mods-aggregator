            "Items": [],
            "Operations": [
                {
                    "Name": "",
                    "Code.Type": "Global",
                    "Code": [
                        "GRun();"
                    ],
                    "#": 28,
                    "Type": "Top",
                    "Parent": -1,
                    "Pos.x": 0,
                    "Pos.y": 610
                },
                {
                    "Name": "",
                    "Code.Type": "Init",
                    "Code": [
                        "// Случайное действительно число от 0.0 до 1.0 с шагом 1e-9",
                        "function random_real() {",
                        "    result = 1.0 * Rnd(0, 1000000000) / 1000000000.0;",
                        "}",
                        "",
                        "// Функции для взвешенного случайного выбора из нескольких значений (надеюсь я нигде не опечатался)",
                        "// w1 - вес, a - значение",
                        "// Сумма весов не обязательно равна 1",
                        "function choice2(w1, a, w2, b) {",
                        "    if (w1 + w2 == 0) {",
                        "        result = choice2(1.0, a, 1.0, b);",
                        "    } else {",
                        "        if (random_real() < 1.0 * w1 / (0.0 + w1 + w2)) {",
                        "            result = a;",
                        "        } else {",
                        "            result = b;",
                        "        }",
                        "    }",
                        "}",
                        "",
                        "function choice4(w1, a, w2, b, w3, c, w4, d) {",
                        "    result = choice2(",
                        "        w1 + w2, choice2(w1, a, w2, b),",
                        "        w3 + w4, choice2(w3, c, w4, d)",
                        "    );",
                        "}",
                        "",
                        "function choice8(w1, a, w2, b, w3, c, w4, d, w5, e, w6, f, w7, g, w8, h) {",
                        "    result = choice2(",
                        "        w1 + w2 + w3 + w4, choice4(w1, a, w2, b, w3, c, w4, d),",
                        "        w5 + w6 + w7 + w8, choice4(w5, e, w6, f, w7, g, w8, h)",
                        "    );",
                        "}",
                        "//",
                        "function choice16(w1, a, w2, b, w3, c, w4, d, w5, e, w6, f, w7, g, w8, h, w9, i, w10, j, w11, k, w12, l, w13, m, w14, n, w15, p, w16, p) {",
                        "    result = choice2(",
                        "        w1 + w2 + w3 + w4 + w5 + w6 + w7 + w8, choice8(w1, a, w2, b, w3, c, w4, d, w5, e, w6, f, w7, g, w8, h),",
                        "        w9 + w10 + w11 + w12 + w13 + w14 + w15 + w16, choice8(w9, i, w10, j, w11, k, w12, l, w13, m, w14, n, w15, p, w16, p)",
                        "    );",
                        "}",
                        "//",
                        "function choice3(w1, a, w2, b, w3, c) {",
                        "    result = choice4(w1, a, w2, b, w3, c, 0, 0);",
                        "}",
                        "",
                        "function choice5(w1, a, w2, b, w3, c, w4, d, w5, e) {",
                        "    result = choice8(w1, a, w2, b, w3, c, w4, d, w5, e, 0, 0, 0, 0, 0, 0);",
                        "}",
                        "",
                        "function choice6(w1, a, w2, b, w3, c, w4, d, w5, e, w6) {",
                        "    result = choice8(w1, a, w2, b, w3, c, w4, d, w5, e, w6, f, 0, 0, 0, 0);",
                        "}",
                        "",
                        "function choice7(w1, a, w2, b, w3, c, w4, d, w5, e, w6, f, w7) {",
                        "    result = choice8(w1, a, w2, b, w3, c, w4, d, w5, e, w6, f, w7, g, 0, 0);",
                        "}",
                        "",
                        "//Приводит значение val к диапазону (mn,mx)",
                        "function toDiap(val, mn, mx) {",
                        "    result = min(max(val, mn), mx);",
                        "}",
                        "",
                        "// Возвращает истину (1) с вероятностью p, иначе - ложь (0)",
                        "function prob(p) {",
                        "    if (random_real() <= p) result = 1;",
                        "    else result = 0;",
                        "}",
                        "",
                        "function _frac(r){",
                        "    result = round(r) - r;",
                        "    if (result < 0) result = result + 1;",
                        "}",
                        "",
                        "function _floor(r){",
                        "    result = round(r);",
                        "    if (result > r) result = result - 1;",
                        "}",
                        "",
                        "// random_real()",
                        "// choiceN(weight_i, val_i, ...)",
                        "// toDiap(val, min, max)",
                        "// prob(p)",
                        "",
                        "// Функции для рандомизации;",
                        "planets = newarray(1);",
                        "speeds = newarray(1);",
                        "times = newarray(1);",
                        "// индекс=0 - ничего",
                        "// остальное - параметры буста;"
                    ],
                    "#": 29,
                    "Type": "Top",
                    "Parent": -1,
                    "Pos.x": 60,
                    "Pos.y": 610
                },
                {
                    "Name": "",
                    "Code.Type": "Turn",
                    "Code": [
                        "for (i = ArrayDim(planets) - 1; i > 0; i = i - 1) {",
                        "    if (planets[i] > 100000) { // Со старой багованной версии, удаляем указатели",
                        "        cost = round(0.100 * GalaxyMoney(2) * times[i] * speeds[i]);",
                        "        SFT('[AMod.Investitions.TurnCode] Удаление планеты из списка и компенсация затрат: ' + cost +' cr. Указатель на планету: ' + planets[i]);",
                        "        ArrayDelete(planets, i);",
                        "        ArrayDelete(times, i);",
                        "        ArrayDelete(speeds, i);",
                        "        ShipMoney(Player(), ShipMoney(Player()) + cost);",
                        "        continue;",
                        "    }",
                        "",
                        "    //SFT(' speeds floor frac: ' + _floor(speeds[i]) + ' ' + _frac(speeds[i]) + ' arraydim: ' + ArrayDim(planets) +' '+ArrayDim(speeds)+' '+ArrayDim(times) + ' i: '+ i + ' planet: ' + planets[i] + ' time: ' + times[i] + ' speed: ' + speeds[i] + ' !');",
                        "",
                        "    cPlanet = planets[i];",
                        "",
                        "    times[i] = times[i] - 1;",
                        "    ",
                        "    j = _floor(speeds[i]);",
                        "    if (random_real() < _frac(speeds[i]))",
                        "        j = j + 1;",
                        "    PlanetBoostInventions(IdToPlanet(planets[i]), j);",
                        "    ",
                        "    if (times[i] == 0) {",
                        "       ArrayDelete(planets, i);",
                        "       ArrayDelete(times, i);",
                        "       ArrayDelete(speeds, i);",
                        "    }",
                        "}"
                    ],
                    "#": 30,
                    "Type": "Top",
                    "Parent": -1,
                    "Pos.x": 120,
                    "Pos.y": 610
                },
                {
                    "Name": "",
                    "Code.Type": "DialogBegin",
                    "Code": [
                        "if(GetShipPlanet(Player())) {",
                        "  if(GetShipPlanet(Player()) != PlanetPirateClan() && PlanetOwner(GetShipPlanet(Player())) != None) {",
                        "    cStar = ShipStar(Player());",
                        "    cPlanet = GetShipPlanet(Player());",
                        "    race = PlanetOwner(cPlanet);",
                        "    eco = PlanetEco(cPlanet);",
                        "    gov = PlanetGov(cPlanet);",
                        "    pop = PlanetPopulation(cPlanet);",
                        "    ",
                        "    if (race == PirateClan) relation = RelationToRanger(PlanetPirateClan(), Player());",
                        "    else relation = RelationToRanger(cPlanet, Player());",
                        "    ",
                        "    str0 = CT(\"Script.mod_investitions.13\");",
                        "    if (StarBattle(cStar)) {",
                        "        if (PlanetOwner(cPlanet) == PirateClan) AddDialogInject('battleClan', '', str0, 2);",
                        "        if (PlanetOwner(cPlanet) <= Gaal) AddDialogInject('battleCoal', '', str0, 2);",
                        "    } else {",
                        "        if (relation < 30) AddDialogInject('badRelation', '', str0, 2);",
                        "        else if (ArrayFind(planets, cPlanet) != -1) AddDialogInject('alreadyBoosted', '', str0, 2);",
                        "        else AddDialogInject('investitions', '', str0, 2);",
                        "    }",
                        "  }",
                        "}"
                    ],
                    "#": 31,
                    "Type": "Top",
                    "Parent": -1,
                    "Pos.x": 180,
                    "Pos.y": 610
                },
                {
                    "Name": "",
                    "Code.Type": "Turn",
                    "Code": [
                        "DChange(0);",
                        "exit;"
                    ],
                    "#": 59,
                    "Type": "Top",
                    "Parent": -1,
                    "Pos.x": -20,
                    "Pos.y": 400
                },
                {
                    "Name": "",
                    "Code.Type": "Turn",
                    "Code": [
                        "DChange(1);",
                        "exit;"
                    ],
                    "#": 60,
                    "Type": "Top",
                    "Parent": -1,
                    "Pos.x": 130,
                    "Pos.y": 400
                },
                {
                    "Name": "",
                    "Code.Type": "Turn",
                    "Code": [
                        "DChange(2);",
                        "exit;"
                    ],
                    "#": 61,
                    "Type": "Top",
                    "Parent": -1,
                    "Pos.x": 280,
                    "Pos.y": 400
                },
                {
                    "Name": "",
                    "Code.Type": "Turn",
                    "Code": [
                        "time = 100;",
                        "speed = 100;",
                        "",
                        "f = 0.100 * GalaxyMoney(2);",
                        "",
                        "if (race ==      Maloc) f = f * 0.600;",
                        "if (race ==     Peleng) f = f * 0.800;",
                        "if (race ==     People) f = f * 1.000;",
                        "if (race ==        Fei) f = f * 1.200;",
                        "if (race ==       Gaal) f = f * 1.400;",
                        "if (race == PirateClan) f = f * 1.000;",
                        "",
                        "if (eco == 0) f = f * 0.800; // Аграрная",
                        "if (eco == 1) f = f * 1.000; // Смешанная",
                        "if (eco == 2) f = f * 1.200; // Индустриальная",
                        "",
                        "if (gov == 0) f = f * 0.800; // Анархия",
                        "if (gov == 1) f = f * 1.000; // Диктатура",
                        "if (gov == 2) f = f * 0.900; // Монархия",
                        "if (gov == 3) f = f * 1.100; // Республика",
                        "if (gov == 4) f = f * 1.200; // Демократия",
                        "",
                        "f = f * (1.000 - 0.001 * pop / 1000000.0); // 0.1% на каждый миллион",
                        "",
                        "f = f * (1.000 + 0.03 * GalaxyDiffLevels()/50);",
                        "",
                        "base_cost = round(f);",
                        "cost = round(0.01 * base_cost * time * speed);",
                        "DChange(3);",
                        "exit;"
                    ],
                    "#": 62,
                    "Type": "Top",
                    "Parent": -1,
                    "Pos.x": 460,
                    "Pos.y": 400
                },
                {
                    "Name": "",
                    "Code.Type": "Turn",
                    "Code": [
                        "DChange(6);",
                        "exit;"
                    ],
