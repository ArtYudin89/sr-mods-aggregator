                    "Pos.y": 470
                },
                {
                    "Name": "",
                    "Code.Type": "Turn",
                    "Code": [
                        "DAdd(0);"
                    ],
                    "#": 66,
                    "Type": "Top",
                    "Parent": -1,
                    "Pos.x": 280,
                    "Pos.y": 470
                },
                {
                    "Name": "",
                    "Code.Type": "Turn",
                    "Code": [
                        "if(ShipMoney(Player()) < cost) {",
                        "  DAdd(3);",
                        "}",
                        "if(ShipMoney(Player()) >= cost) {",
                        "  DAdd(4);",
                        "}",
                        "if(time == time_max) {",
                        "  DAdd(10);",
                        "}",
                        "if(time < time_max) {",
                        "  DAdd(6);",
                        "}",
                        "if(time == time_min) {",
                        "  DAdd(11);",
                        "}",
                        "if(time > time_min) {",
                        "  DAdd(7);",
                        "}",
                        "if(speed == speed_max) {",
                        "  DAdd(12);",
                        "}",
                        "if(speed < speed_max) {",
                        "  DAdd(9);",
                        "}",
                        "if(speed == speed_min) {",
                        "  DAdd(13);",
                        "}",
                        "if(speed > speed_min) {",
                        "  DAdd(8);",
                        "}",
                        "DAdd(2);"
                    ],
