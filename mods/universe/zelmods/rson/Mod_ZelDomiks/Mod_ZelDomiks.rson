                    "#": 287,
                    "Type": "Top",
                    "Parent": -1,
                    "Pos.x": 580,
                    "Pos.y": 695
                },
                {
                    "Name": "",
                    "Code.Type": "Turn",
                    "Code": [
                        "if (arrBertorQuestData['questPhase'] == 1) {",
                        "    dword player = Player();",
                        "    int itemCount = ShipItems(player);",
                        "    int flag = 0;",
                        "    for (i = 0; i < itemCount && !flag; i = i + 1) {",
                        "        dword curItem = ShipItems(player, i);",
                        "        if (ItemType(curItem) == t_UselessItem) {",
                        "            if (Name(curItem) == 'Остатки бертора серии Блазер' || Name(curItem) == 'Остатки бертора серии Келлер' || Name(curItem) == 'Остатки бертора серии Террон')",
                        "                flag = 1;",
                        "        }",
                        "    }",
                        "    DAddText('Текущий статус таков:",
                        "",
                        "');",
                        "    DAddText('Серия <color=255,0,0>Блазер</color>: ');",
                        "    if (arrBertorQuestData['SeriesResearchStatus', 0] == 0)",
                        "        DAddText('мы не знаем на какой сигнал откликается бертор этой серии.",
                        "');",
                        "    else if (arrBertorQuestData['SeriesResearchStatus', 0] == 1)",
                        "        DAddText('мы поняли, что бертор этой серии откликается на сигнал о скоплении кораблей гуманоидов. Возможно создание субпортала для этой серии.",
                        "');",
                        "    else if (arrBertorQuestData['SeriesResearchStatus', 0] == 2)",
                        "        DAddText('мы получили от вас остатки бертора и исследуем их. Возможно создание субпортала для этой серии.",
                        "');",
                        "    DAddText('Серия <color=0,0,255>Келлер</color>: ');",
                        "    if (arrBertorQuestData['SeriesResearchStatus', 1] == 0)",
                        "        DAddText('мы не знаем на какой сигнал откликается бертор этой серии.",
                        "');",
                        "    else if (arrBertorQuestData['SeriesResearchStatus', 1] == 1)",
                        "        DAddText('мы поняли, что бертор этой серии откликается на сигнал о скоплении неизученного вещества. Возможно создание субпортала для этой серии.",
                        "');",
                        "    else if (arrBertorQuestData['SeriesResearchStatus', 1] == 2)",
                        "        DAddText('мы получили от вас остатки бертора и исследуем их. Возможно создание субпортала для этой серии.",
                        "');",
                        "    DAddText('Серия <color=0,160,0>Террон</color>: ');",
                        "    if (arrBertorQuestData['SeriesResearchStatus', 2] == 0)",
                        "        DAddText('мы не знаем на какой сигнал откликается бертор этой серии.",
                        "');",
                        "    else if (arrBertorQuestData['SeriesResearchStatus', 2] == 1)",
                        "        DAddText('мы поняли, что бертор этой серии откликается на сигнал о скоплении полезных ископаемых. Возможно создание субпортала для этой серии.",
                        "');",
                        "    else if (arrBertorQuestData['SeriesResearchStatus', 2] == 2)",
                        "        DAddText('мы получили от вас остатки бертора и исследуем их. Возможно создание субпортала для этой серии.",
                        "');",
                        "    InjectAnswer('dBlackHoleForBertors', 'У меня есть Субпортал, доработайте его для заманивания берторов', 0);",
                        "    if (flag)",
                        "        InjectAnswer('dBertorQuestPhase1NewRemains', 'Я вам привез новые остатки бертора', 0);",
                        "}",
                        "else if (arrBertorQuestData['questPhase'] == 2 && arrBertorQuestData['questSubphase'] == 0) { //если еще не сдавали материал бертора",
                        "    DAddText('Правда? Замечательно, давайте посмотрим.",
                        "');",
                        "    player = Player();",
                        "    dword material = 0;",
                        "    itemCount = ShipItems(player);",
                        "    for (i = 0; i < itemCount && !material; i = i + 1) {",
                        "        curItem = ShipItems(player, i);",
                        "        if (ItemType(curItem) == t_UselessCountableItem && Name(curItem) == 'Неизвестный материал') {",
                        "            material = curItem;",
                        "        }",
                        "    }",
                        "    if (material) { //если материал есть в трюме, то берем 3 штуки (или меньше, если его меньше)",
                        "        int materialCount = ItemSize(material, 'Count');",
                        "        int materialTarget = arrBertorQuestData['bertorMaterialTarget'];",
                        "        if (materialCount > 3) {",
                        "            arrBertorQuestData['bertorMaterialReceived'] = 3;",
                        "            materialCount = materialCount - 3;",
                        "            ItemSize(material, materialCount, 'Count');",
                        "        }",
                        "        else {",
                        "            arrBertorQuestData['bertorMaterialReceived'] = materialCount;",
                        "            materialCount = 0;",
                        "            FreeItem(GetItemFromShip(player, material));",
                        "        }",
                        "        DAddText('Да, это совершенно точно что-то новое... Давайте это сюда, мы постараемся узнать что это и как оно работает.",
                        "');",
                        "        DAddText(Format('Нам понадобится провести самые разные эксперементы, а это может привести к повреждению материала. Так что привозите еще. Нам нужно всего <0> шт.",
                        "',\"<0>\",materialTarget));",
                        "        DAddText('Мы добавили вам на бортовой компьютер данные об этом материале. Попробуйте поискать на незаленных планетах, в том числе и на тех, где ранее что-то искали. К тому же, мы сообщим об этом материале всем рейнджерам, так что, быть может, вы сможете найти его у них.');",
                        "        Ether(0, '', 'Ученые Коалиции обнаружили новый редкий материал, который может существенно помочь в войне. Всем рейнджерам рекомендуется прилететь на Базу Доминаторов за подробностями.');",
                        "        arrBertorQuestData['questSubphase'] = 1;",
                        "        arrBertorQuestData['freeBertorMaterialAppearTurn'] = CurTurn() + Rnd(75, 125);",
                        "        arrBertorQuestData['recearchedBertorMaterialTurn'] = CurTurn();",
                        "    }",
                        "    else",
                        "        DAddText('Странно, но мы не нашли никакого нового материала у вас в трюме. Возможно, вы забыли его взять?');",
                        "}",
                        "else if (arrBertorQuestData['questPhase'] == 2 && arrBertorQuestData['questSubphase'] == 1) { //можем сдать больше материала",
                        "    materialTarget = arrBertorQuestData['bertorMaterialTarget'];",
                        "    int materialReceived = arrBertorQuestData['bertorMaterialReceived'];",
                        "    int materialProcentReceived = round(100.0 * materialReceived / materialTarget);",
                        "    DAddText(Format('Нам нужно собрать <0> шт. материала, мы готовы его покупать по полной цене.",
                        "',\"<0>\",materialTarget));",
                        "    DAddText(Format('На данный момент у нас есть <0> шт.",
                        "",
                        "',\"<0>\",materialReceived));",
                        "    DAddText('Благодаря полученому материалу мы смогли понять следующее:",
                        "');",
                        "    DAddText('1. Данный материал крайне редкий и очень тяжелый.",
                        "');",
                        "    DAddText('2. Материал используется берторами доминаторов.",
                        "');",
                        "    if (materialProcentReceived > 30)",
                        "        DAddText('3. Материал способен полностью исчезать без следа. При чем делает это даже при умеренных тепловых или физических нагрузках.",
                        "');",
                        "    if (materialProcentReceived > 50)",
                        "        DAddText('4. Материал способен копировать другую материю без затрат своей собственной массы или энергии.",
                        "');",
                        "    if (materialProcentReceived > 70)",
                        "        DAddText('5. При правильной стимуляции, материал способен особым, настраиваемым образом воздействовать на другую материю вокруг себя.",
                        "');",
                        "    InjectAnswer('dBertorQuestPhase2GiveMaterial', 'Я хочу помочь вашим исследованиям и сдать материал бертора', 0);",
                        "}",
                        "DAdd(40);"
                    ],
                    "#": 288,
                    "Type": "Top",
                    "Parent": -1,
                    "Pos.x": 730,
                    "Pos.y": 695
                },
                {
                    "Name": "",
                    "Code.Type": "Turn",
                    "Code": [
                        "dword player = Player();",
                        "dword art = 0;",
                        "int needToTalk = GAnswerData;",
                        "int itemCount = ShipArts(player);",
                        "for (i = 0; i < itemCount; i = i + 1) {",
                        "    dword curItem = ShipArts(player, i);",
                        "    if (ItemType(curItem) == t_ArtBlackHole) {",
                        "        art = curItem;",
                        "    }",
                        "}",
                        "",
                        "if (art) { //у игрока в инвентаре есть Субпортал",
                        "    int cost = GalaxyMoney(2);",
                        "    tempDword = art;",
                        "    DAddText(Format('Да, действительно, ваш Субпортал нам подходит. Стоимость данной процедуры <0>.",
                        "',\"<0>\",cost));",
                        "    DAddText('Для какой серии нам добавить сигнал?",
                        "');",
                        "    if (ShipMoney(player) >= cost) {",
                        "        if (arrBertorQuestData['SeriesResearchStatus', 0] > 0)",
                        "            InjectAnswer('dBlackHoleForBertorsUpgradeArt', 'Серия Блазер', 0);",
                        "        else",
                        "            InjectAnswer('dBlackHoleForBertorsUpgradeArt', 'block~' + 'Серия Блазер', 0);",
                        "        if (arrBertorQuestData['SeriesResearchStatus', 1] > 0)",
                        "            InjectAnswer('dBlackHoleForBertorsUpgradeArt', 'Серия Келлер', 1);",
                        "        else",
                        "            InjectAnswer('dBlackHoleForBertorsUpgradeArt', 'block~' + 'Серия Келлер', 1);",
                        "        if (arrBertorQuestData['SeriesResearchStatus', 2] > 0)",
                        "            InjectAnswer('dBlackHoleForBertorsUpgradeArt', 'Серия Террон', 2);",
                        "        else",
                        "            InjectAnswer('dBlackHoleForBertorsUpgradeArt', 'block~' + 'Серия Террон', 2);",
                        "    }",
                        "}",
                        "else {",
                        "    DAddText('Простите, но мы не нашли у вас Субпортал, который бы мог нам подойти.');",
                        "}",
                        "DAdd(41);"
