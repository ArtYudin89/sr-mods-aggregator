                {
                    "Name": "",
                    "Code.Type": "Turn",
                    "Code": [
                        "dword player = Player();",
                        "int itemCount = ShipItems(player);",
                        "for (i = 0; i < itemCount; i = i + 1) {",
                        "    dword curItem = ShipItems(player, i);",
                        "    if (ItemType(curItem) == t_UselessItem) {",
                        "        if (Name(curItem) == 'Остатки бертора серии Блазер') {",
                        "            arrBertorQuestData['SeriesResearchStatus', 0] = 2;",
                        "            FreeItem(GetItemFromShip(player, curItem));",
                        "            i = i - 1;",
                        "        }",
                        "        else if (Name(curItem) == 'Остатки бертора серии Келлер') {",
                        "            arrBertorQuestData['SeriesResearchStatus', 1] = 2;",
                        "            FreeItem(GetItemFromShip(player, curItem));",
                        "            i = i - 1;",
                        "        }",
                        "        else if (Name(curItem) == 'Остатки бертора серии Террон') {",
                        "            arrBertorQuestData['SeriesResearchStatus', 2] = 2;",
                        "            FreeItem(GetItemFromShip(player, curItem));",
                        "            i = i - 1;",
                        "        }",
                        "    }",
                        "}",
                        "if (arrBertorQuestData['questPhase'] == 1 && arrBertorQuestData['questSubphase'] == 0) { //если первый раз сдаем остатки бертора",
                        "    arrBertorQuestData['questSubphase'] = 1; //запускаем процесс исследования субпортала для третьей серии",
                        "    arrBertorQuestData['unlockThirdSerieTurn'] = CurTurn() + BertorQuestGetResearchDuration(1);",
                        "}",
                        "int numOfRemainUnresearchedRemains = (arrBertorQuestData['SeriesResearchStatus', 0] != 2) + (arrBertorQuestData['SeriesResearchStatus', 1] != 2) + (arrBertorQuestData['SeriesResearchStatus', 2] != 2);",
                        "tempInt = numOfRemainUnresearchedRemains;",
                        "if (numOfRemainUnresearchedRemains == 0) {",
                        "    arrBertorQuestData['bertorMaterialTarget'] = 15 + 2 * (arrDifficultLevels['Breakdown'] / 50);",
                        "    arrBertorQuestData['questSubphase'] = 0;",
                        "    arrBertorQuestData['questPhase'] = 2; //запускаем вторую фазу квеста: собираем материал бертора",
                        "    DChange(19);",
                        "}",
                        "else",
                        "    AddDialogInject('dBertorQuest', '', 'Каков теперь статус изучения?', 0);",
                        "Sound('Sound.Repair');",
                        "if(tempInt == 2) {",
                        "  DChange(33);",
                        "  exit;",
                        "}",
                        "if(tempInt == 1) {",
                        "  DChange(34);",
                        "  exit;",
                        "}"
