                {
                    "Name": "",
                    "Code.Type": "Turn",
                    "Code": [
                        "dword player = Player();",
                        "unknown arrMaterial = newarray(1);",
                        "ArrayDelete(arrMaterial, 0);",
                        "int materialCount = 0;",
                        "int itemCount = ShipItems(player);",
                        "for (i = 0; i < itemCount; i = i + 1) {",
                        "    dword curItem = ShipItems(player, i);",
                        "    if (ItemType(curItem) == t_UselessCountableItem && Name(curItem) == 'Неизвестный материал') {",
                        "        ArrayAdd(arrMaterial, curItem);",
                        "        materialCount = materialCount + ItemSize(curItem, 'Count');",
                        "    }",
                        "}",
                        "if (materialCount > 0) {",
                        "    int materialCost = ItemCost(arrMaterial[0]) / ItemSize(arrMaterial[0], 'Count');",
                        "    int materialTarget = arrBertorQuestData['bertorMaterialTarget'];",
                        "    int materialReceived = arrBertorQuestData['bertorMaterialReceived'];",
                        "    int maxPossibleDonateMaterial = min(materialTarget - materialReceived, materialCount);",
                        "    str selectedCount = CountBox('Bm.Items.2ZelDomiks_UselessBertorMaterial0_s', 'Сколько материала отдать?', 0, maxPossibleDonateMaterial, materialCost, 1);",
                        "    if (selectedCount != 'Cancel' && selectedCount > 0) {",
                        "        Sound('Sound.Sell');",
                        "        int selectedCount2 = selectedCount;",
                        "        for (i = 0; selectedCount2 > 0; i = i + 1) {",
                        "            int curMaterialCount = ItemSize(arrMaterial[i], 'Count'); //теперь отнимаем необходимое количество материала во всем корабле (неважно на сколько кучек поделено)",
                        "            if (curMaterialCount) {",
                        "                if (selectedCount2 >= curMaterialCount) { //удаляем весь стак материала и добавляем денег игроку",
                        "                    selectedCount2 = selectedCount2 - curMaterialCount;",
                        "                    ShipMoney(player, ShipMoney(player) + ItemCost(arrMaterial[i]));",
                        "                    FreeItem(GetItemFromShip(player, arrMaterial[i]));",
                        "                }",
                        "                else {",
                        "                    int newCurMaterialCount = curMaterialCount - selectedCount2;",
                        "                    selectedCount2 = 0;",
                        "                    ShipMoney(player, ShipMoney(player) + (ItemCost(arrMaterial[i]) * (curMaterialCount - newCurMaterialCount)));",
                        "                    ItemSize(arrMaterial[i], newCurMaterialCount, 'Count');",
                        "                }",
                        "            }",
                        "        }",
                        "        arrBertorQuestData['bertorMaterialReceived'] = materialReceived + selectedCount;",
                        "        if (arrBertorQuestData['bertorMaterialReceived'] < arrBertorQuestData['bertorMaterialTarget'])",
                        "            DChange(36);",
                        "        else {",
                        "            dword targetPlanet = BertorQuestPhase3FindTargetPlanet();",
                        "            arrBertorQuestData['questSubphase'] = 0;",
                        "            arrBertorQuestData['questPhase'] = 3;",
                        "            arrBertorQuestData['finalProjectEndTurn'] = CurTurn() + BertorQuestGetResearchDuration(3);",
                        "            arrBertorQuestData['nextAttackTurn'] = CurTurn() + GetBertorQuestPhase3AttackCooldown();",
                        "            arrBertorQuestData['scientistPlanetId'] = Id(targetPlanet);",
                        "            BertorQuestPhase3PrepareAttack(1);",
                        "            BertorQuestPhase3PrepareTargetStar();",
                        "            Ether(3, 'bertorQuestPhase3', Format('Помогите освободить систему <0> и прилетите на планету <1>.',\"<0>\",Name(PlanetToStar(targetPlanet)),\"<1>\",Name(targetPlanet)), targetPlanet);",
                        "            DChange(27);",
                        "        }",
                        "    }",
                        "    else",
                        "        DChange(35);",
                        "}",
                        "else",
                        "    DChange(35);"
                    ],
