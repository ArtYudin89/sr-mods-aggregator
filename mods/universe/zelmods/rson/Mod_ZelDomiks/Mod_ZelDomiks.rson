                    "Pos.y": 720
                },
                {
                    "Name": "",
                    "Code.Type": "Turn",
                    "Code": [
                        "// ZelDomiks_RangerMaterialInfo int 1 - количество материала",
                        "// ZelDomiks_RangerMaterialInfo int 2 - ходов до попытки получить материал",
                        "// ZelDomiks_RangerMaterialInfo int 3 - множитель цены (в процентах) у этого рейнджера",
                        "// ZelDomiks_RangerMaterialInfo str 1 - процент вероятности спавна материала у этого рейнджера",
                        "",
                        "dword talkShip = GetTalkShip();",
                        "dword player = Player();",
                        "int materialCount = ShipCustomShipInfoData(talkShip, 'ZelDomiks_RangerMaterialInfo', 1);",
                        "int materialCost = GetBertorMaterialCost() * ShipCustomShipInfoData(talkShip, 'ZelDomiks_RangerMaterialInfo', 3) / 100;",
                        "if (materialCount > 0) {",
                        "    DAddText(Format('Да, у меня есть <0> шт.",
                        "',\"<0>\",materialCount));",
                        "    DAddText(Format('Каждую штуку весом в 7 тонн готов продать за <0> cr.",
                        "',\"<0>\",materialCost));",
                        "    InjectAnswer('dBuyMaterialFromRanger', 'Хорошо, я согласен', 0);",
                        "}",
                        "else {",
                        "    if (RelationToShip(talkShip, player) > 80)",
                        "        DAddText('Извини, но у меня нет такого материала.",
                        "');",
                        "    else",
                        "        DAddText('У меня нет такого материала.",
                        "');",
                        "}",
                        "DAdd(50);"
                    ],
