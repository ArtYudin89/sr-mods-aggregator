                        "arrResearchTarget = newarray(10);",
                        "int turns = GetIntByGeomLaw(157, (arrDifficultLevels['Science'] / 50) - 1, 1.2);",
                        "for (i = 0; i < 10; i = i + 1) {",
                        "    arrResearchTarget[i] = turns;",
                        "    if (isScriptTest)",
                        "        arrResearchTarget[i] = turns / 10;",
                        "    turns = 1.4 * turns;",
                        "}",
                        "",
                        "int originalDomikEqPower = min(200, domikEq); //максимум 200",
                        "if (domikEq > 200) //уровень экипировки влияет и с 200 до 350, просто все меньше",
                        "    originalDomikEqPower = originalDomikEqPower + (0.9 * min(50, (domikEq - 200))); //максимум плюс 45",
                        "if (domikEq > 250)",
                        "    originalDomikEqPower = originalDomikEqPower + (0.7 * min(50, (domikEq - 250))); //максимум плюс 35",
                        "if (domikEq > 300)",
                        "    originalDomikEqPower = originalDomikEqPower + (0.4 * min(50, (domikEq - 250))); //максимум плюс 20",
                        "originalDomikEqPower = PortionInDiapason(originalDomikEqPower, 50, 300, 50, 350);",
                        "originalDomikEqPower = originalDomikEqPower * 2; //экипировка в два раза важнее, чем другие параметры",
                        "int originalDomikSpPower = PortionInDiapason(domikSp, 50, 250, 50, 350);",
                        "int originalDomikActPower = PortionInDiapason(domikAct, 50, 300, 50, 350);",
                        "int originalDomikSumPower = originalDomikEqPower + originalDomikSpPower + originalDomikActPower; //минимум 200, максимум 1400",
                        "int NisperMaxUpgrades = PortionInDiapason(originalDomikSumPower, 200, 1400, 25, 80);",
                        "int NisperMaxUpgradesWithoutBonus = NisperMaxUpgrades - (NisperMaxUpgrades / 10);",
                        "arrLevelsAddUpgrades = newarray(11);",
                        "arrLevelsAddUpgrades[0] =  0;",
                        "arrLevelsAddUpgrades[1] =  4; //сколько базово очков за переход НА i-тый уровень",
                        "for (i = 2; i <= 10; i = i + 1)",
                        "    arrLevelsAddUpgrades[i] = i - 1;",
                        "int delta = NisperMaxUpgradesWithoutBonus - 49; //дальше распределяем очки сверху-вниз (более высокие уровни приоритетнее получают очки)",
                        "if (delta > 0) { // увеличиваем очки",
                        "    for (i = 10; delta > 0;) {",
                        "        arrLevelsAddUpgrades[i] = arrLevelsAddUpgrades[i] + 1;",
                        "        delta = delta - 1;",
                        "        i = i - 1;",
                        "        if (i < 1)",
                        "            i = 10;",
                        "    }",
                        "}",
                        "else if (delta < 0) { //уменьшаем очки",
                        "    for (i = 10; delta < 0;) {",
                        "        if (i == 1 || i > 7) {",
                        "            if (arrLevelsAddUpgrades[i] > 3) {",
                        "                arrLevelsAddUpgrades[i] = arrLevelsAddUpgrades[i] - 1;",
                        "                delta = delta + 1;",
                        "            }",
                        "        }",
                        "        else if (i > 4) {",
                        "            if (arrLevelsAddUpgrades[i] > 2) {",
                        "                arrLevelsAddUpgrades[i] = arrLevelsAddUpgrades[i] - 1;",
                        "                delta = delta + 1;",
                        "            }",
                        "        }",
                        "        else {",
                        "            if (arrLevelsAddUpgrades[i] > 1) {",
                        "                arrLevelsAddUpgrades[i] = arrLevelsAddUpgrades[i] - 1;",
                        "                delta = delta + 1;",
                        "            }",
                        "        }",
                        "        i = i - 1;",
                        "        if (i < 1)",
                        "            i = 10;",
                        "    }",
                        "}",
