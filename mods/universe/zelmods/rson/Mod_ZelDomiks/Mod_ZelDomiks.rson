                        "ArrayAdd(arrDifficultLevels, domikEq, 'DomikEq');",
                        "ArrayAdd(arrDifficultLevels, domikAct, 'DomikAct');",
                        "ArrayAdd(arrDifficultLevels, domikSp, 'DomikSp');",
