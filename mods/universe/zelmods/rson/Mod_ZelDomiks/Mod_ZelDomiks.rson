                    "Pos.x": 640
                },
                {
                    "Name": "",
                    "Code.Type": "Turn",
                    "Code": [
                        "FactoryAlgorithmClearData(CurShip);",
                        "ChangeState(10);",
                        "exit;"
                    ],
                    "#": 233,
                    "Type": "Top",
                    "Parent": -1,
                    "Pos.x": 720
                },
                {
                    "Name": "",
                    "Code.Type": "Turn",
                    "Code": [
                        "// Data 0 - номер следующей системы",
                        "// Data 1 - Id целевой планеты",
                        "// Data 2 - нужно ли самоуничтожиться",
                        "",
                        "StdAlgorithmEveryTurn(CurShip);",
                        "dword shipStar = ShipStar(CurShip);",
                        "if (GetShipHangar(CurShip)) {",
                        "    if (GetData(2, CurShip) == 1)",
                        "        ShipDestroy(CurShip);",
                        "    else if (GetShipHangar(CurShip) != IdToPlanet(GetData(1, CurShip))) { //взлетаем",
                        "        StdAlgorithmFullRepair(CurShip);",
                        "        OrderTakeOff(CurShip);",
                        "    }",
                        "    else { //или переходим в режим АФК, так как мы достигли цели",
                        "        ChangeState(11);",
                        "    }",
                        "}",
                        "else if (ShipInNormalSpace(CurShip)) {",
                        "    dword nearHangar;",
                        "    if (GetData(2, CurShip) == 1) {",
                        "        nearHangar = GetShipNearHangar(CurShip);",
                        "        if (nearHangar)",
                        "            OrderLanding(CurShip, nearHangar);",
                        "    }",
                        "    else {",
                        "        dword nextStar = GalaxyStar(GetData(0, CurShip));",
                        "        if (shipStar == nextStar) {",
                        "            dword targetPlanet = IdToPlanet(GetData(1, CurShip));",
                        "            dword targetStar = PlanetToStar(targetPlanet);",
                        "            if (targetStar != shipStar) { //если не достигли финальной системы",
                        "                int radius = ShipJump(CurShip);",
                        "                if (GetArrRouteFromStarToStar(radius, shipStar, targetStar, 0) > 1) { //если все в порядке, то просто ставим новую систему в цель",
                        "                    unknown arrRouteFromStarToStar;",
                        "                    copy(arrRouteFromStarToStar, tempArr);",
                        "                    SetData(Id(arrRouteFromStarToStar[1]) - 1, 0, CurShip);",
                        "                    ChangeState(10);",
                        "                }",
                        "                else { //если прежняя цель недостижима, то меняем на новую (или летим на ближайшую планету и самоуничтожаемся, если новой цели не существует)",
                        "                    targetPlanet = GetNewFactoryTargetPlanet(radius, ShipStar(CurShip));",
                        "                    if (targetPlanet != 0) {",
                        "                        SetData(Id(targetPlanet), 1, CurShip);",
                        "                        ChangeState(10);",
                        "                    }",
                        "                    else {",
                        "                        SetData(1, 2, CurShip);",
                        "                        nearHangar = GetShipNearHangar(CurShip);",
                        "                        if (nearHangar)",
                        "                            OrderLanding(CurShip, nearHangar);",
                        "                    }",
                        "                }",
                        "            }",
                        "            else //если достигли финальной системы, то просто садимся на целевую планету",
                        "                OrderLanding(CurShip, targetPlanet);",
                        "        }",
                        "        else { //еще не достигли следующей системы",
                        "            if (ShipFuel(CurShip) < round(sqrt(Dist2Star(shipStar, nextStar)))) {",
                        "                dword hangar = GetShipNearHangar(CurShip);",
                        "                if (hangar)",
                        "                    OrderLanding(CurShip, hangar);",
                        "            }",
                        "            else {",
                        "                OrderJump(CurShip, nextStar);",
                        "            }",
                        "        }",
                        "    }",
                        "}"
                    ],
                    "#": 234,
                    "Type": "Top",
                    "Parent": -1,
                    "Pos.x": 800
                },
                {
                    "Name": "",
                    "Code.Type": "Turn",
                    "Code": [
                        "dword shipPlanet = GetShipPlanet(CurShip);",
                        "str planetInfoName = ShipCustomShipInfoTextData(CurShip, 'ZelDomiks_FactoryInfo', 1);",
                        "if (planetInfoName == '-----') { //если инфошка стандартная, то выставляем имя планеты в инфошку",
                        "    ShipCustomShipInfoTextData(CurShip, 'ZelDomiks_FactoryInfo', 1, Name(shipPlanet));",
                        "    planetInfoName = Name(shipPlanet);",
                        "}",
                        "if (IsStarOwnerCoal(ShipStar(CurShip))) { //если система коалиционная, то можем менять имя планеты",
                        "    if (!IsShipNisperFriend(Player())) //если игрок не является другом, то не показываем на каких планетах есть фабрики",
                        "        SetName(shipPlanet, planetInfoName);",
                        "    else",
                        "        SetName(shipPlanet, planetInfoName + ' <color=255,153,0>(Н)</color>');",
                        "}",
                        "else { //иначе самоуничтожаемся",
                        "    ShipDestroy(CurShip);",
                        "}"
                    ],
                    "#": 235,
                    "Type": "Top",
                    "Parent": -1,
                    "Pos.x": 880
                },
                {
                    "Name": "",
                    "Code.Type": "Turn",
                    "Code": [
                        "// Data 0 - ходов до новой точки патруля",
                        "// Data 1 - маркер того, а нужно ли доминатору сесть на планету и починиться",
                        "// Data 2 - номер системы (id -1), в которую стремится попасть домик",
                        "// Data 3 - Id корабля, который нужно сопровождать (или 0, если такого нет)",
                        "",
                        "if (ShipInHyperSpace(CurShip)) exit;",
                        "",
                        "if (ShipInNormalSpace(CurShip)) { //основной алгоритм, мы в космосе",
                        "    dword enemy = ShipGetBad(CurShip);",
                        "    if (enemy) { //в системе есть враг, идем в воюющий стейт",
                        "        SetData(Id(ShipStar(CurShip)) - 1, 2, CurShip); //сбрасываем целевую систему на текущую. Полет отменяется",
                        "        SetData(0, 3, CurShip); //и больше не будем никого сопровождать",
                        "        ChangeState('domikBattle');",
                        "    }",
                        "    else {",
                        "        dword targetStar = GalaxyStar(GetData(2, CurShip));",
                        "        if (targetStar != ShipStar(CurShip)) { //смотрим нужно ли перейти в другую систему",
                        "            OrderJump(CurShip, targetStar); //прыгаем",
                        "            SetData(0, 0, CurShip);",
                        "        }",
                        "        else {",
                        "            dword escortRequestorId = GetData(3, CurShip);",
                        "            if (GetData(1, CurShip)) { //нужна починка",
                        "                dword hangar = GetShipNearHangar(CurShip); //ищем ближайшую дружелюбную станцию или планету",
                        "                if (hangar) {",
                        "                    OrderLanding(CurShip, hangar);",
                        "                    SetData(0, 0, CurShip);",
                        "                }",
                        "            }",
                        "            else { //обычный алгоритм патрулирования",
                        "                int isNeedToEscortSomeone = 0;",
                        "                dword escortRequestor = IdToShip(escortRequestorId);",
                        "                if (escortRequestorId && escortRequestor) { //нужно кого-то сопровождать",
                        "                    if (ShipInNormalSpace(escortRequestor) && Dist(escortRequestor, targetStar) > (PlanetOrbitRadius(StarPlanets(ShipStar(CurShip), 0)) + 150)) {",
                        "                        isNeedToEscortSomeone = 1;",
                        "                    }",
                        "                }",
                        "                if (isNeedToEscortSomeone) {",
                        "                    OrderFollowShip(CurShip, escortRequestor, 1);",
                        "                    SetData(0, 0, CurShip);",
                        "                }",
                        "                else {",
                        "                    int turns = GetData(0, CurShip);",
                        "                    if (turns < 1) {",
                        "                        dword star = ShipStar(CurShip);",
                        "                        float ugol = 0.01 * Rnd(0, 200);",
                        "                        int radius = PlanetOrbitRadius(StarPlanets(star, 0)) + Rnd(-50, 100);",
                        "                        int x = round(sin(ugol * pi) * radius);",
                        "                        int y = -1 * round(cos(ugol * pi) * radius);",
                        "                        OrderMove(CurShip, x, y);",
                        "                        int distance = round(sqrt(sqr(abs(CoordX(CurShip) - x)) + sqr(abs(CoordY(CurShip) - y))));",
                        "                        int shipSpeed = ShipSpeed(CurShip);",
                        "                        turns = distance / shipSpeed + (distance % shipSpeed != 0);",
                        "                    }",
                        "                    SetData(turns - 1, 0, CurShip);",
                        "                }",
                        "            }",
                        "        }",
                        "        SetData(0, 3, CurShip);",
                        "    }",
                        "}",
                        "else if (GetShipHangar(CurShip)) { //если мы в ангаре станции или планеты",
                        "    StdAlgorithmFullRepair(CurShip);",
                        "    OrderTakeOff(CurShip);",
                        "    SetData(0, 0, CurShip);",
                        "}"
                    ],
                    "#": 236,
                    "Type": "Top",
                    "Parent": -1,
                    "Pos.x": 1040
                },
                {
                    "Name": "",
                    "Code.Type": "Turn",
                    "Code": [
                        "if(ShipInHyperSpace(CurShip)) exit;",
                        "",
                        "if (ShipInNormalSpace(CurShip)) {",
                        "    dword enemy = ShipGetBad(CurShip);",
                        "    if (enemy) {",
                        "        OrderFollowShip(CurShip, enemy, 1);",
                        "    }",
                        "    else { //врага нет, идем в обычный стэйт",
                        "        SetData(0, 0, CurShip);",
                        "        SetData(IsShipNeedRepair(CurShip), 1, CurShip); //после боя ставим маркер того, а нужно ли починиться",
                        "        ChangeState('domikPatrol');",
                        "    }",
                        "}"
                    ],
                    "#": 237,
                    "Type": "Top",
