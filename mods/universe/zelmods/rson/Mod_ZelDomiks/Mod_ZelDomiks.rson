                        "KligAlgorithmClearData(CurShip);",
                        "OrderLock(CurShip, 1);",
                        "ChangeState(18);",
                        "exit;"
                    ],
                    "#": 241,
                    "Type": "Top",
                    "Parent": -1,
                    "Pos.x": 1440
                },
                {
                    "Name": "",
                    "Code.Type": "Turn",
                    "Code": [
                        "// Data 0 - ходов до новой точки патруля",
                        "// Data 1 - id бертора",
                        "",
                        "if (ShipInHyperSpace(CurShip)) exit;",
                        "",
                        "if (ShipInNormalSpace(CurShip)) { //основной алгоритм, мы в космосе",
                        "    dword enemy = ShipGetBad(CurShip);",
                        "    if (enemy) { //в системе есть враг, идем в воюющий стейт",
                        "        ChangeState('kligBattle');",
                        "    }",
                        "    else {",
                        "        dword bertor = IdToShip(GetData(1, CurShip));",
                        "        if (bertor) {",
                        "            dword bertorStar = ShipStar(bertor);",
                        "            dword kligStar = ShipStar(CurShip);",
                        "            if (bertorStar != kligStar) {",
                        "                OrderJump(CurShip, bertorStar);",
                        "                SetData(0, 0, CurShip);",
                        "            }",
                        "            else if (ShipInNormalSpace(bertor) && Dist(bertor, bertorStar) > (PlanetOrbitRadius(StarPlanets(ShipStar(CurShip), 0)) + 150)) {",
                        "                OrderFollowShip(CurShip, bertor, 1); //если бертор не у звезды - летим за бертором",
                        "                SetData(0, 0, CurShip);",
                        "            }",
                        "            else { //обычный алгоритм патрулирования",
                        "                int turns = GetData(0, CurShip);",
                        "                if (turns < 1) {",
                        "                    dword star = ShipStar(CurShip);",
                        "                    float ugol = 0.01 * Rnd(0, 200);",
                        "                    int radius = PlanetOrbitRadius(StarPlanets(star, 0)) + Rnd(-50, 100);",
                        "                    int x = round(sin(ugol * pi) * radius);",
                        "                    int y = -1 * round(cos(ugol * pi) * radius);",
                        "                    OrderMove(CurShip, x, y);",
                        "                    int distance = round(sqrt(sqr(abs(CoordX(CurShip) - x)) + sqr(abs(CoordY(CurShip) - y))));",
                        "                    int shipSpeed = ShipSpeed(CurShip);",
                        "                    turns = distance / shipSpeed + (distance % shipSpeed != 0);",
                        "                }",
                        "                SetData(turns - 1, 0, CurShip);",
                        "            }",
                        "        }",
                        "        else { //если бертор сдох, то меняем клигу группу на обычного домика",
                        "            if (ShipFindCustomShipInfoByType(CurShip, 'ZelDomiks_KligInfo') > -1)",
                        "                ShipDeleteCustomShipInfo(CurShip, 'ZelDomiks_KligInfo');",
                        "            ShipJoin(gDomiks, CurShip);",
                        "        }",
                        "    }",
                        "}",
                        "else if (GetShipHangar(CurShip)) { //если мы в ангаре станции или планеты",
                        "    StdAlgorithmFullRepair(CurShip);",
                        "    OrderTakeOff(CurShip);",
                        "    SetData(0, 0, CurShip);",
                        "}"
                    ],
                    "#": 242,
                    "Type": "Top",
                    "Parent": -1,
                    "Pos.x": 1520
                },
                {
                    "Name": "",
                    "Code.Type": "Turn",
                    "Code": [
                        "if (ShipInHyperSpace(CurShip)) exit;",
                        "",
                        "if (ShipInNormalSpace(CurShip)) {",
                        "    dword enemy = ShipGetBad(CurShip);",
                        "    if (enemy) {",
                        "        if (ChanceToWin(CurShip, enemy, 1) < 0.2 && Dist(CurShip, enemy) <= 0.66 * ShipSpeed(CurShip)) {",
                        "            OrderForsage(CurShip, 1);",
                        "            OrderFollowShip(CurShip, enemy, 3);",
                        "            dword CRM = GetCRM();",
                        "            ShipAddCustomShipInfo(CurShip, 'ZelDomiks_KligKamikaze', 'NoShow', Id(enemy), Id(CRM));",
                        "        }",
                        "        else {",
                        "            OrderForsage(CurShip, 0);",
                        "            OrderFollowShip(CurShip, enemy, 1);",
                        "        }",
                        "    }",
                        "    else { //врага нет, идем в обычный стэйт",
                        "        SetData(0, 0, CurShip);",
                        "        OrderForsage(CurShip, 0);",
                        "        ChangeState('kligPatrol');",
                        "    }",
                        "}"
                    ],
                    "#": 243,
                    "Type": "Top",
                    "Parent": -1,
                    "Pos.x": 1600
                },
                {
                    "Name": "",
                    "Code.Type": "Turn",
                    "Code": [
                        "//Стэйт для бертора и клигов, которые должны стремиться в черную дыру",
                        "// Data 0 - подтип домика (6 или 7)",
                        "",
                        "dword blackHole = IdToHole(arrBlackHoleForBertorsData['BlackHoleId']);",
                        "dword targetBertor = IdToShip(arrBlackHoleForBertorsData['TargetBertorId']);",
                        "int turnOfEndSignal = arrBlackHoleForBertorsData['TurnOfEndSignal'];",
                        "if (targetBertor && CurTurn() < turnOfEndSignal) {",
                        "    if (CurShip == targetBertor) {",
                        "        if (ShipInNormalSpace(CurShip)) {",
                        "            OrderLock(CurShip, 1);",
                        "            OrderJumpHole(CurShip, blackHole);",
                        "        }",
                        "        else if (ShipInHole(CurShip)) {",
                        "            OrderLock(CurShip, 0);",
                        "            ShipOrderData1(CurShip, 2);",
                        "        }",
                        "    }",
                        "    else {",
                        "        if (ShipInHole(targetBertor)) {",
                        "            OrderLock(CurShip, 1);",
                        "            OrderJumpHole(CurShip, blackHole);",
                        "        }",
                        "        else if (ShipInHole(CurShip)) {",
                        "            OrderLock(CurShip, 0);",
                        "            ShipOrderData1(CurShip, 2);",
                        "        }",
                        "    }",
                        "}",
                        "else { //если из-за чего-то целевой бертор сдох или время истекло, то все отменяется",
                        "    arrBlackHoleForBertorsData['TargetBertorId'] = 0;",
                        "    BlackHoleForBertorsResetGroup();",
                        "}"
                    ],
                    "#": 244,
                    "Type": "Top",
                    "Parent": -1,
                    "Pos.x": 1680
                },
                {
                    "Name": "",
                    "Code.Type": "Turn",
                    "Code": [
                        "// Data 0 - Id системы в которой готовимся к прыжку",
                        "// Data 1 - когда должны начать атаку",
                        "// Data 2 - маркер того, является ли корабль домиком",
                        "",
                        "OrderLock(CurShip, 1);",
                        "if (ShipInHyperSpace(CurShip)) exit;",
                        "",
                        "if (ShipInNormalSpace(CurShip)) {",
                        "    dword shipStar = ShipStar(CurShip);",
                        "    dword prepareStar = GalaxyStar(GetData(0, CurShip));",
                        "    dword targetStar = PlanetToStar(IdToPlanet(arrBertorQuestData['scientistPlanetId']));",
                        "    if (arrBertorQuestData['questSubphase'] > 1) {",
                        "        OrderLock(CurShip, 0);",
                        "        if (GetData(2, CurShip) == 0) {",
                        "            ShipOut(CurShip);",
                        "            exit;",
                        "        }",
                        "        else {",
                        "            ShipJoin(gDomiks, CurShip);",
                        "            exit;",
                        "        }",
                        "    }",
                        "    if (CurTurn() > GetData(1, CurShip)) {",
                        "        if (shipStar != targetStar)",
                        "            OrderJump(CurShip, targetStar);",
                        "        else {",
                        "            OrderLock(CurShip, 0);",
                        "            if (GetData(2, CurShip) == 0) {",
                        "                ShipOut(CurShip);",
                        "                exit;",
                        "            }",
                        "            else {",
                        "                ShipJoin(gDomiks, CurShip);",
                        "                exit;",
                        "            }",
                        "        }",
                        "    }",
                        "    else if (shipStar != prepareStar)",
                        "        OrderJump(CurShip, prepareStar);",
                        "    else {",
                        "        float starAngle = 0.01 * PortionInDiapason(StarAngle(prepareStar, targetStar), 0, 360, 0, 200);",
                        "        int radius = PlanetOrbitRadius(StarPlanets(shipStar, StarPlanets(shipStar) - 1));",
                        "        int x = round(sin(starAngle * pi) * radius);",
                        "        int y = -1 * round(cos(starAngle * pi) * radius);",
                        "        float angle = 0.01 * Rnd(0, 200);",
                        "        radius = Rnd(0, 200);",
                        "        x = x + round(sin(angle * pi) * radius);",
                        "        y = y + (-1 * round(cos(angle * pi) * radius));",
                        "        OrderMove(CurShip, x, y);",
                        "    }",
                        "}",
                        "else if (GetShipHangar(CurShip)) { //если мы в ангаре станции или планеты",
                        "    StdAlgorithmFullRepair(CurShip);",
                        "    OrderTakeOff(CurShip);",
                        "}"
                    ],
