                        "DAddText(Format('",
                        "Так, уходим от темы... В общем, нам нужен один ученый с планеты <0>, которая находится в системе <1>.",
                        "',\"<0>\",Name(targetPlanet),\"<1>\",Name(targetStar)));",
                        "DAddText('К сожалению, планета находится под контролем доминаторов. Совет Коалиции решил, что нам нужно отбить эту систему любой ценой. Помогите нам и привезите этого ученого к нам сюда..",
                        "');",
                        "DAdd(52);"
                    ],
                    "#": 298,
                    "Type": "Top",
                    "Parent": -1,
                    "Pos.x": 430,
                    "Pos.y": 720
                },
                {
                    "Name": "",
