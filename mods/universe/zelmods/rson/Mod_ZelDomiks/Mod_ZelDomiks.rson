                        "DAddText(Format('Вы можете улучшить <0> раз следующие параметры:",
                        "",
                        "',\"<0>\",GetPlayerUpgradesRemain()));",
                        "DAddText(Format('Уровень активности оценивается в <0>/20 балов:",
                        "',\"<0>\",upgradeActive+arrPlayerUpgrades[0]));",
                        "DAddText(Format('<0>",
                        "",
                        "',\"<0>\",GetUpgradeLine(20, upgradeActive, arrPlayerUpgrades[0], 0, 0)));",
                        "DAddText(Format('Уровень экипировки оценивается в <0>/40 балов:",
                        "',\"<0>\",upgradePower+arrPlayerUpgrades[1]));",
                        "DAddText(Format('<0>",
                        "",
                        "',\"<0>\",GetUpgradeLine(40, upgradePower, arrPlayerUpgrades[1], 0, 0)));",
                        "DAddText(Format('Уровень количества оценивается в <0>/20 балов:",
                        "',\"<0>\",upgradeSpawn+arrPlayerUpgrades[2]));",
                        "DAddText(Format('<0>",
                        "",
                        "',\"<0>\",GetUpgradeLine(20, upgradeSpawn, arrPlayerUpgrades[2], 0, 0)));",
                        "if (GetPlayerUpgradesRemain() == 0)",
                        "    InjectAnswer('dUpgradesSwitchSet', 'Применить изменения', 0);",
                        "else",
                        "    InjectAnswer('dUpgradesSwitchSet', 'block~'+'Применить изменения', 0);",
                        "if (upgradeActive + arrPlayerUpgrades[0] < 20 && GetPlayerUpgradesRemain() > 0)",
                        "    InjectAnswer('dUpgradesSwitch', 'Добавить пункт к параметру активности', 1);",
                        "else",
                        "    InjectAnswer('dUpgradesSwitch', 'block~'+'Добавить пункт к параметру активности', 1);",
                        "if (arrPlayerUpgrades[0] > 0)",
                        "    InjectAnswer('dUpgradesSwitch', 'Убавить пункт от параметра активности', 4);",
                        "else",
                        "    InjectAnswer('dUpgradesSwitch', 'block~'+'Убавить пункт от параметра активности', 4);",
                        "if (upgradePower + arrPlayerUpgrades[1] < 40 && GetPlayerUpgradesRemain() > 0)",
                        "    InjectAnswer('dUpgradesSwitch', 'Добавить пункт к параметру экипировки', 2);",
                        "else",
                        "    InjectAnswer('dUpgradesSwitch', 'block~'+'Добавить пункт к параметру экипировки', 2);",
                        "if (arrPlayerUpgrades[1] > 0)",
                        "    InjectAnswer('dUpgradesSwitch', 'Убавить пункт от параметра экипировки', 5);",
                        "else",
                        "    InjectAnswer('dUpgradesSwitch', 'block~'+'Убавить пункт от параметра экипировки', 5);",
                        "if (upgradeSpawn + arrPlayerUpgrades[2] < 20 && GetPlayerUpgradesRemain() > 0)",
