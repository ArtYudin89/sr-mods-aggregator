                        "ArrayAdd(arrBertorQuestData, 0, 'finalProjectEndTurn');",
                        "ArrayAdd(arrBertorQuestData, 0, 'scientistPlanetId');",
                        "ArrayAdd(arrBertorQuestData, 0, 'scientistCapsulaId');",
                        "ArrayAdd(arrBertorQuestData, 0, 'nextAttackTurn');",
                        "ArrayAdd(arrBertorQuestData, unknownVar, 'SeriesResearchStatus');",
                        "arrBertorQuestData['SeriesResearchStatus'] = newarray(1);",
                        "ArrayDelete(arrBertorQuestData['SeriesResearchStatus'], 0);",
                        "ArrayAdd(arrBertorQuestData['SeriesResearchStatus'], 1); //0 = нельзя выдать субпортал серии, 1 = можно, 2 = сданы ошметки данной серии",
                        "ArrayAdd(arrBertorQuestData['SeriesResearchStatus'], 1);",
                        "ArrayAdd(arrBertorQuestData['SeriesResearchStatus'], 1);",
                        "arrBertorQuestData['SeriesResearchStatus', rndSerie] = 0; //одной случайной серии в начале партии убираем возможность выдавать субпортал",
                        "",
                        "ArrayDelete(arrPlayerBertorHullData, 0);",
                        "ArrayAdd(arrPlayerBertorHullData, 0, 'hullLevel');",
                        "ArrayAdd(arrPlayerBertorHullData, 0, 'hullId');",
                        "ArrayAdd(arrPlayerBertorHullData, 0, 'upgradeTurn');",
                        "ArrayAdd(arrPlayerBertorHullData, 0, 'upgradeStatus'); //0 - не готово; 1 - началось исследование; 2 - исследование готово",
                        "ArrayAdd(arrPlayerBertorHullData, unknownVar, 'upgradeResourceNeed');",
                        "arrPlayerBertorHullData['upgradeResourceNeed'] = newarray(1);",
                        "ArrayDelete(arrPlayerBertorHullData['upgradeResourceNeed'], 0);",
                        "ArrayAdd(arrPlayerBertorHullData['upgradeResourceNeed'], 0, 'money');",
                        "ArrayAdd(arrPlayerBertorHullData['upgradeResourceNeed'], 0, 'nod');",
                        "ArrayAdd(arrPlayerBertorHullData['upgradeResourceNeed'], 0, 'material');",
                        "",
                        "ArrayDelete(arrActiveMods, 0); i = 0;",
                        "if(IsScriptActive('Mod_EvoArmada')) i = 1;",
                        "ArrayAdd(arrActiveMods, i, 'EvoArmada'); i = 0;",
                        "if(IsScriptActive('Mod_ShuDomiks')) i = 1;",
                        "ArrayAdd(arrActiveMods, i, 'ShuDomiks'); i = 0;",
                        "if(BlockExist('ShipInfo.AddInfo.CustomInfos.ExpPanel_infos')) { i = 1; ExpPanelStart(); }",
                        "ArrayAdd(arrActiveMods, i, 'ExpPanel'); i = 0;",
                        "function GetStarNisperPoints(star, usePriority) { //возвращает приоритет защищать/атаковать заданную систему. При usePriority = 1 будет также учитывать приоритеты систем",
                        "    float starPointsEnemys = 0;",
                        "    float starPointsOwners = 0;",
                        "    float starPointsFriends = 0;",
                        "    float starPoints = 0;",
                        "    dword selectShip;",
                        "    int countShipsStar = StarShips(star);",
                        "    int starSerie = StarSeries(star);",
                        "    str starCustomOwner = StarCustomFaction(star);",
                        "    str shipCustomOwner;",
                        "    if (IsStarOwnerCoal(star)) { //система коалиции",
                        "        for (i = 0; i < countShipsStar; i = i + 1) {",
                        "            selectShip = StarShips(star, i);",
                        "            if (ShipInNormalSpace(selectShip)) {",
                        "                if (!IsShipNisperEnemy(selectShip) && IsShipOwnerCoal(selectShip))",
                        "                    starPointsOwners = starPointsOwners + ShipStrengthInBestRanger(selectShip);",
                        "                else if (IsShipNisperEnemy(selectShip) && IsShipOwnerPirate(selectShip))",
                        "                    starPointsEnemys = starPointsEnemys + 0.8 * ShipStrengthInBestRanger(selectShip);",
                        "                else if (IsShipNisperEnemy(selectShip))",
                        "                    starPointsEnemys = starPointsEnemys + ShipStrengthInBestRanger(selectShip);",
                        "            }",
                        "        }",
                        "        if (starPointsOwners > 1.6 * starPointsEnemys) { //если коалы явно сильнее врагов - сильно снижаем приоритет системы",
                        "            starPoints = starPointsEnemys - starPointsOwners;",
                        "            starPoints = starPoints * 3;",
                        "        } else",
                        "            starPoints = starPointsEnemys - starPointsOwners;",
                        "    } else if (IsStarOwnerPirate(star)) { //система пиратов",
                        "        for (i = 0; i < countShipsStar; i = i + 1) {",
                        "            selectShip = StarShips(star, i);",
                        "            if (ShipInNormalSpace(selectShip)) {",
                        "                if (IsShipNisperEnemy(selectShip) && IsShipOwnerPirate(selectShip))",
                        "                    starPointsOwners = starPointsOwners + ShipStrengthInBestRanger(selectShip);",
                        "                else if (!IsShipNisperEnemy(selectShip) && IsShipOwnerCoal(selectShip))",
                        "                    starPointsFriends = starPointsFriends + ShipStrengthInBestRanger(selectShip);",
                        "                else if (IsShipNisperEnemy(selectShip))",
                        "                    starPointsEnemys = starPointsEnemys + ShipStrengthInBestRanger(selectShip);",
                        "            }",
                        "        }",
                        "        if (starPointsEnemys > 1.2 * (starPointsOwners + starPointsFriends)) //если атакующие сильнее пиратов и коалов вместе - система считается вражеской без пиратов (сдохнут или сбегут)",
                        "            starPoints = starPointsFriends - starPointsEnemys;",
                        "        else if (starPointsFriends > 1.6 * (starPointsEnemys + starPointsOwners)) { //если коалы явно сильнее всех врагов - делаем приоритет системы отрицательным",
                        "            starPoints = starPointsOwners + starPointsEnemys - starPointsFriends;",
                        "            starPoints = starPoints * 3;",
                        "        } else { //иначе считаем просто, но немного снижаем внимание к системе, так как это пиратская",
                        "            starPoints = starPointsFriends + starPointsEnemys - starPointsOwners;",
                        "            starPoints = 0.8 * starPoints;",
                        "        }",
                        "    } else if (IsStarOwnerDomik(star)) { //система доминаторов",
                        "        for (i = 0; i < countShipsStar; i = i + 1) {",
                        "            selectShip = StarShips(star, i);",
                        "            if (ShipInNormalSpace(selectShip)) {",
                        "                if (IsShipOwnerDomik(selectShip) == starSerie + 1)",
                        "                    starPointsOwners = starPointsOwners + ShipStrengthInBestRanger(selectShip);",
                        "                else if (!IsShipNisperEnemy(selectShip))",
                        "                    starPointsFriends = starPointsFriends + ShipStrengthInBestRanger(selectShip);",
                        "                else if (IsShipNisperEnemy(selectShip))",
                        "                    starPointsEnemys = starPointsEnemys + ShipStrengthInBestRanger(selectShip);",
                        "            }",
                        "        }",
                        "        if (starPointsFriends > 1.6 * (starPointsEnemys + starPointsOwners)) { //если коалы явно сильнее врагов - делаем приоритет системы отрицательным",
                        "            starPoints = starPointsOwners + starPointsEnemys - starPointsFriends;",
                        "            starPoints = starPoints * 3;",
                        "        } else if (starPointsEnemys > 1.6 * starPointsOwners) //если враги явно сильнее домиков - считаем эту систему вражеской, а домиков союзниками",
                        "            starPoints = starPointsOwners + starPointsFriends - starPointsEnemys;",
                        "        else if (starPointsOwners > 5 * starPointsFriends) //если коалы намного слабее домиков, то не считаем коалов (быстро сольются)",
                        "            starPoints = starPointsEnemys - starPointsOwners;",
                        "        else",
                        "            starPoints = starPointsFriends + starPointsEnemys - starPointsOwners;",
                        "    } else { //система кастомной фракции (все тоже самое, что и с домиками)",
                        "        for (i = 0; i < countShipsStar; i = i + 1) {",
                        "            selectShip = StarShips(star, i);",
                        "            if (ShipInNormalSpace(selectShip)) {",
                        "                shipCustomOwner = ShipCustomFaction(selectShip);",
                        "                if (starCustomOwner == shipCustomOwner)",
                        "                    starPointsOwners = starPointsOwners + ShipStrengthInBestRanger(selectShip);",
                        "                else if (!IsShipNisperEnemy(selectShip))",
                        "                    starPointsFriends = starPointsFriends + ShipStrengthInBestRanger(selectShip);",
                        "                else if (IsShipNisperEnemy(selectShip))",
                        "                    starPointsEnemys = starPointsEnemys + ShipStrengthInBestRanger(selectShip);",
                        "            }",
                        "        }",
                        "        if (starPointsFriends > 1.6 * (starPointsEnemys + starPointsOwners)) {",
                        "            starPoints = starPointsOwners + starPointsEnemys - starPointsFriends;",
                        "            starPoints = starPoints * 3;",
                        "        } else if (starPointsEnemys > 1.6 * starPointsOwners)",
                        "            starPoints = starPointsOwners + starPointsFriends - starPointsEnemys;",
                        "        else if (starPointsOwners > 5 * starPointsFriends)",
                        "            starPoints = starPointsEnemys - starPointsOwners;",
                        "        else",
                        "            starPoints = starPointsFriends + starPointsEnemys - starPointsOwners;",
                        "    }",
                        "    if (usePriority) { //если нужно учитывать приоритет - учитываем его",
                        "        int starNum = Id(star) - 1;",
                        "        float starPriority = arrStarsPriority[starNum];",
                        "        if (starPriority >= 1.0) { //если приоритет выше 1, то увеличиваем положительный приоритет и уменьшаем негативный",
                        "            if (starPoints > 0)",
                        "                starPoints = starPoints * starPriority;",
                        "            else",
                        "                starPoints = starPoints / starPriority;",
                        "        }",
                        "        else { //если приоритет ниже 0, то увеличиваем негативный приоритет и уменьшаем положительный",
                        "            if (starPoints > 0)",
                        "                starPoints = starPoints / starPriority;",
                        "            else",
                        "                starPoints = starPoints * starPriority;",
                        "        }",
                        "    }",
                        "    result = starPoints;",
                        "}",
                        "",
                        "function GetCountCoalStars() { //возвращает количество систем коалиции",
                        "    int countStars = GalaxyStars();",
                        "    int countCoalStars = 0;",
                        "    for (i = 0; i < countStars; i = i + 1) {",
                        "        dword selectStar = GalaxyStar(i);",
                        "        if (IsStarOwnerCoal(selectStar))",
                        "            countCoalStars = countCoalStars + 1;",
                        "    }",
                        "    result = countCoalStars;",
                        "}",
                        "",
                        "function GetProcCoalStars() { //возвращает процент систем коалиции от общего количества систем",
                        "    float procCoalStars = 100.0 * GetCountCoalStars() / GalaxyStars();",
                        "    result = procCoalStars;",
                        "}",
                        "",
                        "function GetBestBuildDBStar() { //возвращает лучшую систему (самую безопасную, с учетом дальности к вражеским) для постройки Базы Доминаторов",
                        "    int countStars = GalaxyStars();",
                        "    float bestStarPoints = 100000;",
                        "    dword bestStar = 0;",
                        "    for (j = 0; j < countStars; j = j + 1) {",
                        "        dword selectStar = GalaxyStar(j);",
                        "        if (IsStarOwnerCoal(selectStar)) {",
                        "            float starPoints = GetStarNisperPoints(selectStar, 0);",
                        "            int distToNearEnemyStar = GetNearNonCoalStarToStar(selectStar, 0);",
                        "            distToNearEnemyStar = min(10, distToNearEnemyStar);",
                        "            if (starPoints > 0)",
                        "                starPoints = starPoints * (11 - distToNearEnemyStar);",
                        "            else",
                        "                starPoints = starPoints * 0.1 * distToNearEnemyStar;",
                        "            if (starPoints < bestStarPoints) {",
                        "                bestStarPoints = starPoints;",
                        "                bestStar = selectStar;",
                        "            }",
                        "        }",
                        "    }",
                        "    result = bestStar;",
                        "}",
                        "",
                        "function GetArrFreeDomiksStar(star) { //возвращает массив свободных доминаторов в системе",
                        "    int countShipsStar = StarShips(star);",
                        "    unknown arrFreeDomiksStar;",
                        "    arrFreeDomiksStar = newarray(1);",
                        "    ArrayDelete(arrFreeDomiksStar, 0);",
                        "    for (i = 0; i < countShipsStar; i = i + 1) {",
                        "        dword selectShip = StarShips(star, i);",
                        "        if (IsDomikFree(selectShip))",
                        "            ArrayAdd(arrFreeDomiksStar, selectShip);",
                        "    }",
                        "    copy(tempArr, arrFreeDomiksStar);",
                        "}",
                        "",
                        "function GetCountFreeDomiksStar(star) { //возвращает количество свободных доминаторов в системе",
                        "    int countShipsStar = StarShips(star);",
                        "    int countFreeDomiksStar = 0;",
                        "    for (i = 0; i < countShipsStar; i = i + 1) {",
                        "        dword selectShip = StarShips(star, i);",
                        "        if (IsDomikFree(selectShip))",
                        "            countFreeDomiksStar = countFreeDomiksStar + 1;",
                        "    }",
                        "    result = countFreeDomiksStar;",
                        "}",
                        "",
                        "function GetArrNearStars(star, countNearStars) { //возвращает массив из указанного количества ближайших систем к выбранной системе",
                        "    unknown arrNearStars = newarray(1);",
                        "    ArrayDelete(arrNearStars, 0);",
                        "    for (i = 1; i <= countNearStars; i = i + 1) {",
                        "        dword selectStar = StarNearbyStars(star, i);",
                        "        if (!IsStarInPirateCon(selectStar))",
                        "            ArrayAdd(arrNearStars, selectStar);",
                        "        else",
                        "            countNearStars = countNearStars + 1;",
                        "    }",
                        "    copy(tempArr, arrNearStars);",
                        "}",
                        "",
                        "function GetArrShipsNisperPoints(arrShips) { //возвращает количество суммарных очков Ниспера (используются в расчете приоритета для систем) для выбранного массива кораблей",
                        "    int countShips = ArrayDim(arrShips);",
                        "    float shipsPoints = 0;",
                        "    for (i = 0; i < countShips; i = i + 1) {",
                        "        dword selectShip = arrShips[i];",
                        "        shipsPoints = shipsPoints + ShipStrengthInBestRanger(selectShip);",
                        "    }",
                        "    result = shipsPoints;",
                        "}",
                        "",
                        "function GetNearNonCoalStarToStar(star, returnStar) { //возвращает ближайшую вражескую систему (или индес отдаленности этой системы) по отношению к выбранной (скрытый сектор не в счет)",
                        "    dword nearNonCoalStar = 0;",
                        "    int countStars = GalaxyStars();",
                        "    for (i = 1; i < countStars && !nearNonCoalStar; i = i + 1) {",
                        "        dword selectStar = StarNearbyStars(star, i);",
                        "        if (!IsStarOwnerCoal(selectStar) && !IsStarInPirateCon(selectStar))",
                        "            nearNonCoalStar = selectStar;",
                        "    }",
                        "    if (returnStar)",
                        "        result = nearNonCoalStar;",
                        "    else",
                        "        result = i - 1;",
                        "}",
                        "",
                        "function GetStarActiveAttack(star, countNearStars, arrDomiksStar) { //возвращает лучшую (или 0, если таковой нет) вражескую систему для атаки на которую хватит сил",
                        "    GetArrNearStars(star, countNearStars);",
                        "    unknown arrNearStars = tempArr;",
                        "    unknown tempArrDomiksStar;",
                        "    copy(tempArrDomiksStar, arrDomiksStar);",
                        "    float bestSelectStarPoints = -0.75 * GetArrShipsNisperPoints(tempArrDomiksStar); //идем атаковать только те системы, на которые у нас теоретически может хватить сил",
                        "    dword bestSelectStar = 0;",
                        "    for (j = 0; j < countNearStars; j = j + 1) {",
                        "        dword selectStar = arrNearStars[j];",
                        "        if (!IsStarOwnerCoal(selectStar)) {",
                        "            float selectStarPoints = GetStarNisperPoints(selectStar, 1);",
                        "            if (selectStarPoints > bestSelectStarPoints) {",
                        "                bestSelectStarPoints = selectStarPoints;",
                        "                bestSelectStar = selectStar;",
                        "            }",
                        "        }",
                        "    }",
                        "    result = bestSelectStar;",
                        "}",
                        "",
                        "function GetStarActiveDefense(star, countNearStars) { //возвращает лучшую (или 0, если таковой нет) дружественную систему для защиты",
                        "    GetArrNearStars(star, countNearStars);",
                        "    unknown arrNearStars = tempArr;",
                        "    float bestSelectStarPoints = -100000;",
                        "    dword bestSelectStar = 0;",
                        "    for (j = 0; j < countNearStars; j = j + 1) {",
                        "        dword selectStar = arrNearStars[j];",
                        "        if (IsStarOwnerCoal(selectStar) && StarBattle(selectStar)) {",
                        "            float selectStarPoints = GetStarNisperPoints(selectStar, 1);",
                        "            if (selectStarPoints > bestSelectStarPoints) {",
                        "                bestSelectStarPoints = selectStarPoints;",
                        "                bestSelectStar = selectStar;",
                        "            }",
                        "        }",
                        "    }",
                        "    result = bestSelectStar;",
                        "}",
                        "",
                        "function GetStarActiveBalance(star, countNearStars) { //возвращает лучшую (или 0, если таковой нет) дружественную систему для балансировки количества доминаторов",
                        "    GetArrNearStars(star, countNearStars);",
                        "    unknown arrNearStars = tempArr;",
                        "    int bestFreeDomiksSelectStar = GetCountFreeDomiksStar(star)/4 + 1;",
                        "    dword bestSelectStar = 0;",
                        "    for (j = 0; j < countNearStars; j = j + 1) {",
                        "        dword selectStar = arrNearStars[j];",
                        "        if (IsStarOwnerCoal(selectStar)) {",
                        "            int selectStarFreeDomiks = GetCountFreeDomiksStar(selectStar);",
                        "            if (selectStarFreeDomiks < bestFreeDomiksSelectStar) {",
                        "                bestFreeDomiksSelectStar = selectStarFreeDomiks;",
                        "                bestSelectStar = selectStar;",
                        "            }",
                        "        }",
                        "    }",
                        "    result = bestSelectStar;",
                        "}",
                        "",
                        "function GetStarActiveConcetration(star, countNearStars) { //возвращает лучшую (или 0, если таковой нет) дружественную прифронтовую систему для скопления сил",
                        "    GetArrNearStars(star, countNearStars);",
                        "    unknown arrNearStars = tempArr;",
                        "    int bestNumNearNonCoalStarToSelectStar = GetNearNonCoalStarToStar(star, 0);",
                        "    dword bestSelectStar = 0;",
                        "    for (j = 0; j < countNearStars; j = j + 1) {",
                        "        dword selectStar = arrNearStars[j];",
                        "        if (IsStarOwnerCoal(selectStar)) {",
                        "            int numNearNonCoalStarToSelect = GetNearNonCoalStarToStar(selectStar, 0);",
                        "            if (numNearNonCoalStarToSelect < bestNumNearNonCoalStarToSelectStar) {",
                        "                bestNumNearNonCoalStarToSelectStar = numNearNonCoalStarToSelect;",
                        "                bestSelectStar = selectStar;",
                        "            }",
                        "        }",
                        "    }",
                        "    result = bestSelectStar;",
                        "}",
                        "",
                        "function TryStarActive(star, arrFreeDomiksStar) { //попытка перекинуть часть сил обычных домиков в указанной системе. Возвращает 0 если не удалось и 1 в обратном случае",
                        "    if (Rnd(1,1000) <= averageActiveChance) {",
                        "        unknown tempArrFreeDomiksStar;",
                        "        copy(tempArrFreeDomiksStar,arrFreeDomiksStar);",
                        "        int countNearStarsActive = 6;",
                        "        dword targetStar = 0;",
                        "        if ((targetStar = GetStarActiveAttack(star, countNearStarsActive, arrFreeDomiksStar)) > 0)",
                        "            ChangeArrDomiksTargetStar(tempArrFreeDomiksStar, targetStar, 75);",
                        "        else if((targetStar = GetStarActiveDefense(star, countNearStarsActive)) > 0)",
                        "            ChangeArrDomiksTargetStar(tempArrFreeDomiksStar, targetStar, 75);",
                        "        else if((targetStar = GetStarActiveBalance(star, countNearStarsActive)) > 0)",
                        "            ChangeArrDomiksTargetStar(tempArrFreeDomiksStar, targetStar, 25);",
                        "        else if((targetStar = GetStarActiveConcetration(star, countNearStarsActive)) > 0)",
                        "            ChangeArrDomiksTargetStar(tempArrFreeDomiksStar, targetStar, 15);",
                        "        if (targetStar)",
                        "            result = 1;",
                        "        else",
                        "            result = 0;",
                        "    }",
                        "    result = 0;",
                        "}",
                        "",
                        "function ChangeArrDomiksTargetStar(arrDomiks, targetStar, procent) { //меняет систему в которую стремится указанный процент домиков системы на указанную",
                        "    int numTargetStar = Id(targetStar) - 1;",
                        "    int countDomiks = ArrayDim(arrDomiks);",
                        "    countDomiks = round(1.0 * procent * countDomiks / 100);",
                        "    for (i = 0; i < countDomiks; i = i + 1) {",
                        "        dword selectDomik = arrDomiks[i];",
                        "        SetData(numTargetStar, 2, selectDomik);",
                        "    }",
                        "}",
                        "",
                        "function GetArrFabricPlanetsStar(star) { //возвращает массив незаселенных планет с фабриками в указанной системе",
                        "    unknown arrFabricPlanets = newarray(1);",
                        "    ArrayDelete(arrFabricPlanets, 0);",
                        "    int starPlanets = StarPlanets(star);",
                        "    for (i = 0; i < starPlanets; i = i + 1) {",
                        "        dword selectPlanet = StarPlanets(star, i);",
                        "        if (PlanetOwner(selectPlanet) == 6 && CountIn(gFactories, selectPlanet))",
                        "            ArrayAdd(arrFabricPlanets, selectPlanet);",
                        "    }",
                        "    copy(tempArr, arrFabricPlanets);",
                        "}",
                        "",
                        "function GetArrCivilPlanetsStar(star) { //возвращает массив заселенных планет указанной системы",
                        "    unknown arrCivilPlanets = newarray(1);",
                        "    ArrayDelete(arrCivilPlanets, 0);",
                        "    int starPlanets = StarPlanets(star);",
                        "    for (i = 0; i < starPlanets; i = i + 1) {",
                        "        dword selectPlanet = StarPlanets(star, i);",
                        "        if (PlanetOwner(selectPlanet) != 6)",
                        "            ArrayAdd(arrCivilPlanets, selectPlanet);",
                        "    }",
                        "    copy(tempArr, arrCivilPlanets);",
                        "}",
                        "",
                        "function TrySpawnDomik(star, spawnChance) { //попытка заспавнить доминатора на случайной подходящей планете в системе. Возвращает домика или 0 если не удалось",
                        "    dword spawnPlanet;",
                        "    int domikPowerPoints;",
                        "    int domikPower;",
                        "    int canSpawnBertor;",
                        "    dword spawnedDomik = 0;",
                        "    GetArrFabricPlanetsStar(star);",
                        "    unknown arrFabricPlanets;",
                        "    copy(arrFabricPlanets, tempArr);",
                        "    int countFabricPlanets = ArrayDim(arrFabricPlanets);",
                        "    int starSpawnChance = 1000 - GetIntByGeomLaw(1000, countFabricPlanets, 0.001 * (1000 - spawnChance));",
                        "    if (Rnd(1, 1000) <= starSpawnChance) {",
                        "        spawnPlanet = arrFabricPlanets[Rnd(0, countFabricPlanets-1)];",
                        "        domikPowerPoints = GetStarDomiksPower(star);",
                        "        domikPower = GetPowerFromPowerPoints(domikPowerPoints);",
                        "        canSpawnBertor = !IsStarConHaveBertor(star) && IsBertorQuestComplete();",
                        "        spawnedDomik = StdAlgorithmBuyDomik(spawnPlanet, domikPower, -1, canSpawnBertor);",
                        "    }",
                        "    if (spawnedDomik == 0 && specialBonus == 3) {",
                        "        GetArrCivilPlanetsStar(star);",
                        "        unknown arrCivilPlanets = tempArr;",
                        "        int countCivilPlanets = ArrayDim(arrCivilPlanets);",
                        "        starSpawnChance = 1000 - GetIntByGeomLaw(1000, countCivilPlanets, 0.001 * (1000 - (spawnChance / 10)));",
                        "        if (Rnd(1, 1000) <= starSpawnChance) {",
                        "            spawnPlanet = arrCivilPlanets[Rnd(0, countCivilPlanets-1)];",
                        "            domikPowerPoints = GetStarDomiksPower(star);",
                        "            domikPower = GetPowerFromPowerPoints(domikPowerPoints);",
                        "            canSpawnBertor = !IsStarConHaveBertor(star) && IsBertorQuestComplete();",
                        "            spawnedDomik = StdAlgorithmBuyDomik(spawnPlanet, domikPower, -1, canSpawnBertor);",
                        "        }",
                        "    }",
                        "    result = spawnedDomik;",
                        "}",
                        "",
                        "function GetArrGalaxyCoalPossibleReachedStars(radius, startStar, ignoreStarsWithBattle) { //возвращает массив систем с идентификатором того, может ли корабль долететь со стартовой с учетом указанного радиуса прыжка (с учетом множественных прыжков). Может игнорировать системы в которых идет битва.",
                        "    int starsCount = GalaxyStars();",
                        "    unknown arrGalaxyCoalPossibleReachedStars = newarray(starsCount);",
                        "    for (i = 0; i < starsCount; i = i + 1) {",
                        "        dword curStar = GalaxyStar(i);",
                        "        if (IsStarOwnerCoal(curStar))",
                        "            arrGalaxyCoalPossibleReachedStars[i] = 2; //индекс 0 означает то, что система не подходит, 1 = проверили, можно долететь, 2 = возможно подходит, но еще не проверили на возможность долета",
                        "        else",
                        "            arrGalaxyCoalPossibleReachedStars[i] = 0;",
                        "        if (!ignoreStarsWithBattle && StarBattle(curStar))",
                        "            arrGalaxyCoalPossibleReachedStars[i] = 0;",
                        "    }",
                        "    arrGalaxyCoalPossibleReachedStars[Id(startStar) - 1] = 1;",
                        "    for (int needToCycleAgain = 1; needToCycleAgain;) {",
                        "        needToCycleAgain = 0;",
                        "        for (i = 0; i < starsCount; i = i + 1) {",
                        "            if (arrGalaxyCoalPossibleReachedStars[i] == 1) {",
                        "                curStar = GalaxyStar(i);",
                        "                for (j = 1; radius >= StarNearbyStarsDist(curStar, j) && j < starsCount; j = j + 1) {",
                        "                    if (arrGalaxyCoalPossibleReachedStars[Id(StarNearbyStars(curStar, j)) - 1] == 2) {",
                        "                        arrGalaxyCoalPossibleReachedStars[Id(StarNearbyStars(curStar, j)) - 1] = 1;",
                        "                        needToCycleAgain = 1;",
                        "                    }",
                        "                }",
                        "            }",
                        "        }",
                        "    }",
                        "    for (i = 0; i < starsCount; i = i + 1) {",
                        "        if (arrGalaxyCoalPossibleReachedStars[i] == 2)",
                        "            arrGalaxyCoalPossibleReachedStars[i] = 0;",
                        "    }",
                        "    copy(tempArr, arrGalaxyCoalPossibleReachedStars);",
                        "}",
                        "",
                        "function GetArrRouteFromStarToStar(radius, startStar, targetStar, ignoreStarsWithBattle) { //возвращает самый короткий маршрут от одной звезды до второй (пока что только для коалиционных систем). В result записывается количество систем из которых состоит маршрут (где 0 означает невозможность маршрута)",
                        "    GetArrGalaxyCoalPossibleReachedStars(radius, startStar, ignoreStarsWithBattle);",
                        "    dword curStar;",
                        "    unknown arrRouteFromStarToStar = newarray(1);",
                        "    ArrayDelete(arrRouteFromStarToStar, 0);",
                        "    unknown arrGalaxyCoalPossibleReachedStars = tempArr;",
                        "    if (arrGalaxyCoalPossibleReachedStars[Id(targetStar) - 1] == 1) {",
                        "        int starsCount = GalaxyStars();",
                        "        unknown arrRouteMinJumps = newarray(starsCount);",
                        "        for (i = 0; i < starsCount; i = i + 1)",
                        "            arrRouteMinJumps[i] = 10000;",
                        "        arrRouteMinJumps[Id(startStar) - 1] = 0;",
                        "        for (int jumps = 0; arrRouteMinJumps[Id(targetStar) - 1] == 10000; jumps = jumps + 1) {",
                        "            for (i = 0; i < starsCount; i = i + 1) {",
                        "                if (arrRouteMinJumps[i] == jumps) {",
                        "                    curStar = GalaxyStar(i);",
                        "                    for (j = 1; radius >= StarNearbyStarsDist(curStar, j) && j < starsCount; j = j + 1) {",
                        "                        if (arrGalaxyCoalPossibleReachedStars[Id(StarNearbyStars(curStar, j)) - 1] && ((jumps + 1) < arrRouteMinJumps[Id(StarNearbyStars(curStar, j)) - 1]))",
                        "                            arrRouteMinJumps[Id(StarNearbyStars(curStar, j)) - 1] = jumps + 1;",
                        "                    }",
                        "                }",
                        "            }",
                        "        }",
                        "        int jumpsToTargetStar = arrRouteMinJumps[Id(targetStar) - 1];",
                        "        arraychange(arrRouteFromStarToStar, jumpsToTargetStar + 1);",
                        "        arrRouteFromStarToStar[jumpsToTargetStar] = targetStar;",
                        "        jumpsToTargetStar = jumpsToTargetStar - 1;",
                        "        dword nextStar = targetStar;",
                        "        for (; jumpsToTargetStar > 0; jumpsToTargetStar = jumpsToTargetStar - 1) {",
                        "            curStar = nextStar;",
                        "            for (j = 1; radius >= round(sqrt(Dist2Star(curStar, StarNearbyStars(curStar, j)))) && curStar == nextStar && j < starsCount; j = j + 1) {",
                        "                if (arrRouteMinJumps[Id(StarNearbyStars(curStar, j)) - 1] < arrRouteMinJumps[Id(curStar) - 1]) {",
                        "                    nextStar = StarNearbyStars(curStar, j);",
                        "                }",
                        "            }",
                        "            arrRouteFromStarToStar[jumpsToTargetStar] = nextStar;",
                        "        }",
                        "        arrRouteFromStarToStar[0] = startStar;",
                        "        copy(tempArr, arrRouteFromStarToStar);",
                        "        result = ArrayDim(arrRouteFromStarToStar);",
                        "    }",
                        "    else",
                        "        result = 0;",
                        "}",
                        "",
                        "function GetRandomCoalCivilPlanet() { //возвращает случайную заселенную планету в случайной системе под контролем коалиции",
                        "    int countStars = GalaxyStars();",
                        "    unknown arrPossiblePlanets = newarray(1);",
                        "    ArrayDelete(arrPossiblePlanets, 0);",
                        "    for (k = 0; k < countStars; k = k + 1) {",
                        "        dword selectStar = GalaxyStar(k);",
                        "        if (IsStarOwnerCoal(selectStar)) {",
                        "            GetArrCivilPlanetsStar(selectStar);",
                        "            unknown arrCivilPlanets = tempArr;",
                        "            int countCivilPlanets = ArrayDim(arrCivilPlanets);",
                        "            for (i = 0; i < countCivilPlanets; i = i + 1)",
                        "                ArrayAdd(arrPossiblePlanets, arrCivilPlanets[i]);",
                        "        }",
                        "    }",
                        "    int countPossiblePlanets = ArrayDim(arrPossiblePlanets);",
                        "    if (countPossiblePlanets < 1)",
                        "        result = 0;",
                        "    else {",
                        "        result = arrPossiblePlanets[Rnd(0, countPossiblePlanets - 1)];",
                        "    }",
                        "}",
                        "",
                        "function FindBertorNewStar(ship) { //находит новую целевую систему для бертора в его секторе (или возвращает 0, если подходящей системы нет)",
                        "    dword star = ShipStar(ship);",
                        "    dword con = StarToCon(star);",
                        "    dword bestStar = 0;",
                        "    int bestStarPoints = -100000;",
                        "    int conStarCount = ConStars(con);",
                        "    for (j = 0; j < conStarCount; j = j + 1) {",
                        "        star = ConStar(con, j);",
                        "        if (IsStarOwnerCoal(star)) {",
                        "            float starPoints = GetStarNisperPoints(star, 1);",
                        "            if (starPoints > bestStarPoints) {",
                        "                bestStar = star;",
                        "                bestStarPoints = starPoints;",
                        "            }",
                        "        }",
                        "    }",
                        "    result = bestStar;",
                        "}",
                        "function StdAlgorithmBuyDomik(planet, domikPower, domikType, canSpawnBertor) { //стандартный алгоритм постройки доминатора Ниспера на выбранной планете с указанной силой, типом домика (-1 это случайный) и возможность построить бертора",
                        "    dword domik = BuyTranclucator(planet);",
                        "    dword hull = ShipItems(domik, 0);",
                        "    if (domikType == -1)",
                        "        domikType = GetRandomDomikType(canSpawnBertor);",
                        "    if (domikType == 6)",
                        "        domikPower = domikPower + 1;",
                        "    else if (domikType == 7)",
                        "        domikPower = domikPower - 1;",
                        "    domikPower = min(7, max(1, domikPower));",
                        "    if (domikType == 6)",
                        "        ShipJoin(gBertors, domik);",
                        "    else if (domikType == 7)",
                        "        ShipJoin(gKligs, domik);",
                        "    else",
                        "        ShipJoin(gDomiks, domik);",
                        "    SetTrancProprietorDB(domik);",
                        "    DeleteAllItemsShip(domik);",
                        "    SetHullStdNisperDomik(hull, domikType, domikPower);",
                        "    SetShipNisperRace(domik, domikType);",
                        "    SetShipNisperFacing(domik, domikType);",
                        "    GetStdDomikEqKit(domik, domikType, domikPower);",
                        "    UseAllItemsShip(domik);",
                        "    if (specialBonus == 2)",
                        "        StdUpgradeAllEq(domik, domikPower);",
                        "    SetShipNisperSkills(domik, domikType);",
                        "    StdDomikInfos(domik, domikType);",
                        "    ChangeItemsSizeToHullSize(domik);",
                        "    ModsCompatibility(domik, 0);",
                        "    result = domik;",
                        "}",
                        "",
                        "function StdAlgorithmBuyNisper(planet, domikPower, nisperType) { //стандартный алгоритм создания Ниспера на выбранной планете с указанной силой и типом",
                        "    dword Nisper = BuyTranclucator(planet);",
                        "    dword hull = ShipItems(Nisper, 0);",
                        "    domikPower = min(7, max(1, domikPower + 1));",
                        "    ShipJoin(gNisper, Nisper);",
                        "    SetTrancProprietorDB(Nisper);",
                        "    DeleteAllItemsShip(Nisper);",
                        "    SetHullNisper(hull, nisperType, domikPower);",
                        "    SetShipNisperRace(Nisper, 0);",
                        "    SetName(Nisper, 'Ниспер');",
                        "    SetNisperFacing(Nisper, nisperType);",
                        "    GetNisperEqKit(Nisper,  domikPower);",
                        "    UseAllItemsShip(Nisper);",
                        "    if (specialBonus == 2)",
                        "        StdUpgradeAllEq(domik, domikPower);",
                        "    SetShipNisperSkills(Nisper, 0);",
                        "    StdNisperInfos(Nisper);",
                        "    ChangeItemsSizeToHullSize(Nisper);",
                        "    ModsCompatibility(Nisper, 0);",
                        "    result = Nisper;",
                        "}",
                        "",
                        "function StdAlgorithmBuyDB(star) { //стандартный алгоритм постройки Базы Доминаторов",
                        "    dword DB = BuildCustomRuins(star, 'DB', 2);",
                        "    ShipJoin(gDomiksBase, DB);",
                        "    DBAlgorithmFacing(DB);",
                        "    SetAllDomTrancProprietorDB();",
                        "    ModsCompatibility(DB, 1);",
                        "    result = DB;",
                        "}",
                        "",
                        "function TryBuildDB() { //попытка построить в этом ходу Базу Доминаторов, возвращает систему (или 0, если не удалось)",
                        "    dword star = GetBestBuildDBStar();",
                        "    if (star) {",
                        "        StdAlgorithmBuyDB(star);",
                        "        CustomEther('NisperEther', 6, '', 'База Доминаторов построена в системе ' + StarName(star));",
                        "    }",
                        "    result = star;",
                        "}",
                        "",
                        "function BuildAndHideCoalRelationMeter() { //создание и маскировка коалиционной базы, которую потом будем использовать в качестве мерила отношений",
                        "    dword CRM = BuildCustomRuins(GalaxyStar(0), 'DB', 2);",
                        "    PutShipInHyperspace(CRM);",
                        "    SetName(CRM, 'Ты не должен этого видеть');",
                        "    ShipJoin(gCoalRelationMeter, CRM);",
                        "    result = CRM;",
                        "}",
                        "",
                        "function StdAlgorithmBuyFactory(planet) { //стандартный алгоритм постройки фабрики доминаторов",
                        "    dword factory = BuyTransport(planet, 0, 500);",
                        "    SetStdFactoryHull(factory);",
                        "    SetStdFactoryEq(factory);",
                        "    ShipJoin(gFactories, factory);",
                        "    ShipType(factory, 'Factory');",
                        "    StdFactoryInfos(factory);",
                        "    ModsCompatibility(factory, 2);",
                        "    result = factory;",
                        "}",
                        "",
                        "function BertorStdKligSpawnAlgorithm(bertor) { //стандартный алгоритм попытки спавна клигов для берторов",
                        "    dword DB = GetDB();",
                        "    int aliveKligsCount = ShipCustomShipInfoData(bertor, 'ZelDomiks_BertorInfo', 1);",
                        "    int maxKligsCount = ShipCustomShipInfoData(bertor, 'ZelDomiks_BertorInfo', 2);",
                        "    if (aliveKligsCount < maxKligsCount && Rnd(1, maxKligsCount * 2) > maxKligsCount - aliveKligsCount) { //чем больше живых клигов - тем больше шанс заспавнить новых",
                        "        int bertorId = Id(bertor);",
                        "        int domikPowerPoints = GetStarDomiksPower(ShipStar(bertor));",
                        "        int domikPower = GetPowerFromPowerPoints(domikPowerPoints);",
                        "        while (aliveKligsCount < maxKligsCount) {",
                        "            dword klig = StdAlgorithmBuyDomik(NearCivilPlanet(DB), domikPower, 7, 0);",
                        "            TakeOffStraightFromShip(klig, bertor);",
                        "            SetData(bertorId, 1, klig);",
                        "            aliveKligsCount = aliveKligsCount + 1;",
                        "        }",
                        "        OrderNone(bertor);",
                        "        SetData(0, 0, bertor);",
                        "        ShipCustomShipInfoData(bertor, 'ZelDomiks_BertorInfo', 1, maxKligsCount);",
                        "    }",
                        "}",
                        "",
                        "function PlayerKligSpawnAlgorithm(player) { //алгоритм спавна клигов для игрока с корпусом бертора",
                        "    dword DB = GetDB();",
                        "    int aliveKligsCount = ShipCustomShipInfoData(player, 'ZelDomiks_BertorInfo', 1);",
                        "    int readyKligsCount = ShipCustomShipInfoData(player, 'ZelDomiks_BertorInfo', 3);",
                        "    int maxKligsCount = ShipCustomShipInfoData(player, 'ZelDomiks_BertorInfo', 2);",
                        "    if (ShipOrder(player) == 0 && readyKligsCount) { //чем больше живых клигов - тем больше шанс заспавнить новых",
                        "        int playerId = Id(player);",
                        "        int domikPowerPoints = GetStarDomiksPower(ShipStar(player));",
                        "        int domikPower = GetPowerFromPowerPoints(domikPowerPoints);",
                        "        aliveKligsCount = aliveKligsCount + readyKligsCount;",
                        "        while (readyKligsCount) {",
                        "            dword klig = StdAlgorithmBuyDomik(NearCivilPlanet(DB), domikPower, 7, 0);",
                        "            TakeOffStraightFromShip(klig, player);",
                        "            SetData(playerId, 1, klig);",
                        "            readyKligsCount = readyKligsCount - 1;",
                        "        }",
                        "        ShipCustomShipInfoData(player, 'ZelDomiks_BertorInfo', 1, aliveKligsCount);",
                        "        ShipCustomShipInfoData(player, 'ZelDomiks_BertorInfo', 3, 0);",
                        "    }",
                        "}",
                        "",
                        "function PlayerKligBuildAlgorithm(player) { //алгоритм постройки и сохранения клигов в корпусе бертора игрока",
                        "    int aliveKligsCount = ShipCustomShipInfoData(player, 'ZelDomiks_BertorInfo', 1);",
                        "    int readyKligsCount = ShipCustomShipInfoData(player, 'ZelDomiks_BertorInfo', 3);",
                        "    int maxKligsCount = ShipCustomShipInfoData(player, 'ZelDomiks_BertorInfo', 2);",
                        "    if (aliveKligsCount + readyKligsCount < maxKligsCount) {",
                        "        if (Rnd(1, maxKligsCount * 2) > maxKligsCount - (aliveKligsCount + readyKligsCount)) {",
                        "            readyKligsCount = maxKligsCount - aliveKligsCount; //если сработала вероятность, то добавляем готовых клигов игроку",
                        "        }",
                        "    }",
                        "    ShipCustomShipInfoData(player, 'ZelDomiks_BertorInfo', 3, readyKligsCount);",
                        "}",
                        "",
                        "function CreateBertorMaterial(materialCount, materialCost) { //создает и возвращает указанное количество материала бертора по указанной цене",
                        "    dword material = CreateCustomCountableItem('ZelDomiks_UselessBertorMaterial', materialCount);",
                        "    ItemCost(material, materialCost * materialCount);",
                        "    result = material;",
                        "}",
                        "function GetStartResearchItemsTarget() { //возвращает стартовое количество необходимого материала для активации Ниспера",
                        "    float multiplicator = 1.12;",
                        "    int startResearchItemsTarget = 800 + Rnd(-10, 10);",
                        "    int multCount = arrDifficultLevels['Science'] / 50;",
                        "    if (isScriptTest)",
                        "        startResearchItemsTarget = startResearchItemsTarget / 10;",
                        "    result = GetIntByGeomLaw(startResearchItemsTarget, multCount, multiplicator);",
                        "}",
                        "",
                        "function GetSizePassiveAddStartResearchItems() { //возвращает количество материала пассивного добавления для активации Ниспера",
                        "    int procentPassiveAdd = Rnd(5, 25);",
                        "    int sizePassiveAdd = startResearchItemsTarget * procentPassiveAdd / 1000;",
                        "    result = sizePassiveAdd;",
                        "}",
                        "",
                        "function GetSeriePassiveAddStartResearchItems() { //возвращает серию к которой будет пассивно добавлен материал для активации Ниспера",
                        "    int seriePassiveAdd;",
                        "    str strSeriePassiveAdd;",
                        "    if (Rnd(1, 5) != 1)",
                        "        seriePassiveAdd = Rnd(0, 2);",
                        "    else { //добавляем к самому большому скоплению",
                        "        if (arrStartResearchItems['Blazer'] > arrStartResearchItems['Keller'] && arrStartResearchItems['Blazer'] > arrStartResearchItems['Terron'])",
                        "            seriePassiveAdd = 0;",
                        "        else if(arrStartResearchItems['Terron'] > arrStartResearchItems['Blazer'] && arrStartResearchItems['Terron'] > arrStartResearchItems['Keller'])",
                        "            seriePassiveAdd = 2;",
                        "        else",
                        "            seriePassiveAdd = 1;",
                        "    }",
                        "    strSeriePassiveAdd = GetStrSerieName(seriePassiveAdd);",
                        "    result = strSeriePassiveAdd;",
                        "}",
                        "",
                        "function TryPassiveAddStartResearchItems() { //попытка пассивно добавить материал для активации Ниспера",
                        "    if (IsNeedPassiveAddStartResearchItems()) {",
                        "        str strSeriePassiveAdd = GetSeriePassiveAddStartResearchItems();",
                        "        int sizePassiveAdd = GetSizePassiveAddStartResearchItems();",
                        "        arrStartResearchItems[strSeriePassiveAdd] = arrStartResearchItems[strSeriePassiveAdd] + sizePassiveAdd;",
                        "    }",
                        "}",
                        "",
                        "function GetRemainingStartResearchItems() { //возвращает текущее количества нехватки материалов для активации Ниспера",
                        "    int remainingStartResearchItems = startResearchItemsTarget - arrStartResearchItems['Blazer'] - arrStartResearchItems['Keller'] - arrStartResearchItems['Terron'];",
                        "    remainingStartResearchItems = max(0, remainingStartResearchItems);",
                        "    result = remainingStartResearchItems;",
                        "}",
                        "",
                        "function GetStartResearchPlayerItemsProcent() {",
                        "    result = round(startResearchPlayerItems*100/startResearchItemsTarget);",
                        "}",
                        "",
                        "function FirstSpawnDB() { //функция первого спавна Базы Доминаторов (активации Ниспера)",
                        "    NisperStarted = 1;",
                        "    if (GetStartResearchPlayerItemsProcent() < 51)",
                        "        NisperLevelUp(0);",
                        "    else",
                        "        NisperLevelUp(1);",
                        "    dword star = TryBuildDB();",
                        "    SetData(0, 0, GetDB());",
                        "    arrBertorQuestData['startQuestTurn'] = CurTurn() + Rnd(250, 350); //запускаем отсчет до возможности стартовать квест бертора",
                        "    if (isScriptTest)",
                        "        arrBertorQuestData['startQuestTurn'] = 300;",
                        "    result = star;",
                        "}",
                        "",
                        "function GetResearchProcent() { //возвращает процент исследования, где 100% при >= 300 тонн материала для исследований и 20% при 0 тонн",
                        "    int procent = round(PortionInDiapason(researchItems, 0, 300, 20, 100));",
                        "    result = procent;",
                        "}",
                        "",
                        "function DecreaseResearchItems() { //уменьшает, если есть, количество материалов для исследований",
                        "    int maxDecreaseItems = round(PortionInDiapason(arrDifficultLevels['Breakdown'], 50, 500, 3, 18));",
                        "    int decreaseItems = Rnd(1, maxDecreaseItems);",
                        "    if (Rnd(1, 3) == 1) {",
                        "        decreaseItems = min(decreaseItems, researchItems);",
                        "        researchItems = researchItems - decreaseItems;",
                        "    }",
                        "}",
                        "",
                        "function GetResearchRemainDays(procent) { //возвращает количество дней необходимого для завершения текущего этапа исследовний при указанном проценте исследований",
                        "    int researchTarget = arrResearchTarget[NisperLevel - 1];",
                        "    float researchTargetRemain = 1.0 * researchTarget - researchCount;",
                        "    float researchAdd = 1.0 * procent / 100;",
                        "    float researchTurnsRemainFloat = researchTargetRemain / researchAdd;",
                        "    int researchTurnsRemain = researchTurnsRemainFloat + (researchTurnsRemainFloat % 1.0 > 0);",
                        "    result = researchTurnsRemain;",
                        "}",
                        "",
                        "function AddResearchCount(researchAdd) { //добавляет количество дней к исследованиям и обрабатывает превышение параметра (если таковое есть)",
                        "    int researchTarget = arrResearchTarget[NisperLevel - 1];",
                        "    float researchTargetRemain = 1.0 * researchTarget - researchCount;",
                        "    if (researchTargetRemain > researchAdd)",
                        "        researchCount = researchCount + researchAdd;",
                        "    else {",
                        "        if (researchTargetRemain == researchAdd)",
                        "            researchAdd = 0;",
                        "        else",
                        "            researchAdd = researchAdd - researchTargetRemain;",
                        "        NisperLevelUp(1);",
                        "        CustomEther('NisperEther', 6, '', 'Уровень Ниспера повышен.",
                        "Если желаете, загляните на Базу Доминаторов.');",
                        "        researchCount = researchCount + researchAdd;",
                        "    }",
                        "}",
                        "",
                        "function NisperLevelUp(canPlayerSelect) { //повышает уровень Ниспера, сбрасывает количество произведенных исследований и увеличивает (или дает игроку возможность) улучшения",
                        "    NisperLevel = NisperLevel + 1;",
                        "    researchCount = 0;",
                        "    curTaskState = 0;",
                        "    int addUpgrades = arrLevelsAddUpgrades[NisperLevel];",
                        "    if (canPlayerSelect)",
                        "        playerUpgrades = playerUpgrades + addUpgrades;",
                        "    else",
                        "        RandomAddUpgrades(addUpgrades);",
                        "}",
                        "",
                        "function RandomAddUpgrades(addUpgrades) { //случайным образом распределяет данное количество улучшений в пределах максимальных значений (учитывая бонусы)",
                        "    while (addUpgrades > 0) {",
                        "        int rndInt = Rnd(1, 4);",
                        "        if (rndInt == 1 && upgradePower < 40) {",
                        "            upgradeActive = upgradeActive + 1;",
                        "            addUpgrades = addUpgrades - 1;",
                        "        } else if ((rndInt == 2 || rndInt == 3) && upgradeActive < 20) {",
                        "            upgradePower = upgradePower + 1;",
                        "            addUpgrades = addUpgrades - 1;",
                        "        } else if (rndInt == 4 && upgradeSpawn < 20) {",
                        "            upgradeSpawn = upgradeSpawn + 1;",
                        "            addUpgrades = addUpgrades - 1;",
                        "        }",
                        "    }",
                        "}",
                        "",
                        "function GetPlayerUpgradesRemain() { //возвращает оставшееся количество улучшений, которые может сделать игрок",
                        "    int playerUpgradesRemain = playerUpgrades-arrPlayerUpgrades[0]-arrPlayerUpgrades[1]-arrPlayerUpgrades[2];",
                        "    result = playerUpgradesRemain;",
                        "}",
                        "",
                        "function GetNewTaskNum() { //возвращает новый случайный номер задания, которое еще не заблокировано в текущей партии. Если таковых нет, то -1",
                        "    /*unknown arrAvailableTasksNum = newarray(1);",
                        "    int availableTasksCount = 0;",
                        "    ArrayDelete(arrAvailableTasksNum, 0);",
                        "    for (i = 0; i < tasksCount; i = i + 1) {",
                        "        if (arrAvailableTasks[i] == 1 && arrTasksConditions[i] == 1) {",
                        "            ArrayAdd(arrAvailableTasksNum, i);",
                        "            availableTasksCount = availableTasksCount + 1;",
                        "        }",
                        "    }",
                        "    if (availableTasksCount) {",
                        "        int newCurTaskNum = arrAvailableTasksNum[Rnd(0, availableTasksCount - 1)];",
                        "        result = newCurTaskNum;",
                        "    } else*/",
                        "        result = -1;",
                        "}",
                        "",
                        "function checkTasksConditions() { //перепроверяет все условия каждого задания",
                        "    //Для первого нужны пираты в галактике и, как минимум, одна их система не находящаяся в бою.",
                        "    int countStars = GalaxyStars();",
                        "    /*for (i = 0; i < countStars; i = i + 1) {",
                        "        dword selectStar = GalaxyStar(i);",
                        "        if (IsStarOwnerPirate(selectStar) && !StarBattle(selectStar))",
                        "            arrTasksConditions[0] = 1;",
                        "    }",
                        "    arrTasksConditions[1] = 1;*/",
                        "}",
                        "",
                        "function BlackHoleForBertorsABStart(blackHole, reward) { //настраивает и стартует аркадный бой для задания по заманиванию берторов в ЧД",
                        "    int holeDifficulty = arrDifficultLevels['BlackHole'] / 50;",
                        "    int successfulTimes = arrBlackHoleForBertorsData['NumOfSuccessfulTimes'];",
                        "    float baseSpeedPercent = GetEqualizingABStat(1);",
                        "    float baseDamagePercent = GetEqualizingABStat(2); //устанавливаем стандартные урон и скорость вне зависимости от сложности игры",
                        "    dword drop = CreateEquipment(t_Weapon13, 5, 1, 5);",
                        "    dword bertor = IdToShip(arrBlackHoleForBertorsData['TargetBertorId']);",
                        "    ShipDestroy(bertor, 1);",
                        "    DeleteAllWeaponsShip(bertor);",
                        "    int numOfWeapons = round(PortionInDiapason(successfulTimes, 0, 6, 2, 5));",
                        "    for (i = 0; i < numOfWeapons; i = i + 1) {",
                        "        int weaponType = Choice3(0.33, t_Weapon13, 0.33, t_Weapon14, 0.33, t_Weapon15);",
                        "        dword weapon = CreateEquipment(weaponType, 5, 1, 5);",
                        "        AddItemToShip(bertor, weapon);",
                        "    }",
                        "    UseAllItemsShip(bertor);",
                        "    dword bertorRandSeed = bertor;",
                        "    int bertorHealthPerc = 100;",
                        "    if (arrActiveMods['EvoArmada'] == 1)",
                        "        bertorHealthPerc = 34; //поскольку ЕвоАрмада увеличивает ХП бертора, мы будем его уменьшать для ЧД",
                        "    bertor = ConvertToABShip(bertor, 0, bertorHealthPerc, 100, '', reward);",
                        "    float successfulTimesMult = (1.0 + 1.0 * successfulTimes / 10);",
                        "    float successfulTimesHealthMult = 1.0 / successfulTimesMult;",
                        "    float damageMult = 0.4 + (0.2 * holeDifficulty); //бертор не очень дамажит и медленный, зато бронированный",
                        "    float healthMult = 1.0 / (1.0 + (0.3 * holeDifficulty));",
                        "    float speedMult = 0.6 + (0.05 * holeDifficulty);",
                        "    if (arrBlackHoleForBertorsData['Serie'] == 0) { //блазерский бертор сильно дамажит",
                        "        damageMult = damageMult * 2.0;",
                        "    }",
                        "    else if (arrBlackHoleForBertorsData['Serie'] == 1) { //келлерский бертор быстрый",
                        "        speedMult = speedMult * 2.0;",
                        "    }",
                        "    else if (arrBlackHoleForBertorsData['Serie'] == 1) { //терроновский бертор хпшный",
                        "        healthMult = healthMult / 2.0;",
                        "    }",
                        "    ABShipModifiers(bertor, 'damage', round(baseDamagePercent * 100 * damageMult * successfulTimesMult));",
                        "    ABShipModifiers(bertor, 'fragility', round(healthMult * 100 * successfulTimesHealthMult));",
                        "    ABShipModifiers(bertor, 'speed', round(baseSpeedPercent * 100 * speedMult * successfulTimesMult));",
                        "    for (k = 1; k < GroupCount(gBlackHoleForBertors); k = k + 1) {",
                        "        dword klig = GroupShip(gBlackHoleForBertors, k);",
                        "        int flag = 0;",
                        "        if (GetData(0, klig) == 7) {",
                        "            if (blackHole == ShipOrderObj(klig) && ShipInHole(klig)) {",
                        "                flag = 1; //добавляем клигов, которые успели влететь в ЧД до начала боя",
                        "                ShipDestroy(klig);",
                        "            }",
                        "        }",
                        "        if (flag) {",
                        "            DeleteAllWeaponsShip(klig);",
                        "            numOfWeapons = RndObject(1, 2, bertorRandSeed) + PortionInDiapason(successfulTimes, 0, 10, 0, 4);",
                        "            numOfWeapons = min(numOfWeapons, 5);",
                        "            int weaponPull = 2 + (holeDifficulty > 2); //если сложность ЧД выше 100 - берем оружие из более сильного пула",
                        "            for (j = 0; j < numOfWeapons; j = j + 1) {",
                        "                weaponType = GetDomikWeaponType(7, weaponPull);",
                        "                weapon = CreateEquipment(weaponType, 5, 1, 5);",
                        "                AddItemToShip(klig, weapon);",
                        "            }",
                        "            UseAllItemsShip(klig);",
                        "            klig = ConvertToABShip(klig);",
                        "            damageMult = 0.7 + (0.3 * holeDifficulty); //клиги быстрые и дамажащие, но быстро дохнут",
                        "            healthMult = 1.0 / (0.6 + (0.1 * holeDifficulty));",
                        "            speedMult = 0.8 + (0.15 * holeDifficulty);",
                        "            if (arrBlackHoleForBertorsData['Serie'] == 0) { //блазерские клиги сильно дамажат",
                        "                damageMult = damageMult * 2.0;",
                        "            }",
                        "            else if (arrBlackHoleForBertorsData['Serie'] == 1) { //келлерские клиги быстрые",
                        "                speedMult = speedMult * 2.0;",
                        "            }",
                        "            else if (arrBlackHoleForBertorsData['Serie'] == 1) { //терроновские клиги хпшные",
                        "                healthMult = healthMult / 2.0;",
                        "            }",
                        "            ABShipModifiers(klig, 'damage', round(baseDamagePercent * 100 * damageMult * successfulTimesMult));",
                        "            ABShipModifiers(klig, 'fragility', round(healthMult * 100 * successfulTimesHealthMult));",
                        "            ABShipModifiers(klig, 'speed', round(baseSpeedPercent * 100 * speedMult * successfulTimesMult));",
                        "        }",
                        "    }",
                        "    StartAB('ABMap.map_' + RndObject(1, 14, bertorRandSeed));",
                        "}",
                        "",
                        "function BlackHoleForBertorsResetGroup() { //обнуляет группу бертора и клигов идущих в ЧД для задания по заманиванию берторов в ЧД",
                        "    int groupSize = GroupCount(gBlackHoleForBertors);",
                        "    for (i = 0; i < groupSize; i = i + 1) {",
                        "        dword curShip = GroupShip(gBlackHoleForBertors, 0);",
                        "        OrderLock(curShip, 0);",
                        "        if (ShipInNormalSpace(curShip))",
                        "            ShipFreeFlight(curShip);",
                        "        else if(ShipInHole(curShip)) {",
                        "            ShipOrderData1(curShip, 0);",
                        "            ShipOrderData2(curShip, 65535);",
                        "        }",
                        "        ShipOut(curShip);",
                        "    }",
                        "}",
                        "",
                        "function BertorQuestGetResearchDuration(phaze) {",
                        "    int duration = 0;",
                        "    int difficulty = arrDifficultLevels['Science'] / 50;",
                        "    if (phaze == 1) { //исследования открытия субпортала третей серии",
                        "        duration = GetIntByGeomLaw(45, difficulty, 1.3);",
                        "        if (isScriptTest)",
                        "            duration = 3;",
                        "    }",
                        "    else if(phaze == 3) { //ученый из другой системы",
                        "        duration = GetIntByGeomLaw(900, difficulty, 1.1);",
                        "    }",
                        "    result = duration;",
                        "}",
                        "",
                        "function PlaceBertorMaterialToPlanets() { //раскидывает по всей галактике материал берторов на незаселенные планеты",
                        "    int difficulty = arrDifficultLevels['Luck'] / 50;",
                        "    int countStars = GalaxyStars();",
                        "    for (i = 0; i < countStars; i = i + 1) {",
                        "        dword curStar = GalaxyStar(i);",
                        "        int countStarPlanets = StarPlanets(curStar);",
                        "        for (j = 0; j < countStarPlanets; j = j + 1) {",
                        "            dword curPlanet = StarPlanets(curStar, j);",
                        "            if (PlanetOwner(curPlanet) == 6) {",
                        "                int chanceToPlace = round(PortionInDiapason(difficulty, 1, 10, 25, 15));",
                        "                if (chanceToPlace >= RndObject(1, 100, curPlanet)) {",
                        "                    int maxNumOfStacks = round(PortionInDiapason(difficulty, 1, 4, 3, 1));",
                        "                    int numOfStacks = RndObject(1, maxNumOfStacks, curPlanet);",
                        "                    int minNumOfMaterialInStack = round(PortionInDiapason(difficulty, 4, 5, 2, 1));",
                        "                    int maxNumOfMaterialInStack = round(PortionInDiapason(difficulty, 1, 10, 5, 2));",
                        "                    for (k = 0; k < numOfStacks; k = k + 1) {",
                        "                        int numOfMaterialInStack = RndObject(minNumOfMaterialInStack, maxNumOfMaterialInStack, curPlanet);",
                        "                        dword material = CreateBertorMaterial(numOfMaterialInStack, GetBertorMaterialCost());",
                        "                        AddItemToPlanet(curPlanet, material);",
                        "                    }",
                        "                }",
                        "            }",
                        "        }",
                        "    }",
                        "}",
                        "",
                        "function BertorQuestPhase3FindTargetPlanet() { //находит и возвращает планету в ближайшей доминаторской системе к БД",
                        "    dword targetPlanet = 0;",
                        "    dword DBStar = ShipStar(GetDB());",
                        "    int countStars = GalaxyStars();",
                        "    for (i = 1; i < countStars && targetPlanet == 0; i = i + 1) {",
                        "        dword curStar = StarNearbyStars(DBStar, i);",
                        "        if (IsStarOwnerDomik(curStar)) {",
                        "            targetPlanet = FindPlanet(curStar, 'NotNone');",
                        "        }",
                        "    }",
                        "    result = targetPlanet;",
                        "}",
                        "",
                        "function BertorQuestPhase3PrepareAttack(biggerOne) { //подготавливает атаку (создает корабли, засовывает их в группу)",
                        "    dword targetStar = PlanetToStar(IdToPlanet(arrBertorQuestData['scientistPlanetId']));",
                        "    int countStars = GalaxyStars();",
                        "    int numOfDesiredStars = 3 + biggerOne;",
                        "    unknown arrCoalStars = newarray(1);",
                        "    ArrayDelete(arrCoalStars, 0);",
                        "    for (i = 1; i < countStars && ArrayDim(arrCoalStars) < numOfDesiredStars; i = i + 1) {",
                        "        dword curStar = StarNearbyStars(targetStar, i);",
                        "        if (IsStarOwnerCoal(curStar) && !StarBattle(curStar))",
                        "            ArrayAdd(arrCoalStars, curStar);",
                        "    }",
                        "    int numOfCoalStars = ArrayDim(arrCoalStars);",
                        "    int numOfDomiks = 2 + upgradeSpawn / 2;",
                        "    int numOfWarriors = 3 + numOfCoalStars * 2;",
                        "    if (biggerOne) {",
                        "        numOfDomiks = 5 + upgradeSpawn / 2;",
                        "        numOfWarriors = 5 + numOfCoalStars * 2;",
                        "    }",
                        "    dword DB = GetDB();",
                        "    dword DBStar = ShipStar(GetDB());",
                        "    dword DBPlanet = NearCivilPlanet(DB);",
                        "    if (DB) {",
                        "        for (int x = 0; x < numOfDomiks; x = x + 1) {",
                        "            int domikPowerPoints = GetStarDomiksPower(DBStar);",
                        "            int domikPower = GetPowerFromPowerPoints(domikPowerPoints);",
                        "            dword domik = StdAlgorithmBuyDomik(DBPlanet, domikPower, -1, 0);",
                        "            TransferShip(domik, DB);",
                        "            ShipJoin(gBertorQuestAttack, domik);",
                        "            SetData(Id(arrCoalStars[0]) - 1, 0, domik);",
                        "            SetData(CurTurn() + 40, 1, domik);",
                        "            SetData(1, 2, domik);",
                        "        }",
                        "    }",
                        "    if (numOfCoalStars) {",
                        "        for (i = 0; i < numOfWarriors; i = i + 1) {",
                        "            dword randStar = arrCoalStars[Rnd(0, numOfCoalStars - 1)];",
                        "            dword randPlanet = FindPlanet(randStar, 'NotNone');",
                        "            dword warrior = BuyWarrior(randPlanet, 150);",
                        "            ShipRefit(warrior);",
                        "            ShipRefit(warrior);",
                        "            ShipRefit(warrior);",
                        "            ShipJoin(gBertorQuestAttack, warrior);",
                        "            SetData(Id(arrCoalStars[0]) - 1, 0, warrior);",
                        "            SetData(CurTurn() + 40, 1, warrior);",
                        "            SetData(0, 2, warrior);",
                        "            if (biggerOne)",
                        "                ShipImproveItems(warrior, 3);",
                        "        }",
                        "        if (biggerOne) {",
                        "            randStar = arrCoalStars[0];",
                        "            randPlanet = FindPlanet(randStar, 'NotNone');",
                        "            warrior = BuyBigWarrior(randPlanet, 200);",
                        "            ShipRefit(warrior);",
                        "            ShipRefit(warrior);",
                        "            ShipRefit(warrior);",
                        "            ShipImproveItems(warrior, 5);",
                        "            ShipJoin(gBertorQuestAttack, warrior);",
                        "            SetData(Id(arrCoalStars[0]) - 1, 0, warrior);",
                        "            SetData(CurTurn() + 40, 1, warrior);",
                        "            SetData(0, 2, warrior);",
                        "        }",
                        "    }",
                        "}",
                        "",
                        "function GetBertorQuestPhase3AttackCooldown() { //возвращает количество дней для подготовки к следующей атаке",
                        "    int daysCount = Rnd(130, 140) - 3 * upgradeActive;",
                        "    result = daysCount;",
                        "}",
                        "",
                        "function BertorQuestPhase3PrepareTargetStar() { //увеличивает количество доминаторов в системе до 20",
                        "    dword targetStar = PlanetToStar(IdToPlanet(arrBertorQuestData['scientistPlanetId']));",
                        "    int targetStarSerie = StarSeries(targetStar);",
                        "    int countShipsStar = StarShips(targetStar);",
                        "    int countOfDomiks = 0;",
                        "    for (i = 0; i < countShipsStar; i = i + 1) {",
                        "        dword curShip = StarShips(targetStar, i);",
                        "        if (IsShipOwnerDomik(curShip) == targetStarSerie + 1) {",
                        "            countOfDomiks = countOfDomiks + 1;",
                        "        }",
                        "    }",
                        "    for (i = countOfDomiks; i < 20; i = i + 1) {",
                        "        dword randPlanet = FindPlanet(targetStar, 'NotNone');",
                        "        BuyDomikExtremal(randPlanet);",
                        "    }",
                        "}",
                        "",
                        "function GetPlayerBertorHullRequirement(resourceType, level) { //возвращает количество необходимого ресурса или времени для улучшения корпуса бертора",
                        "    //level - тот уровень С которого переходим",
                        "    int difficulty = arrDifficultLevels['Breakdown'] / 50;",
                        "    if (resourceType == 0) { //деньги",
                        "        int needMoney = 10000 + round(0.06 * RangersCapital());",
                        "        if (needMoney > 25000)",
                        "            needMoney = 25000 + round((0.06 * RangersCapital() - 10000) / 2);",
                        "        needMoney = GetIntByGeomLaw(needMoney, level - 1 + difficulty - 1, 1.2);",
                        "        result = needMoney;",
                        "    }",
                        "    else if (resourceType == 1) { //ноды",
                        "        int needNod = 30;",
                        "        needNod = GetIntByGeomLaw(needNod, level - 1 + difficulty - 1, 1.2);",
                        "        result = needNod;",
                        "    }",
                        "    else if (resourceType == 2) { //материал",
                        "        int needMaterial = 3 + level * 2;",
                        "        result = needMaterial;",
                        "    }",
                        "    else if (resourceType == 3) { //время",
                        "        difficulty = arrDifficultLevels['Science'] / 50;",
                        "        int turns = 20 + level * 2;",
                        "        turns = GetIntByGeomLaw(turns, difficulty - 1, 1.25);",
                        "        if (isScriptTest)",
                        "            turns = 3;",
                        "        result = turns;",
                        "    }",
                        "}",
                        "function PutShipInHyperspace(ship) { //помещает корабль в гиперпространство навечно",
                        "    dword starShip=ShipStar(ship);",
                        "    dword starFrom=GalaxyStar(0);",
                        "    MakeShipEnterStar(ship, starShip, starFrom, 60000);",
                        "}",
                        "",
                        "function TakeOffStraightFromShip(ship, carrier) { //перемещаем корабль на авианосец и приказываем ему взлететь с него по прямой траектории",
                        "    int x = CoordX(carrier);",
                        "    int y = CoordY(carrier);",
                        "    TransferShip(ship, NearCivilPlanet(carrier));",
                        "    OrderTakeOff(ship);",
                        "    ShipSetCoords(ship, x, y);",
                        "    float ugol = 0.01 * Rnd(0, 200);",
                        "    ShipAngle(ship, ugol * 180 + 90);",
                        "    //int radius = PortionInDiapason(ShipSpeed(ship), 150, 1000, 150, 300);",
                        "    int radius = 200;",
                        "    x = round(cos(ugol * pi) * radius + x);",
                        "    y = round(sin(ugol * pi) * radius + y);",
                        "    OrderMove(ship, x, y);",
                        "    ShipOrder(ship, 5);",
                        "}",
                        "function ModsCompatibility(ship, shipType) {",
                        "    if (arrActiveMods['EvoArmada'] == 1) {",
                        "        EvoArmadaAddExtraAttacksToShip(ship, shipType);",
                        "    }",
                        "    if (arrActiveMods['ShuDomiks'] == 1) {",
                        "        ShuDomiksMainUpgrade(ship);",
                        "    }",
                        "}",
                        "",
                        "function ExpPanelStart() { //вызывается при подключении мода",
                        "    for (i = 0; i < 10; i = i + 1) {",
                        "        InterfaceState('StarMap', 'ZelDomiks_Panel_PlayerBertor_' + i, 0); //записываем оверрайд",
                        "    }",
                        "}",
                        "",
                        "function ExpPanelPlayerBertorReadyKligs() { //меняет панельку бертора где показывается количество построенных клигов",
                        "    if (IsPlayerUseBertorHull()) {",
                        "        if (InterfaceState('StarMap', 'TickHullModeSwitcher') == -1)",
                        "            InterfaceState('StarMap', 'TickHullModeSwitcher', 0);",
                        "        if (InterfaceState('StarMap', 'ZelDomiks_Panel_PlayerBertor_0') == 0)",
                        "            InterfaceState('StarMap', 'ZelDomiks_Panel_PlayerBertor_0', 1);",
                        "        int readyKligsCount = ShipCustomShipInfoData(Player(), 'ZelDomiks_BertorInfo', 3);",
                        "        int prevReadyKligsCount = 0;",
                        "        for (i = 1; i < 10; i = i + 1) {",
                        "            if (InterfaceState('StarMap', 'ZelDomiks_Panel_PlayerBertor_' + i) == 1)",
                        "                prevReadyKligsCount = i;",
                        "        }",
                        "        if (readyKligsCount != prevReadyKligsCount) {",
                        "            if (prevReadyKligsCount > 0)",
                        "                InterfaceState('StarMap', 'ZelDomiks_Panel_PlayerBertor_' + prevReadyKligsCount, 0);",
                        "            if (readyKligsCount > 0)",
                        "                InterfaceState('StarMap', 'ZelDomiks_Panel_PlayerBertor_' + min(9, readyKligsCount), 1);",
                        "        }",
                        "    }",
                        "    else if (InterfaceState('StarMap', 'ZelDomiks_Panel_PlayerBertor_0') == 1) {",
                        "        InterfaceState('StarMap', 'ZelDomiks_Panel_PlayerBertor_0', 0);",
                        "        if (InterfaceState('StarMap', 'TickHullModeSwitcher') == 0)",
                        "            InterfaceState('StarMap', 'TickHullModeSwitcher', -1);",
                        "    }",
                        "}",
                        "",
                        "function EvoArmadaStart() { //вызывается при подключении мода",
                        "    dword ship;",
                        "    int groupCount = GroupCount(gDomiks);",
                        "    for (i = 0; i < groupCount; i = i + 1) {",
                        "        ship = GroupShip(gDomiks, i);",
                        "        EvoArmadaAddExtraAttacksToShip(ship, 0);",
                        "    }",
                        "    groupCount = GroupCount(gBertors);",
                        "    for (i = 0; i < groupCount; i = i + 1) {",
                        "        ship = GroupShip(gBertors, i);",
                        "        EvoArmadaAddExtraAttacksToShip(ship, 0);",
                        "    }",
                        "    groupCount = GroupCount(gKligs);",
                        "    for (i = 0; i < groupCount; i = i + 1) {",
                        "        ship = GroupShip(gKligs, i);",
                        "        EvoArmadaAddExtraAttacksToShip(ship, 0);",
                        "    }",
                        "    groupCount = GroupCount(gNisper);",
                        "    for (i = 0; i < groupCount; i = i + 1) {",
                        "        ship = GroupShip(gNisper, i);",
                        "        EvoArmadaAddExtraAttacksToShip(ship, 0);",
                        "    }",
                        "    groupCount = GroupCount(gDomiksBase);",
                        "    for (i = 0; i < groupCount; i = i + 1) {",
                        "        ship = GroupShip(gDomiksBase, i);",
                        "        EvoArmadaAddExtraAttacksToShip(ship, 1);",
                        "    }",
                        "    groupCount = GroupCount(gFactories);",
                        "    for (i = 0; i < groupCount; i = i + 1) {",
                        "        ship = GroupShip(gFactories, i);",
                        "        EvoArmadaAddExtraAttacksToShip(ship, 2);",
                        "    }",
                        "}",
                        "",
                        "function EvoArmadaAddExtraAttacksToShip(ship, shipType) { //функция навешивания дополнительных залпов кораблям",
                        "    dword hull = ShipItems(ship, 0);",
                        "    int hull_level = ItemLevel(hull);",
                        "    int GeneralDiffLevel = arrDifficultLevels['Average'] / 50;",
                        "    int ShuDomiksInit = arrActiveMods['ShuDomiks'];",
                        "    dword item;",
                        "    int bon;",
                        "    if (shipType == 1) { //станции (сейчас есть только БД)",
                        "        ItemExtraSpecialsAddByType(hull, FindBonusByNameInCfg('EvoArmada_ExtraSpecialsLineBreak'));",
                        "        tint = round((3 * GeneralDiffLevel) + (3 * PortionInDiapason(hull_level, 1, 8, 1, 10)));",
                        "        ItemExtraSpecialsAddByType(hull, FindBonusByNameInCfg('EvoArmada_bonWRadius'), tint);",
                        "        tint = round((0.5 * GeneralDiffLevel) + (0.5 * PortionInDiapason(hull_level, 1, 8, 1, 10)));",
                        "        ItemExtraSpecialsAddByType(hull, FindBonusByNameInCfg('EvoArmada_bonHull'), tint);",
                        "",
                        "        ShipSpecialBonuses(ship, bonAttacks, 2);",
                        "        //Вешаем инфошку для пересчёта числа доп. залпов при стрельбе крупных кораблей по более мелким судам",
                        "        ShipAddCustomShipInfo(ship, 'EvoArmada_CapitalShipInfos', 'NoShow', 2);",
                        "        //Также повышаем всем станциям количество HP",
                        "        ItemSize(hull, round(1.0 * ItemSize(hull) * (1.0 + (1.0 * GeneralDiffLevel))));",
                        "        //И значительно снижаем получаемый от астероидов урон",
                        "        ShipSpecialBonuses(ship, bonResistAsteroid, 75);",
                        "    }",
                        "    else if (shipType == 0) { //доминаторы и босс Ниспер",
                        "        int sub_type = ShipCustomShipInfoData(ship, 'ZelDomiks_DomInfo', 1);",
                        "        if(!ShuDomiksInit)",
                        "        {",
                        "            //Эквентор",
                        "            if(sub_type == 1)",
                        "            {",
                        "                //Проводим всю эту хероборию чтобы не вешать на доминатора валидный акрин и не ломать его скин",
                        "                tint = FindBonusByNameInCfg('EvoArmada_EquantorDomHull');",
                        "                bon = EqModule(hull);",
                        "                if(~bon) ModuleToEquipment(-1, hull);",
                        "                ModuleToEquipment(tint, hull);",
                        "                EqModule(hull, -1);",
                        "                if(~bon) ModuleToEquipment(bon, hull);",
                        "                //После чего вешаем на него чисто текстовый акрин",
                        "                if(HullSpecial(hull) == -1) HullSpecial(hull, tint);",
                        "",
                        "                ItemExtraSpecialsAddByType(hull, FindBonusByNameInCfg('EvoArmada_ExtraSpecialsLineBreak'));",
                        "                //Эквентору вешаем бонус на силу энергетических орудий и броню",
                        "                tint = round((1.8 * GeneralDiffLevel / 2) + (1.8 * PortionInDiapason(hull_level, 1, 8, 1, 10) / 2));",
                        "                ItemExtraSpecialsAddByType(hull, FindBonusByNameInCfg('EvoArmada_bonWEnergy'), tint);",
                        "                tint = round((0.8 * GeneralDiffLevel / 2) + (0.8 * PortionInDiapason(hull_level, 1, 8, 1, 10) / 2));",
                        "                ItemExtraSpecialsAddByType(hull, FindBonusByNameInCfg('EvoArmada_bonHull'), tint);",
                        "",
                        "                ShipSpecialBonuses(ship, bonAttacks, 3);",
                        "                //Вешаем инфошку для пересчёта числа доп. залпов при стрельбе крупных кораблей по более мелким судам",
                        "                ShipAddCustomShipInfo(ship, 'EvoArmada_CapitalShipInfos', 'NoShow', 3);",
                        "",
                        "                //Ограничиваем максимальный уровень навыка атаки",
                        "                if(ShipSkill(ship, 'Accuracy') > 2) ShipSkill(ship, 'Accuracy', RndObject(2, 3, ship));",
                        "            }",
                        "            //Ургант",
                        "            else if(sub_type == 2)",
                        "            {",
                        "                //Проводим всю эту хероборию чтобы не вешать на доминатора валидный акрин и не ломать его скин",
                        "                tint = FindBonusByNameInCfg('EvoArmada_UrgantDomHull');",
                        "                bon = EqModule(hull);",
                        "                if(~bon) ModuleToEquipment(-1, hull);",
                        "                ModuleToEquipment(tint, hull);",
                        "                EqModule(hull, -1);",
                        "                if(~bon) ModuleToEquipment(bon, hull);",
                        "                //После чего вешаем на него чисто текстовый акрин",
                        "                if(HullSpecial(hull) == -1) HullSpecial(hull, tint);",
                        "",
                        "                ItemExtraSpecialsAddByType(hull, FindBonusByNameInCfg('EvoArmada_ExtraSpecialsLineBreak'));",
                        "                //Урганту вешаем бонус на силу осколочных орудий и ГЗП",
                        "                tint = round((1.8 * GeneralDiffLevel / 2) + (1.8 * PortionInDiapason(hull_level, 1, 8, 1, 10) / 2));",
                        "                ItemExtraSpecialsAddByType(hull, FindBonusByNameInCfg('EvoArmada_bonWSplinter'), tint);",
                        "                tint = round((1.5 * GeneralDiffLevel / 2) + (1.5 * PortionInDiapason(hull_level, 1, 8, 1, 10) / 2));",
                        "                ItemExtraSpecialsAddByType(hull, FindBonusByNameInCfg('EvoArmada_bonDef'), tint);",
                        "                ShipSpecialBonuses(ship, bonAttacks, 1);",
                        "                ShipSkill(ship, 'Accuracy', ShipSkill(ship, 'Accuracy') + 2);",
                        "            }",
                        "            //Смерш",
                        "            else if(sub_type == 3)",
                        "            {",
                        "                //Проводим всю эту хероборию чтобы не вешать на доминатора валидный акрин и не ломать его скин",
                        "                tint = FindBonusByNameInCfg('EvoArmada_SmershDomHull');",
                        "                bon = EqModule(hull);",
                        "                if(~bon) ModuleToEquipment(-1, hull);",
                        "                ModuleToEquipment(tint, hull);",
                        "                EqModule(hull, -1);",
                        "                if(~bon) ModuleToEquipment(bon, hull);",
                        "                //После чего вешаем на него чисто текстовый акрин",
                        "                if(HullSpecial(hull) == -1) HullSpecial(hull, tint);",
                        "",
                        "                ItemExtraSpecialsAddByType(hull, FindBonusByNameInCfg('EvoArmada_ExtraSpecialsLineBreak'));",
                        "                //Смершу вешаем бонус на силу ракетных орудий и дальность стрельбы, а также повышаем навык точности",
                        "                tint = GeneralDiffLevel + PortionInDiapason(hull_level, 1, 8, 1, 10);",
                        "                ItemExtraSpecialsAddByType(hull, FindBonusByNameInCfg('EvoArmada_bonWMissile'), tint);",
                        "                tint = (5 * GeneralDiffLevel) + (5 * PortionInDiapason(hull_level, 1, 8, 1, 10));",
                        "                ItemExtraSpecialsAddByType(hull, FindBonusByNameInCfg('EvoArmada_bonWRadius'), tint);",
                        "                ShipSkill(ship, 'Accuracy', ShipSkill(ship, 'Accuracy') + 2);",
                        "            }",
                        "            //Менок",
                        "            else if(sub_type == 4)",
                        "            {",
                        "                //Проводим всю эту хероборию чтобы не вешать на доминатора валидный акрин и не ломать его скин",
                        "                tint = FindBonusByNameInCfg('EvoArmada_MenocDomHull');",
                        "                bon = EqModule(hull);",
                        "                if(~bon) ModuleToEquipment(-1, hull);",
                        "                ModuleToEquipment(tint, hull);",
                        "                EqModule(hull, -1);",
                        "                if(~bon) ModuleToEquipment(bon, hull);",
                        "                //После чего вешаем на него чисто текстовый акрин",
                        "                if(HullSpecial(hull) == -1) HullSpecial(hull, tint);",
                        "",
                        "                ItemExtraSpecialsAddByType(hull, FindBonusByNameInCfg('EvoArmada_ExtraSpecialsLineBreak'));",
                        "                //Менку вешаем бонусы на силу энергетического и ракетного оружия, а также повышаем навык точности",
                        "                tint = GeneralDiffLevel + PortionInDiapason(hull_level, 1, 8, 1, 10);",
                        "                ItemExtraSpecialsAddByType(hull, FindBonusByNameInCfg('EvoArmada_bonWEnergy'), tint);",
                        "                ItemExtraSpecialsAddByType(hull, FindBonusByNameInCfg('EvoArmada_bonWMissile'), tint);",
                        "                ShipSkill(ship, 'Accuracy', ShipSkill(ship, 'Accuracy') + 1);",
                        "                ShipSkill(ship, 'Mobility', ShipSkill(ship, 'Mobility') + 2);",
                        "            }",
                        "            //Штип",
                        "            else if(sub_type == 5)",
                        "            {",
                        "                //Проводим всю эту хероборию чтобы не вешать на доминатора валидный акрин и не ломать его скин",
                        "                tint = FindBonusByNameInCfg('EvoArmada_ShtipDomHull');",
                        "                bon = EqModule(hull);",
                        "                if(~bon) ModuleToEquipment(-1, hull);",
                        "                ModuleToEquipment(tint, hull);",
                        "                EqModule(hull, -1);",
                        "                if(~bon) ModuleToEquipment(bon, hull);",
                        "                //После чего вешаем на него чисто текстовый акрин",
                        "                if(HullSpecial(hull) == -1) HullSpecial(hull, tint);",
                        "",
                        "                ItemExtraSpecialsAddByType(hull, FindBonusByNameInCfg('EvoArmada_ExtraSpecialsLineBreak'));",
                        "                //Штипу вешаем бонус на скорость и повышаем навык манёвренности",
                        "                tint = (10 * GeneralDiffLevel) + (10 * PortionInDiapason(hull_level, 1, 8, 1, 10));",
                        "                ItemExtraSpecialsAddByType(hull, FindBonusByNameInCfg('EvoArmada_bonSpeed'), tint);",
                        "                ShipSkill(ship, 'Mobility', ShipSkill(ship, 'Mobility') + 3);",
                        "            }",
                        "            //Бертор",
                        "            else if(sub_type == 6)",
                        "            {",
                        "                //Проводим всю эту хероборию чтобы не вешать на доминатора валидный акрин и не ломать его скин",
                        "                tint = FindBonusByNameInCfg('EvoArmada_BertorDomHull');",
                        "                bon = EqModule(hull);",
                        "                if(~bon) ModuleToEquipment(-1, hull);",
                        "                ModuleToEquipment(tint, hull);",
                        "                EqModule(hull, -1);",
                        "                if(~bon) ModuleToEquipment(bon, hull);",
                        "                //После чего вешаем на него чисто текстовый акрин",
                        "                if(HullSpecial(hull) == -1) HullSpecial(hull, tint);",
                        "",
                        "                ItemExtraSpecialsAddByType(hull, FindBonusByNameInCfg('EvoArmada_ExtraSpecialsLineBreak'));",
                        "                //Бертору вешаем бонус на броню",
                        "                tint = round((1.2 * GeneralDiffLevel / 2) + (1.2 * PortionInDiapason(hull_level, 1, 8, 1, 10) / 2));",
                        "                ItemExtraSpecialsAddByType(hull, FindBonusByNameInCfg('EvoArmada_bonHull'), tint);",
                        "",
                        "                ShipSpecialBonuses(ship, bonAttacks, 4);",
                        "                //Вешаем инфошку для пересчёта числа доп. залпов при стрельбе крупных кораблей по более мелким судам",
                        "                ShipAddCustomShipInfo(ship, 'EvoArmada_CapitalShipInfos', 'NoShow', 4);",
                        "",
                        "                //Ограничиваем максимальный уровень навыка атаки",
                        "                if(ShipSkill(ship, 'Accuracy') > 1) ShipSkill(ship, 'Accuracy', RndObject(1, 2, ship));",
                        "            }",
                        "            //Клиг",
                        "            else if(sub_type == 7)",
                        "            {",
                        "                //Проводим всю эту хероборию чтобы не вешать на доминатора валидный акрин и не ломать его скин",
                        "                tint = FindBonusByNameInCfg('EvoArmada_KligDomHull');",
                        "                bon = EqModule(hull);",
                        "                if(~bon) ModuleToEquipment(-1, hull);",
                        "                ModuleToEquipment(tint, hull);",
                        "                EqModule(hull, -1);",
                        "                if(~bon) ModuleToEquipment(bon, hull);",
                        "                //После чего вешаем на него чисто текстовый акрин",
                        "                if(HullSpecial(hull) == -1) HullSpecial(hull, tint);",
                        "",
                        "                ItemExtraSpecialsAddByType(hull, FindBonusByNameInCfg('EvoArmada_ExtraSpecialsLineBreak'));",
                        "                //Клигу вешаем бонус на скорость",
                        "                tint = (10 * GeneralDiffLevel) + (10 * PortionInDiapason(hull_level, 1, 8, 1, 10));",
                        "                ItemExtraSpecialsAddByType(hull, FindBonusByNameInCfg('EvoArmada_bonSpeed'), tint);",
                        "                ShipSkill(ship, 'Mobility', ShipSkill(ship, 'Mobility') + 4);",
                        "            }",
                        "        }",
                        "        if (sub_type == 0) {",
                        "            ItemExtraSpecialsAddByType(hull, FindBonusByNameInCfg('EvoArmada_ExtraSpecialsLineBreak'));",
                        "            //Вешаем Блазеру бонус на силу всех типов орудий и усиливаем броню",
                        "            tint = (2 * GeneralDiffLevel) + 10;",
                        "            ItemExtraSpecialsAddByType(hull, FindBonusByNameInCfg('EvoArmada_bonWEnergy'), tint);",
                        "            ItemExtraSpecialsAddByType(hull, FindBonusByNameInCfg('EvoArmada_bonWSplinter'), tint);",
                        "            ItemExtraSpecialsAddByType(hull, FindBonusByNameInCfg('EvoArmada_bonWMissile'), tint);",
                        "            SetEquipmentStats(hull, GetEquipmentStats(hull, 0) + (GeneralDiffLevel + 5), 0);",
                        "            //Увеличиваем размер корпуса Блазера",
                        "            ItemSize(hull, round(ItemSize(hull) * (1.0 + (0.5 * GeneralDiffLevel))));",
                        "            HullHP(hull, ItemSize(hull));",
                        "",
                        "            //Также увеличиваем число его залпов",
                        "            ShipSpecialBonuses(ship, bonAttacks, 6);",
                        "        }",
                        "    }",
                        "    else if (shipType == 2) { //фабрики доминаторов",
                        "        ItemExtraSpecialsAddByType(hull, FindBonusByNameInCfg('EvoArmada_ExtraSpecialsLineBreak'));",
                        "        tint = round((0.3 * GeneralDiffLevel) + (0.3 * PortionInDiapason(hull_level, 1, 8, 1, 10)));",
                        "        ItemExtraSpecialsAddByType(hull, FindBonusByNameInCfg('EvoArmada_bonHull'), tint);",
                        "",
                        "        ShipSpecialBonuses(ship, bonAttacks, 1);",
                        "        //Также повышаем всем станциям количество HP",
                        "        ItemSize(hull, round(1.0 * ItemSize(hull) * 2.0));",
                        "        //И значительно снижаем получаемый от астероидов урон",
                        "        ShipSpecialBonuses(ship, bonResistAsteroid, 50);",
                        "    }",
                        "    HullHP(hull, ItemSize(hull));",
                        "    ShipImproveItems(ship, 0);",
                        "}",
                        "",
                        "function ShuDomiksStart() { //вызывается при подключении мода",
                        "    dword ship;",
                        "    int groupCount = GroupCount(gDomiks);",
                        "    for (i = 0; i < groupCount; i = i + 1) {",
                        "        ship = GroupShip(gDomiks, i);",
                        "        ShuDomiksMainUpgrade(ship);",
                        "    }",
                        "    groupCount = GroupCount(gBertors);",
                        "    for (i = 0; i < groupCount; i = i + 1) {",
                        "        ship = GroupShip(gBertors, i);",
                        "        ShuDomiksMainUpgrade(ship);",
                        "    }",
                        "    groupCount = GroupCount(gKligs);",
                        "    for (i = 0; i < groupCount; i = i + 1) {",
                        "        ship = GroupShip(gKligs, i);",
                        "        ShuDomiksMainUpgrade(ship);",
                        "    }",
                        "}",
                        "",
                        "function ShuDomiksMainUpgrade(ship) { //функция усиления доминаторов",
                        "    dword hull = ShipItems(ship, 0);",
                        "    str bon_mod = 'ShuDomiks';",
                        "    int sub_type = ShipCustomShipInfoData(ship, 'ZelDomiks_DomInfo', 1);",
                        "    int GeneralDiffLevel = arrDifficultLevels['Average'] / 50;",
                        "    int hull_level = ItemLevel(hull);",
                        "    int EvoArmadaInit = arrActiveMods['EvoArmada'];",
                        "",
                        "    if(EvoArmadaInit) bon_mod = 'EvoArmada';",
                        "",
                        "    //Клиг",
                        "    if(sub_type == 7)",
                        "    {",
                        "        //Проводим всю эту хероборию чтобы не вешать на доминатора валидный акрин и не ломать его скин",
                        "        tint3 = FindBonusByNameInCfg(bon_mod + '_KligDomHull');",
                        "        ModuleToEquipment(tint3, hull);",
                        "        EqModule(hull, -1);",
                        "        HullSpecial(hull, tint3);",
                        "        ItemExtraSpecialsAddByType(hull, FindBonusByNameInCfg('ShuDomiks_ExtraSpecialsLineBreak'));",
                        "        //Клигу вешаем бонус на скорость",
                        "        tint3 = (10 * GeneralDiffLevel) + (10 * PortionInDiapason(hull_level, 1, 8, 1, 10));",
                        "        ItemExtraSpecialsAddByType(hull, FindBonusByNameInCfg('ShuDomiks_bonSpeed'), tint3);",
                        "        ShipSkill(ship, 'Mobility', ShipSkill(ship, 'Mobility') + 4);",
                        "    }",
                        "    else if(sub_type == 5)",
                        "    {",
                        "        tint3 = FindBonusByNameInCfg(bon_mod + '_ShtipDomHull');",
                        "        ModuleToEquipment(tint3, hull);",
                        "        EqModule(hull, -1);",
                        "        HullSpecial(hull, tint3);",
                        "        ItemExtraSpecialsAddByType(hull, FindBonusByNameInCfg('ShuDomiks_ExtraSpecialsLineBreak'));",
                        "        //Штипу вешаем бонус на скорость и повышаем навык манёвренности",
                        "        tint3 = (10 * GeneralDiffLevel) + (10 * PortionInDiapason(hull_level, 1, 8, 1, 10));",
                        "        ItemExtraSpecialsAddByType(hull, FindBonusByNameInCfg('ShuDomiks_bonSpeed'), tint3);",
                        "        ShipSkill(ship, 'Mobility', ShipSkill(ship, 'Mobility') + 3);",
                        "    }",
                        "    //Менок",
                        "    else if(sub_type == 4)",
                        "    {",
                        "        tint3 = FindBonusByNameInCfg(bon_mod + '_MenocDomHull');",
                        "        ModuleToEquipment(tint3, hull);",
                        "        EqModule(hull, -1);",
                        "        HullSpecial(hull, tint3);",
                        "        ItemExtraSpecialsAddByType(hull, FindBonusByNameInCfg('ShuDomiks_ExtraSpecialsLineBreak'));",
                        "        //Менку вешаем бонусы на силу энергетического и ракетного оружия, а также повышаем навык точности",
                        "        tint3 = GeneralDiffLevel + PortionInDiapason(hull_level, 1, 8, 1, 10);",
                        "        ItemExtraSpecialsAddByType(hull, FindBonusByNameInCfg('ShuDomiks_bonWEnergy'), tint3);",
                        "        ItemExtraSpecialsAddByType(hull, FindBonusByNameInCfg('ShuDomiks_bonWMissile'), tint3);",
                        "        ShipSkill(ship, 'Accuracy', ShipSkill(ship, 'Accuracy') + 1);",
                        "        ShipSkill(ship, 'Mobility', ShipSkill(ship, 'Mobility') + 2);",
                        "    }",
                        "    //Смерш",
                        "    else if(sub_type == 3)",
                        "    {",
                        "        tint3 = FindBonusByNameInCfg(bon_mod + '_SmershDomHull');",
                        "        ModuleToEquipment(tint3, hull);",
                        "        EqModule(hull, -1);",
                        "        HullSpecial(hull, tint3);",
                        "        ItemExtraSpecialsAddByType(hull, FindBonusByNameInCfg('ShuDomiks_ExtraSpecialsLineBreak'));",
                        "        //Смершу вешаем бонус на силу ракетных орудий и дальность стрельбы, а также повышаем навык точности",
                        "        tint3 = GeneralDiffLevel + PortionInDiapason(hull_level, 1, 8, 1, 10);",
                        "        ItemExtraSpecialsAddByType(hull, FindBonusByNameInCfg('ShuDomiks_bonWMissile'), tint3);",
                        "        tint3 = (5 * GeneralDiffLevel) + (5 * PortionInDiapason(hull_level, 1, 8, 1, 10));",
                        "        ItemExtraSpecialsAddByType(hull, FindBonusByNameInCfg('ShuDomiks_bonWRadius'), tint3);",
                        "        ShipSkill(ship, 'Accuracy', ShipSkill(ship, 'Accuracy') + 2);",
                        "    }",
                        "    //Ургант",
                        "    else if(sub_type == 2)",
                        "    {",
                        "        tint3 = FindBonusByNameInCfg(bon_mod + '_UrgantDomHull');",
                        "        ModuleToEquipment(tint3, hull);",
                        "        EqModule(hull, -1);",
                        "        HullSpecial(hull, tint3);",
                        "        ItemExtraSpecialsAddByType(hull, FindBonusByNameInCfg('ShuDomiks_ExtraSpecialsLineBreak'));",
                        "        //Урганту вешаем бонус на силу осколочных орудий и ГЗП",
                        "        tint3 = round((1.8 * GeneralDiffLevel / 2) + (1.8 * PortionInDiapason(hull_level, 1, 8, 1, 10) / 2));",
                        "        ItemExtraSpecialsAddByType(hull, FindBonusByNameInCfg('ShuDomiks_bonWSplinter'), tint3);",
                        "        tint3 = round((1.5 * GeneralDiffLevel / 2) + (1.5 * PortionInDiapason(hull_level, 1, 8, 1, 10) / 2));",
                        "        ItemExtraSpecialsAddByType(hull, FindBonusByNameInCfg('ShuDomiks_bonDef'), tint3);",
                        "        ShipSkill(ship, 'Accuracy', ShipSkill(ship, 'Accuracy') + 2);",
                        "",
                        "        //Если подключён мод EvoArmada, добавляем дополнительные залпы кораблю в этом же цикле (чтоб два раза не перебирать доминаторов в разных модах)",
                        "        if(EvoArmadaInit) ShipSpecialBonuses(ship, bonAttacks, 1);",
                        "    }",
                        "    //Эквентор",
                        "    else if(sub_type == 1)",
                        "    {",
                        "        tint3 = FindBonusByNameInCfg(bon_mod + '_EquantorDomHull');",
                        "        ModuleToEquipment(tint3, hull);",
                        "        EqModule(hull, -1);",
                        "        HullSpecial(hull, tint3);",
                        "        ItemExtraSpecialsAddByType(hull, FindBonusByNameInCfg('ShuDomiks_ExtraSpecialsLineBreak'));",
                        "        //Эквентору вешаем бонус на силу энергетических орудий и броню",
                        "        tint3 = round((1.8 * GeneralDiffLevel / 2) + (1.8 * PortionInDiapason(hull_level, 1, 8, 1, 10) / 2));",
                        "        ItemExtraSpecialsAddByType(hull, FindBonusByNameInCfg('ShuDomiks_bonWEnergy'), tint3);",
                        "        tint3 = round((0.8 * GeneralDiffLevel / 2) + (0.8 * PortionInDiapason(hull_level, 1, 8, 1, 10) / 2));",
                        "        ItemExtraSpecialsAddByType(hull, FindBonusByNameInCfg('ShuDomiks_bonHull'), tint3);",
                        "",
                        "        //Если подключён мод EvoArmada, добавляем дополнительные залпы кораблю в этом же цикле (чтоб два раза не перебирать доминаторов в разных модах)",
                        "        if(EvoArmadaInit)",
                        "        {",
                        "            ShipSpecialBonuses(ship, bonAttacks, 3);",
                        "            //Вешаем инфошку для пересчёта числа доп. залпов при стрельбе крупных кораблей по более мелким судам",
                        "            ShipAddCustomShipInfo(ship, 'EvoArmada_CapitalShipInfos', 'NoShow', 3);",
                        "            //Ограничиваем максимальный уровень навыка атаки (чтобы не так сильно нагибал)",
                        "            if(ShipSkill(ship, 'Accuracy') > 2) ShipSkill(ship, 'Accuracy', RndObject(2, 3, ship));",
                        "        }",
                        "    }",
                        "    //бертор",
                        "    else if(sub_type == 6)",
                        "    {",
                        "        tint3 = FindBonusByNameInCfg(bon_mod + '_BertorDomHull');",
                        "        ModuleToEquipment(tint3, hull);",
                        "        EqModule(hull, -1);",
                        "        HullSpecial(hull, tint3);",
                        "        ItemExtraSpecialsAddByType(hull, FindBonusByNameInCfg('ShuDomiks_ExtraSpecialsLineBreak'));",
                        "        //Бертору вешаем бонус на броню",
                        "        tint3 = round((1.2 * GeneralDiffLevel / 2) + (1.2 * PortionInDiapason(hull_level, 1, 8, 1, 10) / 2));",
                        "        ItemExtraSpecialsAddByType(hull, FindBonusByNameInCfg('ShuDomiks_bonHull'), tint3);",
                        "",
                        "        //Если подключён мод EvoArmada, добавляем дополнительные залпы кораблю в этом же цикле (чтоб два раза не перебирать доминаторов в разных модах)",
                        "        if(EvoArmadaInit)",
                        "        {",
                        "            ShipSpecialBonuses(ship, bonAttacks, 4);",
                        "            //Вешаем инфошку для пересчёта числа доп. залпов при стрельбе крупных кораблей по более мелким судам",
                        "            ShipAddCustomShipInfo(ship, 'EvoArmada_CapitalShipInfos', 'NoShow', 4);",
                        "            //Ограничиваем максимальный уровень навыка атаки (чтобы не так сильно нагибал)",
                        "            if(ShipSkill(ship, 'Accuracy') > 1) ShipSkill(ship, 'Accuracy', RndObject(1, 2, ship));",
                        "        }",
                        "    }",
                        "",
                        "    //Далее пропускаем клигов",
                        "    if(sub_type == 7)",
                        "    {",
                        "        HullHP(hull, ItemSize(hull));",
                        "        ShipImproveItems(ship, 0); //Снимаем возможный перегруз",
                        "        exit;",
                        "    }",
                        "",
                        "    if(GetValueFromScript('Mod_ShuDomiks','UnknownDomAcrynsTimer') == -1)",
                        "    {",
                        "        int ReSupply = 0;",
                        "        int check = 0;",
                        "        int credit_cost = 0;",
                        "        dword cur_item;",
                        "        dword module;",
                        "",
                        "        //Для рандомизации выборки модифицируемого оружия на корабле используется while",
                        "        while(!check)",
                        "        {",
                        "            if(!ShipCntWeapon(ship)) break;",
                        "            cur_item = ShipWeapon(ship, RndObject(1, ShipCntWeapon(ship), ship));",
                        "            if(cur_item)",
                        "            {",
                        "                if(EqSpecial(cur_item) == -1)",
                        "                {",
                        "                    tint3 = ItemType(cur_item);",
                        "                    if(tint3 != t_Weapon16 && tint3 != t_Weapon17 && tint3 != t_Weapon18)",
                        "                    {",
                        "                        //Доминатор получит тем меньше модифицированных пушек, чем выше его уровень деградации после смерти босса",
                        "                        if(RndObject(1, 3, ship) == 2) check = 1;",
                        "                        if(ReSupply == GetValueFromScript('Mod_ShuDomiks','MaxWSup')) check = 1;",
                        "",
                        "                        if(tint3 == t_CustomWeapon)",
                        "                        {",
                        "                            //Если попалось кастомное орудие, но оно не сплэшевый фазер",
                        "                            if(CustomWeaponType(cur_item) != CT('Items.Weapon.CustomWeapon.ShuEmitter.4')) break;",
                        "                        }",
                        "",
                        "                        //Проверки на ММ, чтобы не дублировать имя модуля в названии предмета",
                        "                        module = EqModule(cur_item);",
                        "                        if(~module) ModuleToEquipment(-1, cur_item);",
                        "                        tstr2 = '<color=255,167,84>' + Name(cur_item) + '</color>';",
                        "                        if(~module) ModuleToEquipment(module, cur_item);",
                        "",
                        "                        rand = RndObject(1, 100, ship);",
                        "                        //Штип",
                        "                        if(sub_type == 5)",
                        "                        {",
                        "                            if(rand <= 45) tstr1 = 'SpeedDrop';",
                        "                            else if(rand <= 80) tstr1 = 'Strike';",
                        "                            else tstr1 = 'Quickshot';",
                        "                        }",
                        "                        //Менок",
                        "                        else if(sub_type == 4)",
                        "                        {",
                        "                            if(rand <= 25) tstr1 = 'SpeedDrop';",
                        "                            else if(rand <= 75) tstr1 = 'Strike';",
                        "                            else tstr1 = 'Quickshot';",
                        "                        }",
                        "                        //Смерш",
                        "                        else if(sub_type == 3)",
                        "                        {",
                        "                            if(rand <= 50) tstr1 = 'SpeedDrop';",
                        "                            else if(rand <= 75) tstr1 = 'Strike';",
                        "                            else tstr1 = 'Quickshot';",
                        "                        }",
                        "                        //Ургант",
                        "                        else if(sub_type == 2)",
                        "                        {",
                        "                            if(rand <= 20) tstr1 = 'SpeedDrop';",
                        "                            else if(rand <= 60) tstr1 = 'Strike';",
                        "                            else tstr1 = 'Quickshot';",
                        "                        }",
                        "                        //Эквентор",
                        "                        else if(sub_type == 1)",
                        "                        {",
                        "                            if(rand <= 22) tstr1 = 'SpeedDrop';",
                        "                            else if(rand <= 45) tstr1 = 'Strike';",
                        "                            else tstr1 = 'Quickshot';",
                        "                        }",
                        "                        //Бертор",
                        "                        else if(sub_type == 6) tstr1 = 'Quickshot';",
                        "",
                        "                        //Убрал проверку, т.к. теперь если максимальный урон орудия не может опуститься ниже минимального",
                        "                        //if(tstr1 == 'Quickshot')",
                        "                        //{",
                        "                            //Не накладываем квикшот на орудие в том случае, если дебаф квикшота полностью обнулит его максимальный урон",
                        "                            //if(GetEquipmentStats(cur_item, 0) + CT('MicroModuls.ShuDomiks_' + tstr1 + 'WDomModLocked.bonWMissile') <= 0) continue;",
                        "                        //}",
                        "",
                        "                        if(tint3 == t_CustomWeapon) SpecialToEquipment(FindBonusByNameInCfg('ShuDomiks_' + tstr1 + 'CWDomModLocked'), cur_item);",
                        "                        else SpecialToEquipment(FindBonusByNameInCfg('ShuDomiks_' + tstr1 + 'WDomModLocked'), cur_item);",
                        "",
                        "                        //Не знаю нахера оно тут, пока что просто выключу",
                        "                        //if(GetEquipmentStats(cur_item, 0) < GetEquipmentStats(cur_item, 1)) SetEquipmentStats(cur_item, GetEquipmentStats(cur_item, 1), 0);",
                        "                        SetName(cur_item, tstr2);",
                        "                        ReSupply = ReSupply + 1;",
                        "                    }",
                        "                }",
                        "            }",
                        "            credit_cost = credit_cost + 1;",
                        "            if(credit_cost >= 10) break;",
                        "        }",
                        "",
                        "        ReSupply = 0;",
                        "        check = 0;",
                        "        credit_cost = 0;",
                        "        //Для рандомизации выборки модифицируемого оборудования на корабле используется while",
                        "        while(!check)",
                        "        {",
                        "            cur_item = ShipEqInSlot(ship, RndObject(t_FuelTanks, t_DefGenerator, ship));",
                        "            if(cur_item)",
                        "            {",
                        "                if(EqSpecial(cur_item) == -1)",
                        "                {",
                        "                    //Доминатор получит тем меньше модифицированных вещей, чем выше его уровень деградации после смерти босса",
                        "                    if(RndObject(1, 3, ship) == 2) check = 1;",
                        "                    if(ReSupply == GetValueFromScript('Mod_ShuDomiks','MaxReSup')) check = 1;",
                        "",
                        "                    //Проверки на ММ, чтобы не дублировать имя модуля в названии предмета",
                        "                    module = EqModule(cur_item);",
                        "                    if(~module) ModuleToEquipment(-1, cur_item);",
                        "                    tstr2 = '<color=255,167,84>' + Name(cur_item) + '</color>';",
                        "                    if(~module) ModuleToEquipment(module, cur_item);",
                        "",
                        "                    //Штип",
                        "                    rand = RndObject(1, 100, ship);",
                        "                    if(sub_type == 5)",
                        "                    {",
                        "                        if(rand <= 17) tstr1 = 'Energize';",
                        "                        else if(rand <= 65) tstr1 = 'Glue';",
                        "                        else if(rand <= 87) tstr1 = 'Detriment';",
                        "                        else tstr1 = 'RocketLauncher';",
                        "                    }",
                        "                    //Менок",
                        "                    else if(sub_type == 4)",
                        "                    {",
                        "                        if(rand <= 15) tstr1 = 'Energize';",
                        "                        else if(rand <= 30) tstr1 = 'Glue';",
                        "                        else if(rand <= 70) tstr1 = 'Detriment';",
                        "                        else tstr1 = 'RocketLauncher';",
                        "                    }",
                        "                    //Смерш",
                        "                    else if(sub_type == 3)",
                        "                    {",
                        "                        if(rand <= 13) tstr1 = 'Energize';",
                        "                        else if(rand <= 43) tstr1 = 'Glue';",
                        "                        else if(rand <= 60) tstr1 = 'Detriment';",
                        "                        else tstr1 = 'RocketLauncher';",
                        "                    }",
                        "                    //Ургант",
                        "                    else if(sub_type == 2)",
                        "                    {",
                        "                        if(rand <= 24) tstr1 = 'Energize';",
                        "                        else if(rand <= 42) tstr1 = 'Glue';",
                        "                        else if(rand <= 73) tstr1 = 'Detriment';",
                        "                        else tstr1 = 'RocketLauncher';",
                        "                    }",
                        "                    //Эквентор",
                        "                    else if(sub_type == 1)",
                        "                    {",
                        "                        if(rand <= 20) tstr1 = 'Energize';",
                        "                        else if(rand <= 60) tstr1 = 'Glue';",
                        "                        else if(rand <= 90) tstr1 = 'Detriment';",
                        "                        else tstr1 = 'RocketLauncher';",
                        "                    }",
                        "                    //Бертор",
                        "                    else if(sub_type == 6)",
                        "                    {",
                        "                        if(rand <= 20) tstr1 = 'Energize';",
                        "                        else if(rand <= 50) tstr1 = 'Glue';",
                        "                        else if(rand <= 80) tstr1 = 'Detriment';",
                        "                        else tstr1 = 'RocketLauncher';",
                        "                    }",
                        "",
                        "                    SpecialToEquipment(FindBonusByNameInCfg('ShuDomiks_' + tstr1 + 'EqDomModLocked'), cur_item);",
                        "",
                        "                    tint3 = ItemType(cur_item);",
                        "                    if(tint3 == t_Engine) EquipmentImageName(cur_item, 'EngineDomMod');",
                        "                    else if(tint3 == t_FuelTanks) EquipmentImageName(cur_item, 'FuelTanksDomMod');",
                        "                    else if(tint3 == t_RepairRobot) EquipmentImageName(cur_item, 'RepairRobotDomMod');",
                        "                    else if(tint3 == t_CargoHook) EquipmentImageName(cur_item, 'CargoHookDomMod');",
                        "                    else if(tint3 == t_DefGenerator) EquipmentImageName(cur_item, 'DefGeneratorDomMod');",
                        "                    else if(tint3 == t_Radar) EquipmentImageName(cur_item, 'RadarDomMod');",
                        "                    else if(tint3 == t_Scaner) EquipmentImageName(cur_item, 'ScanerDomMod');",
                        "",
                        "                    SetName(cur_item, tstr2);",
                        "                    ReSupply = ReSupply + 1;",
                        "                }",
                        "            }",
                        "",
                        "            credit_cost = credit_cost + 1;",
                        "            if(credit_cost >= 10) break;",
                        "        }",
                        "    }",
                        "",
                        "    //А здесь происходит случайное улучшение оборудования доминатора",
                        "    //Случайное оборудование и оружие получает случайные улучшения и микромодули",
                        "    //Да-да, именно здесь в доминаторов и попадают все микромодули",
                        "    //Вставляем их уже после установки неизвестных модификаций,",
                        "    //иначе при переустановке имени предмета в него может попасть удвоенное имя установленного ММ",
                        "    int MaxUp = GetValueFromScript('Mod_ShuDomiks','kMaxUpgrade');",
                        "    int MinUp = GetValueFromScript('Mod_ShuDomiks','kMinUpgrade');",
                        "    if(MinUp > MaxUp) MinUp = MaxUp;",
                        "    ShipImproveItems(ship, RndObject(MinUp, MaxUp, ship));",
                        "",
                        "    HullHP(hull, ItemSize(hull));",
                        "    ShipImproveItems(ship, 0); //Снимаем возможный перегруз",
                        "}",
                        "function GetAverageActiveChance() { //возвращает средний шанс (в тысячных долях) активности системы",
                        "    int activeChance = GetIntByGeomLaw(10, upgradeActive, 1.28);",
                        "    int delta = DeltaWin(0);",
                        "    int maxProcCoalStars = GetMaxProcCoalStars();",
                        "    int procCoalStars = GetProcCoalStars();",
                        "    activeChance = round(PortionInDiapason(procCoalStars, 1, maxProcCoalStars, activeChance, 0));",
                        "    activeChance = round(1.0 * activeChance * PortionInDiapason(delta, 0, 10, 1, 0.3));",
                        "    result = activeChance;",
                        "}",
                        "",
                        "function GetAveragePowerPoints() { //возвращает средние очки силы Ниспера на галактику",
                        "    int powerPoints = 1000 + 155 * upgradePower;",
                        "    if (powerPoints > 7000) //излишки силы будут действовать только на клигов и в качестве компенсации за дэльту",
                        "        powerPoints = powerPoints + 5 * (powerPoints - 7000); //поэтому увеличиваем излишок, чтобы хоть как-то забалансить последние улучшения",
                        "    powerPoints = powerPoints + round(PortionInDiapason(CurTurn(), 300, 300 + 365 * 60, 0, 500));",
                        "    result = powerPoints;",
                        "}",
                        "",
                        "function GetAverageSpawnChance() { //возвращает средний шанс (в тысячных долях) спавна домика Ниспера на планете",
                        "    int spawnChance = 200 + 20 * upgradeSpawn;",
                        "    int maxProcCoalStars = GetMaxProcCoalStars();",
                        "    spawnChance = RndByProcStars(1, spawnChance, maxProcCoalStars);",
                        "    result = spawnChance;",
                        "}",
                        "",
                        "function GetAverageSpawnCooldown() { //возвращает среднюю длительность кулдауна на спавн домиков Ниспера в системе",
                        "    int maxProcCoalStars = GetMaxProcCoalStars();",
                        "    int spawnCooldown = max(1, GetIntByGeomLaw(81, upgradeSpawn, 0.81));",
                        "    spawnCooldown = RndByProcStars(spawnCooldown, 1, maxProcCoalStars);",
                        "    result = spawnCooldown;",
                        "}",
                        "",
                        "function GetAverageSpawnPeak() { //возвращает потолок спавна домиков на одну систему",
                        "    int spawnPeak = round(PortionInDiapason(upgradeSpawn, 0, 20, 9, 15));",
                        "    int maxSpawnPeak = round(1.6 * spawnPeak);",
                        "    int maxProcCoalStars = GetMaxProcCoalStars();",
                        "    int procCoalStars = GetProcCoalStars();",
                        "    spawnPeak = round(PortionInDiapason(procCoalStars, 1, maxProcCoalStars, maxSpawnPeak, spawnPeak));",
                        "    result = spawnPeak;",
                        "}",
                        "",
                        "function EveryTurnCalculations() { //ежеходные глобальные расчеты",
                        "    averagePowerPoints = GetAveragePowerPoints();",
                        "    averageActiveChance = GetAverageActiveChance();",
                        "    averageSpawnChance = GetAverageSpawnChance();",
                        "    averageSpawnCooldown = GetAverageSpawnCooldown();",
                        "    averageSpawnPeak = GetAverageSpawnPeak();",
                        "    GTL = GalaxyTechLevel();",
                        "}",
                        "",
                        "function EveryTurnActiveModsCheck() { //каждый ход проверяем какие моды подключены",
                        "    if (arrActiveMods['EvoArmada'] == 0 && arrActiveMods['ShuDomiks'] == 0 && IsScriptActive('Mod_EvoArmada') && IsScriptActive('Mod_ShuDomiks')) {",
                        "        arrActiveMods['EvoArmada'] = 1;",
                        "        arrActiveMods['ShuDomiks'] = 1;",
                        "        ShuDomiksStart();",
                        "    }",
                        "    if (arrActiveMods['EvoArmada'] == 0) {",
                        "        if(IsScriptActive('Mod_EvoArmada')) {",
                        "            arrActiveMods['EvoArmada'] = 1;",
                        "            EvoArmadaStart();",
                        "        }",
                        "    }",
                        "    if (arrActiveMods['ShuDomiks'] == 0) {",
                        "        if(IsScriptActive('Mod_ShuDomiks')) {",
                        "            arrActiveMods['ShuDomiks'] = 1;",
                        "            ShuDomiksStart();",
                        "        }",
                        "    }",
                        "    if (arrActiveMods['ExpPanel'] == 0) {",
                        "        if(BlockExist('ShipInfo.AddInfo.CustomInfos.ExpPanel_infos')) {",
                        "            arrActiveMods['ExpPanel'] = 1;",
                        "            ExpPanelStart();",
                        "        }",
                        "    }",
                        "}",
                        "",
                        "function EveryTurnResearch() { //ежеходная обработка исследований",
                        "    int procent = GetResearchProcent();",
                        "    float researchAdd = 1.0 * procent / 100;",
                        "    AddResearchCount(researchAdd);",
                        "    DecreaseResearchItems();",
                        "}",
                        "",
                        "function EveryTurnStarsLogic() { //ежедневная логика всех систем галактики",
                        "    int countStars = GalaxyStars();",
                        "    for (k = 0; k < countStars; k = k + 1) {",
                        "        dword selectStar = GalaxyStar(k);",
                        "        if (IsStarOwnerCoal(selectStar)) {",
                        "            dword Nisper = GetNisper();",
                        "            if (Nisper) { //активность",
                        "                if (ShipInNormalSpace(Nisper)) {",
                        "                    GetArrFreeDomiksStar(selectStar);",
                        "                    unknown arrFreeDomiksSelectStar = tempArr;",
                        "                    int countFreeDomiksSelectStar = ArrayDim(arrFreeDomiksSelectStar);",
                        "                    int starBattle = StarBattle(selectStar);",
                        "                    if (countFreeDomiksSelectStar > 5 && !starBattle)",
                        "                        TryStarActive(selectStar, arrFreeDomiksSelectStar);",
                        "                }",
                        "            }",
                        "            if (GetDB()) { //спавн домиков",
                        "                int spawnCooldown = arrSpawnCooldown[k];",
                        "                if (spawnCooldown > 1) {",
                        "                    spawnCooldown = spawnCooldown - 1;",
                        "                    arrSpawnCooldown[k] = spawnCooldown;",
                        "                }",
                        "                else if (countFreeDomiksSelectStar < averageSpawnPeak) {",
                        "                    int spawnChance = averageSpawnChance + ((starBattle > 0) * GetAddBattleStarSpawnChance());",
                        "                    dword spawnedDomik = TrySpawnDomik(selectStar, spawnChance);",
                        "                    if (spawnedDomik)",
                        "                        arrSpawnCooldown[k] = averageSpawnCooldown;",
                        "                }",
                        "            }",
                        "        }",
                        "        if (CountIn(gDomiks, selectStar, 1) > 0 || CountIn(gKligs, selectStar, 1) > 0 || CountIn(gBertors, selectStar, 1) > 0)",
                        "            StarDomiksBehaviorOptimization(selectStar);",
                        "    }",
                        "}",
                        "",
                        "function EveryTurnChecks() { //ежеходные проверки всяких событий (в основном, для заданий и продвижения сюжета)",
                        "    dword player = Player();",
                        "    ETC_BlackHoleForBertorsCheck();",
                        "    ETC_BertorQuest();",
                        "    if (ShipInHole(player)) {",
                        "        dword blackHole = ShipOrderObj(player);",
                        "        if (arrBlackHoleForBertorsData['BlackHoleId'] > 0) {",
                        "            if (blackHole == IdToHole(arrBlackHoleForBertorsData['BlackHoleId']))",
                        "                ETC_BlackHoleForBertorsSettings(blackHole);",
                        "        }",
                        "    }",
                        "}",
                        "",
                        "function ETC_BlackHoleForBertorsSettings(blackHole) {",
                        "    dword bertor = IdToShip(arrBlackHoleForBertorsData['TargetBertorId']);",
                        "    int blackHoleSerie = arrBlackHoleForBertorsData['Serie'];",
                        "    int numOfRemainUnresearchedRemains = (arrBertorQuestData['SeriesResearchStatus', 0] != 2) + (arrBertorQuestData['SeriesResearchStatus', 1] != 2) + (arrBertorQuestData['SeriesResearchStatus', 2] != 2);",
                        "    if (!StartAB() && !GABStatus) {",
                        "        int bertorInHole = 0;",
                        "        if (bertor) {",
                        "            if (ShipInHole(bertor) && (blackHole == ShipOrderObj(bertor)))",
                        "                bertorInHole = 1;",
                        "        }",
                        "        if (bertorInHole) {",
                        "            //если ошметки не сданы - добавляем ошметки",
                        "            //в третий, последний раз, позже добавим еще материал бертора",
                        "            if (numOfRemainUnresearchedRemains <= 3 && numOfRemainUnresearchedRemains >= 1) {",
                        "                dword reward = CreateQuestItem('ZelDomiks_UselessBertorRemain' + GetStrSerieName(blackHoleSerie));",
                        "                ItemOwner(reward, 5);",
                        "                ItemSubrace(reward, blackHoleSerie);",
                        "            }",
                        "            else if (numOfRemainUnresearchedRemains == 0) //если все ошметки сданы - выдаем только материал бертора",
                        "                reward = CreateBertorMaterial(Rnd(5, 7), GetBertorMaterialCost());",
                        "            BlackHoleForBertorsABStart(blackHole, reward);",
                        "        }",
                        "        HoleMap(blackHole, 'NoEntry'); //запрещаем повторный вход в ЧД",
                        "        arrBlackHoleForBertorsData['TargetBertorId'] = 0; //обнуляем всех домиков",
                        "        BlackHoleForBertorsResetGroup();",
                        "    }",
                        "    //GABStatus == 2 означает, что это была скриптовая ЧД, а значит все что ниже работает в случае победы над бертором",
                        "    else if(GABStatus == 2) {",
                        "        //если первый раз в такой черной дыре для этой серии, то не добавляем сложность к последующим",
                        "        if (arrBlackHoleForBertorsData['SerieFirstTime', blackHoleSerie]) {",
                        "            arrBlackHoleForBertorsData['SerieFirstTime', blackHoleSerie] = 0;",
                        "            //однако, если это третий вид ЧД, то повышаем, чтобы после того, как игрок протестировал все три вида, они стали сложнее",
                        "            if ((arrBlackHoleForBertorsData['SerieFirstTime', 0] + arrBlackHoleForBertorsData['SerieFirstTime', 1] + arrBlackHoleForBertorsData['SerieFirstTime', 2]) == 0)",
                        "                arrBlackHoleForBertorsData['NumOfSuccessfulTimes'] = arrBlackHoleForBertorsData['NumOfSuccessfulTimes'] + 1;",
                        "        }",
                        "        else",
                        "            arrBlackHoleForBertorsData['NumOfSuccessfulTimes'] = arrBlackHoleForBertorsData['NumOfSuccessfulTimes'] + 1;",
                        "        //в третий раз добавляем материал бертора тут (из-за того, что невозможно обычным способом выдать 2 разных предмета)",
                        "        if (numOfRemainUnresearchedRemains == 1) {",
                        "            reward = CreateBertorMaterial(3, GetBertorMaterialCost());",
                        "            AddItemToShip(Player(), reward);",
                        "        }",
                        "    }",
                        "}",
                        "",
                        "function ETC_BlackHoleForBertorsCheck() { //чтение данных черной дыры из инфошки, добавление кораблей в группу",
                        "    dword player = Player();",
                        "    if (ShipFindCustomShipInfoByType(player, 'ZelDomiks_BlackHoleForBertor') > -1) {",
                        "        int needToClearData = 0;",
                        "        arrBlackHoleForBertorsData['BlackHoleId'] = ShipCustomShipInfoData(player, 'ZelDomiks_BlackHoleForBertor', 1);",
                        "        arrBlackHoleForBertorsData['Serie'] = ShipCustomShipInfoData(player, 'ZelDomiks_BlackHoleForBertor', 2);",
                        "        arrBlackHoleForBertorsData['TargetBertorId'] = ShipCustomShipInfoData(player, 'ZelDomiks_BlackHoleForBertor', 3);",
                        "        arrBlackHoleForBertorsData['TurnOfEndSignal'] = CurTurn() + 15;",
                        "        ShipDeleteCustomShipInfo(player, 'ZelDomiks_BlackHoleForBertor');",
                        "        dword bertor = IdToShip(arrBlackHoleForBertorsData['TargetBertorId']);",
                        "        if (bertor) {",
                        "            BlackHoleForBertorsResetGroup(); //на всякий случай, выводим из группы все предыдущие корабли",
                        "            ShipJoin(gBlackHoleForBertors, bertor);",
                        "            SetData(6, 0, bertor);",
                        "            dword blackHole = IdToHole(arrBlackHoleForBertorsData['BlackHoleId']);",
                        "            dword blackHoleStar = HoleStar1(blackHole);",
                        "            int starShipCount = StarShips(blackHoleStar);",
                        "            for (i = 0; i < starShipCount; i = i + 1) {",
                        "                dword curShip = StarShips(blackHoleStar, i);",
                        "                if (GetOwner(curShip) == 5 && ItemSubrace(ShipItems(curShip, 0)) == arrBlackHoleForBertorsData['Serie']) {",
                        "                    if (ShipSubType(curShip) == 7) {",
                        "                        ShipJoin(gBlackHoleForBertors, curShip);",
                        "                        SetData(7, 0, curShip);",
                        "                    }",
                        "                }",
                        "            }",
                        "        }",
                        "        //если бертор внезапно умер, то ставим флаг стирания данных",
                        "        else",
                        "            needToClearData = 1;",
                        "    }",
                        "    //если истекло время, то ставим флаг стирания данных",
                        "    if (CurTurn() > arrBlackHoleForBertorsData['TurnOfEndSignal'] && arrBlackHoleForBertorsData['TargetBertorId'])",
                        "        needToClearData = 1;",
                        "    if (needToClearData) { //стираем данные про черную дыру",
                        "        arrBlackHoleForBertorsData['TargetBertorId'] = 0;",
                        "        BlackHoleForBertorsResetGroup();",
                        "    }",
                        "}",
                        "",
                        "function ETC_BertorQuest() { //ежеходная обработка квеста бертора",
                        "    if (arrBertorQuestData['questPhase'] == 1 && arrBertorQuestData['questSubphase'] == 1) {",
                        "        if (CurTurn() >= arrBertorQuestData['unlockThirdSerieTurn']) {",
                        "            arrBertorQuestData['questSubphase'] = 2; //добавляем возможность делать субпорталы третьей серии",
                        "            if (arrBertorQuestData['SeriesResearchStatus', 0] == 0) {",
                        "                arrBertorQuestData['SeriesResearchStatus', 0] = 1;",
                        "                arrBertorQuestData['unlockThirdSerieGiftSerie'] = 0;",
                        "            }",
                        "            else if (arrBertorQuestData['SeriesResearchStatus', 1] == 0) {",
                        "                arrBertorQuestData['SeriesResearchStatus', 1] = 1;",
                        "                arrBertorQuestData['unlockThirdSerieGiftSerie'] = 1;",
                        "            }",
                        "            else if (arrBertorQuestData['SeriesResearchStatus', 2] == 0) {",
                        "                arrBertorQuestData['SeriesResearchStatus', 2] = 1;",
                        "                arrBertorQuestData['unlockThirdSerieGiftSerie'] = 2;",
                        "            }",
                        "            CustomEther('NisperEther', 6, '', 'Ученые коалиции научились делать Субпорталы с сигналом для берторов всех трех серий. Загляните на Базу Доминаторов для получения нового Субпортала.');",
                        "        }",
                        "    }",
                        "    else if (arrBertorQuestData['questPhase'] == 2 && arrBertorQuestData['questSubphase'] > 0) {",
                        "        if (CurTurn() > arrBertorQuestData['freeBertorMaterialAppearTurn']) { //добавляем время от времени бесплатный материал бертора",
                        "            if (arrBertorQuestData['bertorMaterialReceived'] + 2 < arrBertorQuestData['bertorMaterialTarget']) { //но последний материал всегда должен принести игрок",
                        "                arrBertorQuestData['bertorMaterialReceived'] = Rnd(1, 2) + arrBertorQuestData['bertorMaterialReceived'];",
                        "            }",
                        "            arrBertorQuestData['freeBertorMaterialAppearTurn'] = CurTurn() + Rnd(125, 175);",
                        "        }",
                        "    }",
                        "    else if (arrBertorQuestData['questPhase'] == 3 && arrBertorQuestData['questSubphase'] < 2) { //пока не отобьем систему первый раз - будем запускать время от времени атаки и увеличивать приоритет системы",
                        "        dword targetStar = PlanetToStar(IdToPlanet(arrBertorQuestData['scientistPlanetId']));",
                        "        int targetStarNum = Id(targetStar) - 1;",
                        "        if (IsStarOwnerCoal(targetStar)) {",
                        "            arrBertorQuestData['questSubphase'] = 2;",
                        "            arrStarsPriority[targetStarNum] = 1.0;",
                        "        }",
                        "        else if (CurTurn() > arrBertorQuestData['nextAttackTurn']) {",
                        "            arrBertorQuestData['nextAttackTurn'] = CurTurn() + GetBertorQuestPhase3AttackCooldown();",
                        "            BertorQuestPhase3PrepareAttack(0);",
                        "            arrStarsPriority[targetStarNum] = 2.0;",
                        "        }",
                        "    }",
                        "    else if (arrBertorQuestData['questPhase'] == 3 && CurTurn() > arrBertorQuestData['finalProjectEndTurn']) { //если изучили финальные проект",
                        "        if (arrBertorQuestData['questSubphase'] < 4) { //убираем эзэры и сообщаем об их выполнении",
                        "            Sound('Sound.QuestOk');",
                        "            if (EtherState('bertorQuestPhase3') != -1)",
                        "                Ether(4, 'bertorQuestPhase3', '');",
                        "        }",
                        "        arrBertorQuestData['questPhase'] = 4;",
                        "        arrBertorQuestData['questSubphase'] = 0;",
                        "        CustomEther('NisperEther', 6, '', 'Ученые коалиции полностью освоили технологию берторов. Загляните на Базу Доминаторов, вас там ожидает подарок.');",
                        "    }",
                        "    if (arrBertorQuestData['rangersCanMineMaterial']) { //развешиваем всем рейнджерам инфошку материала берторов",
                        "        if(GalaxyShipId() > lastShipId_BertorMaterial) {",
                        "            int shipCount = BuildListOfNewShips(tempArr, lastShipId_BertorMaterial, 2, 0, 1, '');",
                        "            if (shipCount) {",
                        "                for(j = shipCount - 1; j >= 0; j = j - 1) {",
                        "                    dword curShip = tempArr[j];",
                        "                    if (curShip != Player()) {",
                        "                        int difficulty = arrDifficultLevels['Price'] / 50;",
                        "                        int turnsToGetNew = RndObject(10, 120, curShip);",
                        "                        int costMult = round(GetIntByGeomLaw(RndObject(200, 300, curShip), difficulty, 1.2));",
                        "                        int chanceToGetNew = round(GetIntByGeomLaw(RndObject(5, 20, curShip), difficulty, 0.9));",
                        "                        if (ShipSubType(curShip) == 0) { //торговец чаще получает, но и дороже продает",
                        "                            chanceToGetNew = chanceToGetNew * RndObject(110, 140, curShip) / 100;",
                        "                            costMult = costMult * RndObject(125, 175, curShip) / 100;",
                        "                        }",
                        "                        ShipAddCustomShipInfo(curShip, 'ZelDomiks_RangerMaterialInfo', 'NoShow', 0, turnsToGetNew, costMult, chanceToGetNew);",
                        "                    }",
                        "                }",
                        "            }",
                        "            lastShipId_BertorMaterial = GalaxyShipId();",
                        "        }",
                        "    }",
                        "    if (arrPlayerBertorHullData['upgradeStatus'] == 1) { //исследуем корпус бертора игрока",
                        "        int upgradeTurn = arrPlayerBertorHullData['upgradeTurn'];",
                        "        if (CurTurn() > upgradeTurn) {",
                        "            arrPlayerBertorHullData['upgradeStatus'] = 2;",
                        "            CustomEther('NisperEther', 6, '', 'Ученые коалиции готовы улучшить ваш корпус бертора. Прилетайте на Базу Доминаторов.');",
                        "        }",
                        "    }",
                        "}"
                    ],
