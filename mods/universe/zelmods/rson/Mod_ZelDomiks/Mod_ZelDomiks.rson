                        "ArrayAdd(arrBlackHoleForBertorsData, 0, 'tonnageDonatedForResearch');",
                        "ArrayAdd(arrBlackHoleForBertorsData, 1000, 'tonnageTargetForGift');",
                        "ArrayAdd(arrBlackHoleForBertorsData, unknownVar, 'SerieFirstTime'); //в первые разы для каждой серии не увеличиваем счетчик успешных посещений",
                        "arrBlackHoleForBertorsData['SerieFirstTime'] = newarray(1);",
