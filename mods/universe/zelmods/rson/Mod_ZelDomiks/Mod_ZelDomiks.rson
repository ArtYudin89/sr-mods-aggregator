                    "_orig_danswer": "DAnswer(CT(\"Script.Mod_ZelDomiks.39\"))"
                },
                {
                    "Name": "restart",
                    "Pos.x": 1080,
                    "Pos.y": 865,
                    "Type": "TDialogAnswer",
                    "Parent": -1,
                    "#": 205,
                    "Msg": "Спасибо! Все понял, выдвигаюсь",
