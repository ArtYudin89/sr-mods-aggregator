                },
                {
                    "Name": "",
                    "Pos.x": 480,
                    "Pos.y": 865,
                    "Type": "TDialogAnswer",
                    "Parent": -1,
                    "#": 200,
                    "Msg": "А кто должен уничтожить бертора в гиперпространстве? И как вы хотите его туда заманить?",
                    "AMsg.Num": "34",
                    "_orig_danswer": "DAnswer(CT(\"Script.Mod_ZelDomiks.35\"))"
                },
                {
                    "Name": "",
                    "Pos.x": 600,
                    "Pos.y": 865,
                    "Type": "TDialogAnswer",
                    "Parent": -1,
                    "#": 201,
                    "Msg": "А как это связано?",
                    "AMsg.Num": "35",
                    "_orig_danswer": "DAnswer(CT(\"Script.Mod_ZelDomiks.36\"))"
                },
                {
                    "Name": "",
                    "Pos.x": 720,
                    "Pos.y": 865,
                    "Type": "TDialogAnswer",
                    "Parent": -1,
                    "#": 202,
                    "Msg": "То есть, вы способны управлять бертором?",
                    "AMsg.Num": "36",
                    "_orig_danswer": "DAnswer(CT(\"Script.Mod_ZelDomiks.37\"))"
                },
                {
                    "Name": "",
                    "Pos.x": 840,
                    "Pos.y": 865,
                    "Type": "TDialogAnswer",
                    "Parent": -1,
                    "#": 203,
                    "Msg": "Понятно. Я могу вам помочь?",
                    "AMsg.Num": "37",
                    "_orig_danswer": "DAnswer(CT(\"Script.Mod_ZelDomiks.38\"))"
                },
                {
                    "Name": "",
                    "Pos.x": 960,
                    "Pos.y": 865,
                    "Type": "TDialogAnswer",
                    "Parent": -1,
                    "#": 204,
                    "Msg": "Отлично, я готов!",
