                        "    arrPlayerUpgrades[0] = arrPlayerUpgrades[0] + 1;",
                        "else if (last == 2)",
                        "    arrPlayerUpgrades[1] = arrPlayerUpgrades[1] + 1;",
                        "else if (last == 3)",
                        "    arrPlayerUpgrades[2] = arrPlayerUpgrades[2] + 1;",
                        "else if (last == 4)",
                        "    arrPlayerUpgrades[0] = arrPlayerUpgrades[0] - 1;",
                        "else if (last == 5)",
                        "    arrPlayerUpgrades[1] = arrPlayerUpgrades[1] - 1;",
                        "else if (last == 6)",
                        "    arrPlayerUpgrades[2] = arrPlayerUpgrades[2] - 1;",
                        "DAddText(Format('На данный момент уровень Ниспера равен <0>/10:",
                        "',\"<0>\",NisperLevel));",
                        "DAddText(Format('<0>",
                        "",
