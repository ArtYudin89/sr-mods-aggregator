                {
                    "Name": "",
                    "Code.Type": "Turn",
                    "Code": [
                        "arrBertorQuestData['questSubphase'] == 4;",
                        "arrBertorQuestData['finalProjectEndTurn'] = CurTurn() + ((arrBertorQuestData['finalProjectEndTurn'] - CurTurn()) / 10);",
                        "dword capsula = GAnswerData;",
