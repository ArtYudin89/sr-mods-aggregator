                    "Code": [
                        "DAddText('",
                        "К тому же, на данный момент мы способны создавать такие сигналы только для берторов серии ');",
                        "int flag = 0;",
                        "if (arrBertorQuestData['SeriesResearchStatus', 0]) {",
                        "    DAddText('<color=255,0,0>Блазер</color>');",
                        "    flag = flag + 1;",
                        "}",
                        "if (flag == 1) {",
                        "    DAddText(' и ');",
                        "}",
                        "if (arrBertorQuestData['SeriesResearchStatus', 1]) {",
                        "    DAddText('<color=0,0,255>Келлер</color>');",
                        "    flag = flag + 1;",
                        "}",
                        "if (flag == 1) {",
                        "    DAddText(' и ');",
                        "}",
                        "if (arrBertorQuestData['SeriesResearchStatus', 2]) {",
                        "    DAddText('<color=0,160,0>Террон</color>');",
                        "    flag = flag + 1;",
                        "}",
                        "DAddText('. Но мы неустанно работаем над тем, чтобы понять на какой вид сигналов реагирует и третья серия.');",
                        "DAdd(37);"
                    ],
