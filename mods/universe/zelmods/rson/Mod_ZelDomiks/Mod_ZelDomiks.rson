                {
                    "Name": "",
                    "Code.Type": "DialogBegin",
                    "Code": [
                        "dword player = Player();",
                        "dword DB = GetDB();",
                        "dword playerRuins = GetShipRuins(player);",
                        "if (NisperStarted == 0) {",
                        "    if (playerRuins) {",
                        "        if (ShipType(playerRuins) == 'SB') {",
                        "            if (!startResearchStarted)",
                        "                AddDialogInject('dStart', '', 'Я слышал про четвертую серию доминаторов...', 100);",
                        "            else if (startResearchStarted == 1)",
                        "                AddDialogInject('dStartResearch', '', 'Хочу помочь исследованиям четвертой серии доминаторов', 0);",
                        "        }",
                        "    }",
                        "} else {",
                        "    if (playerRuins) {",
                        "        if (playerRuins == DB) {",
                        "            if (arrBertorQuestData['questPhase'] == 1 && arrBertorQuestData['questSubphase'] == 2) {",
                        "                AddDialogOverride('dBertorQuestPhase1Gift', 0);",
                        "            }",
                        "            DText('Добро пожаловать на Базу Доминаторов!');",
                        "            if (isScriptTest)",
                        "                AddDialogInject('dDomiksBaseTest', '', 'Debug: изменить параметры доминаторов Ниспера', 100);",
                        "            if (NisperLevel < 10) {",
                        "                /*checkTasksConditions();",
                        "                curTaskNum = GetNewTaskNum();",
                        "                if (curTaskNum != -1 && !curTaskState)",
                        "                    AddDialogInject('dTaskStdStart', '', 'Есть ли для меня какое-то задание?', 1);*/",
                        "                AddDialogInject('dResearch', '', 'Хочу помочь исследованиям', 1, 0, 0);",
                        "            }",
                        "            AddDialogInject('dUpgrades', '', 'Как там обстоят дела с усилением доминаторов Ниспера?', 0);",
                        "            if (IsNumInBorders(arrPlayerBertorHullData['hullLevel'], 1, 9, 1)) {",
                        "                if (arrPlayerBertorHullData['upgradeStatus'] == 0) //улучшение корпуса еще не начато",
                        "                    AddDialogInject('dBertorHullUpgrade', '', 'Я могу что-то сделать, чтобы помочь вам улучшить мой корпус бертора?', 0);",
                        "                else if (arrPlayerBertorHullData['upgradeStatus'] > 0)",
                        "                    AddDialogInject('dBertorHullUpgrade', '', 'Есть новости по поводу улучшения моего корпуса бертора?', 0);",
                        "            }",
                        "            if (arrBertorQuestData['questPhase'] > 1 || (arrBertorQuestData['questPhase'] == 1 && arrBertorQuestData['questSubphase'] > 1)) {",
                        "                if (arrBlackHoleForBertorsData['tonnageDonatedForResearch'] > arrBlackHoleForBertorsData['tonnageTargetForGift']) //если надонатили достаточно много для получения халявного Субпортала",
                        "                    AddDialogOverride('dBlackHoleForBertorsGift', 0);",
                        "            }",
                        "            if (arrBertorQuestData['questPhase'] > 1)",
                        "                AddDialogInject('dBlackHoleForBertors', '', 'У меня есть Субпортал, доработайте его для заманивания берторов', 1);",
                        "            if (arrBertorQuestData['questPhase'] == 0 && CurTurn() > arrBertorQuestData['startQuestTurn'])",
                        "                AddDialogInject('dBertorQuestStart', '', 'Почему коалиция не создает своих берторов?', 100);",
                        "            else if (arrBertorQuestData['questPhase'] == 1)",
                        "                AddDialogInject('dBertorQuest', '', 'Как продвигается изучение сигналов и механизмов берторов?', 1);",
                        "            else if (arrBertorQuestData['questPhase'] == 2 && arrBertorQuestData['questSubphase'] == 0)",
                        "                AddDialogInject('dBertorQuest', '', 'Вот, я принес вам материал бертора, как вы и просили', 2);",
                        "            else if (arrBertorQuestData['questPhase'] == 2 && arrBertorQuestData['questSubphase'] > 0)",
                        "                AddDialogInject('dBertorQuest', '', 'Как продвигается изучение материала бертора?', 1);",
                        "            else if (arrBertorQuestData['questPhase'] == 3 && arrBertorQuestData['questSubphase'] == 3) {",
                        "                int itemCount = ShipItems(player);",
                        "                for (i = 0; i < itemCount; i = i + 1) {",
                        "                    dword curItem = ShipItems(player, i);",
                        "                    if (ItemType(curItem) == t_UselessItem) {",
                        "                        if (Id(curItem) == arrBertorQuestData['scientistCapsulaId'])",
                        "                            AddDialogOverride('dBertorQuestPhase3Final', 0, curItem);",
                        "                    }",
                        "                }",
                        "            }",
                        "            else if (arrBertorQuestData['questPhase'] > 3 && arrPlayerBertorHullData['hullLevel'] < 1)",
                        "                AddDialogOverride('dBertorHullStart', 0, curItem);",
                        "        }",
                        "    }",
                        "    if (GetTalkShip() && !TalkByAI()) {",
                        "        dword talkShip = GetTalkShip();",
                        "        int relationWithTalkShip = RelationToShip(talkShip, player);",
                        "        int haveInfo = ShipFindCustomShipInfoByType(talkShip, 'ZelDomiks_RangerMaterialInfo');",
                        "        if (haveInfo != -1 && relationWithTalkShip >= 10 && arrPlayerBertorHullData['hullLevel'] < 10) {",
                        "            str firstReply = 'Слушай, а у тебя есть материал бертора? Я готов купить его';",
                        "            if (CurTurn() - arrBertorQuestData['recearchedBertorMaterialTurn'] < 90)",
                        "                firstReply = 'Слушай, а у тебя есть материал бертора, который недавно открыли? Я готов купить его';",
                        "            AddDialogInject('dAskMaterialFromRanger', '', firstReply, 0);",
                        "        }",
                        "    }",
                        "    if (GetShipPlanet(player)) {",
                        "        if (arrBertorQuestData['questPhase'] == 3 && arrBertorQuestData['questSubphase'] == 2) {",
                        "            if (Id(GetShipPlanet(player)) == arrBertorQuestData['scientistPlanetId']) {",
                        "                AddDialogOverride('dBertorQuestPhase3Scientist', 0);",
                        "            }",
                        "        }",
                        "    }",
                        "}"
                    ],
                    "#": 80,
                    "Type": "Top",
                    "Parent": -1,
                    "Pos.x": 180,
                    "Pos.y": 960
                },
                {
                    "Name": "",
                    "Code.Type": "Turn",
                    "Code": [
                        "// Data 0 - ходов до постройки Ниспера",
                        "// Data 1 - денег до постройки фабрики",
                        "",
                        "dword Nisper = GetNisper();",
                        "if (ShipInNormalSpace(CurShip)) {",
                        "    if (!Nisper) {",
                        "        int turnsToBuildNisper = GetData(0, CurShip);",
                        "        if (turnsToBuildNisper > 0)",
                        "            turnsToBuildNisper = turnsToBuildNisper - 1;",
                        "        else {",
                        "            int domikPowerPoints = GetStarDomiksPower(ShipStar(CurShip));",
                        "            int domikPower = GetPowerFromPowerPoints(domikPowerPoints);",
                        "            Nisper = StdAlgorithmBuyNisper(NearCivilPlanet(CurShip), domikPower, NisperBonus);",
                        "            TransferShip(Nisper, CurShip);",
                        "            turnsToBuildNisper = GetTurnsRespawnNisper();",
                        "        }",
                        "        SetData(turnsToBuildNisper, 0, CurShip);",
                        "    }",
                        "    if (NisperLevel < 10)",
                        "        EveryTurnResearch();",
                        "    int turnsToBuildFactory = GetData(1, CurShip);",
                        "    if (turnsToBuildFactory > 0)",
                        "            turnsToBuildFactory = turnsToBuildFactory - 1;",
                        "    else {",
                        "        dword planet = GetRandomCoalCivilPlanet();",
                        "        if (planet > 0) {",
                        "            dword factory = StdAlgorithmBuyFactory(planet);",
                        "            TransferShip(factory, CurShip);",
                        "        }",
                        "        turnsToBuildFactory = 30;",
                        "    }",
                        "    SetData(turnsToBuildFactory, 1, CurShip);",
                        "}",
                        "int a;"
                    ],
                    "#": 225,
                    "Type": "Top",
                    "Parent": -1,
                    "Pos.x": 80
                },
                {
                    "Name": "",
                    "Code.Type": "Turn",
                    "Code": [
                        "// Data 0 - ходов до новой точки патруля",
                        "// Data 1 - ходов до смены экипировки",
                        "// Data 2 - количество ходов, которое Ниспер уже потратил при попытке долететь до ближайшего ангара",
                        "",
                        "StdAlgorithmEveryTurn(CurShip);",
                        "if (GetShipHangar(CurShip)) { //взлетаем",
                        "    NisperReequipment(CurShip, NisperBonus);",
                        "    StdAlgorithmFullRepair(CurShip);",
                        "    OrderTakeOff(CurShip);",
                        "    SetData(0, 0, CurShip);",
                        "    SetData(0, 2, CurShip);",
                        "    SetData(GetNisperReloadReequipment(), 1, CurShip);",
                        "} else if (ShipInNormalSpace(CurShip)) {",
                        "    dword enemy = GetNisperDomikBad(CurShip); //ищем врага",
                        "    if (enemy)",
                        "        ChangeState(3);",
                        "    else {",
                        "        dword shipStar = ShipStar(CurShip);",
                        "        int turnsToReequipment = GetData(1, CurShip);",
                        "        turnsToReequipment = turnsToReequipment - 1;",
                        "        SetData(turnsToReequipment, 1, CurShip);",
                        "        if(turnsToReequipment < 1) {",
                        "            dword hangar = GetShipNearHangar(CurShip);",
                        "            if (hangar) {",
                        "                OrderLanding(CurShip, hangar);",
                        "                int turnsWithoutForsage = GetData(2, CurShip);",
                        "                if (turnsWithoutForsage < 15)",
                        "                    turnsWithoutForsage = turnsWithoutForsage + 1;",
                        "                else",
                        "                    OrderForsage(CurShip, 1);",
                        "                SetData(turnsWithoutForsage, 2, CurShip);",
                        "            } else",
                        "                StdAlgorithmPatrolStar(CurShip, 1);",
                        "        } else",
                        "            StdAlgorithmPatrolStar(CurShip, 1);",
                        "    }",
                        "}"
                    ],
                    "#": 226,
                    "Type": "Top",
                    "Parent": -1,
                    "Pos.x": 160
                },
                {
                    "Name": "",
                    "Code.Type": "Turn",
                    "Code": [
                        "StdAlgorithmEveryTurn(CurShip);",
                        "dword enemy = GetNisperDomikBad(CurShip);",
                        "if (enemy) { //преследуем и сражаемся с врагом",
                        "    dword star = ShipStar(CurShip);",
                        "    SetData(Id(star) - 1, 1, CurShip);",
                        "    OrderFollowAndAttackShip(CurShip, enemy);",
                        "} else { //возвращаемся к патрулю",
                        "    SetData(0, 0, CurShip);",
                        "    ShipSetBad(CurShip, 0);",
                        "    ChangeState(2);",
                        "}"
                    ],
                    "#": 227,
                    "Type": "Top",
                    "Parent": -1,
                    "Pos.x": 240
                },
                {
                    "Name": "",
                    "Code.Type": "Turn",
                    "Code": [
                        "// Data 0 - ходов до постройки Базы Доминаторов",
                        "",
                        "dword DB = GetDB();",
                        "if (!DB && NisperStarted) {",
                        "    int turnsToBuildDB = GetData(0, CurShip);",
                        "    if (turnsToBuildDB > 0)",
                        "        turnsToBuildDB = turnsToBuildDB - 1;",
                        "    else {",
                        "        TryBuildDB();",
                        "        turnsToBuildDB = GetTurnsRespawnDB();",
                        "    }",
                        "    SetData(turnsToBuildDB, 0, CurShip);",
                        "}"
