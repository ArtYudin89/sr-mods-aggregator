                        "arrTasksDescription[0] = 'Нам нужно защитить нашего дипломата, который сейчас находится в пиратской системе. Он несет ценные сведения. Найдите и защитите его.';",
                        "arrTasksDescription[1] = '2.';",
                        "",
                        "arrTasksConditions = newarray(tasksCount);",
                        "for (i = 0; i < tasksCount; i = i + 1)",
                        "    arrTasksConditions[i] = 1;*/",
