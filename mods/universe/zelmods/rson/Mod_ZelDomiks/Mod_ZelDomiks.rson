                {
                    "Name": "",
                    "Code.Type": "Turn",
                    "Code": [
                        "dword talkShip = GetTalkShip();",
                        "dword player = Player();",
                        "int materialCount = ShipCustomShipInfoData(talkShip, 'ZelDomiks_RangerMaterialInfo', 1);",
                        "int materialCost = GetBertorMaterialCost() * ShipCustomShipInfoData(talkShip, 'ZelDomiks_RangerMaterialInfo', 3) / 100;",
                        "int playerMoney = ShipMoney(player);",
                        "int maxPossibleMaterialCount = min(materialCount, playerMoney / materialCost);",
                        "str selectedCount = CountBox('Bm.Items.2ZelDomiks_UselessBertorMaterial0_s','Сколько материала купить?', 0, materialCount, materialCost, 1, maxPossibleMaterialCount, materialCount, playerMoney);",
                        "if (selectedCount != 'Cancel' && selectedCount > 0) {",
                        "    ShipCustomShipInfoData(talkShip, 'ZelDomiks_RangerMaterialInfo', 1, materialCount - selectedCount);",
                        "    ShipCustomShipInfoData(talkShip, 'ZelDomiks_RangerMaterialInfo', 2, RndObject(90, 120, talkShip));",
                        "    dword material = CreateBertorMaterial(selectedCount, GetBertorMaterialCost());",
                        "    AddItemToShip(player, material);",
                        "    ShipMoney(player, playerMoney - (materialCost * selectedCount));",
