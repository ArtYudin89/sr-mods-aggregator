            "Items": [],
            "Operations": [
                {
                    "Name": "",
                    "Code.Type": "Global",
                    "Code": [
                        "GRun();"
                    ],
                    "#": 77,
                    "Type": "Top",
                    "Parent": -1,
                    "Pos.x": 0,
                    "Pos.y": 960
                },
                {
                    "Name": "",
                    "Code.Type": "Init",
                    "Code": [
                        "function StdAlgorithmEveryTurn(ship) { //ежеходные команды корабля",
                        "    OrderLock(ship, 1);",
                        "    OrderForsage(ship, 0);",
                        "}",
                        "",
                        "function StdAlgorithmDomikOrderJump(ship, targetStar) { //команды прыжка корабля в систему",
                        "    OrderJump(ship, targetStar);",
                        "    SetData(0, 0, ship);",
                        "}",
                        "",
                        "function StdAlgorithmFullRepair(ship) { //полная починка корабля",
                        "    ShipRefuel(ship);",
                        "    ShipRepairEq(ship);",
                        "    HullHP(ship, ItemSize(ShipItems(ship, 0)));",
                        "}",
                        "",
                        "function StdAlgorithmPatrolStar(ship, bigRadius) { //расчет патруля в системе для указанного корабля по маленькому или большому радиусу",
                        "    int turns = GetData(0, ship);",
                        "    if (turns < 1) {",
                        "        dword star = ShipStar(ship);",
                        "        float ugol = 0.01 * Rnd(0, 200);",
                        "        int radius;",
                        "        if (!bigRadius)",
                        "            radius = PlanetOrbitRadius(StarPlanets(star, 0)) + Rnd(-50, 100);",
                        "        else",
                        "            radius = Rnd(PlanetOrbitRadius(StarPlanets(star, 0)) - 50, PlanetOrbitRadius(StarPlanets(star, StarPlanets(star) - 1)));",
                        "        int x = round(sin(ugol * pi) * radius);",
                        "        int y = -1 * round(cos(ugol * pi) * radius);",
                        "        OrderMove(ship, x, y);",
                        "        int distance = round(sqrt(sqr(abs(CoordX(ship) - x)) + sqr(abs(CoordY(ship) - y))));",
                        "        int shipSpeed = ShipSpeed(ship);",
                        "        turns = distance / shipSpeed + (distance % shipSpeed != 0);",
                        "    }",
                        "    SetData(turns - 1, 0, ship);",
                        "}",
                        "",
                        "function GetShipNearHangar(ship) { //возвращает ближайшую дружелюбную станцию или планету к кораблю",
                        "    dword nearPlanet = NearCivilPlanet(ship);",
                        "    dword nearRuin = 0;",
                        "    dword shipStar = ShipStar(ship);",
                        "    int countShipsInStar = StarShips(shipStar);",
                        "    int nearRuinDist = 1000000;",
                        "    int nearPlanetDist = Dist(ship, nearPlanet);",
                        "    if (GetRelationPlanet(nearPlanet, ship) < 10)",
                        "        nearPlanet = 0;",
                        "    for (i = 0; i <= countShipsInStar; i = i + 1) {",
                        "        dword selectShip = StarShips(shipStar, i);",
                        "        if (ShipInNormalSpace(selectShip)) {",
                        "            if (!IsShipNisperEnemy(selectShip) && IsThisRuin(selectShip)) {",
                        "                int distance = Dist(ship, selectShip);",
                        "                if (distance < nearRuinDist) {",
                        "                    nearRuin = selectShip;",
                        "                    nearRuinDist = distance;",
                        "                }",
                        "            }",
                        "        }",
                        "    }",
                        "    if (nearPlanetDist < nearRuinDist)",
                        "        result = nearPlanet;",
                        "    else",
                        "        result = nearRuin;",
                        "}",
                        "",
                        "function GetNisperDomikBad(ship) { //возвращает нового (или старого) врага для корабля по критериям Ниспера",
                        "    dword enemy = ShipGetBad(ship);",
                        "    dword DB = GetDB();",
                        "    if (!DB)",
                        "        enemy = 0;",
                        "    else {",
                        "        if (enemy) { //если старый враг был, то он может быть отсеян",
                        "            if (Dist(ship, enemy) > ShipSpeed(ship) || !ShipInNormalSpace(enemy) || ShipStar(ship) != ShipStar(enemy))",
                        "                enemy = 0;",
                        "        }",
                        "        if (!enemy) { //ищу нового врага",
                        "            dword star = ShipStar(ship);",
                        "            dword bestDistance = 1000000;",
                        "            int countShipsInStar = StarShips(star);",
                        "            for (i = 0; i <= countShipsInStar; i = i + 1) {",
                        "                dword potentialEnemy = StarShips(star, i);",
                        "                if (ShipInNormalSpace(potentialEnemy)) {",
                        "                    if(IsShipNisperEnemy(potentialEnemy)) {",
                        "                        int distance = Dist(ship, potentialEnemy) * Rnd(1, 10);",
                        "                        if (distance < bestDistance) {",
                        "                            enemy = potentialEnemy;",
                        "                            bestDistance = distance;",
                        "                        }",
                        "                    }",
                        "                }",
                        "            }",
                        "        }",
                        "    }",
                        "    result = enemy;",
                        "}",
                        "",
                        "function OrderFollowAndAttackShip(ship, enemy) { //команда приближаться и атаковать указанный корабль",
                        "    ShipSetBad(ship, enemy);",
                        "    OrderFollowShip(ship, enemy, 1);",
                        "}",
                        "",
                        "function SetTrancProprietorDB(tranclucator) { //устанавливаем указанному транклюкатору в хозяины Базу Доминаторов",
                        "    dword DB = GetDB();",
                        "    if (DB)",
                        "        TranclucatorData(tranclucator, 'Proprietor', DB);",
                        "}",
                        "",
                        "function SetAllDomTrancProprietorDB() { //устанавливаем всем группам в хозяины Базу Доминаторов",
                        "    unknown groups = newarray(1);",
                        "    ArrayDelete(groups, 0);",
                        "    ArrayAdd(groups, gDomiks);",
                        "    int groupsCount = ArrayDim(groups);",
                        "    for (k = 0; k < groupsCount; k = k + 1) {",
                        "        int countShips = GroupCount(groups[k]);",
                        "        for (i = 0; i < countShips; i = i + 1) {",
                        "            dword tranclucator = GroupShip(groups[k], i);",
                        "            SetTrancProprietorDB(tranclucator);",
                        "        }",
                        "    }",
                        "}",
                        "",
                        "function SetShipNisperRace(ship, domikType) { //устанавливаем внутренние механики доминаторов Ниспера кораблю, включая случайное имя",
                        "    ShipType(ship, 'Nisper' + domikType);",
                        "    SetName(ship, CT('ShipName.Kling.' + Rnd(1, 123)) + ' -' + Rnd(1, 100) + '-');",
                        "    ShipCustomFaction(ship, 'SubFaction.Nisper');",
                        "    ShipTechLevelKnowledge(ship, 8);",
                        "    NoTargetToShip(ship, 2);",
                        "    NoDropToShip(ship, 1);",
                        "}",
                        "",
                        "function DomikAlgorithmClearData(ship) { //обнуляем дату до начальных значений обычному доминатору",
                        "    dword numShipStar = Id(ShipStar(ship)) - 1;",
                        "    SetData(0, 0, ship);",
                        "    SetData(0, 1, ship);",
                        "    SetData(numShipStar, 2, ship);",
                        "    SetData(0, 3, ship);",
                        "}",
                        "",
                        "function BertorAlgorithmClearData(ship) { //обнуляем дату до начальных значений бертору",
                        "    dword numShipStar = Id(ShipStar(ship)) - 1;",
                        "    SetData(0, 0, ship);",
                        "    SetData(0, 1, ship);",
                        "    SetData(numShipStar, 2, ship);",
                        "    SetData(GetBertorChangeStarCooldown(), 3, ship);",
                        "}",
                        "",
                        "function KligAlgorithmClearData(ship) { //обнуляем дату до начальных значений клигу",
                        "    SetData(0, 0, ship);",
                        "    SetData(0, 1, ship);",
                        "}",
                        "",
                        "function NisperAlgorithmClearData(ship, nisperType) { //обнуляем дату до начальных значений Нисперу",
                        "    if (nisperType == 0) {",
                        "        SetData(0, 0, ship);",
                        "        SetData(GetNisperReloadReequipment(), 1, ship);",
                        "        SetData(0, 2, ship);",
                        "    }",
                        "}",
                        "",
                        "function DBAlgorithmClearData(ship) { //обнуляем дату до начальных значений Базе Доминаторов",
                        "    SetData(GetTurnsRespawnNisper(), 0, ship);",
                        "    SetData(3, 1, ship);",
                        "}",
                        "",
                        "function CRMAlgorithmClearData(ship) { //обнуляем дату до начальных значений CRM",
                        "    SetData(GetTurnsRespawnDB(), 0, ship);",
                        "}",
                        "",
                        "function FactoryAlgorithmClearData(ship) { //обнуляем дату до начальных значений заводу",
                        "    SetData(0, 2, ship);",
                        "    int radius = ShipJump(ship);",
                        "    dword starDB = ShipStar(GetDB());",
                        "    dword targetPlanet = GetNewFactoryTargetPlanet(radius, starDB);",
                        "    if (targetPlanet != 0) {",
                        "        SetData(Id(targetPlanet), 1, ship);",
                        "        if (GetArrRouteFromStarToStar(radius, starDB, PlanetToStar(targetPlanet), 0) < 2) { //путь по сути состоит из одной и той же системы (не нужно лететь в другие системы)",
                        "            SetData(Id(PlanetToStar(targetPlanet)) - 1, 0, ship);",
                        "        }",
                        "        else {",
                        "            unknown arrRouteFromStarToStar = tempArr;",
                        "            if (ArrayDim(arrRouteFromStarToStar) > 1) //если все в порядке, то просто ставим новую систему в цель",
                        "                SetData(Id(arrRouteFromStarToStar[1]) - 1, 0, ship);",
                        "            else",
                        "                ShipDestroy(ship);",
                        "        }",
                        "    }",
                        "    else {",
                        "        ShipDestroy(ship);",
                        "    }",
                        "}",
                        "",
                        "function StdDomikInfos(ship, domikType) { //выдает кораблю стандартные инфошки доминатора Ниспера",
                        "    ShipAddCustomShipInfo(ship, 'ZelDomiks_DomInfo', 'NoShow', domikType);",
                        "    if (domikType == 6) { //бертор",
                        "        ShipAddCustomShipInfo(ship, 'ZelDomiks_BertorInfo', 'NoShow', 0, 5, 0);",
                        "        ShipAddCustomShipInfo(ship, 'ZelDomiks_BertorAuraSource', 'NoShow');",
                        "    }",
                        "    else if (domikType == 7) { //клиг",
                        "        ShipAddCustomShipInfo(ship, 'ZelDomiks_KligInfo', 'NoShow');",
                        "    }",
                        "}",
                        "",
                        "function StdNisperInfos(ship) { //выдает кораблю стандартные инфошки Ниспера",
                        "    ShipAddCustomShipInfo(ship, 'ZelDomiks_DomInfo', 'NoShow', 0);",
                        "    ShipAddCustomShipInfo(ship, 'ZelDomiks_NisperAuraSource', 'NoShow', Id(GetCRM()));",
                        "}",
                        "",
                        "function StdFactoryInfos(ship) { //выдает кораблю стандартные инфошки фабрики",
                        "    ShipAddCustomShipInfo(ship, 'ZelDomiks_FactoryInfo', 'NoShow');",
                        "    ShipCustomShipInfoTextData(ship, 'ZelDomiks_FactoryInfo', 1, '-----');",
                        "}",
                        "",
                        "function GetNewFactoryTargetPlanet(radius, startStar) { //возвращает случайную незаселенную планету, которая не является целью любой фабрики и до которой сможет долететь корабль с учетом его двигателя и текущего положения. Если такой планеты не существует, то возвращает -1",
                        "    GetArrCoalPossibleReachedStars(radius, startStar, 0);",
                        "    unknown arrPossibleFabricPlanets = newarray(1);",
                        "    ArrayDelete(arrPossibleFabricPlanets, 0);",
                        "    unknown arrCoalPossibleReachedStars = tempArr;",
                        "    for (i = 0; i < ArrayDim(arrCoalPossibleReachedStars); i = i + 1) {",
                        "        dword curStar = arrCoalPossibleReachedStars[i];",
                        "        int starPlanetsCount = StarPlanets(curStar);",
                        "        for (j = 0; j < starPlanetsCount; j = j + 1) {",
                        "            dword selectPlanet = StarPlanets(curStar, j);",
                        "            if (PlanetOwner(selectPlanet) == 6 && IsAnyFactoryChoosedThisPlanet(selectPlanet) == 0)",
                        "                ArrayAdd(arrPossibleFabricPlanets, selectPlanet);",
                        "        }",
                        "    }",
                        "    int countPossibleFabricPlanets = ArrayDim(arrPossibleFabricPlanets);",
                        "    if (countPossibleFabricPlanets > 0) {",
                        "        dword targetFabricPlanet = arrPossibleFabricPlanets[Rnd(0, countPossibleFabricPlanets - 1)];",
                        "        result = targetFabricPlanet;",
                        "    }",
                        "    else",
                        "        result = 0;",
                        "}",
                        "",
                        "function StarDomiksBehaviorOptimization(star) { //функция создана в целях оптимизации. Берет на себя самые ресурсоемкие операции доминаторов",
                        "    int starShipsCount = StarShips(star);",
                        "    unknown arrStarShipPossibleTarget = newarray(1); //возможные цели",
                        "    unknown arrStarShipNisperWarriors = newarray(1); //доминаторы Ниспера, которым будем менять цель и маркеры необходимости починки на планете",
                        "    unknown arrStarShipNisperFreeDomiks = newarray(1); //доминаторы Ниспера, которые будут сопровождать",
                        "    unknown arrStarShipNisperEscortRequestors = newarray(1); //те, кого нужно сопровождать",
                        "    unknown arrStarShipAlly = newarray(1); //100% союзники, которых нет смысла рассматривать в качестве целей. Возможно в будущем что-то буду с ними делать",
                        "    ArrayDelete(arrStarShipPossibleTarget, 0);",
                        "    ArrayDelete(arrStarShipNisperWarriors, 0);",
                        "    ArrayDelete(arrStarShipNisperFreeDomiks, 0);",
                        "    ArrayDelete(arrStarShipNisperEscortRequestors, 0);",
                        "    ArrayDelete(arrStarShipAlly, 0);",
                        "    //сразу добавляем игрока в тех, кого нужно сопровождать, если на нем одет корпус бертора",
                        "    if (IsPlayerUseBertorHull() && ShipInNormalSpace(Player()) && ShipStar(Player()) == star)",
                        "        ArrayAdd(arrStarShipNisperEscortRequestors, Player());",
                        "    for (i = 0; i < starShipsCount; i = i + 1) {",
                        "        dword curShip = StarShips(star, i);",
                        "        if (ShipInNormalSpace(curShip)) { //многое имеет смысл просчитывать только корабли в обычном космосе",
                        "            int shipGroup = ShipGroup(curShip);",
                        "            if (shipGroup == gDomiks || shipGroup == gBertors || shipGroup == gKligs) {",
                        "                ArrayAdd(arrStarShipNisperWarriors, curShip);",
                        "                if (shipGroup == gBertors)",
                        "                    ArrayAdd(arrStarShipNisperEscortRequestors, curShip); //нужно сопровождать",
                        "            }",
                        "            else if (ShipGroup(curShip) == gFactories)",
                        "                ArrayAdd(arrStarShipAlly, curShip);",
                        "            else",
                        "                ArrayAdd(arrStarShipPossibleTarget, curShip);",
                        "        }",
                        "        if (ArrayDim(arrStarShipNisperEscortRequestors) || CountIn(gBertors, star)) {",
                        "            //для того, чтобы домики постоянно не сменяли друг-друга в эскорте, будем учитывать и тех, кто сидит на планете или станции",
                        "            if (StateIs(curShip, 'domikPatrol') && (ShipInNormalSpace(curShip) || GetShipHangar(curShip))) {",
                        "                if (star == GalaxyStar(GetData(2, curShip))) //если это обычный доминатор и его целевая система совпадает с текущей",
                        "                    ArrayAdd(arrStarShipNisperFreeDomiks, curShip); //то он может быть сопровождающим",
                        "            }",
                        "        }",
                        "    }",
                        "    int starShipPossibleTargetCount = ArrayDim(arrStarShipPossibleTarget);",
                        "    int starShipNisperWarriorsCount = ArrayDim(arrStarShipNisperWarriors);",
                        "    int starShipNisperFreeDomiksCount = ArrayDim(arrStarShipNisperFreeDomiks);",
                        "    int starShipNisperEscortRequestorsCount = ArrayDim(arrStarShipNisperEscortRequestors);",
                        "    dword DB = GetDB();",
                        "    dword CRM = GetCRM();",
                        "    for (i = 0; i < starShipNisperWarriorsCount; i = i + 1) { //цикл для смены врагов и маркеров необходимости починки на планете",
                        "        curShip = arrStarShipNisperWarriors[i];",
                        "        dword enemy = ShipGetBad(curShip);",
                        "        //перенастраиваем цели для доминаторов",
                        "        if (!DB)",
                        "            enemy = 0;",
                        "        else {",
                        "            if (enemy) { //если старый враг был, то он может быть отсеян",
                        "                if (Dist(curShip, enemy) > ShipSpeed(curShip) || !ShipInNormalSpace(enemy) || ShipStar(curShip) != ShipStar(enemy))",
                        "                    enemy = 0;",
                        "            }",
                        "            if (!enemy) { //ищу нового врага",
                        "                dword bestDistance = 1000000;",
                        "                int countShipsInStar = StarShips(star);",
                        "                for (j = 0; j < starShipPossibleTargetCount; j = j + 1) {",
                        "                    dword possibleTarget = arrStarShipPossibleTarget[j];",
                        "                    if (ShipInNormalSpace(possibleTarget)) {",
                        "                        if(RelationToShip(CRM, possibleTarget) < 10) {",
                        "                            int distance = Dist(curShip, possibleTarget) * Rnd(1, 10);",
                        "                            if (distance < bestDistance) {",
                        "                                enemy = possibleTarget;",
                        "                                bestDistance = distance;",
                        "                            }",
                        "                        }",
                        "                    }",
                        "                }",
                        "            }",
                        "        }",
                        "        ShipSetBad(curShip, enemy);",
                        "",
                        "        //перенастраиваем маркеры того, нужно ли сесть на планету",
                        "        if (StateIs(curShip, 'domikPatrol') || StateIs(curShip, 'bertorPatrol')) { //находимся в стэйте патруля. В других стэйтах нет смысла тратить на это ресурсы",
                        "            int isNeedRepair = 0;",
                        "            if (ItemSize(ShipItems(curShip, 0)) - HullHP(curShip) > ShipDroidRepair(curShip) * 5) //если повреждения не зарегенить за 5 ходов",
                        "                isNeedRepair = 1;",
                        "            if (!isNeedRepair) { //ищем предметы или артефакты на грани поломки",
                        "                int countItems = ShipItems(curShip);",
                        "                int countArts = ShipArts(curShip);",
                        "                for (j = 1; !isNeedRepair && j < countItems; j = j + 1) {",
                        "                    dword thisItem = ShipItems(curShip, j);",
                        "                    if (ItemDurability(thisItem) < 10)",
                        "                        isNeedRepair = 1;",
                        "                }",
                        "                for (j = 0; !isNeedRepair && j < countArts; j = j + 1) {",
                        "                    dword thisArt = ShipArts(curShip, j);",
                        "                    if (ItemDurability(thisArt) < 10)",
                        "                        isNeedRepair = 1;",
                        "                }",
                        "            }",
                        "            SetData(isNeedRepair, 1, curShip);",
                        "        }",
                        "    }",
                        "",
                        "    //перенастраиваем сопровождающих",
                        "    if (starShipNisperEscortRequestorsCount > 0 && starShipNisperFreeDomiksCount > 0) { //имеет смысл делать только если есть кто-то, кому нужен эскорт",
                        "        unknown escortSizes = newarray(starShipNisperEscortRequestorsCount + 1); //размер защиты для каждой цели эскорта + звезды",
                        "        int remainder = starShipNisperFreeDomiksCount % (starShipNisperEscortRequestorsCount + 1);",
                        "        for (i = starShipNisperEscortRequestorsCount; i >= 0; i = i - 1) {",
                        "            escortSizes[i] = starShipNisperFreeDomiksCount / (starShipNisperEscortRequestorsCount + 1); //сначала делим поровну",
                        "            if (remainder > 0) { //если есть остаток от деления, то запихиваем домиков сначала в последние слоты эскорта (звезда всегда будет последней)",
                        "                escortSizes[i] = escortSizes[i] + 1;",
                        "                remainder = remainder - 1;",
                        "            }",
                        "        }",
                        "        int numEscortRequestor = 0;",
                        "        for (i = 0; i < starShipNisperFreeDomiksCount; i = i + 1) { //цикл для тех, кто будет сопровождать берторов",
                        "            curShip = arrStarShipNisperFreeDomiks[i];",
                        "            if (escortSizes[numEscortRequestor] < 1)",
                        "                numEscortRequestor = numEscortRequestor + 1;",
                        "            if (numEscortRequestor < starShipNisperEscortRequestorsCount) { //реально меняем цель для эскорта только для тех, кто будет охранять корабль, а не звезду",
                        "                SetData(Id(arrStarShipNisperEscortRequestors[numEscortRequestor]), 3, curShip);",
                        "                escortSizes[numEscortRequestor] = escortSizes[numEscortRequestor] - 1;",
                        "            }",
                        "        }",
                        "    }",
                        "}",
                        "function IsShipNisperEnemy(ship) { //является ли корабль врагом для Ниспера",
                        "    dword CRM = GetCRM();",
                        "    int relationCoalToShip = RelationToShip(CRM, ship);",
                        "    if (relationCoalToShip < 10)",
                        "        result = 1;",
                        "    else",
                        "        result = 0;",
                        "}",
                        "",
                        "function IsShipNisperFriend(ship) { //является ли корабль другом для Ниспера",
                        "    dword CRM = GetCRM();",
                        "    int relationCoalToShip = RelationToShip(CRM, ship);",
                        "    if (relationCoalToShip >= 60)",
                        "        result = 1;",
                        "    else",
                        "        result = 0;",
                        "}",
                        "",
                        "function GetShipHangar(ship) { //возвращает планету/станцию, на которой находится корабль (или 0, если такой нет)",
                        "    int shipPlanet = GetShipPlanet(ship);",
                        "    int shipRuin = GetShipRuins(ship);",
                        "    if (shipPlanet)",
                        "        result = shipPlanet;",
                        "    else",
                        "        result = shipRuin;",
                        "}",
                        "",
                        "function IsThisRuin(ship) { //является ли станцией корабль",
                        "    result = ShipTypeN(ship) >= 6;",
                        "}",
                        "",
                        "function IsShipNeedRepair(ship) { //нуждается ли корабль в ремонте",
                        "    int isNeedRepair = 0;",
                        "    if (ItemSize(ShipItems(ship, 0)) - HullHP(ship) > ShipDroidRepair(ship) * 5) //если повреждения не зарегенить за 5 ходов",
                        "        isNeedRepair = 1;",
                        "    if (!isNeedRepair) { //ищем предметы или артефакты на грани поломки",
                        "        int countItems = ShipItems(ship);",
                        "        int countArts = ShipArts(ship);",
                        "        for (i = 1; !isNeedRepair && i < countItems; i = i + 1) {",
                        "            dword thisItem = ShipItems(ship, i);",
                        "            if (ItemDurability(thisItem) < 10)",
                        "                isNeedRepair = 1;",
                        "        }",
                        "        for (i = 0; !isNeedRepair && i < countArts; i = i + 1) {",
                        "            dword thisArt = ShipArts(ship, i);",
                        "            if (ItemDurability(thisArt) < 10)",
                        "                isNeedRepair = 1;",
                        "        }",
                        "    }",
                        "    result = isNeedRepair;",
                        "}",
                        "",
                        "function IsStarOwnerCoal(star) { //принадлежит ли система коалиции",
                        "    int starOwner = StarOwner(star);",
                        "    str starCustomOwner = StarCustomFaction(star);",
                        "    int isStarOwnerCoal = (starOwner == 0 && starCustomOwner == '');",
                        "    result = isStarOwnerCoal;",
                        "}",
                        "",
                        "function IsStarOwnerPirate(star) { //принадлежит ли система пиратам",
                        "    int starOwner = StarOwner(star);",
                        "    str starCustomOwner = StarCustomFaction(star);",
                        "    int isStarOwnerPirate = (starOwner == 2 && starCustomOwner == '');",
                        "    result = isStarOwnerPirate;",
                        "}",
                        "",
                        "function IsStarOwnerDomik(star) { //принадлежит ли система доминаторам (возвращает серию доминаторов +1)",
                        "    int starOwner = StarOwner(star);",
                        "    str starCustomOwner = StarCustomFaction(star);",
                        "    int starSerie = StarSeries(star);",
                        "    int isStarOwnerDomik = (starOwner == 1 && starCustomOwner == '') * (starSerie + 1);",
                        "    result = isStarOwnerDomik;",
                        "}",
                        "",
                        "function IsStarInPirateCon(star) { //находится ли система в скрытом секторе пиратов",
                        "    int conPirate = StarToCon(PlanetToStar(PlanetPirateClan()));",
                        "    int conStar = StarToCon(star);",
                        "    if (conStar != conPirate)",
                        "        result = 0;",
                        "    else",
                        "        result = 1;",
                        "}",
                        "",
                        "function IsStarConHaveBertor(star) { //есть ли в секторе указанной звезды бертор",
                        "    dword con = StarToCon(star);",
                        "    int conStarCount = ConStars(con);",
                        "    int flag = 0;",
                        "    for (i = 0; i < conStarCount && !flag; i = i + 1) {",
                        "        star = ConStar(con, i);",
                        "        int bertorsCount = GroupCount(gBertors);",
                        "        for (int j = 0; j < bertorsCount; j = j + 1) {",
                        "            dword bertor = GroupShip(gBertors, j);",
                        "            dword bertorTargetStar = GalaxyStar(GetData(2, bertor));",
                        "            if (bertorTargetStar == star)",
                        "                flag = 1;",
                        "        }",
                        "    }",
                        "    result = flag;",
                        "}",
                        "",
                        "function IsShipOwnerCoal(ship) { //является ли корабль коалиционным",
                        "    int shipOwner = ShipOwner(ship);",
                        "    str shipCustomOwner = ShipCustomFaction(ship);",
                        "    int isShipOwnerCoal = (shipOwner < 5 && (shipCustomOwner == '' || shipCustomOwner == 'SubFaction.Nisper'));",
                        "    result = isShipOwnerCoal;",
                        "}",
                        "",
                        "function IsShipOwnerPirate(ship) { //является ли корабль пиратским",
                        "    int shipOwner = ShipOwner(ship);",
                        "    str shipCustomOwner = ShipCustomFaction(ship);",
                        "    int isShipOwnerPirate = (shipOwner == 7 && shipCustomOwner == '');",
                        "    result = isShipOwnerPirate;",
                        "}",
                        "",
                        "function IsShipOwnerDomik(ship) { //является ли корабль доминаторским (возвращает серию доминатора +1)",
                        "    int shipOwner = ShipOwner(ship);",
                        "    str shipCustomOwner = ShipCustomFaction(ship);",
                        "    int shipSerie = ItemSubrace(ShipItems(ship, 0));",
                        "    int isShipOwnerDomik = (shipOwner == 5 && shipCustomOwner == '') * (shipSerie + 1);",
                        "    result = isShipOwnerDomik;",
                        "}",
                        "",
                        "function IsDomikFree(ship) { //свободен ли доминатор для смены системы",
                        "    int isDomiksFree = 0;",
                        "    if (ShipGroup(ship) == gDomiks) {",
                        "        dword shipTargetStar = GalaxyStar(GetData(2, ship));",
                        "        dword shipStar = ShipStar(ship);",
                        "        if (ShipInNormalSpace(ship) && shipTargetStar == shipStar)",
                        "            isDomiksFree = 1;",
                        "    }",
                        "    result = isDomiksFree;",
                        "}",
                        "",
                        "function IsNeedPassiveAddStartResearchItems() { //нужно ли в этот ход пассивно добавлять материал",
                        "    result = Rnd(1, 25) == 1;",
                        "}",
                        "",
                        "function GetDB() { //возвращает Базу Доминаторов (или 0, если таковой нет)",
                        "    int numDB = GroupCount(gDomiksBase);",
                        "    dword DB = 0;",
                        "    if (numDB > 0)",
                        "        DB = GroupShip(gDomiksBase, 0);",
                        "    result = DB;",
                        "}",
                        "",
                        "function GetCRM() { //возвращает базу оценки отношений (или 0, если таковой нет)",
                        "    int numCRM = GroupCount(gCoalRelationMeter);",
                        "    dword CRM = 0;",
                        "    if (numCRM > 0)",
                        "        CRM = GroupShip(gCoalRelationMeter, 0);",
                        "    result = CRM;",
                        "}",
                        "",
                        "function GetNisper() { //возвращает Ниспера (или 0, если такого нет)",
                        "    dword group;",
                        "    if (NisperBonus == 0)",
                        "        group = gNisper;",
                        "    int numNispers = GroupCount(group);",
                        "    dword Nisper = 0;",
                        "    if (numNispers > 0)",
                        "        Nisper = GroupShip(group, 0);",
                        "    result = Nisper;",
                        "}",
                        "",
                        "function IsAnyFactoryChoosedThisPlanet(selectPlanet) { //проверяет, есть ли какая-нибудь фабрика, которая имеет эту планету в качестве своей цели",
                        "    int flag = 0;",
                        "    int factoryCount = GroupCount(gFactories);",
                        "    for (k = 0; k < factoryCount && flag == 0; k = k + 1) {",
                        "        dword curFactory = GroupShip(gFactories, k);",
                        "        if (IdToPlanet(GetData(1, curFactory)) == selectPlanet)",
                        "            flag = 1;",
                        "    }",
                        "    result = flag;",
                        "}",
                        "",
                        "function IsPlayerUseBertorHull() { //проверяет, установлен ли акрин бертора у игрока в корпусе",
                        "    if (HullSpecial(Player()) == FindBonusByNameInCfg('ZelDomiks_PlayerBertorHull'))",
                        "        result = 1;",
                        "    else",
                        "        result = 0;",
                        "}",
                        "",
                        "function IsNumInBorders(number, botBorder, topBorder, includeBorder) { //по сути просто, что число находится в указанном диапазоне",
                        "    if (includeBorder) {",
                        "        result = (number >= botBorder && number <= topBorder);",
                        "    }",
                        "    else {",
                        "        result = (number > botBorder && number < topBorder);",
                        "    }",
                        "}",
                        "",
                        "function IsBertorQuestComplete() { //простая проверка того, что квест на создание бертора завершен",
                        "    result = arrBertorQuestData['questPhase'] > 3;",
                        "}",
                        "function GetDomikWeaponType(domikType, domikPower) { //возвращает случайный тип оружия в зависимости от типа домика и его силы",
                        "    int weaponType;",
                        "    if (domikType == 0) { //Ниспер",
                        "        if (domikPower <= 3) {",
                        "            weaponType = Choice8(",
                        "                0.30, t_Weapon4,",
                        "                0.10, t_Weapon6,",
                        "                0.15, t_Weapon7,",
                        "                0.15, t_Weapon8,",
                        "                0.15, t_Weapon9,",
                        "                0.05, t_Weapon10,",
                        "                0.05, t_Weapon11,",
                        "                0.05, t_Weapon13",
                        "            );",
                        "        } else if (domikPower <= 4) {",
                        "            weaponType = Choice8(",
                        "                0.25, t_Weapon4,",
                        "                0.20, t_Weapon6,",
                        "                0.15, t_Weapon9,",
                        "                0.10, t_Weapon10,",
                        "                0.10, t_Weapon11,",
                        "                0.05, t_Weapon12,",
                        "                0.10, t_Weapon13,",
                        "                0.05, t_Weapon15",
                        "            );",
                        "        } else if (domikPower <= 5) {",
                        "            weaponType = Choice8(",
                        "                0.15, t_Weapon4,",
                        "                0.15, t_Weapon9,",
                        "                0.15, t_Weapon10,",
                        "                0.15, t_Weapon11,",
                        "                0.10, t_Weapon12,",
                        "                0.15, t_Weapon13,",
                        "                0.05, t_Weapon14,",
                        "                0.10, t_Weapon15",
                        "            );",
                        "        } else if (domikPower <= 6) {",
                        "            weaponType = Choice7(",
                        "                0.05, t_Weapon9,",
                        "                0.10, t_Weapon10,",
                        "                0.10, t_Weapon11,",
                        "                0.15, t_Weapon12,",
                        "                0.25, t_Weapon13,",
                        "                0.15, t_Weapon14,",
                        "                0.20, t_Weapon15",
                        "            );",
                        "        } else {",
                        "            weaponType = Choice5(",
                        "                0.10, t_Weapon10,",
                        "                0.20, t_Weapon12,",
                        "                0.10, t_Weapon13,",
                        "                0.25, t_Weapon14,",
                        "                0.35, t_Weapon15",
                        "            );",
                        "        }",
                        "    }",
                        "    else if (domikType == 1) { //эквентор",
                        "        if (domikPower <= 6) {",
                        "            weaponType = Choice6(",
                        "                0.30, t_Weapon10,",
                        "                0.05, t_Weapon11,",
                        "                0.30, t_Weapon12,",
                        "                0.05, t_Weapon13,",
                        "                0.25, t_Weapon14,",
                        "                0.05, t_Weapon15",
                        "            );",
                        "        } else {",
                        "            weaponType = Choice5(",
                        "                0.10, t_Weapon10,",
                        "                0.30, t_Weapon12,",
                        "                0.15, t_Weapon13,",
                        "                0.35, t_Weapon14,",
                        "                0.10, t_Weapon15",
                        "            );",
                        "        }",
                        "    }",
                        "    else if(domikType == 2) { //ургант",
                        "        if (domikPower <= 6) {",
                        "            weaponType = Choice6(",
                        "                0.30, t_Weapon4,",
                        "                0.25, t_Weapon9,",
                        "                0.05, t_Weapon10,",
                        "                0.05, t_Weapon11,",
                        "                0.30, t_Weapon13,",
                        "                0.05, t_Weapon15",
                        "            );",
                        "        } else {",
                        "            weaponType = Choice6(",
                        "                0.10, t_Weapon4,",
                        "                0.25, t_Weapon9,",
                        "                0.10, t_Weapon10,",
                        "                0.10, t_Weapon12,",
                        "                0.30, t_Weapon13,",
                        "                0.15, t_Weapon15",
                        "            );",
                        "        }",
                        "    }",
                        "    else if(domikType == 3) { //смерш",
                        "        if (domikPower <= 4) {",
                        "            weaponType = Choice4(",
                        "                0.10, t_Weapon5,",
                        "                0.20, t_Weapon7,",
                        "                0.30, t_Weapon8,",
                        "                0.40, t_Weapon15",
                        "            );",
                        "        } else {",
                        "            weaponType = Choice6(",
                        "                0.05, t_Weapon5,",
                        "                0.05, t_Weapon7,",
                        "                0.20, t_Weapon8,",
                        "                0.10, t_Weapon10,",
                        "                0.10, t_Weapon11,",
                        "                0.50, t_Weapon15",
                        "            );",
                        "        }",
                        "    }",
                        "    else if(domikType == 4) { //менок",
                        "        if (domikPower <= 4) {",
                        "            weaponType = Choice4(",
                        "                0.20, t_Weapon2,",
                        "                0.20, t_Weapon4,",
                        "                0.30, t_Weapon6,",
                        "                0.30, t_Weapon7",
                        "            );",
                        "        } else {",
                        "            weaponType = Choice6(",
                        "                0.05, t_Weapon2,",
                        "                0.05, t_Weapon4,",
                        "                0.30, t_Weapon6,",
                        "                0.20, t_Weapon7,",
                        "                0.15, t_Weapon9,",
                        "                0.25, t_Weapon12",
                        "            );",
                        "        }",
                        "    }",
                        "    else if(domikType == 5) { //штип",
                        "        if (domikPower <= 2) {",
                        "            weaponType = Choice3(",
                        "                0.25, t_Weapon1,",
                        "                0.50, t_Weapon3,",
                        "                0.25, t_Weapon5",
                        "            );",
                        "        } else {",
                        "            weaponType = Choice5(",
                        "                0.05, t_Weapon1,",
                        "                0.30, t_Weapon3,",
                        "                0.10, t_Weapon5,",
                        "                0.05, t_Weapon10,",
                        "                0.50, t_Weapon11",
                        "            );",
                        "        }",
                        "    }",
                        "    else if(domikType == 6) { //бертор",
                        "        weaponType = Choice3(",
                        "            0.25, t_Weapon13,",
                        "            0.25, t_Weapon14,",
                        "            0.50, t_Weapon15",
                        "        );",
                        "    }",
                        "    else if(domikType == 7) { //клиг",
                        "        if (domikPower <= 2) {",
                        "            weaponType = Choice4(",
                        "                0.15, t_Weapon1,",
                        "                0.50, t_Weapon3,",
                        "                0.25, t_Weapon5,",
                        "                0.10, t_Weapon8",
                        "            );",
                        "        } else {",
                        "            weaponType = Choice5(",
                        "                0.10, t_Weapon3,",
                        "                0.40, t_Weapon5,",
                        "                0.15, t_Weapon7,",
                        "                0.30, t_Weapon8,",
                        "                0.05, t_Weapon9",
                        "            );",
                        "        }",
                        "    }",
                        "    result = weaponType;",
                        "}",
                        "",
                        "function GetArtTypeSize(artType) { //возвращает минимальную массу стандартных видов артефактов",
                        "    int artSize = 10;",
                        "    if (artType == t_ArtefactHull)",
                        "        artSize = 10;",
                        "    else if (eqType == t_ArtefactFuel)",
                        "        artSize = 3;",
                        "    else if (eqType == t_ArtefactSpeed)",
                        "        artSize = 10;",
                        "    else if (eqType == t_ArtefactPower)",
                        "        artSize = 6;",
                        "    else if (eqType == t_ArtefactRadar)",
                        "        artSize = 8;",
                        "    else if (eqType == t_ArtefactScaner)",
                        "        artSize = 7;",
                        "    else if (eqType == t_ArtefactDroid)",
                        "        artSize = 8;",
                        "    else if (eqType == t_ArtefactNano)",
                        "        artSize = 3;",
                        "    else if (eqType == t_ArtefactHook)",
                        "        artSize = 3;",
                        "    else if (eqType == t_ArtefactDef)",
                        "        artSize = 10;",
                        "    else if (eqType == t_ArtefactAnalyzer)",
                        "        artSize = 4;",
                        "    else if (eqType == t_ArtefactMiniExpl)",
                        "        artSize = 8;",
                        "    else if (eqType == t_ArtefactAntigrav)",
                        "        artSize = 17;",
                        "    else if (eqType == t_ArtefactTransmitter)",
                        "        artSize = 3;",
                        "    else if (eqType == t_ArtefactBomb)",
                        "        artSize = 4;",
                        "    else if (eqType == t_ArtefactTranclucator)",
                        "        artSize = 42;",
                        "    else if (eqType == t_ArtDefToEnergy)",
                        "        artSize = 4;",
                        "    else if (eqType == t_ArtEnergyPulse)",
                        "        artSize = 7;",
                        "    else if (eqType == t_ArtEnergyDef)",
                        "        artSize = 4;",
                        "    else if (eqType == t_ArtSplinter)",
                        "        artSize = 8;",
                        "    else if (eqType == t_ArtDecelerate)",
                        "        artSize = 4;",
                        "    else if (eqType == t_ArtMissileDef)",
                        "        artSize = 5;",
                        "    else if (eqType == t_ArtForsage)",
                        "        artSize = 5;",
                        "    else if (eqType == t_ArtWeaponToSpeed)",
                        "        artSize = 6;",
                        "    else if (eqType == t_ArtGiperJump)",
                        "        artSize = 4;",
                        "    else if (eqType == t_ArtBlackHole)",
                        "        artSize = 3;",
                        "    else if (eqType == t_ArtDefToArms1)",
                        "        artSize = 8;",
                        "    else if (eqType == t_ArtDefToArms2)",
                        "        artSize = 6;",
                        "    else if (eqType == t_ArtArtefactor)",
                        "        artSize = 3;",
                        "    else if (eqType == t_ArtBio)",
                        "        artSize = 2;",
                        "    else if (eqType == t_ArtPDTurret)",
                        "        artSize = 18;",
                        "    else if (eqType == t_ArtFastRacks)",
                        "        artSize = 8;",
                        "    result = artSize;",
                        "}",
                        "",
                        "function GetEqTypeSize(eqType) { //возвращает минимальную массу стандартных видов оборудования",
                        "    int eqSize = 10;",
                        "    if (eqType == t_FuelTanks)",
                        "        eqSize = 20;",
                        "    else if (eqType == t_Engine)",
                        "        eqSize = 20;",
                        "    else if (eqType == t_Radar)",
                        "        eqSize = 15;",
                        "    else if (eqType == t_Scaner)",
                        "        eqSize = 15;",
                        "    else if (eqType == t_RepairRobot)",
                        "        eqSize = 20;",
                        "    else if (eqType == t_CargoHook)",
                        "        eqSize = 20;",
                        "    else if (eqType == t_DefGenerator)",
                        "        eqSize = 20;",
                        "    else if (eqType == t_Weapon1)",
                        "        eqSize = 15;",
                        "    else if (eqType == t_Weapon2)",
                        "        eqSize = 20;",
                        "    else if (eqType == t_Weapon3)",
                        "        eqSize = 25;",
                        "    else if (eqType == t_Weapon4)",
                        "        eqSize = 10;",
                        "    else if (eqType == t_Weapon5)",
                        "        eqSize = 15;",
                        "    else if (eqType == t_Weapon6)",
                        "        eqSize = 20;",
                        "    else if (eqType == t_Weapon7)",
                        "        eqSize = 30;",
                        "    else if (eqType == t_Weapon8)",
                        "        eqSize = 15;",
                        "    else if (eqType == t_Weapon9)",
                        "        eqSize = 35;",
                        "    else if (eqType == t_Weapon10)",
                        "        eqSize = 40;",
                        "    else if (eqType == t_Weapon11)",
                        "        eqSize = 45;",
                        "    else if (eqType == t_Weapon12)",
                        "        eqSize = 50;",
                        "    else if (eqType == t_Weapon13)",
                        "        eqSize = 120;",
                        "    else if (eqType == t_Weapon14)",
                        "        eqSize = 165;",
                        "    else if (eqType == t_Weapon15)",
                        "        eqSize = 30;",
                        "    else if (eqType == t_Weapon16)",
                        "        eqSize = 30;",
                        "    else if (eqType == t_Weapon17)",
                        "        eqSize = 25;",
                        "    else if (eqType == t_Weapon18)",
                        "        eqSize = 15;",
                        "    result = eqSize;",
                        "}",
                        "",
                        "function DeleteAllItemsShip(ship) { //удаляет все предметы на корабле",
                        "    for (i = ShipItems(ship) - 1; i > 0; i = i - 1)",
                        "        FreeItem(GetItemFromShip(ship, i));",
                        "}",
                        "",
                        "function DeleteAllWeaponsShip(ship) { //удаляет все пушки на корабле",
                        "    dword item = ShipEqInSlot(ship, t_Weapon1, 1);",
                        "    for (i = 1; item != 0;) {",
                        "        FreeItem(GetItemFromShip(ship, item));",
                        "        i = i + 1;",
                        "        item = ShipEqInSlot(ship, t_Weapon1, i);",
                        "    }",
                        "}",
                        "",
                        "function SetEqNisperRace(eq) { //выставляет предмету случайную доминаторскую расу с пометкой Ниспера",
                        "    ItemOwner(eq, Kling);",
                        "    ItemSubrace(eq, Rnd(0, 2));",
                        "    EqCustomFaction(eq, 'SubFaction.Nisper');",
                        "}",
                        "",
                        "function GetDomikRndHullSize(domikType) { //возвращает случайный размер корпуса в зависимости от типа доминатора",
                        "    str domikTypeName = GetStrDomikTypeName(domikType);",
                        "    int minDomikSize = arrDomiksSize[domikTypeName, 'Min'];",
                        "    int maxDomikSize = arrDomiksSize[domikTypeName, 'Max'];",
                        "    result = Rnd(minDomikSize, maxDomikSize);",
                        "}",
                        "",
                        "function SetHullStdNisperDomik(hull, domikType, domikPower) { //выставляет корпусу атрибуты обычного домика Ниспера",
                        "    int hullSize = GetDomikRndHullSize(domikType);",
                        "    int eqLevel = GetValueByPower(domikPower, 'StdEqLevel');",
                        "    ItemSize(hull, hullSize);",
                        "    HullHP(hull, hullSize);",
                        "    HullSeries(hull, -1);",
                        "    ItemLevel(hull, eqLevel);",
                        "    SetName(hull, GetStrDominatorHullLevelName(eqLevel) + ' корпус доминатора');",
                        "    SetEqNisperRace(hull);",
                        "}",
                        "",
                        "function SetHullNisper(hull, nisperType, domikPower) { //выставляет корпусу атрибуты Ниспера",
                        "    int hullSize = GetNisperRndHullSize(nisperType);",
                        "    int eqLevel = GetValueByPower(domikPower, 'StdEqLevel');",
                        "    ItemSize(hull, hullSize);",
                        "    HullHP(hull, hullSize);",
                        "    HullSeries(hull, -1);",
                        "    ItemLevel(hull, eqLevel);",
                        "    SetName(hull, GetStrDominatorHullLevelName(eqLevel) + ' корпус доминатора');",
                        "    SetEqNisperRace(hull);",
                        "}",
                        "",
                        "function GetNisperRndHullSize(nisperType) { //возвращает размер корпуса для Ниспера в зависимости от текущей прокачки, рандома и типа Ниспера",
                        "    int rndCoef = Rnd(7, 12);",
                        "    int eqCoef = upgradePower * 11;",
                        "    int spawnCoef = upgradeSpawn * 13;",
                        "    float typeCoef = 1.0;",
                        "    if (nisperType == 1)",
                        "        typeCoef = 1.25;",
                        "    else if (nisperType == 2)",
                        "        typeCoef = 1.1;",
                        "    else if (nisperType == 3)",
                        "        typeCoef = 1.45;",
                        "    int hullSize = typeCoef * (rndCoef * (300 + eqCoef + spawnCoef));",
                        "    hullSize = hullSize / 10 * 10;",
                        "    result = hullSize;",
                        "}",
                        "",
                        "function GetStdNisperEq(domikType, domikPower, eqType) { //выдает кораблю указанный предмет с характеристиками фракции Ниспера в зависимости от силы",
                        "    int eqLevel = 1;",
                        "    str domikTypeName = GetStrDomikTypeName(domikType);",
                        "    int minItemsSizeCoef = arrItemsSize[domikTypeName, 'Min'];",
                        "    int maxItemsSizeCoef = arrItemsSize[domikTypeName, 'Max'];",
                        "    int eqSizeCoef = Rnd(minItemsSizeCoef, maxItemsSizeCoef) / 2;",
                        "    int eqSize = ((3 + eqSizeCoef) * (100 + Rnd(0,50)) * GetEqTypeSize(eqType)) / 300;",
                        "    if (eqType == t_Engine)",
                        "        eqLevel = GetValueByPower(domikPower, 'EngineLevel');",
                        "    else",
                        "        eqLevel = GetValueByPower(domikPower, 'StdEqLevel');",
                        "    dword eq = CreateEquipment(eqType, eqSize, eqLevel, 5);",
                        "    SetEqNisperRace(eq);",
                        "    result = eq;",
                        "}",
                        "",
                        "function SetStdFactoryEq(ship) { //увеличивает бак (минимум так, чтобы хватало на максимальную дальность прыжка)",
                        "    for (i = 0; i < 5; i = i + 1)",
                        "        ShipRefit(ship);",
                        "    int race = GetOwner(ship);",
                        "    dword item;",
                        "    dword newItem;",
                        "    if (race == 0) { //малокам улучшаем все орудия",
                        "        item = ShipEqInSlot(ship, t_Weapon1, 1);",
                        "        for (i = 1; item != 0;) {",
                        "            int itemType = ItemType(item);",
                        "            str customType = CustomWeaponType(item);",
                        "            int itemSize = ItemSize(item);",
                        "            GetItemFromShip(ship, item);",
                        "            FreeItem(item);",
                        "            if (customType == '')",
                        "                newItem = CreateEquipment(itemType, itemSize, GTL, 0);",
                        "            else",
                        "                newItem = CreateCustomWeapon(customType, itemSize, GTL, 0);",
                        "            ItemImprovement(newItem, 2);",
                        "            AddItemToShip(ship, newItem);",
                        "            ItemIsInUse(newItem, ship, 1, i);",
                        "            i = i + 1;",
                        "            item = ShipEqInSlot(ship, t_Weapon1, i);",
                        "        }",
                        "    }",
                        "    else if (race == 1) { //пеленгам улучшаем скорость двигателя",
                        "        item = ShipEqInSlot(ship, t_Engine);",
                        "        itemType = ItemType(item);",
                        "        itemSize = ItemSize(item);",
                        "        GetItemFromShip(ship, item);",
                        "        FreeItem(item);",
                        "        newItem = CreateEquipment(itemType, itemSize, GTL, 1);",
                        "        ItemImprovement(newItem, 2, 1);",
                        "        AddItemToShip(ship, newItem);",
                        "        ItemIsInUse(newItem, ship, 1);",
                        "    }",
                        "    else if (race == 2) { //людям улучшаем дроида",
                        "        item = ShipEqInSlot(ship, t_RepairRobot);",
                        "        if (item) {",
                        "            itemType = ItemType(item);",
                        "            itemSize = ItemSize(item);",
                        "            GetItemFromShip(ship, item);",
                        "            FreeItem(item);",
                        "        }",
                        "        else {",
                        "            itemType = t_RepairRobot;",
                        "            itemSize = Rnd(30, 80);",
                        "        }",
                        "        newItem = CreateEquipment(itemType, itemSize, GTL, 1);",
                        "        ItemImprovement(newItem, 2);",
                        "        AddItemToShip(ship, newItem);",
                        "        ItemIsInUse(newItem, ship, 1);",
                        "    }",
                        "    else if (race == 3) { //фэянам улучшаем двигатель",
                        "        item = ShipEqInSlot(ship, t_Engine);",
                        "        itemType = ItemType(item);",
                        "        itemSize = ItemSize(item);",
                        "        GetItemFromShip(ship, item);",
                        "        FreeItem(item);",
                        "        newItem = CreateEquipment(itemType, itemSize, GTL, 3);",
                        "        ItemImprovement(newItem, 2, 2);",
                        "        AddItemToShip(ship, newItem);",
                        "        ItemIsInUse(newItem, ship, 1);",
                        "    }",
                        "    else if (race == 4) { //гаальцам улучшаем генератор",
                        "        item = ShipEqInSlot(ship, t_DefGenerator);",
                        "        if (item) {",
                        "            itemType = ItemType(item);",
                        "            itemSize = ItemSize(item);",
                        "            GetItemFromShip(ship, item);",
                        "            FreeItem(item);",
                        "        }",
                        "        else {",
                        "            itemType = t_DefGenerator;",
                        "            itemSize = Rnd(30, 80);",
                        "        }",
                        "        newItem = CreateEquipment(itemType, itemSize, GTL, 1);",
                        "        ItemImprovement(newItem, 2);",
                        "        AddItemToShip(ship, newItem);",
                        "        ItemIsInUse(newItem, ship, 1);",
                        "    }",
                        "    dword fuelTanks = ShipEqInSlot(ship, t_FuelTanks);",
                        "    while (GetEquipmentStats(fuelTanks, 0) < ShipJump(ship)) {",
                        "        SetEquipmentStats(fuelTanks, ShipJump(ship), 0);",
                        "    }",
                        "}",
                        "",
                        "function SetStdFactoryHull(ship) { //увеличивает корпус, навешивает нужную серию",
                        "    dword hull = ShipItems(ship, 0);",
                        "    HullSeries(hull, FindSeriesByName('Колосс'));",
                        "    int hullSize = Rnd(1500, 2500);",
                        "    ItemSize(hull, hullSize);",
                        "    HullHP(hull, hullSize);",
                        "    Chameleon(ship);",
                        "    ShipCalcParam(ship);",
                        "}",
                        "",
                        "function GetStdDomikEqKit(ship, domikType, domikPower) { //выдает пакет обычного оборудования доминатора кораблю в зависимости от его типа и силы",
                        "    dword eq;",
                        "    int chanceEq;",
                        "    int weaponCount;",
                        "    eq = GetStdNisperEq(domikType, domikPower, t_Engine);",
                        "    AddItemToShip(ship, eq);",
                        "    eq = GetStdNisperEq(domikType, domikPower, t_Radar);",
                        "    AddItemToShip(ship, eq);",
                        "    eq = GetStdNisperEq(domikType, domikPower, t_Scaner);",
                        "    AddItemToShip(ship, eq);",
                        "    eq = GetStdNisperEq(domikType, domikPower, t_FuelTanks);",
                        "    AddItemToShip(ship, eq);",
                        "    eq = GetStdNisperEq(domikType, domikPower, t_CargoHook);",
                        "    AddItemToShip(ship, eq);",
                        "    chanceEq = GetValueByPower(domikPower, 'DroidChance');",
                        "    if (Rnd(1, 100) <= chanceEq || domikType == 6) {",
                        "        eq = GetStdNisperEq(domikType, domikPower, t_RepairRobot);",
                        "        AddItemToShip(ship, eq);",
                        "    }",
                        "    chanceEq = GetValueByPower(domikPower, 'DefChance');",
                        "    if (Rnd(1, 100) <= chanceEq || domikType == 6) {",
                        "        eq = GetStdNisperEq(domikType, domikPower, t_DefGenerator);",
                        "        AddItemToShip(ship, eq);",
                        "    }",
                        "    weaponCount = GetValueByPower(domikPower, 'WeaponCount');",
                        "    for (j = 0; j < weaponCount; j = j + 1) {",
                        "        dword eqType = GetDomikWeaponType(domikType, domikPower);",
                        "        eq = GetStdNisperEq(domikType, domikPower, eqType);",
                        "        AddItemToShip(ship, eq);",
                        "    }",
                        "}",
                        "",
                        "function GetNisperEqKit(ship, domikPower) { //выдает пакет обычного оборудования Ниспера кораблю в зависимости от силы",
                        "    dword eq;",
                        "    int chanceEq;",
                        "    int weaponCount;",
                        "    eq = GetStdNisperEq(0, domikPower, t_Engine);",
                        "    AddItemToShip(ship, eq);",
                        "    eq = GetStdNisperEq(0, domikPower, t_Radar);",
                        "    AddItemToShip(ship, eq);",
                        "    eq = GetStdNisperEq(0, domikPower, t_Scaner);",
                        "    AddItemToShip(ship, eq);",
                        "    eq = GetStdNisperEq(0, domikPower, t_FuelTanks);",
                        "    AddItemToShip(ship, eq);",
                        "    eq = GetStdNisperEq(0, domikPower, t_RepairRobot);",
                        "    AddItemToShip(ship, eq);",
                        "    eq = GetStdNisperEq(0, domikPower, t_CargoHook);",
                        "    AddItemToShip(ship, eq);",
                        "    eq = GetStdNisperEq(0, domikPower, t_DefGenerator);",
                        "    AddItemToShip(ship, eq);",
                        "    for (j = 0; j < 5; j = j + 1) {",
                        "        dword eqType = GetDomikWeaponType(0, domikPower);",
                        "        eq = GetStdNisperEq(0, domikPower, eqType);",
                        "        AddItemToShip(ship, eq);",
                        "    }",
                        "}",
                        "",
                        "function UseAllItemsShip(ship) { //заставляю корабль надеть все вещи в инвентаре",
                        "    int weaponSlot = 1;",
                        "    int artSlot = 1;",
                        "    int countItems = ShipItems(ship);",
                        "    int countArts = ShipArts(ship);",
                        "    for (i = 1; i < countItems; i = i + 1) {",
                        "        dword item = ShipItems(ship, i);",
                        "        int itemType = ItemType(item);",
                        "        if (itemType >= t_Weapon1 && itemType <= t_CustomWeapon) {",
                        "            ItemIsInUse(item, ship, 1, weaponSlot);",
                        "            weaponSlot = weaponSlot + 1;",
                        "        } else",
                        "            ItemIsInUse(item, ship, 1);",
                        "    }",
                        "    for (i = 0; i < countArts; i = i + 1) {",
                        "        dword art = ShipArts(ship, i);",
                        "        ItemIsInUse(art, ship, 1, artSlot);",
                        "        artSlot = artSlot + 1;",
                        "    }",
                        "}",
                        "",
                        "function SetShipNisperFacing(ship, domikType) { //устанавливает стандартное обличие доминатора кораблю в зависимости от типа домика",
                        "    dword shipHull = ShipItems(ship, 0);",
                        "    str hullName = 'ZelDomiks_Nisper' + domikType;",
                        "    SpecialToEquipment(FindBonusByNameInCfg(hullName), shipHull);",
                        "    Chameleon(ship);",
                        "    ShipFace(ship, 4);",
                        "}",
                        "",
                        "function SetNisperFacing(ship, nisperType) { //устанавливает стандартное обличие Ниспера кораблю в зависимости от типа Ниспера",
                        "    dword shipHull = ShipItems(ship, 0);",
                        "    str strCharNisper;",
                        "    if (nisperType == 0) {",
                        "        strCharNisper = '';",
                        "        ShipFace(ship, 0);",
                        "    } else if (nisperType == 1) {",
                        "        strCharNisper = 'B';",
                        "        ShipFace(ship, 1);",
                        "    } else if (nisperType == 2) {",
                        "        strCharNisper = 'K';",
                        "        ShipFace(ship, 2);",
                        "    } else if (nisperType == 3) {",
                        "        strCharNisper = 'T';",
                        "        ShipFace(ship, 3);",
                        "    }",
                        "    str hullName = 'Ruins.Nisper0' + strCharNisper;",
                        "    SpecialToEquipment(FindBonusByNameInCfg('ZelDomiks_Nisper0'), shipHull);",
                        "    Chameleon(ship, hullName);",
                        "}",
                        "",
                        "function DBAlgorithmFacing(DB) { //устанавливает обличие Базы Доминаторов кораблю",
                        "    ShipCustomFaction(DB,'SubFaction.Nisper');",
                        "    SetName(DB,'База Доминаторов');",
                        "    ShipTechLevelKnowledge(DB, 8);",
                        "    Chameleon(DB);",
                        "}",
                        "",
                        "function SetShipNisperSkills(ship, domikType) { //устанавливает кораблю скиллы в зависимости от количества систем и уровня Ниспера (самому Нисперу выставляется все на фул)",
                        "    if (domikType == 0) {",
                        "        for (i = 0; i < 6; i = i + 1)",
                        "            ShipSkill(ship, i, 6);",
                        "    } else {",
                        "        int maxProcCoalStars = GetMaxProcCoalStars();",
                        "        int mediumSkillLevel = round(PortionInDiapason(NisperLevel, 1, 10, 0, 6));",
                        "        int minSkillLevel = round(PortionInDiapason(NisperLevel, 1, 10, 0, 5));",
                        "        int maxSkillLevel = round(PortionInDiapason(NisperLevel, 1, 10, 3, 6));",
                        "        int skillLevel1 = min(6, max(0, RndByProcStars(minSkillLevel, maxSkillLevel, maxProcCoalStars)));",
                        "        int skillLevel2 = min(6, max(0, RndByProcStars(minSkillLevel, maxSkillLevel, maxProcCoalStars)));",
                        "        ShipSkill(ship, 0, skillLevel1);",
                        "        ShipSkill(ship, 1, skillLevel2);",
                        "        ShipSkill(ship, 2, 6);",
                        "    }",
                        "}",
                        "",
                        "function NisperReequipment(ship, nisperType) { //меняет экипировку Нисперу в зависимости от текущей силы",
                        "    int domikPowerPoints = GetStarDomiksPower(ShipStar(ship));",
                        "    int domikPower = GetPowerFromPowerPoints(domikPowerPoints + 1000);",
                        "    domikPower = min(7, max(1, domikPower + 1));",
                        "    dword hull = ShipItems(ship, 0);",
                        "    DeleteAllItemsShip(ship);",
                        "    SetHullNisper(hull, nisperType, domikPower);",
                        "    GetNisperEqKit(ship,  domikPower);",
                        "    UseAllItemsShip(ship);",
                        "}",
                        "",
                        "function GetNisperReloadReequipment() { //возвращает перезарядку между сменами экипировок",
                        "    result = Rnd(150, 250);",
                        "}",
                        "",
                        "function ChangeItemsSizeToHullSize(ship) { //приближает размер оборудования на корабле к размерам корпуса (убирает перевес)",
                        "    int freeSpace = ShipFreeSpace(ship);",
                        "    while (freeSpace < 0) {",
                        "        for (i = ShipItems(ship) - 1; freeSpace < 0 && i > 0; i = i - 1) {",
                        "            int eqSize = ItemSize(ShipItems(ship, i));",
                        "            int updateEqSize = max(1, eqSize / 10);",
                        "            ItemSize(ShipItems(ship, i), max(1, eqSize - updateEqSize));",
                        "            freeSpace = freeSpace + updateEqSize;",
                        "        } for (i = ShipArts(ship) - 1; freeSpace < 0 && i >= 0; i = i - 1) {",
                        "            int artSize = ItemSize(ShipArts(ship, i));",
                        "            int updateArtSize = max(1, artSize / 10);",
                        "            ItemSize(ShipItems(ship, i), max(1, artSize - updateArtSize));",
                        "            freeSpace = freeSpace + updateArtSize;",
                        "        }",
                        "    }",
                        "    ShipCalcParam(ship);",
                        "}",
                        "",
                        "function StdUpgradeAllEq(ship, domikPower) { //пытается улучшить все оборудование на корабле в зависимости от силы",
                        "    for (i = ShipItems(ship) - 1; i >= 0; i = i - 1) {",
                        "        dword item = ShipItems(ship, i);",
                        "        chanceUpgr = GetValueByPower(domikPower, 'UpgradeChance');",
                        "        if (ItemImprovement(item) == 0) {",
                        "            if (Rnd(1, 100) <= chanceUpgr || domikType == 6) {",
                        "                upgrLevel = GetValueByPower(domikPower, 'UpgradeLevel');",
                        "                ItemImprovement(item, upgrLevel);",
                        "            }",
                        "        }",
                        "    }",
                        "}",
                        "",
                        "function CreateArtBlackHoleForBertors(donorArt, serie) { //создает кастомный юзлес (на основе артефакта-донора), который должен работать как субпортал",
                        "    dword artBlackHoleForBertors;",
                        "    artBlackHoleForBertors = CreateQuestItem('ZelDomiks_UselessBlackHoleForBertors' + GetStrSerieName(serie), ItemOwner(donorArt));",
                        "    //ItemSubrace(artBlackHoleForBertors, serie);",
                        "    ItemSize(artBlackHoleForBertors, ItemSize(donorArt) + Rnd(1, 2));",
                        "    ItemCost(artBlackHoleForBertors, round(1.3 * ItemCost(donorArt)));",
                        "    result = artBlackHoleForBertors;",
                        "}",
                        "",
                        "function GetBertorMaterialCost() { //возвращает цену за 1 штуку материала бертора",
                        "    int cost = 1000 + round(0.02 * RangersCapital());",
                        "    if (cost > 2000)",
                        "        cost = 2000 + round((0.02 * RangersCapital() - 1000) / 2);",
                        "    result = cost;",
                        "}",
                        "function Random_real() {",
                        "    result = 1.0 * Rnd(0, 1000000000) / 1000000000.0;",
                        "}",
                        "",
                        "function Choice2(w1, a, w2, b) {",
                        "    if (w1 + w2 == 0)",
                        "        result = Choice2(1.0, a, 1.0, b);",
                        "    else {",
                        "        if (Random_real() < 1.0 * w1 / (0.0 + w1 + w2))",
                        "            result = a;",
                        "        else",
                        "            result = b;",
                        "    }",
                        "}",
                        "",
                        "function Choice4(w1, a, w2, b, w3, c, w4, d) {",
                        "    result = Choice2(",
                        "        w1 + w2, Choice2(w1, a, w2, b),",
                        "        w3 + w4, Choice2(w3, c, w4, d)",
                        "    );",
                        "}",
                        "",
                        "function Choice8(w1, a, w2, b, w3, c, w4, d, w5, e, w6, f, w7, g, w8, h) {",
                        "    result = Choice2(",
                        "        w1 + w2 + w3 + w4, Choice4(w1, a, w2, b, w3, c, w4, d),",
                        "        w5 + w6 + w7 + w8, Choice4(w5, e, w6, f, w7, g, w8, h)",
                        "    );",
                        "}",
                        "",
                        "function Choice3(w1, a, w2, b, w3, c) {",
                        "    result = Choice4(w1, a, w2, b, w3, c, 0, 0);",
                        "}",
                        "",
                        "function Choice5(w1, a, w2, b, w3, c, w4, d, w5, e) {",
                        "    result = Choice8(w1, a, w2, b, w3, c, w4, d, w5, e, 0, 0, 0, 0, 0, 0);",
                        "}",
                        "",
                        "function Choice6(w1, a, w2, b, w3, c, w4, d, w5, e, w6, f) {",
                        "    result = Choice8(w1, a, w2, b, w3, c, w4, d, w5, e, w6, f, 0, 0, 0, 0);",
                        "}",
                        "",
                        "function Choice7(w1, a, w2, b, w3, c, w4, d, w5, e, w6, f, w7, g) {",
                        "    result = Choice8(w1, a, w2, b, w3, c, w4, d, w5, e, w6, f, w7, g, 0, 0);",
                        "}",
                        "",
                        "function GetRandomDomikType(canSpawnBertor) {",
                        "    int typeOfDomik = 5;",
                        "    int maxProcCoalStars = GetMaxProcCoalStars();",
                        "    int procCoalStars = GetProcCoalStars();",
                        "    int level = round(PortionInDiapason(procCoalStars, 1, maxProcCoalStars, 1, 5));",
                        "    if (level == 1) {",
                        "        typeOfDomik = Choice6(",
                        "            0.100, 1,",
                        "            0.150, 2,",
                        "            0.300, 3,",
                        "            0.250, 4,",
                        "            0.200, 5,",
                        "            0.030, 6",
                        "        );",
                        "    } else if (level == 2) {",
                        "        typeOfDomik = Choice6(",
                        "            0.100, 1,",
                        "            0.100, 2,",
                        "            0.250, 3,",
                        "            0.250, 4,",
                        "            0.300, 5,",
                        "            0.020, 6",
                        "        );",
                        "    } else if (level == 3) {",
                        "        typeOfDomik = Choice6(",
                        "            0.050, 1,",
                        "            0.100, 2,",
                        "            0.200, 3,",
                        "            0.250, 4,",
                        "            0.400, 5,",
                        "            0.010, 6",
                        "        );",
                        "    } else if (level == 4) {",
                        "        typeOfDomik = Choice6(",
                        "            0.050, 1,",
                        "            0.050, 2,",
                        "            0.150, 3,",
                        "            0.250, 4,",
                        "            0.500, 5,",
                        "            0.002, 6",
                        "        );",
                        "    } else if (level == 5) {",
                        "        typeOfDomik = Choice6(",
                        "            0.050, 1,",
                        "            0.050, 2,",
                        "            0.100, 3,",
                        "            0.200, 4,",
                        "            0.600, 5,",
                        "            0.000, 6",
                        "        );",
                        "    }",
                        "    if (!canSpawnBertor && typeOfDomik == 6)",
                        "        typeOfDomik = 1; //если выпал бертор, но его нельзя спавнить - спавним эквентора",
                        "    result = typeOfDomik;",
                        "}",
                        "",
                        "function GetMidValueByTurn(value) {",
                        "    int half = value / 2;",
                        "    result = round(PortionInDiapason(CurTurn(), 300, 300 + 365 * 30, half / 2, half * 3 / 2));",
                        "}",
                        "",
                        "function RndByProcStars(bigProcStarsValue, smallProcStarsValue, maxProcCoalStars) { //рандомизирует число в зависимости от заданных границ и количества систем под коалицией",
                        "    int procCoalStars = GetProcCoalStars();",
                        "    int halfProcCoalStars = GetMidValueByTurn(maxProcCoalStars);",
                        "    int minimum = round(PortionInDiapason(procCoalStars, 1, halfProcCoalStars, smallProcStarsValue, bigProcStarsValue));",
                        "    int maximum = round(PortionInDiapason(procCoalStars, halfProcCoalStars, maxProcCoalStars, smallProcStarsValue, bigProcStarsValue));",
                        "    result = Rnd(minimum, maximum);",
                        "}",
                        "",
                        "function GetValueByPower(domikPower, category) { //возвращает число выбранной категории в зависимости от силы доминатора",
                        "    int minBoard = arrCountAndLevelEq[category, 'Power' + domikPower, 'Min'];",
                        "    int maxBoard = arrCountAndLevelEq[category, 'Power' + domikPower, 'Max'];",
                        "    int maxProcCoalStars = GetMaxProcCoalStars();",
                        "    result = RndByProcStars(minBoard, maxBoard, maxProcCoalStars);",
                        "}",
                        "",
                        "function GetIntByGeomLaw(startint, multCount, multiplicator) { //возвращает целое число умноженное multCount число раз на multiplicator",
                        "    float multint = 1.0 * startint;",
                        "    for (i = 0; i < multCount; i = i + 1)",
                        "        multint = multiplicator * multint;",
                        "    result = round(multint);",
                        "}",
                        "",
                        "function GetStrSerieName(serie) { //возвращает строку - имя определенной серии доминаторов",
                        "    str strSerie;",
                        "    if (serie == 0)",
                        "        strSerie = 'Blazer';",
                        "    else if(serie == 1)",
                        "        strSerie = 'Keller';",
                        "    else if(serie == 2)",
                        "        strSerie = 'Terron';",
                        "    else if(serie == 3)",
                        "        strSerie = 'Nisper';",
                        "    result = strSerie;",
                        "}",
                        "",
                        "function GetStrDomikTypeName(domikType) {",
                        "    str domikTypeName;",
                        "    if(domikType == 0)",
                        "        domikTypeName = 'Boss';",
                        "    else if (domikType == 1)",
                        "        domikTypeName = 'Ekventor';",
                        "    else if (domikType == 2)",
                        "        domikTypeName = 'Urgant';",
                        "    else if (domikType == 3)",
                        "        domikTypeName = 'Smersh';",
                        "    else if (domikType == 4)",
                        "        domikTypeName = 'Menok';",
                        "    else if (domikType == 5)",
                        "        domikTypeName = 'Shtip';",
                        "    else if (domikType == 6)",
                        "        domikTypeName = 'Bertor';",
                        "    else if (domikType == 7)",
                        "        domikTypeName = 'Klig';",
                        "    result = domikTypeName;",
                        "}",
                        "",
                        "function GetStrDominatorHullLevelName(hullLevel) {",
                        "    if (hullLevel == 1)",
                        "        result = 'Гравикорный';",
                        "    else if (hullLevel == 2)",
                        "        result = 'Мезоструктурный';",
                        "    else if (hullLevel == 3)",
                        "        result = 'Рогостовый';",
                        "    else if (hullLevel == 4)",
                        "        result = 'Бромированный';",
                        "    else if (hullLevel == 5)",
                        "        result = 'Хробайтовый';",
                        "    else if (hullLevel == 6)",
                        "        result = 'Полиморфный';",
                        "    else if (hullLevel == 7)",
                        "        result = 'Нанохитиновый';",
                        "    else",
                        "        result = 'Биослотовый';",
                        "}",
                        "",
                        "function GetMaxProcCoalStars() { //возвращает максимальный желаемый процент количества систем Коалиции",
                        "    result = 15 + 8 * NisperLevel;",
                        "}",
                        "",
                        "function GetAddBattleStarSpawnChance() {",
                        "    result = 50 + 5 * upgradeSpawn / 2;",
                        "}",
                        "",
                        "function GetPowerFromPowerPoints(powerPoints) { //возвращает значение силы Ниспера в зависимости от данного количества очков силы Ниспера",
                        "    int power = powerPoints / 1000;",
                        "    if (Rnd(1, 1000) <= (powerPoints % 1000))",
                        "        power = power + 1;",
                        "    result = power;",
                        "}",
                        "",
                        "function GetStarDomiksPower(star) { //возвращает очки силы Ниспера для указанной системы",
                        "    int powerPoints = averagePowerPoints;",
                        "    int deltaPowerPoints = -150 * max(DeltaWin(0), -10); //чем больше проигрываем - тем больше бонус",
                        "    int distancePowerPoints = 40 * (GetNearNonCoalStarToStar(star, 0) - 1); //чем глубже звезда - тем больше очков",
                        "    if (deltaPowerPoints > 0)",
                        "        powerPoints = powerPoints + deltaPowerPoints + distancePowerPoints / 4;",
                        "    else if (deltaPowerPoints + distancePowerPoints < 0)",
                        "        powerPoints = powerPoints + deltaPowerPoints + distancePowerPoints;",
                        "    else",
                        "        powerPoints = powerPoints + (deltaPowerPoints + distancePowerPoints) / 4;",
                        "    result = powerPoints;",
                        "}",
                        "",
                        "function GetTurnsRespawnDB() {",
                        "    int turns = Rnd(160, 185) - 3 * upgradeSpawn;",
                        "    result = turns;",
                        "}",
                        "",
                        "function GetTurnsRespawnNisper() {",
                        "    int turns = Rnd(180, 250) - 7 * upgradeSpawn;",
                        "    result = turns;",
                        "}",
                        "",
                        "function GetBertorChangeStarCooldown() {",
                        "    int maxProcCoalStars = GetMaxProcCoalStars();",
                        "    int turns = 225 - 10 * upgradeActive;",
                        "    turns = RndByProcStars(round(1.8 * turns), turns, maxProcCoalStars);",
                        "    result = turns;",
                        "}",
                        "",
                        "function GetUpgradeLine(lineSize, greenSection, orangeSection, darkBlueSection, whiteBlueSection) { //возвращает строку заполненную закрашеными блоками, которые используются для визуального обозначения прокачки Ниспера",
                        "    str line = '';",
                        "    for (i = 0; i < lineSize - darkBlueSection; i = i + 1) {",
                        "        if (greenSection > 0) {",
                        "            line = line + '<color=10,150,10>#</color>';",
                        "            greenSection = greenSection - 1;",
                        "        } else if(orangeSection > 0) {",
                        "            line = line + '<color=230,125,20>#</color>';",
                        "            orangeSection = orangeSection - 1;",
                        "        } else",
                        "            line = line + '<color=255,0,0>#</color>';",
                        "        if (i == 19)",
                        "            line = line + '",
                        "';",
                        "        //if (i + 1 < lineSize - darkBlueSection)",
                        "            //line = line + '-';",
                        "    }",
                        "    for (i = 0; i < darkBlueSection; i = i + 1) {",
                        "        if (whiteBlueSection > 0) {",
                        "            line = line + '<color=50,50,200>#</color>';",
                        "            greenSection = greenSection - 1;",
                        "        } else",
                        "            line = line + '<color=0,0,100>#</color>';",
                        "        //if (i + 1 < darkBlueSection)",
                        "            //line = line + '-';",
                        "    }",
                        "    result = line;",
                        "}",
                        "",
                        "function GetArrCoalPossibleReachedStars(radius, shipStar, ignoreStarsWithBattle) { //превращает массив в котором собраны номера всех систем (и отмечены подходящие для перелета) в массив только подходящих номеров систем",
                        "    unknown arrCoalPossibleReachedStars = newarray(1);",
                        "    ArrayDelete(arrCoalPossibleReachedStars, 0);",
                        "    GetArrGalaxyCoalPossibleReachedStars(radius, shipStar, ignoreStarsWithBattle);",
                        "    unknown arrGalaxyCoalPossibleReachedStars = tempArr;",
                        "    int starsCount = GalaxyStars();",
                        "    for (i = 0; i < starsCount; i = i + 1) {",
                        "        if (arrGalaxyCoalPossibleReachedStars[i] == 1) {",
                        "            ArrayAdd(arrCoalPossibleReachedStars, GalaxyStar(i));",
                        "        }",
                        "    }",
                        "    copy(tempArr, arrCoalPossibleReachedStars);",
                        "}",
                        "",
                        "function BertorAuraApply(bertor, radius) { //накладывает эффект ауры бертора на дружественные корабли в определенном радиусе",
                        "    dword star = ShipStar(bertor);",
                        "    int shipCount = StarShips(star);",
                        "    for (i = 0; i <= shipCount; i = i + 1) {",
                        "        dword curShip = StarShips(star, i);",
                        "        if (ShipInNormalSpace(curShip)) {",
                        "            int maxHullSizeForEffect = arrDomiksSize['Ekventor', 'Max'];",
                        "            if(IsScriptActive('Mod_EvoArmada'))",
                        "                maxHullSizeForEffect = round(2.26 * maxHullSizeForEffect);",
                        "            if(curShip != bertor && HullHP(curShip) <= maxHullSizeForEffect && Dist(bertor,curShip) <= radius && IsShipNisperFriend(curShip)) {",
                        "                ShipAddCustomShipInfo(curShip, 'ZelDomiks_BertorAuraEffect', 'NoShow');",
                        "            }",
                        "        }",
                        "    }",
                        "}",
                        "",
                        "function PlayerBertorHullCheckAndUpdate(buildOrSpawnOrAura) { //запускает процесс производства клигов и генерации ауры для игрока",
                        "    dword player = Player();",
                        "    if (IsPlayerUseBertorHull()) {",
                        "        if (ShipInNormalSpace(player)) {",
                        "            dword DB = GetDB();",
                        "            if (buildOrSpawnOrAura == 1 && DB) { //хотим построить клигов",
                        "                PlayerKligBuildAlgorithm(player);",
                        "            }",
                        "            else if (buildOrSpawnOrAura == 2 && DB) { //хотим заспавнить построенных клигов",
                        "                PlayerKligSpawnAlgorithm(player);",
                        "            }",
                        "            else if (buildOrSpawnOrAura == 3) {//хотим запустить ауру игрока",
                        "                BertorAuraApply(player, 500);",
                        "                ShipCustomShipInfoData(player, 'ZelDomiks_BertorAuraSource', 1, 0);",
                        "            }",
                        "        }",
                        "    }",
                        "    if (buildOrSpawnOrAura == 1 && arrActiveMods['ExpPanel']) //дополнительно каждый ход еще меняем панельку отстроенных клигов",
                        "        ExpPanelPlayerBertorReadyKligs();",
                        "}",
                        "",
                        "function GetEqualizingABStat(speedOrDamage) { //возвращает коефициенты урона и скорости для уравнивания сложности ЧД",
                        "    int holeDifficulty = arrDifficultLevels['BlackHole'] / 50;",
                        "    if (speedOrDamage == 1) {",
                        "        float baseSpeedPercent = 1.0 + 0.15 * holeDifficulty;",
                        "        baseSpeedPercent = baseSpeedPercent * PortionInDiapason(ShipStatistic(Player(), 7), 0, 30, 0.6, 1);",
                        "        baseSpeedPercent = 1.0 / baseSpeedPercent;",
                        "        result = baseSpeedPercent;",
                        "    }",
                        "    else if (speedOrDamage == 2) {",
                        "        float baseDamagePercent = 1.0;",
                        "        if (holeDifficulty == 1)",
                        "            baseDamagePercent = 0.9;",
                        "        else if (holeDifficulty == 2)",
                        "            baseDamagePercent = 1.0;",
                        "        else if (holeDifficulty == 3)",
                        "            baseDamagePercent = 1.7;",
                        "        else",
                        "            baseDamagePercent = 1.7 + 0.6 * (holeDifficulty - 3);",
                        "        baseDamagePercent = 1.0 / baseDamagePercent;",
                        "        result = baseDamagePercent;",
                        "    }",
                        "}",
                        "unknown unknownVar;",
                        "",
                        "ArrayDelete(arrCountAndLevelEq, 0);",
                        "ArrayAdd(arrCountAndLevelEq, unknownVar, 'StdEqLevel');",
                        "ArrayAdd(arrCountAndLevelEq, unknownVar, 'EngineLevel');",
                        "ArrayAdd(arrCountAndLevelEq, unknownVar, 'WeaponCount');",
                        "ArrayAdd(arrCountAndLevelEq, unknownVar, 'DroidChance');",
                        "ArrayAdd(arrCountAndLevelEq, unknownVar, 'DefChance');",
                        "ArrayAdd(arrCountAndLevelEq, unknownVar, 'UpgradeChance');",
                        "ArrayAdd(arrCountAndLevelEq, unknownVar, 'UpgradeLevel');",
                        "for (i = 0; i < 7; i = i + 1) { //создаю трехмерный массив",
                        "    arrCountAndLevelEq[i] = newarray(1);",
                        "    ArrayDelete(arrCountAndLevelEq[i], 0);",
                        "    for (j = 1; j <= 7; j = j + 1) {",
                        "        ArrayAdd(arrCountAndLevelEq[i], unknownVar, 'Power' + j);",
                        "        arrCountAndLevelEq[i, j - 1] = newarray(1);",
                        "        ArrayDelete(arrCountAndLevelEq[i, j - 1], 0);",
                        "        ArrayAdd(arrCountAndLevelEq[i, j - 1], 0, 'Min');",
                        "        ArrayAdd(arrCountAndLevelEq[i, j - 1], 0, 'Max');",
                        "    }",
                        "}",
                        "arrCountAndLevelEq['StdEqLevel', 'Power1', 'Min'] = 1;",
                        "arrCountAndLevelEq['StdEqLevel', 'Power1', 'Max'] = 3;",
                        "arrCountAndLevelEq['StdEqLevel', 'Power2', 'Min'] = 1;",
                        "arrCountAndLevelEq['StdEqLevel', 'Power2', 'Max'] = 5;",
