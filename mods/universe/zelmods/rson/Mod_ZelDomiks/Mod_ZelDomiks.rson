                },
                {
                    "Name": "",
                    "Code.Type": "Turn",
                    "Code": [
                        "ShipAddCustomShipInfo(Player(), 'ZelDomiks_BertorInfo', 'NoShow', 0, 2, 0);",
                        "ShipAddCustomShipInfo(Player(), 'ZelDomiks_BertorAuraSource', 'NoShow', 1);",
                        "int desireBertorHullSize = 1750 - ((10 - 1) * 130);",
                        "dword hull = CreateHull(0, desireBertorHullSize, 1, 2);",
                        "ItemOwner(hull, Kling);",
                        "ItemSubrace(hull, Rnd(0, 2));",
                        "EqCustomFaction(hull, 'SubFaction.Nisper');",
                        "HullSeries(hull, -1);",
                        "str hullName = 'ZelDomiks_PlayerBertorHull';",
                        "SpecialToEquipment(FindBonusByNameInCfg(hullName), hull);",
                        "//навешиваем -3 ко всем скилам, -2 к слотам пушек, -2 к артефактам, -1 к дроиду, сканеру и форсажу",
                        "for (i = 1; i <= 6; i = i + 1)",
                        "    ItemExtraSpecialsAddByType(hull, FindBonusByNameInCfg('ZelDomiks_bonAcrinDSkill' + i), 3);",
                        "ItemExtraSpecialsAddByType(hull, FindBonusByNameInCfg('ZelDomiks_bonAcrinDSlotWeapon'), 2);",
                        "ItemExtraSpecialsAddByType(hull, FindBonusByNameInCfg('ZelDomiks_bonAcrinDSlotArt'), 2);",
                        "ItemExtraSpecialsAddByType(hull, FindBonusByNameInCfg('ZelDomiks_bonAcrinDSlotDroid'));",
                        "ItemExtraSpecialsAddByType(hull, FindBonusByNameInCfg('ZelDomiks_bonAcrinDSlotScaner'));",
                        "ItemExtraSpecialsAddByType(hull, FindBonusByNameInCfg('ZelDomiks_bonAcrinDSlotForsage'));",
                        "AddItemToStorage(GetDB(), hull);",
                        "arrPlayerBertorHullData['hullId'] = Id(hull);",
                        "arrPlayerBertorHullData['hullLevel'] = 1;",
                        "arrPlayerBertorHullData['upgradeStatus'] = 0;",
                        "arrPlayerBertorHullData['upgradeResourceNeed', 'money'] = GetPlayerBertorHullRequirement(0, 1);",
                        "arrPlayerBertorHullData['upgradeResourceNeed', 'nod'] = GetPlayerBertorHullRequirement(1, 1);",
                        "arrPlayerBertorHullData['upgradeResourceNeed', 'material'] = GetPlayerBertorHullRequirement(2, 1);",
                        "DAdd(55);"
