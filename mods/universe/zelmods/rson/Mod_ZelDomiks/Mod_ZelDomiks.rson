                {
                    "Name": "",
                    "Code.Type": "Turn",
                    "Code": [
                        "dword player = Player();",
                        "int needMoney = arrPlayerBertorHullData['upgradeResourceNeed', 'money'];",
                        "int needNod = arrPlayerBertorHullData['upgradeResourceNeed', 'nod'];",
                        "int needMaterial = arrPlayerBertorHullData['upgradeResourceNeed', 'material'];",
                        "int resourceType = GAnswerData;",
                        "if (resourceType == 0) { //деньги",
                        "    int playerMoney = ShipMoney(player);",
                        "    int maxMoneyGive = min(needMoney, playerMoney);",
                        "    str selectedCount = CountBox('Bm.ItemsUseless.2Usl_VigenereCoin_s', 'Сколько денег отдать?', 0, maxMoneyGive);",
                        "    if (selectedCount != 'Cancel' && selectedCount > 0) {",
                        "        Sound('Sound.Sell');",
                        "        ShipMoney(player, playerMoney - selectedCount);",
                        "        arrPlayerBertorHullData['upgradeResourceNeed', 'money'] = needMoney - selectedCount;",
                        "        needMoney = arrPlayerBertorHullData['upgradeResourceNeed', 'money'];",
                        "    }",
                        "}",
                        "else if (resourceType == 1) { //ноды",
                        "    int playerNods = GetNodesFromShip(player);",
                        "    int maxNodsGive = min(needNod, playerNods);",
                        "    selectedCount = CountBox('Bm.Items.2Nod2_s', 'Сколько нод отдать?', 0, maxNodsGive);",
                        "    if (selectedCount != 'Cancel' && selectedCount > 0) {",
                        "        Sound('Sound.Sell');",
                        "        GetNodesFromShip(player, selectedCount);",
                        "        arrPlayerBertorHullData['upgradeResourceNeed', 'nod'] = needNod - selectedCount;",
                        "        needNod = arrPlayerBertorHullData['upgradeResourceNeed', 'nod'];",
                        "    }",
                        "}",
                        "else if (resourceType == 2) { //материал бертора",
                        "    unknown arrMaterial = newarray(1);",
                        "    ArrayDelete(arrMaterial, 0);",
                        "    int materialCount = 0;",
                        "    int itemCount = ShipItems(player);",
                        "    for (i = 0; i < itemCount; i = i + 1) {",
                        "        dword curItem = ShipItems(player, i);",
                        "        if (ItemType(curItem) == t_UselessCountableItem && Name(curItem) == 'Неизвестный материал') {",
                        "            ArrayAdd(arrMaterial, curItem);",
                        "            materialCount = materialCount + ItemSize(curItem, 'Count');",
                        "        }",
                        "    }",
                        "    int maxMaterialGive = min(needMaterial, materialCount);",
                        "    selectedCount = CountBox('Bm.Items.2ZelDomiks_UselessBertorMaterial0_s','Сколько материала отдать?', 0, maxMaterialGive);",
                        "    if (selectedCount != 'Cancel' && selectedCount > 0) {",
                        "        Sound('Sound.Sell');",
                        "        int selectedCount2 = selectedCount;",
                        "        for (i = 0; selectedCount2 > 0; i = i + 1) {",
                        "            int curMaterialCount = ItemSize(arrMaterial[i], 'Count'); //теперь отнимаем необходимое количество материала во всем корабле (неважно на сколько кучек поделено)",
                        "            if (curMaterialCount) {",
                        "                if (selectedCount2 >= curMaterialCount) { //удаляем весь стак материала",
                        "                    selectedCount2 = selectedCount2 - curMaterialCount;",
                        "                    FreeItem(GetItemFromShip(player, arrMaterial[i]));",
                        "                }",
                        "                else {",
                        "                    int newCurMaterialCount = curMaterialCount - selectedCount2;",
                        "                    selectedCount2 = 0;",
                        "                    ItemSize(arrMaterial[i], newCurMaterialCount, 'Count');",
                        "                }",
                        "            }",
                        "        }",
                        "        arrPlayerBertorHullData['upgradeResourceNeed', 'material'] = needMaterial - selectedCount;",
                        "        needMaterial = arrPlayerBertorHullData['upgradeResourceNeed', 'material'];",
                        "    }",
                        "}",
                        "if (needMoney == 0 && needNod == 0 && needMaterial == 0) { //сдали все необходимое, начинаем исследования",
                        "    arrPlayerBertorHullData['upgradeStatus'] = 1;",
                        "    int hullLevel = arrPlayerBertorHullData['hullLevel'] + 1;",
                        "    arrPlayerBertorHullData['upgradeTurn'] = GetPlayerBertorHullRequirement(3, hullLevel - 1) + CurTurn();",
                        "}",
                        "DChange(37);"
                    ],
