                    "Code": [
                        "arrBertorQuestData['questPhase'] = 1;",
                        "arrBertorQuestData['questSubphase'] = 0;",
                        "int flag = 0;",
                        "if (arrBertorQuestData['SeriesResearchStatus', 0]) {",
                        "    dword artDonor = CreateArt(t_ArtBlackHole, 3 + flag);",
                        "    dword gift = CreateArtBlackHoleForBertors(artDonor, 0);",
                        "    AddItemToShip(Player(), gift);",
                        "    FreeItem(artDonor);",
                        "    flag = 1;",
                        "}",
                        "if (arrBertorQuestData['SeriesResearchStatus', 1]) {",
                        "    artDonor = CreateArt(t_ArtBlackHole, 3 + flag);",
                        "    gift = CreateArtBlackHoleForBertors(artDonor, 1);",
                        "    AddItemToShip(Player(), gift);",
                        "    FreeItem(artDonor);",
                        "    flag = 1;",
                        "}",
                        "if (arrBertorQuestData['SeriesResearchStatus', 2]) {",
                        "    artDonor = CreateArt(t_ArtBlackHole, 3 + flag);",
                        "    gift = CreateArtBlackHoleForBertors(artDonor, 2);",
                        "    AddItemToShip(Player(), gift);",
                        "    FreeItem(artDonor);",
                        "    flag = 1;",
                        "}",
