                },
                {
                    "Name": "",
                    "Code.Type": "Turn",
                    "Code": [
                        "InjectAnswer('dBertorQuest', 'Он есть, но я вам его не дам', 0);"
                    ],
                    "#": 306,
                    "Type": "Top",
                    "Parent": -1,
                    "Pos.x": 1630,
                    "Pos.y": 720
                },
                {
                    "Name": "",
                    "Code.Type": "Turn",
                    "Code": [
                        "InjectAnswer('dBertorQuest', 'Всегда пожалуйста!', 0);"
                    ],
                    "#": 307,
                    "Type": "Top",
                    "Parent": -1,
                    "Pos.x": -20,
                    "Pos.y": 745
                },
                {
                    "Name": "",
                    "Code.Type": "Turn",
                    "Code": [
                        "if (arrPlayerBertorHullData['upgradeStatus'] == 0) {",
                        "    if (arrPlayerBertorHullData['hullLevel'] < NisperLevel) {",
                        "        DAddText('Да. У нас есть новые идеи того, как мы бы могли улучшить ваш корпус.",
                        "');",
                        "        DAddText('Однако, совет Коалиции не намерен выделять ресурсы на подобный проект с неочевидными результатами. Поэтому, пожалуйста, помогите нам. Сейчас нам не хватает:",
                        "');",
                        "        int number = 0;",
                        "        int needMoney = arrPlayerBertorHullData['upgradeResourceNeed', 'money'];",
                        "        int needNod = arrPlayerBertorHullData['upgradeResourceNeed', 'nod'];",
                        "        int needMaterial = arrPlayerBertorHullData['upgradeResourceNeed', 'material'];",
                        "        if (needMoney > 0) {",
                        "            number = number + 1;",
                        "            DAddText('' + number + Format('. <0> cr.",
                        "',\"<0>\",needMoney));",
                        "            InjectAnswer('dBertorHullUpgradeResource', 'Я готов дать вам денег', 0);",
                        "        }",
                        "        if (needNod > 0) {",
                        "            number = number + 1;",
                        "            DAddText('' + number + Format('. <0> нод.",
                        "',\"<0>\",needNod));",
                        "            InjectAnswer('dBertorHullUpgradeResource', 'Я готов дать вам ноды', 1);",
                        "        }",
                        "        if (needMaterial > 0) {",
                        "            number = number + 1;",
                        "            DAddText('' + number + Format('. <0> материала берторов.",
                        "',\"<0>\",needMaterial));",
                        "            InjectAnswer('dBertorHullUpgradeResource', 'Я готов дать вам материал', 2);",
                        "        }",
                        "    }",
                        "    else",
                        "        DAddText('Нет, к сожалению. Сейчас у нас нет новых идей. Мы не можем пока что улучшить ваш корпус.');",
                        "}",
                        "else if (arrPlayerBertorHullData['upgradeStatus'] == 1) {",
                        "    int numOfTurns = arrPlayerBertorHullData['upgradeTurn'] - CurTurn() + 2;",
                        "    DAddText(Format('Сейчас часть нашей группы работает над этим проектом. Тяжело сказать точно, но мы расчитываем на получение результатов через <0> дней.',\"<0>\",numOfTurns));",
                        "}",
                        "else if (arrPlayerBertorHullData['upgradeStatus'] == 2) {",
                        "    dword player = Player();",
                        "    int itemCount = ShipItems(player);",
                        "    dword inStorage = 0;",
                        "    dword bertorHull = 0;",
                        "    dword bertorHullId = arrPlayerBertorHullData['hullId'];",
                        "    dword playerHull = ShipItems(player, 0);",
                        "    if (Id(playerHull) == bertorHullId)",
                        "        bertorHull = playerHull;",
                        "    if (bertorHull == 0) {",
                        "        bertorHull = IdToItem(arrPlayerBertorHullData['hullId']);",
                        "        if (bertorHull) {",
                        "            inStorage = FindItemInStorage(bertorHull);",
                        "            if (GetDB() != StorageItemLocation(inStorage))",
                        "                bertorHull = 0;",
                        "        }",
                        "    }",
                        "    if (bertorHull) {",
                        "        Sound('Sound.Repair');",
                        "        arrPlayerBertorHullData['upgradeStatus'] = 0;",
                        "        int hullLevel = arrPlayerBertorHullData['hullLevel'] + 1;",
                        "        arrPlayerBertorHullData['hullLevel'] = hullLevel;",
                        "        arrPlayerBertorHullData['upgradeResourceNeed', 'money'] = GetPlayerBertorHullRequirement(0, hullLevel);",
                        "        arrPlayerBertorHullData['upgradeResourceNeed', 'nod'] = GetPlayerBertorHullRequirement(1, hullLevel);",
                        "        arrPlayerBertorHullData['upgradeResourceNeed', 'material'] = GetPlayerBertorHullRequirement(2, hullLevel);",
                        "        DAddText('Да, мы наконец-то добились прорыва! Прямо сейчас, пока мы разговариваем, наши инженеры занялись вашим корпусом.",
                        "');",
                        "        DAddText('Мы планируем получить следующий результат:",
                        "');",
                        "        //на всех уровнях добавляем размер корпуса",
                        "        int desireBertorHullSize = 1750 - ((10 - hullLevel) * 130);",
                        "        ItemSize(bertorHull, desireBertorHullSize);",
                        "        HullHP(bertorHull, 'To100');",
                        "        DAddText(Format('1. Увеличить размер корпуса до <0> единиц.",
                        "',\"<0>\",desireBertorHullSize));",
                        "        if (hullLevel == 2) { //на втором уровне открываем дроида, добавляем броню",
                        "            DAddText('2. Увеличить броню корпуса.",
                        "');",
                        "            str slotName = 'дроида';",
                        "            DAddText(Format('3. Открыть слот <0>.",
                        "',\"<0>\",slotName));",
                        "            ItemLevel(bertorHull, 2);",
                        "            ItemExtraSpecialsDeleteByType(bertorHull, FindBonusByNameInCfg('ZelDomiks_bonAcrinDSlotDroid'));",
                        "        }",
                        "        else if (hullLevel == 3) { //на третьем уровне убираем дебафф одного уровня навыков",
                        "            DAddText('2. Уменьшить количество отвлекающих факторов корпуса. Вы сможете больше сосредотачиваться на своих текущих потребностях.",
                        "');",
                        "            for (i = 1; i <= 6; i = i + 1)",
                        "                ItemExtraSpecialsDeleteByType(bertorHull, FindBonusByNameInCfg('ZelDomiks_bonAcrinDSkill' + i));",
                        "        }",
                        "        else if (hullLevel == 4) { //на четвертом уровне добавляем клига, добавляем броню",
                        "            DAddText('2. Увеличить броню корпуса.",
                        "');",
                        "            DAddText(Format('3. Увеличить скорость производства и максимальное количество клигов до <0>.",
                        "',\"<0>\",3));",
                        "            ItemLevel(bertorHull, 3);",
                        "            ShipCustomShipInfoData(Player(), 'ZelDomiks_BertorInfo', 2, 3);",
                        "        }",
                        "        else if (hullLevel == 5) { //на пятом уровне открываем пушку, сканер и форсаж, добавляем броню",
                        "            DAddText('2. Увеличить броню корпуса.",
                        "');",
                        "            slotName = 'пушки';",
                        "            DAddText(Format('3. Открыть слот <0>.",
                        "',\"<0>\",slotName));",
                        "            slotName = 'сканера';",
                        "            DAddText(Format('4. Открыть слот <0>.",
                        "',\"<0>\",slotName));",
                        "            slotName = 'форсажа';",
                        "            DAddText(Format('5. Открыть слот <0>.",
                        "',\"<0>\",slotName));",
                        "            ItemLevel(bertorHull, 4);",
                        "            ItemExtraSpecialsDeleteByType(bertorHull, FindBonusByNameInCfg('ZelDomiks_bonAcrinDSlotWeapon'));",
                        "            ItemExtraSpecialsDeleteByType(bertorHull, FindBonusByNameInCfg('ZelDomiks_bonAcrinDSlotScaner'));",
                        "            ItemExtraSpecialsDeleteByType(bertorHull, FindBonusByNameInCfg('ZelDomiks_bonAcrinDSlotForsage'));",
                        "        }",
                        "        else if (hullLevel == 6) { //на шестом уровне убираем дебафф одного уровня навыков",
                        "            DAddText('2. Уменьшить количество отвлекающих факторов корпуса. Вы сможете больше сосредотачиваться на своих текущих потребностях.",
                        "');",
                        "            for (i = 1; i <= 6; i = i + 1)",
                        "                ItemExtraSpecialsDeleteByType(bertorHull, FindBonusByNameInCfg('ZelDomiks_bonAcrinDSkill' + i));",
                        "        }",
                        "        else if (hullLevel == 7) { //на седьмом уровне добавляем клига, добавляем броню",
                        "            DAddText('2. Увеличить броню корпуса.",
                        "');",
                        "            DAddText(Format('3. Увеличить скорость производства и максимальное количество клигов до <0>.",
                        "',\"<0>\",4));",
                        "            ItemLevel(bertorHull, 5);",
                        "            ShipCustomShipInfoData(Player(), 'ZelDomiks_BertorInfo', 2, 4);",
                        "        }",
                        "        else if (hullLevel == 8) { //на восьмом уровне открываем пушку и 2 артефакта, добавляем броню",
                        "            DAddText('2. Увеличить броню корпуса.",
                        "');",
                        "            slotName = 'пушки';",
                        "            DAddText(Format('3. Открыть слот <0>.",
                        "',\"<0>\",slotName));",
                        "            slotName = 'артефактов';",
                        "            DAddText(Format('4. Открыть два слота <0>.",
                        "',\"<0>\",slotName));",
                        "            ItemLevel(bertorHull, 6);",
                        "            ItemExtraSpecialsDeleteByType(bertorHull, FindBonusByNameInCfg('ZelDomiks_bonAcrinDSlotWeapon'));",
                        "            ItemExtraSpecialsDeleteByType(bertorHull, FindBonusByNameInCfg('ZelDomiks_bonAcrinDSlotArt'), 2);",
                        "        }",
                        "        else if (hullLevel == 9) { //на девятом уровне убираем дебафф одного уровня навыков, добавляем броню",
                        "            DAddText('2. Увеличить броню корпуса.",
                        "');",
                        "            DAddText('3. Уменьшить количество отвлекающих факторов корпуса. Вы сможете больше сосредотачиваться на своих текущих потребностях.",
                        "');",
                        "            ItemLevel(bertorHull, 7);",
                        "            for (i = 1; i <= 6; i = i + 1)",
                        "                ItemExtraSpecialsDeleteByType(bertorHull, FindBonusByNameInCfg('ZelDomiks_bonAcrinDSkill' + i));",
                        "        }",
                        "        else if (hullLevel == 10) { //на десятом уровне добавляем клига, добавляем броню",
                        "            DAddText('2. Увеличить броню корпуса.",
                        "');",
                        "            DAddText(Format('3. Увеличить скорость производства и максимальное количество клигов до <0>.",
                        "',\"<0>\",5));",
                        "            ItemLevel(bertorHull, 8);",
                        "            ShipCustomShipInfoData(Player(), 'ZelDomiks_BertorInfo', 2, 5);",
                        "        }",
                        "        if (!inStorage)",
                        "            Chameleon(Player());",
                        "    }",
                        "    else",
                        "        DAddText('Мы готовы улучшить ваш корпус, однако, не можем его найти. Пожалуйста, поместите его в инвентарь или на склад нашей станции.",
                        "');",
                        "}",
                        "DAdd(58);"
                    ],
                    "#": 308,
                    "Type": "Top",
                    "Parent": -1,
                    "Pos.x": 130,
                    "Pos.y": 745
                },
                {
                    "Name": "",
                    "Code.Type": "Turn",
                    "Code": [
                        "startResearchStarted=1;",
                        "DChange(1);",
                        "exit;"
                    ],
                    "#": 309,
                    "Type": "Top",
                    "Parent": -1,
                    "Pos.x": 940,
                    "Pos.y": 815
                },
                {
                    "Name": "",
                    "Code.Type": "Turn",
