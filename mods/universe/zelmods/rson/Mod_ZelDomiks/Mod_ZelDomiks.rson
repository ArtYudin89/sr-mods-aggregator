                    "Code": [
                        "arrBertorQuestData['questSubphase'] = 3;",
                        "int planetOwner = PlanetOwner(GetShipPlanet(Player()));",
                        "dword capsula = CreateQuestItem('Usl_75', planetOwner);",
                        "UselessItemText(capsula, 'Крио-капсула с каким-то выдающимся ученым внутри');",
                        "AddItemToShip(Player(), capsula);",
                        "arrBertorQuestData['scientistCapsulaId'] = Id(capsula);",
                        "Ether(3, 'bertorQuestPhase3', 'Отвезите ученого на Базу Доминаторов');",
                        "DAdd(53);"
                    ],
                    "#": 299,
