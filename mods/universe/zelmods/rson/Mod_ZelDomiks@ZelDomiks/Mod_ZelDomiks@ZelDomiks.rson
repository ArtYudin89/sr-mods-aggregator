                    "Type": "TDialogAnswer",
                    "Parent": -1,
                    "#": 532,
                    "Msg": "Бертора? Прям таки полностью рабочего бертора?",
                    "AMsg.Num": "166",
                    "_orig_danswer": "DAnswer(CT(\"Script.Mod_ZelDomiks.356\"))"
                },
                {
