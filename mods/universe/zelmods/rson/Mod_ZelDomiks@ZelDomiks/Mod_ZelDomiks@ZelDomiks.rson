                    "_orig_danswer": "DAnswer(CT(\"Script.Mod_ZelDomiks.444\"))"
                },
                {
                    "Name": "",
                    "Pos.x": 1200,
                    "Pos.y": 1165,
                    "Type": "TDialogAnswer",
                    "Parent": -1,
                    "#": 376,
                    "Msg": "Получается, что под директиву попадает весь пиратский клан?",
