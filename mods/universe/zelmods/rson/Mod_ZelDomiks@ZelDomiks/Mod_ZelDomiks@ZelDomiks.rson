                        "  }",
                        "  else if(powerDomiks>=2){",
                        "    power=1;",
                        "    powerDomiks=powerDomiks-2;",
                        "  }",
                        "  dom=SpawnDom(power,1);",
                        "  TransferShip(dom,NearCivilPlanet(CurShip));",
                        "  OrderTakeOff(dom);",
                        "  ShipSetCoords(dom, HoleX2(blackHole2),HoleY2(blackHole2));",
                        "  ugol=0.01*Rnd(0,200);",
                        "  ShipAngle(dom,Rnd(1,360));",
                        "  radius=Rnd(150,400);",
                        "  x = round(cos(ugol * pi) * radius + HoleX2(blackHole2));",
                        "  y = round(sin(ugol * pi) * radius + HoleY2(blackHole2));",
                        "  OrderMove(dom,x,y);",
                        "  ShipOrder(dom,5);",
                        "}"
