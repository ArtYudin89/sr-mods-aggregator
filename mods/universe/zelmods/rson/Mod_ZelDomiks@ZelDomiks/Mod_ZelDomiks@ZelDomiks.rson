                        "    power = choice4(",
                        "            0.20, 3,",
                        "            0.20, 2,",
                        "            0.10, 1,",
                        "            0.50, 0",
                        "    );",
                        "  } else if (level == 8) {",
                        "    power = choice4(",
                        "            0.20, 3,",
                        "            0.20, 2,",
                        "            0.20, 1,",
                        "            0.40, 0",
                        "    );",
                        "  } else if (level == 9) {",
                        "    power = choice4(",
                        "            0.30, 3,",
                        "            0.30, 2,",
                        "            0.10, 1,",
                        "            0.30, 0",
                        "    );",
                        "  } else if (level == 10) {",
                        "    power = choice4(",
                        "            0.45, 3,",
                        "            0.15, 2,",
                        "            0.15, 1,",
                        "            0.25, 0",
                        "    );",
                        "  } else if (level == 11) {",
                        "    power = choice4(",
                        "            0.50, 3,",
                        "            0.20, 2,",
                        "            0.10, 1,",
                        "            0.20, 0",
                        "    );",
                        "  }",
                        "  result = power;",
                        "}",
                        "// Случайное действительно число от 0.0 до 1.0 с шагом 1e-9",
                        "function random_real() {",
                        "    result = 1.0 * Rnd(0, 1000000000) / 1000000000.0;",
                        "}",
                        "",
                        "// Функции для взвешенного случайного выбора из нескольких значений (надеюсь я нигде не опечатался)",
                        "// w1 - вес, a - значение",
                        "// Сумма весов не обязательно равна 1",
                        "function choice2(w1, a, w2, b) {",
                        "    if (w1 + w2 == 0) {",
                        "        result = choice2(1.0, a, 1.0, b);",
                        "    } else {",
                        "        if (random_real() < 1.0 * w1 / (0.0 + w1 + w2)) {",
                        "            result = a;",
                        "        } else {",
                        "            result = b;",
                        "        }",
                        "    }",
                        "}",
                        "",
                        "function choice4(w1, a, w2, b, w3, c, w4, d) {",
                        "    result = choice2(",
                        "        w1 + w2, choice2(w1, a, w2, b),",
                        "        w3 + w4, choice2(w3, c, w4, d)",
                        "    );",
                        "}",
                        "",
                        "function choice8(w1, a, w2, b, w3, c, w4, d, w5, e, w6, f, w7, g, w8, h) {",
                        "    result = choice2(",
                        "        w1 + w2 + w3 + w4, choice4(w1, a, w2, b, w3, c, w4, d),",
                        "        w5 + w6 + w7 + w8, choice4(w5, e, w6, f, w7, g, w8, h)",
                        "    );",
                        "}",
                        "",
                        "//function choice16(w1, a, w2, b, w3, c, w4, d, w5, e, w6, f, w7, g, w8, h, w9, i, w10, j, w11, k, w12, l, w13, m, w14, n, w15, p, w16, p) {",
                        "//    result = choice2(",
                        "//        w1 + w2 + w3 + w4 + w5 + w6 + w7 + w8, choice8(w1, a, w2, b, w3, c, w4, d, w5, e, w6, f, w7, g, w8, h),",
                        "//        w9 + w10 + w11 + w12 + w13 + w14 + w15 + w16, choice8(w9, i, w10, j, w11, k, w12, l, w13, m, w14, n, w15, p, w16, p)",
                        "//    );",
                        "//}",
                        "",
                        "function choice3(w1, a, w2, b, w3, c) {",
                        "    result = choice4(w1, a, w2, b, w3, c, 0, 0);",
                        "}",
                        "",
                        "function choice5(w1, a, w2, b, w3, c, w4, d, w5, e) {",
                        "    result = choice8(w1, a, w2, b, w3, c, w4, d, w5, e, 0, 0, 0, 0, 0, 0);",
                        "}",
                        "",
                        "function choice6(w1, a, w2, b, w3, c, w4, d, w5, e, w6, f) {",
                        "    result = choice8(w1, a, w2, b, w3, c, w4, d, w5, e, w6, f, 0, 0, 0, 0);",
                        "}",
                        "",
                        "function choice7(w1, a, w2, b, w3, c, w4, d, w5, e, w6, f, w7, g) {",
                        "    result = choice8(w1, a, w2, b, w3, c, w4, d, w5, e, w6, f, w7, g, 0, 0);",
                        "}",
                        "",
                        "// Приводит значение val к диапазону (mn,mx)",
                        "function toDiap(val, mn, mx) {",
                        "    result = min(max(val, mn), mx);",
                        "    //result = choice3(",
                        "    //    val < mn, mn,",
                        "    //    val > mx, mx,",
                        "    //    val >= mn && val <= mx, val",
                        "    //);",
                        "}",
                        "",
                        "// Возвращает истину (1) с вероятностью p, иначе - ложь (0)",
                        "function prob(p) {",
                        "    result = choice2(1.0 - p, 0, 0.0 + p, 1);",
                        "}",
                        "",
                        "// random_real()",
                        "// choiceN(weight_i, val_i, ...)",
                        "// toDiap(val, min, max)",
                        "// prob(p)",
                        "",
                        "// Функции для рандомизации;"
                    ],
                    "#": 131,
                    "Type": "Top",
                    "Parent": -1,
                    "Pos.x": 60,
                    "Pos.y": 1535
                },
                {
                    "Name": "",
                    "Code.Type": "Turn",
                    "Code": [
                        "if(domLevel==6&&completeTask==2) {",
                        "  star = ShipStar(Player());",
                        "  ",
                        "  if (ShipInHole(Player())) {",
                        "    if (!GABStatus) {",
                        "      if (!ABStarted) {",
                        "        if (Id(ShipOrderObj(Player())) == idMissionHole) {",
                        "  ",
                        "          dom = CreateABShip('Ship.X.' + Rnd(0, 2), 0, 150, 110);",
                        "          ABShipModifiers(dom,'speed', 100);",
                        "          dom = CreateABShip('Ship.X.' + Rnd(0, 2), 0, 120, 120);",
                        "          ABShipModifiers(dom,'speed', 120);",
                        "          dom = CreateABShip('Ship.X.' + Rnd(0, 2), 0, 120, 120);",
                        "          ABShipModifiers(dom,'speed', 120);",
                        "          dom = CreateABShip('Ship.X.' + Rnd(0, 2), 0, 100, 120);",
                        "          ABShipModifiers(dom,'speed', 140);",
                        "          dom = CreateABShip('Ship.X.' + Rnd(0, 2), 0, 100, 120);",
                        "          ABShipModifiers(dom,'speed', 140);",
                        "  ",
                        "          if (difficultOfHoles < 4) {",
                        "            dom = SpawnDom(1, 0);",
                        "            GiveABWeapon(dom, 1, Rnd(2, 3));",
                        "            ShipDestroy(dom, 1);",
                        "            dom = ConvertToABShip(dom, 1, 100, 100);",
                        "            ABShipModifiers(dom, 'speed', 130);",
                        "          }",
                        "          if (difficultOfHoles < 7) {",
                        "            dom = SpawnDom(1, 0);",
                        "            GiveABWeapon(dom, 1, Rnd(2, 3));",
                        "            ShipDestroy(dom, 1);",
                        "            dom = ConvertToABShip(dom, 1, 100, 100);",
                        "            ABShipModifiers(dom, 'speed', 130);",
                        "          }",
                        "          dom = SpawnDom(5, 0);",
                        "          GiveABWeapon(dom, 5, 5);",
                        "          ShipDestroy(dom, 1);",
                        "          dom = ConvertToABShip(dom, 1, 120, 110);",
                        "          ABShipModifiers(dom, 'speed', 130);",
                        "  ",
                        "          ABStarted = 1;",
                        "          completeTask=1;",
                        "          OrderLock(Player(),0);",
                        "          StartAB('ABMap.map_' + Rnd(1, 13));",
                        "          Ether(4,'ZelDomiksQuest','Вы смогли победить всех врагов в подпространственном пузыре. Теперь нужно передать все данные об изучении неизвестных кораблей Нисперу. Задание выполнено, осталось только поговорить с Ниспером.');",
                        "        }",
                        "      }",
                        "    }",
                        "  }",
                        "}",
                        "if(domLevel==4&&completeTask==2) {",
                        "  daysMission = daysMission + 1;",
                        "  dword ourDomTrader = IdToShip(domTraderId[0]);",
                        "  if (daysMission < daysMissionComplete) {",
                        "    if (ourDomTrader) {",
                        "      int playerDayMoney = ShipCustomShipInfoData(Player(), 'ZelDomiks_MoneyPlayerInfo', 1);",
                        "      ShipCustomShipInfoData(Player(), 'ZelDomiks_MoneyPlayerInfo', 1, 0);",
                        "      playerProfit = playerProfit + playerDayMoney;",
                        "      if (playerDayMoney > 0) {",
                        "        power = 10 + Rnd(1, 3) * difficultOfMoney;",
                        "        domikProfitPlus[0] = domikProfitPlus[0] + (power * playerDayMoney / 100);",
                        "      }",
                        "      int domikDayMoney = ShipCustomShipInfoData(ourDomTrader, 'ZelDomiks_MoneyDomInfo', 1);",
                        "      ShipCustomShipInfoData(ourDomTrader, 'ZelDomiks_MoneyDomInfo', 1, 0);",
                        "      int bonusProfitDom;",
                        "      if (domikDayMoney > 0) {",
                        "        bonusProfitDom = domikProfitPlus[0] * Rnd(10, 30 + difficultOfMoney * 2) / 100;",
                        "        domikProfitPlus[0] = domikProfitPlus[0] - bonusProfitDom;",
                        "        domikProfit[0] = domikProfit[0] + domikDayMoney + bonusProfitDom;",
                        "      }",
                        "      Ether(3,'ZelDomiksQuest',Format(CT(\"Script.Mod_ZelDomiks.310\"),\"<0>\",playerProfit,\"<1>\",domikProfit[0],\"<2>\",daysMissionComplete-daysMission));",
                        "    } else {",
                        "      completeTask = 0;",
                        "      Sound('Sound.QuestCancel');",
                        "      Ether(5,'ZelDomiksQuest','Модуль Ниспера был уничтожен. Задание считается отмененным.');",
                        "    }",
                        "  } else if (daysMission == daysMissionComplete) {",
                        "    ShipDestroy(ourDomTrader, 1);",
                        "    if (playerProfit > domikProfit[0]) {",
                        "      completeTask = 1;",
                        "      Sound('Sound.QuestOk');",
                        "      Ether(4,'ZelDomiksQuest','По итогам состязания вы получили больше прибыли чем модуль Ниспера. Задание выполнено, осталось только поговорить с Ниспером.');",
                        "    } else {",
                        "      completeTask = 0;",
                        "      Sound('Sound.QuestCancel');",
                        "      Ether(5,'ZelDomiksQuest','По итогам состязания вы получили меньше прибыли чем модуль Ниспера. Задание провалено.');",
                        "    }",
                        "  }",
                        "}",
                        "if(domLevel==5&&completeTask==2&&bonusAdd==1) {",
                        "  daysMission = daysMission + 1;",
                        "  targetStar = GalaxyStar(idStarAttackPirates);",
