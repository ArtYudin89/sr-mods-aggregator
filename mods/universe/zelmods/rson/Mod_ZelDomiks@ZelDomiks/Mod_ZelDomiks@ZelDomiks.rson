                    "Pos.y": 1315,
                    "Type": "TDialogAnswer",
                    "Parent": -1,
                    "#": 461,
                    "Msg": "Ясно",
                    "AMsg.Num": "95",
                    "_orig_danswer": "DAnswer('exit~'+CT(\"Script.Mod_ZelDomiks.54\"))"
                },
