                    "_orig_danswer": "DAnswer(CT(\"Script.Mod_ZelDomiks.50\"))"
                },
                {
                    "Name": "",
                    "Pos.x": 360,
                    "Pos.y": 1190,
                    "Type": "TDialogAnswer",
                    "Parent": -1,
                    "#": 384,
