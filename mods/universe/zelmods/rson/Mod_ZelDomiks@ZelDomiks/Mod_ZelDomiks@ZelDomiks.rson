                        "      if (bool && distance > Dist(CurShip, thisShip) && ShipTypeN(thisShip)!=2) {",
                        "        potentialEnemy = thisShip;",
                        "        distance = Dist(CurShip, thisShip);",
                        "      }",
                        "    }",
                        "  }",
                        "  if (potentialEnemy != 0)",
                        "    ShipSetBad(CurShip, potentialEnemy);",
                        "  OrderLock(CurShip,1);",
                        "  if(ShipGetBad(CurShip)==0&&star==targetStar&&needRen==0) {",
                        "    int turnsForComplete=GetData(0, CurShip);",
                        "    if (turnsForComplete < 1) {",
                        "      ugol = 0.01 * Rnd(0, 200);",
                        "      radius = Rnd(PlanetOrbitRadius(StarPlanets(ShipStar(CurShip), 0)) - 50, PlanetOrbitRadius(StarPlanets(ShipStar(CurShip), StarPlanets(ShipStar(CurShip)) - 1)));",
                        "      x = round(sin(ugol * pi) * radius);",
                        "      y = round(cos(ugol * pi) * radius);",
                        "      OrderMove(CurShip, x, y);",
                        "      distance=round(sqrt(sqr(abs(CoordX(CurShip)-x))+sqr(abs(CoordY(CurShip)-y))));",
                        "      int ourShipSpeed=ShipSpeed(CurShip);",
                        "      turnsForComplete=distance/ourShipSpeed+(distance%ourShipSpeed!=0);",
                        "    }",
                        "    SetData(turnsForComplete - 1, 0, CurShip);",
                        "    SetData(GetData(2,CurShip)+1,2,CurShip);",
                        "  }",
                        "  if(ShipGetBad(CurShip)==0&&star==targetStar&&needRen==1) {",
                        "    ChangeState(27);",
                        "    exit;",
                        "  }",
                        "  if(ShipGetBad(CurShip)>0) {",
                        "    ChangeState(6);",
                        "    exit;",
                        "  }",
                        "  if(star!=targetStar&&ShipGetBad(CurShip)==0) {",
                        "    OrderJump(CurShip,targetStar);",
                        "    SetData(0,0,CurShip);",
                        "  }",
                        "  if(GetData(2,CurShip)>reloadTime) {",
                        "    power=GalaxyStars();",
                        "    pointsMax=-10000;",
                        "    for(i=0;i<power;i=i+1){",
                        "      potentialStar=GalaxyStar(i);",
                        "      pointsStar=0;",
                        "      if(StarOwner(potentialStar)==0){",
                        "        for (j=0;j<StarShips(potentialStar);j=j+1){",
                        "          potentialEnemy=StarShips(potentialStar,j);",
                        "          if((ShipCustomFaction(potentialEnemy)=='SubFaction.Nisper')||(ShipCustomFaction(potentialEnemy)==''&&ShipOwner(potentialEnemy)<=4))",
                        "            pointsStar=pointsStar-ChanceToWin(potentialEnemy,IdToShip(bossId),1);",
                        "          else",
                        "            pointsStar=pointsStar+ChanceToWin(potentialEnemy,IdToShip(bossId),1);",
                        "        }",
                        "      }",
                        "      if(pointsStar>pointsMax){",
                        "        SetData(i,1,CurShip);",
                        "        SetData(0,2,CurShip);",
                        "      }",
                        "    }",
                        "  }",
                        "}"
