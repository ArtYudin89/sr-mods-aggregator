                        "",
                        "function GiveAcrin(level, ship, type){",
                        "  if(type==0){",
                        "    ShipSpecialBonuses(ship,bonWRadius,(0.7+0.2*curDomLevel)*10);",
                        "    ShipSpecialBonuses(ship,bonWEnergy,(0.7+0.2*curDomLevel)*2.7);",
                        "    ShipSpecialBonuses(ship,bonWSplinter,(0.7+0.2*curDomLevel)*3.75);",
                        "    ShipSpecialBonuses(ship,bonDef,(0.7+0.2*curDomLevel)*-1.2);",
                        "    ShipSpecialBonuses(ship,bonHull,(0.7+0.2*curDomLevel)*-0.5);",
                        "  }",
                        "  else if(type==1){",
                        "    ShipSpecialBonuses(ship,bonSpeed,(0.7+0.2*curDomLevel)*1.15*30);",
                        "    ShipSpecialBonuses(ship,bonWEnergy,(0.7+0.2*curDomLevel)*1.15*2.7);",
                        "    ShipSpecialBonuses(ship,bonWRadius,(0.7+0.2*curDomLevel)*1.15*10);",
                        "    ShipSpecialBonuses(ship,bonDef,(0.7+0.2*curDomLevel)*1.15*-1.2);",
                        "    ShipSpecialBonuses(ship,bonDroid,(0.7+0.2*curDomLevel)*1.15*-5);",
                        "  }",
                        "  else if(type==2){",
                        "    ShipSpecialBonuses(ship,bonWSplinter,(0.7+0.2*curDomLevel)*1.3*3.75);",
                        "    ShipSpecialBonuses(ship,bonWMissile,(0.7+0.2*curDomLevel)*1.3*2.1);",
                        "    ShipSpecialBonuses(ship,bonDef,(0.7+0.2*curDomLevel)*1.3*1.2);",
                        "    ShipSpecialBonuses(ship,bonDroid,(0.7+0.2*curDomLevel)*1.3*-5);",
                        "    ShipSpecialBonuses(ship,bonWEnergy,(0.7+0.2*curDomLevel)*1.3*-2.7);",
                        "  }",
                        "  else if(type==3){",
                        "    ShipSpecialBonuses(ship,bonWMissile,(0.7+0.2*curDomLevel)*1.45*2.1);",
                        "    ShipSpecialBonuses(ship,bonDroid,(0.7+0.2*curDomLevel)*1.45*5);",
                        "    ShipSpecialBonuses(ship,bonSpeed,(0.7+0.2*curDomLevel)*1.45*30);",
                        "    ShipSpecialBonuses(ship,bonWSplinter,(0.7+0.2*curDomLevel)*1.45*-3.75);",
                        "    ShipSpecialBonuses(ship,bonWRadius,(0.7+0.2*curDomLevel)*1.45*-10);",
                        "  }",
                        "  else if(type==4){",
                        "    ShipSpecialBonuses(ship,bonWSplinter,(0.7+0.2*curDomLevel)*1.6*3.75);",
                        "    ShipSpecialBonuses(ship,bonDef,(0.7+0.2*curDomLevel)*1.6*1.2);",
                        "    ShipSpecialBonuses(ship,bonHull,(0.7+0.2*curDomLevel)*1.6*0.5);",
                        "    ShipSpecialBonuses(ship,bonWEnergy,(0.7+0.2*curDomLevel)*1.6*-2.7);",
                        "    ShipSpecialBonuses(ship,bonSpeed,(0.7+0.2*curDomLevel)*1.6*-30);",
                        "  }",
                        "  else if(type==5){",
                        "    ShipSpecialBonuses(ship,bonDroid,(0.7+0.2*curDomLevel)*1.75*5);",
                        "    ShipSpecialBonuses(ship,bonWEnergy,(0.7+0.2*curDomLevel)*1.75*2.7);",
                        "    ShipSpecialBonuses(ship,bonWRadius,(0.7+0.2*curDomLevel)*1.75*10);",
                        "    ShipSpecialBonuses(ship,bonWSplinter,(0.7+0.2*curDomLevel)*1.75*-3.75);",
                        "    ShipSpecialBonuses(ship,bonWMissile,(0.7+0.2*curDomLevel)*1.75*-2.1);",
                        "  }",
                        "  else if(type==6){",
                        "    ShipSpecialBonuses(ship,bonDef,(0.7+0.2*curDomLevel)*1.9*1.2);",
                        "    ShipSpecialBonuses(ship,bonDroid,(0.7+0.2*curDomLevel)*1.9*5);",
                        "    ShipSpecialBonuses(ship,bonHull,(0.7+0.2*curDomLevel)*1.9*0.5);",
                        "    ShipSpecialBonuses(ship,bonSpeed,(0.7+0.2*curDomLevel)*1.9*-30);",
                        "    ShipSpecialBonuses(ship,bonWRadius,(0.7+0.2*curDomLevel)*1.9*-10);",
                        "  }",
                        "}",
                        "",
                        "function GiveDomArts(level, ship, type){",
                        "  unknown arrayOfTheArts=newarray(14);",
                        "  arrayOfTheArts[0]=t_ArtefactSpeed;",
                        "  arrayOfTheArts[1]=t_ArtefactDroid;",
                        "  arrayOfTheArts[2]=t_ArtWeaponToSpeed;",
                        "  arrayOfTheArts[3]=t_ArtefactDef;",
                        "  arrayOfTheArts[4]=t_ArtEnergyDef;",
                        "  arrayOfTheArts[5]=t_ArtDefToEnergy;",
                        "  arrayOfTheArts[6]=t_ArtEnergyPulse;",
                        "  arrayOfTheArts[7]=t_ArtefactHull;",
                        "  arrayOfTheArts[8]=t_ArtMissileDef;",
                        "  arrayOfTheArts[9]=t_ArtDecelerate;",
                        "  arrayOfTheArts[10]=t_ArtSplinter;",
                        "  arrayOfTheArts[11]=t_ArtFastRacks;",
                        "  arrayOfTheArts[12]=t_ArtPDTurret;",
                        "  arrayOfTheArts[13]=t_ArtefactAntigrav;",
                        "  j=0;",
                        "  int countOfArts=(4.0+level)*(3.0+type)/25.0;",
                        "  countOfArts=Rnd(countOfArts-1,countOfArts+1);",
                        "  unknown arrayOfArtsOnShip=newarray(10);",
                        "  for(i=0;i<10;i=i+1)",
                        "    arrayOfArtsOnShip[i]=0;",
                        "  while(j<countOfArts){",
                        "    random=Rnd(0,13);",
                        "    bool=1;",
                        "    dword ourArt=arrayOfTheArts[random];",
                        "    for(i=0;i<4;i=i+1){",
                        "      if(arrayOfArtsOnShip[i]==ourArt)",
                        "        bool=0;",
                        "    }",
                        "    if(bool){",
                        "      arrayOfArtsOnShip[j]=ourArt;",
                        "      j=j+1;",
                        "      ourArt=CreateArt(ourArt,5);",
                        "      AddItemToShip(ship,ourArt);",
                        "    }",
                        "  }",
                        "}",
