                        "  if(!IdToShip(shipForBlackHole)){",
                        "    targetStar=GalaxyStar(GetData(1,CurShip)-1);",
                        "    blackHole2=HoleCreate2(targetStar,targetStar);",
                        "    holeId2=Id(blackHole2);",
                        "    HoleX2(blackHole2,HoleX1(blackHole2));",
                        "    HoleY2(blackHole2,HoleY1(blackHole2));",
                        "    random=Rnd(0, StarPlanets(targetStar) - 1);",
                        "    if (PlanetOwner(StarPlanets(targetStar, random)) != None)",
                        "      ourPlanet=StarPlanets(targetStar, random);",
                        "    shipForBlackHole=SpawnDom(-1, 1);",
                        "    MakeShipEnterStar(shipForBlackHole, targetStar, PlanetToStar(IdToPlanet(planetId)), 100);",
                        "    OrderJumpHole(shipForBlackHole,blackHole2);",
                        "    ShipOrderData1(shipForBlackHole,65535);",
                        "    shipForBlackHole=Id(shipForBlackHole);",
                        "  }",
                        "}"
