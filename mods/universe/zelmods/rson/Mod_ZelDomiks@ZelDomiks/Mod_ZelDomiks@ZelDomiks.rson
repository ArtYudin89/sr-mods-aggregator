                        "if(ShipInNormalSpace(CurShip)) {",
                        "  potentialEnemy = 0;",
                        "  distance = 100000;",
                        "  star = ShipStar(CurShip);",
                        "  reloadTime=2*(GalaxyDiffLevels()+1500)/(curDomLevel+15);",
                        "  cShips=StarShips(star);",
                        "  ourPlanet=IdToPlanet(planetId);",
                        "  nearPlanet=NearCivilPlanet(CurShip);",
                        "  for (i = 0; i <= cShips; i = i + 1) {",
                        "    thisShip = StarShips(star, i);",
                        "    if (ShipInNormalSpace(thisShip)) {",
                        "      bool=GetRelationPlanet(ourPlanet, thisShip) <= 30;",
                        "      if (bool && distance > Dist(CurShip, thisShip) && ShipTypeN(thisShip)!=2) {",
                        "        potentialEnemy = thisShip;",
                        "        distance = Dist(CurShip, thisShip);",
                        "      }",
                        "    }",
                        "  }",
                        "  if (potentialEnemy != 0)",
                        "    ShipSetBad(CurShip, potentialEnemy);",
                        "  OrderLock(CurShip,1);",
                        "  if(ShipGetBad(CurShip)==0&&GetData(2,CurShip)<reloadTime&&needRen==1) {",
                        "    ChangeState(25);",
                        "    exit;",
                        "  }",
                        "  if(ShipGetBad(CurShip)==0&&GetData(2,CurShip)<reloadTime&&needRen==0) {",
                        "    int turnsForComplete=GetData(0, CurShip);",
                        "    if (turnsForComplete < 1) {",
                        "      ugol = 0.01 * Rnd(0, 200);",
                        "      radius = Rnd(PlanetOrbitRadius(StarPlanets(ShipStar(CurShip), 0)) - 50, PlanetOrbitRadius(StarPlanets(ShipStar(CurShip), StarPlanets(ShipStar(CurShip)) - 1)));",
                        "      x = round(sin(ugol * pi) * radius);",
                        "      y = round(cos(ugol * pi) * radius);",
                        "      OrderMove(CurShip, x, y);",
                        "      distance=round(sqrt(sqr(abs(CoordX(CurShip)-x))+sqr(abs(CoordY(CurShip)-y))));",
                        "      int ourShipSpeed=ShipSpeed(CurShip);",
                        "      turnsForComplete=distance/ourShipSpeed+(distance%ourShipSpeed!=0);",
                        "    }",
                        "    SetData(turnsForComplete - 1, 0, CurShip);",
                        "    SetData(GetData(2,CurShip)+1,2,CurShip);",
                        "  }",
                        "  if(GetData(2,CurShip)>=reloadTime) {",
                        "    pointsMax=-10000;",
                        "    int pirateSector=StarToCon(PlanetToStar(PlanetPirateClan()));",
                        "    power=GalaxyStars();",
                        "    for(i=0;i<power;i=i+1){",
                        "      pointsStar=0;",
                        "      possibleStar=GalaxyStar(i);",
                        "      str nameCustomStar=StarCustomFaction(possibleStar);",
                        "      str nameCustomShip;",
                        "      if(nameCustomStar!=''){",
                        "        for (j=0;j<StarShips(possibleStar);j=j+1){",
                        "          potentialEnemy=StarShips(possibleStar,j);",
                        "          nameCustomShip=ShipCustomFaction(potentialEnemy);",
                        "          if(nameCustomShip==nameCustomStar)",
                        "            pointsStar=pointsStar-ChanceToWin(potentialEnemy,IdToShip(bossId),1);",
                        "          else if((nameCustomShip=='SubFaction.Nisper')||(nameCustomShip==''&&ShipOwner(potentialEnemy)<=4))",
                        "            pointsStar=pointsStar+ChanceToWin(potentialEnemy,IdToShip(bossId),1);",
                        "          else",
                        "            pointsStar=pointsStar+0.8*ChanceToWin(potentialEnemy,IdToShip(bossId),1);",
                        "        }",
                        "        pointsStar=1.3*pointsStar;",
                        "      }",
                        "      else if(StarOwner(possibleStar)==0){",
                        "        for (j=0;j<StarShips(possibleStar);j=j+1){",
                        "          potentialEnemy=StarShips(possibleStar,j);",
                        "          nameCustomShip=ShipCustomFaction(potentialEnemy);",
                        "          if((nameCustomShip=='SubFaction.Nisper')||(nameCustomShip==''&&ShipOwner(potentialEnemy)<=4))",
                        "            pointsStar=pointsStar-ChanceToWin(potentialEnemy,IdToShip(bossId),1);",
                        "          else if(nameCustomShip==''&&ShipOwner(potentialEnemy)==7)",
                        "            pointsStar=pointsStar+0.7*ChanceToWin(potentialEnemy,IdToShip(bossId),1);",
                        "          else",
                        "            pointsStar=pointsStar+ChanceToWin(potentialEnemy,IdToShip(bossId),1);",
                        "        }",
                        "      }",
                        "      else if(StarOwner(possibleStar)==1){",
                        "        int serieStar=StarSeries(possibleStar);",
                        "        for (j=0;j<StarShips(possibleStar);j=j+1){",
                        "          potentialEnemy=StarShips(possibleStar,j);",
                        "          nameCustomShip=ShipCustomFaction(potentialEnemy);",
                        "          if(nameCustomShip==''&&ShipOwner(potentialEnemy)==5&&serieStar==ItemSubrace(ShipItems(potentialEnemy,0)))",
                        "            pointsStar=pointsStar-ChanceToWin(potentialEnemy,IdToShip(bossId),1);",
                        "          else if((nameCustomShip=='SubFaction.Nisper')||(nameCustomShip==''&&ShipOwner(potentialEnemy)<=4))",
                        "            pointsStar=pointsStar+ChanceToWin(potentialEnemy,IdToShip(bossId),1);",
                        "          else",
                        "            pointsStar=pointsStar+0.8*ChanceToWin(potentialEnemy,IdToShip(bossId),1);",
                        "        }",
                        "        pointsStar=1.3*pointsStar;",
                        "      }",
                        "      else if(StarOwner(possibleStar)==2&&StarToCon(possibleStar)!=pirateSector){",
                        "        for (j=0;j<StarShips(possibleStar);j=j+1){",
                        "          potentialEnemy=StarShips(possibleStar,j);",
                        "          nameCustomShip=ShipCustomFaction(potentialEnemy);",
                        "          if(nameCustomShip==''&&ShipOwner(potentialEnemy)==7)",
                        "            pointsStar=pointsStar-ChanceToWin(potentialEnemy,IdToShip(bossId),1);",
                        "          else if((nameCustomShip=='SubFaction.Nisper')||(nameCustomShip==''&&ShipOwner(potentialEnemy)<=4))",
                        "            pointsStar=pointsStar+ChanceToWin(potentialEnemy,IdToShip(bossId),1);",
                        "          else",
                        "            pointsStar=pointsStar+0.8*ChanceToWin(potentialEnemy,IdToShip(bossId),1);",
                        "        }",
                        "        pointsStar=1.15*pointsStar;",
                        "      }",
                        "      if(pointsStar>pointsMax){",
                        "        pointsMax=pointsStar;",
                        "        SetData(Id(possibleStar),1,CurShip);",
                        "      }",
                        "    }",
                        "    SetData(0,2,CurShip);",
                        "    SetData(0,0,CurShip);",
                        "    blackHole=HoleCreate2(star,star);",
                        "    ugol=0.01*Rnd(0,200);",
                        "    x=round(sin(ugol*pi)*Rnd(125,150)+CoordX(CurShip));",
                        "    y=round(cos(ugol*pi)*Rnd(125,150)+CoordY(CurShip));",
                        "    HoleX1(blackHole,x);",
                        "    HoleY1(blackHole,y);",
                        "    HoleX2(blackHole,x);",
                        "    HoleY2(blackHole,y);",
                        "    holeId=Id(blackHole);",
                        "    ChangeState(10);",
                        "    exit;",
                        "  }",
                        "  if(ShipGetBad(CurShip)>0&&GetData(2,CurShip)<reloadTime) {",
                        "    ChangeState(9);",
                        "    exit;",
                        "  }",
                        "}"
