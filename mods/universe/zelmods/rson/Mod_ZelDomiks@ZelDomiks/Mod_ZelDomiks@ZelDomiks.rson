                {
                    "Name": "",
                    "Code.Type": "Turn",
                    "Code": [
                        "star=ShipStar(Player());",
                        "blackHole=HoleCreate2(star,star);",
                        "ugol=0.01*Rnd(0,200);",
                        "x=round(sin(ugol*pi)*Rnd(125,150)+CoordX(Player()));",
                        "y=round(cos(ugol*pi)*Rnd(125,150)+CoordY(Player()));",
                        "HoleX1(blackHole,x);",
                        "HoleY1(blackHole,y);",
                        "HoleX2(blackHole,x);",
                        "HoleY2(blackHole,y);",
                        "idMissionHole=Id(blackHole);",
                        "OrderLock(Player(),1);",
                        "OrderJumpHole(Player(),blackHole);",
                        "completeTask = 2;",
                        "ABStarted=0;",
                        "ButtonClick('StarMap','PM_EndTurn');"
                    ],
