                        "          ShipAddCustomShipInfo(thisShip,'ZelDomiks_AuraK','NoShow');",
                        "        else if(bonusAdd==3)",
                        "          ShipAddCustomShipInfo(thisShip,'ZelDomiks_AuraT','NoShow');",
                        "        else",
                        "          ShipAddCustomShipInfo(thisShip,'ZelDomiks_Aura','NoShow');",
                        "      }",
                        "    }",
                        "  }",
                        "  ShipCustomShipInfoData(CurShip,'ZelDomiks_BertorsAura',1,0);",
                        "  ",
                        "  dword numOfKligs=ShipCustomShipInfoData(CurShip,'ZelDomiks_BertorsAura',2);",
                        "  if(Rnd(1,10+2*((bonusDomiks==3)+(bonusGlobal==3)))>(5-numOfKligs+(bonusDomiks==3)+(bonusGlobal==3))){",
                        "    while(numOfKligs<5+(bonusDomiks==3)+(bonusGlobal==3)){",
                        "      SpawnKlig(Id(CurShip));",
                        "      numOfKligs=numOfKligs+1;",
                        "      OrderNone(CurShip);",
                        "      SetData(0, 0, CurShip);",
                        "    }",
                        "    ShipCustomShipInfoData(CurShip,'ZelDomiks_BertorsAura',2,5+(bonusDomiks==3)+(bonusGlobal==3));",
                        "  }",
                        "}",
                        "if(GetShipPlanet(CurShip)) {",
                        "  HullHP(CurShip,ItemSize(ShipItems(CurShip,0)));",
                        "  ShipRefuel(CurShip);",
                        "  ShipRepairEq(CurShip);",
                        "  OrderTakeOff(CurShip);",
                        "}",
                        "if(ShipInNormalSpace(CurShip)) {",
                        "  potentialEnemy = 0;",
                        "  distance = 100000;",
                        "  star = ShipStar(CurShip);",
                        "  cShips=StarShips(star);",
                        "  ourPlanet=IdToPlanet(planetId);",
                        "  nearPlanet=NearCivilPlanet(CurShip);",
                        "  BertorStars[Id(star)-1]=1;",
                        "  for (i = 0; i <= cShips; i = i + 1) {",
                        "    thisShip = StarShips(star, i);",
                        "    if (ShipInNormalSpace(thisShip)) {",
                        "      bool=GetRelationPlanet(ourPlanet, thisShip) <= 30;",
                        "      if (bool && distance > Dist(CurShip, thisShip) && ShipTypeN(thisShip)!=2) {",
                        "        potentialEnemy = thisShip;",
                        "        distance = Dist(CurShip, thisShip);",
                        "      }",
                        "    }",
                        "  }",
                        "  if (potentialEnemy != 0)",
                        "    ShipSetBad(CurShip, potentialEnemy);",
                        "  OrderLock(CurShip,1);",
                        "  if(ShipGetBad(CurShip)==0&&GetData(1,CurShip)>=10000) {",
                        "    int turnsForComplete=GetData(0, CurShip);",
                        "    if(ItemSize(ShipItems(CurShip,0))-HullHP(CurShip)>ShipDroidRepair(CurShip)*5)",
                        "      turnsForComplete=OrderLanding(CurShip,NearCivilPlanet(CurShip));",
                        "    else if (turnsForComplete < 1) {",
                        "      ugol = 0.01 * Rnd(0, 200);",
                        "      radius = PlanetOrbitRadius(StarPlanets(ShipStar(CurShip), 0)) + Rnd(-50, 100);",
                        "      x = round(sin(ugol * pi) * radius);",
                        "      y = round(cos(ugol * pi) * radius);",
                        "      OrderMove(CurShip, x, y);",
                        "      distance=round(sqrt(sqr(abs(CoordX(CurShip)-x))+sqr(abs(CoordY(CurShip)-y))));",
                        "      int ourShipSpeed=ShipSpeed(CurShip);",
                        "      turnsForComplete=distance/ourShipSpeed+(distance%ourShipSpeed!=0);",
                        "    }",
                        "    SetData(turnsForComplete - 1, 0, CurShip);",
                        "    if(bonusAdd==3&&!HullDamage(CurShip)){",
                        "      int HPForOurShip=Rnd((6*(7+curDomLevel))/15,(13*(7+curDomLevel))/10);",
                        "      int hitpointsOfTheShip=HullHP(CurShip);",
                        "      ItemSize(ShipItems(CurShip, 0),hitpointsOfTheShip+HPForOurShip);",
                        "      HullHP(CurShip, hitpointsOfTheShip+HPForOurShip);",
                        "      if(hitpointsOfTheShip+HPForOurShip>=2500){",
                        "        dom=SpawnKlig(Id(CurShip));",
                        "        ShipDeleteCustomShipInfo(dom,'ZelDomiks_KligsDeath');",
                        "        ItemSize(ShipItems(CurShip, 0),hitpointsOfTheShip-200);",
                        "        HullHP(CurShip, hitpointsOfTheShip-200);",
                        "      }",
                        "    }",
                        "  }",
                        "  if(ShipGetBad(CurShip)>0) {",
                        "    ChangeState(20);",
                        "    exit;",
                        "  }",
                        "  if(GetData(1,CurShip)>=10000&&GroupCount(bertors)<ControlledSystems(0)) {",
                        "    SetData(GetData(1,CurShip)+Rnd(1,2),1,CurShip);",
                        "  }",
                        "  if(GetData(1,CurShip)<10000&&ShipGetBad(CurShip)==0) {",
                        "    if(GalaxyStar(GetData(1,CurShip))==star) {",
                        "      SetData(10000,1,CurShip);",
                        "      ChangeState(19);",
                        "      exit;",
                        "    }",
                        "    if(GalaxyStar(GetData(1,CurShip))!=star) {",
                        "      OrderJump(CurShip,GalaxyStar(GetData(1,CurShip)));",
                        "      SetData(0,0,CurShip);",
                        "      BertorStars[Id(star)-1]=0;",
                        "    }",
                        "  }",
                        "}",
                        "if(GetData(1,CurShip)>10150) {",
                        "  SetData(GiveBertorStar(),1,CurShip);",
                        "}"
