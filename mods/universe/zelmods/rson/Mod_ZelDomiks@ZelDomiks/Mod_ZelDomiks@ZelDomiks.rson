                        "  }",
                        "}",
                        "if(domLevel==8&&completeTask==2) {",
                        "  daysMission=daysMission-1;",
                        "  if(doneMissions[0]==2)",
                        "    missionsStrings[0]=Format('дал задание по защите системы Тарон от захвата врагов (осталось <0> дней).',\"<0>\",m8MalDays);",
                        "  if(doneMissions[4]==2)",
                        "    missionsStrings[4]=Format('попросил <0> дней на раздумья. Осталось ждать <1> дней.',\"<0>\",45+4*difficultOfMissions,\"<1>\",m8GaalDays);",
                        "  Ether(3,'ZelDomiksQuest',Format(CT(\"Script.Mod_ZelDomiks.411\"),\"<0>\",daysMission,\"<1>\",missionsStrings[0],\"<2>\",missionsStrings[1],\"<3>\",missionsStrings[2],\"<4>\",missionsStrings[3],\"<5>\",missionsStrings[4]));",
                        "  bool=1;",
                        "  for(i=0;i<5;i=i+1){",
                        "    if(!doneMissions[i])",
                        "      bool=0;",
                        "  }",
                        "  if(bool){",
                        "    completeTask=1;",
                        "    Ether(4,'ZelDomiksQuest','Все пять гуманодов согласились пмогать в улучшении доминаторов Ниспера. Задание выполнено, осталось только поговорить с Ниспером.');",
                        "    Sound('Sound.QuestOk');",
                        "  }",
                        "  else if(daysMission==0){",
                        "    completeTask=0;",
                        "    Ether(5,'ZelDomiksQuest','Время отведенное на выполнение миссии вышло. Задание провалено.');",
                        "    Sound('Sound.QuestCancel');",
                        "  }",
                        "}",
                        "if(domLevel==3&&completeTask==2) {",
                        "  daysMission = daysMission + 1;",
                        "  targetStar = GalaxyStar(idStarAttackPirates);",
                        "  ourPlanet = PlanetPirateClan();",
                        "  dword starPirates = PlanetToStar(ourPlanet);",
                        "  int ourHullSize;",
                        "  Ether(3,'ZelDomiksQuest',Format('Нужно защитить систему <0> и не дать ей перейти в руки пиратского клана до конца передачи информации. Осталось дней: <1>.',\"<0>\",StarName(targetStar),\"<1>\",daysMissionComplete-daysMission));",
                        "  if (StarOwner(targetStar) == 0 && PirateWin() == 0) {",
                        "    if (daysMissionComplete-daysMission > 20) {",
                        "      if (Rnd(1, 4) == 1) {",
                        "        for (i = 0; i < Rnd(difficultOfPirates / 3, difficultOfPirates / 2 + 3) + 1; i = i + 1) {",
                        "          dom = BuyWarrior(ourPlanet, 50 + 20 * difficultOfPirates);",
                        "          ourHullSize = 300 + 25 * difficultOfPirates;",
                        "          ourHullSize = Rnd(0.7 * ourHullSize, 1.3 * ourHullSize);",
                        "          for (j = 0; j < Rnd(0, difficultOfPirates / 2); j = j + 1)",
                        "            ShipRefit(dom, ourHullSize);",
                        "          ShipImproveItems(dom, Rnd(0, difficultOfPirates / 2));",
                        "          MakeShipEnterStar(dom, targetStar, starPirates, 5);",
                        "          Chameleon(dom);",
                        "        }",
                        "      }",
                        "    } else if (daysMissionComplete-daysMission == 20) {",
                        "      for (i = 0; i < Rnd(difficultOfPirates / 5, difficultOfPirates / 3) + 2; i = i + 1) {",
                        "        dom = BuyWarrior(ourPlanet, 150 + 50 * difficultOfPirates);",
                        "        ourHullSize = 500 + 35 * difficultOfPirates;",
                        "        ourHullSize = Rnd(0.8 * ourHullSize, 1.2 * ourHullSize);",
                        "        for (j = 0; j < 5; j = j + 1)",
                        "          ShipRefit(dom, ourHullSize);",
                        "        ShipImproveItems(dom, Rnd(difficultOfPirates / 2, difficultOfPirates) + 3);",
                        "        MakeShipEnterStar(dom, targetStar, starPirates, 5);",
                        "        Chameleon(dom);",
                        "        ShipSpecialBonuses(dom, bonSpeed, 100 + 20 * difficultOfPirates);",
                        "        ShipSpecialBonuses(dom, bonDroid, 10 + 2 * difficultOfPirates);",
                        "        ShipSpecialBonuses(dom, bonDef, 5 + 1 * difficultOfPirates);",
                        "        ShipSpecialBonuses(dom, bonWEnergy, 10 + 2 * difficultOfPirates);",
                        "        ShipSpecialBonuses(dom, bonWSplinter, 10 + 2 * difficultOfPirates);",
                        "        ShipSpecialBonuses(dom, bonWMissile, 10 + 2 * difficultOfPirates);",
                        "      }",
                        "    } else if (daysMissionComplete-daysMission == 0) {",
                        "      BertorStars[idStarAttackPirates] = 0;",
                        "      NoComeKlingToStar(GalaxyStar(idStarAttackPirates), 0);",
                        "      completeTask = 1;",
                        "      Sound('Sound.QuestOk');",
                        "      Ether(4,'ZelDomiksQuest',Format('Система <0> успешно закончила передавать всю необходимую информацию. Задание выполнено, осталось только поговорить с Ниспером.',\"<0>\",StarName(targetStar)));",
                        "    }",
                        "  } else if (StarOwner(targetStar) != 0) {",
                        "    BertorStars[idStarAttackPirates] = 0;",
                        "    NoComeKlingToStar(targetStar, 0);",
                        "    completeTask = 0;",
                        "    Sound('Sound.QuestCancel');",
                        "    completeEther=0;",
                        "    researched=15;",
                        "    daysForResearch=1;",
                        "    Ether(5,'ZelDomiksQuest',Format('Пиратский клан захватил систему <0> и часть необходимых данных. Задание провалено, а ученым придется заново восстанавливать утраченную информацию.',\"<0>\",StarName(targetStar)));",
                        "  } else {",
                        "    BertorStars[idStarAttackPirates] = 0;",
                        "    NoComeKlingToStar(targetStar, 0);",
                        "    completeTask = 1;",
                        "    Sound('Sound.QuestOk');",
                        "    Ether(4,'ZelDomiksQuest',Format('Пиратский клан нейтрализован и система <0> в безопасности. Задание выполнено, осталось только поговорить с Ниспером.',\"<0>\",StarName(targetStar)));",
                        "  }",
                        "}",
                        "if(domLevel==5&&completeTask==2&&bonusAdd==3) {",
                        "  daysMission = daysMission + 1;",
                        "  if(daysMission<daysMissionComplete){",
                        "    bool=0;",
                        "    playerDayMoney=ShipCustomShipInfoData(Player(),'ZelDomiks_MoneyPlayerInfo',1);",
                        "    ShipCustomShipInfoData(Player(),'ZelDomiks_MoneyPlayerInfo',1,0);",
                        "    playerProfit=playerProfit+playerDayMoney;",
                        "    for(i=0;i<3;i=i+1){",
                        "      ourDomTrader=IdToShip(domTraderId[i]);",
                        "      if(ourDomTrader){",
                        "        bool=1;",
                        "        if(playerDayMoney>0){",
                        "          power=Rnd(8,16)+Rnd(12,35)*difficultOfMoney/10;",
                        "          domikProfitPlus[i]=domikProfitPlus[i]+(power*playerDayMoney/100);",
                        "        }",
                        "        domikDayMoney=ShipCustomShipInfoData(ourDomTrader,'ZelDomiks_MoneyDomInfo',1);",
                        "        ShipCustomShipInfoData(ourDomTrader,'ZelDomiks_MoneyDomInfo',1,0);",
                        "        bonusProfitDom;",
                        "        if(domikDayMoney>0){",
                        "          bonusProfitDom=domikProfitPlus[i]*Rnd(15,30+difficultOfMoney*2)/100;",
                        "          domikProfitPlus[i]=domikProfitPlus[i]-bonusProfitDom;",
                        "          domikProfit[i]=domikProfit[i]+domikDayMoney+bonusProfitDom;",
                        "        }",
                        "      }",
                        "    }",
                        "    Ether(3,'ZelDomiksQuest',Format(CT(\"Script.Mod_ZelDomiks.309\"),\"<0>\",playerProfit,\"<1>\",domikProfit[0],\"<2>\",domikProfit[1],\"<3>\",domikProfit[2],\"<4>\",daysMissionComplete-daysMission));",
                        "    if(!bool){",
                        "      completeTask = 0;",
                        "      Sound('Sound.QuestCancel');",
                        "      Ether(5,'ZelDomiksQuest','Все торговые доминаторы Ниспера были уничтожены. Задание считается отмененным.');",
                        "    }",
                        "  }",
                        "  else if(daysMission==daysMissionComplete){",
                        "    for(i=0;i<3;i=i+1){",
                        "      ourDomTrader=IdToShip(domTraderId[i]);",
                        "      if(ourDomTrader)",
                        "        ShipDestroy(ourDomTrader,1);",
                        "    }",
                        "    if(playerProfit>domikProfit[0]&&playerProfit>domikProfit[1]&&playerProfit>domikProfit[2]){",
                        "      completeTask=1;",
                        "      Sound('Sound.QuestOk');",
                        "      Ether(4,'ZelDomiksQuest','По итогам состязания вы получили больше прибыли чем любой из модулей Ниспера. Задание выполнено, осталось только поговорить с Ниспером.');",
                        "    }",
                        "    else{",
                        "      completeTask = 0;",
                        "      Sound('Sound.QuestCancel');",
                        "      Ether(5,'ZelDomiksQuest','По итогам состязания вы получили меньше прибыли чем один из модулей Ниспера. Задание провалено.');",
                        "    }",
                        "  }",
                        "}",
                        "if(domLevel==9&&completeTask==2&&bonusAdd==1) {",
                        "  daysMission=daysMission-1;",
                        "  if(daysMission==0){",
                        "    completeTask=0;",
                        "    Ether(5,'ZelDomiksQuest','Враги были уничтожены прилетевшими подкреплениями. Однако до этого доминаторы успели уничтожить часть важной информации. Ученым придется потратить время на ее восстановление. Задание провалено.');",
                        "    Sound('Sound.QuestCancel');",
                        "    completeEther=0;",
                        "  }",
                        "  else if(GetShipRuins(Player())) {",
                        "    if (ShipType(GetShipRuins(Player())) == 'DB')",
                        "      GotoGov(2);",
                        "  }",
                        "}",
                        "if(domLevel==2&&uselessItemOnPlanet==0) {",
                        "  ourPlanet = GetShipPlanet(Player());",
                        "  if (ourPlanet) {",
                        "    if (PlanetOwner(ourPlanet) == None) {",
                        "      bool = 1;",
                        "      int idOurPlanet = Id(ourPlanet);",
                        "      for (i = 0; i < numNeutralPlanets; i = i + 1) {",
                        "        if (idOurPlanet == idNeutralPlanets[i])",
                        "          bool = 0;",
                        "      }",
                        "      if (bool) {",
                        "        idNeutralPlanets[i] = idOurPlanet;",
                        "        if (Rnd(1, maxNeutralPlanets - numNeutralPlanets) == 1) {",
                        "          dword ourUselessItem = CreateQuestItem('Usl_25');",
                        "          SetName(ourUselessItem, 'Неизвестный материал');",
                        "          UselessItemText(ourUselessItem, 'Остатки доминатора класса Бертор');",
                        "          ItemSize(ourUselessItem, 20 + difficultOfLucky * 4);",
                        "          ItemOwner(ourUselessItem,Kling);",
                        "          ItemSubrace(ourUselessItem,Rnd(0,2));",
                        "          AddItemToPlanet(ourPlanet, ourUselessItem);",
                        "          idUselessItem[0] = Id(ourUselessItem);",
                        "          uselessItemOnPlanet = 1;",
                        "        } else",
                        "          numNeutralPlanets = numNeutralPlanets + 1;",
                        "      }",
                        "    }",
                        "  }",
                        "  Ether(3,'ZelDomiksQuest','Необходимо найти и отвезти на Базу Доминаторов образцы остатков доминатора класса Бертор.');",
                        "}",
                        "if(domLevel==5&&completeTask==2&&bonusAdd==2) {",
                        "  for(i=0;completeTask&&i<numItems;i=i+1){",
                        "    if(idUselessItem[i]!=-1){",
                        "      dword ourItem=IdToItem(idUselessItem[i]);",
                        "      if(!ourItem){",
                        "        completeTask=0;",
                        "        Sound('Sound.QuestCancel');",
                        "        Ether(5,'ZelDomiksQuest','Один из экземпляров устройства был уничтожен. Необходимо начать поиски заново.');",
                        "        completeEther=0;",
                        "        idUselessItem[i]=-1;",
                        "        for(j=0;j<numItems;j=j+1){",
                        "          if(idUselessItem[j]!=-1){",
                        "            k=0;",
                        "            ourPlanet=IdToPlanet(idNeutralPlanets[j]);",
                        "            while(idUselessItem[j]!=Id(PlanetItems(ourPlanet,k)))",
                        "              k=k+1;",
                        "            FreeItem(GetItemFromPlanet(ourPlanet, k));",
                        "            idUselessItem[j]=-1;",
                        "          }",
                        "        }",
                        "      }",
                        "    }",
                        "  }",
                        "}",
                        "if(isStartedDomiks==1) {",
                        "  bank = bank + (ControlledSystems(0) * exp(1.2 + 0.8 * GalaxyTechLevel()));",
                        "  if(bankPlayer>0){",
                        "    if(bankPlayer>expenses){",
                        "      bank=bank+expenses;",
                        "      bankPlayer=bankPlayer-expenses;",
                        "    }",
                        "    else{",
                        "      bank=bank+bankPlayer;",
                        "      bankPlayer=0;",
                        "    }",
                        "  }",
                        "  if (bank >= expenses) {",
                        "    bank = bank - expenses;",
                        "    days = days + 1;",
                        "    if (days >= dayBuild) {",
                        "      SpawnDom(-1, 0);",
                        "      expenses = (exp(1.5 + 0.3 * domLevel) * ((1.0 - 0.025 * (bonusGlobal == 3) * domLevel) * 1.0 * GroupCount(domiks) / 3) * (3.0 + 0.5 * domLevel) * (5.0 + 1.0 * GalaxyDiffLevels() / 250));",
                        "      buildTime = ((1.0 * GalaxyDiffLevels() / 120) + 25.0 - (0.9 * curDomLevel)) / (2.0 + ((0.1 + 0.04 * curDomLevel) * (bonusGlobal == 3)));",
                        "      dayBuild = dayBuild + buildTime - days;",
                        "      days = 0;",
                        "    }",
                        "  }",
                        "  ",
                        "  daysAtt = daysAtt + ((10.0 + 1.0 * GroupCount(domiks) - 1.0 * GroupCount(domiks) * (bonusGlobal == 3) * 0.33) * 0.2) / ((1.0 + 0.3 * ControlledSystems(0)) * (1.0 + 1.0 * GalaxyDiffLevels() / 1000));",
                        "  if (ShipFindCustomShipInfoByType(Player(), 'Beacon') != -1) {",
                        "    daysAtt = 0;",
                        "    targetStar = GalaxyStar(ShipCustomShipInfoData(Player(), 'Beacon', 1));",
                        "    ShipDeleteCustomShipInfo(Player(), 'Beacon');",
                        "    StartAttackSystem(targetStar);",
                        "  } else if (daysAtt >= 120 + 30 * (bonusGlobal == 1)) {",
                        "    daysAtt = 0;",
                        "    targetStar = GiveAttackStar();",
                        "    if (targetStar != -1)",
                        "      StartAttackSystem(targetStar);",
                        "    else",
                        "      daysAtt = 0 - GroupCount(domiks) * 10;",
                        "  }",
                        "  ",
                        "  bossShip = IdToShip(bossId);",
                        "  if (!bossShip) {",
                        "    daysBuildBoss = daysBuildBoss - 1;",
                        "    if (daysBuildBoss <= 0) {",
                        "      daysBuildBoss = 100 + GalaxyDiffLevels() / 2;",
                        "      if (bonusBoss == 0)",
                        "        SpawnBoss();",
                        "      else if (bonusBoss == 1){",
                        "        SpawnBossBlazer();",
                        "        daysBuildBoss=daysBuildBoss/2;",
                        "      }",
                        "      else if (bonusBoss == 2)",
                        "        SpawnBossKeller();",
                        "      else if (bonusBoss == 3)",
                        "        SpawnBossTerron();",
                        "    }",
                        "  }",
                        "  ",
                        "  if (domLevel < 10) {",
                        "    if (itemsForResearch < 300)",
                        "      ourItemsForResearch = itemsForResearch;",
                        "    else",
                        "      ourItemsForResearch = 300;",
                        "    speedResearch = (75.0 + ourItemsForResearch) / 375 * (0.18 - 0.014 * difficultOfResearch) * (1.0 + 0.2 * (bonusGlobal == 2));",
                        "    int destroyItemsForResearch = Rnd(0.4 * difficultOfResearch + 1, 1.2 * difficultOfResearch + 2);",
                        "    if (domLevel < 10)",
                        "      daysForResearch = (1.0 * Research[domLevel] - researched) / speedResearch;",
                        "    else",
                        "      daysForResearch = 0;",
                        "    if (daysForResearch > 0) {",
                        "      if (itemsForResearch > destroyItemsForResearch)",
                        "        itemsForResearch = itemsForResearch - destroyItemsForResearch;",
                        "      else if (itemsForResearch <= destroyItemsForResearch)",
                        "        itemsForResearch = 0;",
                        "      researched = researched + speedResearch;",
                        "    } else if (completeEther == 0) {",
                        "      CustomEther('NisperEther', 7, '', 'Ученые Коалиции закончили свои исследования в области доминаторов Ниспера. Для получения более подробной информации обратитесь к Нисперу.');",
                        "      completeEther = 1;",
                        "    }",
                        "  }",
                        "  ",
                        "  playerShip = Player();",
                        "  if (ShipInNormalSpace(playerShip) && Id(ShipItems(playerShip, 0)) == bertorHullId) {",
                        "    star = ShipStar(playerShip);",
                        "    cShips = StarShips(star);",
                        "    ourPlanet = IdToPlanet(planetId);",
                        "    power = (1.0 + 0.03 * (bonusAdd == 3) * curDomLevel) * HullSizeMax[5];",
                        "    for (i = 0; i <= cShips; i = i + 1) {",
                        "      thisShip = StarShips(star, i);",
                        "      if (ShipInNormalSpace(thisShip)) {",
                        "        if (thisShip != playerShip && HullHP(thisShip) <= power && Dist(playerShip, thisShip) <= 500 && GetRelationPlanet(ourPlanet, thisShip) > 30) {",
                        "          if (bonusAdd == 1)",
                        "            ShipAddCustomShipInfo(thisShip, 'ZelDomiks_AuraB', 'NoShow');",
                        "          else if (bonusAdd == 2)",
                        "            ShipAddCustomShipInfo(thisShip, 'ZelDomiks_AuraK', 'NoShow');",
                        "          else if (bonusAdd == 3)",
                        "            ShipAddCustomShipInfo(thisShip, 'ZelDomiks_AuraT', 'NoShow');",
                        "          else",
                        "            ShipAddCustomShipInfo(thisShip, 'ZelDomiks_Aura', 'NoShow');",
                        "        }",
                        "      }",
                        "    }",
                        "    ShipCustomShipInfoData(playerShip, 'ZelDomiks_BertorsAura', 1, 0);",
                        "    int numOfKligs = ShipCustomShipInfoData(playerShip, 'ZelDomiks_BertorsAura', 2);",
                        "    if (Rnd(1, 10 + 2 * ((bonusDomiks == 3) + (bonusGlobal == 3))) > (5 - numOfKligs + (bonusDomiks == 3) + (bonusGlobal == 3))) {",
                        "      while (numOfKligs < 5 + (bonusDomiks == 3) + (bonusGlobal == 3)) {",
                        "        SpawnKlig(Id(playerShip));",
                        "        numOfKligs = numOfKligs + 1;",
                        "      }",
                        "      ShipCustomShipInfoData(playerShip, 'ZelDomiks_BertorsAura', 2, 5 + (bonusDomiks == 3) + (bonusGlobal == 3));",
                        "    }",
                        "  }",
                        "  ",
                        "  if (!IdToShip(DBId)) {",
                        "    bossShip = IdToShip(bossId);",
                        "    if (bossShip)",
                        "      ShipDestroy(bossShip, 1);",
                        "    for (i = 0; i < GroupCount(bertors); i = i + 1)",
                        "      ShipDestroy(GroupShip(bertors, i), 1);",
                        "    for (i = 0; i < GroupCount(kligs); i = i + 1)",
                        "      ShipDestroy(GroupShip(kligs, i), 1);",
                        "    for (i = 0; i < GroupCount(domiks); i = i + 1)",
                        "      ShipDestroy(GroupShip(domiks, i), 1);",
                        "    for (i = 0; i < GroupCount(domiksBes); i = i + 1)",
                        "      ShipDestroy(GroupShip(domiksBes, i), 1);",
                        "    for (i = 0; i < GroupCount(freeGroup); i = i + 1)",
                        "      ShipDestroy(GroupShip(freeGroup, i), 1);",
                        "    isStartedDomiks = 0;",
                        "  /*  bonusGlobal=-1;",
                        "    bonusBoss=Rnd(1,3);",
                        "    bonusDomiks=-1;",
                        "    bonusAdd=0;*/",
                        "    CustomEther('NisperEther', 7, '', 'База Доминаторов уничтожена. Все корабли доминаторов Коалиции, включая Ниспера, получили приказ немедленного самоуничтожения для предотвращения сбоя в программе.');",
                        "  }",
                        "}",
                        "if(robotsReady==1) {",
                        "  if(GRobotStatus==2)",
                        "    robotsReady=3;",
                        "  else",
                        "    robotsReady=2;",
                        "}",
                        "if(domLevel==8&&completeTask==2&&doneMissions[4]==2) {",
                        "  m8GaalDays=m8GaalDays-1;",
                        "  if(m8GaalDays==0){",
                        "    doneMissions[4]=3;",
                        "    missionsStrings[4]=Format('ждет вас на планете <0>.',\"<0>\",PlanetName(IdToPlanet(idPlanetsMissions[4])));",
                        "  }",
                        "}",
                        "if(domLevel==8&&completeTask==2&&doneMissions[0]==2) {",
                        "  m8MalDays=m8MalDays-1;",
                        "  if(m8MalDays==0){",
                        "    doneMissions[0]=3;",
                        "    missionsStrings[0]=Format('ждет вас на планете <0>.',\"<0>\",PlanetName(IdToPlanet(idPlanetsMissions[0])));",
                        "  }",
                        "  else if(StarOwner(PlanetToStar(IdToPlanet(idPlanetsMissions[0]))) != 0){",
                        "    completeTask=0;",
                        "    Ether(5,'ZelDomiksQuest','Вы не выполнили условие Борфорса и он отказывается идти с вами на сделку. Задание провалено.');",
                        "  }",
                        "}",
                        "if(domLevel==8&&completeTask==2&&doneMissions[3]==2) {",
                        "  if(!IdToItem(idFean)){",
                        "    completeTask=0;",
                        "    Ether(5,'ZelDomiksQuest','Кто-то уничтожил капсулу с Абером. Задание провалено.');",
                        "  }",
                        "}"
                    ],
                    "#": 132,
                    "Type": "Top",
                    "Parent": -1,
                    "Pos.x": 120,
                    "Pos.y": 1535
                },
                {
                    "Name": "",
                    "Code.Type": "DialogBegin",
                    "Code": [
                        "dword playerShip = Player();",
                        "dword planet = GetShipPlanet(Player());",
                        "dword shipRuins=GetShipRuins(playerShip);",
                        "if (isStartedDomiks==1) {",
                        "  if (shipRuins) {",
                        "    if (ShipType(shipRuins) == 'DB') {",
                        "      AddDialogInject('dBank', CT(\"Script.Mod_ZelDomiks.159\"), 'Пополнить банк', 1, 1);",
                        "      if (domLevel < 10) {",
                        "        if (daysForResearch > 0)",
                        "          AddDialogInject('dUpgrade', '', 'Помочь исследованиям', 2);",
                        "        else",
                        "          AddDialogInject('dGetMission', '', 'Так что там с исследованиями?', 2);",
                        "        if (domLevel == 2 && completeTask == 2) {",
                        "          bool = 0;",
                        "          for (i = ShipItems(playerShip) - 1; !bool && i > 0; i = i - 1) {",
                        "            if (Id(ShipItems(playerShip, i)) == idUselessItem[0]) {",
                        "              AddDialogInject('d2MissionComplete', '', 'Сдать ошметки Бертора', 3);",
                        "              bool = 1;",
                        "              j = i;",
                        "            }",
                        "          }",
                        "        } else if (domLevel == 5 && completeTask == 2 && bonusAdd == 2) {",
                        "          bool = 0;",
                        "          for (i = ShipItems(playerShip) - 1; !bool && i > 0; i = i - 1) {",
                        "            for (j = 0; !bool && j < numItems; j = j + 1) {",
                        "              if (Id(ShipItems(playerShip, i)) == idUselessItem[j]) {",
                        "                bool = 1;",
                        "                AddDialogInject('d5MissionComplete', '', 'Сдать экземпляры пиратского устройства', 3);",
                        "              }",
                        "            }",
                        "          }",
                        "        } else if (domLevel == 8 && completeTask == 2 && doneMissions[3] == 2) {",
                        "          bool = 0;",
                        "          for (i = ShipItems(playerShip) - 1; !bool && i > 0; i = i - 1) {",
                        "            if (Id(ShipItems(playerShip, i)) == idFean) {",
                        "              AddDialogInject('d8MissionFeanCom', '', 'Отдать капсулу с Абером', 3);",
                        "              bool = 1;",
                        "              j = i;",
                        "            }",
                        "          }",
                        "        } else if (domLevel == 7 && completeTask == 2) {",
                        "          if (!robotsReady)",
                        "            AddDialogInject('dRobots', '', 'Участвовать в боевом состязании с Ниспером', 3);",
                        "          else if (robotsReady == 2)",
                        "            AddDialogInject('dRobotsL', '', 'Я проиграл в состязании с Ниспером', 3);",
                        "          else if (robotsReady == 3)",
                        "            AddDialogInject('dRobotsW', '', 'Я выиграл в состязании с Ниспером', 3);",
                        "        } else if (domLevel == 9 && completeTask == 2 && bonusAdd == 1) {",
                        "          if (!robotsReady)",
                        "            AddDialogOverride('dRobotsF', 100);",
                        "          else if (robotsReady == 2)",
                        "            AddDialogOverride('dRobotsFL', 100);",
                        "          else if (robotsReady == 3)",
                        "            AddDialogOverride('dRobotsFW', 100);",
                        "        }",
                        "      }",
                        "    }",
                        "  }",
                        "  if (GetTalkShip() && !TalkByAI()) {",
                        "    dword bossShip = IdToShip(bossId);",
                        "    dword talkShip = GetTalkShip();",
                        "    int relations = GetRelationPlanet(IdToPlanet(planetId), playerShip);",
                        "    if (bossShip == talkShip) {",
                        "      if (!bossDialog) {",
                        "        AddDialogOverride('dDialogBossStart', 1);",
                        "      } else {",
                        "        if (relations > 30 && ShipGetBad(talkShip) != playerShip)",
                        "          AddDialogOverride('dDialogBoss', 1);",
                        "        else",
                        "          AddDialogOverride('dDialogBossA', 1);",
                        "      }",
                        "    } else if (ShipCustomFaction(talkShip) == 'SubFaction.Nisper' && (ShipTypeN(talkShip) == 5||ShipTypeN(talkShip) == 2)) {",
                        "      if (relations > 30 && ShipGetBad(talkShip) != playerShip)",
                        "        AddDialogOverride('dDialogDom', 1);",
                        "      else",
                        "        AddDialogOverride('dDialogDomA', 1);",
                        "    }",
                        "  }",
                        "  if (domLevel == 8 && completeTask == 2 && planet) {",
                        "    for (i = 0; i < 5; i = i + 1) {",
                        "      if (planet == IdToPlanet(idPlanetsMissions[i])) {",
                        "        if (i == 0) {",
                        "          if (doneMissions[i] == 0)",
                        "            AddDialogInject('d8MissionMal', '', 'Это вы Борфорс?', 1);",
                        "          else if (doneMissions[i] == 3)",
                        "            AddDialogOverride('d8MissionMalW', 1);",
                        "        } else if (i == 1) {",
                        "          if (doneMissions[i] == 0)",
                        "            AddDialogInject('d8MissionPel', '', 'Это вы Кувард?', 1);",
                        "        } else if (i == 2) {",
                        "          if (doneMissions[i] == 0) {",
                        "            if (doneMissions[0] == 1 && doneMissions[1] == 1 && doneMissions[3] == 1 && doneMissions[4] == 1) {",
                        "              if (m8HumIs)",
                        "                AddDialogInject('d8MissionHumY', '', 'Ну так что, вы согласны с предложением Совета Коалиции?', 1);",
                        "              else",
                        "                AddDialogInject('d8MissionHum', '', 'Это вы Леонард?', 1);",
                        "            } else {",
                        "              if (m8HumIs)",
                        "                AddDialogInject('d8MissionHumNo', '', 'Ну так что, вы согласны с предложением Совета Коалиции?', 1);",
                        "              else",
                        "                AddDialogInject('d8MissionHumN', '', 'Это вы Леонард?', 1);",
                        "            }",
                        "          }",
                        "        } else if (i == 3) {",
                        "          if (doneMissions[i] == 0)",
                        "            AddDialogInject('d8MissionFean', '', 'Это вы Абер?', 1);",
                        "        } else {",
                        "          if (doneMissions[i] == 0)",
                        "            AddDialogInject('d8MissionGaal', '', 'Это вы Арту?', 1);",
                        "          else if (doneMissions[i] == 3)",
                        "            AddDialogOverride('d8MissionGaalW', 1);",
                        "        }",
                        "      }",
                        "    }",
                        "  }",
                        "}",
                        "else if (bonusGlobal == -1&&ShipRank(playerShip)>=1) {",
                        "  if (shipRuins) {",
                        "    if (ShipType(shipRuins) == 'SB') {",
                        "      if(SBDialog)",
                        "        AddDialogInject('dSB', '', 'Я хочу сдать вам ошметки доминаторов для новой серии', 0);",
                        "      else",
                        "        AddDialogInject('dSBStart', '', 'Ходят слухи про какую-то четвертую серию доминаторов... Вы ничего об этом не знаете?', 100);",
                        "    }",
                        "  }",
                        "}",
                        "else if(bonusDomiks==-1){",
                        "  if (shipRuins) {",
                        "    if (ShipType(shipRuins) == 'DB') {",
                        "      GotoGov(2);",
                        "      if(robotsReady==0)",
                        "        AddDialogOverride('dDBStart',100);",
                        "      else if(robotsReady==2)",
                        "        AddDialogOverride('dDBLose',100);",
                        "      else if(robotsReady==3)",
                        "        AddDialogOverride('dDBWin',100);",
                        "    }",
                        "  }",
                        "}"
