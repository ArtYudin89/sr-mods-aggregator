                        "for (i = ShipItems(playerShip) - 1; i > 0; i = i - 1) {",
                        "  for (j = 0; bool && j < numItems; j = j + 1) {",
                        "    if (Id(ShipItems(playerShip, i)) == idUselessItem[j]) {",
                        "      FreeItem(GetItemFromShip(playerShip, i));",
                        "      idUselessItem[j]=-1;",
                        "      numNeutralPlanets=numNeutralPlanets+1;",
                        "      bool=0;",
                        "      Ether(3,'ZelDomiksQuest',Format('Необходимо найти и сдать на Базу Доминаторов <0> экземпляров пиратского устройства. Уже сдано <1> штук.',\"<0>\",numItems,\"<1>\",numNeutralPlanets));",
