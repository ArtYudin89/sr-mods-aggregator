                        "  starPirates = PlanetToStar(ourPlanet);",
                        "  Ether(3,'ZelDomiksQuest',Format('Необходимо защитить систему <0> и не позволить пиратскому клану завладеть ею. До конца операции осталось <1> дней.',\"<0>\",StarName(targetStar),\"<1>\",daysMissionComplete-daysMission));",
                        "  if (StarOwner(targetStar) != 2 && PirateWin() == 0) {",
                        "    if (daysMissionComplete - daysMission > 15) {",
                        "      if (Rnd(1, 3) == 1) {",
                        "        for (i = 0; i < Rnd(difficultOfPirates / 2, max(3,difficultOfPirates)) + 1; i = i + 1) {",
                        "          dom = BuyWarrior(ourPlanet, 75 + 25 * difficultOfPirates);",
                        "          ourHullSize = 350 + 30 * difficultOfPirates;",
                        "          ourHullSize = Rnd(0.8 * ourHullSize, 1.2 * ourHullSize);",
                        "          for (j = 0; j < Rnd(0, difficultOfPirates / 2) + 1; j = j + 1)",
                        "            ShipRefit(dom, ourHullSize);",
                        "          ShipImproveItems(dom, Rnd(0, difficultOfPirates / 2) + 1);",
                        "          MakeShipEnterStar(dom, targetStar, starPirates, 1);",
                        "          Chameleon(dom);",
                        "        }",
                        "      }",
                        "    } else if (daysMissionComplete - daysMission == 15) {",
                        "      dom = BuyWarrior(ourPlanet, 200 + 100 * difficultOfPirates);",
                        "      ourHullSize = 700 + 50 * difficultOfPirates;",
                        "      ourHullSize = Rnd(0.9 * ourHullSize, 1.1 * ourHullSize);",
                        "      for (j = 0; j < 5; j = j + 1)",
                        "        ShipRefit(dom, ourHullSize);",
                        "      ShipImproveItems(dom, difficultOfPirates + 5);",
                        "      MakeShipEnterStar(dom, targetStar, starPirates, 1);",
                        "      Chameleon(dom);",
                        "      for (j = 0; j <= 5; j = j + 1)",
                        "        ShipSkill(dom, j, 1 + difficultOfPirates / 2);",
                        "      while (GetShipPirateRank(dom) < 6) {",
                        "        ShipPirateRankPoints(dom, ShipNextPirateRankPoints(dom));",
                        "        RaisePirateRank(dom);",
                        "      }",
                        "      ShipSpecialBonuses(dom, bonSpeed, 150 + 30 * difficultOfPirates);",
                        "      ShipSpecialBonuses(dom, bonDroid, 15 + 3 * difficultOfPirates);",
                        "      ShipSpecialBonuses(dom, bonDef, 7.5 + 1.5 * difficultOfPirates);",
                        "      ShipSpecialBonuses(dom, bonHull, 2.5 + 0.5 * difficultOfPirates);",
                        "      ShipSpecialBonuses(dom, bonWEnergy, 15 + 3 * difficultOfPirates);",
                        "      ShipSpecialBonuses(dom, bonWSplinter, 15 + 3 * difficultOfPirates);",
                        "      ShipSpecialBonuses(dom, bonWMissile, 15 + 3 * difficultOfPirates);",
                        "    } else if (daysMissionComplete-daysMission == 0) {",
                        "      completeTask = 1;",
                        "      Sound('Sound.QuestOk');",
                        "      idStarAttackPirates = -1;",
                        "      Ether(4,'ZelDomiksQuest',Format('Система <0> так и не попала в руки пиратов, а сооружение оказалось очередным заводом доминаторов. Задание выполнено, осталось только поговорить с Ниспером.',\"<0>\",StarName(targetStar)));",
                        "    }",
                        "  } else if (StarOwner(targetStar) == 2) {",
                        "    completeTask = 0;",
                        "    Sound('Sound.QuestCancel');",
                        "    completeEther=0;",
                        "    idStarAttackPirates = -1;",
                        "    researched=20;",
                        "    daysForResearch=1;",
                        "    Ether(5,'ZelDomiksQuest',Format('Системой <0> завладели пираты. Как оказалось, данное сооружение негативно действует на доминаторов серии Ниспер, а значит ученым придется потратить время на создание защиты против такого воздействия. Задание провалено.',\"<0>\",StarName(targetStar)));",
                        "  } else if(StarOwner(targetStar) == 0 || PirateWin() != 0){",
                        "    completeTask = 1;",
                        "    Sound('Sound.QuestOk');",
                        "    idStarAttackPirates = -1;",
                        "    Ether(4,'ZelDomiksQuest','Пиратский клан уничтожен, а значит ничто не помешает Коалиции уничтожить необычное сооружение. Задание выполнено, осталось только поговорить с Ниспером.');",
                        "  }",
                        "}",
                        "if(domLevel==9&&completeTask==2&&bonusAdd==2) {",
                        "  star = ShipStar(Player());",
