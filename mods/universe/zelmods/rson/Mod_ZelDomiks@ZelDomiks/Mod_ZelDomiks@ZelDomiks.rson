                {
                    "Name": "",
                    "Code.Type": "Init",
                    "Code": [
                        "idUselessItem=newarray(1);",
                        "idUselessItem[0]=-1;",
                        "domikProfit=newarray(3);",
                        "domikProfitPlus=newarray(3);",
                        "domTraderId=newarray(3);",
                        "doneMissions=newarray(5);",
                        "idPlanetsMissions=newarray(5);",
                        "missionsStrings=newarray(5);",
                        "for(i=0;i<5;i=i+1){",
                        "  doneMissions[i]=0;",
                        "  idPlanetsMissions[i]=0;",
                        "}",
                        "",
                        "ItemsOnSB = newarray(3);",
                        "for(i=0;i<3;i=i+1)",
                        "  ItemsOnSB[i]=0;",
                        "",
                        "HullSizeMin = newarray(7);",
                        "HullSizeMin[0] = 150;",
                        "HullSizeMin[1] = 250;",
                        "HullSizeMin[2] = 350;",
                        "HullSizeMin[3] = 500;",
                        "HullSizeMin[4] = 700;",
                        "HullSizeMin[5] = 900;",
                        "HullSizeMin[6] = 1250;",
                        "",
                        "HullSizeMax = newarray(7);",
                        "HullSizeMax[0] = 250;",
                        "HullSizeMax[1] = 350;",
                        "HullSizeMax[2] = 500;",
                        "HullSizeMax[3] = 700;",
                        "HullSizeMax[4] = 900;",
                        "HullSizeMax[5] = 1400;",
                        "HullSizeMax[6] = 2000;",
                        "/*",
                        "Research = newarray(10);",
                        "Research[0] = 0.0;",
                        "Research[1] = 0.1;",
                        "Research[2] = 0.1;",
                        "Research[3] = 0.1;",
                        "Research[4] = 0.1;",
                        "Research[5] = 0.1;",
                        "Research[6] = 0.1;",
                        "Research[7] = 0.1;",
                        "Research[8] = 0.1;",
                        "Research[9] = 0.1;",
                        "*/",
                        "Research = newarray(10);",
                        "Research[0] = 0;",
                        "Research[1] = 15;",
                        "Research[2] = 20;",
                        "Research[3] = 25;",
                        "Research[4] = 30;",
                        "Research[5] = 35;",
                        "Research[6] = 40;",
                        "Research[7] = 45;",
                        "Research[8] = 50;",
                        "Research[9] = 60;",
                        "",
                        "BertorStars=newarray(GalaxyStars());",
                        "for(i=0;i<GalaxyStars();i=i+1)",
                        "  BertorStars[i]=0;",
                        "",
                        "difficultOfAll=GalaxyDiffLevels()/50;",
                        "difficultOfPirates=GalaxyDiffLevels(0)/50;",
                        "difficultOfMoney=GalaxyDiffLevels(1)/50;",
                        "difficultOfResearch = GalaxyDiffLevels(2)/50;",
                        "difficultOfBreaks=GalaxyDiffLevels(3)/50;",
                        "difficultOfEquipment=GalaxyDiffLevels(4)/50;",
                        "difficultOfMissions=GalaxyDiffLevels(5)/50;",
                        "difficultOfHoles=GalaxyDiffLevels(6)/50;",
                        "difficultOfLucky=GalaxyDiffLevels(7)/50;",
                        "",
                        "bonusBoss=Rnd(1,3);",
                        "function SpawnDom(type, bes) {",
                        "  dword planet = IdToPlanet(planetId);",
                        "  dom = BuyTranclucator(planet);",
                        "  TransferShip(dom, IdToShip(DBId));",
                        "  TranclucatorData(dom,'Proprietor',IdToShip(proprietorId));",
                        "",
                        "  if (type == -1)",
                        "    domType = GiveTypeDomik(curDomLevel);",
                        "  else",
                        "    domType = type;",
                        "",
                        "  if (domType < 6) {",
                        "    if (bes)",
                        "      ShipJoin(domiksBes, dom);",
                        "    else",
                        "      ShipJoin(domiks, dom);",
                        "  } else{",
                        "    ShipJoin(bertors, dom);",
                        "    power=GalaxyStars();",
                        "    for(i=0;i<power;i=i+1)",
                        "      BertorStars[i]=0;",
                        "  }",
                        "",
                        "  if (bonusDomiks == 3)",
                        "    SetData(domType, 2, dom);",
                        "  else",
                        "    SetData(0, 2, dom);",
                        "",
                        "  if (bonusAdd == 1)",
                        "    ShipAddCustomShipInfo(dom, 'ZelDomiks_AddBonusB', 'NoShow', 40 + 8 * curDomLevel, domType);",
                        "",
                        "  if (bonusAdd == 2)",
                        "    GiveDomArts(curDomLevel, dom, domType);",
                        "",
                        "  if (domType == 6)",
                        "    ShipAddCustomShipInfo(dom, 'ZelDomiks_BertorsAura', 'NoShow', 0, 0);",
                        "",
                        "  ShipAddCustomShipInfo(dom, 'ZelDomiks_DomInfo', 'NoShow', domType);",
                        "  ShipAddCustomShipInfo(dom, 'ZelDomiks_DomRelations', 'NoShow');",
                        "",
                        "  GiveDomAllEq(domType, dom, curDomLevel);",
                        "",
                        "  result = dom;",
                        "}",
                        "",
                        "function SpawnKlig(idBertor) {",
                        "  dword planet = IdToPlanet(planetId);",
                        "  dword father = IdToShip(idBertor);",
                        "",
                        "  dom = BuyTranclucator(planet);",
                        "  ShipJoin(kligs, dom);",
                        "  TranclucatorData(dom,'Proprietor',IdToShip(proprietorId));",
                        "",
                        "  TransferShip(dom, NearCivilPlanet(father));",
                        "  OrderTakeOff(dom);",
                        "  ShipSetCoords(dom, CoordX(father), CoordY(father));",
                        "  ugol = 0.01 * Rnd(0, 200);",
                        "  ShipAngle(dom, ugol * 180 + 90);",
                        "  x = round(cos(ugol * pi) * 200 + CoordX(father));",
                        "  y = round(sin(ugol * pi) * 200 + CoordY(father));",
                        "  OrderMove(dom, x, y);",
                        "  ShipOrder(dom, 5);",
                        "",
                        "  power = GivePowerKlig(curDomLevel);",
                        "",
                        "  ShipAddCustomShipInfo(dom, 'ZelDomiks_KligsDeath', 'NoShow', idBertor);",
                        "  ShipAddCustomShipInfo(dom, 'ZelDomiks_DomInfo', 'NoShow');",
                        "  ShipAddCustomShipInfo(dom, 'ZelDomiks_DomRelations', 'NoShow');",
                        "  SetData(idBertor, 1, dom);",
                        "  Chameleon(dom, 'Ship.Blazer.B7');",
                        "",
                        "  GiveDomAllEq(0, dom, power);",
                        "",
                        "  result = dom;",
                        "}",
                        "",
                        "function SpawnBossBlazer() {",
                        "  dword planet = IdToPlanet(planetId);",
                        "",
                        "  dom = BuyTranclucator(planet);",
                        "  TransferShip(dom, IdToShip(DBId));",
                        "  TranclucatorData(dom,'Proprietor',IdToShip(proprietorId));",
                        "",
                        "  ShipJoin(bossB, dom);",
                        "  bossId = Id(dom);",
                        "",
                        "  ShipAddCustomShipInfo(dom, 'ZelDomiks_DomInfo', 'NoShow');",
                        "  ShipAddCustomShipInfo(dom, 'ZelDomiks_DomRelations', 'NoShow');",
                        "",
                        "  GiveBossAllEq(dom,curDomLevel);",
                        "",
                        "  result = dom;",
                        "}",
                        "",
                        "function SpawnBossKeller() {",
                        "  dword planet = IdToPlanet(planetId);",
                        "",
                        "  dom = BuyTranclucator(planet);",
                        "  TransferShip(dom, IdToShip(DBId));",
                        "  TranclucatorData(dom,'Proprietor',IdToShip(proprietorId));",
                        "",
                        "  ShipJoin(bossK, dom);",
                        "  bossId = Id(dom);",
                        "",
                        "  ShipAddCustomShipInfo(dom, 'ZelDomiks_DomInfo', 'NoShow');",
                        "  ShipAddCustomShipInfo(dom, 'ZelDomiks_DomRelations', 'NoShow');",
                        "",
                        "  GiveBossAllEq(dom,curDomLevel);",
                        "",
                        "  result = dom;",
                        "}",
                        "",
                        "function SpawnBossTerron() {",
                        "  dword planet = IdToPlanet(planetId);",
                        "",
                        "  dom = BuyTranclucator(planet);",
                        "  TransferShip(dom, IdToShip(DBId));",
                        "  TranclucatorData(dom,'Proprietor',IdToShip(proprietorId));",
                        "",
                        "  ShipJoin(bossT, dom);",
                        "  bossId = Id(dom);",
                        "",
                        "  ShipAddCustomShipInfo(dom, 'ZelDomiks_DomInfo', 'NoShow');",
                        "  ShipAddCustomShipInfo(dom, 'ZelDomiks_DomRelations', 'NoShow');",
                        "",
                        "  GiveBossAllEq(dom,curDomLevel);",
                        "",
                        "  result = dom;",
                        "}",
                        "",
                        "function SpawnTerronHelp(type) {",
                        "  dom = SpawnDom(type, 1);",
                        "  dword ourBossShip = IdToShip(bossId);",
                        "  TransferShip(dom, NearCivilPlanet(ourBossShip));",
                        "  OrderTakeOff(dom);",
                        "  ShipSetCoords(dom, CoordX(ourBossShip), CoordY(ourBossShip));",
                        "  ugol = 0.01 * Rnd(0, 200);",
                        "  ShipAngle(dom, Rnd(1, 360));",
                        "  radius = Rnd(150, 400);",
                        "  x = round(cos(ugol * pi) * radius + CoordX(ourBossShip));",
                        "  y = round(sin(ugol * pi) * radius + CoordY(ourBossShip));",
                        "  OrderMove(dom, x, y);",
                        "  ShipOrder(dom, 5);",
                        "  result = dom;",
                        "}",
                        "",
                        "function SpawnTransportDom() {",
                        "  dword planet = IdToPlanet(planetId);",
                        "  dom = BuyTransport(planet,0,50+20*difficultOfMoney);",
                        "  NoTargetToShip(dom,2);",
                        "  NoDropToShip(dom,1);",
                        "",
                        "  ShipJoin(freeGroup, dom);",
                        "  ShipType(dom,'Nisper3');",
                        "  SetName(dom,CT('ShipName.Kling.'+Rnd(1,123))+' -'+Rnd(1,100)+'-');",
                        "  ShipFace(dom,4);",
                        "  ShipCustomFaction(dom,'SubFaction.Nisper');",
                        "  ShipTechLevelKnowledge(dom,8);",
                        "  ItemOwner(ShipItems(dom, 0),5);",
                        "  SpecialToEquipment(FindBonusByNameInCfg('ZelDomiks_Nisper3'),ShipItems(dom, 0));",
                        "  HullSeries(ShipItems(dom, 0),-1);",
                        "  ItemSize(ShipItems(dom, 0),500+Rnd(50,150));",
                        "  HullHP(dom, ItemSize(ShipItems(dom, 0)));",
                        "  for(i=0;i<5;i=i+1)",
                        "    ShipRefit(dom);",
                        "  for (i = ShipItems(dom) - 1; i >= 0; i = i - 1){",
                        "    dword ourItemShip=ShipItems(dom, i);",
                        "    ItemOwner(ourItemShip,Kling);",
                        "    EqCustomFaction(ourItemShip,'SubFaction.Nisper');",
                        "  }",
                        "  Chameleon(dom);",
                        "",
                        "  dword ourBossShip = IdToShip(bossId);",
                        "  TransferShip(dom, NearCivilPlanet(ourBossShip));",
                        "  OrderTakeOff(dom);",
                        "  ShipSetCoords(dom, CoordX(ourBossShip), CoordY(ourBossShip));",
                        "  ugol = 0.01 * Rnd(0, 200);",
                        "  ShipAngle(dom, Rnd(1, 360));",
                        "  radius = Rnd(150, 400);",
                        "  x = round(cos(ugol * pi) * radius + CoordX(ourBossShip));",
                        "  y = round(sin(ugol * pi) * radius + CoordY(ourBossShip));",
                        "  OrderMove(dom, x, y);",
                        "  ShipOrder(dom, 5);",
                        "",
                        "  result = dom;",
                        "}",
                        "function GiveAttackStar(){",
                        "  targetStar=-1;",
                        "  power=GalaxyStars();",
                        "  star=PlanetToStar(IdToPlanet(planetId));",
                        "  pirateSector=StarToCon(PlanetToStar(PlanetPirateClan()));",
                        "  starBlazer=star;",
                        "  starTerron=star;",
                        "  if(Blazer())",
                        "    starBlazer=ShipStar(Blazer());",
                        "  if(Terron())",
                        "    starTerron=ShipStar(Terron());",
                        "  for(i=1;targetStar==-1&&i<power;i=i+1){",
                        "    potentialStar=StarNearbyStars(star,i);",
                        "    if(StarOwner(potentialStar)!=0&&StarToCon(potentialStar)!=pirateSector&&potentialStar!=starBlazer&&potentialStar!=starTerron)",
                        "      targetStar=potentialStar;",
                        "  }",
                        "  result=targetStar;",
                        "}",
                        "",
                        "function GiveStartStar() {",
                        "  minCount = 10000;",
                        "  minId = 0;",
                        "  power=GalaxyStars();",
                        "  if (bonusGlobal != 1) {",
                        "    for (i = 0; i < power; i = i + 1) {",
                        "      if (StarOwner(GalaxyStar(i)) == 0 && minCount > CountIn(domiks, GalaxyStar(i))) {",
                        "        minCount = CountIn(domiks, GalaxyStar(i));",
                        "        minId = i;",
                        "      }",
                        "    }",
                        "  } else {",
                        "    for (i = 0; i < power; i = i + 1) {",
                        "      if (StarOwner(GalaxyStar(i)) == 0 && minCount > CountIn(domiks, GalaxyStar(i))) {",
                        "        for(j=1;StarNearbyStarsDist(GalaxyStar(i),j)<=30;j=j+1){",
                        "          if(StarOwner(StarNearbyStars(GalaxyStar(i),j))!=0){",
                        "            minCount = CountIn(domiks, GalaxyStar(i));",
                        "            minId = i;",
                        "          }",
                        "        }",
                        "      }",
                        "    }",
                        "  }",
                        "  result = minId;",
                        "}",
                        "",
                        "function GiveBertorStar() {",
                        "  minCount = 0;",
                        "  minId = 100000;",
                        "  power=GalaxyStars();",
                        "  unknown allPossibleStars = newarray(100);",
                        "  for (i = 0; i < power; i = i + 1) {",
                        "    if (StarOwner(GalaxyStar(i)) == 0&&BertorStars[i]==0) {",
                        "      allPossibleStars[minCount]=i;",
                        "      minCount=minCount+1;",
                        "    }",
                        "  }",
                        "  minId=allPossibleStars[Rnd(0,minCount-1)];",
                        "  BertorStars[minId]=1;",
                        "  result = minId;",
                        "}",
                        "",
                        "function GiveDomAllEq(type, ship, level) {",
                        "  ShipType(ship,'Nisper'+type);",
                        "  SetName(ship,CT('ShipName.Kling.'+Rnd(1,123))+' -'+Rnd(1,100)+'-');",
                        "  ShipFace(ship,4);",
                        "  ShipCustomFaction(ship,'SubFaction.Nisper');",
                        "  ShipTechLevelKnowledge(ship,8);",
                        "  for (i = ShipItems(ship) - 1; i > 0; i = i - 1)",
                        "    FreeItem(GetItemFromShip(ship, i));",
                        "  SpecialToEquipment(FindBonusByNameInCfg('ZelDomiks_Nisper'+type),ShipItems(ship, 0));",
                        "  HullSeries(ShipItems(ship, 0),-1);",
                        "  ItemSize(ShipItems(ship, 0),Rnd(HullSizeMin[type],HullSizeMax[type]));",
                        "  Chameleon(ship);",
                        "  GiveDomEq(t_Hull, 1, level, ship);",
                        "  GiveDomEq(t_Engine, Rnd(15*(1+0.3*type), 23*(1+0.7*type)), level, ship);",
                        "  GiveDomEq(t_FuelTanks, Rnd(15*(1+0.3*type), 23*(1+0.7*type)), level, ship);",
                        "  GiveDomEq(t_Radar, Rnd(10*(1+0.3*type), 15*(1+0.7*type)), level, ship);",
                        "  GiveDomEq(t_Scaner, Rnd(10*(1+0.3*type), 15*(1+0.7*type)), level, ship);",
                        "  int numOfWeapons=GiveNumWeapons(level);",
                        "  if(type==0&&numOfWeapons>1&&Rnd(1,20)>level)",
                        "    numOfWeapons=numOfWeapons-1;",
                        "  for(i=0;i<numOfWeapons;i=i+1){",
                        "    if(type==0)",
                        "      GiveWeaponKlig(level,ship);",
                        "    else if(type==1)",
                        "      GiveWeaponShtip(level,ship);",
                        "    else if(type==2)",
                        "      GiveWeaponMenok(level,ship);",
                        "    else if(type==3)",
                        "      GiveWeaponSmersh(level,ship);",
                        "    else if(type==4)",
                        "      GiveWeaponUrgant(level,ship);",
                        "    else if(type==5)",
                        "      GiveWeaponEkventor(level,ship);",
                        "    else if(type==6)",
                        "      GiveWeaponBertor(level,ship);",
                        "  }",
                        "  chanceDom=(((bonusDomiks==2)*(2*level))+((type>0)*15)+((type==6)*15)+(5*level));",
                        "  if(Rnd(1,100)<chanceDom)",
                        "    GiveDomEq(t_CargoHook, Rnd(15*(1+0.3*type), 23*(1+0.7*type)), level, ship);",
                        "  if(Rnd(1,100)<chanceDom)",
                        "    GiveDomEq(t_DefGenerator, Rnd(15*(1+0.3*type), 23*(1+0.7*type)), level, ship);",
                        "  if(Rnd(1,100)<chanceDom)",
                        "    GiveDomEq(t_RepairRobot, Rnd(15*(1+0.3*type), 23*(1+0.7*type)), level, ship);",
                        "  unknown itemsForArts=newarray(5);",
                        "  for(i=0;i<5;i=i+1)",
                        "    itemsForArts[i]=0;",
                        "  for (i = ShipItems(ship) - 1; i >= 0; i = i - 1){",
                        "    dword ourItemShip=ShipItems(ship, i);",
                        "    ItemOwner(ourItemShip,Kling);",
                        "    EqCustomFaction(ourItemShip,'SubFaction.Nisper');",
                        "    if(ItemType(ourItemShip)==t_RepairRobot)",
                        "      itemsForArts[0]=1;",
                        "    else if(ItemType(ourItemShip)==t_DefGenerator)",
                        "      itemsForArts[1]=1;",
                        "    else if(ItemType(ourItemShip)==t_Weapon1||ItemType(ourItemShip)==t_Weapon3||ItemType(ourItemShip)==t_Weapon5||ItemType(ourItemShip)==t_Weapon6||ItemType(ourItemShip)==t_Weapon8||ItemType(ourItemShip)==t_Weapon10||ItemType(ourItemShip)==t_Weapon11||ItemType(ourItemShip)==t_Weapon12||ItemType(ourItemShip)==t_Weapon14)",
                        "      itemsForArts[2]=1;",
                        "    else if(ItemType(ourItemShip)==t_Weapon2||ItemType(ourItemShip)==t_Weapon7||ItemType(ourItemShip)==t_Weapon9||ItemType(ourItemShip)==t_Weapon13)",
                        "      itemsForArts[3]=1;",
                        "    else if(ItemType(ourItemShip)==t_Weapon4||ItemType(ourItemShip)==t_Weapon15)",
                        "      itemsForArts[4]=1;",
                        "    dword typeOfItem = ItemType(ourItemShip);",
                        "    if (typeOfItem == t_FuelTanks)",
                        "      UpgradeItem(ourItemShip,GivePowerKlig(level));",
                        "    else if (typeOfItem == t_Engine)",
                        "      UpgradeItem(ourItemShip,GivePowerKlig(level));",
                        "    else if (typeOfItem == t_Radar)",
                        "      UpgradeItem(ourItemShip,GivePowerKlig(level));",
                        "    else if (typeOfItem == t_Scaner)",
                        "      UpgradeItem(ourItemShip,GivePowerKlig(level));",
                        "    else if (typeOfItem == t_CargoHook)",
                        "      UpgradeItem(ourItemShip,GivePowerKlig(level));",
                        "    else if (bonusDomiks == 2 && (typeOfItem == t_RepairRobot || typeOfItem == t_DefGenerator || typeOfItem == t_Hull))",
                        "      UpgradeItem(ourItemShip,level);",
                        "    else if (bonusDomiks == 1 && typeOfItem >= t_Weapon1 && typeOfItem <= t_CustomWeapon)",
                        "      UpgradeItem(ourItemShip,level);",
                        "  }",
                        "  for (i = 0; i < ShipArts(ship);){",
                        "    dword ourArtShip=ShipArts(ship, i);",
                        "    ItemOwner(ourArtShip,Kling);",
                        "    EqCustomFaction(ourArtShip,'SubFaction.Nisper');",
                        "    if(i > 3)",
                        "      FreeItem(GetArtFromShip(ship, i));",
                        "    else if(ItemType(ourArtShip)==t_ArtefactDroid&&!itemsForArts[0])",
                        "      FreeItem(GetArtFromShip(ship, i));",
                        "    else if(ItemType(ourArtShip)==t_ArtefactDef&&!itemsForArts[1])",
                        "      FreeItem(GetArtFromShip(ship, i));",
                        "    else if(ItemType(ourArtShip)==t_ArtEnergyPulse&&!itemsForArts[2])",
                        "      FreeItem(GetArtFromShip(ship, i));",
                        "    else if((ItemType(ourArtShip)==t_ArtSplinter||ItemType(ourArtShip)==t_ArtDecelerate)&&!itemsForArts[3])",
                        "      FreeItem(GetArtFromShip(ship, i));",
                        "    else if(ItemType(ourArtShip)==t_ArtFastRacks&&!itemsForArts[4])",
                        "      FreeItem(GetArtFromShip(ship, i));",
                        "    else if(ItemType(ourArtShip)==t_ArtDefToEnergy&&!itemsForArts[1]&&!itemsForArts[2])",
                        "      FreeItem(GetArtFromShip(ship, i));",
                        "    else if(ItemType(ourArtShip)==t_ArtWeaponToSpeed&&numOfWeapons==5)",
                        "      FreeItem(GetArtFromShip(ship, i));",
                        "    if(ourArtShip==ShipArts(ship, i))",
                        "      i=i+1;",
                        "  }",
                        "  if(bonusGlobal==1)",
                        "    GiveAcrin(level, ship, type);",
                        "  DomSkills(level, ship);",
                        "  if(BlockExist('Script.Mod_ShuDomiks')) ShuModSemerenka(ship,level,type,itemsForArts);",
                        "  if(BlockExist('Script.Mod_EvoArmada')) EvoArmada(ship,type);",
                        "  GiveNeedSizeShip(ship);",
                        "  ArrangeItems(ship);",
                        "}",
                        "",
                        "function GiveBossAllEq(ship, level) {",
                        "  ShipType(ship,'NisperBoss');",
                        "  SetName(ship,'Ниспер');",
                        "  ShipCustomFaction(ship,'SubFaction.Nisper');",
                        "  ShipTechLevelKnowledge(ship,8);",
                        "  SpecialToEquipment(FindBonusByNameInCfg('ZelDomiks_Nisper5'),ShipItems(ship, 0));",
                        "  if(bonusAdd==0){",
                        "    ShipFace(ship,bonusAdd);",
                        "    Chameleon(ship, 'Ruins.NisperB');",
                        "  }",
                        "  else if(bonusAdd==1){",
                        "    ShipFace(ship,bonusAdd);",
                        "    Chameleon(ship, 'Ruins.NisperBB');",
                        "  }",
                        "  else if(bonusAdd==2){",
                        "    ShipFace(ship,bonusAdd);",
                        "    Chameleon(ship, 'Ruins.NisperBK');",
                        "  }",
                        "  else{",
                        "    ShipFace(ship,bonusAdd);",
                        "    Chameleon(ship, 'Ruins.NisperBT');",
                        "  }",
                        "  HullSeries(ShipItems(ship, 0),-1);",
                        "  RenovationBoss(ship,level);",
                        "  for(i=0;i<6;i=i+1)",
                        "    ShipSkill(ship,i,6);",
                        "}",
                        "",
                        "function RenovationBoss(ship, level){",
                        "  dword bossHull=ShipItems(ship, 0);",
                        "  for (i = ShipItems(ship) - 1; i > 0; i = i - 1)",
                        "    FreeItem(GetItemFromShip(ship, i));",
                        "  SpecialToEquipment(FindBonusByNameInCfg('ZelDomiks_Nisper5'),bossHull);",
                        "  ItemSize(bossHull,2100+((15-GalaxyDiffLevels()/50)*(level+2)*40));",
                        "  if(BlockExist('Script.Mod_EvoArmada')){",
                        "    ShipSpecialBonuses(ship, bonAttacks, 6);",
                        "    ShipAddCustomShipInfo(ship, 'EvoArmada_CapitalShipInfos', 'NoShow', 6);",
                        "    ItemSize(bossHull, round(ItemSize(bossHull) * (1.0 + (0.5 * level))));",
                        "    power = (2 * level) + 10;",
                        "    ItemExtraSpecialsAddByType(bossHull, FindBonusByNameInCfg('EvoArmada_bonWEnergy'), power);",
                        "    ItemExtraSpecialsAddByType(bossHull, FindBonusByNameInCfg('EvoArmada_bonWSplinter'), power);",
                        "    ItemExtraSpecialsAddByType(bossHull, FindBonusByNameInCfg('EvoArmada_bonWMissile'), power);",
                        "    SetEquipmentStats(bossHull, GetEquipmentStats(bossHull, 0) + (level + 5), 0);",
                        "  }",
                        "  HullHP(ship, ItemSize(bossHull));",
                        "  GiveDomEq(t_Hull, 1, level, ship);",
                        "  GiveDomEq(t_Engine, Rnd(130, 200), level, ship);",
                        "  GiveDomEq(t_FuelTanks, Rnd(130, 200), level, ship);",
                        "  GiveDomEq(t_Radar, Rnd(100, 150), level, ship);",
                        "  GiveDomEq(t_Scaner, Rnd(100, 150), level, ship);",
                        "  GiveDomEq(t_CargoHook, Rnd(130, 200), level, ship);",
                        "  GiveDomEq(t_DefGenerator, Rnd(150, 250), level, ship);",
                        "  GiveDomEq(t_RepairRobot, Rnd(150, 250), level, ship);",
                        "  for(i=0;i<5;i=i+1)",
                        "    GiveWeaponBoss(level,ship);",
                        "  for (i = ShipItems(ship) - 1; i >= 0; i = i - 1){",
                        "    dword ourItemShip=ShipItems(ship, i);",
                        "    ItemOwner(ourItemShip,Kling);",
                        "    EqCustomFaction(ourItemShip,'SubFaction.Nisper');",
                        "    if(Rnd(1,15)<=level&&ItemLevel(ourItemShip)<8)",
                        "      ItemLevel(ourItemShip,ItemLevel(ourItemShip)+1);",
                        "    UpgradeItem(ourItemShip,level);",
                        "    UpgradeItem(ourItemShip,GivePowerKlig(level));",
                        "    if(BlockExist('Script.Mod_ShuDomiks')) UpgradeItem(ourItemShip,level);",
                        "  }",
                        "  needRen=0;",
                        "  GiveNeedSizeShip(ship);",
                        "  ArrangeItems(ship);",
                        "}",
                        "",
                        "function GiveABWeapon(ship, type, countWeapons) {",
                        "  for (i = ShipItems(ship) - 1; i > 0; i = i - 1)",
                        "    FreeItem(GetItemFromShip(ship, i));",
                        "  for (j = 0; j < countWeapons; j = j + 1) {",
                        "    if (type == 0)",
                        "      GiveWeaponKlig(11, ship);",
                        "    else if (type == 1)",
                        "      GiveWeaponShtip(11, ship);",
                        "    else if (type == 2)",
                        "      GiveWeaponMenok(11, ship);",
                        "    else if (type == 3)",
                        "      GiveWeaponSmersh(11, ship);",
                        "    else if (type == 4)",
                        "      GiveWeaponUrgant(11, ship);",
                        "    else if (type == 5)",
                        "      GiveWeaponEkventor(11, ship);",
                        "    else if (type == 6)",
                        "      GiveWeaponBertor(11, ship);",
                        "  }",
                        "  ArrangeItems(ship);",
                        "}",
                        "",
                        "function GiveNeedSizeShip(ship){",
                        "  ShipCalcParam(ship);",
                        "  int space = ShipFreeSpace(ship);",
                        "  dword hull = ShipItems(ship, 0);",
                        "  if(space < 0)",
                        "  {",
                        "    ItemSize(hull, ItemSize(hull) + abs(space) + Rnd(1, 3));",
                        "    ShipCalcParam(ship);",
                        "  }",
                        "  HullHP(hull, ItemSize(hull));",
                        "}",
                        "",
                        "function StartAttackSystem(attackSystem){",
                        "  for (i = 0; i < GroupCount(domiks); i = i + 1) {",
                        "    dom = GroupShip(domiks, i);",
                        "    if (Rnd(1, 100) < (40 + (bonusGlobal == 1) * 3) && ShipInNormalSpace(dom) && GetData(1, dom) == 10000) {",
                        "      SetData(Id(attackSystem) - 1, 1, dom);",
                        "    }",
                        "  }",
                        "  for (i = 0; i < GroupCount(domiksBes); i = i + 1) {",
                        "    dom = GroupShip(domiksBes, i);",
                        "    if (Rnd(1, 100) < (40 + (bonusGlobal == 1) * 3) && ShipInNormalSpace(dom) && GetData(1, dom) == 10000) {",
                        "      SetData(Id(attackSystem) - 1, 1, dom);",
                        "    }",
                        "  }",
                        "  bossShip=IdToShip(bossId);",
                        "  if (bossShip && bonusBoss == 1 && Rnd(1, 4) == 1) {",
                        "    SetData(Id(attackSystem) - 1, 1, bossShip);",
                        "    SetData(0, 2, bossShip);",
                        "  }",
                        "}",
                        "",
                        "function UpgradeItem(item,level){",
                        "  power=GivePowerUpgrade(level);",
                        "  if(power>-1)",
                        "    ItemImprovement(item,power,0);",
                        "}",
                        "function ShuModSemerenka(ship, level, type, a) {",
                        "  int countOfAllBonusInGalaxy = BonusCount();",
                        "  for (i = ShipItems(ship) - 1; i >= 0; i = i - 1) {",
                        "    dword ourItemShip = ShipItems(ship, i);",
                        "",
                        "    power = GivePowerAcrinAndMM(level);",
                        "    str ourAcrin;",
                        "    if (power > 0 && i > 0) {",
                        "      power = power + (Rnd(1, 11) <= level);",
                        "      str nameOfItem = Name(ourItemShip);",
                        "      int typeOfItem = ItemType(ourItemShip);",
                        "      if (typeOfItem < t_Weapon1) {",
                        "        unknown arrayOfAcrins = newarray(1);",
                        "        arrayOfAcrins[0] = 'ZelDomiks_NisperAcrinAll';",
                        "        if (a[0] && a[1])",
                        "          ArrayAdd(arrayOfAcrins, 'ZelDomiks_NisperAcrinDef');",
                        "        if (a[0])",
                        "          ArrayAdd(arrayOfAcrins, 'ZelDomiks_NisperAcrinAtt');",
                        "        if (a[0] && type <= 3)",
                        "          ArrayAdd(arrayOfAcrins, 'ZelDomiks_NisperAcrinSmall');",
                        "        if (a[1] && type >= 3)",
                        "          ArrayAdd(arrayOfAcrins, 'ZelDomiks_NisperAcrinBig');",
                        "        if (a[2] || a[3])",
                        "          ArrayAdd(arrayOfAcrins, 'ZelDomiks_NisperAcrinDam');",
                        "        ourAcrin = arrayOfAcrins[Rnd(0, ArrayDim(arrayOfAcrins) - 1)] + power;",
                        "        if(BlockExist('Cat_Balance')) ourAcrin=ourAcrin+'_Cat_Balance';",
                        "        SpecialToEquipment(FindBonusByNameInCfg(ourAcrin), ourItemShip);",
                        "        if (power == 1)",
                        "          nameOfItem = nameOfItem + ' <color=255,153,0>Ниспера I</color>';",
                        "        else if (power == 2)",
                        "          nameOfItem = nameOfItem + ' <color=255,153,0>Ниспера II</color>';",
                        "        else if (power == 3)",
                        "          nameOfItem = nameOfItem + ' <color=255,153,0>Ниспера III</color>';",
                        "        else if (power == 4)",
                        "          nameOfItem = nameOfItem + ' <color=255,153,0>Ниспера IV</color>';",
                        "      } else {",
                        "        if (typeOfItem != t_Weapon4 && typeOfItem != t_Weapon15) {",
                        "          random = Rnd(1, 6);",
                        "          ourAcrin = 'ZelDomiks_NisperAcrin' + random + 'Weap' + power;",
                        "          SpecialToEquipment(FindBonusByNameInCfg(ourAcrin), ourItemShip);",
                        "        } else {",
                        "          random = Rnd(3, 7);",
                        "          ourAcrin = 'ZelDomiks_NisperAcrin' + random + 'Weap' + power;",
                        "          SpecialToEquipment(FindBonusByNameInCfg(ourAcrin), ourItemShip);",
                        "        }",
                        "      }",
                        "      SetName(ourItemShip, nameOfItem);",
                        "    }",
                        "",
                        "    power = GivePowerAcrinAndMM(level);",
                        "    if (power == 1) {",
                        "      random = Rnd(0, countOfAllBonusInGalaxy - 1);",
                        "      while (BonusIsSpecial(random) || BonusPriority(random) < 70 || !MayAddBonusToEq(random, ourItemShip))",
                        "        random = Rnd(0, countOfAllBonusInGalaxy - 1);",
                        "      ModuleToEquipment(random, ourItemShip);",
                        "    } else if (power == 2) {",
                        "      random = Rnd(0, countOfAllBonusInGalaxy - 1);",
                        "      while (BonusIsSpecial(random) || BonusPriority(random) > 69 || BonusPriority(random) < 31 || !MayAddBonusToEq(random, ourItemShip))",
                        "        random = Rnd(0, countOfAllBonusInGalaxy - 1);",
                        "      ModuleToEquipment(random, ourItemShip);",
                        "    } else if (power == 3) {",
                        "      random = Rnd(0, countOfAllBonusInGalaxy - 1);",
                        "      while (BonusIsSpecial(random) || BonusPriority(random) > 30 || !MayAddBonusToEq(random, ourItemShip))",
                        "        random = Rnd(0, countOfAllBonusInGalaxy - 1);",
                        "      ModuleToEquipment(random, ourItemShip);",
                        "    }",
                        "  }",
                        "",
                        "  dword hullOurDomik = ShipItems(ship, 0);",
                        "  power = ItemLevel(hullOurDomik);",
                        "  if (type == 0) {",
                        "    random = (10 * level) + (10 * PortionInDiapason(power, 1, 8, 1, 10));",
                        "    ItemExtraSpecialsAddByType(hullOurDomik, FindBonusByNameInCfg('ShuDomiks_bonSpeed'), random);",
                        "    ShipSkill(ship, 'Mobility', ShipSkill(ship, 'Mobility') + 4);",
                        "  } else if (type == 1) {",
                        "    random = (10 * level) + (10 * PortionInDiapason(power, 1, 8, 1, 10));",
                        "    ItemExtraSpecialsAddByType(hullOurDomik, FindBonusByNameInCfg('ShuDomiks_bonSpeed'), random);",
                        "    ShipSkill(ship, 'Mobility', ShipSkill(ship, 'Mobility') + 3);",
                        "  } else if (type == 2) {",
                        "    random = level + PortionInDiapason(power, 1, 8, 1, 10);",
                        "    ItemExtraSpecialsAddByType(hullOurDomik, FindBonusByNameInCfg('ShuDomiks_bonWEnergy'), random);",
                        "    ItemExtraSpecialsAddByType(hullOurDomik, FindBonusByNameInCfg('ShuDomiks_bonWMissile'), random);",
                        "    ShipSkill(ship, 'Accuracy', ShipSkill(ship, 'Accuracy') + 1);",
                        "    ShipSkill(ship, 'Mobility', ShipSkill(ship, 'Mobility') + 2);",
                        "  } else if (type == 3) {",
                        "    random = level + PortionInDiapason(power, 1, 8, 1, 10);",
                        "    ItemExtraSpecialsAddByType(hullOurDomik, FindBonusByNameInCfg('ShuDomiks_bonWMissile'), random);",
                        "    random = (5 * level) + (5 * PortionInDiapason(power, 1, 8, 1, 10));",
                        "    ItemExtraSpecialsAddByType(hullOurDomik, FindBonusByNameInCfg('ShuDomiks_bonWRadius'), random);",
                        "    ShipSkill(ship, 'Accuracy', ShipSkill(ship, 'Accuracy') + 2);",
                        "  } else if (type == 4) {",
                        "    random = round((1.8 * level / 2) + (1.8 * PortionInDiapason(power, 1, 8, 1, 10) / 2));",
                        "    ItemExtraSpecialsAddByType(hullOurDomik, FindBonusByNameInCfg('ShuDomiks_bonWSplinter'), random);",
                        "    random = round((1.5 * level / 2) + (1.5 * PortionInDiapason(power, 1, 8, 1, 10) / 2));",
                        "    ItemExtraSpecialsAddByType(hullOurDomik, FindBonusByNameInCfg('ShuDomiks_bonDef'), random);",
                        "  } else if (type == 5) {",
                        "    random = round((1.8 * level / 2) + (1.8 * PortionInDiapason(power, 1, 8, 1, 10) / 2));",
                        "    ItemExtraSpecialsAddByType(hullOurDomik, FindBonusByNameInCfg('ShuDomiks_bonWEnergy'), random);",
                        "    random = round((0.8 * level / 2) + (0.8 * PortionInDiapason(power, 1, 8, 1, 10) / 2));",
                        "    ItemExtraSpecialsAddByType(hullOurDomik, FindBonusByNameInCfg('ShuDomiks_bonHull'), random);",
                        "  } else if (type == 6) {",
                        "    random = round((1.2 * level / 2) + (1.2 * PortionInDiapason(power, 1, 8, 1, 10) / 2));",
                        "    ItemExtraSpecialsAddByType(hullOurDomik, FindBonusByNameInCfg('ShuDomiks_bonHull'), random);",
                        "  }",
                        "}",
                        "",
                        "function EvoArmada(ship,type){",
                        "  if(type==4){",
                        "    ShipSpecialBonuses(ship, bonAttacks, 1);",
                        "    ShipAddCustomShipInfo(ship, 'EvoArmada_CapitalShipInfos', 'NoShow', 1);",
                        "  }",
                        "  else if(type==5){",
                        "    ShipSpecialBonuses(ship, bonAttacks, 3);",
                        "    ShipAddCustomShipInfo(ship, 'EvoArmada_CapitalShipInfos', 'NoShow', 3);",
                        "  }",
                        "  else if(type==6){",
                        "    ShipSpecialBonuses(ship, bonAttacks, 4);",
                        "    ShipAddCustomShipInfo(ship, 'EvoArmada_CapitalShipInfos', 'NoShow', 4);",
                        "  }",
                        "}",
                        "function GiveMassWeapon(eq,power){",
                        "  int massOfWeapon;",
                        "  if(eq==t_Weapon1){",
                        "    massOfWeapon=(1.0+0.1*power)*14;",
                        "    massOfWeapon=Rnd(massOfWeapon,1.3*massOfWeapon);",
                        "    result=massOfWeapon;",
                        "  }",
                        "  else if(eq==t_Weapon2){",
                        "    massOfWeapon=(1.0+0.1*power)*18;",
                        "    massOfWeapon=Rnd(massOfWeapon,1.3*massOfWeapon);",
                        "    result=massOfWeapon;",
                        "  }",
                        "  else if(eq==t_Weapon3){",
                        "    massOfWeapon=(1.0+0.1*power)*23;",
                        "    massOfWeapon=Rnd(massOfWeapon,1.3*massOfWeapon);",
                        "    result=massOfWeapon;",
                        "  }",
                        "  else if(eq==t_Weapon4){",
                        "    massOfWeapon=(1.0+0.1*power)*9;",
                        "    massOfWeapon=Rnd(massOfWeapon,1.3*massOfWeapon);",
                        "    result=massOfWeapon;",
                        "  }",
                        "  else if(eq==t_Weapon5){",
                        "    massOfWeapon=(1.0+0.1*power)*14;",
                        "    massOfWeapon=Rnd(massOfWeapon,1.3*massOfWeapon);",
                        "    result=massOfWeapon;",
                        "  }",
                        "  else if(eq==t_Weapon6){",
                        "    massOfWeapon=(1.0+0.1*power)*18;",
                        "    massOfWeapon=Rnd(massOfWeapon,1.3*massOfWeapon);",
                        "    result=massOfWeapon;",
                        "  }",
                        "  else if(eq==t_Weapon7){",
                        "    massOfWeapon=(1.0+0.1*power)*27;",
                        "    massOfWeapon=Rnd(massOfWeapon,1.3*massOfWeapon);",
                        "    result=massOfWeapon;",
                        "  }",
                        "  else if(eq==t_Weapon8){",
                        "    massOfWeapon=(1.0+0.1*power)*14;",
                        "    massOfWeapon=Rnd(massOfWeapon,1.3*massOfWeapon);",
                        "    result=massOfWeapon;",
                        "  }",
                        "  else if(eq==t_Weapon9){",
                        "    massOfWeapon=(1.0+0.1*power)*32;",
                        "    massOfWeapon=Rnd(massOfWeapon,1.3*massOfWeapon);",
                        "    result=massOfWeapon;",
                        "  }",
                        "  else if(eq==t_Weapon10){",
                        "    massOfWeapon=(1.0+0.1*power)*36;",
                        "    massOfWeapon=Rnd(massOfWeapon,1.3*massOfWeapon);",
                        "    result=massOfWeapon;",
                        "  }",
                        "  else if(eq==t_Weapon11){",
                        "    massOfWeapon=(1.0+0.1*power)*41;",
                        "    massOfWeapon=Rnd(massOfWeapon,1.3*massOfWeapon);",
                        "    result=massOfWeapon;",
                        "  }",
                        "  else if(eq==t_Weapon12){",
                        "    massOfWeapon=(1.0+0.1*power)*45;",
                        "    massOfWeapon=Rnd(massOfWeapon,1.3*massOfWeapon);",
                        "    result=massOfWeapon;",
                        "  }",
                        "  else if(eq==t_Weapon13){",
                        "    massOfWeapon=(1.0+0.1*power)*108;",
                        "    massOfWeapon=Rnd(massOfWeapon,1.3*massOfWeapon);",
                        "    result=massOfWeapon;",
                        "  }",
                        "  else if(eq==t_Weapon14){",
                        "    massOfWeapon=(1.0+0.1*power)*148;",
                        "    massOfWeapon=Rnd(massOfWeapon,1.3*massOfWeapon);",
                        "    result=massOfWeapon;",
                        "  }",
                        "  else if(eq==t_Weapon15){",
                        "    massOfWeapon=(1.0+0.1*power)*27;",
                        "    massOfWeapon=Rnd(massOfWeapon,1.3*massOfWeapon);",
                        "    result=massOfWeapon;",
                        "  }",
                        "}",
                        "",
                        "function GiveWeaponBoss(level, ship) {",
                        "  str eq;",
                        "  eq=choice8(",
                        "    0.15, t_Weapon4,",
                        "    0.05, t_Weapon9,",
                        "    0.05, t_Weapon10,",
                        "    0.05, t_Weapon11,",
                        "    0.10, t_Weapon12,",
                        "    0.20, t_Weapon13,",
                        "    0.20, t_Weapon14,",
                        "    0.20, t_Weapon15",
                        "  );",
                        "  power=Rnd(max(((1.0*level-2)/11)*8,1),min(((1.0*level+2)/11)*8,8));",
                        "  AddItemToShip(ship, CreateEquipment(eq, GiveMassWeapon(eq,30), power, 5));",
                        "}",
                        "",
                        "function GiveWeaponKlig(level, ship) {",
                        "  str eq;",
                        "  if(level==1){",
                        "    eq=choice4(",
                        "      0.15, t_Weapon1,",
                        "      0.50, t_Weapon3,",
                        "      0.25, t_Weapon5,",
                        "      0.10, t_Weapon8",
                        "    );",
                        "  }",
                        "  else if(level==2){",
                        "    eq=choice4(",
                        "      0.10, t_Weapon1,",
                        "      0.50, t_Weapon3,",
                        "      0.30, t_Weapon5,",
                        "      0.10, t_Weapon8",
                        "    );",
                        "  }",
                        "  else if(level==3){",
                        "    eq=choice4(",
