                    "Pos.y": 1440,
                    "Type": "TDialogAnswer",
                    "Parent": -1,
                    "#": 531,
                    "Msg": "Все равно. Это так классно... Всегда мечтал иметь своих ручных клигов... Спасибо большое!",
                    "AMsg.Num": "165",
                    "_orig_danswer": "DAnswer('restart~'+CT(\"Script.Mod_ZelDomiks.358\"))"
