                    "_orig_danswer": "DAnswer(CT(\"Script.Mod_ZelDomiks.173\"))"
                },
                {
                    "Name": "",
                    "Pos.x": 0,
                    "Pos.y": 1290,
                    "Type": "TDialogAnswer",
                    "Parent": -1,
                    "#": 441,
