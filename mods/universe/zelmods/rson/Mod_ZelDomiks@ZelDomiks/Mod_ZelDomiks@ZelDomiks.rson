                    "_orig_danswer": "DAnswer(CT(\"Script.Mod_ZelDomiks.447\"))"
                },
                {
                    "Name": "",
                    "Pos.x": 120,
                    "Pos.y": 1190,
                    "Type": "TDialogAnswer",
                    "Parent": -1,
                    "#": 382,
                    "Msg": "А какова твоя в этом роль?",
                    "AMsg.Num": "16",
                    "_orig_danswer": "DAnswer(CT(\"Script.Mod_ZelDomiks.448\"))"
                },
                {
                    "Name": "",
                    "Pos.x": 240,
                    "Pos.y": 1190,
                    "Type": "TDialogAnswer",
                    "Parent": -1,
                    "#": 383,
