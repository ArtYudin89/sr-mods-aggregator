                        "          OrderLock(Player(),0);",
                        "          StartAB('ABMap.map_14');",
                        "          Ether(4,'ZelDomiksQuest','Вы успешно уничтожили всех доминаторов Келлера и остались живы. Задание выполнено, осталось только поговорить с Ниспером.');",
                        "        }",
                        "      }",
                        "    }",
                        "  }",
                        "}",
                        "if(domLevel==2&&idUselessItem[0]!=-1) {",
                        "  if(!IdToItem(idUselessItem[0])){",
                        "    completeTask=0;",
                        "    Sound('Sound.QuestCancel');",
                        "    idUselessItem[0]=-1;",
