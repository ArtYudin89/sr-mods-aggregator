                        "      powerDomiks = exp(0.55 * GetData(2, CurShip) - 1.0) * (0.65 + 0.1 * curDomLevel) * (1.0 + 0.033 * (bonusGlobal == 3) * curDomLevel);",
                        "      while (powerDomiks > 1) {",
