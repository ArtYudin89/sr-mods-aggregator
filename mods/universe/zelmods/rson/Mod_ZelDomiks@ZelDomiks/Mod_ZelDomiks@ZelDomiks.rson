                    "_orig_danswer": "DAnswer(CT(\"Script.Mod_ZelDomiks.362\"))"
                },
                {
                    "Name": "",
                    "Pos.x": 1680,
                    "Pos.y": 1290,
                    "Type": "TDialogAnswer",
                    "Parent": -1,
                    "#": 455,
                    "Msg": "Отлично... Может быть вас довезти тогда?",
                    "AMsg.Num": "89",
                    "_orig_danswer": "DAnswer(CT(\"Script.Mod_ZelDomiks.228\"))"
