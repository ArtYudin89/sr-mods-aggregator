                    "Pos.y": 520,
                    "Type": "TDialogMsg",
                    "Parent": -1,
                    "#": 68,
                    "Msg": "Нашим специалистом по улучшению оборудования является <0>.",
                    "DMsg.Num": "11",
                    "_orig_dtext": "DText(Format(CT(\"Script.Mod_ZelRangers.30\"),\"<0>\",StrLvlUpgrade[LvlUpgrade-1]))"
                },
                {
                    "Name": "",
