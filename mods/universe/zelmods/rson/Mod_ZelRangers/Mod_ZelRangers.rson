    "Visual.Objects": [
        {
            "ConstellationCount": 0,
            "DialogAnswers": [
                {
                    "Name": "",
                    "Pos.x": 0,
                    "Pos.y": 615,
                    "Type": "TDialogAnswer",
                    "Parent": -1,
                    "#": 76,
                    "Msg": "Какой ужас... \r\nНо позвольте! Военные ведь абсолютно бесполезны против доминаторов! Я видел собственными глазами, как один клиг уничтожил отряд из 3 флагманов и 14 военных!",
                    "AMsg.Num": "0",
                    "_orig_danswer": "DAnswer(CT(\"Script.Mod_ZelRangers.149\"))"
                },
                {
                    "Name": "",
                    "Pos.x": 120,
                    "Pos.y": 615,
                    "Type": "TDialogAnswer",
                    "Parent": -1,
                    "#": 77,
                    "Msg": "Чего? Надо будет научить их хорошим манерам. \r\nДумаю, пара кварковых бомб внутри правительственных зданий быстро образумит их.Что же касается рейнджеров... Возможно я могу как-то помочь?",
                    "AMsg.Num": "1",
                    "_orig_danswer": "DAnswer(CT(\"Script.Mod_ZelRangers.150\"))"
                },
                {
                    "Name": "",
                    "Pos.x": 240,
                    "Pos.y": 615,
                    "Type": "TDialogAnswer",
                    "Parent": -1,
                    "#": 78,
                    "Msg": "Хорошо, я согласен! Сколько вам нужно?",
                    "AMsg.Num": "2",
                    "_orig_danswer": "DAnswer(CT(\"Script.Mod_ZelRangers.11\"))"
                },
                {
                    "Name": "",
                    "Pos.x": 360,
                    "Pos.y": 615,
                    "Type": "TDialogAnswer",
                    "Parent": -1,
                    "#": 79,
                    "Msg": "Ага, еще чего? Я свои кровно заработанные денюжки никому не отдам.",
                    "AMsg.Num": "3",
                    "_orig_danswer": "DAnswer(CT(\"Script.Mod_ZelRangers.12\"))"
                },
                {
                    "Name": "exit",
                    "Pos.x": 480,
                    "Pos.y": 615,
                    "Type": "TDialogAnswer",
                    "Parent": -1,
                    "#": 80,
                    "Msg": "",
                    "AMsg.Num": "4",
                    "_orig_danswer": "DAnswer('exit')"
                },
                {
