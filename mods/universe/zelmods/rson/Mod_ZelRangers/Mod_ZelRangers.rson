                    "Pos.y": 545,
                    "Type": "TDialogMsg",
                    "Parent": -1,
                    "#": 69,
                    "Msg": "В параметры конкретного рейнджера входит:\r\n1. Размер корпуса\r\n2. Акрин корпуса\r\n3. Уровень экипировки",
                    "DMsg.Num": "12",
                    "_orig_dtext": "DText(CT(\"Script.Mod_ZelRangers.31\"))"
                },
                {
                    "Name": "",
                    "Pos.x": 150,
                    "Pos.y": 545,
                    "Type": "TDialogMsg",
                    "Parent": -1,
                    "#": 70,
                    "Msg": "Этому рейнджеру мы предоставляем <0>.",
                    "DMsg.Num": "13",
                    "_orig_dtext": "DText(Format(CT(\"Script.Mod_ZelRangers.32\"),\"<0>\",StrLvlHullSize[LvlHullSize[current_ranger]-1]))"
                },
