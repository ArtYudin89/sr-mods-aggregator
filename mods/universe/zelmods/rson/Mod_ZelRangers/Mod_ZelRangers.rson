                        "            if ((random == 22) && prob(0.33) && (race == People)) result = FindBonusByNameInCfg('483'); //Корпус \"Ушастик\" IV\"",
                        "            if ((random == 23)) result = FindBonusByNameInCfg('350'); // Убийца",
                        "",
                        "            //if ((random == 24)) result = FindBonusByCustomTag('ExpScienceRanks_TickAttackMode'); // Клещ #Атакующий",
