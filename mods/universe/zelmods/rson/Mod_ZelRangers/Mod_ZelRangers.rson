                {
                    "Name": "",
                    "Code.Type": "Init",
                    "Code": [
                        "// Возвращает силу акрина в зависимости от уровня улучшения акрина рейнджера",
                        "function RandomAcrynPower(lvl) {",
                        "    if (lvl == 1) {",
                        "        result = choice5(",
                        "            0.800, 0,",
                        "            0.170, 1,",
                        "            0.027, 2,",
                        "            0.003, 3,",
                        "            0.000 * exp(-0.7 * admirals_cnt), 4",
                        "        );",
                        "    }",
                        "    if (lvl == 2) {",
                        "        result = choice5(",
                        "            0.400, 0,",
                        "            0.500, 1,",
                        "            0.090, 2,",
                        "            0.010, 3,",
                        "            0.001 * exp(-0.7 * admirals_cnt), 4",
                        "        );",
                        "    }",
                        "    if (lvl == 3) {",
                        "        result = choice5(",
                        "            0.050, 0,",
                        "            0.650, 1,",
                        "            0.250, 2,",
                        "            0.050, 3,",
                        "            0.003 * exp(-0.7 * admirals_cnt), 4",
                        "        );",
                        "    }",
                        "    if (lvl == 4) {",
                        "    result = choice5(",
                        "            0.010, 0,",
                        "            0.400, 1,",
                        "            0.400, 2,",
                        "            0.200, 3,",
                        "            0.006 * exp(-0.7 * admirals_cnt), 4",
                        "        );",
                        "    }",
                        "    if (lvl == 5) {",
                        "        result = choice5(",
                        "            0.001, 0,",
                        "            0.050, 1,",
                        "            0.500, 2,",
                        "            0.400, 3,",
                        "            0.009 * exp(-0.7 * admirals_cnt), 4",
                        "        );",
                        "    }",
                        "}",
                        "",
                        "// Возвращает случайный акрин по силе и расе",
                        "function RandomAcryn(power, ship, race) {",
                        "    result = -1;",
                        "    cnt = 0; // Количество бросков номера. При cnt > 100 цикл завершается",
                        "",
                        "    // Есть 4 категории акринов:",
                        "    //    1 - слабые",
                        "    //    2 - средние",
                        "    //    3 - сильные",
                        "    //    4 - уникальные (вероятность порядка 1%) (получают доп. бонусы)",
                        "",
                        "    // if ((random == <rndid>) && prob(0.20) && (race == Maloc || race == Gaal) && (race != People)) result = FindBonusByName(<str>);",
                        "    //     prob(0.20) - верно с вероятностью 20%",
                        "    //     (race == Maloc || race == Gaal) && (race != People) - условия на расы",
                        "    //     FindBonusByName(<str>); - поиск по имени",
                        "    //     FindBonusByCustomTag(<str>); - поиск по тегу",
                        "    //     FindBonusByNameInCfg(<str>); - поиск по имени раздела в ланге",
                        "    //     если использовать тот же <rndid>, то бонус перезапишется (если вероятность не снижена)",
                        "    while (result == -1 || result == 0) {",
                        "        cnt = cnt + 1;",
                        "        if (cnt > 100) break;",
                        "",
                        "        if (power == 1) {",
                        "            random = Rnd(1, 38);",
                        "            if ((random == 1)) result = FindBonusByNameInCfg('353'); //Быстрый корпус I",
                        "            if ((random == 2)) result = FindBonusByNameInCfg('357'); //Неуязвимый корпус I",
                        "            if ((random == 3)) result = FindBonusByNameInCfg('361'); //Ремонтный корпус I",
                        "            if ((random == 4)) result = FindBonusByNameInCfg('365'); //Миоплазменный корпус I",
                        "            if ((random == 5)) result = FindBonusByNameInCfg('369'); //Пигамарный корпус I",
                        "            if ((random == 6)) result = FindBonusByNameInCfg('472'); //Корпус \"Молния\" I",
                        "            if ((random == 7)) result = FindBonusByNameInCfg('476'); //Корпус \"Броненосец\" I",
                        "            if ((random == 8) && (race == Gaal)) result = FindBonusByNameInCfg('468'); //Корпус \"Честный ренегал\" I",
                        "            if ((random == 9) && (race == Peleng)) result = FindBonusByNameInCfg('460'); //Корпус \"Добрый лякуша\" I",
                        "            if ((random == 10) && (race == People)) result = FindBonusByNameInCfg('464'); //Корпус \"Мирный корсар\" I",
                        "            if ((random == 11) && (race == People)) result = FindBonusByNameInCfg('480'); //Корпус \"Ушастик\" I",
                        "            if ((random == 12)) result = FindBonusByNameInCfg('352'); // Болид",
                        "",
                        "            //if ((random == 13)) result = FindBonusByCustomTag('ExpScienceRanks_TickSpeedMode'); // Клещ #Скоростной",
                        "            if ((random == 14) && prob(0.33)) result = FindBonusByCustomTag('LEOContentMod_Giperion_1_Hull'); // Гиперион I",
                        "            if ((random == 15)) result = FindBonusByCustomTag('?');",
                        "            if ((random == 16)) result = FindBonusByCustomTag('LEOLastHulls_G2_Hull'); // Черный призрак",
                        "            if ((random == 17)) result = FindBonusByCustomTag('LEOLastHulls_G5_Hull'); // Цербер",
                        "",
                        "            if ((random == 18) && (race == Peleng)) result = FindBonusByName(CT(\"Script.Mod_ZelRangers.141\") + ' I');",
                        "            if ((random == 19) && (race == People || race == Maloc)) result = FindBonusByName(CT(\"Script.Mod_ZelRangers.140\") + ' I');",
                        "            if ((random == 20) && (race == Maloc)) result = FindBonusByName(CT(\"Script.Mod_ZelRangers.139\") + ' I');",
                        "            if ((random == 21) && (race == Fei)) result = FindBonusByName(CT(\"Script.Mod_ZelRangers.138\") + ' I');",
                        "            if ((random == 22) && (race == Gaal)) result = FindBonusByName(CT(\"Script.Mod_ZelRangers.137\") + ' I');",
                        "            if ((random == 23) && (race == People || race == Peleng)) result = FindBonusByName(CT(\"Script.Mod_ZelRangers.136\") + ' I');",
                        "            if ((random == 24) && (race == Maloc)) result = FindBonusByNameInCfg('EvoGkvan_GkvanHull');",
                        "            if ((random == 25) && (race == Maloc)) result = FindBonusByNameInCfg('Cat_Ships_Bigrabyrba');",
                        "            if ((random == 26) && (race == Fei)) result = FindBonusByNameInCfg('Cat_Ships_Shegramer');",
                        "            if ((random == 27) && (race == People)) result = FindBonusByNameInCfg('Cat_Ships_Vyhr');",
                        "            if ((random == 28) && (race == Peleng)) result = FindBonusByNameInCfg('Cat_Ships_Beshraflac');",
                        "            if ((random == 29) && (race == Fei)) result = FindBonusByNameInCfg('Cat_Ships_Ellentanda');",
                        "            if ((random == 30)) result = FindBonusByNameInCfg('Cat_Ships_Bongrabar');",
                        "            if ((random == 31)) result = FindBonusByNameInCfg('Cat_Ships_Hramgerb');",
                        "            if ((random == 32) && (race == Peleng)) result = FindBonusByNameInCfg('Cat_Ships_Casholdsha');",
                        "            if ((random == 33) && (race == Peleng)) result = FindBonusByNameInCfg('Cat_Ships_Chipshush');",
                        "            if ((random == 34)) result = FindBonusByNameInCfg('Cat_Ships_Cvahonda');",
                        "            if ((random == 35)) result = FindBonusByNameInCfg('Cat_Ships_Sharcun');",
                        "            if ((random == 36) && (race == People)) result = FindBonusByNameInCfg('Cat_Ships_Horizont');",
                        "            if ((random == 37) && (race == People)) result = FindBonusByNameInCfg('Cat_Ships_Trackvagn');",
                        "            if ((random == 38)) result = FindBonusByNameInCfg('Cat_Ships_Zvedavar');",
                        "        }",
                        "",
                        "        if (power == 2) {",
                        "            random = Rnd(1, 37);",
                        "            if ((random == 1)) result = FindBonusByNameInCfg('354'); //Быстрый корпус II",
                        "            if ((random == 2)) result = FindBonusByNameInCfg('358'); //Неуязвимый корпус II",
                        "            if ((random == 3)) result = FindBonusByNameInCfg('362'); //Ремонтный корпус II",
                        "            if ((random == 4)) result = FindBonusByNameInCfg('366'); //Миоплазменный корпус II",
                        "            if ((random == 5)) result = FindBonusByNameInCfg('370'); //Пигамарный корпус II",
                        "            if ((random == 6)) result = FindBonusByNameInCfg('473'); //Корпус \"Молния\" II",
                        "            if ((random == 7)) result = FindBonusByNameInCfg('477'); //Корпус \"Броненосец\" II",
                        "            if ((random == 8) && (race == Gaal)) result = FindBonusByNameInCfg('469'); //Корпус \"Честный ренегал\" II",
                        "            if ((random == 9) && (race == Peleng)) result = FindBonusByNameInCfg('461'); //Корпус \"Добрый лякуша\" II",
                        "            if ((random == 10) && (race == People)) result = FindBonusByNameInCfg('465'); //Корпус \"Мирный корсар\" II",
                        "            if ((random == 11) && (race == People)) result = FindBonusByNameInCfg('481'); //Корпус \"Ушастик\" II",
                        "            if ((random == 12)) result = FindBonusByNameInCfg('351'); // Скала",
                        "",
                        "            //if ((random == 13)) result = FindBonusByCustomTag('ExpScienceRanks_TickDefenseMode'); // Клещ #Защитный",
                        "            if ((random == 14) && prob(0.33)) result = FindBonusByCustomTag('LEOContentMod_Giperion_2_Hull'); // Гиперион II",
                        "            if ((random == 15) && prob(0.33)) result = FindBonusByCustomTag('LEOContentMod_Giperion_3_Hull'); // Гиперион III",
                        "            if ((random == 16)) result = FindBonusByCustomTag('LEOLastHulls_G1_Hull'); // Горизонт",
                        "",
                        "            if ((random == 17) && (race == Peleng)) result = FindBonusByName(CT(\"Script.Mod_ZelRangers.141\") + ' II');",
                        "            if ((random == 18) && (race == People || race == Maloc)) result = FindBonusByName(CT(\"Script.Mod_ZelRangers.140\") + ' II');",
                        "            if ((random == 19) && (race == Maloc)) result = FindBonusByName(CT(\"Script.Mod_ZelRangers.139\") + ' II');",
                        "            if ((random == 20) && (race == Fei)) result = FindBonusByName(CT(\"Script.Mod_ZelRangers.138\") + ' II');",
                        "            if ((random == 21) && (race == Gaal)) result = FindBonusByName(CT(\"Script.Mod_ZelRangers.137\") + ' II');",
                        "            if ((random == 22) && (race == People || race == Peleng)) result = FindBonusByName(CT(\"Script.Mod_ZelRangers.136\") + ' II');",
                        "            if ((random == 23) && (race == Fei)) result = FindBonusByName(CT(\"Script.Mod_ZelRangers.147\"));",
                        "            if ((random == 24) && (race == People)) result = FindBonusByName(CT(\"Script.Mod_ZelRangers.146\"));",
                        "            if ((random == 25) && (race == Peleng)) result = FindBonusByName(CT(\"Script.Mod_ZelRangers.145\"));",
                        "            if ((random == 26) && (race == Maloc)) result = FindBonusByNameInCfg('Cat_Ships_Bigrabyrba');",
                        "            if ((random == 27) && (race == Fei)) result = FindBonusByNameInCfg('Cat_Ships_Ellentanda');",
                        "            if ((random == 28)) result = FindBonusByNameInCfg('Cat_Ships_Bongrabar');",
                        "            if ((random == 29) && (race == Maloc)) result = FindBonusByNameInCfg('Cat_Ships_Gromodryn');",
                        "            if ((random == 30)) result = FindBonusByNameInCfg('Cat_Ships_Hramgerb');",
                        "            if ((random == 31) && (race == Peleng)) result = FindBonusByNameInCfg('Cat_Ships_Casholdsha');",
                        "            if ((random == 32) && (race == Peleng)) result = FindBonusByNameInCfg('Cat_Ships_Chipshush');",
                        "            if ((random == 33)) result = FindBonusByNameInCfg('Cat_Ships_Cvahonda');",
                        "            if ((random == 34)) result = FindBonusByNameInCfg('Cat_Ships_Zvedavar');",
