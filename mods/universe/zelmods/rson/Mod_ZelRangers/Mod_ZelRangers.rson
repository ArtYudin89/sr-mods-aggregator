                        "",
                        "            if ((random == 31) && (race == Peleng)) result = FindBonusByName(CT(\"Script.Mod_ZelRangers.141\") + ' III');",
                        "            if ((random == 32) && (race == People || race == Maloc)) result = FindBonusByName(CT(\"Script.Mod_ZelRangers.140\") + ' III');",
