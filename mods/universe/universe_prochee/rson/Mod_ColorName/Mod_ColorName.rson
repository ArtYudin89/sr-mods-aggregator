                    "#": 6,
                    "Type": "Top",
                    "Parent": -1,
                    "Pos.x": 0,
                    "Pos.y": 885
                },
                {
                    "Name": "",
                    "Code.Type": "Init",
                    "Code": [
                        "if(GetShipRuins(Player())>0) {",
                        "  if(ShipType(GetShipRuins(Player()))=='RC') {",
                        "    AddDialogInject('ColorName','<br>Также мы можем украсить ваше имя цветом.<br>',CT(\"Script.Mod_ColorName.94\"),1);",
                        "    if(ShipPartners(Player())!=0) {",
                        "      temp_int=ShipPartners(Player());",
                        "      AddDialogInject('FollowerColorName','',CT(\"Script.Mod_ColorName.134\"),1);",
                        "      AddDialogInject('FollowerChangeName',Format('<br>На данный момент количество напарников в вашем распоряжении равняется <clr><0><clrEnd>. Если пожелаете мы можем изменить имя вашему напарнику или же придать ему цвет.<br>',\"<0>\",temp_int),CT(\"Script.Mod_ColorName.174\"),1);",
                        "    }",
                        "  }",
                        "}"
                    ],
                    "#": 7,
                    "Type": "Top",
                    "Parent": -1,
                    "Pos.x": 60,
                    "Pos.y": 885
                },
                {
                    "Name": "",
                    "Code.Type": "Turn",
                    "Code": [
                        "if(ShipMoney(Player())>5000) {",
                        "  DChange(0);",
                        "  exit;",
                        "}",
                        "if(ShipMoney(Player())<5000) {",
                        "  DChange(4);",
                        "  exit;",
                        "}"
                    ],
                    "#": 192,
                    "Type": "Top",
                    "Parent": -1,
                    "Pos.x": -20,
                    "Pos.y": 375
                },
                {
                    "Name": "",
                    "Code.Type": "Turn",
                    "Code": [
                        "if(ShipMoney(Player())>5250) {",
                        "  if(ShipPartners(Player())==1) {",
                        "    DChange(26);",
                        "    exit;",
                        "  }",
                        "  if(ShipPartners(Player())==2) {",
                        "    DChange(25);",
                        "    exit;",
                        "  }",
                        "  if(ShipPartners(Player())==3) {",
                        "    DChange(24);",
                        "    exit;",
                        "  }",
                        "  if(ShipPartners(Player())==4) {",
                        "    DChange(23);",
                        "    exit;",
                        "  }",
                        "  if(ShipPartners(Player())==5) {",
                        "    DChange(22);",
                        "    exit;",
                        "  }",
                        "  if(ShipPartners(Player())==6) {",
                        "    DChange(7);",
                        "    exit;",
                        "  }",
                        "}",
                        "if(ShipMoney(Player())<5250) {",
                        "  DChange(6);",
                        "  exit;",
                        "}"
                    ],
