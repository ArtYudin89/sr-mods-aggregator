                        "adv_art_name = 'ArtRadarv2';",
                        "adv_art_acryn_name = 'AdvancedArts_bonRadar2';",
                        "int artcounter = 0; // число одинаковых артов",
                        "//unknown top3arts; // 3 арта, которые извлекаются",
                        "top3arts = newarray(3,7);",
                        "int i;",
                        "// получение 3-х артов и их характеристик в отдельном списке",
                        "for (i=0;i<player_items_count;i=i+1) {",
                        "\tif ((player_arts[i,4] == stats[artnumber,0] || (artnumber == 2 && player_arts[i,7] == 'ArtSpeedEnabled')) && artcounter <=2)",
                        "    {",
                        "        top3arts[artcounter,0] = player_arts[i,0]; // item",
                        "        top3arts[artcounter,1] = player_arts[i,1]; // тип, возможно, не нужен, ибо есть всякие кастомные арты",
                        "        top3arts[artcounter,2] = player_arts[i,2]; // вес",
                        "        top3arts[artcounter,3] = player_arts[i,3]; // производитель",
                        "        top3arts[artcounter,4] = player_arts[i,4]; // название артефакта",
                        "        top3arts[artcounter,5] = player_arts[i,5]; // стоимость",
                        "        top3arts[artcounter,6] = player_arts[i,6]; // номер на корабле",
                        "        artcounter = artcounter + 1;",
                        "    }",
                        "}",
                        "top3arts_total_sum  = top3arts[0,5]+top3arts[1,5]+top3arts[2,5]; // Сумма, которая будет снята;",
                        "DChange(2);",
                        "exit;"
