                        "//количество всех артов до подсчёта равно 0",
                        "for (i=0;i<64;i=i+1)",
                        "{",
                        "\tstats[i,1] = 0;",
                        "}",
                        "//подсчёт количества артов по массиву артефактов. Для обычных артов по числовому типу, для кастомных по системному имени",
                        "if (player_items_count>0) {",
                        "for (i=0;i<player_items_count;i=i+1)",
                        "    {",
                        "\tif (player_arts[i,4] == stats[0,0]) {stats[0,1]=stats[0,1]+1;} //Железные жупи",
                        "\tif (player_arts[i,4] == stats[1,0]) {stats[1,1]=stats[1,1]+1;} //Чёрная жижа",
                        "\tif (player_arts[i,4] == stats[2,0] || player_arts[i,7] == 'ArtSpeedEnabled') {stats[2,1]=stats[2,1]+1;} //Пси-ускоритель материи",
                        "\tif (player_arts[i,4] == stats[3,0]) {stats[3,1]=stats[3,1]+1;} //Отморозки",
                        "\tif (player_arts[i,4] == stats[4,0]) {stats[4,1]=stats[4,1]+1;} //Пролонгер",
                        "\tif (player_arts[i,4] == stats[5,0]) {stats[5,1]=stats[5,1]+1;} //Сканерный кэш",
                        "\tif (player_arts[i,4] == stats[6,0]) {stats[6,1]=stats[6,1]+1;} //Дроид младший",
                        "\tif (player_arts[i,4] == stats[7,0]) {stats[7,1]=stats[7,1]+1;} //Нанитоиды",
                        "\tif (player_arts[i,4] == stats[8,0]) {stats[8,1]=stats[8,1]+1;} //Эриметр",
                        "\tif (player_arts[i,4] == stats[9,0]) {stats[9,1]=stats[9,1]+1;} //Поляризатор",
                        "\tif (player_arts[i,4] == stats[10,0]) {stats[10,1]=stats[10,1]+1;} //Вероятностный анализатор",
                        "\tif (player_arts[i,4] == stats[11,0]) {stats[11,1]=stats[11,1]+1;} //Локализатор взрывной волны",
                        "\tif (player_arts[i,4] == stats[12,0]) {stats[12,1]=stats[12,1]+1;} //Антигравитатор",
                        "\tif (player_arts[i,4] == stats[13,0]) {stats[13,1]=stats[13,1]+1;} //Трансфакторный маяк",
                        "\tif (player_arts[i,4] == stats[14,0]) {stats[14,1]=stats[14,1]+1;} //Кварковая бомба",
                        "\tif (player_arts[i,4] == stats[15,0]) {stats[15,1]=stats[15,1]+1;} //Транклюкатор",
                        "\tif (player_arts[i,4] == stats[16,0]) {stats[16,1]=stats[16,1]+1;} //Пропорционар",
                        "\tif (player_arts[i,4] == stats[17,0]) {stats[17,1]=stats[17,1]+1;} //Пятерик",
                        "\tif (player_arts[i,4] == stats[18,0]) {stats[18,1]=stats[18,1]+1;} //Проглот",
                        "\tif (player_arts[i,4] == stats[19,0]) {stats[19,1]=stats[19,1]+1;} //Навинт",
                        "\tif (player_arts[i,4] == stats[20,0]) {stats[20,1]=stats[20,1]+1;} //Вжик",
                        "\tif (player_arts[i,4] == stats[21,0]) {stats[21,1]=stats[21,1]+1;} //Ракетанг",
                        "\tif (player_arts[i,4] == stats[22,0]) {stats[22,1]=stats[22,1]+1;} //Обливионный коннектор",
                        "\tif (player_arts[i,4] == stats[23,0]) {stats[23,1]=stats[23,1]+1;} //Сопланатор",
                        "\tif (player_arts[i,4] == stats[24,0]) {stats[24,1]=stats[24,1]+1;} //Гипергенератор",
                        "\tif (player_arts[i,4] == stats[25,0]) {stats[25,1]=stats[25,1]+1;} //Субпортал",
                        "\tif (player_arts[i,4] == stats[26,0]) {stats[26,1]=stats[26,1]+1;} //Протон",
                        "\tif (player_arts[i,4] == stats[27,0]) {stats[27,1]=stats[27,1]+1;} //Армс",
                        "\tif (player_arts[i,4] == stats[28,0]) {stats[28,1]=stats[28,1]+1;} //Артефактор",
                        "\tif (player_arts[i,4] == stats[29,0]) {stats[29,1]=stats[29,1]+1;} //Биомир",
                        "    // Для аэгиса не понял, как сделать экранирование, поэтому сравниваются с 3 по 6 символы",
                        "\tif (substr(player_arts[i,4],2,4) == stats[30,1]) {stats[30,1]=stats[30,1]+1;} // Аэгис",
                        "\tif (player_arts[i,4] == stats[31,0]) {stats[31,1]=stats[31,1]+1;} // Ралс",
                        "\tif (player_arts[i,7] == 'ArtHullv2') {stats[32,1]=stats[32,1]+1;}//'Железные жупи';",
