                        "\tif (player_arts[i,7] == 'ArtEnergyDefv2') {stats[50,1]=stats[50,1]+1;}//'Проглот v2';",
                        "\tif (player_arts[i,7] == 'ArtSplinterv2') {stats[51,1]=stats[51,1]+1;}//'Навинт v2';",
                        "\tif (player_arts[i,7] == 'ArtDeceleratev2') {stats[52,1]=stats[52,1]+1;}//'Вжик v2';",
                        "\tif (player_arts[i,7] == 'ArtMissileDefv2') {stats[53,1]=stats[53,1]+1;}//'Ракетанг v2';",
                        "\t        //if(player_arts[i,7] == '') {stats[54,1]=stats[54,1]+1;}//'Обливионный коннектор v2';",
                        "\tif (player_arts[i,7] == 'ArtWeaponToSpeedv2') {stats[55,1]=stats[55,1]+1;}//'Сопланатор v2';",
                        "\tif (player_arts[i,7] == 'ArtGiperJumpv2') {stats[56,1]=stats[56,1]+1;}//'Гипергенератор v2';",
                        "\t        //if(player_arts[i,7] == '') {stats[57,1]=stats[57,1]+1;}//'Субпортал v2';",
                        "            //if(player_arts[i,7] == '') {stats[58,1]=stats[58,1]+1;}//'Протон v2';",
                        "            //if(player_arts[i,7] == '') {stats[59,1]=stats[59,1]+1;}//'Армс v2';",
                        "            //if(player_arts[i,7] == '') {stats[60,1]=stats[60,1]+1;}//'Артефактор v2';",
                        "            //if(player_arts[i,7] == '') {stats[61,1]=stats[61,1]+1;}//'Биомир v2';",
                        "            //if(player_arts[i,7] == '') {stats[62,1]=stats[62,1]+1;}//'Эгис v2'; // аЭгис",
                        "    if (player_arts[i,7] == 'ArtFastRacksv2') {stats[63,1]=stats[63,1]+1;}//'Ралс v2';",
                        "    }",
                        "}",
