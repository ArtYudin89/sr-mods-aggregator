                {
                    "Name": "",
                    "Code.Type": "Turn",
                    "Code": [
                        "// Удаление 3-х артов",
                        "FreeItem(GetArtFromShip(Player(),top3arts[2,6]));",
                        "FreeItem(GetArtFromShip(Player(),top3arts[1,6]));",
                        "FreeItem(GetArtFromShip(Player(),top3arts[0,6]));",
                        "// снятие средств с игрока",
                        "ShipMoney(Player(),ShipMoney(Player())-top3arts_total_sum);",
                        "Sound('Sound.Sell');",
                        "// Артефакты неизвестной расы и пиратские считаются как челевеческие",
                        "if (top3arts[0,3] == 6 || top3arts[0,3] == 7) {top3arts[0,3] = 2;}",
                        "if (top3arts[1,3] == 6 || top3arts[0,3] == 7) {top3arts[1,3] = 2;}",
                        "if (top3arts[2,3] == 6 || top3arts[0,3] == 7) {top3arts[2,3] = 2;}",
                        "",
                        "// Дообавление нового арта",
                        "dword temp_dword=0;",
                        "temp_dword=CreateCustomArt(adv_art_name, min(top3arts[0,2],top3arts[1,2],top3arts[2,2]), ((top3arts[0,5]+top3arts[1,5]+top3arts[2,5])/3)*2, max(top3arts[0,3], top3arts[1,3], top3arts[2,3]));",
                        "SpecialToEquipment(FindBonusByCustomTag(adv_art_acryn_name),temp_dword);",
                        "AddItemToShip(Player(),temp_dword);",
                        "DChange(1);",
                        "exit;"
                    ],
