            "Items": [],
            "Operations": [
                {
                    "Name": "",
                    "Code.Type": "Global",
                    "Code": [
                        "GRun();"
                    ],
                    "#": 12,
                    "Type": "Top",
                    "Parent": -1,
                    "Pos.x": 0,
                    "Pos.y": 635
                },
                {
                    "Name": "",
                    "Code.Type": "Init",
                    "Code": [
                        "if(GetShipRuins(Player())>0) {",
                        "  if(ShipType(GetShipRuins(Player()))=='SB' || ShipType(GetShipRuins(Player()))=='CB') {",
                        "    AddDialogInject('ask_for_arts','',CT(\"Script.AdvancedArts.0\"),1);",
                        "  }",
                        "}"
                    ],
                    "#": 13,
                    "Type": "Top",
                    "Parent": -1,
                    "Pos.x": 60,
                    "Pos.y": 635
                },
                {
                    "Name": "",
                    "Code.Type": "Turn",
                    "Code": [
                        "DChange(0);",
                        "exit;"
                    ],
                    "#": 60,
                    "Type": "Top",
                    "Parent": -1,
                    "Pos.x": -20,
                    "Pos.y": 375
                },
                {
                    "Name": "",
                    "Code.Type": "Turn",
                    "Code": [
                        "//unknown player_arts; // массив для сохранения списка артефактов на корабле и их характеристик",
                        "player_arts = newarray(1500,8);",
                        "//int player_items_count; // количество артефактов на корабле",
                        "player_items_count = ShipArts(Player());",
                        "int i;",
                        "if (player_items_count>0) {",
                        "    for (i=0;i<player_items_count;i=i+1) {",
                        "    player_arts[i,0] = ShipArts(Player(),i); // item",
                        "    player_arts[i,1] = ItemType(ShipArts(Player(),i)); //тип, возможно, не нужен, ибо есть всякие кастомные арты",
                        "    player_arts[i,2] = ItemSize(ShipArts(Player(),i)); // вес",
                        "    player_arts[i,3] = ItemOwner(ShipArts(Player(),i)); // производитель",
                        "    player_arts[i,4] = Name(ShipArts(Player(),i)); // название артефакта",
                        "    player_arts[i,5] = ItemCost(ShipArts(Player(),i)); // стоимость",
                        "    player_arts[i,6] = i; // номер на корабле",
                        "    player_arts[i,7] = EquipmentImageName(ShipArts(Player(),i)); // системное имя арта (работает только для кастомных артов?)",
                        "    }",
                        "}",
                        "// Количество артефактов [тип артефакта, количество на корабле]",
                        "//unknown stats; // массив для сохранения количества артефактов по типам",
                        "stats = newarray(100, 2);",
                        "stats[0,0]= 'Железные жупи';",
                        "stats[1,0]= 'Чёрная жижа';",
                        "stats[2,0]= 'Пси-ускоритель материи';",
                        "stats[3,0]= 'Отморозки';",
                        "stats[4,0]= 'Пролонгер';",
                        "stats[5,0]= 'Сканерный кэш';",
                        "stats[6,0]= 'Дроид младший';",
                        "stats[7,0]= 'Нанитоиды';",
                        "stats[8,0]= 'Эриметр';",
                        "stats[9,0]= 'Поляризатор';",
                        "stats[10,0]= 'Вероятностный анализатор';",
                        "stats[11,0]= 'Локализатор взрывной волны';",
                        "stats[12,0]= 'Антигравитатор';",
                        "stats[13,0]= 'Трансфакторный маяк';",
                        "stats[14,0]= 'Кварковая бомба';",
                        "stats[15,0]= 'Транклюкатор';",
                        "stats[16,0]= 'Пропорционар';",
                        "stats[17,0]= 'Пятерик';",
                        "stats[18,0]= 'Проглот';",
                        "stats[19,0]= 'Навинт';",
                        "stats[20,0]= 'Вжик';",
                        "stats[21,0]= 'Ракетанг';",
                        "stats[22,0]= 'Обливионный коннектор';",
                        "stats[23,0]= 'Сопланатор';",
                        "stats[24,0]= 'Гипергенератор';",
                        "stats[25,0]= 'Субпортал';",
                        "stats[26,0]= 'Протон';",
                        "stats[27,0]= 'Армс';",
                        "stats[28,0]= 'Артефактор';",
                        "stats[29,0]= 'Биомир';",
                        "stats[30,0]= 'Эгис'; // аЭгис. Возможно, сюда будут попадать Аэгисы v2.",
                        "stats[31,0]= 'Ралс';",
                        "// Артефакты v2",
                        "stats[32,0]= 'Железные жупи v2';",
                        "stats[33,0]= 'Чёрная жижа v2';",
