                        "\tif (player_arts[i,7] == 'ArtSpeedv2') {stats[34,1]=stats[34,1]+1;}//'Пси-ускоритель материи';",
                        "\t        //if(player_arts[i,7] == '') {stats[35,1]=stats[35,1]+1;}//'Отморозки';",
                        "\tif (player_arts[i,7] == 'ArtRadarv2') {stats[36,1]=stats[36,1]+1;}//'Пролонгер';",
                        "\tif (player_arts[i,7] == 'ArtScanerv2') {stats[37,1]=stats[37,1]+1;}//'Сканерный кэш';",
                        "\tif (player_arts[i,7] == 'ArtDroidv2') {stats[38,1]=stats[38,1]+1;}//'Дроид младший';",
                        "\t        //if(player_arts[i,7] == '') {stats[39,1]=stats[39,1]+1;}//'Нанитоиды';",
                        "\tif (player_arts[i,7] == 'ArtHookv2') {stats[40,1]=stats[40,1]+1;}//'Эриметр';",
                        "\tif (player_arts[i,7] == 'ArtDefv2') {stats[41,1]=stats[41,1]+1;}//'Поляризатор';",
                        "\tif (player_arts[i,7] == 'ArtAnalyzerv2') {stats[42,1]=stats[42,1]+1;}//'Вероятностный анализатор v2';",
                        "\t        //if(player_arts[i,7] == '') {stats[43,1]=stats[43,1]+1;}//'Локализатор взрывной волны v2';",
                        "\tif (player_arts[i,7] == 'ArtAntigravv2') {stats[44,1]=stats[44,1]+1;}//'Антигравитатор v2';",
                        "\t        //if(player_arts[i,7] == '') {stats[45,1]=stats[45,1]+1;}//'Трансфакторный маяк v2';",
                        "\t        //if(player_arts[i,7] == '') {stats[46,1]=stats[46,1]+1;}//'Кварковая бомба v2';",
                        "\t        //if(player_arts[i,7] == '') {stats[47,1]=stats[47,1]+1;}//'Транклюкатор v2';",
                        "\tif (player_arts[i,7] == 'ArtDefToEnergyv2') {stats[48,1]=stats[48,1]+1;}//'Пропорционар v2';",
