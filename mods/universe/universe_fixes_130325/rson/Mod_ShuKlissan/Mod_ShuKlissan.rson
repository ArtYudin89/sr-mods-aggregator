                        "      //Если сдаётся оборудка",
                        "      else InjectAnswer('Remains3', '<color=0,50,200>' + DeleteTags(Name(cur_item)) + '</color>' + Format('  (<0> cr.)',\"<0>\",ItemCost(cur_item)), i);",
                        "  }",
                        "",
                        "  DAnswer('restart~' + CT(\"Script.Mod_ShuKlissan.200\"));",
