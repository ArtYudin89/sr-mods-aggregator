                        "    if(ShipOrderObj(cur_ship) == Player())",
                        "    {",
                        "        TruceBetweenShips(Player(), cur_ship);",
                        "        RelationToRanger(cur_ship, Player(), 50);",
                        "    }",
                        "}",
