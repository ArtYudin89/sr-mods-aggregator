                        "    if(ItemType(cur_item) == t_UselessItem) InjectAnswer('Remains2', '<color=0,50,200>' + DeleteTags(Name(cur_item)) + '</color>' + Format('  (<0> cr.) <color=0,50,200>x2</color>',\"<0>\",ItemCost(cur_item)), i);",
                        "    //Если сдаётся оборудка",
                        "    else InjectAnswer('Remains2', '<color=0,50,200>' + DeleteTags(Name(cur_item)) + '</color>' + Format('  (<0> cr.)',\"<0>\",ItemCost(cur_item)), i);",
