                    "Code.Type": "Turn",
                    "Code": [
                        "//Удаляем из инвентаря игрока выбранный им для сдачи предмет, и обновляем счётчики материала",
                        "cur_item = ShipItems(Player(), GAnswerData);",
                        "//Ошмётки сдаются дороже, чем оборудка",
                        "if(ItemType(cur_item) == t_UselessItem) cost = ItemCost(cur_item) * 2;",
                        "else cost = ItemCost(cur_item);",
                        "",
                        "//Сдаём на ментальный коммуникатор",
                        "if(check == 1)",
                        "{",
                        "    KlissanInvasion['MentalCommunicator.ResearchLeft'] = max(KlissanInvasion['MentalCommunicator.ResearchLeft'] - ItemSize(cur_item), 0);",
                        "    //Если сдали уже достаточно",
                        "    if(!KlissanInvasion['MentalCommunicator.ResearchLeft'])",
                        "    {",
                        "        check = 3;",
                        "        //Заводим таймер до завершения исследования",
                        "        KlissanInvasion['MentalCommunicator.WasReceived'] = CurTurn() + Rnd(474, 547);",
                        "        tstr1 = GameDateTxtByTurn(KlissanInvasion['MentalCommunicator.WasReceived']); //Тупой RScript не умеет в одинарные кавычки внутри кавычек двойных",
                        "        tstr1 = '</color>' + Format(CT(\"Script.Mod_ShuKlissan.134\"),\"<0>\",tstr1);",
                        "    }",
                        "    else",
                        "    {",
                        "        tstr1 = KlissanInvasion['MentalCommunicator.ResearchLeft']; //Тупой RScript не умеет в одинарные кавычки внутри кавычек двойных",
                        "        tstr1 = '</color>' + Format(CT(\"Script.Mod_ShuKlissan.135\"),\"<0>\",ItemSize(cur_item),\"<1>\",cost,\"<2>\",tstr1);",
                        "    }",
                        "}",
                        "//Сдаём на Z-трансмиттер",
                        "else if(check == 2)",
                        "{",
                        "    KlissanInvasion['ZTransmitter.ResearchLeft'] = max(KlissanInvasion['ZTransmitter.ResearchLeft'] - ItemSize(cur_item), 0);",
                        "    //Если сдали уже достаточно",
                        "    if(!KlissanInvasion['ZTransmitter.ResearchLeft'])",
                        "    {",
                        "        check = 3;",
                        "        //Заводим таймер до завершения исследования",
                        "        KlissanInvasion['ZTransmitter.WasReceived'] = CurTurn() + Rnd(292, 438);",
                        "        tstr1 = GameDateTxtByTurn(KlissanInvasion['ZTransmitter.WasReceived']); //Тупой RScript не умеет в одинарные кавычки внутри кавычек двойных",
                        "        tstr1 = '</color>' + Format(CT(\"Script.Mod_ShuKlissan.134\"),\"<0>\",tstr1);",
                        "    }",
                        "    else",
                        "    {",
                        "        tstr1 = KlissanInvasion['ZTransmitter.ResearchLeft']; //Тупой RScript не умеет в одинарные кавычки внутри кавычек двойных",
                        "        tstr1 = '</color>' + Format(CT(\"Script.Mod_ShuKlissan.135\"),\"<0>\",ItemSize(cur_item),\"<1>\",cost,\"<2>\",tstr1);",
                        "    }",
                        "}",
                        "",
                        "if(check == 3) Sound('Sound.QuestOk');",
                        "else Sound('Sound.Sell');",
                        "",
                        "ShipMoney(Player(), ShipMoney(Player()) + cost);",
                        "FreeItem(GetItemFromShip(Player(), cur_item));",
                        "DChange(63);",
                        "exit;"
                    ],
