                },
                {
                    "Name": "",
                    "Code.Type": "Turn",
                    "Code": [
                        "int coal_ships = 0;",
                        "int domik_ships = 0;",
                        "int pirate_ships = 0;",
                        "int klissan_ships = 0;",
                        "",
                        "for(i = 0; i < GalaxyStars(); i = i + 1)",
                        "{",
                        "    cur_star = GalaxyStar(i);",
                        "    if(StarCustomFaction(cur_star) == '')",
                        "    {",
                        "        if(StarOwner(cur_star) == 1) domik_ships = domik_ships + 1;",
                        "        if(StarOwner(cur_star) == 2) pirate_ships = pirate_ships + 1;",
                        "    }",
                        "    else if(StarCustomFaction(cur_star) == 'Klissan') klissan_ships = klissan_ships + 1;",
                        "}",
                        "",
                        "tint1 = GalaxyStars();",
                        "pirate_ships = pirate_ships * 100 / tint1;",
                        "domik_ships = domik_ships * 100 / tint1;",
                        "klissan_ships = klissan_ships * 100 / tint1;",
                        "coal_ships = 100 - (pirate_ships + domik_ships + klissan_ships);",
                        "",
                        "if(coal_ships >= 100) tint1 = 1;",
                        "else if(coal_ships >= 90) tint1 = 2;",
                        "else if(coal_ships >= 70) tint1 = 3;",
                        "else if(coal_ships >= 50) tint1 = 4;",
                        "else if(coal_ships >= 30) tint1 = 5;",
                        "else if(coal_ships >= 10) tint1 = 6;",
                        "else tint1 = 7;",
                        "",
                        "cur_star = ShipStar(Player());",
                        "for(i = 1; i < GalaxyStars(); i = i + 1)",
                        "{",
                        "    tdwd1 = StarNearbyStars(cur_star, i);",
                        "    if(StarOwner(tdwd1))",
                        "    {",
                        "        tstr2 = Name(tdwd1);",
                        "        tstr3 = Name(StarToCon(cur_star));",
                        "        break;",
                        "    }",
                        "}",
                        "",
                        "if(KlissanInvasion['DaysPassedAfterStart'] > 4)",
                        "{",
                        "    if(tint1 == 1) tstr1 = '</color>' + Format(CT(\"Script.Mod_ShuKlissan.160\"),\"<0>\",coal_ships,\"<1>\",domik_ships,\"<2>\",pirate_ships,\"<3>\",klissan_ships);",
                        "    else if(tint1 == 2) tstr1 = '</color>' + Format(CT(\"Script.Mod_ShuKlissan.161\"),\"<0>\",coal_ships,\"<1>\",domik_ships,\"<2>\",pirate_ships,\"<3>\",klissan_ships);",
                        "    else if(tint1 == 3) tstr1 = '</color>' + Format(CT(\"Script.Mod_ShuKlissan.162\"),\"<0>\",coal_ships,\"<1>\",domik_ships,\"<2>\",pirate_ships,\"<3>\",klissan_ships,\"<4>\",tstr2,\"<5>\",tstr3);",
                        "    else if(tint1 == 4) tstr1 = '</color>' + Format(CT(\"Script.Mod_ShuKlissan.163\"),\"<0>\",coal_ships,\"<1>\",domik_ships,\"<2>\",pirate_ships,\"<3>\",klissan_ships,\"<4>\",tstr2,\"<5>\",tstr3);",
                        "    else if(tint1 == 5) tstr1 = '</color>' + Format(CT(\"Script.Mod_ShuKlissan.164\"),\"<0>\",coal_ships,\"<1>\",domik_ships,\"<2>\",pirate_ships,\"<3>\",klissan_ships,\"<4>\",tstr2,\"<5>\",tstr3);",
                        "    else if(tint1 == 6) tstr1 = '</color>' + Format(CT(\"Script.Mod_ShuKlissan.165\"),\"<0>\",coal_ships,\"<1>\",domik_ships,\"<2>\",pirate_ships,\"<3>\",klissan_ships,\"<4>\",tstr2);",
                        "    else if(tint1 == 7) tstr1 =  '</color>' + Format(CT(\"Script.Mod_ShuKlissan.166\"),\"<0>\",coal_ships,\"<1>\",domik_ships,\"<2>\",pirate_ships,\"<3>\",klissan_ships,\"<4>\",tstr2);",
                        "}",
                        "else",
                        "{",
                        "    if(tint1 == 1) tstr1 = '</color>' + Format(CT(\"Script.Mod_ShuKlissan.153\"),\"<0>\",coal_ships,\"<1>\",domik_ships,\"<2>\",pirate_ships);",
                        "    else if(tint1 == 2) tstr1 = '</color>' + Format(CT(\"Script.Mod_ShuKlissan.154\"),\"<0>\",coal_ships,\"<1>\",domik_ships,\"<2>\",pirate_ships);",
                        "    else if(tint1 == 3) tstr1 = '</color>' + Format(CT(\"Script.Mod_ShuKlissan.155\"),\"<0>\",coal_ships,\"<1>\",domik_ships,\"<2>\",pirate_ships,\"<3>\",tstr2,\"<4>\",tstr3);",
                        "    else if(tint1 == 4) tstr1 = '</color>' + Format(CT(\"Script.Mod_ShuKlissan.156\"),\"<0>\",coal_ships,\"<1>\",domik_ships,\"<2>\",pirate_ships,\"<3>\",tstr2,\"<4>\",tstr3);",
                        "    else if(tint1 == 5) tstr1 = '</color>' + Format(CT(\"Script.Mod_ShuKlissan.157\"),\"<0>\",coal_ships,\"<1>\",domik_ships,\"<2>\",pirate_ships,\"<3>\",tstr2,\"<4>\",tstr3);",
                        "    else if(tint1 == 6) tstr1 = '</color>' + Format(CT(\"Script.Mod_ShuKlissan.158\"),\"<0>\",coal_ships,\"<1>\",domik_ships,\"<2>\",pirate_ships,\"<3>\",tstr2);",
                        "    else if(tint1 == 7) tstr1 = '</color>' + Format(CT(\"Script.Mod_ShuKlissan.159\"),\"<0>\",coal_ships,\"<1>\",domik_ships,\"<2>\",pirate_ships,\"<3>\",tstr2);",
                        "}",
                        "DChange(77);",
                        "exit;"
