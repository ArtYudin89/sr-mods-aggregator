                },
                {
                    "Name": "",
                    "Code.Type": "Turn",
                    "Code": [
                        "if(attack_type == 1)",
                        "{",
                        "    tint2 = ShipSkill(Player(), 'LeadershipCur');",
                        "    //Добавляем ответы с выбором числа наёмников, которых игрок может нанять для атаки",
                        "    for(i = 3; i <= 10; i = i + 1)",
                        "    {",
                        "        if(i == 3) tstr1 = CT(\"Script.Mod_ShuMercs.127\");",
                        "        else if(i == 4) tstr1 = CT(\"Script.Mod_ShuMercs.128\");",
                        "        else if(i == 5) tstr1 = CT(\"Script.Mod_ShuMercs.129\");",
                        "        else if(i == 6) tstr1 = CT(\"Script.Mod_ShuMercs.130\");",
                        "        else if(i == 7) tstr1 = CT(\"Script.Mod_ShuMercs.132\");",
                        "        else if(i == 8) tstr1 = CT(\"Script.Mod_ShuMercs.131\");",
                        "        else if(i == 9) tstr1 = CT(\"Script.Mod_ShuMercs.134\");",
                        "        else if(i == 10) tstr1 = CT(\"Script.Mod_ShuMercs.133\");",
                        "",
                        "        //Запоминаем требование к навыку лидерства игрока",
                        "        if(i < 9) tint3 = 5;",
                        "        else tint3 = 6;",
                        "",
                        "        if((tint2 * 2) >= i && Soldats >= i) InjectAnswer('AttackMBChoose', tstr1, i);",
                        "        else",
