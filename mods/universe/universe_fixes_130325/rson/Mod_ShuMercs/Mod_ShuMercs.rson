                    "Code": [
                        "if(!PlayerBridge()) {",
                        "  tstr1 = '';",
                        "  for(i = HeadBountyList['TargetsCount'] - 1; i >= 0; i = i - 1)",
                        "  {",
                        "      if(HeadBountyList['TargetsId', i] > 0)",
                        "      {",
                        "          dword target_temp2 = IdToShip(HeadBountyList['TargetsId', i]);",
                        "          if(!target_temp2) throw 'No ship found by Id' + HeadBountyList['TargetsId', i];",
