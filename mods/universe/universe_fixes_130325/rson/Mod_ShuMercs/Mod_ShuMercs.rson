                {
                    "Name": "",
                    "Code.Type": "Turn",
                    "Code": [
                        "coef2 = 95;",
                        "//\"Я мистер Шу, и мне вообще похуЮ на качество диалогов и иммерсивность игры\"",
                        "//\"Поэтому я прямо в реплики персонала ЦН добавлю указание на навык лидерства игрока, см. ниже\";",
