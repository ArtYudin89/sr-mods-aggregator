                    "Pos.x": 130,
                    "Pos.y": 595
                },
                {
                    "Name": "",
                    "Code.Type": "Turn",
                    "Code": [
                        "if(Soldats >= 3 && Squad != 2 && Squad && ShipSkill(Player(), 'LeadershipCur') >= 2 &&",
                        "(ShipRank(Player()) >= 3 || GetShipPirateRank(Player()) >= 3)) {",
                        "  if(CurTurn() >= timer_attack) {",
                        "    DAdd(5);",
                        "  }",
                        "  if(CurTurn() < timer_attack) {",
                        "    DAdd(51);",
                        "  }",
                        "}",
                        "DAdd(6);",
                        "if(Soldats >= 3 && Squad != 1 &&",
                        "(ShipRank(Player()) >= 1 || GetShipPirateRank(Player()) >= 1)) {",
                        "  if(Squad == 3) i = timer_raid + 60;",
                        "  else i = timer_raid;",
                        "  if(CurTurn() >= i) {",
                        "    DAdd(8);",
                        "  }",
                        "  if(CurTurn() < i) {",
                        "    DAdd(50);",
                        "  }",
                        "}",
                        "DAdd(4);",
                        "DAdd(0);"
                    ],
