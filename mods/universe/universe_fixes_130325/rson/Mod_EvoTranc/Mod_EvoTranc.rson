                        "              {",
                        "                  if(GalaxyEventData(i,0)==t_Transport)",
                        "                  {",
                        "                      xp_add=expArr[1]*modifier[ShipSkill(Player(),5)]*(900+GalaxyDiffLevels())/(200000+0.2*GetShipExpByType(Player(),3));",
