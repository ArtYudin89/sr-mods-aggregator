                        "              else",
                        "              {",
                        "                  //Чекаем пиратскую расу, если игрок убивает \"мирных\", играя за Коалицию",
                        "                  if(GalaxyEventData(i, 3) == 7)",
                        "                  {",
                        "                      if(GalaxyEventData(i, 0) == t_Transport)",
