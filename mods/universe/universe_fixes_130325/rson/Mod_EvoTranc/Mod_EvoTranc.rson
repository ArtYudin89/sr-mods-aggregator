                        "    if(tempDwd == cur_Tranc) continue;",
                        "",
                        "    ShipCustomShipInfoData(tempDwd, temp_int_6, 1, 0);",
                        "    ShipCustomShipInfoTextData(tempDwd, temp_int_6, 3, '');",
                        "    OrderForsage(tempDwd, 0);",
                        "    ShipOut(tempDwd);",
                        "}"
                    ],
