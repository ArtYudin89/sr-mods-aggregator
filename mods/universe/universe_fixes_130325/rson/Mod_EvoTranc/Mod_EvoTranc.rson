                    "Code": [
                        "tstr1 = '</color>' + Format(CT('Script.Mod_EvoTranc.NPCsTrancTalks.NormalRelation'), '<Ship'+'>', ShipName(tempDwd) + '<Object=' + tempDwd + ',23,17,0>');",
                        "DChange(30);",
