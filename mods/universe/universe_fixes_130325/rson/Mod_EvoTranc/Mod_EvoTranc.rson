                        "{",
                        "    if(GetGameOptions('FontDialog') >= 2) temp_str = temp_str + CT(\"Script.Mod_EvoTranc.853\");",
                        "    else temp_str = temp_str + CT(\"Script.Mod_EvoTranc.848\");",
                        "    TextCorr = '<color=45,105,45>' + CT(\"Script.Mod_EvoTranc.800\") + '</color>';",
                        "}",
                        "else",
                        "{",
                        "    if(GetGameOptions('FontDialog') >= 2) temp_str = temp_str + CT(\"Script.Mod_EvoTranc.854\");",
                        "    else temp_str = temp_str + CT(\"Script.Mod_EvoTranc.847\");",
                        "    TextCorr = '<color=255,0,0>' + CT(\"Script.Mod_EvoTranc.798\") + '</color>';",
