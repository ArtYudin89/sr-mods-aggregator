                    "Code": [
                        "tstr1 = '</color>' + Format(CT('Script.Mod_EvoTranc.NPCsTrancTalks.HostileRelation'), '<Ship'+'>', ShipName(tempDwd) + '<Object=' + tempDwd + ',23,17,0>');",
                        "DChange(33);",
