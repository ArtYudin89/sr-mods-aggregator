                        "                      xp_add = (xp_add * expArr[cur_Tranc]) / (200000 + 0.2 * GetShipExpByType(Player(), 1));",
                        "                      ShipFreeExp(Player(), ShipFreeExp(Player()) + xp_add);",
                        "                      SetShipExpByType(Player(), GetShipExpByType(Player()) + xp_add, 0);",
                        "                  }",
                        "                  else continue;",
                        "              }",
