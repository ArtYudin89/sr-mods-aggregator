                        "//Режим разрешений для автоматической заправки транклюкатора",
                        "if(ShipCustomShipInfoTextData(cur_Tranc, temp_int_4, 2) == 'False')",
                        "{",
                        "    temp_str = temp_str + Format('<br>') + CT(\"Script.Mod_EvoTranc.797\");",
                        "    TextCorr2 = '<color=45,105,45>' + CT(\"Script.Mod_EvoTranc.796\") + '</color>';",
                        "}",
                        "else",
                        "{",
                        "    temp_str = temp_str + Format('<br>') + CT(\"Script.Mod_EvoTranc.795\") + '</color>';",
                        "    TextCorr2 = '<color=255,0,0>' + CT(\"Script.Mod_EvoTranc.794\") + '</color>';",
                        "}",
                        "//Режим разрешений для автоматического пополнения боезапаса транклюкатора",
                        "if(!ShipCustomShipInfoData(cur_Tranc,temp_int_4,3))",
                        "{",
                        "    temp_str = temp_str + Format('<br>') + CT(\"Script.Mod_EvoTranc.868\");",
                        "    TextCorr3 = '<color=45,105,45>' + CT(\"Script.Mod_EvoTranc.870\") + '</color>';",
                        "}",
                        "else",
                        "{",
                        "    temp_str = temp_str + Format('<br>') + CT(\"Script.Mod_EvoTranc.866\") + '</color>';",
                        "    TextCorr3 = '<color=255,0,0>' + CT(\"Script.Mod_EvoTranc.869\") + '</color>';",
                        "}",
                        "",
                        "//Электронный кошелёк транклюкатора",
                        "temp_str = temp_str + Format('<br>') + Format(CT(\"Script.Mod_EvoTranc.860\"),\"<0>\",ShipCustomShipInfoData(cur_Tranc,temp_int_4,2));",
                        "TextCorr4 = CT(\"Script.Mod_EvoTranc.792\");",
                        "TextCorr5 = CT(\"Script.Mod_EvoTranc.791\");",
                        "DChange(27);",
                        "exit;"
