                        "        {",
                        "            ArrayAdd(hangar_trancs, cur_Tranc);",
                        "            tNumber = tNumber + 1;",
                        "        }",
                        "    }",
                        "}",
                        "",
                        "for(i = 0; i < ShipArts(Player()); i = i + 1)",
                        "{",
                        "    cur_Tranc = ShipArts(Player(),i);",
                        "    if(ItemType(cur_Tranc) == t_ArtefactTranclucator)",
                        "    {",
                        "        if(ShipType(ArtTranclucatorToShip(cur_Tranc)) == 'Tranclucator') //Пропускаем \"фиктивных\", поддельных транков в трюме игрока",
                        "        {",
                        "            ArrayAdd(hold_trancs, cur_Tranc);",
                        "            tNumber = tNumber + 1;",
                        "        }",
                        "    }",
                        "}",
                        "if(!tNumber) {",
                        "  DChange(7);",
                        "  exit;",
                        "}",
                        "if(tNumber > 1) {",
                        "  DChange(4);",
                        "  exit;",
                        "}",
                        "if(tNumber == 1) {",
                        "  if(ArrayDim(hangar_trancs)>1)",
