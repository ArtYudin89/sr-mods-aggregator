                    "Pos.y": 765,
                    "Type": "TDialogAnswer",
                    "Parent": -1,
                    "#": 173,
                    "Msg": "Ага. Поехали!",
                    "AMsg.Num": "12",
                    "_orig_danswer": "DAnswer(CT(\"Script.Mod_ShuDomiks.69\"))"
                },
                {
                    "Name": "",
