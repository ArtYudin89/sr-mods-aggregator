                {
                    "Name": "",
                    "Code.Type": "Turn",
                    "Code": [
                        "if(DomiksDefeated(1)==1) { //Верфь самоуничтожается при уничтожении Келлера программой",
                        "    ShipDestroy(CurShip);",
                        "    exit;",
                        "}",
                        "starDomiks=25+round(0.8*GeneralDiffLevel*4); //Максимум доминаторов в системе с верфью",
                        "spawnChance=15-GeneralDiffLevel; //Шанс на появление нового доминатора с верфи",
                        "if(StarShips(ShipStar(CurShip)) < starDomiks) { //Повышаем число доминаторов в системе",
                        "    if(!Rnd(0, spawnChance)) {",
                        "        cur_ship=BuyDomikExtremal(NearCivilPlanet(CurShip));",
                        "        OrderTakeOff(cur_ship);",
                        "        ShipSetCoords(cur_ship, CoordX(CurShip), CoordY(CurShip));",
                        "    }",
                        "}",
                        "if(CountIn(Trancs1, ShipStar(CurShip))<5) { //Спавним транклюкаторов верфи до 5 штук",
                        "    cur_ship=BuyDomikExtremal(NearCivilPlanet(CurShip), 5);",
                        "    Chameleon(cur_ship, 'Ship.TranclucatorBlue');",
                        "    ArrangeItems(cur_ship);",
                        "    ShipType(cur_ship, 'DomTrank');",
                        "    OrderTakeOff(cur_ship);",
                        "    ShipSetCoords(cur_ship, CoordX(CurShip), CoordY(CurShip));",
                        "    ShipJoin(Trancs1, cur_ship);",
                        "}",
                        "if(ShuDomiksSuperInit) {",
                        "    if(KellerBertorsTimer<=CurTurn()) { //Делаем проверку на спавн супердоминатора бертора",
                        "        if(GroupCount(KellerBertors)<2) { //Если лимит супердоминаторов берторов ещё не превышен",
                        "            if(KellerBertorsTimer) { //Таймер уже был взведён и отсчитал нужное время",
                        "                check=0;",
                        "                cur_star=ShipStar(CurShip);",
                        "                for(i=0; i<StarShips(cur_star); i=i+1) {",
                        "                    cur_ship=StarShips(cur_star, i);",
                        "                    if(ShipOwner(cur_ship)!=Kling) continue;",
                        "                    if(ShipSubType(cur_ship==6)) {",
                        "                        check=1;",
                        "                        break;",
                        "                    }",
                        "                }",
                        "                if(!check) {",
                        "                    cur_ship=BuySuperdominator(NearCivilPlanet(CurShip), 6, 'Keller'); //Спавним супердоминатора бертора",
                        "                    ShipSetCoords(cur_ship, CoordX(CurShip), CoordY(CurShip));",
                        "                    ShipJoin(KellerBertors, cur_ship);",
                        "                    if(GroupCount(KellerBertors)<2) KellerBertorsTimer=CurTurn()+Rnd(1241, 1679); //Перезапускаем таймер",
                        "                    else KellerBertorsTimer=0; //Либо обнуляем его, если число берторов уже и так максимально",
                        "                }",
                        "            }",
                        "            else KellerBertorsTimer=CurTurn()+Rnd(1241, 1679); //Ранее таймер взведён не был, значит один из берторов погиб только что",
                        "        }",
                        "        else KellerBertorsTimer=0;",
                        "    }",
                        "    if(KellerSupersTimer<=CurTurn()) { //Делаем проверку на спавн супердоминатора",
                        "        maxSupers=CalculateMaxSupers(1);",
                        "        if(GroupCount(KellerSupers)<maxSupers) { //Если лимит супердоминаторов ещё не превышен",
                        "            if(KellerSupersTimer) { //Таймер уже был взведён и отсчитал нужное время",
                        "                for(i=0; i<Rnd(1,3); i=i+1) {",
                        "                    cur_ship=BuySuperdominator(NearCivilPlanet(CurShip),Rnd(1,5),'Keller'); //Спавним супердоминатора",
                        "                    ShipSetCoords(cur_ship,CoordX(CurShip),CoordY(CurShip));",
                        "                    ShipJoin(KellerSupers,cur_ship);",
                        "                    if(GroupCount(KellerSupers)<maxSupers) KellerSupersTimer=CurTurn()+Rnd(310, 420); //Перезапускаем таймер",
                        "                    else KellerSupersTimer=0; //Либо обнуляем его, если число супердоминаторов уже и так максимально",
                        "                }",
                        "            }",
                        "            else KellerSupersTimer=CurTurn()+Rnd(310, 420); //Ранее таймер взведён не был, значит один из супердоминаторов погиб только что",
                        "        }",
                        "        else KellerSupersTimer=0;",
                        "    }",
                        "}"
