                    "Type": "TDialogAnswer",
                    "Parent": -1,
                    "#": 195,
                    "Msg": "На мостик",
                    "AMsg.Num": "34",
                    "_orig_danswer": "DAnswer('restart~'+CT(\"Script.Mod_ShuDomiks.90\"))"
                },
                {
                    "Name": "block",
                    "Pos.x": 600,
                    "Pos.y": 815,
                    "Type": "TDialogAnswer",
                    "Parent": -1,
                    "#": 196,
                    "Msg": "Ага. Поехали!",
                    "AMsg.Num": "35",
                    "_orig_danswer": "DAnswer('block~'+CT(\"Script.Mod_ShuDomiks.69\"))"
                },
                {
                    "Name": "block",
                    "Pos.x": 720,
                    "Pos.y": 815,
                    "Type": "TDialogAnswer",
                    "Parent": -1,
                    "#": 197,
                    "Msg": "Я заплачу зеленым стажерам!",
                    "AMsg.Num": "36",
                    "_orig_danswer": "DAnswer('block~'+CT(\"Script.Mod_ShuDomiks.62\"))"
                },
                {
                    "Name": "block",
