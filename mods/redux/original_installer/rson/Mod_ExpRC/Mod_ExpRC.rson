                },
                {
                    "Name": "",
                    "Code.Type": "Turn",
                    "Code": [
                        "//Считаем сколько неизвестных ММ сдал игрок (и удаляем их из трюма)",
                        "int0 = 0;",
                        "for(i = ShipItems(Player()) - 1; i > 0; i = i - 1)",
                        "{",
                        "\tdwd0 = ShipItems(Player(), i);",
                        "\tif(ItemType(dwd0) != t_UselessCountableItem) continue;",
                        "\tif(EquipmentImageName(dwd0) != 'Mod_ExpRC_UnknownMM') continue;",
                        "\tint0 = int0 + ItemSize(dwd0);",
                        "\tFreeItem(GetItemFromShip(Player(), i));",
                        "}",
                        "",
                        "//Переходим к выдаче уникальных наградных ММ",
                        "if(mmTake > -1) mmTake = mmTake + int0;",
                        "//mmTake = mmTake + int0; //Для продолжения выдачи уникальных ММ по второму кругу после получения 5-го модуля",
                        "RangerBaseNodes(Player(), RangerBaseNodes(Player()) + (int0 * UnknownMMReward));",
                        "Sound('Sound.Sell');",
                        "str0 = '';",
                        "if(mmTake > 24)",
                        "{",
                        "\tk = int(mmTake / 25);",
                        "\tmmTake = mmTake - (25 * k);",
                        "\tstr3 = '';",
                        "\tfor(k = k; k > 0; k = k - 1)",
                        "\t{",
                        "        if(mmTake == -1) break;",
                        "\t\tif(BonMMRand4 == -1 || BonMMRand3 == -1 || BonMMRand2 == -1 || BonMMRand1 == -1)",
                        "\t\t{",
                        "\t\t\ti = Rnd(0, 3);",
                        "\t\t\t//Бросаем \"кости\" до тех пор, пока не выпадет ещё не выдававшийся ММ",
                        "\t\t\twhile(i == BonMMRand1 || i == BonMMRand2 || i == BonMMRand3) i = Rnd(0, 3);",
                        "\t\t\tdwd0 = CreateMM(FindBonusByCustomTag('Mod_ExpRC' + i));",
                        "\t\t\tBonMMRand4 = BonMMRand3;",
                        "\t\t\tBonMMRand3 = BonMMRand2;",
                        "\t\t\tBonMMRand2 = BonMMRand1;",
                        "\t\t\tBonMMRand1 = i;",
                        "\t\t\tItemOwner(dwd0, ShipOwner(GetShipRuins(Player())));",
                        "\t\t\tAddItemToShip(Player(), dwd0);",
                        "\t\t\tstr1 = BonusName(FindBonusByCustomTag('Mod_ExpRC' + i));",
                        "\t\t\tstr2 = BonusText(FindBonusByCustomTag('Mod_ExpRC' + i));",
                        "\t\t\tstr3 = str3 + CT(\"Script.Mod_ExpRC.79\") + DefSplt + CT(\"Script.Mod_ExpRC.80\") + str1 + '<clrEnd>' + CT(\"Script.Mod_ExpRC.79\") + str2;",
                        "\t\t}",
                        "\t\telse if(mmTake > -1)",
                        "\t\t{",
                        "\t\t\tdwd0 = CreateMM(FindBonusByCustomTag('Mod_ExpRC4'));",
                        "\t\t\tItemOwner(dwd0, ShipOwner(GetShipRuins(Player())));",
                        "\t\t\tAddItemToShip(Player(), dwd0);",
                        "\t\t\tstr1 = BonusName(FindBonusByCustomTag('Mod_ExpRC4'));",
                        "\t\t\tstr2 = BonusText(FindBonusByCustomTag('Mod_ExpRC4'));",
                        "\t\t\tstr3 = str3 + CT(\"Script.Mod_ExpRC.79\") + DefSplt + CT(\"Script.Mod_ExpRC.80\") + str1 + '<clrEnd>' + CT(\"Script.Mod_ExpRC.79\") + str2;",
                        "\t\t\tBonMMRand4 = -1;",
                        "\t\t\tBonMMRand3 = -1;",
                        "\t\t\tBonMMRand2 = -1;",
                        "\t\t\tBonMMRand1 = -1;",
                        "            //Блокируем дальнейшую выдачу уникальных ММ",
                        "\t\t\tmmTake = -1;",
                        "\t\t}",
                        "\t}",
                        "\tstr0 = '</color>' + CT(\"Script.Mod_ExpRC.86\") + str3;",
                        "\tstr1 = '';",
                        "\tstr2 = '';",
                        "\tstr3 = '';",
                        "}",
                        "DChange(11);",
                        "exit;"
                    ],
