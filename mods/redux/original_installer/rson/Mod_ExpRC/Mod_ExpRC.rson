                        "            //Добавляем подмену оригинального диалога для приобретения новых ММ",
                        "            AddDialogBlock(CT('FormRuins.RC.TakeNod.PlayerSend'), 2);",
                        "            AddDialogInject('BuyNewMM', '', CT('FormRuins.RC.TakeNod.PlayerSendMod'), 0);",
