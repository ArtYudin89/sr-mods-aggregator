            "Items": [],
            "Operations": [
                {
                    "Name": "",
                    "Code.Type": "Global",
                    "Code": [
                        "GRun();"
                    ],
                    "#": 38,
                    "Type": "Top",
                    "Parent": -1,
                    "Pos.x": 0,
                    "Pos.y": 685
                },
                {
                    "Name": "",
                    "Code.Type": "Init",
                    "Code": [
                        "array0 = newarray(1);",
                        "array1 = newarray(1);",
                        "mm_storage = newarray(1);",
                        "mm_storage_name = newarray(1);",
                        "mmTake = 0;",
                        "BonMMRand1 = -1;",
                        "BonMMRand1 = -1;",
                        "if(CT('ExpRC.ExpRCRebootMMChain')) ExpRCRebootMMChainInit = 1;  //Флаг выдачи ММ без повторов",
                        "//Раздаём доминаторам неизвестные ММ, а также вешаем спец. инфошки на ЦР на старте скрипта",
                        "//Ищем все корабли в Галактике, после чего начинаем их подробный перебор",
                        "i = BuildListOfNewShips(array0, lastShipId, 1, 32, 1, '');",
                        "if(i)",
                        "{",
                        "\tfor(i = 0; i < ArrayDim(array0); i = i + 1)",
                        "\t{",
                        "\t\tdwd1 = array0[i];",
                        "",
                        "\t\tif(ShipInScript(dwd1)) continue; //Исключаем скриптовые корабли",
                        "",
                        "        j = ShipSubType(dwd1);",
                        "\t\tif(j == 0) continue; //Исключаем боссов",
                        "\t\tif(j == 7) continue; //Исключаем клигов",
                        "",
                        "\t\tif(Rnd(1, 100) > 9) continue; //9% шанс на то, что доминатор при смерти дропнет неизвестный микромодуль",
                        "",
                        "\t\tdwd2 = CreateCustomCountableItem('Mod_ExpRC_UnknownMM', 1, 1);",
                        "\t\tItemOwner(dwd2, 5);",
                        "\t\tItemSubrace(dwd2, ItemSubrace(ShipItems(dwd1, 0)));",
                        "\t\tShipAddDropItem(dwd1, dwd2);",
                        "\t}",
                        "}",
                        "lastShipId = GalaxyShipId();",
                        "",
                        "//Функция для вывода и обновления уведомлений с хранилищем микромодулей",
                        "function MMStorageEther()",
                        "{",
                        "\tif(ArrayDim(mm_storage) >= 2)",
                        "\t{",
                        "\t\t//Проверка на количество ММ, если больше 38 - запускаем счётчик страниц уведомлений",
                        "\t\tif(ArrayDim(mm_storage) <= 39)",
                        "\t\t{",
                        "\t\t\tfor(k = 1; k <= CountMMStor; k = k + 1)",
                        "\t\t\t{",
                        "\t\t\t\tEtherDelete('WJ5TB-BJSZJ-TFB6W-JTJJJ-3Z3CB-' + k);",
                        "\t\t\t\tCountMMStorBac = -1;",
                        "\t\t\t}",
                        "\t\t\t//^ выше происходит удаление всех номерных уведомлений (если они были)",
                        "\t\t\tLStorageMsg = CT(\"Script.Mod_ExpRC.59\") + CT('FormInfo.td_otstup_price') + CT(\"Script.Mod_ExpRC.57\");",
                        "\t\t\tLStorageMsg = LStorageMsg + CT('FormInfo.br') + '<color=127,127,127>--------------------------------------------------------------------------------------------------</color>';",
                        "\t\t\tLStorageMsg = LStorageMsg + CT('FormInfo.br') + CT('FormInfo.td_margin_center') + CT(\"Script.Mod_ExpRC.56\") + CT('FormInfo.br');",
                        "\t\t\tLStorageMsg = LStorageMsg + '<color=127,127,127>--------------------------------------------------------------------------------------------------</color>';",
                        "\t\t\tfor(j = 1; j < ArrayDim(mm_storage); j = j + 1)",
                        "\t\t\t{",
                        "\t\t\t\tLStorageMsg = LStorageMsg+CT('FormInfo.br') + '- ' + mm_storage_name[j];",
                        "\t\t\t\tint1 = ItemCost(IdToItem(substr(mm_storage[j], 7)));",
                        "\t\t\t\tif(int1 <= 9) str3 = 'td_margin_cost_0';",
                        "\t\t\t\telse if(int1 > 9 && int1 < 100) str3 = 'td_margin_cost_00';",
                        "\t\t\t\telse if(int1 > 99 && int1 < 1000) str3 = 'td_margin_cost_000';",
                        "\t\t\t\telse if(int1 > 999 && int1 < 10000) str3 = 'td_margin_cost_0000';",
                        "\t\t\t\telse if(int1 > 9999 && int1 < 100000) str3 = 'td_margin_cost_00000';",
                        "\t\t\t\telse if(int1 > 99999 && int1 < 1000000) str3 = 'td_margin_cost_000000';",
                        "\t\t\t\telse if(int1 > 999999 && int1 < 10000000) str3 = 'td_margin_cost_0000000';",
                        "\t\t\t\telse if(int1 > 9999999 && int1 < 100000000) str3 = 'td_margin_cost_00000000';",
                        "\t\t\t\telse if(int1 > 99999999 && int1 < 1000000000) str3 = 'td_margin_cost_000000000';",
                        "\t\t\t\tLStorageMsg = LStorageMsg + CT('FormInfo.' + str3) + '<color=0,255,255>' + int1 + '</color>';",
                        "\t\t\t}",
                        "\t\t\tLStorageMsg = LStorageMsg + CT('FormInfo.br');",
                        "\t\t\t//Не считая последней цифры в конце - весь этот сложный ID является SHiFT кодом... пасхалочка",
                        "\t\t\tCustomEther('MMStorage', 9, 'WJ5TB-BJSZJ-TFB6W-JTJJJ-3Z3CB-0', LStorageMsg);",
                        "\t\t}",
                        "\t\t//Обработчик добавления номерных уведомлений, если количество ММ в хранилище превышает 38",
                        "\t\tif(ArrayDim(mm_storage) > 39)",
                        "\t\t{",
                        "\t\t\tEtherDelete('WJ5TB-BJSZJ-TFB6W-JTJJJ-3Z3CB-0');",
                        "\t\t\t//^ выше происходит удаление предыдущего не номерного (0) уведомления",
                        "\t\t\tint3 = int(ArrayDim(mm_storage) / 38);",
                        "\t\t\tint3 = (38 * (int3 + 1)) + 1;",
                        "\t\t\tCountMMStor = 1;",
                        "\t\t\tfor(k = 39; k <= int3; k = k + 38)",
                        "\t\t\t{",
                        "\t\t\t\tif(k > ArrayDim(mm_storage)) int2 = ArrayDim(mm_storage);",
                        "\t\t\t\tif(k <= ArrayDim(mm_storage)) int2 = k;",
                        "\t\t\t\tLStorageMsg = CT(\"Script.Mod_ExpRC.58\") + CountMMStor + '</color><color=0,255,0>)</color>' + CT('FormInfo.td_otstup_price') + CT(\"Script.Mod_ExpRC.57\");",
                        "\t\t\t\tLStorageMsg = LStorageMsg + CT('FormInfo.br')+'<color=127,127,127>--------------------------------------------------------------------------------------------------</color>';",
                        "\t\t\t\tLStorageMsg = LStorageMsg + CT('FormInfo.br') + CT('FormInfo.td_margin_center') + CT(\"Script.Mod_ExpRC.56\") + CT('FormInfo.br');",
                        "\t\t\t\tLStorageMsg = LStorageMsg + '<color=127,127,127>--------------------------------------------------------------------------------------------------</color>';",
                        "\t\t\t\tfor(j = k - 38; j < int2; j = j + 1)",
                        "\t\t\t\t{",
                        "\t\t\t\t\tLStorageMsg = LStorageMsg + CT('FormInfo.br') + '- ' + mm_storage_name[j];",
                        "\t\t\t\t\tint1 = ItemCost(IdToItem(substr(mm_storage[j], 7)));",
                        "\t\t\t\t\tif(int1 <= 9) str3 = 'td_margin_cost_0';",
                        "\t\t\t\t\telse if(int1 > 9 && int1 < 100) str3 = 'td_margin_cost_00';",
                        "\t\t\t\t\telse if(int1 > 99 && int1 < 1000) str3 = 'td_margin_cost_000';",
                        "\t\t\t\t\telse if(int1 > 999 && int1 < 10000) str3 = 'td_margin_cost_0000';",
                        "\t\t\t\t\telse if(int1 > 9999 && int1 < 100000) str3 = 'td_margin_cost_00000';",
                        "\t\t\t\t\telse if(int1 > 99999 && int1 < 1000000) str3 = 'td_margin_cost_000000';",
                        "\t\t\t\t\telse if(int1 > 999999 && int1 < 10000000) str3 = 'td_margin_cost_0000000';",
                        "\t\t\t\t\telse if(int1 > 9999999 && int1 < 100000000) str3 = 'td_margin_cost_00000000';",
                        "\t\t\t\t\telse if(int1 > 99999999 && int1 < 1000000000) str3 = 'td_margin_cost_000000000';",
                        "\t\t\t\t\tLStorageMsg = LStorageMsg + CT('FormInfo.' + str3) + '<color=0,255,255>' + int1 + '</color>';",
                        "\t\t\t\t}",
                        "\t\t\t\tLStorageMsg = LStorageMsg + CT('FormInfo.br');",
                        "\t\t\t\tCustomEther('MMStorage', 9, 'WJ5TB-BJSZJ-TFB6W-JTJJJ-3Z3CB-' + CountMMStor, LStorageMsg);",
                        "\t\t\t\tCountMMStor = CountMMStor + 1;",
                        "\t\t\t}",
                        "\t\t\t//Проверка на наличие лишнего (пустого) номерного уведомления и его удаление",
                        "\t\t\t//Если CountMMStorBac равна -1, значит на панели вообще нет номерных уведомлений",
                        "\t\t\tif(CountMMStorBac != -1)",
                        "\t\t\t{",
                        "\t\t\t\tif(int((ArrayDim(mm_storage) - 2) / 38) + 1 < CountMMStorBac) EtherDelete('WJ5TB-BJSZJ-TFB6W-JTJJJ-3Z3CB-' + (CountMMStor - 1));",
                        "\t\t\t}",
                        "\t\t\tCountMMStorBac = CountMMStor - 1;",
                        "\t\t}",
                        "\t}",
                        "}"
                    ],
                    "#": 39,
                    "Type": "Top",
                    "Parent": -1,
                    "Pos.x": 60,
                    "Pos.y": 685
                },
                {
                    "Name": "",
                    "Code.Type": "Turn",
                    "Code": [
                        "if(!ShipIsTakeoff(Player())) {",
                        "  if(!ExpRCRebootMMChainInit) //Флаг выдачи ММ без повторов",
                        "  {",
                        "      if(CT('ExpRC.ExpRCRebootMMChain')) ExpRCRebootMMChainInit = 1;",
                        "  }",
                        "  //Проверяем, что текущий тёрн не сработал второй раз за ход (что изредка бывает, один даб знает почему)",
                        "  if(CurTurn() != lastRun) {",
                        "      lastRun = CurTurn();",
                        "      for(i = GalaxyEvents() - 1; i > -1; i = i - 1) {",
                        "      \tif(GalaxyEventDate(i) < CurTurn()) break;",
                        "          if(GalaxyEventType(i) == 'RuinsDestroyed') { //Была уничтожена станция, проверяем, что это не ЦР",
                        "      \t\tif(ArrayDim(mm_storage) < 2) continue;",
                        "      \t\tfor(j = 0; j < GalaxyStars(); j = j + 1) {",
                        "      \t\t   int0 = StarRuins(GalaxyStar(j), 'RC');",
                        "      \t\t   if(int0) break;",
                        "      \t\t}",
                        "      \t\tif(!int0) {",
                        "      \t\t\tfor(j = 1; j < ArrayDim(mm_storage); j = j + 1) {",
                        "      \t\t\t\tFreeItem(GetItemFromVault(mm_storage[j]));",
                        "      \t\t\t}",
                        "      \t\t\tArrayClear(mm_storage);",
                        "      \t\t\tArrayClear(mm_storage_name);",
                        "      \t\t\tEtherDelete('WJ5TB-BJSZJ-TFB6W-JTJJJ-3Z3CB-0');",
                        "      \t\t\tfor(k = 1; k <= CountMMStor; k = k + 1) {",
                        "      \t\t\t\tEtherDelete('WJ5TB-BJSZJ-TFB6W-JTJJJ-3Z3CB-' + k);",
                        "      \t\t\t\tCountMMStorBac = -1;",
                        "      \t\t\t}",
                        "      \t\t\tif(RangerBaseNodes(Player()) == 0) NewsAdd(CT(\"Script.Mod_ExpRC.54\"));",
                        "      \t\t}",
                        "      \t\tint0 = 0;",
                        "      \t}",
                        "      \telse if(GalaxyEventType(i) == 'PlayerReceivesMMOnNewYear') { //Игрок получил ММ на новый год, помещаем его в хранилище",
                        "      \t\tdwd0 = IdToItem(GalaxyEventData(i, 0));",
                        "      \t\tif(dwd0) { //Если модуль ещё существует (иногда он может пропасть или быть перенесён в хранилище раньше)",
                        "      \t\t\tstr0 = 'Exp_RC_' + Id(dwd0);",
                        "      \t\t\tArrayAdd(mm_storage, str0);",
                        "      \t\t\tArrayAdd(mm_storage_name, ItemFullName(dwd0));",
                        "      \t\t\tPutItemInVault(str0, GetItemFromStorage(FindItemInStorage(dwd0)));",
                        "      \t\t    MMStorageEther();",
                        "      \t\t}",
                        "      \t}",
                        "      }",
                        "  }",
                        "  //Раздаём доминаторам неизвестные ММ при рождении новых кораблей",
                        "  if(GalaxyShipId() > lastShipId)",
                        "  {",
                        "      //Ищем все новорождённые корабли в Галактике, после чего начинаем их подробный перебор",
                        "  \ti = BuildListOfNewShips(array0, lastShipId, 1, 32, 1, '');",
                        "  \tif(i)",
                        "  \t{",
                        "  \t\tfor(i = 0; i < ArrayDim(array0); i = i + 1)",
                        "  \t\t{",
                        "  \t\t\tdwd1 = array0[i];",
                        "  ",
                        "  \t\t\tif(ShipInScript(dwd1)) continue; //Исключаем скриптовые корабли",
                        "  \t\t\tif(ShipSubType(dwd1) == 7) continue; //Исключаем клигов",
                        "  ",
                        "  \t\t\tif(Rnd(1, 100) > 5) continue; //5% шанс на то, что доминатор при смерти дропнет неизвестный микромодуль",
                        "  ",
                        "  \t\t\tdwd2 = CreateCustomCountableItem('Mod_ExpRC_UnknownMM', 1, 1);",
                        "  \t\t\tItemOwner(dwd2, 5);",
                        "  \t\t\tItemSubrace(dwd2, ItemSubrace(ShipItems(dwd1, 0)));",
                        "  \t\t\tShipAddDropItem(dwd1, dwd2);",
                        "  \t\t}",
                        "  \t}",
                        "  ",
                        "  \tlastShipId = GalaxyShipId();",
                        "  }",
                        "}"
                    ],
                    "#": 40,
                    "Type": "Top",
                    "Parent": -1,
                    "Pos.x": 120,
                    "Pos.y": 685
                },
                {
                    "Name": "",
                    "Code.Type": "DialogBegin",
                    "Code": [
                        "cur_ruin = GetShipRuins(Player());",
                        "if(cur_ruin)",
                        "{",
                        "\tif(ShipType(cur_ruin) == 'RC')",
                        "\t{",
                        "\t    if(GetGameOptions('FontDialog') == 0) DefSplt = '</color>-------------------------------------------------------------';",
                        "\t    else if(GetGameOptions('FontDialog') == 1) DefSplt = '</color>------------------------------------------';",
                        "\t    else if(GetGameOptions('FontDialog') == 2) DefSplt = '</color>-----------------------------------------';",
                        "\t    else DefSplt = '</color>-------------------------------------';",
                        "",
                        "\t\tAddDialogBlock(CT('FormRuins.RC.AboutNod.PlayerSend'), 2);",
                        "\t\tAddDialogBlock(CT('FormRuins.RC.PirateClan.PlayerSend'), 2);",
                        "\t\tAddDialogBlock(CT('FormRuins.RC.Rating.PlayerSend'), 2);",
                        "\t\tAddDialogBlock(CT('FormRuins.RC.BestRanger.PlayerSend'), 2);",
                        "\t\tAddDialogBlock('NodeStateInfoPosCorrection', 2);",
                        "\t\tAddDialogBlock(CT(\"Script.Mod_ExpRC.60\"), 2);",
                        "\t\tAddDialogInject('MM_storage', '', CT(\"Script.Mod_ExpRC.10\"), 1);",
                        "\t\tAddDialogInject('Info', '', CT(\"Script.Mod_ExpRC.11\"), 1);",
                        "",
                        "\t\tint0 = 0;",
                        "\t\tfor(i = 1; i < ShipItems(Player()); i = i + 1)",
                        "\t\t{",
                        "\t\t\tdwd0 = ShipItems(Player(), i);",
                        "\t\t\tif(ItemType(dwd0) != t_UselessCountableItem) continue;",
                        "\t\t\tif(EquipmentImageName(dwd0) != 'Mod_ExpRC_UnknownMM') continue;",
                        "\t\t\tint0 = 1;",
                        "\t\t\tbreak;",
                        "\t\t}",
                        "",
                        "\t\tif(int0 == 1) AddDialogInject('UniMM', '', CT(\"Script.Mod_ExpRC.27\"), 0);",
                        "\t\tAddDialogInject('X', Format(CT('FormRuins.RC.GreetingAddMod'), '#BaseNod#', RangerBaseNodes(Player())), 'NodeStateInfoPosCorrection', 0);",
                        "        if(ExpRCRebootMMChainInit)",
