                        "        if(AnsCount==1)AddDialogBlock(CT(\"Script.Mod_ExpRepair.82\"),1);",
                        "        if(AnsCount==1)InjectAnswer('Repair_TC_fix',CT(\"Script.Mod_ExpRepair.82\"),2);",
                        "        if(AnsCount>1)AddDialogBlock(CT(\"Script.Mod_ExpRepair.171\"),1);",
                        "        if(AnsCount>1)InjectAnswer('Repair_TC_fix',CT(\"Script.Mod_ExpRepair.171\"),2);",
                        "    }",
                        "}",
                        "if(nod_cost>0)",
                        "{",
                        "    //Маркер, что для нестандартного ремонта у игрока возможно не хватает нодов",
                        "    tint=temp_dword;",
                        "    if(ShipMoney(Player())<domik_wpn_cost)tint=1;",
                        "    if(tint==0)",
                        "    {",
                        "        if(AnsCount==1)InjectAnswer('Repair_TC_fix',CT(\"Script.Mod_ExpRepair.82\"),1);",
                        "        if(AnsCount>1)InjectAnswer('Repair_TC_fix',CT(\"Script.Mod_ExpRepair.170\"),1);",
                        "    }",
                        "    if(tint==1)",
                        "    {",
                        "        if(AnsCount==1)AddDialogBlock(CT(\"Script.Mod_ExpRepair.82\"),1);",
                        "        if(AnsCount==1)InjectAnswer('Repair_TC_fix',CT(\"Script.Mod_ExpRepair.82\"),1);",
                        "        if(AnsCount>1)AddDialogBlock(CT(\"Script.Mod_ExpRepair.170\"),1);",
                        "        if(AnsCount>1)InjectAnswer('Repair_TC_fix',CT(\"Script.Mod_ExpRepair.170\"),1);",
                        "    }",
                        "}",
