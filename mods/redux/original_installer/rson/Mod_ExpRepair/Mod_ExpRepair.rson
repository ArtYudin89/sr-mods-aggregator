                {
                    "Name": "",
                    "Code.Type": "Turn",
                    "Code": [
                        "tint=0;",
                        "temp_dword=0;",
                        "//Проверяем количество нодов в трюме, а если не хватает, то чекаем ещё и склад",
                        "if(nod_cost && GetNodesFromShip(Player())<nod_cost)",
                        "{",
                        "    nodes_count_total=0;",
                        "    for(i=0; i<StorageItems(); i=i+1)",
                        "    {",
                        "        if(ItemType(StorageItems(i))!=t_Protoplasm)continue;",
                        "        if(StorageItemLocation(i)==GetShipRuins(Player()))",
                        "        {",
                        "            nodes_count_total=nodes_count_total+ItemSize(StorageItems(i));",
                        "            ArrayAdd(nodes_count_array,StorageItems(i));",
                        "        }",
                        "    }",
                        "    if((GetNodesFromShip(Player())+nodes_count_total)<nod_cost)",
                        "    {",
                        "        tint=1;",
                        "        temp_dword=1;",
                        "    }",
                        "}",
                        "if(ShipMoney(Player())<total)tint=1;",
                        "if(!item_cost && !art_cost)tint=2;",
                        "if(!item_cost && !domik_wpn_cost)tint=2;",
                        "if(!art_cost && !domik_wpn_cost)tint=2;",
                        "//Определяем вариативность ремонта",
                        "if(item_cost)AnsCount=AnsCount+1;",
                        "if(nod_cost)AnsCount=AnsCount+1;",
                        "if(art_cost)AnsCount=AnsCount+1;",
                        "",
                        "if(tint==0)",
                        "{",
                        "    InjectAnswer('Repair_SB_fix',CT(\"Script.Mod_ExpRepair.184\"),4);",
                        "}",
                        "if(tint==1)",
                        "{",
                        "    AddDialogBlock(CT(\"Script.Mod_ExpRepair.184\"),1);",
                        "    InjectAnswer('Repair_SB_fix',CT(\"Script.Mod_ExpRepair.184\"),4);",
                        "}",
                        "if(item_cost)",
                        "{",
                        "    tint=0;",
                        "    if(ShipMoney(Player())<item_cost)tint=1;",
                        "    if(tint==0)",
                        "    {",
                        "        if(AnsCount==1)InjectAnswer('Repair_SB_fix',CT(\"Script.Mod_ExpRepair.82\"),2);",
                        "        if(AnsCount>1)InjectAnswer('Repair_SB_fix',CT(\"Script.Mod_ExpRepair.171\"),2);",
                        "    }",
                        "    if(tint==1)",
                        "    {",
                        "        if(AnsCount==1)",
                        "        {",
                        "            AddDialogBlock(CT(\"Script.Mod_ExpRepair.82\"),1);",
                        "            InjectAnswer('Repair_SB_fix',CT(\"Script.Mod_ExpRepair.82\"),2);",
                        "        }",
                        "        if(AnsCount>1)",
                        "        {",
                        "            AddDialogBlock(CT(\"Script.Mod_ExpRepair.171\"),1);",
                        "            InjectAnswer('Repair_SB_fix',CT(\"Script.Mod_ExpRepair.171\"),2);",
                        "        }",
                        "    }",
                        "}",
                        "if(nod_cost>0)",
                        "{",
                        "    //Маркер, что для нестандартного ремонта у игрока возможно не хватает нодов",
                        "    tint=temp_dword;",
                        "    if(ShipMoney(Player())<domik_wpn_cost)tint=1;",
                        "    if(tint==0)",
                        "    {",
                        "        if(AnsCount==1)InjectAnswer('Repair_SB_fix',CT(\"Script.Mod_ExpRepair.82\"),1);",
                        "        if(AnsCount>1)InjectAnswer('Repair_SB_fix',CT(\"Script.Mod_ExpRepair.170\"),1);",
                        "    }",
                        "    if(tint==1)",
                        "    {",
                        "        if(AnsCount==1)",
                        "        {",
                        "            AddDialogBlock(CT(\"Script.Mod_ExpRepair.82\"),1);",
                        "            InjectAnswer('Repair_SB_fix',CT(\"Script.Mod_ExpRepair.82\"),1);",
                        "        }",
                        "        if(AnsCount>1)",
                        "        {",
                        "            AddDialogBlock(CT(\"Script.Mod_ExpRepair.170\"),1);",
                        "            InjectAnswer('Repair_SB_fix',CT(\"Script.Mod_ExpRepair.170\"),1);",
                        "        }",
                        "    }",
                        "}",
                        "if(art_cost)",
                        "{",
                        "    tint=0;",
                        "    if(ShipMoney(Player())<art_cost)tint=1;",
                        "    if(tint==0)",
                        "    {",
                        "        if(AnsCount==1)InjectAnswer('Repair_SB_fix',CT(\"Script.Mod_ExpRepair.82\"),3);",
                        "        if(AnsCount>1)InjectAnswer('Repair_SB_fix',CT(\"Script.Mod_ExpRepair.194\"),3);",
                        "    }",
                        "    if(tint==1)",
                        "    {",
                        "        if(AnsCount==1)",
                        "        {",
                        "            AddDialogBlock(CT(\"Script.Mod_ExpRepair.82\"),1);",
                        "            InjectAnswer('Repair_SB_fix',CT(\"Script.Mod_ExpRepair.82\"),3);",
                        "        }",
                        "        if(AnsCount>1)",
                        "        {",
                        "            AddDialogBlock(CT(\"Script.Mod_ExpRepair.194\"),1);",
                        "            InjectAnswer('Repair_SB_fix',CT(\"Script.Mod_ExpRepair.194\"),3);",
                        "        }",
                        "    }",
                        "}",
                        "InjectAnswer('Repair_SB_no',CT(\"Script.Mod_ExpRepair.9\"),0);"
                    ],
