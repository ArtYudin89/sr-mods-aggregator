                        "            {",
                        "                AddText=Format(CT(\"Script.Mod_ExpRepair.608\"),\"<0>\",tint,\"<1>\",discount);",
                        "                AddTextNodes=CT(\"Script.Mod_ExpRepair.269\");",
                        "            }",
                        "            else if(ShipType(cur_ship)=='Rebel')",
                        "            {",
                        "                AddText=Format(CT(\"Script.Mod_ExpRepair.607\"),\"<0>\",tint,\"<1>\",discount);",
                        "                AddTextNodes=CT(\"Script.Mod_ExpRepair.269\");",
                        "            }",
                        "            else",
                        "            {",
                        "                AddText=Format(CT(\"Script.Mod_ExpRepair.606\"),\"<0>\",tint,\"<1>\",discount);",
                        "                AddTextNodes=CT(\"Script.Mod_ExpRepair.269\");",
                        "            }",
                        "        }",
                        "        else",
                        "        {",
                        "            AddText=Format(CT(\"Script.Mod_ExpRepair.605\"),\"<0>\",tint,\"<1>\",discount);",
