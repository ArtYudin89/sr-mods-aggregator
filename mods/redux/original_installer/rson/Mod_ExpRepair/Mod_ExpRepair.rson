                        "      }",
                        "      if(max_duration<100-ItemDurability(cur_item))max_duration=100-ItemDurability(cur_item);",
                        "  }",
                        "  if(!item_cost && !art_cost && !domik_wpn_cost) {",
                        "    if(cur_ship==Player())AddText=CT(\"Script.Mod_ExpRepair.493\");",
                        "    else if(!TrankRep)",
                        "    {",
                        "        if(ShipType(cur_ship)=='Merc')AddText=CT(\"Script.Mod_ExpRepair.495\");",
                        "        else AddText=CT(\"Script.Mod_ExpRepair.496\");",
                        "    }",
                        "    else AddText=CT(\"Script.Mod_ExpRepair.494\");",
                        "    DChange(28);",
                        "    exit;",
                        "  }",
                        "  if(item_cost || art_cost || domik_wpn_cost) {",
                        "    //Не менее одного нода на нестандартный ремонт",
