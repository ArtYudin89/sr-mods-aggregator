                        "    else",
                        "    {",
                        "        AddText = CT(\"Script.Mod_ExpRepair.113\");",
                        "        AddTextNodes = CT(\"Script.Mod_ExpRepair.517\");",
                        "    }",
                        "    if(!bad_equipments && nod_cost > 0) {",
                        "      DChange(12);",
                        "      exit;",
                        "    }",
                        "    if(!bad_equipments && nod_cost < 1) {",
                        "      DChange(4);",
                        "      exit;",
                        "    }",
                        "    if(bad_equipments && nod_cost < 1) {",
                        "      DChange(3);",
                        "      exit;",
                        "    }",
                        "    if(bad_equipments && nod_cost > 0) {",
                        "      DChange(11);",
                        "      exit;",
                        "    }",
                        "  }",
                        "}",
                        "if(GAnswerData == 2 || GAnswerData == 3) {",
