                        "    if(cur_ship == Player())",
                        "    {",
                        "        AddText = CT(\"Script.Mod_ExpRepair.112\");",
                        "        AddTextNodes = CT(\"Script.Mod_ExpRepair.516\");",
                        "    }",
                        "    else if(!TrankRep)",
                        "    {",
                        "        if(ShipType(cur_ship) == 'Merc')",
                        "        {",
                        "            AddText = CT(\"Script.Mod_ExpRepair.185\");",
                        "            AddTextNodes = CT(\"Script.Mod_ExpRepair.518\");",
                        "        }",
