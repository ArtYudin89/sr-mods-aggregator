                    "Type": "Top",
                    "Parent": -1,
                    "Pos.x": 340,
                    "Pos.y": 450
                },
                {
                    "Name": "",
                    "Code.Type": "Turn",
                    "Code": [
                        "if(tstr == 'ArtRep' || tstr == 'ProbeRep') {",
                        "  if(tstr=='ArtRep')AddText='</color>'+CT(\"Script.Mod_ExpRepair.446\");",
                        "  else AddText='</color>'+CT(\"Script.Mod_ExpRepair.553\");",
                        "  DChange(16);",
                        "  exit;",
                        "}",
                        "if(tstr!='ArtRep' && tstr!='ProbeRep') {",
                        "  //Готовим ответные реплики, снова",
                        "  if(cur_ship==Player())AddText='</color>'+CT(\"Script.Mod_ExpRepair.548\");",
                        "  else if(!TrankRep)",
                        "  {",
                        "      if(ShipType(cur_ship)=='Merc' && bad_equipments==0)AddText='</color>'+CT(\"Script.Mod_ExpRepair.551\");",
                        "      else if(ShipType(cur_ship)=='Merc' && bad_equipments==1)AddText='</color>'+CT(\"Script.Mod_ExpRepair.550\");",
                        "      else AddText='</color>'+CT(\"Script.Mod_ExpRepair.552\");",
                        "  }",
                        "  else AddText='</color>'+CT(\"Script.Mod_ExpRepair.549\");",
                        "  DChange(5);",
                        "  exit;",
                        "}"
                    ],
                    "#": 121,
                    "Type": "Top",
                    "Parent": -1,
                    "Pos.x": 550,
