                        "if(CurRuinTypeStr == 'SB') tstr1 = '</color>' + CT(\"Script.Mod_ExpRepair.137\");",
                        "else if(CurRuinTypeStr == 'PB') tstr1 = '</color>' + CT(\"Script.Mod_ExpRepair.392\");",
                        "else if(CurRuinTypeStr == 'TC') tstr1 = '</color>' + CT(\"Script.Mod_ExpRepair.530\");",
                        "else tstr1 = '</color>' + CT('Script.Mod_ExpRepair.' + CurRuinTypeStr + '.DeclainRepair');",
                        "DChange(33);",
                        "exit;"
