                        "}",
                        "if(tstr!='ArtRep' && tstr!='ProbeRep') {",
                        "  //Готовим ответные реплики, снова",
                        "  if(cur_ship==Player())AddText='</color>'+CT(\"Script.Mod_ExpRepair.556\");",
                        "  else if(!TrankRep)",
                        "  {",
                        "      if(ShipType(cur_ship)=='Merc')AddText='</color>'+CT(\"Script.Mod_ExpRepair.559\");",
                        "      else if(ShipType(cur_ship)=='Rebel')AddText='</color>'+CT(\"Script.Mod_ExpRepair.558\");",
                        "      else AddText='</color>'+CT(\"Script.Mod_ExpRepair.560\");",
                        "  }",
                        "  else AddText='</color>'+CT(\"Script.Mod_ExpRepair.557\");",
