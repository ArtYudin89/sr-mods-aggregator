                        "}",
                        "if(GAnswerData==2 || GAnswerData==3) {",
                        "  ArrayClear(items);//Очищаем массив предметов",
                        "  if(GAnswerData==2)",
                        "  {",
                        "      for(i=0;i<ShipArts(cur_ship);i=i+1)",
