                        "                AddText=Format(CT(\"Script.Mod_ExpRepair.410\"),\"<0>\",tint,\"<1>\",discount);",
                        "                AddTextNodes=CT(\"Script.Mod_ExpRepair.520\");",
                        "            }",
                        "            else if(ShipType(cur_ship)=='Rebel')",
                        "            {",
                        "                AddText=Format(CT(\"Script.Mod_ExpRepair.448\"),\"<0>\",tint,\"<1>\",discount);",
                        "                AddTextNodes=CT(\"Script.Mod_ExpRepair.520\");",
                        "            }",
                        "            else",
                        "            {",
                        "                AddText=Format(CT(\"Script.Mod_ExpRepair.411\"),\"<0>\",tint,\"<1>\",discount);",
                        "                AddTextNodes=CT(\"Script.Mod_ExpRepair.520\");",
                        "            }",
