                {
                    "Name": "",
                    "Code.Type": "Turn",
                    "Code": [
                        "InjectAnswer('Repair_TC_player',CT(\"Script.Mod_ExpRepair.139\"),0);",
                        "InjectAnswer('Repair_TC_player',CT(\"Script.Mod_ExpRepair.87\"),1);",
                        "if(!ShipArts(Player()))AddDialogBlock(CT(\"Script.Mod_ExpRepair.91\"),1);",
                        "InjectAnswer('Repair_TC_player',CT(\"Script.Mod_ExpRepair.91\"),2);",
                        "",
                        "//Ищем в трюме хотя бы один зонд",
                        "tint=0;",
                        "for(i=0; i<ShipItems(Player()); i=i+1)",
                        "{",
                        "    cur_item=ShipItems(Player(),i);",
                        "    //Пропускаем всё, кроме зондов",
                        "    if(ItemType(cur_item) != t_Satellite)continue;",
                        "    tint=1;",
                        "    break;",
                        "}",
                        "if(!tint)AddDialogBlock(CT(\"Script.Mod_ExpRepair.543\"),1);",
                        "InjectAnswer('Repair_TC_player',CT(\"Script.Mod_ExpRepair.543\"),3);",
                        "InjectAnswer('Repair_TC_player',CT(\"Script.Mod_ExpRepair.455\"),4);",
                        "",
                        "if(ArrayDim(ship)-1)",
                        "{",
                        "    for(i=1; i<ArrayDim(ship); i=i+1)",
                        "    {",
                        "        cur_ship=ship[i];",
                        "        if(ShipTypeN(cur_ship) == t_Tranclucator) InjectAnswer('Repair_TC_ship',Format(CT(\"Script.Mod_ExpRepair.105\"),\"<0>\",ShipName(cur_ship)),cur_ship);",
                        "        else if(ShipTypeN(cur_ship) == t_Ranger)",
                        "        {",
                        "            if(ShipType(cur_ship) == 'Merc' || ShipType(cur_ship) == 'Freelancer') InjectAnswer('Repair_TC_ship',Format(CT(\"Script.Mod_ExpRepair.99\"),\"<0>\",ShipName(cur_ship)),cur_ship);",
                        "            else if(ShipType(cur_ship) == 'RangerPirate' || ShipType(cur_ship) == 'RangerPirateExplorer') InjectAnswer('Repair_TC_ship',Format(CT(\"Script.Mod_ExpRepair.98\"),\"<0>\",ShipName(cur_ship)),cur_ship);",
                        "            else if(ShipType(cur_ship) == 'FemRanger') InjectAnswer('Repair_TC_ship',Format(CT(\"Script.Mod_ExpRepair.541\"),\"<0>\",ShipName(cur_ship)),cur_ship);",
                        "            else InjectAnswer('Repair_TC_ship',Format(CT(\"Script.Mod_ExpRepair.198\"),\"<0>\",ShipName(cur_ship)),cur_ship);",
                        "        }",
                        "        else if(ShipTypeN(cur_ship) == t_Pirate)",
                        "        {",
                        "            if(ShipType(cur_ship) == 'Rebel') InjectAnswer('Repair_TC_ship',Format(CT(\"Script.Mod_ExpRepair.447\"),\"<0>\",ShipName(cur_ship)),cur_ship);",
                        "            else if(ShipType(cur_ship) == 'Merc' || ShipType(cur_ship) == 'Freelancer') InjectAnswer('Repair_TC_ship',Format(CT(\"Script.Mod_ExpRepair.99\"),\"<0>\",ShipName(cur_ship)),cur_ship);",
                        "            else InjectAnswer('Repair_TC_ship',Format(CT(\"Script.Mod_ExpRepair.98\"),\"<0>\",ShipName(cur_ship)),cur_ship);",
                        "        }",
                        "    }",
                        "}",
                        "InjectAnswer('GetBack',CT(\"Script.Mod_ExpRepair.481\"),-1);"
