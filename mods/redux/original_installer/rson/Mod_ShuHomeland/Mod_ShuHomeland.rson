                }
            ],
            "Items": [],
            "Operations": [
                {
                    "Name": "",
                    "Code.Type": "Global",
                    "Code": [
                        "GRun();"
                    ],
                    "#": 24,
                    "Type": "Top",
                    "Parent": -1,
                    "Pos.x": 0,
                    "Pos.y": 610
                },
                {
                    "Name": "",
                    "Code.Type": "Init",
                    "Code": [
                        "//Проверяем наличие ВБ и ПБ в Галактике при подключении мода",
                        "MBExist=0;",
                        "for(j=0;j<GalaxyStars();j=j+1)",
                        "{",
                        "\tif(StarRuins(GalaxyStar(j),'WB')>0)",
                        "\t{",
                        "\t\tMBExist=1;",
                        "\t\tTempDword=StarRuins(GalaxyStar(j),'WB');",
                        "\t}",
                        "}",
                        "PBExist=0;",
                        "for(j=0;j<GalaxyStars();j=j+1)",
                        "{",
                        "\tif(StarRuins(GalaxyStar(j),'PB')>0)",
                        "\t{",
                        "\t\tPBExist=1;",
                        "\t\tbreak;",
                        "\t}",
                        "}",
                        "",
                        "HomePlanetId=Id(GetShipHomePlanet(Player()));",
                        "HomePlanetName=PlanetName(GetShipHomePlanet(Player()));",
                        "HomeStarId=Id(PlanetToStar(GetShipHomePlanet(Player())))-1;",
                        "HomeStarName=StarName(PlanetToStar(GetShipHomePlanet(Player())));",
                        "",
                        "IsHomeAttackEtherOn=1;"
                    ],
                    "#": 25,
                    "Type": "Top",
                    "Parent": -1,
                    "Pos.x": 60,
                    "Pos.y": 610
                },
                {
                    "Name": "",
                    "Code.Type": "Turn",
                    "Code": [
                        "//Отсчитываем ходы после последней отправки уведомления об атаке родной системы (чтобы его не присылали игроку каждый ход)",
                        "if(HomeAttackEtherTimer<30)HomeAttackEtherTimer=HomeAttackEtherTimer+1;",
                        "//Перебираем галактические события",
                        "for(i=GalaxyEvents()-1;i>=0;i=i-1)",
                        "{",
                        "\tif(GalaxyEventDate(i)<CurTurn())break;",
                        "\tif(GalaxyEventType(i)=='RuinsDestroyed')",
                        "\t{",
                        "\t\t//Узнаём, что была уничтожена военная база и сразу проверяем, остались ли в Галактике ещё",
                        "\t\tif(GalaxyEventData(i,0)==8)",
                        "\t\t{",
                        "\t\t\tMBExist=0;",
                        "\t\t\tfor(j=0;j<GalaxyStars();j=j+1)",
                        "\t\t\t{",
                        "\t\t\t\tif(StarRuins(GalaxyStar(j),'WB')>0)",
                        "\t\t\t\t{",
                        "\t\t\t\t\tMBExist=1;",
                        "\t\t\t\t\tbreak;",
                        "\t\t\t\t}",
                        "\t\t\t}",
                        "\t\t}",
                        "\t\t//Узнаём, что была уничтожена пиратская база и сразу проверяем, остались ли в Галактике ещё",
                        "\t\tif(GalaxyEventData(i,0)==7)",
                        "\t\t{",
                        "\t\t\tPBExist=0;",
                        "\t\t\tfor(j=0;j<GalaxyStars();j=j+1)",
                        "\t\t\t{",
                        "\t\t\t\tif(StarRuins(GalaxyStar(j),'PB')>0)",
                        "\t\t\t\t{",
                        "\t\t\t\t\tPBExist=1;",
                        "\t\t\t\t\tbreak;",
                        "\t\t\t\t}",
                        "\t\t\t}",
                        "\t\t}",
                        "\t}",
                        "\tif(GalaxyEventType(i)=='RuinsCreated')",
                        "\t{",
                        "\t\t//Узнаём, что была построена военная или пиратская база, и запоминаем это в переменной, если ранее все ВБ и/или ПБ были уничтожены",
                        "\t\tif(GalaxyEventData(i,0)==8)",
                        "\t\t{",
                        "\t\t\tif(!MBExist)MBExist=1;",
                        "\t\t\tMBLostMessCheck=0;",
                        "\t\t}",
                        "\t\tif(GalaxyEventData(i,0)==7)",
                        "\t\t{",
                        "\t\t\tif(!PBExist)PBExist=1;",
                        "\t\t\tPBLostMessCheck=0;",
                        "\t\t}",
                        "\t}",
                        "}",
                        "//Уведомление об уничтожении всех военных баз (если игрок на стороне Коалиции)",
                        "if(!MBExist)",
                        "{",
                        "\tif(!MBLostMessCheck)",
                        "\t{",
                        "\t\tTempDword=GalaxyStar(HomeStarId);",
                        "\t\tif(ShipOwner(Player())>=0 && ShipOwner(Player())<=4)",
                        "\t\t{",
                        "\t\t\tif(StarOwner(TempDword)==0)Ether(0,'',Format(CT(\"Script.Mod_ShuHomeland.51\"),\"<0>\",HomePlanetName,\"<1>\",HomeStarName));",
                        "\t\t\tMBLostMessCheck=1;",
                        "\t\t}",
                        "\t}",
                        "}",
                        "//Уведомление об уничтожении всех пиратских баз (если игрок на стороне пиратского клана)",
                        "if(!PBExist)",
                        "{",
                        "\tif(!PBLostMessCheck)",
                        "\t{",
                        "\t\tTempDword=GalaxyStar(HomeStarId);",
                        "\t\tif(ShipOwner(Player())==7)",
                        "\t\t{",
                        "\t\t\tif(StarOwner(TempDword)==2 && StarCustomFaction(TempDword)!='Klissan')Ether(0,'',Format(CT(\"Script.Mod_ShuHomeland.50\"),\"<0>\",HomePlanetName,\"<1>\",HomeStarName));",
                        "\t\t\tPBLostMessCheck=1;",
                        "\t\t}",
                        "\t}",
                        "}",
                        "//Уведомление об атаке родной системы",
                        "if(IsHomeAttackEtherOn)",
                        "{",
                        "\tif(HomeAttackEtherTimer>=30)",
                        "\t{",
                        "\t\tTempDword=GalaxyStar(HomeStarId);",
                        "\t\tif(StarBattle(TempDword))",
                        "\t\t{",
                        "\t\t\tif(!ShipInStar(Player(),TempDword))",
                        "\t\t\t{",
                        "\t\t\t\t//Игрок на стороне Коалиции",
                        "\t\t\t\tif(ShipOwner(Player())>=0 && ShipOwner(Player())<=4)",
                        "\t\t\t\t{",
                        "\t\t\t\t\tif(StarOwner(TempDword)==0)",
                        "\t\t\t\t\t{",
                        "\t\t\t\t\t\tTempDword2=Rnd(1,3);",
                        "\t\t\t\t\t\tif(TempDword2==1)CustomEther('Galaxy_Alert',0,'',Format(CT(\"Script.Mod_ShuHomeland.60\"),\"<0>\",HomeStarName));",
                        "\t\t\t\t\t\tif(TempDword2==2)CustomEther('Galaxy_Alert',0,'',Format(CT(\"Script.Mod_ShuHomeland.59\"),\"<0>\",HomeStarName));",
                        "\t\t\t\t\t\tif(TempDword2==3)CustomEther('Galaxy_Alert',0,'',Format(CT(\"Script.Mod_ShuHomeland.58\"),\"<0>\",HomeStarName));",
                        "\t\t\t\t\t\tHomeAttackEtherTimer=0;",
                        "\t\t\t\t\t}",
                        "\t\t\t\t}",
                        "\t\t\t\t//Игрок на стороне пиратского клана",
                        "\t\t\t\tif(ShipOwner(Player())==7)",
                        "\t\t\t\t{",
                        "\t\t\t\t\tif(StarOwner(TempDword)==2 && StarCustomFaction(TempDword)!='Klissan')",
                        "\t\t\t\t\t{",
                        "\t\t\t\t\t\tTempDword2=Rnd(1,3);",
                        "\t\t\t\t\t\tif(TempDword2==1)CustomEther('Galaxy_Alert',0,'',Format(CT(\"Script.Mod_ShuHomeland.57\"),\"<0>\",HomeStarName));",
                        "\t\t\t\t\t\tif(TempDword2==2)CustomEther('Galaxy_Alert',0,'',Format(CT(\"Script.Mod_ShuHomeland.56\"),\"<0>\",HomeStarName));",
                        "\t\t\t\t\t\tif(TempDword2==3)CustomEther('Galaxy_Alert',0,'',Format(CT(\"Script.Mod_ShuHomeland.55\"),\"<0>\",HomeStarName));",
                        "\t\t\t\t\t\tHomeAttackEtherTimer=0;",
                        "\t\t\t\t\t}",
                        "\t\t\t\t}",
                        "\t\t\t}",
                        "\t\t}",
                        "\t}",
                        "}",
                        "//Повышаем военное звание всех рейнджеров, севших на родную планету игрока",
                        "//(работает только при отсутствии в Галактике ВБ и при наличии у рейнджера достаточного количества очков лётчика)",
                        "if(!MBExist)",
                        "{",
                        "\tTempDword=GalaxyStar(HomeStarId);",
                        "\t//Родная система игрока принадлежит Коалиции",
                        "\tif(StarOwner(TempDword)==0)",
                        "\t{",
                        "\t\tfor(i=0;i<StarShips(TempDword);i=i+1)",
                        "\t\t{",
                        "\t\t\tTempDword2=StarShips(TempDword,i);",
                        "\t\t\tif(ShipOnSidePirateClan(TempDword2))continue;",
                        "\t\t\tif(IsPlayer(TempDword2))continue;",
                        "\t\t\tif(ShipType(TempDword2)!='Ranger')continue;",
                        "\t\t\tif(ShipRankPoints(TempDword2)<ShipNextRankPoints(TempDword2))continue;",
                        "\t\t\tj=GetShipHomePlanet(Player());",
                        "\t\t\tif(GetShipPlanet(TempDword2)==j)",
                        "\t\t\t{",
                        "\t\t\t\tShipRaiseRank(TempDword2);",
                        "\t\t\t\tShipImproveItems(TempDword2,Rnd(1,2));",
                        "\t\t\t\tif(Rnd(0,1))GiveRewardByNom(TempDword2,13);",
                        "\t\t\t\telse if(PlanetOwner(j)==0)GiveRewardByNom(TempDword2,14);",
                        "\t\t\t\telse if(PlanetOwner(j)==1)GiveRewardByNom(TempDword2,25);",
                        "\t\t\t\telse if(PlanetOwner(j)==2)GiveRewardByNom(TempDword2,18);",
                        "\t\t\t\telse if(PlanetOwner(j)==3)GiveRewardByNom(TempDword2,8);",
                        "\t\t\t\telse if(PlanetOwner(j)==4)GiveRewardByNom(TempDword2,11);",
                        "\t\t\t}",
                        "\t\t}",
                        "\t}",
                        "}"
                    ],
                    "#": 26,
                    "Type": "Top",
                    "Parent": -1,
                    "Pos.x": 120,
                    "Pos.y": 610
                },
                {
                    "Name": "",
                    "Code.Type": "DialogBegin",
                    "Code": [
                        "if(!PBExist) {",
                        "  if(GetShipPlanet(Player())==GetShipHomePlanet(Player())) {",
                        "    if(PlanetOwner(GetShipPlanet(Player()))==PirateClan) {",
                        "      if(RelationToRanger(GetShipPlanet(Player()),Player())>=30) {",
                        "        if(ShipOwner(Player())==7) {",
                        "          if(GetShipPirateRank(Player())<7) {",
                        "            if(ShipPirateRankPoints(Player())>=ShipNextPirateRankPoints(Player())) {",
                        "              AddDialogOverride('PirateRankRaise',1001);",
                        "            }",
                        "          }",
                        "        }",
                        "      }",
                        "    }",
                        "  }",
                        "}",
                        "if(!MBExist) {",
                        "  if(GetShipPlanet(Player())==GetShipHomePlanet(Player())) {",
                        "    if(PlanetOwner(GetShipPlanet(Player()))>=0 && PlanetOwner(GetShipPlanet(Player()))<=4) {",
                        "      if(RelationToRanger(GetShipPlanet(Player()),Player())>=30) {",
                        "        if(ShipOwner(Player())>=0 && ShipOwner(Player())<=4) {",
                        "          if(ShipRank(Player())<7) {",
                        "            if(ShipRankPoints(Player())>=ShipNextRankPoints(Player())) {",
                        "              AddDialogOverride('CoalitionRankRaise',1001);",
                        "            }",
                        "          }",
                        "        }",
                        "      }",
                        "    }",
                        "  }",
                        "}",
                        "if(IsScriptActive('Mod_ExpPilotBridge')) {",
                        "  if(PlayerBridge()>0) {",
                        "    if(GetMainData('CustomBridgeCheck.Enabled')=='True') {",
                        "      if(PlayerBridge()==12) {",
                        "        TempDword=IdToPlanet(HomePlanetId);",
                        "        TempStr=StarName(PlanetToStar(GetShipHomePlanet(Player())));",
                        "        if(PlanetRace(TempDword)==0 && TempStr==CT('Star.00'))TempStr2=CT(\"Script.Mod_ShuHomeland.38\");",
                        "        else if(PlanetRace(TempDword)==1 && TempStr==CT('Star.01'))TempStr2=CT(\"Script.Mod_ShuHomeland.37\");",
                        "        else if(PlanetRace(TempDword)==2 && TempStr==CT('Star.02'))TempStr2=CT(\"Script.Mod_ShuHomeland.36\");",
                        "        else if(PlanetRace(TempDword)==3 && TempStr==CT('Star.03'))TempStr2=CT(\"Script.Mod_ShuHomeland.35\");",
                        "        else if(PlanetRace(TempDword)==4 && TempStr==CT('Star.04'))TempStr2=CT(\"Script.Mod_ShuHomeland.34\");",
                        "        else TempStr2=TempStr;",
                        "        if(GetGameOptions('FontDialog')==0)TempStr3=CT(\"Script.Mod_ShuHomeland.33\");",
                        "        else if(GetGameOptions('FontDialog')==1)TempStr3=CT(\"Script.Mod_ShuHomeland.33\");",
                        "        else if(GetGameOptions('FontDialog')==2)TempStr3=CT(\"Script.Mod_ShuHomeland.32\");",
                        "        else if(GetGameOptions('FontDialog')==3)TempStr3=CT(\"Script.Mod_ShuHomeland.32\");",
                        "        if(!IsHomeAttackEtherOn)",
                        "        {",
                        "            TempStr=CT(\"Script.Mod_ShuHomeland.14\");",
                        "            AddDialogInject('Notification_ON',Format(CT(\"Script.Mod_ShuHomeland.39\"),\"<0>\",TempStr),CT(\"Script.Mod_ShuHomeland.31\")+' '+TempStr3+' '+Format(CT(\"Script.Mod_ShuHomeland.27\"),\"<0>\",TempStr2),8);",
                        "        }",
                        "        if(IsHomeAttackEtherOn)",
                        "        {",
                        "            TempStr=CT(\"Script.Mod_ShuHomeland.12\");",
                        "            AddDialogInject('Notification_OFF',Format(CT(\"Script.Mod_ShuHomeland.39\"),\"<0>\",TempStr),CT(\"Script.Mod_ShuHomeland.30\")+' '+TempStr3+' '+Format(CT(\"Script.Mod_ShuHomeland.27\"),\"<0>\",TempStr2),8);",
                        "        }",
                        "        if(GetMainData('CustomBridgeCheck.Enabled')!='True')InjectAnswer('',CT(\"Script.Mod_ShuHomeland.9\"),-1);",
                        "      }",
                        "    }",
                        "    if(GetMainData('CustomBridgeCheck.Enabled')!='True') {",
                        "      if(PlayerBridge()==1 || PlayerBridge()==2 || PlayerBridge()==3) {",
                        "        AddDialogInject('OptionMenu',CT(\"Script.Mod_ShuHomeland.8\"),0);",
                        "      }",
                        "    }",
                        "  }",
                        "}"
                    ],
                    "#": 27,
                    "Type": "Top",
                    "Parent": -1,
                    "Pos.x": 180,
                    "Pos.y": 610
                },
                {
                    "Name": "",
                    "Code.Type": "Turn",
                    "Code": [
                        "SkipGreeting();",
                        "ShipRaiseRank(Player());",
                        "TempDword=GetShipPlanet(Player());",
                        "//Выдача награды (медали)",
                        "if(Rnd(0,1)){GiveRewardByNom(Player(),13);TempStr=CT('Reward.13.Name');}",
                        "else if(PlanetOwner(TempDword)==0){GiveRewardByNom(Player(),14);TempStr=CT('Reward.14.Name');}",
                        "else if(PlanetOwner(TempDword)==1){GiveRewardByNom(Player(),25);TempStr=CT('Reward.25.Name');}",
                        "else if(PlanetOwner(TempDword)==2){GiveRewardByNom(Player(),18);TempStr=CT('Reward.18.Name');}",
                        "else if(PlanetOwner(TempDword)==3){GiveRewardByNom(Player(),8);TempStr=CT('Reward.8.Name');}",
                        "else if(PlanetOwner(TempDword)==4){GiveRewardByNom(Player(),11);TempStr=CT('Reward.11.Name');}",
                        "//Запоминаем имя полученного игроком звания",
                        "if(ShipRank(Player())==1)TempStr2=CT('Rank.Cadet.Name');",
                        "if(ShipRank(Player())==2)TempStr2=CT('Rank.Pilot.Name');",
                        "if(ShipRank(Player())==3)TempStr2=CT('Rank.Wingman.Name');",
                        "if(ShipRank(Player())==4)TempStr2=CT('Rank.Leader.Name');",
                        "if(ShipRank(Player())==5)TempStr2=CT('Rank.Ace.Name');",
                        "if(ShipRank(Player())==6)TempStr2=CT('Rank.Commander.Name');",
                        "if(ShipRank(Player())==7)TempStr2=CT('Rank.Admiral.Name');",
                        "//Выбираем и выдаём игроку случайный микромодуль (в зависимости от высоты полученного ранга)",
                        "if(ShipRank(Player())==7)TempDword2=CreateMM(FindBonusByCustomTag('AkrinAmplifier'));",
                        "else",
                        "{",
                        "    if(ShipRank(Player())==1)BuildListOfMMByPriority(NewRankReward,60,80);",
                        "    if(ShipRank(Player())==2)BuildListOfMMByPriority(NewRankReward,50,70);",
                        "    if(ShipRank(Player())==3)BuildListOfMMByPriority(NewRankReward,40,60);",
                        "    if(ShipRank(Player())==4)BuildListOfMMByPriority(NewRankReward,25,40);",
                        "    if(ShipRank(Player())==5)BuildListOfMMByPriority(NewRankReward,15,30);",
                        "    if(ShipRank(Player())==6)BuildListOfMMByPriority(NewRankReward,1,10);",
                        "    ArrayRandomize(50,NewRankReward);",
                        "    TempDword2=CreateMM(NewRankReward[0]);",
                        "    ArrayClear(NewRankReward);",
                        "}",
                        "AddItemToShip(Player(),TempDword2);",
                        "TempStr4='</color>'+CT(\"Script.Mod_ShuHomeland.17\");",
                        "TempStr5='</color>'+CT(\"Script.Mod_ShuHomeland.44\")+' '+substr(Name(TempDword2),12,100);",
                        "//Проверяем, подключён ли мод ExpAcrin и добавляем соответствующую реплику при получении звания Капитан",
                        "TempStr3='';",
                        "if(IsScriptActive('Mod_ExpAcryn'))",
                        "{",
                        "    if(GetValueFromScript('Mod_ExpAcryn','HomeGiveCaseCheck')==1)",
                        "    {",
                        "        TempStr3='</color>'+CT(\"Script.Mod_ShuHomeland.49\");",
                        "        TempStr4='</color>'+CT(\"Script.Mod_ShuHomeland.15\");",
                        "        //GotoGov(2);",
                        "    }",
                        "}",
                        "//Звук победы",
                        "Sound('Sound.QuestOk');",
                        "DChange(0);",
                        "exit;"
                    ],
                    "#": 38,
                    "Type": "Top",
                    "Parent": -1,
                    "Pos.x": -20,
                    "Pos.y": 400
                },
                {
                    "Name": "",
                    "Code.Type": "Turn",
                    "Code": [
                        "SkipGreeting();",
                        "RaisePirateRank(Player());",
                        "TempDword=GetShipPlanet(Player());",
                        "//Запоминаем имя полученного игроком звания",
                        "if(GetShipPirateRank(Player())==1)TempStr2=CT(\"Script.Mod_ShuHomeland.24\");",
                        "if(GetShipPirateRank(Player())==2)TempStr2=CT(\"Script.Mod_ShuHomeland.23\");",
                        "if(GetShipPirateRank(Player())==3)TempStr2=CT(\"Script.Mod_ShuHomeland.22\");",
                        "if(GetShipPirateRank(Player())==4)TempStr2=CT(\"Script.Mod_ShuHomeland.21\");",
                        "if(GetShipPirateRank(Player())==5)TempStr2=CT(\"Script.Mod_ShuHomeland.20\");",
                        "if(GetShipPirateRank(Player())==6)TempStr2=CT(\"Script.Mod_ShuHomeland.19\");",
                        "if(GetShipPirateRank(Player())==7)TempStr2=CT(\"Script.Mod_ShuHomeland.18\");",
                        "//Выбираем и выдаём игроку случайный микромодуль (в зависимости от высоты полученного ранга)",
                        "if(GetShipPirateRank(Player())==7)TempDword2=CreateMM(FindBonusByCustomTag('AkrinAmplifier'));",
                        "else",
                        "{",
                        "    if(GetShipPirateRank(Player())==1)BuildListOfMMByPriority(NewRankReward,60,80);",
                        "    if(GetShipPirateRank(Player())==2)BuildListOfMMByPriority(NewRankReward,50,70);",
                        "    if(GetShipPirateRank(Player())==3)BuildListOfMMByPriority(NewRankReward,40,60);",
                        "    if(GetShipPirateRank(Player())==4)BuildListOfMMByPriority(NewRankReward,25,40);",
                        "    if(GetShipPirateRank(Player())==5)BuildListOfMMByPriority(NewRankReward,15,30);",
                        "    if(GetShipPirateRank(Player())==6)BuildListOfMMByPriority(NewRankReward,1,10);",
                        "    ArrayRandomize(50,NewRankReward);",
                        "    TempDword2=CreateMM(NewRankReward[0]);",
                        "    ArrayClear(NewRankReward);",
                        "}",
                        "AddItemToShip(Player(),TempDword2);",
                        "TempStr5='</color>'+Name(TempDword2);",
                        "Sound('Sound.QuestOk');",
                        "DChange(1);",
                        "exit;"
                    ],
                    "#": 39,
                    "Type": "Top",
                    "Parent": -1,
                    "Pos.x": 250,
                    "Pos.y": 400
                },
                {
                    "Name": "",
                    "Code.Type": "Turn",
                    "Code": [
                        "IsHomeAttackEtherOn=1;",
                        "DAnswer('main');",
                        "Sound('Sound.ButtonInfoEnter');"
                    ],
                    "#": 40,
                    "Type": "Top",
                    "Parent": -1,
                    "Pos.x": 460,
                    "Pos.y": 400
                },
                {
                    "Name": "",
                    "Code.Type": "Turn",
                    "Code": [
                        "IsHomeAttackEtherOn=0;",
                        "DAnswer('main');",
                        "Sound('Sound.ButtonInfoEnter');"
                    ],
                    "#": 41,
                    "Type": "Top",
                    "Parent": -1,
                    "Pos.x": 670,
                    "Pos.y": 400
                },
                {
                    "Name": "",
                    "Code.Type": "Turn",
                    "Code": [
                        "TempDword=IdToPlanet(HomePlanetId);",
                        "TempStr=StarName(PlanetToStar(GetShipHomePlanet(Player())));",
                        "if(PlanetRace(TempDword)==0 && TempStr==CT('Star.00'))TempStr2=CT(\"Script.Mod_ShuHomeland.38\");",
                        "else if(PlanetRace(TempDword)==1 && TempStr==CT('Star.01'))TempStr2=CT(\"Script.Mod_ShuHomeland.37\");",
                        "else if(PlanetRace(TempDword)==2 && TempStr==CT('Star.02'))TempStr2=CT(\"Script.Mod_ShuHomeland.36\");",
                        "else if(PlanetRace(TempDword)==3 && TempStr==CT('Star.03'))TempStr2=CT(\"Script.Mod_ShuHomeland.35\");",
                        "else if(PlanetRace(TempDword)==4 && TempStr==CT('Star.04'))TempStr2=CT(\"Script.Mod_ShuHomeland.34\");",
                        "else TempStr2=TempStr;",
                        "if(GetGameOptions('FontDialog')==0)TempStr3=CT(\"Script.Mod_ShuHomeland.33\");",
                        "else if(GetGameOptions('FontDialog')==1)TempStr3=CT(\"Script.Mod_ShuHomeland.33\");",
                        "else if(GetGameOptions('FontDialog')==2)TempStr3=CT(\"Script.Mod_ShuHomeland.32\");",
                        "else if(GetGameOptions('FontDialog')==3)TempStr3=CT(\"Script.Mod_ShuHomeland.32\");",
                        "if(!IsHomeAttackEtherOn)",
                        "{",
                        "    TempStr=CT(\"Script.Mod_ShuHomeland.14\");",
                        "    AddDialogInject('Notification_ON',Format(CT(\"Script.Mod_ShuHomeland.39\"),\"<0>\",TempStr),CT(\"Script.Mod_ShuHomeland.31\")+' '+TempStr3+' '+Format(CT(\"Script.Mod_ShuHomeland.27\"),\"<0>\",TempStr2),8);",
                        "}",
                        "if(IsHomeAttackEtherOn)",
                        "{",
                        "    TempStr=CT(\"Script.Mod_ShuHomeland.12\");",
                        "    AddDialogInject('Notification_OFF',Format(CT(\"Script.Mod_ShuHomeland.39\"),\"<0>\",TempStr),CT(\"Script.Mod_ShuHomeland.30\")+' '+TempStr3+' '+Format(CT(\"Script.Mod_ShuHomeland.27\"),\"<0>\",TempStr2),8);",
                        "}",
                        "if(GetMainData('CustomBridgeCheck.Enabled')!='True')InjectAnswer('',CT(\"Script.Mod_ShuHomeland.9\"),-1);"
                    ],
                    "#": 42,
                    "Type": "Top",
