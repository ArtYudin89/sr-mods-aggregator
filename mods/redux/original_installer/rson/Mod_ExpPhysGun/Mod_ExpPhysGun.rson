                    "#": 120,
                    "Type": "Top",
                    "Parent": -1,
                    "Pos.x": 640,
                    "Pos.y": 450
                },
                {
                    "Name": "",
                    "Code.Type": "Turn",
                    "Code": [
                        "if(dialogVar == 1) {",
                        "  DChange(11);",
                        "  exit;",
                        "}",
                        "if(dialogVar == 0) {",
                        "  DChange(8);",
                        "  exit;",
                        "}",
                        "if(dialogVar == 2) {",
                        "  DChange(12);",
                        "  exit;",
                        "}",
                        "if(dialogVar == 3) {",
                        "  if(questState == 7) {",
                        "    addRew = '';",
                        "    int0 = questVar + GroupCount(EvacShips);",
                        "    int1 = round(min(RangersCapital() / 100, ShipWealth(Player()) / 100) * 7) + 1200;",
                        "    int1 = round(int1 * 12 / 10);",
                        "    int1 = int1 + round(int1 / 10 * ShipSkill(Player(), 4));",
                        "    int1 = int1 * 3 + (int1 * 5 * int0) / 100;",
                        "    ShipMoney(Player(), ShipMoney(Player()) + int1);",
                        "    ChangeGlobalRelationsPlanets(Player(), StarToCon(ScriptStar), 2, 100, 31);",
                        "    if(int0 == 0) addRew = '</color>' + CT(\"Script.Mod_ExpPhysGun.120\");",
                        "    if(int0 > 0 && int0 < 10) addRew = '</color>' + Format(CT(\"Script.Mod_ExpPhysGun.119\"),\"<0>\",int0,\"<1>\",10);",
                        "    if(int0 == 10) addRew = '</color>' + CT(\"Script.Mod_ExpPhysGun.141\");",
                        "    dialogVar = -3;",
                        "    //60 ходов на завершение скрипта или 3, если сдал сломаный физган на ТЦ",
                        "    if(!QuestTC_Id)",
                        "    {",
                        "        //стейт завершения скрипта",
                        "    \tquestState = 10;",
                        "    \tendDate = CurTurn() + 3;",
                        "    }",
                        "    else endDate = CurTurn() + 60;",
                        "    ",
                        "    //Меняем уведомление задания, задание с физганом успешно выполнено",
                        "    Ether(4, 'ExpPhysGun_QuestEther', Format(CT(\"Script.Mod_ExpPhysGun.73\"),\"<0>\",Name(TargetPlanet)));",
                        "    DChange(14);",
                        "    exit;",
                        "  }",
                        "  if(questState == 8) {",
                        "    if(questState == 3) Ether(4, 'ExpPhysGun_QuestEther', Format(CT(\"Script.Mod_ExpPhysGun.103\"),\"<0>\",Name(TargetPlanet),\"<1>\",AsteroidNumber));",
                        "    if(questState == 5 && QuestTC_Id != -3) Ether(4, 'ExpPhysGun_QuestEther', Format(CT(\"Script.Mod_ExpPhysGun.22\"),\"<0>\",QuestTC_Name));",
                        "    if(questState == 8) Ether(4, 'ExpPhysGun_QuestEther', CT(\"Script.Mod_ExpPhysGun.45\"));",
                        "    //игрок уничтожил астероид не физганом, завершаем скрипт",
                        "    dialogVar = -3;",
                        "    //3 хода на завершение скрипта",
                        "    endDate = CurTurn() + 3;",
                        "    //стейт завершения скрипта",
                        "    questState = 10;",
                        "    DChange(13);",
                        "    exit;",
                        "  }",
                        "}"
                    ],
