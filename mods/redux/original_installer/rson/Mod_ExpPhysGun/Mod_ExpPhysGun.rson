                },
                {
                    "Name": "",
                    "Code.Type": "Turn",
                    "Code": [
                        "DAdd(20);"
                    ],
                    "#": 139,
                    "Type": "Top",
                    "Parent": -1,
                    "Pos.x": 580,
                    "Pos.y": 545
                },
                {
                    "Name": "",
                    "Code.Type": "Turn",
                    "Code": [
                        "//Накладываем на астероид инфошку бессмертия (только физган будет наносить урон)",
                        "asteroid = GroupToShip(Asteroid);",
                        "ShipAddCustomShipInfo(asteroid, 'ExpPhysGun_ImmortalAsteroid');",
                        "//Накладываем броню корпуса, просто так... чтобы соточка была (ну как скажешь, Хук - \"Klaxons\")",
                        "ShipSpecialBonuses(asteroid, bonHull, 94);",
                        "SetName(asteroid, Format(' -<0>-',\"<0>\",AsteroidNumber));",
                        "NoTalkToShip(asteroid, 1);",
                        "NoScanToShip(asteroid, 1);",
                        "//Запрет на дроп вещей (не глобальный, иначе потом не выпадут минералы)",
                        "for(i = 0; i < ShipItems(asteroid); i = i + 1) NoDropItem(ShipItems(asteroid, i), 1);",
                        "//Запрещаем всем другим NPC нападать на астероид (всем кроме доминаторов, естественно)",
                        "NoTargetToShip(asteroid, 2);",
                        "//Выставляем ТУ корпуса 6, так как при данном ТУ сопротивление ракетам (и всем остальным типам) равно 100",
                        "ItemLevel(ShipEqInSlot(asteroid, t_Hull), 6);",
                        "//Добавляем кучу ценной руды и минералов в дроп к астероиду",
                        "for(i = 1; i <= Rnd(7, 10); i = i + 1)",
                        "{",
                        "    dwd1 = CreateCustomCountableItem('NuggetAsteroid', Rnd(35, 70), 1);",
                        "    ItemCost(dwd1, ItemCost(dwd1) * (GoodsBuyPrice(TargetPlanet, t_Minerals) * 7));",
                        "    ShipAddDropItem(asteroid, dwd1);",
                        "}",
                        "for(i = 1; i <= Rnd(4, 7); i = i + 1)",
                        "{",
                        "    dwd1 = CreateGoods(t_Minerals, Rnd(35, 70), 1);",
                        "    ShipAddDropItem(asteroid, dwd1);",
                        "}",
                        "//Астероид начинает движение",
                        "OrderMove(asteroid, hookX, hookY);",
                        "OrderLock(asteroid, 1);",
                        "//Центрируем камеру на астероиде",
                        "StarMapCenterView(startX, startY);",
                        "ShipSetBad(asteroid, Player());",
                        "",
                        "//Выставляем маркер начала эвакуации (прирост населения эвакуируемой планеты будет остановлен)",
                        "EvacInProcess = PlanetPopulation(TargetPlanet);",
                        "//На время квеста блокируем все атаки доминаторов на систему",
                        "NoComeKlingToStar(ScriptStar, 1);",
                        "",
                        "questState = 2;",
                        "//Выводим уведомление о задании, добавляем текст о приближении астероида к планете",
                        "Ether(3, 'ExpPhysGun_QuestEther', Format(CT(\"Script.Mod_ExpPhysGun.124\"),\"<0>\",Name(TargetPlanet),\"<1>\",AsteroidNumber), asteroid);",
                        "DChange(1);",
                        "exit;"
                    ],
                    "#": 140,
                    "Type": "Top",
                    "Parent": -1,
                    "Pos.x": -20,
                    "Pos.y": 615
                },
                {
                    "Name": "",
                    "Code.Type": "Turn",
                    "Code": [
                        "//Число запусков скрипта +1",
                        "GExpPhysGunGlobalState = GExpPhysGunGlobalState + 1;",
                        "//Квест временно отменяется (но позднее игрок всё равно сможет его начать)",
                        "questState = -2;",
                        "//Уничтожаем временного транка",
                        "if(GroupToShip(NavigationPoint))",
                        "{",
                        "    ShipDestroy(GroupToShip(NavigationPoint), 1);",
                        "    ShipOut(GroupToShip(NavigationPoint));",
                        "}",
                        "//Прячем астероид на планету и уничтожаем",
                        "if(GroupToShip(Asteroid))",
                        "{",
                        "    TransferShip(GroupToShip(Asteroid), PlanetNone);",
                        "    ShipDestroy(GroupToShip(Asteroid), 1);",
                        "    Chameleon(GroupToShip(Asteroid));",
                        "    ShipOut(GroupToShip(Asteroid));",
                        "}",
                        "ShipOut(Player());"
                    ],
                    "#": 141,
                    "Type": "Top",
                    "Parent": -1,
                    "Pos.x": 100,
                    "Pos.y": 615
                },
                {
                    "Name": "",
                    "Code.Type": "Turn",
                    "Code": [
                        "OrderFollowShip(Player(), asteroid, 1);"
                    ],
                    "#": 142,
                    "Type": "Top",
                    "Parent": -1,
                    "Pos.x": 220,
                    "Pos.y": 615
                },
                {
                    "Name": "",
