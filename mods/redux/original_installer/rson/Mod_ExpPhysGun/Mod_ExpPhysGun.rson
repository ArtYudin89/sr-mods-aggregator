                },
                {
                    "Type": "TItem",
                    "Name": "PhysGunPrototype",
                    "Class": 5,
                    "Item.Type": 0,
                    "Size": 10,
                    "Level": 1,
                    "Radius": 150,
                    "Owner": 6,
                    "Useless": "",
                    "+Place": "",
                    "Pos.x": 90,
                    "Pos.y": 280,
                    "Parent": -1,
                    "#": 51
                }
            ],
            "Operations": [
                {
                    "Name": "",
                    "Code.Type": "Global",
                    "Code": [
                        "//GExpPhysGunGlobalState >= 0 - число запусков данного скрипта (при запуске может быть сброшен игроком)",
                        "//GExpPhysGunGlobalState == -3 - астероид успешно уничтожен, квест завершён",
                        "//GExpPhysGunGlobalState == -4 - астероид врезался в планету, все погибли, квест завершён",
                        "//Если не выставлен маркер о завершении квеста",
                        "if(GExpPhysGunGlobalState >= 0)",
                        "{",
                        "    //Скрипт стартует не раньше, чем через 5 лет от начала игры",
                        "    if(CurTurn() >= 2125)",
                        "    {",
                        "        //Попытка запуска скрипта происходит не чаще чем раз в 10 ходов и только в момент выхода игрока из гипера (влёта в систему)",
                        "        if(GRunFrom == 3)",
                        "        {",
                        "            if(CurTurn() - GLastTurnRun(GScriptName) > 10)",
                        "            {",
                        "                //У игрока в слоте также должен быть установлен радар",
                        "                if(ShipEqInSlot(Player(), t_Radar))",
                        "                {",
                        "                    GRun();",
                        "                }",
                        "            }",
                        "        }",
                        "    }",
                        "}"
                    ],
                    "#": 57,
                    "Type": "Top",
                    "Parent": -1,
                    "Pos.x": 0,
                    "Pos.y": 710
                },
                {
                    "Name": "",
                    "Code.Type": "Init",
                    "Code": [
                        "dialogVar = -1;",
                        "//Для тестирования можно выставить значение меньше 2220 (или закоментить следующие условие), это влияет на дальность стартовой позиции астероида",
                        "if(PlanetOrbitRadius(TargetPlanet) < 2200) questState = -2;",
                        "//Если игрок имеет слишком медленный корабль, отменяем запуск скрипта",
                        "if(ShipSpeed(Player()) < 800) questState = -2;",
                        "//Если в системе нет ТЦ, отменяем запуск скрипта",
                        "if(!StarRuins(ScriptStar, 'TC')) questState = -2;",
                        "else",
                        "{",
                        "    QuestTC_Id = Id(StarRuins(ScriptStar, 'TC'));",
                        "    QuestTC_Name = ShipName(StarRuins(ScriptStar, 'TC'));",
                        "    //Случайно определяем номер астероида",
                        "    AsteroidNumber = Rnd(333, 999);",
                        "    //Определяем верхний лимит популяции на планете, которой угрожает астероид",
                        "    //1000 единиц популяции соответствует в игре миллиону человек, а не тысяче",
                        "    //MaxTargetPlanetPopulation = round(PortionInDiapason(PlanetSize(TargetPlanet), 60, 100, 100000, 1000000));",
                        "}"
                    ],
                    "#": 58,
                    "Type": "Top",
                    "Parent": -1,
                    "Pos.x": 60,
                    "Pos.y": 710
                },
                {
                    "Name": "",
                    "Code.Type": "Turn",
                    "Code": [
                        "if(!ShipIsTakeoff(Player())) {",
                        "  //Обеспечиваем \"Враждебное\" отношение астероида к игроку (потому что \"Отличное\" выглядит тупее)",
                        "  if(GroupToShip(Asteroid)) ShipSetBad(GroupToShip(Asteroid), Player());",
                        "  //Каждый день пока идёт эвакуация, компенсируем прирост населения эвакуируемой планеты",
                        "  if(EvacInProcess)",
                        "  {",
                        "      PlanetPopulation(TargetPlanet, EvacInProcess);",
                        "      //Можно считать по оригинальным формулам, а можно тупо запомнить число населения на момент начала эвакуации",
                        "      //if(EvacInProcess < CurTurn())",
                        "      //{",
                        "          //Используем оригинальную игровую формулу для расчёта сегодняшнего прироста населения планеты",
                        "          //1000 единиц популяции соответствует в игре миллиону человек, а не тысяче",
                        "          //300 - константа прироста населения при превышении доступного для планеты лимита",
                        "      //    flt0 = PlanetPopulation(TargetPlanet);",
                        "      //    if(flt0 > MaxTargetPlanetPopulation) PlanetPopulation(TargetPlanet, round(flt0 - 300));",
                        "      //    else PlanetPopulation(TargetPlanet, round(flt0 / 0.02));",
                        "          //Делаем пометку, что за текущий ход убыль населения уже обеспечили",
                        "      //    EvacInProcess = CurTurn();",
                        "      //}",
                        "  }",
                        "  ",
                        "  //Скрипт успешно стартовал, начинаем расчёт координат, скоростей, орбит и т.д.",
                        "  if(!questState)",
                        "  {",
                        "  \t//Устанавливаем ходы",
                        "  \t//turnPlanet - сколько ходов сделает планета до столкновения с астероидом",
                        "  \t//turnAsteroid - сколько ходов астероид летит к центру системы, больше устанавливать",
                        "  \t//не рекомендуется из-за скорости",
                        "  \t//turnCrash - сколько ходов астероид будет лететь после крюка",
                        "  \tturnAsteroid = 35;",
                        "  \tturnCrash = 7;",
                        "  \tturnPlanet = turnAsteroid + turnCrash;",
                        "  \t//Создаём транка для координирования пути астероида",
                        "  \tdwd0 = BuyTranclucator(PlanetNone);",
                        "  \tShipJoin(NavigationPoint, dwd0);",
                        "  \tChangeState(1, dwd0);",
                        "  \t//рассчитываем угол вращения планеты и где она будет через turnPlanet ходов",
                        "  \ta = PlanetOrbitalVelocity(TargetPlanet);",
                        "  \tif(a < 0) modR = -1.0;",
                        "  \telse modR = 1.0;",
                        "  \ta = a * turnPlanet;",
                        "  \ta = a * pi;",
                        "  \ta = a / 1800.0;",
                        "  \tflt0 = CoordX(TargetPlanet);",
                        "  \tflt1 = CoordY(TargetPlanet);",
                        "  \t//Вычисляем координаты столкновения",
                        "  \tcrashX = flt0 * cos(a) - flt1 * sin(a);",
                        "  \tcrashY = flt0 * sin(a) + flt1 * cos(a);",
                        "  \t//Устанавливаем транку координаты столкновения, транк остаётся сидеть на незаселёнке, координаты запоминаем",
                        "  \tShipSetCoords(dwd0, crashX, crashY);",
                        "  \t//Код транка-астероида",
                        "  \t//Создаём транка-астероида и выставляем ему нужные параметры/координаты",
                        "  \tdwd1 = BuyTranclucator(PlanetNone);",
                        "  \t//Меняем некоторые параметры для выставления нужной скорости",
                        "  \t//Удаляем все предметы кроме двигателя/бака/корпуса",
                        "  \tfor(i = ShipItems(dwd1) - 1; i > 0; i = i - 1)",
                        "  \t{",
                        "  \t\tdwd3 = ShipItems(dwd1, i);",
                        "  \t\tif(!ItemIsInUse(dwd3) || ItemType(dwd3) >= t_Weapon1) FreeItem(GetItemFromShip(dwd1, i));",
                        "  \t\telse",
                        "  \t\t{",
                        "  \t\t\tif(ItemType(dwd3) >= t_Hull && ItemType(dwd3) <= t_Engine) continue;",
                        "  \t\t\telse FreeItem(GetItemFromShip(dwd1, i));",
                        "  \t\t}",
                        "  \t}",
                        "  \t//Выставляем размер корпуса в зависимости от уровня сложности настройки удачи",
                        "  \tItemSize(ShipEqInSlot(dwd1, t_Hull), 900 * (GalaxyDiffLevels(7) / 50) + Rnd(125, 250));",
                        "      HullHP(dwd1, ItemSize(ShipEqInSlot(dwd1, t_Hull)));",
                        "  \t//Накладываем штраф к массе корабля в 20%, для нужного коэффициента скорости",
                        "  \tShipSpecialBonuses(dwd1, bonMass, 20);",
                        "  \tShipRepairEq(dwd1);",
                        "  \t//Выставляем транклюкатору кастомный тип",
                        "  \tShipType(dwd1, 'KillerAsteroid');",
                        "  \t//Меняем скин на астероид",
                        "  \tChameleon(dwd1, 'Ship.Akrin.KillerAsteroid');",
                        "  \tShipCalcParam(dwd1);",
                        "  \tShipJoin(Asteroid, dwd1);",
                        "      //Чтобы из астероида выбивались белые цифры урона",
                        "      ShipCustomFaction(dwd1, 'Asteroid');",
                        "  \t//Запоминаем угол между 0,0 и точкой столкновения",
                        "  \t//dwd1 - транк астероид",
                        "  \t//dwd0 - транк место столкновение",
                        "  \tShipSetCoords(dwd1, 0, 0);",
                        "  \ta = Angle(dwd0, dwd1);",
                        "  \t//Рассчитываем точку крюка",
                        "  \tflt0 = a + modR * 170.0;",
                        "  \tflt0 = flt0 * pi;",
                        "  \tflt0 = flt0 / 180.0;",
                        "  \thookX = CoordX(ScriptStar) + 375.0 * sin(flt0);",
                        "  \thookY = CoordY(ScriptStar) - 375.0 * cos(flt0);",
                        "  \t//Выставляем координаты и начальный угол поворота астероида",
                        "  \t//Рассчитываем масштаб карты, чтобы заспавнить астероид за пределами",
                        "  \tdwd3 = StarPlanets(ScriptStar, StarPlanets(ScriptStar) - 1);",
                        "  \t//flt0 - на этом радиусе будет спавится астероид",
                        "  \tflt0 = PlanetOrbitRadius(dwd3) + PlanetSize(dwd3) + 800.0 + 2600.0;",
                        "  \t//Начальные координаты астероида, рассчитываются как точка на удалении flt0 с углом а-90 градусов",
                        "  \tflt1 = a + modR * -115;",
                        "  \tflt1 = flt1 * pi;",
                        "  \tflt1 = flt1 / 180.0;",
                        "  \tstartX = flt0 * sin(flt1);",
                        "  \tstartY = -flt0 * cos(flt1);",
                        "  \t//Выставляем астероиду начальные координаты",
                        "  \tShipSetCoords(dwd1, startX, startY);",
                        "  \t//Вычисляем скорость",
                        "  \t//(!) минимальная скорость 173",
                        "  \t//Выставляем временному транку координат крюка, для вычисления скорости",
                        "  \tdwd0 = GroupToShip(NavigationPoint);",
                        "  \tShipSetCoords(dwd0, hookX, hookY);",
                        "  \tflt1 = Dist(dwd1, dwd0);",
                        "  \t//Какую скорсоть выставить чтобы астероид прошёл расстояние за turnAsteroid ходов",
                        "  \tflt1 = flt1 / turnAsteroid;",
                        "  \t//Увеличиваем стартовую позицию астероида, если скорость слишком низкая",
                        "  \twhile(flt1 < 177.0)",
                        "  \t{",
                        "  \t\tflt0 = flt0 + 100.0;",
                        "  \t\t//Начальные координаты астероида, рассчитываются как точка на удалении flt0 с углом а-90 градусов",
                        "  \t\tflt1 = a + modR * -115;",
                        "  \t\tflt1 = flt1 * pi;",
                        "  \t\tflt1 = flt1 / 180.0;",
                        "  \t\tstartX = flt0 * sin(flt1);",
                        "  \t\tstartY = -flt0 * cos(flt1);",
                        "  \t\tShipSetCoords(dwd1, startX, startY);",
                        "  \t\tflt1 = Dist(dwd1, dwd0);",
                        "  \t\t//Какую скорсоть выставить чтобы астероид прошёл расстояние за turnAsteroid ходов",
                        "  \t\tflt1 = flt1 / turnAsteroid;",
                        "  \t}",
                        "  \t//Перемещаем астероид в систему",
                        "  \tTransferShip(dwd1, ScriptStar);",
                        "  \t//Выставляем начальный угол носом к звезде",
                        "  \tShipAngle(dwd1, Angle(ScriptStar, dwd1));",
                        "  \t//Рассчитываем сколько bonSpeed накинуть для выставления скорости",
                        "  \tflt0 = sqr(ln(0.333));",
                        "  \tflt0 = exp(-sqrt(flt0));",
                        "  \tif(flt1 < 200)",
                        "  \t{",
                        "  \t\tflt1 = flt1 / 0.2;",
                        "  \t\tflt1 = flt1 - 800.0;",
                        "  \t}",
                        "  \tflt1 = flt1 / flt0;",
                        "  \tint0 = round(flt1, 1);",
                        "  \tint0 = int0 - GetEquipmentStats(ShipEqInSlot(dwd1, t_Engine), 0);",
                        "  \t//Меняем скорость через bonSpeed",
                        "  \tShipSpecialBonuses(dwd1, bonSpeed, int0);",
                        "  \tShipCalcParam(dwd1);",
                        "  \t//Активируется турнкод астероида",
                        "  \tmoveState = 1;",
                        "  \t//Квест начинается",
                        "  \tquestState = 1;",
                        "  }",
                        "  //Если условия в системе оказались неподходящими для запуска квеста (проверяется в инит-коде), завершаем скрипт",
                        "  else if(questState == -2)",
                        "  {",
                        "      ShipOut(Player());",
                        "  }",
                        "}",
                        "if(questState > 1)",
                        "{",
                        "    //Типа античит. на самом деле, этот чит может сломать ВСЁ, проще",
                        "    //засчитывать квест проваленным, чем пытаться разобраться после него",
                        "    for(i = GalaxyEvents() - 1; i > -1; i = i - 1)",
                        "    {",
                        "        if(GalaxyEventDate(i) < CurTurn()) break;",
                        "        if(GalaxyEventType(i) == 'PlayerEntersCheatCode')",
                        "        {",
                        "            if(GalaxyEventsTextData(i, 0) == 'ZAWARUDO')",
                        "            {",
                        "                questState = 10;",
                        "                endDate = CurTurn() - 10;",
                        "                GExpPhysGunGlobalState = -4;",
                        "            }",
                        "        }",
                        "    }",
                        "",
                        "\t//Создаём лайнеры и военных",
                        "    if(questState == 2)",
                        "    {",
                        "\t\tquestState = 3;",
                        "\t\tquestVar = 0;",
                        "\t\tdialogVar = 0;",
                        "\t\tif(ShipStar(Player()) == ScriptStar) CustomEther('Galaxy_Alert', 7, '', Format(CT(\"Script.Mod_ExpPhysGun.139\"),\"<0>\",Name(ScriptStar),\"<1>\",Name(TargetPlanet)));",
                        "",
                        "\t\tAddPlanetNews(Format(CT(\"Script.Mod_ExpPhysGun.27\"),\"<0>\",Name(ScriptStar),\"<1>\",Name(TargetPlanet)));",
                        "",
                        "\t\tfor(i = 0; i < 5; i = i + 1)",
                        "\t\t{",
                        "\t\t\tdwd0 = BuyTransport(TargetPlanet, 1);",
                        "\t\t\tShipJoin(EvacShips, dwd0);",
                        "\t\t\tChangeState(5, dwd0);",
                        "\t\t}",
                        "\t\tfor(i = 0; i < 3; i = i + 1)",
                        "\t\t{",
                        "\t\t\tdwd0 = BuyWarrior(EvacPlanet, 1);",
                        "\t\t\tShipJoin(PlanetDefenders, dwd0);",
                        "\t\t\tChangeState(3, dwd0);",
                        "\t\t}",
                        "\t\tGroupSetBad(PlanetDefenders, GroupToShip(Asteroid));",
                        "\t\tShipSetBad(GroupToShip(Asteroid), Player());",
                        "\t\tfor(i = 0; i < 5; i = i + 1)",
                        "\t\t{",
                        "\t\t\tdwd0 = BuyTransport(EvacPlanet, 1);",
                        "\t\t\tShipJoin(EvacShips, dwd0);",
                        "\t\t\tChangeState(4, dwd0);",
                        "\t\t}",
                        "    }",
                        "\t//Ждём, пока игрок ударит астероид",
                        "    else if(questState == 3)",
                        "    {",
                        "\t\tif(GroupToShip(Asteroid))",
                        "\t\t{",
                        "\t\t\tif(Hit(GroupToShip(Asteroid), 0))",
                        "\t\t\t{",
                        "\t\t\t\tquestVar = questVar + 1;",
                        "\t\t\t\tif(questVar == 2) questState = 4;",
                        "\t\t\t}",
                        "\t\t}",
                        "    }",
                        "    else",
                        "\t{",
                        "\t\tif(!GroupToShip(Asteroid))",
                        "\t\t{",
                        "\t\t\tif(moveState > 0)",
                        "\t\t\t{",
                        "\t\t\t\t//Если астероид столкнулся с планетой",
                        "\t\t\t\tif(moveState == 7)",
                        "\t\t\t\t{",
                        "\t\t\t\t\tif(ShipStar(Player()) == ScriptStar) CustomEther('Galaxy_Alert', 7, '',Format(CT(\"Script.Mod_ExpPhysGun.137\"),\"<0>\",Name(TargetPlanet)));",
                        "\t\t\t\t\tAddPlanetNews(Format(CT(\"Script.Mod_ExpPhysGun.64\"),\"<0>\",GameDateTxtByTurn(CurTurn() + 1),\"<1>\",Name(TargetPlanet),\"<2>\",Name(ScriptStar),\"<3>\",AsteroidNumber));",
                        "\t\t\t\t\tif(questState == 3) Ether(5, 'ExpPhysGun_QuestEther', Format(CT(\"Script.Mod_ExpPhysGun.103\"),\"<0>\",Name(TargetPlanet),\"<1>\",AsteroidNumber));",
                        "\t\t\t\t\tif(questState == 5 && QuestTC_Id != -3) Ether(5, 'ExpPhysGun_QuestEther', Format(CT(\"Script.Mod_ExpPhysGun.22\"),\"<0>\",QuestTC_Name));",
                        "\t\t\t\t\tif(questState == 6) Ether(5, 'ExpPhysGun_QuestEther', CT(\"Script.Mod_ExpPhysGun.45\"));",
                        "",
                        "\t\t\t\t\tif(GetShipPlanet(Player()))",
                        "\t\t\t\t\t{",
                        "\t\t\t\t\t\tif(GetShipPlanet(Player()) == TargetPlanet) CustomLose('FormGameEnd.LossKilledByExplosion');",
                        "\t\t\t\t\t}",
                        "",
                        "\t\t\t\t\tPlanetOwner(TargetPlanet, None);",
                        "\t\t\t\t\tPlanetTerrain(TargetPlanet, 0, 100);",
                        "\t\t\t\t\tPlanetTerrain(TargetPlanet, 1, 80);",
                        "\t\t\t\t\tPlanetTerrain(TargetPlanet, 2, 50);",
                        "                    //Добавляем кучу ценной руды и минералов на планету",
                        "                    for(i = 1; i <= Rnd(7, 10); i = i + 1) {",
                        "                        dwd1 = CreateCustomCountableItem('NuggetAsteroid', Rnd(35, 70), 1);",
                        "                        ItemCost(dwd1, ItemCost(dwd1) * (GoodsBuyPrice(TargetPlanet, t_Minerals) * 7));",
                        "                        AddItemToPlanet(TargetPlanet, dwd1);",
                        "                    }",
                        "                    for(i = 1; i <= Rnd(4, 7); i = i + 1) {",
                        "                        dwd1 = CreateGoods(t_Minerals, Rnd(35, 70), 1);",
                        "                        AddItemToPlanet(TargetPlanet, dwd1);",
                        "                    }",
                        "\t\t\t\t\tif(ShipInNormalSpace(Player())) StarMapCenterView(crashX, crashY);",
                        "\t\t\t\t\t//Проверяем наличие физгана на борту игрока",
                        "\t\t\t\t\tdwd0 = ScriptItemToItem(PhysGunPrototype);",
                        "\t\t\t\t\t//Физган существует (не уничтожен)",
                        "\t\t\t\t\tif(dwd0)",
                        "\t\t\t\t\t{",
                        "\t\t\t\t\t\tItemOnActCode(dwd0, '');",
                        "\t\t\t\t\t\tItemOnUseCode(dwd0, '');",
                        "\t\t\t\t\t\t//Физган у игрока в трюме",
                        "\t\t\t\t\t\t//Взрываем физган",
                        "\t\t\t\t\t\tif(ItemIn(PhysGunPrototype, Player()))",
                        "\t\t\t\t\t\t{",
                        "\t\t\t\t\t\t\tHullHP(Player(), HullHP(Player()) - round(0.40 * HullHP(Player())));",
                        "\t\t\t\t\t\t\tif(HullHP(Player()) < 1) HullHP(Player(), 1);",
                        "\t\t\t\t\t\t\tEther(8, '',CT(\"Script.Mod_ExpPhysGun.61\"));",
                        "\t\t\t\t\t\t\tdwd1 = CreateQuestItem('BrokenPhysGun');",
                        "\t\t\t\t\t\t\tItemSize(dwd1, ItemSize(PhysGunPrototype));",
                        "\t\t\t\t\t\t\tItemCost(dwd1, 1);",
                        "\t\t\t\t\t\t\tFreeItem(GetItemFromShip(Player(), FindItemInShip(Player(), dwd0)));",
                        "\t\t\t\t\t\t\tSetName(dwd1, CT('Script.Mod_ExpPhysGun.PhysGunDestroyedName'));",
                        "\t\t\t\t\t\t\tAddItemToShip(Player(), dwd1);",
                        "\t\t\t\t\t\t}",
                        "\t\t\t\t\t}",
                        "\t\t\t\t\t//Стейт завершения скрипта",
                        "\t\t\t\t\tquestState = 10;",
                        "\t\t\t\t\t//3 хода на завершение скрипта",
                        "\t\t\t\t\tendDate = CurTurn() + 3;",
                        "\t\t\t\t\t//Тернкод астероида отключается",
                        "\t\t\t\t\tmoveState = -1;",
                        "\t\t\t\t}",
                        "\t\t\t\t//Если астероид был как-либо уничтожен до столкновения",
                        "\t\t\t\telse",
                        "\t\t\t\t{",
                        "\t\t\t\t\tif(ShipStar(Player()) == ScriptStar) CustomEther('Galaxy_Alert', 7, '', Format(CT(\"Script.Mod_ExpPhysGun.63\"),\"<0>\",AsteroidNumber,\"<1>\",Name(TargetPlanet)));",
                        "\t\t\t\t\tif(questState == 3) Ether(4, 'ExpPhysGun_QuestEther', Format(CT(\"Script.Mod_ExpPhysGun.136\"),\"<0>\",Name(TargetPlanet),\"<1>\",AsteroidNumber));",
                        "\t\t\t\t\tif(questState == 5 && QuestTC_Id != -3) Ether(4, 'ExpPhysGun_QuestEther', Format(CT(\"Script.Mod_ExpPhysGun.22\"),\"<0>\",QuestTC_Name));",
                        "\t\t\t\t\t//изначально выставляем стейт 'игрок уничтожил астероид нечестно', пока непонятно чем бил",
                        "\t\t\t\t\t//если не отказался от задания на ТЦ (questState = 5)",
                        "\t\t\t\t\tif(questState == 5 && QuestTC_Id == -3) questState = 5;",
                        "\t\t\t\t\telse questState = 8;",
                        "\t\t\t\t\t//проверяем наличие физгана на борту игрока и бил ли он им, если да то даём юслс предмет(сломаный физган)",
                        "\t\t\t\t\tdwd0 = ScriptItemToItem(PhysGunPrototype);",
                        "\t\t\t\t\t//Физган существует(не уничтожен)",
                        "\t\t\t\t\tif(dwd0)",
                        "\t\t\t\t\t{",
                        "\t\t\t\t\t\tItemOnActCode(dwd0, '');",
                        "\t\t\t\t\t\tItemOnUseCode(dwd0, '');",
                        "\t\t\t\t\t\t//Физган у игрока в трюме",
                        "\t\t\t\t\t\t//Взрываем физган",
                        "\t\t\t\t\t\tif(ItemIn(PhysGunPrototype, Player()))",
                        "\t\t\t\t\t\t{",
                        "\t\t\t\t\t\t\tHullHP(Player(), HullHP(Player()) - round(0.40 * HullHP(Player())));",
                        "\t\t\t\t\t\t\tif(HullHP(Player()) < 1) HullHP(Player(), 1);",
                        "\t\t\t\t\t\t\tEther(8, '', CT(\"Script.Mod_ExpPhysGun.135\"));",
                        "\t\t\t\t\t\t\t//Игрок бил физганом, даём сломаный",
                        "\t\t\t\t\t\t\tif(ScriptItemData(dwd0, 1) == 3)",
                        "\t\t\t\t\t\t\t{",
                        "\t\t\t\t\t\t\t\t//Выставляем стейт 'игрок бил астероид физганом'",
                        "\t\t\t\t\t\t\t\tquestState = 7;",
                        "\t\t\t\t\t\t\t\tEvacInProcess = 0;",
                        "\t\t\t\t\t\t\t\tdwd1 = CreateQuestItem('BrokenPhysGun');",
                        "\t\t\t\t\t\t\t\tItemSize(dwd1, ItemSize(PhysGunPrototype));",
                        "\t\t\t\t\t\t\t\tItemCost(dwd1, 1);",
                        "\t\t\t\t\t\t\t\tLinkItemToScript(dwd1, PhysGunPrototype);",
                        "\t\t\t\t\t\t\t\tAddItemToShip(Player(), dwd1);",
                        "\t\t\t\t\t\t\t\tAddPlanetNews(Format(CT(\"Script.Mod_ExpPhysGun.62\"),\"<0>\",Name(ScriptStar),\"<1>\",Name(TargetPlanet)));",
                        "\t\t\t\t\t\t\t\tNewsAdd(Format(CT(\"Script.Mod_ExpPhysGun.140\"),\"<0>\",Name(TargetPlanet)));",
                        "\t\t\t\t\t\t\t\tSound('Sound.LiberationSystem');",
                        "\t\t\t\t\t\t\t}",
                        "\t\t\t\t\t\t\tFreeItem(GetItemFromShip(Player(), FindItemInShip(Player(), dwd0)));",
                        "\t\t\t\t\t\t}",
                        "\t\t\t\t\t}",
                        "\t\t\t\t\t//Включаем диалоги, если не отказался от задания на ТЦ (questState = 5)",
                        "\t\t\t\t\tif(questState == 5 && QuestTC_Id == -3) dialogVar = -3;",
                        "\t\t\t\t\telse dialogVar = 3;",
                        "\t\t\t\t\tquestVar = 0;",
                        "\t\t\t\t\t//60 ходов на завершение скрипта или 3, если отказался от задания на ТЦ (questState = 5)",
                        "\t\t\t\t\tif(questState == 5 && QuestTC_Id == -3)",
                        "\t\t\t\t\t{",
                        "\t\t\t\t\t\t//Завершаем скрипт",
                        "\t\t\t\t\t\tquestState = 10;",
                        "\t\t\t\t\t\tendDate = CurTurn() + 3;",
                        "\t\t\t\t\t}",
                        "\t\t\t\t\telse endDate = CurTurn() + 60;",
                        "\t\t\t\t\t//Тернкод астероида отключается",
                        "\t\t\t\t\tmoveState = -1;",
                        "\t\t\t\t}",
                        "\t\t\t}",
                        "\t\t}",
                        "",
                        "\t\tif(questState > 6) {",
                        "\t\t\tif(dialogVar == 4) {",
                        "\t\t\t\tif(CurTurn() > questVar) { //Переименование планеты",
                        "\t\t\t\t\tAddPlanetNews(Format(CT(\"Script.Mod_ExpPhysGun.144\"),\"<0>\",Name(TargetPlanet),\"<1>\",Name(TargetPlanet),\"<2>\",addRew));",
                        "\t\t\t\t\tSetName(TargetPlanet, addRew);",
                        "\t\t\t\t\tdialogVar = -3;",
                        "\t\t\t\t\tif(!QuestTC_Id) {",
                        "\t\t\t\t\t\tquestState = 10; //Стейт завершения скрипта",
                        "\t\t\t\t\t\tendDate = CurTurn() + 3;",
                        "\t\t\t\t\t}",
                        "\t\t\t\t\telse endDate = CurTurn() + 60;",
                        "\t\t\t\t}",
                        "            }",
                        "\t\t\t//Полное завершение квеста (игрок победил, либо проиграл)",
                        "\t\t\tif(CurTurn() > endDate)",
                        "\t\t\t{",
                        "\t\t\t\tif(GExpPhysGunGlobalState >= 0) GExpPhysGunGlobalState = -3;",
                        "\t\t\t\tquestState = -3;",
                        "\t\t\t\tmoveState = -3;",
                        "\t\t\t\tQuestTC_Id = -3;",
                        "\t\t\t\tdialogVar = -3;",
                        "\t\t\t\tcur_ship = GroupToShip(Asteroid);",
                        "\t\t\t\tif(cur_ship)",
                        "\t\t\t\t{",
                        "\t\t\t\t\tTransferShip(cur_ship, PlanetNone);",
                        "\t\t\t\t\tShipDestroy(cur_ship, 1);",
                        "\t\t\t\t}",
                        "\t\t\t\tif(GroupToShip(NavigationPoint)) ShipDestroy(GroupToShip(NavigationPoint), 1);",
                        "\t\t\t\t//Выставляем маркер завершения эвакуации (прирост населения планеты вновь продолжится)",
                        "\t\t\t\tEvacInProcess = 0;",
                        "\t\t\t\t//Снимаем защиту системы",
                        "\t\t\t\tNoComeKlingToStar(ScriptStar, 0);",
                        "\t\t\t\tAllShipOut();",
                        "\t\t\t}",
                        "\t\t}",
                        "    }",
                        "}",
                        "if(moveState > 0)",
                        "{",
                        "    asteroid = GroupToShip(Asteroid);",
                        "    if(asteroid)",
                        "    {",
                        "\t\t//Астероид подлетает к звезде, ускоряем его",
                        "\t\tif(moveState == 1)",
                        "\t\t{",
                        "\t\t\tif(sqr(CoordX(asteroid) - hookX) + sqr(CoordY(asteroid) - hookY) < sqr(3 * ShipSpeed(asteroid)))",
                        "\t\t\t{",
                        "\t\t\t\tmoveState = 2;",
                        "\t\t\t\tint0 = ShipSpecialBonuses(asteroid, bonSpeed);",
                        "\t\t\t\tShipSpecialBonuses(asteroid, bonSpeed, int0 + 2000);",
                        "\t\t\t\tShipCalcParam(asteroid);",
                        "\t\t\t\tif(ShipStar(Player()) == ScriptStar) CustomEther('Galaxy_Alert', 7, '', Format(CT(\"Script.Mod_ExpPhysGun.66\"),\"<0>\",Name(ScriptStar),\"<1>\",AsteroidNumber,\"<2>\",Name(TargetPlanet)));",
                        "\t\t\t}",
                        "\t\t}",
                        "\t\t//Выставляем траекторию и приказ лететь в точку столкновения",
                        "\t\telse if(moveState == 2)",
                        "\t\t{",
                        "\t\t\tif(sqr(CoordX(asteroid) - hookX) + sqr(CoordY(asteroid) - hookY) < 10000)",
                        "\t\t\t{",
                        "\t\t\t\tmoveState = 3;",
                        "\t\t\t\tShipSetCoords(GroupToShip(NavigationPoint), crashX, crashY);",
                        "\t\t\t\tflt1 = Angle(GroupToShip(NavigationPoint), asteroid);",
                        "\t\t\t\tflt1 = flt1 * pi;",
                        "\t\t\t\tflt1 = flt1 / 180.0;",
                        "\t\t\t\tflt0 = 7000.0;",
                        "\t\t\t\tendX = CoordX(asteroid);",
                        "\t\t\t\tendX = endX + flt0 * sin(flt1);",
                        "\t\t\t\tendY = CoordY(asteroid);",
                        "\t\t\t\tendY = endY - flt0 * cos(flt1);",
                        "\t\t\t\tOrderMove(asteroid, endX, endY);",
                        "\t\t\t}",
                        "\t\t}",
                        "\t\t//Уменьшаем скорость, обновляем траекторию от текущего угла",
                        "\t\telse if(moveState == 3)",
                        "\t\t{",
                        "\t\t\tmoveState = 4;",
                        "\t\t\tint0 = ShipSpecialBonuses(asteroid, bonSpeed);",
                        "\t\t\tShipSpecialBonuses(asteroid, bonSpeed, int0 / 2);",
                        "\t\t\tShipCalcParam(asteroid);",
                        "\t\t\tShipSetCoords(GroupToShip(NavigationPoint), crashX, crashY);",
                        "\t\t\tflt1 = Angle(GroupToShip(NavigationPoint), asteroid);",
                        "\t\t\tflt1 = flt1 * pi;",
                        "\t\t\tflt1 = flt1 / 180.0;",
                        "\t\t\tflt0 = 7000.0;",
                        "\t\t\tendX = CoordX(asteroid);",
                        "\t\t\tendX = endX + flt0 * sin(flt1);",
                        "\t\t\tendY = CoordY(asteroid);",
                        "\t\t\tendY = endY - flt0 * cos(flt1);",
                        "\t\t\tOrderMove(asteroid, endX, endY);",
                        "\t\t}",
                        "\t\t//Последняя точка, меняем скорость для столкновения с планетой и снова обновляем траекторию относительно угла",
                        "\t\telse if(moveState == 4)",
                        "\t\t{",
                        "\t\t\tmoveState = 5;",
                        "\t\t\tnav_point = GroupToShip(NavigationPoint);",
                        "\t\t\t//Проверяем координаты точки столкновения",
                        "\t\t\ta = PlanetOrbitalVelocity(TargetPlanet);",
                        "\t\t\ta = a * turnCrash;",
                        "\t\t\ta = a * pi;",
                        "\t\t\ta = a / 1800.0;",
                        "\t\t\tflt0 = CoordX(TargetPlanet);",
                        "\t\t\tflt1 = CoordY(TargetPlanet);",
                        "\t\t\t//Все переменные типа флоат заняты, использую startX / startY в данный момент",
                        "\t\t\tstartX = flt0 * cos(a) - flt1 * sin(a);",
                        "\t\t\tstartY = flt0 * sin(a) + flt1 * cos(a);",
                        "\t\t\t//Если первоначальные координаты столкновения больше на +/-5 чем текущие, то выставляем текущие",
                        "\t\t\tif(sqr(abs(startX) - abs(crashX)) > 24) crashX = startX;",
                        "\t\t\tif(sqr(abs(startY) - abs(crashY)) > 24) crashY = startY;",
                        "\t\t\t//Выставляем координаты столкновения транку на незаселёнке",
                        "\t\t\tShipSetCoords(nav_point, crashX, crashY);",
                        "\t\t\tflt1 = Angle(nav_point, asteroid);",
                        "\t\t\tShipAngle(asteroid, flt1);",
                        "\t\t\tflt1 = flt1 * pi;",
                        "\t\t\tflt1 = flt1 / 180.0;",
                        "\t\t\tflt0 = 5000.0;",
                        "\t\t\t//Вычисляем более точные координаты столкновения и выставляем приказ лететь к ним",
                        "\t\t\tendX = CoordX(asteroid);",
                        "\t\t\tendX = endX + flt0 * sin(flt1);",
                        "\t\t\tendY = CoordY(asteroid);",
                        "\t\t\tendY = endY - flt0 * cos(flt1);",
                        "\t\t\tOrderMove(asteroid, endX, endY);",
                        "            OrderLanding(asteroid, TargetPlanet);",
                        "\t\t\t//Вычисляем скорость",
                        "\t\t\t//(!) Минимальная скорость 173",
                        "\t\t\tflt0 = sqr(ln(0.333));",
                        "\t\t\tflt0 = exp(-sqrt(flt0));",
                        "\t\t\tflt1 = Dist(asteroid, nav_point);",
                        "\t\t\tflt1 = flt1 / turnCrash;",
                        "\t\t\tif(flt1 < 200)",
                        "\t\t\t{",
                        "\t\t\t\tflt1 = flt1 / 0.2;",
                        "\t\t\t\tflt1 = flt1 - 800.0;",
                        "\t\t\t}",
                        "\t\t\tflt1 = flt1 / flt0;",
                        "\t\t\tint0 = round(flt1, 1);",
                        "\t\t\tint0 = int0 - GetEquipmentStats(ShipEqInSlot(asteroid, t_Engine), 0);",
                        "",
                        "\t\t\t//Меняем скорость с помощью bonSpeed",
                        "\t\t\tShipSpecialBonuses(asteroid, bonSpeed, int0);",
                        "\t\t\tShipCalcParam(asteroid);",
                        "\t\t\tif(ShipStar(Player()) == ScriptStar) CustomEther('Galaxy_Alert', 7, '', Format(CT(\"Script.Mod_ExpPhysGun.67\"),\"<0>\",AsteroidNumber,\"<1>\",turnCrash));",
                        "\t\t}",
                        "\t\t//До столкновения с планетой остался 1 ход (!!!)",
                        "\t\telse if(moveState == 5)",
                        "\t\t{",
                        "\t\t\tif(CountTurn(asteroid, TargetPlanet) <= 2)",
                        "\t\t\t{",
                        "\t\t\t\tmoveState = 6;",
                        "\t\t\t\t//Вешаем на корпус транка-астероида скриптовый акткод для анимации столкновения",
                        "\t\t\t\tdwd1 = ShipEqInSlot(asteroid, t_Hull);",
                        "\t\t\t\tLinkItemToScript(dwd1, AsteroidCrashActCode);",
                        "\t\t\t\tItemOnActCode(dwd1, GenerateCodeStringFromBlock('ActCodeBlocksList.AsteroidCrashActCode'));",
                        "\t\t\t\tif(ShipStar(Player()) == ScriptStar) CustomEther('Galaxy_Alert', 7, '', Format(CT(\"Script.Mod_ExpPhysGun.68\"),\"<0>\",AsteroidNumber,\"<1>\",Name(TargetPlanet)));",
                        "\t\t\t}",
                        "\t\t}",
                        "    }",
                        "}"
                    ],
                    "#": 59,
                    "Type": "Top",
                    "Parent": -1,
                    "Pos.x": 120,
                    "Pos.y": 710
                },
                {
                    "Name": "",
                    "Code.Type": "DialogBegin",
                    "Code": [
                        "//С игроком в космосе связывается квестовый ТЦ",
                        "if(questState == 4)",
                        "{",
                        "    cur_ruin = GetTalkShip();",
                        "    if(cur_ruin)",
                        "    {",
                        "        if(Id(cur_ruin) == QuestTC_Id) AddDialogOverride('TCSpaceDialog', 1);",
                        "    }",
                        "}",
                        "//Вступительный диалог, стартующий задание",
                        "if(questState == 1)",
                        "{",
                        "    if(GetTalkShip() == Player())",
                        "    {",
                        "        if(questVar == 99) AddDialogOverride('QuestBeginDialog', 1);",
                        "    }",
                        "}",
                        "//Игрок сел на планету, которой угрожает/угрожал астероид, запускаем диалог",
                        "if(dialogVar < 4)",
                        "{",
                        "    cur_planet = GetShipPlanet(Player());",
                        "    if(cur_planet)",
                        "    {",
                        "        if(cur_planet == TargetPlanet) AddDialogOverride('TargetPlanetDialog', 1);",
                        "    }",
                        "}",
                        "cur_ruin = GetShipRuins(Player());",
                        "if(cur_ruin)",
                        "{",
                        "    if(ShipType(cur_ruin) == 'TC')",
                        "    {",
                        "        //Прилетел на тот самый квестовый ТЦ",
                        "        if(Id(cur_ruin) == QuestTC_Id)",
                        "        {",
                        "\t\t\t//Если квестовый ТЦ всё ещё находится в квестовой системе",
                        "\t\t\tif(ShipStar(cur_ruin) == ScriptStar)",
                        "\t\t\t{",
                        "\t\t\t\t//Игрок уже поговорил с ТЦ в космосе и теперь прилетел за физганом",
                        "\t\t\t\tif(questState == 5)",
                        "\t\t\t\t{",
                        "\t\t\t\t\t//Спавним 3 пиратов и отправляем их в систему ScriptStar, ну чтобы задача с лайнерами халявой не казалась",
                        "\t\t\t\t\tif(!pirateAttack)",
                        "\t\t\t\t\t{",
                        "\t\t\t\t\t\tpirateAttack = 1;",
                        "\t\t\t\t\t\tdwd1 = StarNearbyStars(ScriptStar, 1);",
                        "                        for(i = 1; i <= 3; i = i + 1)",
                        "                        {",
                        "\t\t\t\t\t\t    dwd0 = BuyPirate(PlanetPirateClan(), 200);",
                        "                            ShipSubType(dwd0, 0);",
                        "\t\t\t\t\t\t    ShipRefit(dwd0);",
                        "                            ShipRefit(dwd0);",
                        "\t\t\t\t\t\t    MakeShipEnterStar(dwd0, ScriptStar, dwd1, 0);",
                        "                        }",
                        "\t\t\t\t\t}",
                        "\t\t\t\t\tAddDialogOverride('TCPhysGunDialog', 21);",
                        "\t\t\t\t}",
                        "\t\t\t\t//Астероид уничтожен физганом, игрок прилетел жаловаться, что физган ёбнул",
                        "\t\t\t\telse if(questState == 7)",
                        "\t\t\t\t{",
                        "\t\t\t\t\tif(ItemIn(PhysGunPrototype, Player()))",
                        "\t\t\t\t\t{",
                        "\t\t\t\t\t\t//Игрок сдал сломанный физган",
                        "\t\t\t\t\t\tQuestTC_Id = 0;",
                        "\t\t\t\t\t\t//60 ходов на завершение скрипта или 3, если уже завершил диалоги с планетой",
                        "\t\t\t\t\t\tif(dialogVar == -3) endDate = CurTurn() + 3;",
                        "\t\t\t\t\t\telse endDate = CurTurn() + 60;",
                        "\t\t\t\t\t\tFreeItem(GetItemFromShip(Player(), FindItemInShip(Player(), PhysGunPrototype)));",
                        "\t\t\t\t\t\tAddDialogOverride('TCFinalDialog', 21);",
                        "\t\t\t\t\t}",
                        "\t\t\t\t}",
                        "\t\t\t}",
                        "        }",
                        "    }",
                        "}"
                    ],
                    "#": 60,
                    "Type": "Top",
                    "Parent": -1,
                    "Pos.x": 180,
                    "Pos.y": 710
                },
                {
                    "Name": "",
                    "Code.Type": "Turn",
                    "Code": [
                        "if(questState == 1) {",
                        "  if(ShipInNormalSpace(Player()))",
                        "  {",
                        "      //Стартует начальный диалог квеста (типа игрок общается со своими мыслями)",
                        "      questVar = 99;",
                        "      Dialog(QuestBeginDialog, Player());",
                        "      questVar = 0;",
                        "  }",
                        "}",
                        "if(questState == 4) {",
                        "  if(ShipStar(Player()) == ScriptStar && ShipInNormalSpace(Player()))",
                        "  {",
                        "      cur_ruin = IdToShip(QuestTC_Id);",
                        "      if(cur_ruin)",
                        "      {",
                        "          if(ShipStar(cur_ruin) == ScriptStar && ShipInNormalSpace(cur_ruin))",
                        "          {",
                        "              //Запускаем диалог с ТЦ в космосе",
                        "              Dialog(TCSpaceDialog, cur_ruin);",
                        "          }",
                        "      }",
                        "  }",
                        "}"
                    ],
                    "#": 112,
                    "Type": "Top",
                    "Parent": -1,
                    "Pos.x": 80
                },
                {
                    "Name": "",
                    "Code.Type": "Turn",
                    "Code": [
                        "if(EndState) {",
                        "  ShipOut(CurShip);",
                        "}"
                    ],
                    "#": 113,
                    "Type": "Top",
                    "Parent": -1,
                    "Pos.x": 160
                },
                {
                    "Name": "",
                    "Code.Type": "Turn",
                    "Code": [
                        "if(EndState) {",
                        "  //\"Загружаем\" население для эвакуации на другую планету",
                        "  //1000 единиц популяции соответствует в игре миллиону человек, а не тысяче",
                        "  if(EvacInProcess)",
                        "  {",
                        "      if(EvacInProcess > 10000)",
                        "      {",
                        "          EvacInProcess = EvacInProcess - 250;",
                        "          ShipData(250);",
                        "      }",
                        "      else",
                        "      {",
                        "          EvacInProcess = EvacInProcess - 25;",
                        "          ShipData(25);",
                        "      }",
                        "  }",
                        "  ChangeState(5);",
                        "  exit;",
                        "}",
                        "if(moveState >= 6 || moveState < 0) {",
                        "  ChangeState(5);",
                        "  exit;",
                        "}"
                    ],
                    "#": 114,
                    "Type": "Top",
                    "Parent": -1,
                    "Pos.x": 240
                },
                {
                    "Name": "",
                    "Code.Type": "Turn",
                    "Code": [
                        "if(EndState) {",
                        "  //\"Выгружаем\" население на планету для эвакуации",
                        "  //1000 единиц популяции соответствует в игре миллиону человек, а не тысяче",
                        "  PlanetPopulation(EvacPlanet, PlanetPopulation(EvacPlanet) + ShipData());",
                        "  ShipData(0);",
                        "  if(moveState < 6 && moveState > 0) {",
                        "    ChangeState(4);",
                        "    exit;",
                        "  }",
                        "  if(moveState >= 6 || moveState < 0) {",
                        "    ChangeState(6);",
                        "    exit;",
                        "  }",
                        "}"
                    ],
                    "#": 115,
                    "Type": "Top",
                    "Parent": -1,
                    "Pos.x": 320
                },
                {
                    "Name": "",
                    "Code.Type": "Turn",
                    "Code": [
                        "//Астероид уничтожен, либо достиг планеты, все эвакуационные лайнеры выводятся из скрипта",
                        "if(ShipType(CurShip) == 'Liner' && dialogVar != 4) questVar = questVar + 1;",
                        "ShipOut(CurShip);"
                    ],
                    "#": 116,
