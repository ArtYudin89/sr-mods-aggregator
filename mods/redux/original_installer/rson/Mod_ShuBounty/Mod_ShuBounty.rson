                        "for (i=0; i<ShipItems(Player()); i=i+1)",
                        "{",
                        "    s=ShipItems(Player(),i);",
                        "    if (Name(s)==CT(\"Script.Mod_ShuBounty.110\")) {",
                        "        //Если нашли - определяем, сколько на них денег",
                        "        tmp2=tmp2+ItemCost(s)*Rnd(3,5);",
                        "        tmp=tmp+1;",
                        "    }",
                        "}",
                        "//Общая сумма сбережений",
                        "tmp3=tmp2;",
                        "//Сумма с комиссией",
                        "tmp2=tmp2*(100-2*GalaxyTechLevel())/100;",
