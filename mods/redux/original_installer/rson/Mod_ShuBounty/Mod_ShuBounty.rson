            "Items": [],
            "Operations": [
                {
                    "Name": "",
                    "Code.Type": "Global",
                    "Code": [
                        "GRun();"
                    ],
                    "#": 32,
                    "Type": "Top",
                    "Parent": -1,
                    "Pos.x": 0,
                    "Pos.y": 685
                },
                {
                    "Name": "",
                    "Code.Type": "Init",
                    "Code": [
                        "ArrayClear(tArr);",
                        "ArrayClear(hit_list);",
                        "ArrayClear(rewards);",
                        "//Перебираем все системы галактики",
                        "for(i = 0; i < GalaxyStars(); i = i + 1)",
                        "{",
                        "    tmp = GalaxyStar(i);",
                        "    for(j = 0; j < StarPlanets(tmp); j = j + 1)",
                        "    {",
                        "        //Ищем в системе незаселенные планеты",
                        "        tmp2 = StarPlanets(tmp, j);",
                        "        if(PlanetOwner(tmp2) == None)",
                        "        {",
                        "            //С шансом 25% закапываем на планету кристалл",
                        "            if(Rnd(1, 100) <= 25)",
                        "            {",
                        "                tmp3 = CreateQuestItem('ShuBounty_Crystals', None);",
                        "                ItemSize(tmp3, 1);",
                        "                ItemCost(tmp3, Rnd(5000, 12500));",
                        "                AddItemToPlanet(tmp2, tmp3);",
                        "            }",
                        "            //Если у игрока подключён мод ExpTC, закапываем ценную руду и самородки",
                        "            if(IsScriptActive('Mod_ExpTC'))",
                        "            {",
                        "                //Их цены лучше считать, исходя из стоимости обычных минералов",
                        "                //С шансом в 66% закапываем ещё одну партию драгоценных минералов",
                        "                if(Rnd(1, 100) <= 66)",
                        "                {",
                        "                    rand = Rnd(1, 9);",
                        "                    tmp3 = CreateCustomCountableItem('NuggetAsteroid', rand);",
                        "                    ItemCost(tmp3, rand * (Rnd(10, 15) * 7));",
                        "                    AddItemToPlanet(tmp2, tmp3);",
                        "                }",
                        "                //С дополнительным шансом в 33% закапываем ещё одну партию драгоценных минералов",
                        "                if(Rnd(1, 100) <= 33)",
                        "                {",
                        "                    rand = Rnd(3, 33);",
                        "                    tmp3 = CreateCustomCountableItem('NuggetAsteroid', rand);",
                        "                    ItemCost(tmp3, rand * (Rnd(10, 15) * 7));",
                        "                    AddItemToPlanet(tmp2, tmp3);",
                        "                }",
                        "                //С ещё более дополнительным шансом в 9% закапываем партию драгоценных минералов",
                        "                if(Rnd(1, 100) <= 9)",
                        "                {",
                        "                    rand = Rnd(6, 66);",
                        "                    tmp3 = CreateCustomCountableItem('NuggetAsteroid', rand);",
                        "                    ItemCost(tmp3, rand * (Rnd(10, 15) * 7));",
                        "                    AddItemToPlanet(tmp2, tmp3);",
                        "                }",
                        "            }",
                        "        }",
                        "    }",
                        "}",
                        "//Массив имен для спасательных капсул",
                        "ArrayClear(names);",
                        "ArrayAdd(names,CT(\"Script.Mod_ShuBounty.81\"));",
                        "ArrayAdd(names,CT(\"Script.Mod_ShuBounty.80\"));",
                        "ArrayAdd(names,CT(\"Script.Mod_ShuBounty.79\"));",
                        "ArrayAdd(names,CT(\"Script.Mod_ShuBounty.78\"));",
                        "ArrayAdd(names,CT(\"Script.Mod_ShuBounty.77\"));",
                        "ArrayAdd(names,CT(\"Script.Mod_ShuBounty.76\"));",
                        "ArrayAdd(names,CT(\"Script.Mod_ShuBounty.75\"));",
                        "ArrayAdd(names,CT(\"Script.Mod_ShuBounty.74\"));",
                        "ArrayAdd(names,CT(\"Script.Mod_ShuBounty.73\"));",
                        "ArrayAdd(names,CT(\"Script.Mod_ShuBounty.72\"));",
                        "ArrayAdd(names,CT(\"Script.Mod_ShuBounty.71\"));",
                        "ArrayAdd(names,CT(\"Script.Mod_ShuBounty.70\"));",
                        "ArrayAdd(names,CT(\"Script.Mod_ShuBounty.69\"));",
                        "ArrayAdd(names,CT(\"Script.Mod_ShuBounty.68\"));",
                        "ArrayAdd(names,CT(\"Script.Mod_ShuBounty.67\"));",
                        "ArrayAdd(names,CT(\"Script.Mod_ShuBounty.66\"));",
                        "ArrayAdd(names,CT(\"Script.Mod_ShuBounty.65\"));",
                        "ArrayAdd(names,CT(\"Script.Mod_ShuBounty.64\"));",
                        "ArrayAdd(names,CT(\"Script.Mod_ShuBounty.63\"));",
                        "ArrayAdd(names,CT(\"Script.Mod_ShuBounty.62\"));",
                        "ArrayAdd(names,CT(\"Script.Mod_ShuBounty.61\"));",
                        "ArrayAdd(names,CT(\"Script.Mod_ShuBounty.60\"));",
                        "ArrayAdd(names,CT(\"Script.Mod_ShuBounty.59\"));",
                        "ArrayAdd(names,CT(\"Script.Mod_ShuBounty.58\"));",
                        "ArrayAdd(names,CT(\"Script.Mod_ShuBounty.57\"));",
                        "ArrayAdd(names,CT(\"Script.Mod_ShuBounty.56\"));",
                        "ArrayAdd(names,CT(\"Script.Mod_ShuBounty.55\"));",
                        "//Функция создания корабля из капсулы. Параметр - указатель на капсулу. Возвращает сумму, которую игрок получит за сдачу капсулы в МЦ.",
                        "function CapsuleToShip(int capsule) {",
                        "    dword planet, planetOwner, planetRace, ship, type, star, cost;",
                        "    str shipName;",
                        "    int i, j;",
                        "    if(findsubstr(UselessItemText(capsule),CT(\"Script.Mod_ShuBounty.208\"))>=0) type=1;",
                        "    else if(findsubstr(UselessItemText(capsule),CT(\"Script.Mod_ShuBounty.207\"))>=0) type=2;",
                        "    else if(findsubstr(UselessItemText(capsule),CT(\"Script.Mod_ShuBounty.206\"))>=0) type=5;",
                        "    else if(findsubstr(UselessItemText(capsule),CT(\"Script.Mod_ShuBounty.205\"))>=0) type=3;",
                        "    else if(findsubstr(UselessItemText(capsule),CT(\"Script.Mod_ShuBounty.204\"))>=0) type=4;",
                        "    else",
                        "    {",
                        "        if(findsubstr(Name(capsule),CT(\"Script.Mod_ShuBounty.81\"))>=0) type=1;",
                        "        else if (findsubstr(Name(capsule),CT(\"Script.Mod_ShuBounty.80\"))>=0) type=2;",
                        "        else if(findsubstr(Name(capsule),CT(\"Script.Mod_ShuBounty.79\"))>=0 || findsubstr(Name(capsule),CT(\"Script.Mod_ShuBounty.78\"))>=0 || findsubstr(Name(capsule),CT(\"Script.Mod_ShuBounty.77\"))>=0 || findsubstr(Name(capsule),CT(\"Script.Mod_ShuBounty.76\"))>=0 || findsubstr(Name(capsule),CT(\"Script.Mod_ShuBounty.75\"))>=0) type=2;",
                        "        else if(findsubstr(Name(capsule),CT(\"Script.Mod_ShuBounty.144\"))>=0 || findsubstr(Name(capsule),CT(\"Script.Mod_ShuBounty.143\"))>=0 || findsubstr(Name(capsule),CT(\"Script.Mod_ShuBounty.142\"))>=0 || findsubstr(Name(capsule),CT(\"Script.Mod_ShuBounty.141\"))>=0 || findsubstr(Name(capsule),CT(\"Script.Mod_ShuBounty.140\"))>=0) type=2;",
                        "        else if(findsubstr(Name(capsule),CT(\"Script.Mod_ShuBounty.74\"))>=0 || findsubstr(Name(capsule),CT(\"Script.Mod_ShuBounty.73\"))>=0 || findsubstr(Name(capsule),CT(\"Script.Mod_ShuBounty.72\"))>=0 || findsubstr(Name(capsule),CT(\"Script.Mod_ShuBounty.71\"))>=0 || findsubstr(Name(capsule),CT(\"Script.Mod_ShuBounty.70\"))>=0) type=5;",
                        "        else if(findsubstr(Name(capsule),CT(\"Script.Mod_ShuBounty.64\"))>=0 || findsubstr(Name(capsule),CT(\"Script.Mod_ShuBounty.63\"))>=0 || findsubstr(Name(capsule),CT(\"Script.Mod_ShuBounty.62\"))>=0 || findsubstr(Name(capsule),CT(\"Script.Mod_ShuBounty.61\"))>=0 || findsubstr(Name(capsule),CT(\"Script.Mod_ShuBounty.60\"))>=0) type=4;",
                        "        else if(findsubstr(Name(capsule),CT(\"Script.Mod_ShuBounty.69\"))>=0 || findsubstr(Name(capsule),CT(\"Script.Mod_ShuBounty.68\"))>=0 || findsubstr(Name(capsule),CT(\"Script.Mod_ShuBounty.67\"))>=0 || findsubstr(Name(capsule),CT(\"Script.Mod_ShuBounty.66\"))>=0 || findsubstr(Name(capsule),CT(\"Script.Mod_ShuBounty.65\"))>=0) type=3;",
                        "    }",
                        "    planet=FindPlanet(ShipStar(Player()), 'NotNone', 0, 0); //Первая заселенная планета в системе",
                        "    planetOwner=PlanetOwner(planet); //Запоминаем первоначальных расу и владельца планеты",
                        "    planetRace=PlanetRace(planet);",
                        "    PlanetRace(planet, ItemOwner(capsule));",
                        "    if(type!=2 || planetOwner!=PirateClan) PlanetOwner(planet, ItemOwner(capsule)); //Меняем владельца планеты по необходимости",
                        "    //Спавним новый корабль",
                        "    if (type==1) ship=BuyRanger(planet);",
                        "    else if (type==2) ship=BuyPirate(planet);",
                        "    else if (type==3) ship=BuyTransport(planet, 0);",
                        "    else if (type==4) ship=BuyTransport(planet, 1);",
                        "    else ship=BuyTransport(planet, 2);",
                        "    RelationToRanger(ship, Player(), 100);",
                        "    PlanetOwner(planet, planetOwner); //Возвращаем первоначальных расу и владельца планеты",
                        "    PlanetRace(planet, planetRace);",
                        "    shipName=Name(capsule); //Запоминаем имя корабля",
                        "    //Перебираем все системы в галактике",
                        "    for(i=0; i<GalaxyStars(); i=i+1) {",
                        "        star=StarNearbyStars(ShipStar(Player()), i); //Ищем ближайшие к игроку",
                        "        if(StarOwner(star)==1) continue; //Пропускаем доминаторские системы",
                        "        if(StarCustomFaction(star)!='') continue;",
                        "        for(j=0; j<StarShips(star); j=j+1) { //Перебираем корабли в системе",
                        "            //Если нашли корабль с таким же именем - добавляем случайную цифру к имени спасенного корабля",
                        "            if(Name(StarShips(star, j))==shipName) {",
                        "                shipName=shipName+' -'+Rnd(1, 100)+'-';",
                        "                break;",
                        "            }",
                        "        }",
                        "    }",
                        "    SetName(ship, shipName); //Задаем имя корабля",
                        "    ShipAddCustomShipInfo(ship, 'ShuBountyNoCapsule', 'NoShow'); //Инфошка нужна, чтобы кораблю не выдало капсулу еще раз",
                        "    HullHP(ship, 1);",
                        "    ShipHealthFactor(ship, 7, 5); //добавляем вихревую контузию на пять дней, типа ее и лечат на медцентре",
                        "    ShipHealthFactor(ship, 4, Rnd(30, 75)); //вешаем комплексный иммуноцид на пару месяцев - типа последствия реабилитации",
                        "    TransferShip(ship, GetShipRuins(Player())); //Переносим корабль на МЦ",
                        "    //Считаем, сколько денег получит игрок за спасение",
                        "    if(planetOwner==PirateClan) {",
                        "        if(type==2) cost=ItemCost(capsule)*3/2;",
                        "        else cost=ItemCost(capsule)*5/4;",
                        "    }",
                        "    else {",
                        "        if(type==2) cost=ItemCost(capsule)*5/4;",
                        "        else cost=ItemCost(capsule)*3/2;",
                        "    }",
                        "    ShipMoney(Player(),ShipMoney(Player())+cost);",
                        "    FreeItem(GetItemFromShip(Player(), FindItemInShip(Player(), capsule)));",
                        "    Sound('Sound.Buy');",
                        "    result=cost;",
                        "}"
                    ],
                    "#": 33,
                    "Type": "Top",
                    "Parent": -1,
                    "Pos.x": 60,
                    "Pos.y": 685
                },
                {
                    "Name": "",
                    "Code.Type": "Turn",
                    "Code": [
                        "//Раздача юзлессов",
                        "//Перебираем все новые корабли в галактике по заданным фильтрам",
                        "if(GalaxyShipId()>lastShipId) {",
                        "  tmp=BuildListOfNewShips(tArr,lastShipId,2+4+8+16,1+2+4+8+16+128,1,'','FemRanger,Militiaman1,,Militiaman2,Militiaman3,Rebel,PirateRunner,RangerPirate,RangerExplorer,RangerPirateExplorer,Smuggler,EliteWarrior,Merc,Freelancer,RedLeader,AtlantLeader,FeiLeader,Khan,Thug');",
                        "  if(tmp) { //Если найден хотя бы один корабль, выдаем юзлессы",
                        "    for(i=0;i<ArrayDim(tArr);i=i+1) {",
                        "      tmp=0; //Обнуляем флаг для раздачи юзлессов",
                        "      tmp2=tArr[i]; //Выбираем корабль",
                        "      if(ShipInHyperSpace(tmp2)) continue; //На всякий случай пропускаем корабли в гипере",
                        "      chance=0; //Устанавливаем шанс на выдачу того или иного юзлесса",
                        "      tmp=ShipTypeN(tmp2);",
                        "      tmp3=ShipPilotRace(tmp2);",
                        "      if(tmp==t_Ranger) chance=40; //Рейнджеры",
                        "      else if(tmp==t_Transport) chance=35; //Мирные корабли",
                        "      else if(tmp==t_Pirate) chance=30; //Пираты",
                        "      else if(tmp==t_Warrior) chance=25; //Военные",
                        "      if(Rnd(1,100)<=chance) { //Случайно определяем шанс выдачи",
                        "        //Формируется массив из всех возможных юзлессов для данного корабля",
                        "        ArrayClear(hit_list);",
                        "        ArrayAdd(hit_list, CreateQuestItem('Usl_63', tmp3)); //Письмо",
                        "        ArrayAdd(hit_list, CreateQuestItem('Usl_72', tmp3)); //Конверт с кредитами",
                        "        if(tmp==t_Transport) {",
                        "          ArrayAdd(hit_list, CreateQuestItem('Usl_LasosCup', None)); //Чашка с рыбой",
                        "          ArrayAdd(hit_list, CreateQuestItem('Usl_8', tmp3)); //Коробка подарочная",
                        "          ArrayAdd(hit_list, CreateQuestItem('Usl_Cactus', tmp3)); //Кактус",
                        "          ArrayAdd(hit_list, CreateQuestItem('Usl_74', tmp3)); //Кредитка",
                        "          if(ShipType(tmp2)=='Transport') { //Транспорт",
                        "            ArrayAdd(hit_list, CreateQuestItem('Usl_Pilot', tmp3)); //Сертификат",
                        "            ArrayAdd(hit_list, CreateQuestItem('Usl_MusicialTools', tmp3)); //Инструменты",
                        "            ArrayAdd(hit_list, CreateQuestItem('Usl_42', Gaal)); //Теплая одежда",
                        "            ArrayAdd(hit_list, CreateQuestItem('Usl_39', Fei)); //Сервер",
                        "            ArrayAdd(hit_list, CreateQuestItem('Usl_Faruk', tmp3)); //Фарюки",
                        "            ArrayAdd(hit_list, CreateQuestItem('Usl_37', tmp3)); //Комплект биоигр",
                        "            if(tmp3==Fei) {",
                        "              ArrayAdd(hit_list, CreateQuestItem('Usl_38', Fei)); //СВ-ткани",
                        "              ArrayAdd(hit_list, CreateQuestItem('Usl_26', Fei)); //Процессоры",
                        "            }",
                        "            else if(tmp3==Peleng) {",
                        "              ArrayAdd(hit_list, CreateQuestItem('Usl_9', Peleng)); //Инкубатор для жаб",
                        "              ArrayAdd(hit_list, CreateQuestItem('Usl_16', Peleng)); //Пеленгские плащи",
                        "            }",
                        "          }",
                        "          else if(ShipType(tmp2)=='Liner') { //Лайнер",
                        "            ArrayAdd(hit_list, CreateQuestItem('Usl_68', Gaal)); //Пылесос",
                        "            ArrayAdd(hit_list, CreateQuestItem('Usl_60', Gaal)); //Гаальская книга",
                        "            ArrayAdd(hit_list, CreateQuestItem('Usl_58', tmp3)); //Ковер",
                        "            ArrayAdd(hit_list, CreateQuestItem('Usl_37', tmp3)); //Комплект биоигр",
                        "          }",
                        "          else { //Дипломат",
                        "            ArrayAdd(hit_list, CreateQuestItem('Usl_RandomItem_04', tmp3)); //Кейс с документами",
                        "            ArrayAdd(hit_list, CreateQuestItem('Usl_RandomItem_02', tmp3)); //Срочное письмо",
                        "            ArrayAdd(hit_list, CreateQuestItem('Usl_40', tmp3)); //Жучки",
                        "            ArrayAdd(hit_list, CreateQuestItem('Usl_PTQ68', None)); //Секретные документы",
                        "            ArrayAdd(hit_list, CreateQuestItem('Usl_PTQn60', None)); //Диск",
                        "            ArrayAdd(hit_list, CreateQuestItem('Usl_PTQn64', None)); //Важные документы",
                        "            ArrayAdd(hit_list, CreateQuestItem('Usl_28', tmp3)); //Короб с шифром",
                        "            if(tmp3==People) {",
                        "              ArrayAdd(hit_list, CreateQuestItem('Usl_55', People)); //Аннигилятор материи",
                        "              ArrayAdd(hit_list, CreateQuestItem('Usl_23', People)); //Часовой механизм",
                        "            }",
                        "            else if(tmp3==Fei) {",
                        "              ArrayAdd(hit_list, CreateQuestItem('Usl_29', Fei)); //Гимн фэян и людей",
                        "            }",
                        "            else if(tmp3==Gaal) {",
                        "              ArrayAdd(hit_list, CreateQuestItem('Usl_43', Gaal)); //Рецепт пиццы",
                        "            }",
                        "          }",
                        "        }",
                        "        else if(tmp==t_Pirate) {",
                        "          ArrayAdd(hit_list, CreateQuestItem('Usl_71', tmp3)); //Секретная записка с паролем",
                        "          ArrayAdd(hit_list, CreateQuestItem('Usl_MemoryModule', None)); //Модуль памяти",
                        "          ArrayAdd(hit_list, CreateQuestItem('Usl_25', tmp3)); //Дизодан",
                        "          ArrayAdd(hit_list, CreateQuestItem('Usl_8', tmp3)); //Коробка подарочная",
                        "          ArrayAdd(hit_list, CreateQuestItem('Usl_28', tmp3)); //Короб с шифром",
                        "          ArrayAdd(hit_list, CreateQuestItem('Usl_Cactus', tmp3)); //Кактус",
                        "          ArrayAdd(hit_list, CreateQuestItem('Usl_74', tmp3)); //Кредитка",
                        "        }",
                        "        else if(tmp==t_Warrior) {",
                        "          ArrayAdd(hit_list, CreateQuestItem('Usl_Svarokok', Maloc)); //Сварококс",
                        "          ArrayAdd(hit_list, CreateQuestItem('Usl_PTQ68', None)); //Секретные документы",
                        "          ArrayAdd(hit_list, CreateQuestItem('Usl_PTQn60', None)); //Диск",
                        "          ArrayAdd(hit_list, CreateQuestItem('Usl_PTQn64', None)); //Важные документы",
                        "        }",
                        "        else if(tmp==t_Ranger) {",
                        "          ArrayAdd(hit_list, CreateQuestItem('Usl_8', tmp3)); //Коробка подарочная",
                        "          ArrayAdd(hit_list, CreateQuestItem('Usl_40', tmp3)); //Жучки",
                        "          ArrayAdd(hit_list, CreateQuestItem('Usl_41', Gaal)); //Партия грауков",
                        "          ArrayAdd(hit_list, CreateQuestItem('Usl_46', Peleng)); //Дряхлоуст",
                        "          ArrayAdd(hit_list, CreateQuestItem('Usl_Faruk', tmp3)); //Фарюки",
                        "          ArrayAdd(hit_list, CreateQuestItem('Usl_LasosCup', None)); //Чашка с рыбой",
                        "          ArrayAdd(hit_list, CreateQuestItem('Usl_MemoryModule', None)); //Модуль памяти",
                        "          ArrayAdd(hit_list, CreateQuestItem('Usl_37', tmp3)); //Комплект биоигр",
                        "          ArrayAdd(hit_list, CreateQuestItem('Usl_25', tmp3)); //Дизодан",
                        "          ArrayAdd(hit_list, CreateQuestItem('Usl_Cactus', tmp3)); //Кактус",
                        "          ArrayAdd(hit_list, CreateQuestItem('Usl_74', tmp3)); //Кредитка",
                        "          if(tmp3==People) {",
                        "            ArrayAdd(hit_list, CreateQuestItem('Usl_23', People)); //Часовой механизм",
                        "            ArrayAdd(hit_list, CreateQuestItem('Usl_29', People)); //Гимн фэян и людей",
                        "          }",
                        "        }",
                        "        if(ShipOwner(tmp2)==PirateClan) { //Пираты",
                        "          ArrayAdd(hit_list, CreateQuestItem('Usl_11', PirateClan)); //Контейнер хавас",
                        "          if(GetShipPirateRank(tmp2)>3) ArrayAdd(hit_list, CreateQuestItem('Usl_DataArchive', None)); //Секретный архив",
                        "        }",
                        "        if(tmp3==Maloc) { //Малоки",
                        "          ArrayAdd(hit_list, CreateQuestItem('Usl_64', Maloc)); //Табурет",
                        "          ArrayAdd(hit_list, CreateQuestItem('Usl_2', Maloc)); //Малокский флаг",
                        "          ArrayAdd(hit_list, CreateQuestItem('Usl_19', tmp3)); //Коробка сигарет",
                        "          ArrayAdd(hit_list, CreateQuestItem('Usl_Orcs', Maloc)); //Старинная книга",
                        "        }",
                        "        else if(tmp3==Peleng) { //Пеленги",
                        "          ArrayAdd(hit_list, CreateQuestItem('Usl_12',Peleng)); //Парадные черпала",
                        "          ArrayAdd(hit_list, CreateQuestItem('Usl_19', tmp3)); //Коробка сигарет",
                        "          ArrayAdd(hit_list, CreateQuestItem('Usl_18',Peleng)); //Пеленгские плащи",
                        "        }",
                        "        else if(tmp3==People) { //Люди",
                        "          ArrayAdd(hit_list, CreateQuestItem('Usl_30', People)); //Зубная щетка",
                        "          ArrayAdd(hit_list, CreateQuestItem('Usl_GoldenRocket', People)); //Золотая статуэтка",
                        "          ArrayAdd(hit_list, CreateQuestItem('Usl_70', People)); //Флэшка",
                        "          ArrayAdd(hit_list, CreateQuestItem('Usl_19', tmp3)); //Коробка сигарет",
                        "          ArrayAdd(hit_list, CreateQuestItem('Usl_22', tmp3)); //Религиозные сувениры",
                        "        }",
                        "        else if(tmp3==Fei) { //Фэяне",
                        "          ArrayAdd(hit_list, CreateQuestItem('Usl_33', Fei)); //Гиниромасло",
                        "          ArrayAdd(hit_list, CreateQuestItem('Usl_35', Fei)); //Пси-оружие",
                        "        }",
                        "        else if(tmp3==Gaal) { //Гаальцы",
                        "          ArrayAdd(hit_list, CreateQuestItem('Usl_49', Gaal)); //Сферощит",
                        "          ArrayAdd(hit_list, CreateQuestItem('Usl_56', Gaal)); //Детектор лжи",
                        "          ArrayAdd(hit_list, CreateQuestItem('Usl_48', Gaal)); //Сканер вселенной",
                        "          ArrayAdd(hit_list, CreateQuestItem('Usl_22', tmp3)); //Религиозные сувениры",
                        "        }",
                        "        //Из сформированного массива рандомно выбирается один предмет",
                        "        if(ArrayDim(hit_list)>1) tmp3=Rnd(1,ArrayDim(hit_list)-1);",
                        "        else tmp3=0;",
                        "        if(tmp3) {",
                        "          ShipAddDropItem(tmp2, hit_list[tmp3]);",
                        "          ArrayDelete(hit_list, tmp3);",
                        "          for(j=1; j<ArrayDim(hit_list); j=j+1) FreeItem(hit_list[j]);",
                        "        }",
                        "        ArrayClear(hit_list);",
                        "      }",
                        "      if(!Rnd(0,35)) { //С шансом 1:35 после уничтожения корабля останется гиперпыль",
                        "        ShipAddDropItem(tmp2, CreateQuestItem('Dust', None));",
                        "      }",
                        "      //Раздача спасательных капсул",
                        "      if(ShipInScript(tmp2) && ShipType(tmp2)!='RangerPirate' && ShipType(tmp2)!='Smuggler') continue;",
                        "      if(~ShipFindCustomShipInfoByType(tmp2, 'ShuBountyNoCapsule')) continue;",
                        "      chance=0;",
                        "      if(ShipType(tmp2)=='Ranger') {",
                        "        type=1; chance=40;",
                        "      }",
                        "      else if (ShipType(tmp2)=='RangerPirate') {",
                        "        type=2; chance=40;",
                        "      }",
                        "      else if(ShipType(tmp2)=='Diplomat') {",
                        "        type=3; chance=35;",
                        "      }",
                        "      else if(ShipType(tmp2)=='Transport' || ShipType(tmp2)=='Smuggler') {",
                        "        type=4; chance=30;",
                        "      }",
                        "      else if(ShipType(tmp2)=='Liner') {",
                        "        type=5; chance=30;",
                        "      }",
                        "      else if(ShipTypeN(tmp2)==t_Pirate) {",
                        "        type=2; chance=30;",
                        "      }",
                        "      if(Rnd(1,100)<=chance) {",
                        "        tmp3=CreateQuestItem('Usl_EscapePod', ShipPilotRace(tmp2));",
                        "        SetName(tmp3, ShortName(tmp2));",
                        "        if (type==1) UselessItemText(tmp3,Format(CT(\"Script.Mod_ShuBounty.54\"),\"<0>\",ShortName(tmp2)));",
                        "        if (type==2) UselessItemText(tmp3,Format(CT(\"Script.Mod_ShuBounty.53\"),\"<0>\",ShortName(tmp2)));",
                        "        if (type==3) UselessItemText(tmp3,Format(CT(\"Script.Mod_ShuBounty.52\"),\"<0>\",ShortName(tmp2)));",
                        "        if (type==4) UselessItemText(tmp3,Format(CT(\"Script.Mod_ShuBounty.51\"),\"<0>\",ShortName(tmp2)));",
                        "        if (type==5) UselessItemText(tmp3,Format(CT(\"Script.Mod_ShuBounty.50\"),\"<0>\",ShortName(tmp2)));",
                        "        ShipAddDropItem(tmp2, tmp3);",
                        "      }",
                        "    }",
                        "  }",
                        "  lastShipId=GalaxyShipId(); //Обновляем Id последнего рожденного корабля",
                        "}",
                        "//Сброс статистики по сданным цистернам",
                        "if(CurTurn()>=timerCis) {",
                        "    timerCis=CurTurn()+Rnd(300,420);",
                        "    fuel_total=0;",
                        "    how_cis=0;",
                        "    CisCount=0;",
                        "}",
                        "//Начисление награды за пиратов/военных и рейнджеров",
                        "if(!ShipIsTakeoff(Player())) {",
                        "  for(i=GalaxyEvents()-1; i>=0; i=i-1) {",
                        "    if(GalaxyEventDate(i) < CurTurn()) break;",
                        "    if(GalaxyEventType(i)=='PlayerChangesSide') { //При смене стороны накопленная награда теряется",
                        "      if(!GalaxyEventData(i, 0)) WarriorBounty=0;",
                        "      else PirateBounty=0;",
                        "      break;",
                        "    }",
                        "    else if(ShipOnSidePirateClan(Player())) { //Награда за военных/рейнджеров, если Коалиция не побеждена + игрок в клане",
                        "      if(!CoalitionDefeated()) {",
                        "        if(GalaxyEventType(i)=='PlayerKillsShip') {",
                        "          if(GalaxyEventData(i,0)==t_Warrior) WarriorBounty=WarriorBounty+GalaxyMoney(3,0);",
                        "          else if(GalaxyEventData(i,0)==t_Ranger) WarriorBounty=WarriorBounty+GalaxyMoney(2,2);",
                        "        }",
                        "        else if(GalaxyEventType(i)=='PlayerAssistKillsShip') {",
                        "          if(GalaxyEventData(i,0)==t_Warrior) WarriorBounty=WarriorBounty+GalaxyMoney(2,0);",
                        "          else if(GalaxyEventData(i,0)==t_Ranger) WarriorBounty=WarriorBounty+GalaxyMoney(1,2);",
                        "        }",
                        "        else if(GalaxyEventType(i)=='PlayerTranclucatorKillsShip') {",
                        "          if(GalaxyEventData(i,0)==t_Warrior) WarriorBounty=WarriorBounty+GalaxyMoney(3,0);",
                        "          else if(GalaxyEventData(i,0)==t_Ranger) WarriorBounty=WarriorBounty+GalaxyMoney(2,2);",
                        "        }",
                        "        else if(GalaxyEventType(i)=='PlayerTranclucatorAssistKillsShip') {",
                        "          if(GalaxyEventData(i,0)==t_Warrior) WarriorBounty=WarriorBounty+GalaxyMoney(2,0);",
                        "          else if(GalaxyEventData(i,0)==t_Ranger) WarriorBounty=WarriorBounty+GalaxyMoney(1,2);",
                        "        }",
                        "        else if(GalaxyEventType(i)=='PlayerCompanionKillsShip') {",
                        "          if(GalaxyEventData(i,0)==t_Warrior) WarriorBounty=WarriorBounty+GalaxyMoney(3,0);",
                        "          else if(GalaxyEventData(i,0)==t_Ranger) WarriorBounty=WarriorBounty+GalaxyMoney(2,2);",
                        "        }",
                        "        else if(GalaxyEventType(i)=='PlayerCompanionAssistKillsShip') {",
                        "          if(GalaxyEventData(i,0)==t_Warrior) WarriorBounty=WarriorBounty+GalaxyMoney(2,0);",
                        "          else if(GalaxyEventData(i,0)==t_Ranger) WarriorBounty=WarriorBounty+GalaxyMoney(2,2);",
                        "        }",
                        "      }",
                        "    }",
                        "    else { //Награда за пиратов, если игрок за Коалицию + клан не побежден",
                        "      if(PirateWin()!=3 && PirateWin()!=4) {",
                        "        if(GalaxyEventType(i)=='PlayerKillsShip') {",
                        "          if(GalaxyEventData(i,0)==t_Pirate) PirateBounty=PirateBounty+GalaxyMoney(3,0);",
                        "        }",
                        "        else if(GalaxyEventType(i)=='PlayerAssistKillsShip') {",
                        "          if(GalaxyEventData(i,0)==t_Pirate) PirateBounty=PirateBounty+GalaxyMoney(2,2);",
                        "        }",
                        "        else if(GalaxyEventType(i)=='PlayerTranclucatorKillsShip') {",
                        "          if(GalaxyEventData(i,0)==t_Pirate) PirateBounty=PirateBounty+GalaxyMoney(3,0);",
                        "        }",
                        "        else if(GalaxyEventType(i)=='PlayerTranclucatorAssistKillsShip') {",
                        "          if(GalaxyEventData(i,0)==t_Pirate) PirateBounty=PirateBounty+GalaxyMoney(2,2);",
                        "        }",
                        "        else if(GalaxyEventType(i)=='PlayerCompanionKillsShip') {",
                        "          if(GalaxyEventData(i,0)==t_Pirate) PirateBounty=PirateBounty+GalaxyMoney(3,0);",
                        "        }",
                        "        else if(GalaxyEventType(i)=='PlayerCompanionAssistKillsShip') {",
                        "          if(GalaxyEventData(i,0)==t_Pirate) PirateBounty=PirateBounty+GalaxyMoney(2,2);",
                        "        }",
                        "      }",
                        "    }",
                        "  }",
                        "}"
                    ],
                    "#": 34,
                    "Type": "Top",
                    "Parent": -1,
                    "Pos.x": 120,
                    "Pos.y": 685
                },
                {
                    "Name": "",
                    "Code.Type": "DialogBegin",
                    "Code": [
                        "if(GetShipRuins(Player())) {",
                        "  if(!PlayerBridge()) {",
                        "    str0=ShipType(GetShipRuins(Player()));",
                        "    if(str0=='SB') {",
                        "      AddDialogInject('SellItems','',CT(\"Script.Mod_ShuBounty.98\"),2);",
                        "    }",
                        "    else if(str0=='RC') {",
                        "      if(!ShipOnSidePirateClan(Player()))AddDialogInject('SellItems','',CT(\"Script.Mod_ShuBounty.98\"),2);",
                        "      AddDialogInject('Cistern',CT(\"Script.Mod_ShuBounty.209\"),CT(\"Script.Mod_ShuBounty.96\"),2);",
                        "    }",
                        "    else if(str0=='PB') {",
                        "      if(ShipOnSidePirateClan(Player())) {",
                        "        if(!ControlledSystems(0) || !ControlledSystems(2)) {",
                        "          AddDialogInject('NoWarReward','',CT(\"Script.Mod_ShuBounty.87\"),2);",
                        "        }",
                        "        else {",
                        "          if(WarriorBounty) {",
                        "            AddDialogInject('TakeForWars',Format(CT(\"Script.Mod_ShuBounty.86\"),\"<0>\",WarriorBounty),CT(\"Script.Mod_ShuBounty.85\"),2);",
                        "            AddDialogInject('AboutWars','',CT(\"Script.Mod_ShuBounty.83\"),2);",
                        "          }",
                        "          else {",
                        "            AddDialogInject('AboutWars',CT(\"Script.Mod_ShuBounty.84\"),CT(\"Script.Mod_ShuBounty.83\"),2);",
                        "          }",
                        "        }",
                        "        AddDialogInject('SellItems','',CT(\"Script.Mod_ShuBounty.98\"),2);",
                        "      }",
                        "    }",
                        "    else if(str0=='MC') {",
                        "      if(StarOwner(ShipStar(Player()))==0)AddDialogInject('Capsule','',CT(\"Script.Mod_ShuBounty.93\"),2);",
                        "      else if(StarOwner(ShipStar(Player()))==2)AddDialogInject('CapsulePirateClan','',CT(\"Script.Mod_ShuBounty.93\"),2);",
                        "      AddDialogInject('SellItems','',CT(\"Script.Mod_ShuBounty.98\"),2);",
                        "    }",
                        "    else if(str0=='WB') {",
                        "      if(!ShipOnSidePirateClan(Player())) {",
                        "        if(PirateWin()==3 || PirateWin()==4) AddDialogInject('AboutPirates','',CT(\"Script.Mod_ShuBounty.92\"),2);",
                        "        else {",
                        "          if(PirateBounty) {",
                        "            AddDialogInject('TakeForPirates',Format(CT(\"Script.Mod_ShuBounty.91\"),\"<0>\",PirateBounty),CT(\"Script.Mod_ShuBounty.90\"),2);",
                        "            AddDialogInject('AboutPirates','',CT(\"Script.Mod_ShuBounty.89\"),2);",
                        "          }",
                        "          else {",
                        "            AddDialogInject('AboutPirates',CT(\"Script.Mod_ShuBounty.88\"),CT(\"Script.Mod_ShuBounty.83\"),2);",
                        "          }",
                        "        }",
                        "        AddDialogInject('SellItems','',CT(\"Script.Mod_ShuBounty.98\"),2);",
                        "      }",
                        "    }",
                        "    else if(str0=='BK') {",
                        "      AddDialogInject('Crystal','',CT(\"Script.Mod_ShuBounty.94\"),2);",
                        "      AddDialogInject('SellItems','',CT(\"Script.Mod_ShuBounty.98\"),2);",
                        "    }",
                        "    else if(str0=='CB') {",
                        "      AddDialogInject('Card','',CT(\"Script.Mod_ShuBounty.95\"),2);",
                        "      AddDialogInject('SellItems','',CT(\"Script.Mod_ShuBounty.98\"),2);",
                        "    }",
                        "  }",
                        "}"
                    ],
                    "#": 35,
                    "Type": "Top",
                    "Parent": -1,
                    "Pos.x": 180,
                    "Pos.y": 685
                },
                {
                    "Name": "",
                    "Code.Type": "Turn",
                    "Code": [
                        "if(PirateWin()!=3 && PirateWin()!=4) {",
                        "  DChange(0);",
                        "  exit;",
                        "}",
                        "if(PirateWin()==3 || PirateWin()==4) {",
                        "  DChange(4);",
                        "  exit;",
                        "}"
                    ],
                    "#": 95,
                    "Type": "Top",
                    "Parent": -1,
                    "Pos.x": -20,
                    "Pos.y": 400
                },
                {
                    "Name": "",
                    "Code.Type": "Turn",
                    "Code": [
                        "WasPir=PirateBounty;",
                        "ShipMoney(Player(),ShipMoney(Player())+PirateBounty);",
                        "PirateBounty=0;",
                        "Sound('Sound.Buy');",
                        "DChange(2);",
                        "exit;"
                    ],
                    "#": 96,
                    "Type": "Top",
