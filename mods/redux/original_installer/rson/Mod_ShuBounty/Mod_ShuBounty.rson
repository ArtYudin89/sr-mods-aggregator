                        "{",
                        "    tmp=ShipItems(Player(),i);",
                        "    if(Name(tmp)==CT(\"Script.Mod_ShuBounty.110\")) FreeItem(GetItemFromShip(Player(),i));",
                        "}",
                        "//Переводим деньги на счет игрока",
                        "ShipMoney(Player(),ShipMoney(Player())+tmp2);",
                        "Sound('Sound.Buy');"
