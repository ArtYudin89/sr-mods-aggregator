                        "for(i=ShipItems(Player())-1;i>0;i=i-1)",
                        "{",
                        "    s=ShipItems(Player(),i);",
                        "    if(ItemType(s)!=t_UselessItem)continue;",
                        "    if(EquipmentImageName(s)!='ShuBounty_Crystals' && EquipmentImageName(s)!='Crystal')continue;",
                        "    FreeItem(GetItemFromShip(Player(),i));",
                        "}",
                        "//Переводим деньги на счет игрока",
                        "ShipMoney(Player(),ShipMoney(Player())+tmp2);",
                        "Sound('Sound.Buy');"
