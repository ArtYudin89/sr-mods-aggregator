                    "Code": [
                        "DChange(3);",
                        "exit;"
                    ],
                    "#": 97,
                    "Type": "Top",
                    "Parent": -1,
                    "Pos.x": 370,
                    "Pos.y": 400
                },
                {
                    "Name": "",
                    "Code.Type": "Turn",
                    "Code": [
                        "WasWar=WarriorBounty;",
                        "ShipMoney(Player(),ShipMoney(Player())+WarriorBounty);",
                        "WarriorBounty=0;",
                        "Sound('Sound.Buy');",
                        "DChange(6);",
                        "exit;"
                    ],
                    "#": 98,
                    "Type": "Top",
                    "Parent": -1,
                    "Pos.x": 520,
                    "Pos.y": 400
                },
                {
                    "Name": "",
                    "Code.Type": "Turn",
                    "Code": [
                        "if(!ControlledSystems(2)) {",
                        "  DChange(9);",
                        "  exit;",
                        "}",
                        "if(!ControlledSystems(0) && ControlledSystems(2)) {",
                        "  if(TalkToPirs || WarriorBounty<=50) {",
                        "    DChange(8);",
                        "    exit;",
                        "  }",
                        "  if(!TalkToPirs && WarriorBounty>50) {",
                        "    DChange(7);",
                        "    exit;",
                        "  }",
                        "}"
                    ],
                    "#": 99,
                    "Type": "Top",
                    "Parent": -1,
                    "Pos.x": 700,
                    "Pos.y": 400
                },
                {
                    "Name": "",
                    "Code.Type": "Turn",
                    "Code": [
                        "if(CisCount<150) {",
                        "  DChange(10);",
                        "  exit;",
                        "}",
                        "if(CisCount>=150) {",
                        "  DChange(13);",
                        "  exit;",
                        "}"
                    ],
                    "#": 100,
                    "Type": "Top",
                    "Parent": -1,
                    "Pos.x": 880,
                    "Pos.y": 400
                },
                {
                    "Name": "",
                    "Code.Type": "Turn",
                    "Code": [
                        "//Смотрим объем цистерны",
                        "cis_fuel=GetEquipmentStats(ShipItems(Player(),GAnswerData),0);",
                        "//Считаем, на сколько увеличится нод-счет игрока после сдачи цистерны",
                        "tmp2=cis_fuel/2;",
                        "if(CisCount+tmp2<150)",
                        "{",
                        "    Sound('Sound.Sell');",
                        "    dState=0;",
                        "}",
                        "//Если игрок выполнил/перевыполнил план по сдаче цистерн, выдаем наградной ММ",
                        "else",
                        "{",
                        "    if(GalaxyTechLevel()<3) BuildListOfMMByPriority(rewards,90,100);",
                        "    if(GalaxyTechLevel()==3) BuildListOfMMByPriority(rewards,75,100);",
                        "    if(GalaxyTechLevel()==4) BuildListOfMMByPriority(rewards,70,100);",
                        "    if(GalaxyTechLevel()==5) BuildListOfMMByPriority(rewards,60,90);",
                        "    if(GalaxyTechLevel()==6) BuildListOfMMByPriority(rewards,55,85);",
                        "    if(GalaxyTechLevel()==7) BuildListOfMMByPriority(rewards,50,80);",
                        "    if(GalaxyTechLevel()==8) BuildListOfMMByPriority(rewards,45,75);",
                        "    ArrayRandomize(50,rewards);",
                        "    tmp=CreateMM(rewards[0]);",
                        "    AddItemToShip(Player(),tmp);",
                        "    ArrayClear(rewards);",
                        "    Sound('Sound.QuestOk');",
                        "    dState=1;",
                        "}",
                        "CisCount=CisCount+tmp2;",
                        "//Пополняем нод-счет игрока",
                        "RangerBaseNodes(Player(),RangerBaseNodes(Player())+tmp2);",
