                {
                    "Name": "",
                    "Code.Type": "Turn",
                    "Code": [
                        "//Ищем в трюме корабля юзлессы",
                        "tmp=GetShipRuins(Player());",
                        "for(i=0;i<ShipItems(Player());i=i+1) {",
                        "    j=ShipItems(Player(),i);",
                        "    if (ItemType(j)==t_UselessItem) {",
                        "        c=0;",
                        "        s=0;",
                        "        if(ShipType(tmp)=='WB')  { //Военная база",
                        "            if(EquipmentImageName(j)=='Usl_2') s=1;",
                        "            else if(EquipmentImageName(j)=='Usl_12') s=1;",
                        "            else if(EquipmentImageName(j)=='Usl_16') s=1;",
                        "            else if(EquipmentImageName(j)=='Usl_27') s=1;",
                        "            else if(EquipmentImageName(j)=='Usl_35') s=1;",
                        "            else if(EquipmentImageName(j)=='Usl_38') s=1;",
                        "            else if(EquipmentImageName(j)=='Usl_39') s=1;",
                        "            else if(EquipmentImageName(j)=='Usl_42') s=1;",
                        "            else if(EquipmentImageName(j)=='Usl_47') s=1;",
                        "            else if(EquipmentImageName(j)=='Usl_56') s=1;",
                        "            else if(EquipmentImageName(j)=='Usl_6') s=1;",
                        "            else if(EquipmentImageName(j)=='Usl_Drugs') s=1;",
                        "            else if(EquipmentImageName(j)=='Usl_Bomber') s=1;",
                        "            else if(EquipmentImageName(j)=='Usl_MemoryModule') s=1;",
                        "            else if(EquipmentImageName(j)=='Usl_70') s=1;",
                        "            else if(EquipmentImageName(j)=='Usl_71') s=1;",
                        "            else if(EquipmentImageName(j)=='Usl_RandomItem_02') s=1;",
                        "            else if(EquipmentImageName(j)=='Usl_RandomItem_03') s=1;",
                        "            else if(EquipmentImageName(j)=='Usl_RandomItem_04') s=1;",
                        "            else if(EquipmentImageName(j)=='Usl_PTQ68') s=1;",
                        "            else if(EquipmentImageName(j)=='Usl_PTQn64') s=1;",
                        "            else if(EquipmentImageName(j)=='Usl_Svarokok') s=1;",
                        "            else if(EquipmentImageName(j)=='ReScripter') s=1;",
                        "            else if(EquipmentImageName(j)=='TrankMod') s=1;",
                        "            else if(EquipmentImageName(j)=='Ultrascan') s=1;",
                        "            else if(EquipmentImageName(j)=='secret_loot1') s=1;",
                        "            else if(EquipmentImageName(j)=='secret_loot3') s=1;",
