                {
                    "Name": "",
                    "Code.Type": "Turn",
                    "Code": [
                        "//Ищем в трюме корабля кристаллы",
                        "tmp=0;",
                        "tmp2=0;",
                        "tmp3=0;",
                        "for(i=0;i<ShipItems(Player());i=i+1)",
                        "{",
                        "    s=ShipItems(Player(),i);",
                        "    if(ItemType(s)!=t_UselessItem)continue;",
                        "    if(EquipmentImageName(s)!='ShuBounty_Crystals' && EquipmentImageName(s)!='Crystal')continue;",
                        "    //Считаем стоимость всех кристаллов",
                        "    tmp2=tmp2+0.5*ItemCost(s)*GalaxyTechLevel();",
                        "    //Считаем количество кристаллов",
                        "    tmp=tmp+ItemSize(s);",
                        "}",
                        "//Считаем наценку на кристаллы, исходя из навыков и торгового рейтинга игрока",
                        "if(tmp)",
                        "{",
                        "    tmp3=5*(ShipSkill(Player(),'TraderCur')+ShipSkill(Player(),'CharmCur')+0.05*ShipStatus(Player(),0));",
                        "    tmp2=tmp2*(tmp3+100)/100;",
                        "}",
                        "if(!tmp) {",
                        "  DChange(19);",
                        "  exit;",
                        "}",
                        "if(tmp) {",
                        "  DChange(18);",
                        "  exit;",
                        "}"
