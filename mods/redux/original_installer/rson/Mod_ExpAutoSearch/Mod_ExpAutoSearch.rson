                    "#": 31,
                    "Type": "Top",
                    "Parent": -1,
                    "Pos.x": 60,
                    "Pos.y": 610
                },
                {
                    "Name": "",
                    "Code.Type": "Turn",
                    "Code": [
                        "if(!ShipIsTakeoff(Player())) {",
                        "  //Перерассчитываем стоимость оформления и переоформления поискового запроса",
                        "  requestCreateCost = round(0.80 * GalaxyMoney(1, 2));",
                        "  ",
                        "  //Проверяем галасобытия, ищем создание и уничтожение бизнес-центров",
                        "  for(i=GalaxyEvents() - 1; i >= 0; i = i - 1)",
                        "  {",
                        "  \tif(GalaxyEventDate(i) < CurTurn()) break;",
                        "  \tif(GalaxyEventType(i) == 'RuinsCreated')",
                        "  \t{",
                        "          //Если был построен БЦ, производим поиск, т.к. БЦ мог построить другой мод в своих целях",
                        "          if(GalaxyEventData(i, 0) == t_BK)",
                        "          {",
                        "              if(GalaxyEventsTextData(i, 1) == '')",
                        "              {",
                        "                  //Проверяем появление нового БЦ в Галактике",
                        "                  cur_star = GalaxyStar(GalaxyEventData(i, 2) - 1);",
                        "                  if(StarRuins(cur_star, 'BK'))",
                        "                  {",
                        "                      //Если таки действительно построили новый БЦ",
                        "                      //Если ранее все БЦ в Галактике были уничтожены, то обнуляем счетчики во всех автопоисковых запросах",
                        "                      if(!TotalBKCount)",
                        "                      {",
                        "                          for(tint1 = 1; tint1 <= GItemsToSearchArr[0, 0]; tint1 = tint1 + 1)",
                        "                          {",
                        "                              //Обновляем таймер запроса",
                        "                              GItemsToSearchArr[tint1, 39] = CurTurn() + GItemsToSearchArr[tint1, 40];",
                        "                          }",
                        "                      }",
                        "                      TotalBKCount = TotalBKCount + 1;",
                        "                  }",
                        "              }",
                        "          }",
                        "      }",
                        "  \telse if(GalaxyEventType(i) == 'RuinsDestroyed')",
                        "  \t{",
                        "          //Если был уничтожен БЦ, отматываем счётчик",
                        "          if(GalaxyEventData(i, 0) == t_BK)",
                        "          {",
                        "              if(GalaxyEventsTextData(i,1) == '')",
                        "              {",
                        "                  TotalBKCount = TotalBKCount - 1;",
                        "                  if(!TotalBKCount)",
                        "                  {",
                        "                      if(GItemsToSearchArr[0, 0]) NewsAdd(CT('Script.Mod_ExpAutoSearch.NoBKLeft'));",
                        "                  }",
                        "              }",
                        "          }",
                        "      }",
                        "  }",
                        "  //Если в Галактике есть хотя бы один БЦ",
                        "  if(TotalBKCount)",
                        "  {",
                        "  \t//Проверяем наличие активных запросов",
                        "  \tif(GItemsToSearchArr[0, 0])",
                        "  \t{",
                        "  \t\t//Если у игрока имеется не более двух просрочек по кредиту",
                        "  \t\tif(PlayerDebtCnt() <= 2)",
                        "  \t\t{",
                        "  \t\t\tGAcrynListTempArr = newarray(1);",
                        "  \t\t\t//Ищем среди активных запросов те, которые должны произойти на этом ходу",
                        "  \t\t\tfor(i = 1; i <= GItemsToSearchArr[0, 0]; i = i + 1)",
                        "  \t\t\t{",
                        "  \t\t\t\tif(GItemsToSearchArr[i, 39] <= CurTurn()) ArrayAdd(GAcrynListTempArr, i);",
                        "  \t\t\t}",
                        "  \t\t\t//Если нашли хоть один такой",
                        "  \t\t\tif(ArrayDim(GAcrynListTempArr) > 1)",
                        "  \t\t\t{",
                        "  \t\t\t\t//Передаём в dll указатель на любой сектор для того чтобы она смогла найти в памяти галактические системы, планеты и т.п.",
                        "  \t\t\t\t//Используется для последовательного перебора систем, начиная с нулевой, но в текущей реализации не нужно",
                        "  \t\t\t\t//LoadSectorsToAutoSearchLib(GalaxySectors(0));",
                        "  \t\t\t\ttint3 = 0;",
                        "  \t\t\t\tfor(i = 1; i < ArrayDim(GAcrynListTempArr); i = i + 1)",
                        "  \t\t\t\t{",
                        "  \t\t\t\t\trequestNum = GAcrynListTempArr[i];",
                        "  \t\t\t\t\t//Если у игрока на счету достаточно денег для произведения запроса",
                        "  \t\t\t\t\tif(ShipMoney(Player()) < requestRollCost)",
                        "  \t\t\t\t\t{",
                        "  \t\t\t\t\t\t//Обновляем таймер запроса",
                        "  \t\t\t\t\t\tGItemsToSearchArr[requestNum, 39] = CurTurn() + GItemsToSearchArr[requestNum, 40];",
                        "  \t\t\t\t\t\tCustomEther('AutoSearch', 0, '', Format(CT('Script.Mod_ExpAutoSearch.NoMoneyForRequest'), '#0#', requestRollCost));",
                        "  \t\t\t\t\t\tcontinue;",
                        "  \t\t\t\t\t}",
                        "  \t\t\t\t\telse tint3 = tint3 + requestRollCost;",
                        "  \t\t\t\t\t//Передаём dll акрин уже в виде номера (сохранять точный номер в запрос нецелесообразно по причине возможной ренумерации при переподключении модов)",
                        "  \t\t\t\t\tif(GItemsToSearchArr[requestNum, 33] >= 0) tint1 = FindBonusByNameInCfg(GItemsToSearchArr[requestNum, 33]);",
                        "  \t\t\t\t\telse tint1 = GItemsToSearchArr[requestNum, 33];",
                        "  \t\t\t\t\t//Определяем необходимость пропуска скрытого пиратского сектора",
                        "  \t\t\t\t\ttint2 = 0;",
                        "  \t\t\t\t\tif(PirateWin()) tint2 = 1;",
                        "  \t\t\t\t\t//Передаём в dll параметры текущего запроса",
                        "  \t\t\t\t\tFillAutoSearchRequestList(GItemsToSearchArr[requestNum, 38], GItemsToSearchArr[requestNum, 0], GItemsToSearchArr[requestNum, 1], GItemsToSearchArr[requestNum, 2], GItemsToSearchArr[requestNum, 3], GItemsToSearchArr[requestNum, 4], GItemsToSearchArr[requestNum, 5], GItemsToSearchArr[requestNum, 6], GItemsToSearchArr[requestNum, 7], GItemsToSearchArr[requestNum, 12], GItemsToSearchArr[requestNum, 13], GItemsToSearchArr[requestNum, 14], GItemsToSearchArr[requestNum, 15], GItemsToSearchArr[requestNum, 16], GItemsToSearchArr[requestNum, 17], GItemsToSearchArr[requestNum, 18], GItemsToSearchArr[requestNum, 30], GItemsToSearchArr[requestNum, 19], '' + GItemsToSearchArr[requestNum, 20], tint1, GItemsToSearchArr[requestNum, 34], GItemsToSearchArr[requestNum, 36], GItemsToSearchArr[requestNum, 37], tint2);",
                        "  \t\t\t\t\t//Запускаем цикл поиска в dll и получаем назад число успешных результатов",
                        "  \t\t\t\t\ttint1 = AutoSearchLaunch(GalaxyPtr(), ShipStar(Player()));",
                        "  \t\t\t\t\tif(tint1)",
                        "  \t\t\t\t\t{",
                        "                          //Нужно, если создаём единый список, а не делим на отдельные Ether",
                        "                          //tstr1 = '';",
                        "  \t\t\t\t\t\t//Перебираем полученные из dll результаты",
                        "  \t\t\t\t\t\tfor(j = 0, tint2 = 0; j < tint1; j = j + 1)",
                        "  \t\t\t\t\t\t{",
                        "                              tstr1 = '';",
                        "  \t\t\t\t\t\t\tcur_item = GetAutoSearchResult(j, 0);",
                        "                              item_type = ItemType(cur_item);",
                        "  ",
                        "  \t\t\t\t\t\t\t//Если поиск производился для корпусов, то дополнительно применяем к результатам некоторые проверки, которые было невозможно перенести в dll",
                        "  \t\t\t\t\t\t\tif(GItemsToSearchArr[requestNum, 38] == 'Hulls')",
                        "  \t\t\t\t\t\t\t{",
                        "  \t\t\t\t\t\t\t\t//Проверка на восприимчивость к энергетическому урону",
                        "  \t\t\t\t\t\t\t\tif(GItemsToSearchArr[requestNum, 27])",
                        "  \t\t\t\t\t\t\t\t{",
                        "  \t\t\t\t\t\t\t\t\tif(HullDamageSuspectibility(cur_item, 0) > GItemsToSearchArr[requestNum, 27]) continue;",
                        "  \t\t\t\t\t\t\t\t}",
                        "  \t\t\t\t\t\t\t\t//Проверка на восприимчивость к осколочному урону",
                        "  \t\t\t\t\t\t\t\tif(GItemsToSearchArr[requestNum, 28])",
                        "  \t\t\t\t\t\t\t\t{",
                        "  \t\t\t\t\t\t\t\t\tif(HullDamageSuspectibility(cur_item,1) > GItemsToSearchArr[requestNum, 28]) continue;",
                        "  \t\t\t\t\t\t\t\t}",
                        "  \t\t\t\t\t\t\t\t//Проверка на восприимчивость к ракетному урону",
                        "  \t\t\t\t\t\t\t\tif(GItemsToSearchArr[requestNum, 29])",
                        "  \t\t\t\t\t\t\t\t{",
                        "  \t\t\t\t\t\t\t\t\tif(HullDamageSuspectibility(cur_item,2) > GItemsToSearchArr[requestNum, 29]) continue;",
                        "  \t\t\t\t\t\t\t\t}",
                        "  \t\t\t\t\t\t\t\t//Проверка на количество слотов под оружие",
                        "  \t\t\t\t\t\t\t\tif(GetEquipmentStats(cur_item, 1) < GItemsToSearchArr[requestNum, 19]) continue;",
                        "  \t\t\t\t\t\t\t\t//Проверка на количество слотов под артефакты",
                        "  \t\t\t\t\t\t\t\tif(GetEquipmentStats(cur_item, 2) < GItemsToSearchArr[requestNum, 20]) continue;",
                        "  \t\t\t\t\t\t\t\t//Проверка на слот под радар",
                        "  \t\t\t\t\t\t\t\tif(GetEquipmentStats(cur_item, 3) < GItemsToSearchArr[requestNum, 21]) continue;",
                        "  \t\t\t\t\t\t\t\t//Проверка на слот под сканер",
                        "  \t\t\t\t\t\t\t\tif(GetEquipmentStats(cur_item, 4) < GItemsToSearchArr[requestNum, 22]) continue;",
                        "  \t\t\t\t\t\t\t\t//Проверка на слот под дроида",
                        "  \t\t\t\t\t\t\t\tif(GetEquipmentStats(cur_item, 5) < GItemsToSearchArr[requestNum, 23]) continue;",
                        "  \t\t\t\t\t\t\t\t//Проверка на слот под захват",
                        "  \t\t\t\t\t\t\t\tif(GetEquipmentStats(cur_item, 6) < GItemsToSearchArr[requestNum, 24]) continue;",
                        "  \t\t\t\t\t\t\t\t//Проверка на слот под ГЗП",
                        "  \t\t\t\t\t\t\t\tif(GetEquipmentStats(cur_item, 7) < GItemsToSearchArr[requestNum, 25]) continue;",
                        "  \t\t\t\t\t\t\t\t//Проверка на форсаж",
                        "  \t\t\t\t\t\t\t\tif(GetEquipmentStats(cur_item, 8) < GItemsToSearchArr[requestNum, 26]) continue;",
                        "  \t\t\t\t\t\t\t}",
                        "  ",
                        "  \t\t\t\t\t\t\tcur_shop = GetAutoSearchResult(j, 1);",
                        "  ",
                        "                              //Вывод разделителей при \"тромбовании\" всех результатов по одному запросу в один Ether",
                        "                              //Лучше не включать, т.к. при выводе сразу десяти результатов первые два \"прошибают потолок\" экрана",
                        "                              //if(j) tstr1 = tstr1 + \"<br>\" + '------------------------------' + \"<br>\";",
                        "  ",
                        "  \t\t\t\t\t\t\t//Выписываем название и размер предмета",
                        "  \t\t\t\t\t\t\ttstr1 = tstr1 + '<color=255,240,100>- ' + Name(cur_item) + ' [<color=0,255,0>' + ItemSize(cur_item) + '</color>] -</color>' + CT(\"Script.Mod_ExpAutoSearch.0\");",
                        "  \t\t\t\t\t\t\tif(ObjectType(cur_shop) == 3)",
                        "  \t\t\t\t\t\t\t{",
                        "                                  //Учитываем Роджерию (не называем её планетой)",
                        "                                  if(cur_shop == PlanetPirateClan()) tstr2 = CT('Script.Mod_ExpAutoSearch.TheShop') + ' <color=255,240,100>' + Name(cur_shop) + '</color>';",
                        "  \t\t\t\t\t\t\t\telse tstr2 = CT('Script.Mod_ExpAutoSearch.TheShop') + ' <color=255,240,100>' + CT('Planet.Name') + ' ' + Name(cur_shop) + '</color>';",
                        "                                  cur_star = PlanetToStar(cur_shop);",
                        "  \t\t\t\t\t\t\t}",
                        "  \t\t\t\t\t\t\telse",
                        "  \t\t\t\t\t\t\t{",
                        "  \t\t\t\t\t\t\t\ttstr2 = CT('Script.Mod_ExpAutoSearch.TheShop') + ' <color=255,240,100>' + Name(cur_shop) + '</color>';",
                        "  \t\t\t\t\t\t\t\tcur_star = ShipStar(cur_shop);",
                        "  \t\t\t\t\t\t\t}",
                        "  ",
                        "                              //Пропускаем скрытый сектор, если пиратская ветка ещё не завершена",
                        "                              if(!PirateWin())",
                        "                              {",
                        "                                  if(StarToCon(cur_star) == StarToCon(PlanetToStar(PlanetPirateClan()))) continue;",
                        "                              }",
                        "  ",
                        "  \t\t\t\t\t\t\t//Выписываем сектор",
                        "  \t\t\t\t\t\t\ttstr1 = tstr1 + CT('FormInfo.M09Const') + ' <color=255,240,100>' + Name(StarToCon(cur_star)) + '</color>' + CT(\"Script.Mod_ExpAutoSearch.0\");",
                        "  ",
                        "  \t\t\t\t\t\t\t//Выписываем систему",
                        "  \t\t\t\t\t\t\ttstr1 = tstr1 + CT('FormInfo.M09Star') + ' <color=255,240,100>' + Name(cur_star) + '</color>' + CT(\"Script.Mod_ExpAutoSearch.0\");",
                        "  ",
                        "                              //Выписываем магазин",
                        "  \t\t\t\t\t\t\ttstr1 = tstr1 + tstr2 + CT(\"Script.Mod_ExpAutoSearch.0\");",
                        "  ",
                        "                              //Выписываем ТУ предмета (для оружия здесь же указывается его тип)",
                        "  \t\t\t\t\t\t\tif(item_type >= t_Weapon1)",
                        "  \t\t\t\t\t\t\t{",
                        "  \t\t\t\t\t\t\t\ttint4 = ItemLevel(cur_item);",
                        "  \t\t\t\t\t\t\t\tif(tint4 >= 8) tstr2 = 'H';",
                        "  \t\t\t\t\t\t\t\telse if(tint4 == 7) tstr2 = 'G';",
                        "  \t\t\t\t\t\t\t\telse if(tint4 == 6) tstr2 = 'F';",
                        "  \t\t\t\t\t\t\t\telse if(tint4 == 5) tstr2 = 'E';",
                        "  \t\t\t\t\t\t\t\telse if(tint4 == 4) tstr2 = 'D';",
                        "  \t\t\t\t\t\t\t\telse if(tint4 == 3) tstr2 = 'C';",
                        "  \t\t\t\t\t\t\t\telse if(tint4 == 2) tstr2 = 'B';",
                        "  \t\t\t\t\t\t\t\telse if(tint4 <= 1) tstr2 = 'A';",
                        "  ",
                        "                                  if(GetEquipmentStats(cur_item, 3) == 0) tstr1 = tstr1 + CT('FormInfo.ISType') + ' <color=255,240,100>' + CT('FormInfo.Equipment.EnergyType') + '</color>' + ' <color=255,240,100>(' + tstr2 + ')</color>' + CT(\"Script.Mod_ExpAutoSearch.0\");",
                        "                                  else if(GetEquipmentStats(cur_item, 3) == 1) tstr1 = tstr1 + CT('FormInfo.ISType') + ' <color=255,240,100>' + CT('FormInfo.Equipment.SplinterType') + '</color>' + ' <color=255,240,100>(' + tstr2 + ')</color>' + CT(\"Script.Mod_ExpAutoSearch.0\");",
                        "                                  else tstr1 = tstr1 + CT('FormInfo.ISType') + ' <color=255,240,100>' + CT('FormInfo.Equipment.MissileType') + '</color>' + ' <color=255,240,100>(' + tstr2 + ')</color>' + CT(\"Script.Mod_ExpAutoSearch.0\");",
                        "  \t\t\t\t\t\t\t}",
                        "  \t\t\t\t\t\t\telse tstr1 = tstr1 + DeleteTags(CT('FormInfo.Equipment.Tech')) + '<color=255,240,100>' + ItemLevel(cur_item) + '</color>' + CT(\"Script.Mod_ExpAutoSearch.0\");",
                        "  ",
                        "                              //Выписываем модификацию оружия (если искали оружие и если модификация есть)",
                        "                              if(item_type >= t_Weapon1)",
                        "                              {",
                        "                                  tint4 = EqSpecial(cur_item);",
                        "                                  if(tint4 > -1)",
                        "                                  {",
                        "                                      tstr1 = tstr1 + CT('Items.Weapon.WSpecial') + ' <color=255,240,100>' + BonusName(tint4) + '</color>' + CT(\"Script.Mod_ExpAutoSearch.0\");",
                        "                                  }",
                        "                              }",
                        "  ",
                        "                              //Выписываем статы предмета",
                        "                              if(item_type >= t_Weapon1)",
                        "                              {",
                        "                                  tstr1 = tstr1 + Format(DeleteTags(CT('FormInfo.Equipment.Damage')), ' -', GetEquipmentStats(cur_item, ' <MinDamage' + '><color=248,252,216>-</color><' + 'MaxDamage><' + 'Bonus>')) + ', ' + Format(DeleteTags(CT('FormInfo.Equipment.Radius')), ' ', GetEquipmentStats(cur_item, ' <Radius' + '>'));",
                        "                                  //Для ракетного оружия также добавляем максимальный боезапас",
                        "                                  if(GetEquipmentStats(cur_item, 3) == 2) tstr1 = tstr1 + ', ' + Format(CT('FormInfo.Equipment.MaxAmmo'), '#MaxCount#', GetEquipmentStats(cur_item, '<MaxCount' + '>')) + CT(\"Script.Mod_ExpAutoSearch.0\");",
                        "                                  else tstr1 = tstr1 + CT(\"Script.Mod_ExpAutoSearch.0\");",
                        "                              }",
                        "                              else if(item_type == t_Hull)",
                        "                              {",
                        "                                  tint4 = HullSeries(cur_item);",
                        "                                  if(tint4 > -1) tstr1 = tstr1 + Format(DeleteTags(CT('FormInfo.Equipment.Series')), ' ', ' ' + CT('HullType.' + SeriesNumInCfg(tint4) + '.Name')) + CT(\"Script.Mod_ExpAutoSearch.0\");",
                        "                                  tstr1 = tstr1 + Format(CT('FormInfo.Equipment.SusceptibilitySearch'), '#1#', GetEquipmentStats(cur_item, '<FragilityE' + '>'), '#2#', GetEquipmentStats(cur_item, '<FragilityS' + '>'), '#3#', GetEquipmentStats(cur_item, '<FragilityM' + '>')) + CT(\"Script.Mod_ExpAutoSearch.0\");",
                        "                                  tstr1 = tstr1 + Format(DeleteTags(CT('FormInfo.Equipment.Protect')), ' ', GetEquipmentStats(cur_item, ' <HitProtect' + '>')) + CT(\"Script.Mod_ExpAutoSearch.0\");",
                        "                              }",
                        "                              else if(item_type == t_Engine)",
                        "                              {",
                        "                                  tstr1 = tstr1 + Format(DeleteTags(CT('FormInfo.Equipment.Speed')), ' ', GetEquipmentStats(cur_item, ' <Speed' + '>')) + ', ' + Format(DeleteTags(CT('FormInfo.Equipment.Jump')), ' ', GetEquipmentStats(cur_item, ' <Parsec' + '>')) + CT(\"Script.Mod_ExpAutoSearch.0\");",
                        "                              }",
                        "                              else if(item_type == t_FuelTanks)",
                        "                              {",
                        "                                  tstr1 = tstr1 + Format(DeleteTags(CT('FormInfo.Equipment.Fuel')), ' ', GetEquipmentStats(cur_item, ' <Capacity' + '>')) + CT(\"Script.Mod_ExpAutoSearch.0\");",
                        "                              }",
                        "                              else if(item_type == t_Radar)",
                        "                              {",
                        "                                  tstr1 = tstr1 + Format(DeleteTags(CT('FormInfo.Equipment.Radar')), ' ', GetEquipmentStats(cur_item, ' <Radius' + '>')) + CT(\"Script.Mod_ExpAutoSearch.0\");",
                        "                              }",
                        "                              else if(item_type == t_Scaner)",
                        "                              {",
                        "                                  tstr1 = tstr1 + Format(DeleteTags(CT('FormInfo.Equipment.Scaner')), ' ', GetEquipmentStats(cur_item, ' <Percent' + '>')) + CT(\"Script.Mod_ExpAutoSearch.0\");",
                        "                              }",
                        "                              else if(item_type == t_RepairRobot)",
                        "                              {",
                        "                                  tstr1 = tstr1 + Format(DeleteTags(CT('FormInfo.Equipment.Droid')), ' ', GetEquipmentStats(cur_item, ' <RecoverHitPoints' + '>')) + CT(\"Script.Mod_ExpAutoSearch.0\");",
                        "                              }",
                        "                              else if(item_type == t_CargoHook)",
                        "                              {",
                        "                                  tstr1 = tstr1 + Format(DeleteTags(CT('FormInfo.Equipment.Hook')), ' ', GetEquipmentStats(cur_item, ' <PickUpSize' + '>')) + ', ' + Format(DeleteTags(CT('FormInfo.Equipment.HookRadius')), ' ', GetEquipmentStats(cur_item, ' <Radius' + '>')) + ', ' + Format(DeleteTags(CT('FormInfo.Equipment.HookSpeed')), ' -', GetEquipmentStats(cur_item, ' <SpeedMin' + '><color=248,252,216>-</color><SpeedMax' + '>')) + CT(\"Script.Mod_ExpAutoSearch.0\");",
                        "                              }",
                        "                              else if(item_type == t_DefGenerator)",
                        "                              {",
                        "                                  tstr1 = tstr1 + Format(DeleteTags(CT('FormInfo.Equipment.Defend')), ' ', GetEquipmentStats(cur_item, ' <Percent' + '>')) + CT(\"Script.Mod_ExpAutoSearch.0\");",
                        "                              }",
                        "  ",
                        "  \t\t\t\t\t\t\tif(item_type != t_Hull)",
                        "  \t\t\t\t\t\t\t{",
                        "  \t\t\t\t\t\t\t\t//Выписываем надёжность предмета",
                        "  \t\t\t\t\t\t\t\ttflt1 = ItemFragility(cur_item);",
                        "  \t\t\t\t\t\t\t\ttflt2 = 0.60;",
                        "  \t\t\t\t\t\t\t\ttflt3 = 5.00;",
                        "  \t\t\t\t\t\t\t\ttint4 = 0;",
                        "  \t\t\t\t\t\t\t\tfor(k = 0; k <= 6; k = k + 1)",
                        "  \t\t\t\t\t\t\t\t{",
                        "  \t\t\t\t\t\t\t\t\tif(k <= 3) tflt2 = tflt2 + 0.10;",
                        "  \t\t\t\t\t\t\t\t\telse tflt2 = tflt2 + 0.20;",
                        "  \t\t\t\t\t\t\t\t\tif(abs(tflt1 - tflt2) < tflt3)",
                        "  \t\t\t\t\t\t\t\t\t{",
                        "  \t\t\t\t\t\t\t\t\t\ttflt3 = abs(tflt1 - tflt2);",
                        "  \t\t\t\t\t\t\t\t\t\ttint4 = k;",
                        "  \t\t\t\t\t\t\t\t\t}",
                        "  \t\t\t\t\t\t\t\t}",
                        "  \t\t\t\t\t\t\t\ttstr1 = tstr1 + CT('FormInfo.Equipment.Reliability') + '<color=255,240,100>' + CT('FormInfo.Equipment.QualityGrade' + tint4) + '</color>' + CT(\"Script.Mod_ExpAutoSearch.0\");",
                        "  \t\t\t\t\t\t\t}",
                        "  ",
                        "  \t\t\t\t\t\t\t//Выписываем стоимость предмета",
                        "  \t\t\t\t\t\t\ttstr1 = tstr1 + CT('FormInfo.CostShort') + ' <color=255,240,100>' + ItemCost(cur_item) + '</color> cr.';",
                        "  ",
                        "                              //Вывод отдельного уведомления для каждого успешного результата",
                        "                              CustomEther('AutoSearch', 7, '', tstr1);",
                        "  ",
                        "                              //Прерываем цикл, если число результатов достигло максимального предела (чтобы не засорять панель уведомлений сотнями Ether)",
                        "                              tint2 = tint2 + 1;",
                        "                              if(tint2 >= maxResultsCount) break;",
                        "  \t\t\t\t\t\t}",
                        "  ",
                        "                          //Выводим общее уведомление с десятком (максимум) успешных результатов",
                        "                          //Лучше не включать, т.к. при выводе сразу десяти результатов первые два \"прошибают потолок\" экрана",
                        "                          //CustomEther('AutoSearch', 7, '', tstr1);",
                        "  ",
                        "  \t\t\t\t\t\t//Если автопоиск не нашёл ни одного подходящего предмета (при желании можно добавить сюда какой-нибудь вывод)",
                        "  \t\t\t\t\t\t//if(!tint2) CustomEther('AutoSearch', 0, '', Format(CT('Script.Mod_ExpAutoSearch.NoSuccessfulResults'), '#0#', ''));",
                        "  \t\t\t\t\t}",
                        "  \t\t\t\t\t//Обновляем таймер запроса",
                        "  \t\t\t\t\tGItemsToSearchArr[requestNum, 39] = CurTurn() + GItemsToSearchArr[requestNum, 40];",
                        "  \t\t\t\t}",
                        "  \t\t\t\t//Если был произведён хотя бы один запрос",
                        "  \t\t\t\tif(tint3)",
                        "  \t\t\t\t{",
                        "  \t\t\t\t\tShipMoney(Player(), ShipMoney(Player()) - tint3);",
                        "  \t\t\t\t\tSound('Sound.Sell');",
                        "  \t\t\t\t}",
                        "  \t\t\t\t//Зачищаем временный массив, превращая его в unknown",
                        "  \t\t\t\tfree(GAcrynListTempArr);",
                        "  \t\t\t\tcopy(GAcrynListTempArr, clear);",
                        "  \t\t\t}",
                        "  \t\t}",
                        "  \t}",
                        "  }",
                        "}"
                    ],
                    "#": 32,
                    "Type": "Top",
                    "Parent": -1,
                    "Pos.x": 120,
                    "Pos.y": 610
                },
                {
                    "Name": "",
                    "Code.Type": "DialogBegin",
                    "Code": [
                        "cur_shop = GetShipRuins(Player());",
                        "if(cur_shop)",
                        "{",
                        "    //Если ExpPilotBridge подключён",
                        "    if(IsScriptActive('Mod_ExpPilotBridge'))",
                        "    {",
                        "        if(PlayerBridge() == 14)",
                        "        {",
                        "            if(IsScriptActive('Mod_ExpBK'))tstr1 = CT('Script.Mod_ExpAutoSearch.DialogHeaderWithExpBK');",
                        "            else tstr1 = CT('Script.Mod_ExpAutoSearch.DialogHeaderWithNoExpBK');",
                        "            //Блокируем диалог, если игрок допустил уже больше двух просрочек по кредиту",
                        "            if(PlayerDebtCnt() > 2)AddDialogBlock(CT('Script.Mod_ExpAutoSearch.MainDialogInject'), 1);",
                        "            AddDialogInject('AutoSearch', tstr1, CT('Script.Mod_ExpAutoSearch.MainDialogInject'), 7);",
                        "        }",
                        "    }",
                        "    //Иначе выводим диалог на БЦ",
                        "    else",
                        "    {",
                        "        if(ShipType(cur_shop) == 'BK')",
                        "        {",
                        "            //Блокируем диалог, если игрок допустил уже больше двух просрочек по кредиту",
                        "            if(PlayerDebtCnt() > 2)AddDialogBlock(CT('Script.Mod_ExpAutoSearch.MainDialogInject'), 1);",
                        "            AddDialogInject('AutoSearch', '', CT('Script.Mod_ExpAutoSearch.MainDialogInject'), 0);",
                        "        }",
                        "    }",
                        "}"
                    ],
                    "#": 33,
                    "Type": "Top",
                    "Parent": -1,
                    "Pos.x": 180,
                    "Pos.y": 610
                },
                {
                    "Name": "",
                    "Code.Type": "Turn",
                    "Code": [
                        "tstr1 = '</color>' + Format(CT('Script.Mod_ExpAutoSearch.GreetingsText'), '#0#', maxRequestCount, '#1#', maxResultsCount, '#2#', requestCreateCost, '#3#', requestRollCost);",
                        "DChange(0);",
                        "exit;"
                    ],
                    "#": 45,
                    "Type": "Top",
                    "Parent": -1,
                    "Pos.x": -20,
                    "Pos.y": 400
                },
                {
                    "Name": "",
                    "Code.Type": "Turn",
                    "Code": [
                        "GAcrynListTempArr=newarray(2);",
                        "GAcrynListTempArr[0]=GAnswerData;",
                        "//Запоминаем старое значение числа запросов на случай, если изменяемый запрос будет удалён",
                        "tint1=GItemsToSearchArr[0,0];",
                        "OpenCustomForm('AutoSearch');",
                        "//Если запрос был изменён",
                        "if(GAcrynListTempArr[0])tstr1='</color>'+CT('Script.Mod_ExpAutoSearch.RequestWasChanged');",
                        "//Если запрос был удалён",
                        "else if(GItemsToSearchArr[0,0]<tint1)tstr1='</color>'+CT('Script.Mod_ExpAutoSearch.RequestWasDeleted');",
                        "//Если запрос не изменялся и не удалялся",
                        "else tstr1='</color>'+CT('Script.Mod_ExpAutoSearch.RequestChangeList');",
                        "free(GAcrynListTempArr);",
                        "arraychange(GAcrynListTempArr,1);",
                        "if(!GItemsToSearchArr[0, 0]) {",
                        "  DChange(0);",
                        "  exit;",
                        "}",
                        "if(GItemsToSearchArr[0, 0]) {",
                        "  DChange(1);",
                        "  exit;",
                        "}"
                    ],
                    "#": 46,
                    "Type": "Top",
                    "Parent": -1,
                    "Pos.x": 130,
                    "Pos.y": 400
                },
                {
                    "Name": "",
                    "Code.Type": "Turn",
                    "Code": [
                        "tstr1 = '</color>' + CT('Script.Mod_ExpAutoSearch.CreateNewRequest');",
                        "tstr2 = '</color>' + CT('Script.Mod_ExpAutoSearch.ChangeExistedRequest');",
                        "tstr3 = '</color>' + CT('Script.Mod_ExpAutoSearch.GetBack');",
                        "if(GItemsToSearchArr[0, 0] < maxRequestCount) {",
                        "  DAdd(1);",
                        "}",
                        "if(GItemsToSearchArr[0, 0] >= maxRequestCount) {",
                        "  DAdd(2);",
                        "}",
                        "if(GItemsToSearchArr[0, 0]) {",
                        "  DAdd(3);",
                        "}",
                        "if(!GItemsToSearchArr[0, 0]) {",
                        "  DAdd(4);",
                        "}",
                        "DAdd(0);"
                    ],
                    "#": 47,
                    "Type": "Top",
                    "Parent": -1,
                    "Pos.x": -20,
                    "Pos.y": 470
                },
                {
                    "Name": "",
                    "Code.Type": "Turn",
                    "Code": [
                        "//Выводим в ответы список активных запросов",
                        "for(i = 1; i <= GItemsToSearchArr[0, 0]; i = i + 1)",
                        "{",
                        "    tstr1 = DeleteTags(CT('Script.Mod_ExpAutoSearch.' + GItemsToSearchArr[i, 38]));",
                        "    tstr1 = '' + i + '. ' + Format(CT('Script.Mod_ExpAutoSearch.RequestAnswer'), '#0#', tstr1,'#1#', GItemsToSearchArr[i, 40]);",
                        "    InjectAnswer('AutoSearchChange', tstr1, i);",
                        "}",
                        "tstr2 = '</color>' + CT('Script.Mod_ExpAutoSearch.GetBack');",
                        "DAdd(5);"
                    ],
                    "#": 48,
                    "Type": "Top",
                    "Parent": -1,
                    "Pos.x": 130,
                    "Pos.y": 470
                },
                {
                    "Name": "",
                    "Code.Type": "Turn",
                    "Code": [
                        "GAcrynListTempArr=newarray(2);",
                        "GAcrynListTempArr[0]=0;",
                        "OpenCustomForm('AutoSearch');",
                        "//Если новый запрос был создан",
                        "if(GAcrynListTempArr[0])tstr1='</color>'+CT('Script.Mod_ExpAutoSearch.GreetingsNewRequestText');",
                        "//Если не был",
                        "else tstr1='</color>'+Format(CT('Script.Mod_ExpAutoSearch.GreetingsText'),'#0#',maxRequestCount,'#1#',maxResultsCount,'#2#',requestCreateCost,'#3#',requestRollCost);",
                        "free(GAcrynListTempArr);",
                        "arraychange(GAcrynListTempArr,1);",
                        "DChange(0);",
                        "exit;"
                    ],
                    "#": 49,
                    "Type": "Top",
                    "Parent": -1,
                    "Pos.x": 100,
                    "Pos.y": 540
                },
                {
                    "Name": "",
                    "Code.Type": "Turn",
                    "Code": [
                        "tstr1 = '</color>' + CT('Script.Mod_ExpAutoSearch.RequestChangeList');",
                        "DChange(1);",
                        "exit;"
                    ],
                    "#": 50,
                    "Type": "Top",
                    "Parent": -1,
                    "Pos.x": 340,
                    "Pos.y": 540
                },
