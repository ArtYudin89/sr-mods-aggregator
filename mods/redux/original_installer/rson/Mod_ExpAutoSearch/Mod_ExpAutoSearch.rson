                        "",
                        "//Задаём максимальное число выводимых по запросу успешных результатов",
                        "maxResultsCount = 10;",
                        "//Задаём цену оформления и переоформления запроса",
                        "requestCreateCost = round(0.80 * GalaxyMoney(1, 2));",
