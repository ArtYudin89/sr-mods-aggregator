                        "",
                        "//Стартовый перебор числа БЦ в Галактике",
                        "for(i = 0; i < GalaxyStars(); i = i + 1)",
                        "{",
                        "    cur_star = GalaxyStar(i);",
                        "    if(!StarRuins(cur_star, 'BK')) continue;",
                        "    TotalBKCount = TotalBKCount + 1;",
                        "}"
