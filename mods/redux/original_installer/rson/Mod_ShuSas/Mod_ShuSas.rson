                    "#": 26
                },
                {
                    "Name": "  if(!sst) {\r\n  \t//Запоминаем изначального владельца планеты\r\n  \tplanetOwner=PlanetOwner(OccupiedPlanet);\r\n  \t//Создаем военных\r\n  \tfor(i=0;i<Rnd(5,7);i=i+1)\r\n  \t{\r\n  \t\t//Меняем владельца и расу планеты для спавна на расу из захваченной системы\r\n  \t\tPlanetOwner(OccupiedPlanet,PlanetRace(OccupiedPlanet));\r\n  \t\tship=BuyWarrior(OccupiedPlanet,Rnd(200,500));\r\n  \t\t//Оснащаем военных\r\n  \t\tItemSize(ShipItems(ship,0),round((0.00085*GalaxyDiffLevels()+1)*GalaxyTechLevel()*100)+Rnd(-25,45));\r\n  \t\tif(ItemSize(ShipItems(ship,0))<250)\r\n  \t\tItemSize(ShipItems(ship,0),250);\r\n  \t\tHullHP(ship,ItemSize(ShipItems(ship,0)));\r\n  \t\tChameleon(ship);\r\n  \t\tfor(j=0;j<5;j=j+1) ShipRefit(ship);\r\n  \t\tfor(j=0;j<3;j=j+1) {\r\n  \t\t\ttint=round(0.5*GalaxyTechLevel())+Rnd(-1,2);\r\n  \t\t\tShipSkill(ship,j,tint);\r\n  \t\t}\r\n          if(GetEquipmentStats(ShipItems(ship,0),7))  {\r\n      \t\tif(!ShipEqInSlot(ship,t_DefGenerator)) {\r\n      \t\t\titem=CreateEquipment(t_DefGenerator,Rnd(20,45),GalaxyTechLevel(),ShipOwner(ship));\r\n      \t\t\tAddItemToShip(ship,item);\r\n      \t\t\tItemIsInUse(item,ship,1);\r\n  \t\t    }\r\n          }\r\n          if(GetEquipmentStats(ShipItems(ship,0),5)) {\r\n      \t\tif(!ShipEqInSlot(ship,t_RepairRobot)) {\r\n      \t\t\titem=CreateEquipment(t_RepairRobot,Rnd(20,45),GalaxyTechLevel(),ShipOwner(ship));\r\n      \t\t\tAddItemToShip(ship,item);\r\n      \t\t\tItemIsInUse(item,ship,1);\r\n      \t\t}\r\n          }\r\n  \t\t//Рандомно улучшаем оборудование\r\n  \t\tShipImproveItems(ship,2*GalaxyTechLevel());\r\n  \t\t//Устраняем возможный перевес\r\n  \t\tShipCalcParam(ship);\r\n  \t\tif(ShipFreeSpace(ship)<0) {\r\n  \t\t\tItemSize(ShipItems(ship,0),ItemSize(ShipItems(ship,0))+abs(ShipFreeSpace(ship))+Rnd(1,5));\r\n  \t\t\tHullHP(ship,ItemSize(ShipItems(ship,0)));\r\n  \t\t}\r\n  \t\tShipJoin(Warriors,ship);\r\n  \t\tTransferShip(ship,UnhabitablePlanet);\r\n  \t}\r\n  \t//Возвращаем планете первоначального владельца\r\n  \tPlanetOwner(OccupiedPlanet,planetOwner);\r\n      sst=1;\r\n  }\r\n  if(sst && !GroupCount(Warriors)) AllShipOut();\r",
                    "Type": "TDialog",
