                        "if(ShipMoney(Player())<(cost*6)/10 || nod_sum<(cost*6)/1000) {",
                        "  DAdd(26);",
                        "}",
                        "if(ShipMoney(Player())>=(cost*3)/10 && nod_sum>=(cost*3)/1000) {",
                        "  DAdd(5);",
                        "}",
                        "if(ShipMoney(Player())<(cost*3)/10 || nod_sum<(cost*3)/1000) {",
                        "  DAdd(27);",
                        "}",
