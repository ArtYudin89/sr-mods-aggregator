            "Operations": [
                {
                    "Name": "",
                    "Code.Type": "Global",
                    "Code": [
                        "GRun();"
                    ],
                    "#": 34,
                    "Type": "Top",
                    "Parent": -1,
                    "Pos.x": 0,
                    "Pos.y": 710
                },
                {
                    "Name": "",
                    "Code.Type": "Init",
                    "Code": [
                        "//Инфошка ядерки NPC:",
                        "//data 1 - ход следующего запуска",
                        "//data 2 - время перезарядки между запусками",
                        "//Создание кастомного оружия для запуска нова-торпеды. Нужно, чтобы был радиус взрыва 700.",
                        "tdwd=InventNewCustomWeapon('nova',t_Weapon9);",
                        "SetCustomWeaponSE(tdwd,'Weapon.3','Weapon.NoGraph','Weapon.MissileHit',8);",
                        "SetCustomWeaponPrimaryData(tdwd,6,t_Weapon9,t_Weapon15);",
                        "SetCustomWeaponSizeAndCost(tdwd,1,1);",
                        "SetCustomWeaponDamageData(tdwd,1,1,4);",
                        "SetCustomWeaponShotData(tdwd,'Torpedo1',0,1500,700,6);",
                        "SetCustomWeaponAvailability(tdwd,'NotSold');",
                        "SetCustomMissileWeaponStats(tdwd,1500,10,500,0);",
                        "//Закапываем нова-торпеды и нейтронные бомбы на незаселенках",
                        "//Заносим в массив все незаселенки, пропускаем родную систему игрока и планеты Дицеи",
                        "ArrayClear(tempArr);",
                        "for(i=0;i<GalaxyStars();i=i+1) {",
                        "    tStar=GalaxyStar(i);",
                        "    if(tStar==PlanetToStar(GetShipHomePlanet(Player()))) continue;",
                        "    if(StarToCon(tStar) == StarToCon(PlanetToStar(PlanetPirateClan()))) continue;",
                        "\tfor(j=0;j<StarPlanets(tStar);j=j+1) {",
                        "\t\ttPlanet=StarPlanets(tStar,j);",
                        "\t\tif(PlanetOwner(tPlanet)==None) ArrayAdd(tempArr,Id(tPlanet));",
                        "\t}",
                        "}",
                        "ArrayDelete(tempArr, 0); //Удаляем нулевой элемент, чтобы он не перемешивался",
                        "ArrayRandomize(150,tempArr);",
                        "nBombCount=Rnd(12,18);    //Число нейтронных бомб",
                        "novaCount=Rnd(2,5);    //Число нова-торпед",
                        "i=1;    //Начальная итерация",
                        "while(nBombCount) {    //Закапываем нейтронные бомбы",
                        "    tPlanet=IdToPlanet(tempArr[i]);",
                        "    AddItemToPlanet(tPlanet,CreateQuestItem('NeutronBomb'));",
                        "    nBombCount=nBombCount-1;",
                        "    i=i+1;",
                        "}",
                        "while(novaCount) {    //Закапываем нова-торпеды",
                        "    tPlanet=IdToPlanet(tempArr[i]);",
                        "    AddItemToPlanet(tPlanet,CreateQuestItem('NovaTorpedo'));",
                        "    novaCount=novaCount-1;",
                        "    i=i+1;",
                        "}",
                        "//Таймер апгрейда количества доступных ядерок",
                        "if(GalaxyDiffLevels()<100) nukesCntUpTimer=Rnd(0,960)+365*20;",
                        "else if(GalaxyDiffLevels()<150) nukesCntUpTimer=Rnd(0,960)+365*27;",
                        "else if(GalaxyDiffLevels()<175) nukesCntUpTimer=Rnd(0,960)+365*33;",
                        "else if(GalaxyDiffLevels()<200) nukesCntUpTimer=Rnd(0,960)+365*39;",
                        "else nukesCntUpTimer=Rnd(0,960)+365*45;",
                        "//Таймер до возможности апгрейда ядерной установки игрока на ВБ",
                        "if(GalaxyDiffLevels()<100) nukeLauncherWBUpTimer=Rnd(180,480)+365*15;",
                        "else if(GalaxyDiffLevels()<150) nukeLauncherWBUpTimer=Rnd(180,480)+365*20;",
                        "else if(GalaxyDiffLevels()<175) nukeLauncherWBUpTimer=Rnd(180,480)+365*24;",
                        "else if(GalaxyDiffLevels()<200) nukeLauncherWBUpTimer=Rnd(180,480)+365*28;",
                        "else nukeLauncherWBUpTimer=Rnd(180,480)+365*32;",
                        "nukeLauncherCBUpTimer=nukeLauncherWBUpTimer-365*Rnd(1,3);    //До пиратов такое дойдет с задержкой в 1-3 года;"
                    ],
                    "#": 35,
                    "Type": "Top",
                    "Parent": -1,
                    "Pos.x": 60,
                    "Pos.y": 710
                },
                {
                    "Name": "",
                    "Code.Type": "Turn",
                    "Code": [
                        "if(!bossNuke) {",
                        "  if(Blazer()) {",
                        "      if(ShipFindCustomShipInfoByType(Blazer(),'Absorber')==-1) ShipAddCustomShipInfo(Blazer(),'Absorber');",
                        "  \tif(ShipFindCustomShipInfoByType(Blazer(),'NpcNuke')==-1) {",
                        "          ShipAddCustomShipInfo(Blazer(),'NpcNuke');",
                        "          ShipCustomShipInfoData(Blazer(),'NpcNuke',2,5);",
                        "      }",
                        "      ShipAddCustomShipInfo(Blazer(),'BossNuke2','NoShow');",
                        "  \tShipAddCustomShipInfo(Blazer(),'BossNuke3','NoShow');",
                        "  }",
                        "  if(Terron()) {",
                        "      if(ShipFindCustomShipInfoByType(Terron(),'Absorber')==-1) ShipAddCustomShipInfo(Terron(),'Absorber');",
                        "  \tif(ShipFindCustomShipInfoByType(Terron(),'NpcNuke')==-1) {",
                        "          ShipAddCustomShipInfo(Terron(),'NpcNuke');",
                        "          ShipCustomShipInfoData(Terron(),'NpcNuke',2,5);",
                        "      }",
                        "  \tShipAddCustomShipInfo(Terron(),'BossNuke2','NoShow');",
                        "  \tShipAddCustomShipInfo(Terron(),'BossNuke3','NoShow');",
                        "  }",
                        "  if(Keller()) {",
                        "      if(ShipFindCustomShipInfoByType(Keller(),'Absorber')==-1) ShipAddCustomShipInfo(Keller(),'Absorber');",
                        "  \tif(ShipFindCustomShipInfoByType(Keller(),'NpcNuke')==-1) {",
                        "          ShipAddCustomShipInfo(Keller(),'NpcNuke');",
                        "          ShipCustomShipInfoData(Keller(),'NpcNuke',2,5);",
                        "      }",
                        "  \tShipAddCustomShipInfo(Keller(),'BossNuke2','NoShow');",
                        "  \tShipAddCustomShipInfo(Keller(),'BossNuke3','NoShow');",
                        "  }",
                        "  bossNuke=1;",
                        "}",
                        "GTL=GalaxyTechLevel();",
                        "//Раздача ядерок, абсорберов и генераторов помех",
                        "//Перебираем все новые корабли в галактике по заданным фильтрам",
                        "if(GalaxyShipId()>lastShipId) {",
                        "    tdwd=BuildListOfNewShips(tempArr,lastShipId,1+2+4+8+16+256+4096+8192,1+2+4+8+16+128,1,'','Militiaman1,,Militiaman2,Militiaman3,Rebel,RangerPirate,RangerExplorer,RangerPirateExplorer,Smuggler,EliteWarrior,Merc,Freelancer,RedLeader,AtlantLeader,FeiLeader,Khan,Headhunter,Marauder,PirateCorvette,PirateFrigate,PirateGalleon,Dreadnought,Klissan5,Klissan4,Klissan3,Klissan2,Klissan1,Machpella');",
                        "    if(tdwd) {    //Если найден хотя бы один корабль",
                        "        for(i=0;i<ArrayDim(tempArr);i=i+1) {",
                        "            tdwd=0;    //Обнуляем флаг",
                        "            chance=0;    //Обнуляем шанс выдачи",
                        "            tShip=tempArr[i];    //Выбираем корабль",
                        "            //if(ShipInScript(tShip,0)) continue; //пропуск скриптовых кораблей?",
                        "            if(IsPlayer(tShip)) continue;",
                        "            if(ShipOwner(tShip)==Kling && ShipSubType(tShip)==7) continue;    //Пропуск клигов",
                        "            if(ShipOwner(tShip)==Kling && !ShipSubType(tShip)) continue;    //Пропуск боссов",
                        "            if(~ShipFindCustomShipInfoByType(tShip, 'ShuNukes_BlockNukes')) continue;",
                        "            tStr=ShipType(tShip);",
                        "            //Абсорбер",
                        "            //Рейнджеры и производные от них",
                        "            if(tStr=='Ranger' || tStr=='RangerPirate' || tStr=='Freelancer' || tStr=='Merc' || tStr=='PlayerMerc' || tStr=='RangerExplorer' || tStr=='RangerPirateExplorer') chance=8+GTL*2;",
                        "\t\t\telse if(tStr=='Smuggler') chance=4+GTL;",
                        "\t\t\telse if(tStr=='Diplomat') chance=4+GTL;",
                        "\t\t\telse if(tStr=='Transport' || tStr=='Liner') chance=GTL;",
                        "\t\t\telse if((tStr=='Pirate' && PirateType(tShip)) || tStr=='Rebel' || tStr=='Thug' || tStr=='PirateCorvette') chance=GTL+GetShipPirateRank(tShip)*5;",
                        "            else if(tStr=='PirateFrigate') chance=GTL*4;",
                        "\t\t\telse if(tStr=='Pirate' && !PirateType(tShip)) chance=GTL*2;",
                        "\t\t\telse if((tStr=='Warrior' && ShipSubType(tShip)) || tStr=='Dreadnought' || tStr=='PirateGalleon') chance=GTL*10;    //Крупные корабли",
                        "\t\t\telse if((tStr=='Warrior' && !ShipSubType(tShip)) || tStr=='EliteWarrior' || tStr=='Militiaman1' || tStr=='Militiaman2' || tStr=='Militiaman3') chance=GTL+ShipRank(tShip)*5;",
                        "\t\t\telse if(tStr=='Khan' || tStr=='Marauder' || tStr=='Machpella' || tStr=='Handler' || tStr=='Klissan1' || tStr=='Klissan2' || tStr=='Klissan3' || tStr=='Klissan4' || tStr=='Klissan5' || tStr=='KB' || tStr=='AtlantLeader' || tStr=='RedLeader' || tStr=='FeiLeader' || tStr=='MB' || tStr=='Inhibitor') chance=100;",
                        "\t\t\telse if(ShipOwner(tShip)==5 && ShipSubType(tShip)==6) chance=GTL*10;",
                        "\t\t\telse if(ShipOwner(tShip)==5 && ShipSubType(tShip)!=6) chance=11;",
                        "\t\t\telse if(ObjectType(tShip)==4) chance=100;",
                        "\t\t\telse chance=0;",
                        "\t\t\tif(Rnd(1,100)<=chance) ShipAddCustomShipInfo(tShip,'Absorber');",
                        "            //Генератор помех",
                        "\t\t\tif(tStr=='Ranger' || tStr=='RangerPirate' || tStr=='Freelancer' || tStr=='Merc' || tStr=='PlayerMerc' || tStr=='RangerExplorer' || tStr=='RangerPirateExplorer') chance=4+GTL*2;",
                        "\t\t\telse if(tStr=='Smuggler') chance=8+GTL;",
                        "\t\t\telse if(tStr=='Transport' || tStr=='Liner' || tStr=='Diplomat') chance=4+GTL*80/100;",
                        "\t\t\telse if(tStr=='Pirate' || tStr=='Rebel' || tStr=='Thug' || tStr=='PirateCorvette' || tStr=='PirateFrigate') chance=GetShipPirateRank(tShip)*3;",
                        "\t\t\telse if((tStr=='Warrior' && ShipSubType(tShip)) || tStr=='Dreadnought' || tStr=='PirateGalleon') chance=GTL*9;",
                        "\t\t\telse if((tStr=='Warrior' && !ShipSubType(tShip)) || tStr=='EliteWarrior' || tStr=='Militiaman1' || tStr=='Militiaman2' || tStr=='Militiaman3') chance=ShipRank(tShip)*4;",
                        "\t\t\telse if(tStr=='Khan' || tStr=='Marauder' || tStr=='Handler' || tStr=='AtlantLeader' || tStr=='RedLeader' || tStr=='FeiLeader' || tStr=='MB' || tStr=='Inhibitor' || tStr=='Salvager') chance=100;",
                        "\t\t\telse if(ShipOwner(tShip)==5 && ShipSubType(tShip)==6) chance=40+GTL*5;",
                        "\t\t\telse if(ShipOwner(tShip)==5 && ShipSubType(tShip)) chance=6+GTL*90/100;",
                        "\t\t\telse if(ObjectType(tShip)==4) chance=100;",
                        "            else chance=0;",
                        "            if(!ShipProtectability(tShip)) chance=0;",
                        "\t\t\tif(Rnd(1,100)<=chance) ShipAddCustomShipInfo(tShip,'ECM');",
                        "            //Ядерное оружие",
                        "\t\t\tif(ShipCustomFaction(tShip)!='') continue;",
                        "            if(tStr=='Ranger' || tStr=='RangerPirate' || tStr=='Freelancer' || tStr=='Merc' || tStr=='PlayerMerc' || tStr=='RangerExplorer' || tStr=='RangerPirateExplorer') {chance=4+GTL*2; charge=20;}",
                        "\t\t\telse if(tStr=='Smuggler') {chance=5+GTL*50/100; charge=20;}",
                        "\t\t\telse if((tStr=='Pirate' && PirateType(tShip)) || tStr=='Rebel' || tStr=='Thug') {chance=GTL+GetShipPirateRank(tShip)*4; charge=20;}",
                        "\t\t\telse if(tStr=='Pirate' && !PirateType(tShip)) {chance=9+GTL*120/100; charge=20;}",
                        "            else if(tStr=='PirateCorvette' || tStr=='PirateFrigate' ) {chance=9+GTL*120/100; charge=20;}",
                        "\t\t\telse if(tStr=='Warrior' && ShipSubType(tShip) || tStr=='Dreadnought' || tStr=='PirateGalleon') {chance=30+GTL*8; charge=10;}",
                        "\t\t\telse if((tStr=='Warrior' && !ShipSubType(tShip)) || tStr=='EliteWarrior' || tStr=='Militiaman1' || tStr=='Militiaman2' || tStr=='Militiaman3')  {chance=GTL+ShipRank(tShip)*4; charge=20;}",
                        "\t\t\telse if(tStr=='Khan' || tStr=='Marauder' || tStr=='Machpella' || tStr=='Handler' || tStr=='KB' || tStr=='AtlantLeader' || tStr=='RedLeader' || tStr=='FeiLeader' || tStr=='MB' || tStr=='Salvager') {chance=100; charge=20;}",
                        "            else if(tStr=='WB' || tStr=='CB' || tStr=='Inhibitor') {",
                        "                ShipAddCustomShipInfo(tShip,'RuinsNuke');",
                        "                ShipCustomShipInfoData(tShip,'RuinsNuke',2,3);",
                        "                chance=0;",
                        "            }",
                        "\t\t\telse if(ShipOwner(tShip)==5) {",
                        "                if(ShipSubType(tShip)>3) continue;",
                        "                else if(ShipSubType(tShip)==6) {chance=25+GTL*5; charge=10;}",
                        "                else {chance=10+GTL*80/100; charge=20;}",
                        "            }",
                        "\t\t\telse chance=0;",
                        "\t\t\tif(Rnd(1,100)<=chance) {",
                        "                ShipAddCustomShipInfo(tShip,'NpcNuke');",
                        "                ShipCustomShipInfoData(tShip,'NpcNuke',2,charge);",
                        "            }",
                        "        }",
                        "    }",
                        "    lastShipId=GalaxyShipId();    //Обновляем Id последнего рожденного корабля",
                        "}",
                        "//Таймер до обновления числа доступных ядерок для ВБ",
                        "if(findsubstr(GameDateTxtByTurn(CurTurn()),CT(\"Script.Mod_ShuNukes.17\"))==0 || findsubstr(GameDateTxtByTurn(CurTurn()),CT(\"Script.Mod_ShuNukes.16\"))==0) {",
                        "\tif(CurTurn()>=nukesCntUpTimer && upgrade) ammo=6;",
                        "\telse if(CurTurn()+2500>=nukesCntUpTimer) ammo=4;",
                        "\telse if(upgrade) ammo=3;",
                        "\telse ammo=2;",
                        "}",
                        "//Для доминиона",
                        "if(CurTurn()>=nukeUpdCB) {",
                        "\tif(upgrade) ammo2=3;",
                        "\telse ammo2=2;",
                        "\tnukeUpdCB=CurTurn()+Rnd(175,185);",
                        "}"
                    ],
                    "#": 36,
                    "Type": "Top",
                    "Parent": -1,
                    "Pos.x": 120,
                    "Pos.y": 710
                },
                {
                    "Name": "",
                    "Code.Type": "DialogBegin",
                    "Code": [
                        "if (GetShipRuins(Player())) {",
                        "  if (!PlayerBridge()) {",
                        "    tdwd = GetShipRuins(Player());",
                        "    if (ShipType(tdwd) == 'MC' || ShipType(tdwd) == 'RC' || ShipType(tdwd) == 'SB' || ShipType(tdwd) == 'BK' || ShipType(tdwd) == 'PB') {",
                        "      AddDialogInject('BuyNukeForRuins', '', CT(\"Script.Mod_ShuNukes.29\"), 1);",
                        "    } else if (ShipType(tdwd) == 'TC') {",
                        "      AddDialogInject('BuyNukeForRuins', '', CT(\"Script.Mod_ShuNukes.29\"), 1);",
                        "      if (GalaxyTechLevel() >= 5) {",
                        "        if (!playerGotECM) {",
                        "          AddDialogInject('BuyECM', CT(\"Script.Mod_ShuNukes.71\"), CT(\"Script.Mod_ShuNukes.70\"), 1);",
                        "        }",
                        "      }",
                        "    } else if (ShipType(tdwd) == 'WB') {",
                        "      if (!ShipOnSidePirateClan(Player())) {",
                        "        if (!playerGotAbsorber) {",
                        "          if (ShipRank(Player()) >= 2) {",
                        "            AddDialogInject('BuyAbsorber', CT(\"Script.Mod_ShuNukes.24\"), CT(\"Script.Mod_ShuNukes.23\"), 1);",
                        "          }",
                        "        }",
                        "        if (playerGotNuke) {",
                        "          if (upgrade) total = 6;",
                        "          else total = 4;",
                        "          AddDialogInject('NukeWB', '', CT(\"Script.Mod_ShuNukes.28\"), 1);",
                        "          if (UselessItemData(PlayerNuke, 1) == total) AddDialogBlock(CT(\"Script.Mod_ShuNukes.28\"), 1);",
                        "          else if (!ItemIn(PlayerNuke, Player())) AddDialogBlock(CT(\"Script.Mod_ShuNukes.28\"), 1);",
                        "          else AddDialogBlock(CT(\"Script.Mod_ShuNukes.28\"), 0);",
                        "          if (FindItemInShip(Player(), PlayerNuke) > 0) {",
                        "            if (!upgrade && ShipRank(Player()) >= 5 && CurTurn() > nukeLauncherWBUpTimer) AddDialogInject('UpgradeWB', CT(\"Script.Mod_ShuNukes.27\"), CT(\"Script.Mod_ShuNukes.20\"), 1);",
                        "          }",
                        "        }",
                        "        if (!playerGotNuke) {",
                        "          if (ShipRank(Player()) >= 3) {",
                        "            AddDialogInject('BuyNukeWB', CT(\"Script.Mod_ShuNukes.75\"), CT(\"Script.Mod_ShuNukes.25\"), 1);",
                        "          }",
                        "        }",
                        "      }",
                        "    } else if (ShipType(tdwd) == 'CB') {",
                        "      if (ShipOnSidePirateClan(Player())) {",
                        "        if (!playerGotAbsorber) {",
                        "          if (GetShipPirateRank(Player()) >= 2) {",
                        "            AddDialogInject('BuyAbsorber', CT(\"Script.Mod_ShuNukes.24\"), CT(\"Script.Mod_ShuNukes.23\"), 1);",
                        "          }",
                        "        }",
                        "        if (playerGotNuke) {",
                        "          if (upgrade) total = 6;",
                        "          else total = 4;",
                        "          AddDialogInject('NukeCB', '', CT(\"Script.Mod_ShuNukes.22\"), 1);",
                        "          if (UselessItemData(PlayerNuke, 1) == total) AddDialogBlock(CT(\"Script.Mod_ShuNukes.22\"), 1);",
                        "          else if (!ItemIn(PlayerNuke, Player())) AddDialogBlock(CT(\"Script.Mod_ShuNukes.22\"), 1);",
                        "          else AddDialogBlock(CT(\"Script.Mod_ShuNukes.22\"), 0);",
                        "          if (FindItemInShip(Player(), PlayerNuke) > 0) {",
                        "            if (!upgrade && GetShipPirateRank(Player()) >= 5 && CurTurn() > nukeLauncherCBUpTimer) AddDialogInject('UpgradeCB', CT(\"Script.Mod_ShuNukes.21\"), CT(\"Script.Mod_ShuNukes.20\"), 1);",
                        "          }",
                        "        }",
                        "        if (!playerGotNuke) {",
                        "          if (GetShipPirateRank(Player()) >= 3) {",
                        "            AddDialogInject('BuyNukeCB', CT(\"Script.Mod_ShuNukes.19\"), CT(\"Script.Mod_ShuNukes.18\"), 1);",
                        "          }",
                        "        }",
                        "      }",
                        "    }",
                        "  }",
                        "}",
                        "if (GetTalkShip()) {",
                        "  if (ShipInNormalSpace(Player())) {",
                        "    if (ShipType(GetTalkShip()) == 'ShuNukes_SelectTargetNuke') AddDialogOverride('SelectTarget', 20, 0);",
                        "    else if (ShipType(GetTalkShip()) == 'ShuNukes_SelectTargetNova') AddDialogOverride('SelectTarget', 20, 1);",
                        "  }",
                        "}"
                    ],
