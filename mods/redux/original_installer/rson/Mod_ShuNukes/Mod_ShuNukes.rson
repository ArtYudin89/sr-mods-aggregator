                        "else num=ShipCustomShipInfoData(tdwd,ShipFindCustomShipInfoByType(tdwd,'RuinsNuke'),2);",
                        "if (GalaxyTechLevel()<3) sum=175000;",
                        "if (GalaxyTechLevel()==3) sum=200000;",
                        "if (GalaxyTechLevel()==4) sum=225000;",
                        "if (GalaxyTechLevel()==5) sum=260000;",
                        "if (GalaxyTechLevel()==6) sum=295000;",
                        "if (GalaxyTechLevel()==7) sum=335000;",
                        "if (GalaxyTechLevel()==8) sum=375000;",
                        "sum=sum/2;",
                        "sum=sum+GalaxyMoney(0);",
                        "if (nuke_cnt==0) sum=sum*40/100;",
                        "else if (nuke_cnt==1) sum=sum*75/100;",
                        "if(num==0 && StarOwner(ShipStar(Player()))==2 || num==0 && ShipType(GetShipRuins(Player()))=='PB') {",
                        "  DChange(11);",
                        "  exit;",
                        "}",
                        "if(num==0 && StarOwner(ShipStar(Player()))!=2 && ShipType(GetShipRuins(Player()))!='PB') {",
                        "  DChange(6);",
                        "  exit;",
                        "}",
                        "if(num==1) {",
                        "  DChange(7);",
                        "  exit;",
                        "}",
                        "if(num==2) {",
                        "  DChange(8);",
                        "  exit;",
                        "}",
                        "if(num==3) {",
                        "  DChange(9);",
                        "  exit;",
                        "}"
