            ],
            "DialogMessages": [
                {
                    "Name": "",
                    "Pos.x": 0,
                    "Pos.y": 445,
                    "Type": "TDialogMsg",
                    "Parent": -1,
                    "#": 19,
                    "Msg": "Ас-саляму Алейкум, ополченец! В этот прекрасный день мы решили собрать всей галактикой на межгалактическую мечеть, чтобы распространять нашу культуру в глубины космоса! Взносы фиксированы - 95000 чеченорублей.",
                    "DMsg.Num": "0",
                    "_orig_dtext": "DText(CT(\"Script.kavscr7.30\"))"
                },
                {
                    "Name": "",
                    "Pos.x": 150,
                    "Pos.y": 445,
                    "Type": "TDialogMsg",
                    "Parent": -1,
                    "#": 20,
                    "Msg": "Большое вам спасибо, храни вас Аллах!",
                    "DMsg.Num": "1",
                    "_orig_dtext": "DText(CT(\"Script.kavscr7.31\"))"
                },
                {
                    "Name": "",
                    "Pos.x": 300,
                    "Pos.y": 445,
                    "Type": "TDialogMsg",
                    "Parent": -1,
                    "#": 21,
                    "Msg": "Ты ставишь под сомнение НАШУ ВЕРУ?! Ты.. ты.. сейчас я покажу тебе мощь и братство нашей религии, я объявляю тебе Джихад! Ты умрёшь, неверный, и очень скоро.",
                    "DMsg.Num": "2",
                    "_orig_dtext": "DText(CT(\"Script.kavscr7.32\"))"
                }
            ],
