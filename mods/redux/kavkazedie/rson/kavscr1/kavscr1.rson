                        "                OrderLock(GroupToShip(Knash),1);",
                        "                SFT('Кнаш летит за тобой - kavscr1');",
                        "            }",
                        "        }",
                        "    }",
                        "}",
                        "",
                        "if(!GroupCount(Knash)) {",
                        "    if(GroupCount(Chechentsi)) {",
                        "        //SFT('Кнаш помер, вывод вояк из скрипта - kavscr1');",
                        "        //SFT('Вывод игрока из скрипта - kavscr1');",
                        "        AllShipOut();",
                        "        iksyu=421;",
                        "        //SFT('kavscr1 - завершён, концовка 1');",
                        "    }",
