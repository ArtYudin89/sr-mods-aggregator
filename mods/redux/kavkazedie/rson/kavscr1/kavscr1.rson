                        "        //SFT('Вывод игрока из скрипта2 - kavscr1');",
                        "        AllShipOut();",
                        "        iksyu=124;",
                        "        //SFT('kavscr1 - завершён, концовка 2');",
                        "    }",
                        "}",
                        "",
                        "if(!iksyu) {",
                        "    if(dd>1) {",
                        "        NoTalkToShip(GroupToShip(Knash),1);",
                        "    }",
                        "    if(dd==3) {",
                        "        for(i=0;(GroupCount(Chechentsi)-1)>i;i=i+1) {",
