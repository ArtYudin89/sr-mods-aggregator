                        "        }",
                        "    }",
                        "    if(!y) {",
                        "        if(ShipInPlanet(GroupToShip(Knash),Dar)) {",
                        "            GiveExtremeEq(GroupToShip(Knash),'Weapon',2,228);",
                        "            GiveCoolEq(GroupToShip(Knash),'Weapon',2,202);",
                        "            GiveCoolEq(GroupToShip(Knash),'Weapon',2,295);",
                        "            GiveCoolEq(GroupToShip(Knash),'Weapon',2,207);",
