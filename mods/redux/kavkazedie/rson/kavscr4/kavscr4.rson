            "DialogMessages": [
                {
                    "Name": "",
                    "Pos.x": 0,
                    "Pos.y": 445,
                    "Type": "TDialogMsg",
                    "Parent": -1,
                    "#": 15,
                    "Msg": "Ас-саляму Алейкум, братишка! Слушай, у меня тут к тебе деловой вопрос. Понимаешь ли, я придумал бизнес проект ежжи, как говорят урусы, стартап, и всё бы ничего, но есть небольшая проблемка - финансовая. Так что с тебя 950 chechenoroubley (cr), без обид.",
                    "DMsg.Num": "0",
                    "_orig_dtext": "DText(CT(\"Script.kavscr4.12\"))"
                },
                {
                    "Name": "",
                    "Pos.x": 150,
                    "Pos.y": 445,
                    "Type": "TDialogMsg",
                    "Parent": -1,
                    "#": 16,
                    "Msg": "Да-да, обязательно брат! Спасибо за помощь, век не забуду!",
                    "DMsg.Num": "1",
                    "_orig_dtext": "DText(CT(\"Script.kavscr4.13\"))"
                },
                {
                    "Name": "",
                    "Pos.x": 300,
                    "Pos.y": 445,
                    "Type": "TDialogMsg",
                    "Parent": -1,
                    "#": 17,
                    "Msg": "Э-э-э, сам чёрт, понял?! Да и вообще, за базар сейчас ответишь, цифры урони!",
                    "DMsg.Num": "2",
                    "_orig_dtext": "DText(CT(\"Script.kavscr4.14\"))"
                }
            ],
