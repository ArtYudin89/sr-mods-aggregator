    "Visual.Objects": [
        {
            "ConstellationCount": 0,
            "DialogAnswers": [
                {
                    "Name": "",
                    "Pos.x": 0,
                    "Pos.y": 515,
                    "Type": "TDialogAnswer",
                    "Parent": -1,
                    "#": 29,
                    "Msg": "Привет тебе, брат мой, рад тебя видеть!",
                    "AMsg.Num": "0",
                    "_orig_danswer": "DAnswer(CT(\"Script.kavscr8.9\"))"
                },
                {
                    "Name": "",
                    "Pos.x": 120,
                    "Pos.y": 515,
                    "Type": "TDialogAnswer",
                    "Parent": -1,
                    "#": 30,
                    "Msg": "Ох, брат, говори же скорее, что тебя печалит, какой шайтан мучит тебя и мешает сомкнуть глаза ночами!",
                    "AMsg.Num": "1",
                    "_orig_danswer": "DAnswer(CT(\"Script.kavscr8.10\"))"
                },
                {
                    "Name": "",
                    "Pos.x": 240,
                    "Pos.y": 515,
                    "Type": "TDialogAnswer",
                    "Parent": -1,
                    "#": 31,
                    "Msg": "Ох, вацок, как я за тебя рад! Обязательно прилечу на вашу свадьбу!.. Но в чём беда-то?",
                    "AMsg.Num": "2",
                    "_orig_danswer": "DAnswer(CT(\"Script.kavscr8.11\"))"
                },
                {
                    "Name": "fastexit",
                    "Pos.x": 360,
                    "Pos.y": 515,
                    "Type": "TDialogAnswer",
                    "Parent": -1,
                    "#": 32,
                    "Msg": "Брат брата выручает! Лети за своей любимой! Я буду ждать на орбите.",
                    "AMsg.Num": "3",
                    "_orig_danswer": "DAnswer('fastexit~'+CT(\"Script.kavscr8.12\"))"
                },
                {
                    "Name": "",
                    "Pos.x": 480,
                    "Pos.y": 515,
                    "Type": "TDialogAnswer",
                    "Parent": -1,
                    "#": 33,
                    "Msg": "Прости, брат, ничем не смогу помочь",
                    "AMsg.Num": "4",
                    "_orig_danswer": "DAnswer(CT(\"Script.kavscr8.13\"))"
                },
                {
                    "Name": "fastexit",
                    "Pos.x": 600,
                    "Pos.y": 515,
                    "Type": "TDialogAnswer",
                    "Parent": -1,
                    "#": 34,
                    "Msg": "Жду, брат",
                    "AMsg.Num": "5",
                    "_orig_danswer": "DAnswer('fastexit~'+CT(\"Script.kavscr8.14\"))"
                },
                {
                    "Name": "fastexit",
                    "Pos.x": 720,
                    "Pos.y": 515,
                    "Type": "TDialogAnswer",
                    "Parent": -1,
                    "#": 35,
                    "Msg": "Спасибо, брат. Счастья вам!",
                    "AMsg.Num": "6",
                    "_orig_danswer": "DAnswer('fastexit~'+CT(\"Script.kavscr8.15\"))"
                },
                {
                    "Name": "fastexit",
                    "Pos.x": 840,
                    "Pos.y": 515,
                    "Type": "TDialogAnswer",
                    "Parent": -1,
                    "#": 36,
                    "Msg": "Конец связи",
                    "AMsg.Num": "7",
                    "_orig_danswer": "DAnswer('fastexit~'+CT(\"Script.kavscr8.16\"))"
                },
                {
                    "Name": "fastexit",
                    "Pos.x": 960,
                    "Pos.y": 515,
                    "Type": "TDialogAnswer",
                    "Parent": -1,
                    "#": 37,
                    "Msg": "Кажется, пора браться за ятаган. Мирного решения не будет.",
                    "AMsg.Num": "8",
                    "_orig_danswer": "DAnswer('fastexit~'+CT(\"Script.kavscr8.17\"))"
                }
            ],
            "DialogMessages": [
                {
                    "Name": "",
                    "Pos.x": 0,
                    "Pos.y": 445,
                    "Type": "TDialogMsg",
                    "Parent": -1,
                    "#": 21,
                    "Msg": "Вацок, здравствуй!",
                    "DMsg.Num": "0",
                    "_orig_dtext": "DText(CT(\"Script.kavscr8.1\"))"
                },
                {
                    "Name": "",
                    "Pos.x": 150,
                    "Pos.y": 445,
                    "Type": "TDialogMsg",
                    "Parent": -1,
                    "#": 22,
                    "Msg": "И я тебя, брат мой. Но мне очень нужна твоя помощь, вацок",
                    "DMsg.Num": "1",
                    "_orig_dtext": "DText(CT(\"Script.kavscr8.2\"))"
                },
                {
                    "Name": "",
                    "Pos.x": 300,
                    "Pos.y": 445,
                    "Type": "TDialogMsg",
                    "Parent": -1,
                    "#": 23,
                    "Msg": "В общем, вацок, влюбился я в одну прекрасную деву... Блеск её очей освещает мне путь тёмной ночью... Ох, как хочу обнять её сейчас, чувствуя биение любящего меня сердца...",
                    "DMsg.Num": "2",
                    "_orig_dtext": "DText(CT(\"Script.kavscr8.3\"))"
                },
                {
                    "Name": "",
                    "Pos.x": 450,
                    "Pos.y": 445,
                    "Type": "TDialogMsg",
                    "Parent": -1,
                    "#": 24,
                    "Msg": "Понимаешь, её братья и отец против нашей свадьбы. Мы договорились, что я выкраду её ночью, оставив калым, и мы улетим во владения нашего клана, которые мне удалось отстоять у наших старейшин и приумножить плодородие и богатство по праву моих земель.\r\n\r\nТеперь мне остаётся только организовать кражу и заключить брак.\r\n\r\nТолько вот мне не удастся улететь под огнём тестя и шуринов. Пожалуйста, ополченец, помоги - отвлеки их внимание, пока я буду улетать! Я щедро заплачу!",
                    "DMsg.Num": "3",
                    "_orig_dtext": "DText(CT(\"Script.kavscr8.4\"))"
                },
                {
                    "Name": "",
                    "Pos.x": 600,
                    "Pos.y": 445,
                    "Type": "TDialogMsg",
                    "Parent": -1,
                    "#": 25,
                    "Msg": "Уже лечу, брат. Жди!",
                    "DMsg.Num": "4",
                    "_orig_dtext": "DText(CT(\"Script.kavscr8.5\"))"
                },
                {
                    "Name": "",
                    "Pos.x": 750,
                    "Pos.y": 445,
                    "Type": "TDialogMsg",
                    "Parent": -1,
                    "#": 26,
                    "Msg": "Спасибо за помощь, брат! Никогда не забуду! Мы назовём нашего первенца твоим именем! Пусть тебя хранит Аллах!",
                    "DMsg.Num": "5",
                    "_orig_dtext": "DText(CT(\"Script.kavscr8.6\"))"
                },
                {
                    "Name": "",
                    "Pos.x": 900,
                    "Pos.y": 445,
                    "Type": "TDialogMsg",
                    "Parent": -1,
                    "#": 27,
                    "Msg": "Эх... А ещё ополченцем зовётся...",
                    "DMsg.Num": "6",
                    "_orig_dtext": "DText(CT(\"Script.kavscr8.7\"))"
                },
                {
                    "Name": "",
                    "Pos.x": 1050,
                    "Pos.y": 445,
                    "Type": "TDialogMsg",
                    "Parent": -1,
                    "#": 28,
                    "Msg": "Смерть тебе, шайтан, укравший нашу сестру! Смерть! Смерть! Смерть!",
                    "DMsg.Num": "7",
                    "_orig_dtext": "DText(CT(\"Script.kavscr8.8\"))"
                }
            ],
