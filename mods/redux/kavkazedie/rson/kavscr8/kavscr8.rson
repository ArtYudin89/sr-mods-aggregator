            "Items": [],
            "Operations": [
                {
                    "Name": "",
                    "Code.Type": "Global",
                    "Code": [
                        "if(GalaxyTechLevel() > 2) {",
                        "    if(kavscr8 == 1) {",
                        "        GRun();",
                        "    }",
                        "}"
                    ],
                    "#": 11,
                    "Type": "Top",
                    "Parent": -1,
                    "Pos.x": 0,
                    "Pos.y": 585
                },
                {
                    "Name": "",
                    "Code.Type": "Turn",
                    "Code": [
                        "if(!GroupCount(Pirates) && !GroupCount(shipok)) AllShipOut();",
                        "if(ShipInStar(GroupToShip(shipok),StarTo)) AllShipOut();"
                    ],
                    "#": 12,
                    "Type": "Top",
                    "Parent": -1,
                    "Pos.x": 120,
                    "Pos.y": 585
                },
                {
                    "Name": "",
                    "Code.Type": "Turn",
                    "Code": [
                        "if(ShipStar(GroupToShip(shipok))==ShipStar(Player())) {",
                        "  if(ShipInNormalSpace(Player()) && ShipInNormalSpace(GroupToShip(shipok))) {",
                        "    if(dlg2==0) {",
                        "      Dialog(DialogNew,shipok);",
                        "      //SFT('Диалог стартовал - kavscr8');",
                        "    }",
                        "  }",
                        "}",
                        "if(dlg2 == 1) {",
                        "  ChangeState(3);",
                        "  exit;",
                        "}"
                    ],
                    "#": 38,
                    "Type": "Top",
                    "Parent": -1,
                    "Pos.x": 80
                },
                {
                    "Name": "",
                    "Code.Type": "Turn",
                    "Code": [
                        "if(GetShipPlanet(CurShip)) {",
                        "  OrderTakeOff(CurShip);",
                        "  SetRelationGroup(Pirates,GroupNew,0);",
                        "  ChangeState(5);",
                        "  exit;",
                        "}"
                    ],
                    "#": 39,
                    "Type": "Top",
                    "Parent": -1,
                    "Pos.x": 160
                },
                {
                    "Name": "",
                    "Code.Type": "Turn",
                    "Code": [
                        "if(GetShipPlanet(CurShip)) {",
                        "  ",
                        "  OrderTakeOff(CurShip);",
                        "  dlg2 = 2;",
                        "  ",
                        "  //награда игроку",
                        "  int rand = Rnd(1,3);",
                        "  if(rand == 1) AddItemToStorage(GetShipPlanet(CurShip),CreateArt(t_ArtefactDroid,People));",
                        "  if(rand == 2) AddItemToStorage(GetShipPlanet(CurShip),CreateArt(t_ArtefactHull,People));",
                        "  if(rand == 3) AddItemToStorage(GetShipPlanet(CurShip),CreateArt(t_ArtefactHook,People));",
                        "  Sound('Sound.NewMsg');",
                        "  NewsAdd(CT(\"Script.kavscr8.0\"));",
                        "  ",
                        "  //Шурины вылетают по душу игрока",
                        "  int i;",
                        "  dword ship;",
                        "  for(i = 0; i < 7; i = i + 1) {",
                        "      ship = BuyPirate(GetShipPlanet(CurShip));",
                        "      ShipJoin(Pirates,ship);",
                        "  }",
                        "  ChangeState(4);",
                        "  exit;",
                        "}"
                    ],
                    "#": 40,
                    "Type": "Top",
                    "Parent": -1,
                    "Pos.x": 240
                },
                {
                    "Name": "",
                    "Code.Type": "Turn",
                    "Code": [
                        "if(ItemDurability(ShipEqInSlot(CurShip,t_Engine)) > 20) OrderForsage(CurShip);"
                    ],
                    "#": 41,
                    "Type": "Top",
                    "Parent": -1,
                    "Pos.x": 320
                },
