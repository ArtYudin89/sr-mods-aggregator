    "Visual.Objects": [
        {
            "ConstellationCount": 0,
            "DialogAnswers": [
                {
                    "Name": "",
                    "Pos.x": 0,
                    "Pos.y": 515,
                    "Type": "TDialogAnswer",
                    "Parent": -1,
                    "#": 18,
                    "Msg": "Ассаламу алейкум, собрат по борьбе с террористами! Рад тебя слышать и всегда готов выслушать тебя!",
                    "AMsg.Num": "0",
                    "_orig_danswer": "DAnswer(CT(\"Script.kavscr9.5\"))"
                },
                {
                    "Name": "",
                    "Pos.x": 120,
                    "Pos.y": 515,
                    "Type": "TDialogAnswer",
                    "Parent": -1,
                    "#": 19,
                    "Msg": "Конечно, брат, о чём может идти речь?! Я с тобой бы даже баранов полетел красть, о чём ты говоришь?",
                    "AMsg.Num": "1",
                    "_orig_danswer": "DAnswer(CT(\"Script.kavscr9.6\"))"
                },
                {
                    "Name": "",
                    "Pos.x": 240,
                    "Pos.y": 515,
                    "Type": "TDialogAnswer",
                    "Parent": -1,
                    "#": 20,
                    "Msg": "Ахмат - сила! Чечня - круто!",
                    "AMsg.Num": "2",
                    "_orig_danswer": "DAnswer(CT(\"Script.kavscr9.7\"))"
                },
                {
                    "Name": "",
                    "Pos.x": 360,
                    "Pos.y": 515,
                    "Type": "TDialogAnswer",
                    "Parent": -1,
                    "#": 21,
                    "Msg": "Ахмат-чай, лучший чай во всей Галактике!",
                    "AMsg.Num": "3",
                    "_orig_danswer": "DAnswer(CT(\"Script.kavscr9.8\"))"
                },
                {
                    "Name": "",
                    "Pos.x": 480,
                    "Pos.y": 515,
                    "Type": "TDialogAnswer",
                    "Parent": -1,
                    "#": 22,
                    "Msg": "Аллах акбар, брат, и Он направит наши персты, чтобы задушить негодяев!",
                    "AMsg.Num": "4",
                    "_orig_danswer": "DAnswer(CT(\"Script.kavscr9.9\"))"
                },
                {
                    "Name": "",
                    "Pos.x": 600,
                    "Pos.y": 515,
                    "Type": "TDialogAnswer",
                    "Parent": -1,
                    "#": 23,
                    "Msg": "Сначала подлети ко мне, шайтан!",
                    "AMsg.Num": "5",
                    "_orig_danswer": "DAnswer(CT(\"Script.kavscr9.10\"))"
                }
            ],
            "DialogMessages": [
                {
                    "Name": "",
                    "Pos.x": 0,
                    "Pos.y": 445,
                    "Type": "TDialogMsg",
                    "Parent": -1,
                    "#": 13,
                    "Msg": "Эй, вацок... *ик*",
                    "DMsg.Num": "0",
                    "_orig_dtext": "DText(CT(\"Script.kavscr9.0\"))"
                },
                {
                    "Name": "",
                    "Pos.x": 150,
                    "Pos.y": 445,
                    "Type": "TDialogMsg",
                    "Parent": -1,
                    "#": 14,
                    "Msg": "Ты ведь меня уважаешь??!.. *ик*",
                    "DMsg.Num": "1",
                    "_orig_dtext": "DText(CT(\"Script.kavscr9.1\"))"
                },
                {
                    "Name": "",
                    "Pos.x": 300,
                    "Pos.y": 445,
                    "Type": "TDialogMsg",
                    "Parent": -1,
                    "#": 15,
                    "Msg": "Так вот, брат... Вот скажи, Ахмат ведь...",
                    "DMsg.Num": "2",
                    "_orig_dtext": "DText(CT(\"Script.kavscr9.2\"))"
                },
                {
                    "Name": "",
                    "Pos.x": 450,
                    "Pos.y": 445,
                    "Type": "TDialogMsg",
                    "Parent": -1,
                    "#": 16,
                    "Msg": "Вот! Речи настоящего джигита! Таких бы ополченцев побольше - террористов бы уже давно всех победили!",
                    "DMsg.Num": "3",
                    "_orig_dtext": "DText(CT(\"Script.kavscr9.3\"))"
                },
                {
                    "Name": "",
                    "Pos.x": 600,
                    "Pos.y": 445,
                    "Type": "TDialogMsg",
                    "Parent": -1,
                    "#": 17,
                    "Msg": "Ах ты пёс шелудивый! Ну я тебя!!!",
                    "DMsg.Num": "4",
                    "_orig_dtext": "DText(CT(\"Script.kavscr9.4\"))"
                }
            ],
