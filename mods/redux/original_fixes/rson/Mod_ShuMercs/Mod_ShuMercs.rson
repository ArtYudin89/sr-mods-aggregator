                    "Pos.x": 940,
                    "Pos.y": 865
                },
                {
                    "Name": "",
                    "Code.Type": "Turn",
                    "Code": [
                        "timer_attack=CurTurn()+90;",
                        "TimeToRun=0;",
                        "enemy_for_all=0;",
                        "",
                        "for(j=0; j<SqNom; j=j+1) {",
                        "    if(Squad==1) {",
                        "        cur_ship = BuyMerc(0, 2, GroupToShip(MercCenter));",
                        "        Atlant=Atlant-1;",
                        "        ChangeRelations(1, Rnd(-1, 0), Rnd(-1, 0));",
                        "    }",
                        "    else if(Squad==2) {",
                        "        cur_ship = BuyMerc(1, 2, GroupToShip(MercCenter));",
                        "        Reds=Reds-1;",
                        "        ChangeRelations(Rnd(-1, 0), 1, -1);",
                        "    }",
                        "    else if(Squad==3) {",
                        "        cur_ship = BuyMerc(2, 2, GroupToShip(MercCenter));",
                        "        Feis=Feis-1;",
                        "        ChangeRelations(Rnd(-1, 0), -1, 1);",
                        "    }",
                        "    else if(Squad==4) {",
                        "        cur_ship = BuyMerc(3, 2, GroupToShip(MercCenter));",
                        "        Frees=Frees-1;",
                        "    }",
                        "    ShipJoin(Attack, cur_ship);",
                        "}",
                        "",
                        "ShipMoney(Player(),ShipMoney(Player())-cost);",
                        "Sound('Sound.Buy');"
                    ],
                    "#": 458,
                    "Type": "Top",
                    "Parent": -1,
                    "Pos.x": 1060,
                    "Pos.y": 865
                },
                {
                    "Name": "",
                    "Code.Type": "Turn",
                    "Code": [
                        "rospusk_raida=CurTurn()+1;",
                        "timer_raid=CurTurn()+90;",
                        "stroka='';",
                        "",
                        "for(j=0; j<SqNom; j=j+1) {",
                        "    if(Squad==1) {",
                        "        cur_ship = BuyMerc(0, 3, GroupToShip(MercCenter));",
                        "        Atlant=Atlant-1;",
                        "        ChangeRelations(1, Rnd(-1, 0), Rnd(-1, 0));",
                        "    }",
                        "    else if(Squad==2) {",
                        "        cur_ship = BuyMerc(1, 3, GroupToShip(MercCenter));",
                        "        Reds=Reds-1;",
                        "        ChangeRelations(Rnd(-1, 0), 1, -1);",
                        "    }",
                        "    else if(Squad==3) {",
                        "        cur_ship = BuyMerc(2, 3, GroupToShip(MercCenter));",
                        "        Feis=Feis-1;",
                        "        ChangeRelations(Rnd(-1, 0), -1, 1);",
                        "    }",
                        "    else if(Squad==4) {",
                        "        cur_ship = BuyMerc(3, 3, GroupToShip(MercCenter));",
                        "        Frees=Frees-1;",
                        "    }",
                        "    ShipJoin(Raid, cur_ship);",
                        "}",
                        "",
                        "ShipMoney(Player(),ShipMoney(Player())-cost);",
                        "Sound('Sound.Buy');"
                    ],
                    "#": 459,
                    "Type": "Top",
                    "Parent": -1,
                    "Pos.x": 1180,
                    "Pos.y": 865
                },
                {
                    "Name": "",
                    "Code.Type": "Turn",
                    "Code": [
                        "special_order = 0;",
                        "tstr1 = TextBox(CT(\"Script.Mod_ShuMercs.191\"));",
                        "tstr1 = lowercase(tstr1);",
                        "if (tstr1 == '') dState = 6;",
                        "else {",
                        "  for (i = 0; i < GalaxyStars(); i = i + 1) {",
                        "    star = GalaxyStar(i);",
                        "    for (j = 0; j < StarShips(star); j = j + 1) {",
                        "      target_ship = StarShips(star, j);",
                        "      if (CT('AssistantExclusions.' + ShipType(target_ship)) == 'NoSearch') continue;",
                        "      if (findsubstr(lowercase(Name(target_ship)), tstr1) >= 0) {",
                        "        if (ShipStar(ship) != ShipStar(target_ship)) { //Наемник не знает о доминаторских/кастомных кораблях (кроме боссов) за пределами своей системы",
                        "          if (ShipCustomFaction(target_ship) != '') continue;",
                        "          else if (ShipOwner(target_ship) == None) continue;",
                        "          else if (ShipOwner(target_ship) == Kling && ShipSubType(target_ship)) continue;",
                        "        }",
                        "        if (StarToCon(ShipStar(target_ship)) == StarToCon(PlanetToStar(PlanetPirateClan()))) continue; //Пропуск целей в скрытом секторе",
                        "        ArrayAdd(tempArray, target_ship);",
                        "      }",
                        "    }",
                        "  }",
                        "}",
                        "if(ArrayDim(tempArray) > 2) {",
                        "  DChange(61);",
                        "  exit;",
                        "}",
                        "if(ArrayDim(tempArray) == 2) {",
                        "  target_ship = tempArray[1];",
                        "  ArrayClear(tempArray);",
                        "  if (ShipStrengthInAverageRanger(target_ship) >= ShipStrengthInAverageRanger(ship) * 1.50) {",
                        "    dState = 1;",
                        "  } else if (ShipStrengthInAverageRanger(target_ship) >= ShipStrengthInAverageRanger(ship) * 1.35) {",
                        "    dState = 2;",
                        "    coef = 200;",
                        "  } else if (ShipStrengthInAverageRanger(target_ship) >= ShipStrengthInAverageRanger(ship) * 1.20) {",
                        "    dState = 3;",
                        "    coef = 150;",
                        "  } else if (ShipStrengthInAverageRanger(target_ship) >= ShipStrengthInAverageRanger(ship) * 0.85) {",
                        "    dState = 4;",
                        "    coef = 110;",
                        "  } else {",
                        "    dState = 5;",
                        "    coef = 75;",
                        "  }",
                        "  ",
                        "  if (NoTargetToShip(target_ship) == 1) {",
                        "    dState = 7;",
                        "  }",
                        "  ",
                        "  if (ShipType(target_ship) == 'AtlantLeader' || ShipType(target_ship) == 'RedLeader' || ShipType(target_ship) == 'FeiLeader') {",
                        "    dState = 7;",
                        "  }",
                        "  if (ShipType(target_ship) == 'Tranclucator') {",
                        "    dState = 7;",
                        "  }",
                        "  if (ShipType(target_ship) == 'Merc' || ShipType(target_ship) == 'Freelancer') {",
                        "    if (!GroupCount(MercCenter)) dState = dState;",
                        "    else if (ShipStar(target_ship) != ShipStar(GroupToShip(MercCenter))) dState = dState;",
                        "    else dState = 8;",
                        "  }",
                        "  if (target_ship == ship ||",
                        "    target_ship == Terron() ||",
                        "    target_ship == Keller() ||",
                        "    target_ship == Blazer() ||",
                        "    target_ship == Player() ||",
                        "    ShipOwner(target_ship) == Kling ||",
                        "    ObjectType(target_ship) == 4",
                        "  ) {",
                        "    dState = 7;",
                        "  }",
                        "  if (target_ship == GroupToShip(MercCenter)) {",
                        "    dState = 7;",
                        "  }",
                        "  if (ShipIsPartner(target_ship) == ship || ShipIsPartner(ship) == target_ship) {",
                        "    dState = 9;",
                        "  }",
                        "  ",
                        "  if (ShipType(ship) == 'Merc' && ShipType(target_ship) == 'Merc') {",
                        "    if (ShipPilotRace(ship) == ShipPilotRace(target_ship)) dState = 9;",
                        "    else if (",
                        "      ShipPilotRace(ship) > Maloc && ShipPilotRace(ship) < Fei &&",
                        "      ShipPilotRace(target_ship) > Maloc && ShipPilotRace(ship) < Fei",
                        "    ) dState = 9;",
                        "  }",
                        "  ",
                        "  if (ShipStar(target_ship) == GalaxyStar(71) || ShipStar(target_ship) == PlanetToStar(PlanetPirateClan())) {",
                        "    dState = 6;",
                        "  }",
                        "  cost = GalaxyMoney(3) * coef / 100;",
                        "  ",
                        "  if (merc_type == 1) {",
                        "    cost = cost * coef2 / 100;",
                        "    if (ShipPilotRace(ship) == Maloc) rel = red_rel / 2;",
                        "    else if (ShipPilotRace(ship) == Fei) rel = fei_rel / 2;",
                        "    else rel = atlant_rel / 2;",
                        "  }",
                        "  coef = 100 - rel;",
                        "  cost = cost * coef / 100;",
                        "  if(dState==8) {",
                        "    DChange(56);",
                        "    exit;",
                        "  }",
                        "  if(dState==9) {",
                        "    DChange(57);",
                        "    exit;",
                        "  }",
                        "  if(dState==1) {",
                        "    DChange(13);",
                        "    exit;",
                        "  }",
                        "  if(dState==2 && merc_type==1) {",
                        "    DChange(14);",
                        "    exit;",
                        "  }",
                        "  if(dState==3 && merc_type==1) {",
                        "    DChange(15);",
                        "    exit;",
                        "  }",
                        "  if(dState==4 && merc_type==1) {",
                        "    DChange(16);",
                        "    exit;",
                        "  }",
                        "  if(dState==5 && merc_type==1) {",
                        "    DChange(17);",
                        "    exit;",
                        "  }",
                        "  if(dState==2 && merc_type==2) {",
                        "    DChange(20);",
                        "    exit;",
                        "  }",
                        "  if(dState==3 && merc_type==2) {",
                        "    DChange(21);",
                        "    exit;",
                        "  }",
                        "  if(dState==4 && merc_type==2) {",
                        "    DChange(22);",
                        "    exit;",
                        "  }",
                        "  if(dState==5 && merc_type==2) {",
                        "    DChange(23);",
                        "    exit;",
                        "  }",
                        "  if(dState == 6) {",
                        "    DChange(18);",
                        "    exit;",
                        "  }",
                        "  if(dState == 7) {",
                        "    DChange(19);",
                        "    exit;",
                        "  }",
                        "}",
                        "if(ArrayDim(tempArray) <= 1) {",
                        "  dState = 6;",
                        "  ArrayClear(tempArray);",
                        "  DChange(18);",
                        "  exit;",
                        "}"
                    ],
                    "#": 460,
                    "Type": "Top",
                    "Parent": -1,
                    "Pos.x": 1420,
                    "Pos.y": 865
                },
                {
                    "Name": "",
                    "Code.Type": "Turn",
                    "Code": [
                        "free_timer = CurTurn() + 120;",
                        "free_name = Name(ship);",
                        "target_name = Name(target_ship);",
                        "target_id = Id(target_ship);",
                        "free_id = Id(ship);",
                        "if(merc_type == 2) ChangeRelations(-2, -2, -2);",
                        "else if(merc_type == 1) {",
                        "    if(ShipPilotRace(ship) == Maloc) ChangeRelations(Rnd(-1, 0), 1, -1);",
                        "    else if(ShipPilotRace(ship) == Fei) ChangeRelations(Rnd(-1, 0), -1, 1);",
                        "    else ChangeRelations(1, Rnd(-1, 0), Rnd(-1, 0));",
                        "}",
                        "if(ShipIsPartner(ship)) ShipSetPartner(ship, ShipIsPartner(ship), 0);",
                        "ShipJoin(ContractGroup, ship);",
                        "ShipMoney(Player(), ShipMoney(Player()) - cost);",
                        "Sound('Sound.Buy');"
                    ],
                    "#": 461,
                    "Type": "Top",
                    "Parent": -1,
                    "Pos.x": 1540,
                    "Pos.y": 865
                },
                {
                    "Name": "",
                    "Code.Type": "Turn",
                    "Code": [
                        "item = GetItemFromStorage(i);",
