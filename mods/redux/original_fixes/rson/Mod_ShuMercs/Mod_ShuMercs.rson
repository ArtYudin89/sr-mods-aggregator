                        "if(ShipInNormalSpace(CurShip)) ShipDestroy(CurShip);"
                    ],
                    "#": 354,
                    "Type": "Top",
                    "Parent": -1,
                    "Pos.x": 1920
                },
                {
                    "Name": "",
                    "Code.Type": "Turn",
                    "Code": [
                        "if(!GetData(0, CurShip)) {",
                        "    SetData(Id(Player()), 0, CurShip); //Id преследуемого корабля",
                        "    SetData(CurTurn() + 90, 1, CurShip); //Сколько преследуем",
                        "    SetData(2, 2, CurShip); //Тип преследования (1 - игрок заказал кого-то, 2 - кто-то заказал игрока, 3 - имитация задания).",
                        "}",
                        "target_ship = IdToShip(GetData(0, CurShip));",
                        "if (target_ship) { //Есть, кого преследовать",
                        "  if (CurTurn() >= GetData(1, CurShip)) {",
                        "    if (GetData(2, CurShip) == 1) { //Контракт от игрока",
                        "      CustomEther('ContractCancel', 5, '', Format(CT(\"Script.Mod_ShuMercs.108\"),\"<0>\",free_name,\"<1>\",target_name));",
                        "      free_timer = 0;",
                        "      free_id = 0;",
                        "      target_id = 0;",
                        "    }",
                        "    TruceBetweenShips(CurShip, target_ship);",
                        "    SetData(0, 0, CurShip);",
                        "    SetData(0, 1, CurShip);",
                        "    SetData(0, 2, CurShip);",
                        "    JoinDefaultMercGroup(CurShip);",
                        "  } else if (ShipInNormalSpace(CurShip)) {",
                        "    if (ShipStar(CurShip) == ShipStar(target_ship)) {",
                        "      if (ShipInNormalSpace(target_ship)) {",
                        "        ShipSetBad(CurShip, target_ship);",
                        "        OrderFollowShip(CurShip, target_ship, 1, 10);",
                        "        ShipFreeFlight(CurShip);",
                        "      }",
                        "    } else {",
                        "      if (StarOwner(ShipStar(target_ship)) != 1 || StarCustomFaction(ShipStar(target_ship)) != '') {",
                        "        if (ShipInHyperSpace(target_ship)) {",
                        "          if (ShipOrder(target_ship) == 3) {",
                        "            if (ShipOrderObj(target_ship) != ShipStar(CurShip)) OrderJump(CurShip, ShipOrderObj(target_ship));",
                        "          }",
                        "        } else if (ShipInNormalSpace(target_ship) || GetShipPlanet(target_ship) || GetShipRuins(target_ship)) {",
                        "          OrderJump(CurShip, ShipStar(target_ship));",
                        "        }",
                        "      }",
                        "    }",
                        "  }",
                        "} else { //Цель уничтожена",
                        "  if (GetData(2, CurShip) == 1) { //Контракт от игрока",
                        "    if (GroupCount(MercCenter)) CustomEther('ContractOk', 4, '', Format(CT(\"Script.Mod_ShuMercs.109\"),\"<0>\",free_name,\"<1>\",target_name));",
                        "    free_timer = 0;",
                        "    free_id = 0;",
                        "    target_id = 0;",
                        "  }",
                        "  SetData(0, 0, CurShip);",
                        "  SetData(0, 1, CurShip);",
                        "  SetData(0, 2, CurShip);",
                        "  JoinDefaultMercGroup(CurShip);",
                        "}"
                    ],
