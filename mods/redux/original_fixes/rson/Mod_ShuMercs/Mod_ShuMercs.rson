            "Items": [],
            "Operations": [
                {
                    "Name": "",
                    "Code.Type": "Global",
                    "Code": [
                        "GRun();"
                    ],
                    "#": 135,
                    "Type": "Top",
                    "Parent": -1,
                    "Pos.x": 0,
                    "Pos.y": 1035
                },
                {
                    "Name": "",
                    "Code.Type": "Init",
                    "Code": [
                        "//Запоминаем текущий ГТУ в отдельную переменную",
                        "GTL = GalaxyTechLevel();",
                        "",
                        "function GiveExtremeEq(dword ship, int eq_type, int race, int size) {",
                        "  dword techlvl, rand;",
                        "  if (eq_type >= t_Weapon1) {",
                        "    if (GTL <= 3) {",
                        "      rand = Rnd(1, 2);",
                        "      if (rand == 1) eq_type = t_Weapon3;",
                        "      else eq_type = t_Weapon6;",
                        "      if (eq_type == t_Weapon3) techlvl = Rnd(3, 4);",
                        "      else techlvl = Rnd(2, 3);",
                        "    }",
                        "    else if (GTL == 4) {",
                        "      rand = Rnd(1, 100);",
                        "      if (rand <= 35) eq_type = t_Weapon6;",
                        "      else if (rand <= 75) eq_type = t_Weapon7;",
                        "      else eq_type = t_Weapon3;",
                        "      if (eq_type == t_Weapon3) techlvl = Rnd(5, 6);",
                        "      else if (eq_type == t_Weapon6) techlvl = Rnd(4, 5);",
                        "      else techlvl = Rnd(3, 4);",
                        "    }",
                        "    else if (GTL == 5) {",
                        "      rand = Rnd(1, 100);",
                        "      if (rand <= 30) eq_type = t_Weapon7;",
                        "      else if (rand <= 70) eq_type = t_Weapon8;",
                        "      else eq_type = t_Weapon9;",
                        "      if (eq_type == t_Weapon7) techlvl = Rnd(4, 6);",
                        "      else if (eq_type == t_Weapon8) techlvl = Rnd(3, 5);",
                        "      else if (eq_type == t_Weapon9) techlvl = Rnd(3, 4);",
                        "    }",
                        "    else if (GTL == 6) {",
                        "      rand = Rnd(1, 100);",
                        "      if (rand <= 20) eq_type = t_Weapon8;",
                        "      else if (rand <= 47) eq_type = t_Weapon9;",
                        "      else if (rand <= 73) eq_type = t_Weapon10;",
                        "      else eq_type = t_Weapon11;",
                        "      if (eq_type == t_Weapon8) techlvl = Rnd(6, 7);",
                        "      else if (eq_type == t_Weapon9) techlvl = Rnd(4, 6);",
                        "      else techlvl = Rnd(3, 5);",
                        "    }",
                        "    else if (GTL == 7) {",
                        "      rand = Rnd(1, 100);",
                        "      if (rand <= 30) eq_type = t_Weapon10;",
                        "      else if (rand <= 65) eq_type = t_Weapon11;",
                        "      else eq_type = t_Weapon12;",
                        "      if (eq_type == t_Weapon12) techlvl = Rnd(3, 5);",
                        "      else techlvl = Rnd(5, 7);",
                        "    }",
                        "    else {",
                        "      if (rand <= 45) eq_type = t_Weapon12;",
                        "      else if (rand <= 75) eq_type = t_Weapon11;",
                        "      else eq_type = t_Weapon10;",
                        "      if (eq_type == t_Weapon12) techlvl = Rnd(6, 8);",
                        "      else techlvl = Rnd(7, 8);",
                        "    }",
                        "    if (eq_type == t_Weapon2) size = Rnd(20, 40);",
                        "    if (eq_type == t_Weapon3) size = Rnd(25, 50);",
                        "    if (eq_type == t_Weapon4) size = Rnd(10, 30);",
                        "    if (eq_type == t_Weapon6) size = Rnd(20, 40);",
                        "    if (eq_type == t_Weapon7) size = Rnd(30, 60);",
                        "    if (eq_type == t_Weapon8) size = Rnd(15, 30);",
                        "    if (eq_type == t_Weapon9) size = Rnd(35, 70);",
                        "    if (eq_type == t_Weapon10) size = Rnd(40, 80);",
                        "    if (eq_type == t_Weapon11) size = Rnd(45, 90);",
                        "    if (eq_type == t_Weapon12) size = Rnd(50, 100);",
                        "    if (eq_type == t_Weapon16) size = Rnd(30, 60);",
                        "    if (eq_type == t_Weapon17) size = Rnd(25, 50);",
                        "    if (eq_type == t_Weapon18) size = Rnd(15, 40);",
                        "  } else {",
                        "    rand = Rnd(1, 100);",
                        "    if (GTL <= 3) {",
                        "      if (rand <= 45) techlvl = 4;",
                        "      else techlvl = 3;",
                        "    }",
                        "    else if (GTL == 4) {",
                        "      if (rand <= 47) techlvl = 5;",
                        "      else techlvl = 4;",
                        "    }",
                        "    else if (GTL == 5) {",
                        "      if (rand <= 50) techlvl = 6;",
                        "      else techlvl = 5;",
                        "    }",
                        "    else if (GTL == 6) {",
                        "      if (rand <= 53) techlvl = 7;",
                        "      else techlvl = 6;",
                        "    }",
                        "    else if (GTL == 7) {",
                        "      if (rand <= 55) techlvl = 8;",
                        "      else techlvl = 7;",
                        "    }",
                        "    else {",
                        "      if (rand <= 85) techlvl = 8;",
                        "      else techlvl = 7;",
                        "    }",
                        "  }",
                        "  dword item = CreateEquipment(eq_type, size, techlvl, race);",
                        "  AddItemToShip(ship, item);",
                        "  result = item;",
                        "}",
                        "function GiveCoolEq(dword ship, int eq_type, int race, int size) {",
                        "  dword techlvl, rand;",
                        "  if (eq_type >= t_Weapon1) {",
                        "    if (GTL <= 3) {",
                        "      rand = Rnd(1, 3);",
                        "      if (rand == 1) eq_type = t_Weapon3;",
                        "      else eq_type = t_Weapon2;",
                        "      if (race == PirateClan && !Rnd(0, 1)) eq_type = t_Weapon17;",
                        "      techlvl = Rnd(2, 3);",
                        "    }",
                        "    else if (GTL == 4) {",
                        "      rand = Rnd(1, 100);",
                        "      if (rand <= 40) eq_type = t_Weapon6;",
                        "      else if (rand <= 70) eq_type = t_Weapon4;",
                        "      else eq_type = t_Weapon3;",
                        "      if (race == PirateClan && !Rnd(0, 3)) eq_type = t_Weapon17;",
                        "      if (eq_type == t_Weapon6) techlvl = Rnd(2, 3);",
                        "      if (eq_type == t_Weapon4) techlvl = Rnd(3, 4);",
                        "      if (eq_type == t_Weapon3 || eq_type == t_Weapon17) techlvl = 4;",
                        "    }",
                        "    else if (GTL == 5) {",
                        "      rand = Rnd(1, 100);",
                        "      if (rand <= 50) eq_type = t_Weapon7;",
                        "      if (rand <= 80) eq_type = t_Weapon6;",
                        "      else eq_type = t_Weapon4;",
                        "      if (race == PirateClan && !Rnd(0, 2)) eq_type = t_Weapon18;",
                        "      if (eq_type == t_Weapon7 || eq_type == t_Weapon18) techlvl = Rnd(2, 4);",
                        "      if (eq_type == t_Weapon6) techlvl = Rnd(4, 5);",
                        "      if (eq_type == t_Weapon4) techlvl = Rnd(4, 5);",
                        "    }",
                        "    else if (GTL == 6) {",
                        "      rand = Rnd(1, 100);",
                        "      if (rand <= 45) eq_type = t_Weapon9;",
                        "      else if (rand <= 85) eq_type = t_Weapon8;",
                        "      else eq_type = t_Weapon7;",
                        "      if (race == PirateClan && !Rnd(0, 4)) eq_type = t_Weapon18;",
                        "      if (eq_type == t_Weapon9) techlvl = Rnd(2, 4);",
                        "      else if (eq_type == t_Weapon8) techlvl = Rnd(3, 5);",
                        "      else if (eq_type == t_Weapon18 || eq_type == t_Weapon7) techlvl = Rnd(5, 6);",
                        "    }",
                        "    else if (GTL == 7) {",
                        "      rand = Rnd(1, 100);",
                        "      if (rand <= 35) eq_type = t_Weapon10;",
                        "      else if (rand <= 70) eq_type = t_Weapon11;",
                        "      else eq_type = t_Weapon9;",
                        "      if (race == PirateClan && !Rnd(0, 3)) eq_type = t_Weapon16;",
                        "      if (eq_type == t_Weapon10 || eq_type == t_Weapon11) techlvl = Rnd(3, 5);",
                        "      if (eq_type == t_Weapon9 || eq_type == t_Weapon16) techlvl = Rnd(4, 6);",
                        "    }",
                        "    else {",
                        "      if (rand <= 30) eq_type = t_Weapon12;",
                        "      else if (rand <= 55) eq_type = t_Weapon11;",
                        "      else if (rand <= 80) eq_type = t_Weapon10;",
                        "      else eq_type = t_Weapon9;",
                        "      if (race == PirateClan && !Rnd(0, 4)) eq_type = t_Weapon16;",
                        "      if (eq_type == t_Weapon12) techlvl = Rnd(2, 5);",
                        "      if (eq_type == t_Weapon11 || eq_type == t_Weapon10) techlvl = Rnd(4, 6);",
                        "      if (eq_type == t_Weapon9 || eq_type == t_Weapon16) techlvl = Rnd(5, 8);",
                        "    }",
                        "    if (eq_type == t_Weapon2) size = Rnd(20, 40);",
                        "    if (eq_type == t_Weapon3) size = Rnd(25, 50);",
                        "    if (eq_type == t_Weapon4) size = Rnd(10, 30);",
                        "    if (eq_type == t_Weapon6) size = Rnd(20, 40);",
                        "    if (eq_type == t_Weapon7) size = Rnd(30, 60);",
                        "    if (eq_type == t_Weapon8) size = Rnd(15, 30);",
                        "    if (eq_type == t_Weapon9) size = Rnd(35, 70);",
                        "    if (eq_type == t_Weapon10) size = Rnd(40, 80);",
                        "    if (eq_type == t_Weapon11) size = Rnd(45, 90);",
                        "    if (eq_type == t_Weapon12) size = Rnd(50, 100);",
                        "    if (eq_type == t_Weapon16) size = Rnd(30, 60);",
                        "    if (eq_type == t_Weapon17) size = Rnd(25, 50);",
                        "    if (eq_type == t_Weapon18) size = Rnd(15, 40);",
                        "  } else {",
                        "    rand = Rnd(1, 100);",
                        "    if (GTL <= 3) {",
                        "      if (rand <= 65) techlvl = 3;",
                        "      else techlvl = 2;",
                        "    }",
                        "    else if (GTL == 4) {",
                        "      if (rand <= 60) techlvl = 4;",
                        "      else techlvl = 3;",
                        "    }",
                        "    else if (GTL == 5) {",
                        "      if (rand <= 55) techlvl = 5;",
                        "      else techlvl = 4;",
                        "    }",
                        "    else if (GTL == 6) {",
                        "      if (rand <= 45) techlvl = 6;",
                        "      else if (rand <= 85) techlvl = 5;",
                        "      else techlvl = 4;",
                        "    }",
                        "    else if (GTL == 7) {",
                        "      if (rand <= 42) techlvl = 7;",
                        "      else if (rand <= 79) techlvl = 6;",
                        "      else techlvl = 5;",
                        "    }",
                        "    else {",
                        "      if (rand <= 38) techlvl = 8;",
                        "      else if (rand <= 75) techlvl = 7;",
                        "      else techlvl = 6;",
                        "    }",
                        "  }",
                        "  dword item = CreateEquipment(eq_type, size, techlvl, race);",
                        "  AddItemToShip(ship, item);",
                        "  result = item;",
                        "}",
                        "function GiveCommonEq(ship, eq_type, race, size) {",
                        "  dword techlvl, rand;",
                        "  if (eq_type >= t_Weapon1) {",
                        "    if (GTL <= 3) {",
                        "      rand = Rnd(1, 3);",
                        "      if (rand == 1) eq_type = t_Weapon2;",
                        "      else eq_type = t_Weapon1;",
                        "      techlvl = 1;",
                        "    }",
                        "    if (GTL == 4) {",
                        "      rand = Rnd(1, 5);",
                        "      if (rand == 1 || rand == 2 || rand == 3) eq_type = t_Weapon1;",
                        "      if (rand == 4 || rand == 5) eq_type = t_Weapon2;",
                        "      if (eq_type == t_Weapon1) techlvl = Rnd(1, 2);",
                        "      else techlvl = 1;",
                        "    }",
                        "    else if (GTL == 5) {",
                        "      rand = Rnd(1, 10);",
                        "      if (rand == 1 || rand == 2 || rand == 3 || rand == 4) eq_type = t_Weapon1;",
                        "      if (rand == 5 || rand == 6 || rand == 7) eq_type = t_Weapon2;",
                        "      if (rand == 8 || rand == 9) eq_type = t_Weapon5;",
                        "      if (rand == 10) eq_type = t_Weapon3;",
                        "      if (eq_type == t_Weapon1 && Rnd(0, 3)) techlvl = Rnd(1, 2);",
                        "      else if (eq_type == t_Weapon1) techlvl = 3;",
                        "      if (eq_type == t_Weapon2 && Rnd(0, 3)) techlvl = 1;",
                        "      else if (eq_type == t_Weapon2) techlvl = 2;",
                        "      else techlvl = 1;",
                        "    }",
                        "    else if (GTL == 6) {",
                        "      rand = Rnd(1, 9);",
                        "      if (rand == 1 || rand == 2 || rand == 3) eq_type = t_Weapon1;",
                        "      if (rand == 4 || rand == 5) eq_type = t_Weapon2;",
                        "      if (rand == 6 || rand == 7 || rand == 8) eq_type = t_Weapon5;",
                        "      if (rand == 9) eq_type = t_Weapon3;",
                        "      techlvl = Rnd(1, 3);",
                        "    }",
                        "    else if (GTL == 7) {",
                        "      rand = Rnd(1, 11);",
                        "      if (rand == 1 || rand == 2 || rand == 3) eq_type = t_Weapon1;",
                        "      if (rand == 4 || rand == 5) eq_type = t_Weapon2;",
                        "      if (rand == 6 || rand == 7 || rand == 8) eq_type = t_Weapon5;",
                        "      if (rand == 9 || rand == 10) eq_type = t_Weapon3;",
                        "      if (rand == 11) eq_type = t_Weapon6;",
                        "      if (eq_type == t_Weapon6) techlvl = 1;",
                        "      else techlvl = Rnd(1, 3);",
                        "    }",
                        "    else {",
                        "      rand = Rnd(1, 11);",
                        "      if (rand == 1 || rand == 2 || rand == 3) eq_type = t_Weapon1;",
                        "      if (rand == 4 || rand == 5) eq_type = t_Weapon2;",
                        "      if (rand == 6 || rand == 7 || rand == 8) eq_type = t_Weapon5;",
                        "      if (rand == 9 || rand == 10) eq_type = t_Weapon3;",
                        "      if (rand == 11) eq_type = t_Weapon6;",
                        "      if (eq_type == t_Weapon6 && Rnd(0, 2)) techlvl = 1;",
                        "      else if (eq_type == t_Weapon6) techlvl = 2;",
                        "      else techlvl = Rnd(1, 3);",
                        "    }",
                        "    if (eq_type == t_Weapon1) size = Rnd(15, 30);",
                        "    if (eq_type == t_Weapon2) size = Rnd(20, 40);",
                        "    if (eq_type == t_Weapon3) size = Rnd(25, 50);",
                        "    if (eq_type == t_Weapon5) size = Rnd(15, 30);",
                        "    if (eq_type == t_Weapon6) size = Rnd(20, 40);",
                        "  } else {",
                        "    if (GTL <= 3) techlvl = 1;",
                        "    else if (GTL == 4) {",
                        "      if (Rnd(0, 3)) techlvl = 1;",
                        "      else techlvl = 2;",
                        "    }",
                        "    else if (GTL == 5) {",
                        "      rand = Rnd(1, 5);",
                        "      if (rand == 1 || rand == 2) techlvl = 1;",
                        "      if (rand == 3 || rand == 4) techlvl = 2;",
                        "      if (rand == 5) techlvl = 3;",
                        "    }",
                        "    else if (GTL == 6) {",
                        "      rand = Rnd(0, 7);",
                        "      if (rand == 0 || rand == 1) techlvl = 1;",
                        "      if (rand == 2 || rand == 3 || rand == 4) techlvl = 2;",
                        "      if (rand == 5 || rand == 6) techlvl = 3;",
                        "    }",
                        "    else if (GTL == 7) {",
                        "      rand = Rnd(1, 8);",
                        "      if (rand == 1 || rand == 2) techlvl = 1;",
                        "      if (rand == 3 || rand == 4 || rand == 5) techlvl = 2;",
                        "      if (rand == 6 || rand == 7) techlvl = 3;",
                        "      if (rand == 8) techlvl = 4;",
                        "    }",
                        "    else {",
                        "      rand = Rnd(1, 4);",
                        "      if (rand == 1) techlvl = 1;",
                        "      if (rand == 2) techlvl = 2;",
                        "      if (rand == 3) techlvl = 3;",
                        "      if (rand == 4) techlvl = 4;",
                        "    }",
                        "  }",
                        "  dword item = CreateEquipment(eq_type, size, techlvl, race);",
                        "  AddItemToShip(ship, item);",
                        "  result = item;",
                        "}",
                        "",
                        "function GiveAverageEq(dword ship, int eq_type, int race, int size) {",
                        "  dword techlvl, rand;",
                        "  if (eq_type >= t_Weapon1) {",
                        "    if (GTL <= 3) {",
                        "      rand = Rnd(1, 100);",
                        "      if (rand <= 65) eq_type = t_Weapon2;",
                        "      else eq_type = t_Weapon1;",
                        "      techlvl = Rnd(1, 3);",
                        "    }",
                        "    else if (GTL == 4) {",
                        "      rand = Rnd(1, 100);",
                        "      if (rand <= 35) eq_type = t_Weapon3;",
                        "      else if (rand <= 75) eq_type = t_Weapon2;",
                        "      else eq_type = t_Weapon1;",
                        "      if (race == PirateClan && !Rnd(0, 2)) eq_type = t_Weapon17;",
                        "      if (eq_type == t_Weapon2 || eq_type == t_Weapon1) techlvl = Rnd(3, 4);",
                        "      else techlvl = Rnd(2, 4);",
                        "    }",
                        "    else if (GTL == 5) {",
                        "      rand = Rnd(1, 100);",
                        "      if (rand <= 25) eq_type = t_Weapon3;",
                        "      else if (rand <= 55) eq_type = t_Weapon2;",
                        "      else if (rand <= 75) eq_type = t_Weapon6;",
                        "      else eq_type = t_Weapon5;",
                        "      if (race == PirateClan && !Rnd(0, 3)) eq_type = t_Weapon17;",
                        "      if (eq_type == t_Weapon6) techlvl = Rnd(2, 3);",
                        "      else techlvl = Rnd(3, 5);",
                        "    }",
                        "    else if (GTL == 6) {",
                        "      rand = Rnd(1, 100);",
                        "      if (rand <= 25) eq_type = t_Weapon2;",
                        "      else if (rand <= 50) eq_type = t_Weapon3;",
                        "      else if (rand <= 75) eq_type = t_Weapon6;",
                        "      else if (rand <= 100) eq_type = t_Weapon7;",
                        "      if (race == PirateClan && !Rnd(0, 3)) eq_type = t_Weapon18;",
                        "      if (eq_type == t_Weapon2 || eq_type == t_Weapon3) techlvl = Rnd(5, 6);",
                        "      if (eq_type == t_Weapon6) techlvl = Rnd(3, 5);",
                        "      if (eq_type == t_Weapon7 || eq_type == t_Weapon18) techlvl = Rnd(2, 4);",
                        "    }",
                        "    else if (GTL == 7) {",
                        "      rand = Rnd(1, 100);",
                        "      if (rand <= 20) eq_type = t_Weapon2;",
                        "      else if (rand <= 40) eq_type = t_Weapon3;",
                        "      else if (rand <= 60) eq_type = t_Weapon6;",
                        "      else if (rand <= 80) eq_type = t_Weapon7;",
                        "      else eq_type = t_Weapon8;",
                        "      if (race == PirateClan && !Rnd(0, 4)) eq_type = t_Weapon18;",
                        "      if (eq_type == t_Weapon3 || eq_type == t_Weapon2) techlvl = Rnd(6, 7);",
                        "      if (eq_type == t_Weapon6) techlvl = Rnd(5, 7);",
                        "      if (eq_type == t_Weapon7 || eq_type == t_Weapon18) techlvl = Rnd(3, 6);",
                        "      if (eq_type == t_Weapon8) techlvl = Rnd(2, 4);",
                        "    }",
                        "    else {",
                        "      rand = Rnd(1, 100);",
                        "      if (rand <= 19) eq_type = t_Weapon2;",
                        "      else if (rand <= 34) eq_type = t_Weapon3;",
                        "      else if (rand <= 51) eq_type = t_Weapon6;",
                        "      else if (rand <= 69) eq_type = t_Weapon7;",
                        "      else if (rand <= 86) eq_type = t_Weapon8;",
                        "      else eq_type = t_Weapon9;",
                        "      if (race == PirateClan && !Rnd(0, 4)) eq_type = t_Weapon16;",
                        "      if (eq_type == t_Weapon2 || eq_type == t_Weapon3) techlvl = Rnd(7, 8);",
                        "      if (eq_type == t_Weapon6) techlvl = Rnd(6, 8);",
                        "      if (eq_type == t_Weapon7) techlvl = Rnd(5, 8);",
                        "      if (eq_type == t_Weapon8) techlvl = Rnd(4, 7);",
                        "      if (eq_type == t_Weapon9 || eq_type == t_Weapon16) techlvl = Rnd(2, 5);",
                        "    }",
                        "    if (eq_type == t_Weapon1) size = Rnd(15, 45);",
                        "    if (eq_type == t_Weapon2) size = Rnd(20, 60);",
                        "    if (eq_type == t_Weapon3) size = Rnd(25, 75);",
                        "    if (eq_type == t_Weapon4) size = Rnd(10, 40);",
                        "    if (eq_type == t_Weapon5) size = Rnd(15, 45);",
                        "    if (eq_type == t_Weapon6) size = Rnd(20, 60);",
                        "    if (eq_type == t_Weapon7) size = Rnd(30, 90);",
                        "    if (eq_type == t_Weapon8) size = Rnd(15, 45);",
                        "    if (eq_type == t_Weapon9) size = Rnd(35, 105);",
                        "    if (eq_type == t_Weapon16) size = Rnd(30, 90);",
                        "    if (eq_type == t_Weapon17) size = Rnd(25, 75);",
                        "    if (eq_type == t_Weapon18) size = Rnd(15, 45);",
                        "  } else {",
                        "    if (GTL <= 3) techlvl = Rnd(1, 2);",
                        "    else if (GTL == 4) {",
                        "      if (Rnd(0, 3)) techlvl = Rnd(1, 2);",
                        "      else techlvl = Rnd(2, 3);",
                        "    }",
                        "    else if (GTL == 5) {",
                        "      rand = Rnd(1, 5);",
                        "      if (rand == 1 || rand == 2) techlvl = Rnd(1, 2);",
                        "      if (rand == 3 || rand == 4) techlvl = Rnd(2, 3);",
                        "      if (rand == 5) techlvl = Rnd(3, 4);",
                        "    }",
                        "    else if (GTL == 6) {",
                        "      rand = Rnd(0, 7);",
                        "      if (rand == 0 || rand == 1) techlvl = 2;",
                        "      if (rand == 2 || rand == 3 || rand == 4) techlvl = Rnd(2, 3);",
                        "      if (rand == 5 || rand == 6) techlvl = Rnd(3, 4);",
                        "    }",
                        "    else if (GTL == 7) {",
                        "      rand = Rnd(1, 8);",
                        "      if (rand == 1 || rand == 2) techlvl = 2;",
                        "      if (rand == 3 || rand == 4 || rand == 5) techlvl = 3;",
                        "      if (rand == 6 || rand == 7) techlvl = Rnd(3, 4);",
                        "      if (rand == 8) techlvl = Rnd(4, 5);",
                        "    }",
                        "    else {",
                        "      rand = Rnd(1, 4);",
                        "      if (rand == 1) techlvl = 2;",
                        "      if (rand == 2) techlvl = 3;",
                        "      if (rand == 3) techlvl = 4;",
                        "      if (rand == 4) techlvl = 5;",
                        "    }",
                        "  }",
                        "  dword item = CreateEquipment(eq_type, size, techlvl, race);",
                        "  AddItemToShip(ship, item);",
                        "  result = item;",
                        "}",
                        "//Новое",
                        "//Функция создания абстрактного наемника. mType: типа наемника (0 - атлант, 1 - топор, 2 - фэй, 3+ - фрилансер).",
                        "//opType: тип операции (1 - эскорт, 2 - военная операция, 3 - рейд или обычный спавн). ruins: станция для появления.",
                        "//Возвращает указатель на корабль",
                        "function BuyMerc(int mType, int opType, dword ruins) {",
                        "    dword planet = SelectPlanet(mType);",
                        "    dword ship; int side;",
                        "    //Выбор стороны (пираты или коалы) в зависимости от того, зачем появился наемник",
                        "    if((opType!=3 && ShipOnSidePirateClan(Player())) || (opType==3 && StarOwner(ShipStar(GroupToShip(MercCenter)))==2)) side = 0;",
                        "    else side = 1;",
                        "    if(!mType) ship = BuyAtlant(planet, side);",
                        "    else if(mType == 1) ship = BuyRed(planet, side);",
                        "    else if(mType == 2) ship = BuyFei(planet, side);",
                        "    else ship = BuyFreelancer(planet, side);",
                        "    if(!side) { //Охрана/военная операция при игроке-пирате или рейд/свободное появление при ЦН в пиратской системе",
                        "        ShipJoinsClan(ship);",
                        "//        ItemOwner(ShipItems(ship, 0), shipPilotRace(ship));",
                        "        while(GetShipPirateRank(ship) < Rnd(1, 4)) RaisePirateRank(ship);",
                        "    }",
                        "    else {",
                        "        RangerExcludedFromRating(ship,1);",
                        "        ShipOwner(ship,ShipPilotRace(ship));",
                        "//        ItemOwner(ShipItems(ship, 0), ShipPilotRace(ship));",
                        "        while(ShipRank(ship) < Rnd(1, 4)) {",
                        "            ShipRankPoints(ship, 5000);",
                        "            ShipRaiseRank(ship);",
                        "        }",
                        "    }",
                        "    ItemSize(ShipItems(ship,0),(250+50*GTL)+Rnd(-25,35));",
                        "    HullHP(ship,'To100');",
                        "    Chameleon(ship);",
                        "    for(int i=3;i<5;i=i+1) ShipSkill(ship,i,Rnd(0,4));",
                        "    ShipSkill(ship,5,0);",
                        "    EqUpgrade(ship, mType);",
                        "    for(i=0;i<5;i=i+1) ShipRefit(ship);",
                        "    TransferShip(ship, ruins);",
                        "    for(i=0;i<3;i=i+1) ShipRefit(ship); //Доп. закупка акринов на станции",
                        "    ItemOwner(ShipEqInSlot(ship, t_Hull), ShipPilotRace(ship)); //Фикс вылета с корпусом, узнать причину потом",
                        "    if(!mType) ShipImproveItems(ship,Rnd(0,3));",
                        "    else if(mType == 1) ShipImproveItems(ship,Rnd(1,5));",
                        "    else if(mType == 2) ShipImproveItems(ship,Rnd(1,7));",
                        "    else ShipImproveItems(ship,Rnd(0,3));",
                        "    FreeAllHoldEquipment(ship);",
                        "    GiveFreeSpace(ship);",
                        "    result = ship;",
                        "}",
                        "//Функции появления конкретных наемников со своими различиями.",
                        "//planet: планета для найма. type: базовый тип (0 - пират, 1 - рейнджер). Возвращают указатель на корабль.",
                        "function BuyAtlant(dword planet, int type) {",
                        "    dword ship, rand;",
                        "    if(type) {",
                        "        ship=BuyRanger(planet,125);",
                        "        rand=Rnd(1, 100);",
                        "        if(rand <= 20) { //Пират",
                        "            ShipSubType(ship, 1);",
                        "            ShipStatus(ship, 0, 25); //Торговый рейтинг",
                        "            ShipStatus(ship, 1, 50); //Пиратский рейтинг",
                        "            ShipStatus(ship, 2, 25); //Военный рейтинг",
                        "        } else if(rand <= 55) { //Воин",
                        "            ShipSubType(ship, 2);",
                        "            ShipStatus(ship, 0, 15);",
                        "            ShipStatus(ship, 1, 25);",
                        "            ShipStatus(ship, 2, 60);",
                        "        } else if(rand <= 70) { //Наемник-воин",
                        "            ShipSubType(ship, 2);",
                        "            ShipStatus(ship, 0, 15);",
                        "            ShipStatus(ship, 1, 25);",
                        "            ShipStatus(ship, 2, 60);",
                        "        } else { //Наемник-пират",
                        "            ShipSubType(ship, 1);",
                        "            ShipStatus(ship, 0, 25);",
                        "            ShipStatus(ship, 1, 50);",
                        "            ShipStatus(ship, 2, 25);",
                        "        }",
                        "    }",
                        "    else ship=BuyPirate(planet,125);",
                        "    if(ShipPilotRace(ship)==Peleng) SpecialToEquipment(FindBonusByNameInCfg('ShuMercs_MercPelengHull'),ShipItems(ship,0));",
                        "    else SpecialToEquipment(FindBonusByNameInCfg('ShuMercs_MercPeopleHull'),ShipItems(ship,0));",
                        "    for(int i=ShipItems(ship)-1; i>0; i=i-1) FreeItem(GetItemFromShip(ship,i));",
                        "    for(i=0;i<3;i=i+1) ShipSkill(ship,i,Rnd(1,5));",
                        "    ShipType(ship,'Merc');",
                        "    result = ship;",
                        "}",
                        "function BuyRed(dword planet, int type) {",
                        "    dword ship, rand;",
                        "    if(type) {",
                        "        ship=BuyRanger(planet,150);",
                        "        rand=Rnd(1, 100);",
                        "        if(rand <= 15) { //Пират",
                        "            ShipSubType(ship, 1);",
                        "            ShipStatus(ship, 0, 0); //Торговый рейтинг",
                        "            ShipStatus(ship, 1, 100); //Пиратский рейтинг",
                        "            ShipStatus(ship, 2, 0); //Военный рейтинг",
                        "        } else if(rand <= 70) { //Воин",
                        "            ShipSubType(ship, 2);",
                        "            ShipStatus(ship, 0, 0);",
                        "            ShipStatus(ship, 1, 0);",
                        "            ShipStatus(ship, 2, 100);",
                        "        } else { //Наемник",
                        "            ShipSubType(ship, 2);",
                        "            ShipStatus(ship, 0, 0);",
                        "            ShipStatus(ship, 1, 50);",
                        "            ShipStatus(ship, 2, 50);",
                        "        }",
                        "    }",
                        "    else ship=BuyPirate(planet,150);",
                        "    SpecialToEquipment(FindBonusByNameInCfg('ShuMercs_MercMalocHull'),ShipItems(ship,0));",
                        "    for(int i=ShipItems(ship)-1; i>0; i=i-1) FreeItem(GetItemFromShip(ship,i));",
                        "    for(i=0;i<2;i=i+1) ShipSkill(ship,i,Rnd(2,6));",
                        "    ShipType(ship,'Merc');",
                        "    result=ship;",
                        "}",
                        "function BuyFei(dword planet, int type) {",
                        "    dword ship, rand;",
                        "    if(type) {",
                        "        ship=BuyRanger(planet,200);",
                        "        rand=Rnd(1, 100);",
                        "        if(rand <= 20) { //Пират",
                        "            ShipSubType(ship, 1);",
                        "            ShipStatus(ship, 0, 20); //Торговый рейтинг",
                        "            ShipStatus(ship, 1, 60); //Пиратский рейтинг",
                        "            ShipStatus(ship, 2, 20); //Военный рейтинг",
                        "        } else if(rand <= 75) { //Воин",
                        "            ShipSubType(ship, 2);",
                        "            ShipStatus(ship, 0, 25);",
                        "            ShipStatus(ship, 1, 0);",
                        "            ShipStatus(ship, 2, 75);",
                        "        } else { //Наемник",
                        "            ShipSubType(ship, 2);",
                        "            ShipStatus(ship, 0, 20);",
                        "            ShipStatus(ship, 1, 30);",
                        "            ShipStatus(ship, 2, 50);",
                        "        }",
                        "    }",
                        "    else ship=BuyPirate(planet,200);",
                        "    SpecialToEquipment(FindBonusByNameInCfg('ShuMercs_MercFeiHull'),ShipItems(ship,0));",
                        "    for(int i=ShipItems(ship)-1; i>0; i=i-1) FreeItem(GetItemFromShip(ship,i));",
                        "    for(i=0;i<3;i=i+1) ShipSkill(ship,i,Rnd(3,6));",
                        "    ShipType(ship,'Merc');",
                        "    result=ship;",
                        "}",
                        "function BuyFreelancer(dword planet, int type) {",
                        "    dword ship, rand;",
                        "    if(type) {",
                        "        ship=BuyRanger(planet,Rnd(125,200));",
                        "        rand=Rnd(1, 100);",
                        "        ShipSubType(ship, Rnd(1, 2)); //Рандомный характер наемника",
                        "        if(rand <= 25) {",
                        "            ShipStatus(ship, 0, 0);",
                        "            ShipStatus(ship, 1, 50);",
                        "            ShipStatus(ship, 2, 50);",
                        "        } else if (rand <= 50) {",
                        "            ShipStatus(ship, 0, 20);",
                        "            ShipStatus(ship, 1, 30);",
                        "            ShipStatus(ship, 2, 50);",
                        "        } else if (rand <= 75) {",
                        "            ShipStatus(ship, 0, 50);",
                        "            ShipStatus(ship, 1, 0);",
                        "            ShipStatus(ship, 2, 50);",
                        "        } else {",
                        "            ShipStatus(ship, 0, 25);",
                        "            ShipStatus(ship, 1, 50);",
                        "            ShipStatus(ship, 2, 25);",
                        "        }",
                        "    }",
                        "    else ship=BuyPirate(planet,Rnd(125,200));",
                        "    if(!ShipPilotRace(ship)) SpecialToEquipment(FindBonusByNameInCfg('ShuMercs_FreeMercMalocHull'),ShipItems(ship,0));",
                        "\telse if(ShipPilotRace(ship)==1) SpecialToEquipment(FindBonusByNameInCfg('ShuMercs_FreeMercPelengHull'),ShipItems(ship,0));",
                        "\telse if(ShipPilotRace(ship)==2) SpecialToEquipment(FindBonusByNameInCfg('ShuMercs_FreeMercPeopleHull'),ShipItems(ship,0));",
                        "\telse if(ShipPilotRace(ship)==3) SpecialToEquipment(FindBonusByNameInCfg('ShuMercs_FreeMercFeiHull'),ShipItems(ship,0));",
                        "\telse SpecialToEquipment(FindBonusByNameInCfg('ShuMercs_FreeMercGaalHull'),ShipItems(ship,0));",
                        "    for(int i=ShipItems(ship)-1; i>0; i=i-1) FreeItem(GetItemFromShip(ship,i));",
                        "    for(i=0;i<3;i=i+1) ShipSkill(ship,i,Rnd(1,6));",
                        "    ShipType(ship,'Freelancer');",
                        "    result=ship;",
                        "}",
                        "//Функция устранения перевеса корабля (вызывается из BuyMerc()), параметр - указатель на корабль",
                        "function GiveFreeSpace(dword ship) {",
                        "    ShipCalcParam(ship);",
                        "    int space = ShipFreeSpace(ship);",
                        "    if(space < 0) {",
                        "        dword hull = ShipItems(ship, 0);",
                        "        ItemSize(hull, ItemSize(hull) + abs(space) + Rnd(1, 3));",
                        "        HullHP(hull, ItemSize(hull));",
                        "        ShipCalcParam(ship);",
                        "    }",
                        "}",
                        "//Функция выбора планеты для спавна наемника. Пока поддерживается только Нифигац.",
                        "//Возвращает указатель на планету.",
                        "function SelectPlanet(int mType) {",
                        "    dword planet;",
                        "    if(!mType) planet=StarPlanets(GalaxyStar(71),Rnd(1,2));",
                        "    else if(mType == 1) planet=StarPlanets(GalaxyStar(71),0);",
                        "    else if(mType == 2) planet=StarPlanets(GalaxyStar(71),3);",
                        "    else planet=StarPlanets(GalaxyStar(71),Rnd(0,4));",
                        "    result = planet;",
                        "}",
                        "//Пока что это функция выдачи оборудки через шуфункции (Give...Equipment). Первый параметр - указатель на корабль.",
                        "//Второй параметр - тип наемника.",
                        "function EqUpgrade(dword ship, dword mType) {",
                        "    dword item;",
                        "    for(int i=ShipItems(ship)-1; i>0; i=i-1) FreeItem(GetItemFromShip(ship,i));",
                        "    for(i=t_FuelTanks; i<=t_DefGenerator; i=i+1) { //Выдаем оборудку через шуфункции. Потом надо будет заменить.",
                        "        dword random=Rnd(1,100);",
                        "        if(!mType) {",
                        "            if(random<=25) item=GiveCoolEq(ship,i,ShipOwner(ship),Rnd(20,60));",
                        "            else if(random<=50) item=GiveAverageEq(ship,i,ShipOwner(ship),Rnd(20,60));",
                        "            else item=GiveCommonEq(ship,i,ShipOwner(ship),Rnd(20,60));",
                        "        }",
                        "        else if(mType==1) {",
                        "            if(random<=50) item=GiveCoolEq(ship,i,ShipOwner(ship),Rnd(20,60));",
                        "            else item=GiveAverageEq(ship,i,ShipOwner(ship),Rnd(20,60));",
                        "        }",
                        "        else if(mType==2) {",
                        "            if(random<=20) item=GiveExtremeEq(ship,i,ShipOwner(ship),Rnd(20,60));",
                        "            if(random<=45) item=GiveCoolEq(ship,i,ShipOwner(ship),Rnd(20,60));",
                        "            if(random<=75) item=GiveAverageEq(ship,i,ShipOwner(ship),Rnd(20,60));",
                        "            else item=GiveCommonEq(ship,i,ShipOwner(ship),Rnd(20,60));",
                        "        }",
                        "        else {",
                        "            if(random<=20) item=GiveExtremeEq(ship,i,ShipOwner(ship),Rnd(20,60));",
                        "            if(random<=45) item=GiveCoolEq(ship,i,ShipOwner(ship),Rnd(20,60));",
                        "            if(random<=75) item=GiveAverageEq(ship,i,ShipOwner(ship),Rnd(20,60));",
                        "            else item=GiveCommonEq(ship,i,ShipOwner(ship),Rnd(20,60));",
                        "        }",
                        "        ItemIsInUse(item,ship,1);",
                        "    }",
                        "    for(i=0; i<GetEquipmentStats(ShipEqInSlot(ship,t_Hull),1); i=i+1) { //Выдаем пушки, пока не кончатся слоты",
                        "        random=Rnd(1,100);",
                        "        if(!mType) {",
                        "            if(random<=25) item=GiveCoolEq(ship,t_Weapon1,ShipOwner(ship),Rnd(20,60));",
                        "            else if(random<=50) item=GiveAverageEq(ship,t_Weapon1,ShipOwner(ship),Rnd(20,60));",
                        "            else item=GiveCommonEq(ship,t_Weapon1,ShipOwner(ship),Rnd(20,60));",
                        "        }",
                        "        else if(mType==1) {",
                        "            if(random<=10) item=GiveExtremeEq(ship,t_Weapon1,ShipOwner(ship),Rnd(20,60));",
                        "            else if(random<=50) item=GiveCoolEq(ship,t_Weapon1,ShipOwner(ship),Rnd(20,60));",
                        "            else item=GiveAverageEq(ship,t_Weapon1,ShipOwner(ship),Rnd(20,60));",
                        "        }",
                        "        else if(mType==2) {",
                        "            if(random<=30) item=GiveExtremeEq(ship,t_Weapon1,ShipOwner(ship),Rnd(20,60));",
                        "            else if(random<=60) item=GiveCoolEq(ship,t_Weapon1,ShipOwner(ship),Rnd(20,60));",
                        "            else item=GiveAverageEq(ship,t_Weapon1,ShipOwner(ship),Rnd(20,60));",
                        "        }",
                        "        else {",
                        "            if(random<=20) item=GiveExtremeEq(ship,t_Weapon1,ShipOwner(ship),Rnd(20,60));",
                        "            if(random<=45) item=GiveCoolEq(ship,t_Weapon1,ShipOwner(ship),Rnd(20,60));",
                        "            if(random<=75) item=GiveAverageEq(ship,t_Weapon1,ShipOwner(ship),Rnd(20,60));",
                        "            else item=GiveCommonEq(ship,t_Weapon1,ShipOwner(ship),Rnd(20,60));",
                        "        }",
                        "        ItemIsInUse(item,ship,1);",
                        "    }",
                        "//    if(GetEquipmentStats(ShipItems(ship,0),5)) { //Если в корпусе открыт слот дроида, но самого дроида нет - выдаем",
                        "//        if(!ShipEqInSlot(ship,t_RepairRobot)) {",
                        "//            item=CreateEquipment(t_RepairRobot,Rnd(20,40),GalaxyTechLevel(),ShipOwner(ship));",
                        "//            AddItemToShip(ship,item);",
                        "//            ItemIsInUse(item,ship,1);",
                        "//        }",
                        "//    }",
                        "//    if(GetEquipmentStats(ShipItems(ship,0),7))  { //Аналогично для ГЗП",
                        "//        if(!ShipEqInSlot(ship,t_DefGenerator)) {",
                        "//            item=CreateEquipment(t_DefGenerator,Rnd(20,40),GalaxyTechLevel(),ShipOwner(ship));",
                        "//            AddItemToShip(ship,item);",
                        "//            ItemIsInUse(item,ship,1);",
                        "//        }",
                        "//    }",
                        "}",
                        "//Функция, удаляющая из трюма корабля всё оборудование и оружие, но не удаляющая скриптовые предметы",
                        "function FreeAllHoldEquipment(ship)",
                        "{",
                        "    for(int i = ShipItems(ship) - 1; i > 0; i = i - 1)",
                        "    {",
                        "        dword item = ShipItems(ship, i);",
                        "        if(ItemIsInUse(item)) continue;",
                        "        if(ItemType(item) < t_FuelTanks) continue;",
                        "        if(ItemType(item) > t_CustomWeapon) continue;",
                        "        if(ItemInScript(item)==1) continue;",
                        "        FreeItem(GetItemFromShip(ship, i));",
                        "    }",
                        "}",
                        "//Функция изменения отношений в наемниками. atlantRel: изменение отношений с атлантами.",
                        "//axeRel: с топорами. feiRel: с фэй.",
                        "function ChangeRelations(int atlantRel, int axeRel, int feiRel) {",
                        "    if(atlantRel) {",
                        "        if(atlantRel < 0) atlant_rel = max(0, atlant_rel + atlantRel);",
                        "        else atlant_rel = min(100, atlant_rel + atlantRel);",
                        "    }",
                        "    if(axeRel) {",
                        "        if(axeRel < 0) red_rel = max(0, red_rel + axeRel);",
                        "        else red_rel = min(100, red_rel + axeRel);",
                        "    }",
                        "    if(feiRel) {",
                        "        if(feiRel < 0) fei_rel = max(0, fei_rel + feiRel);",
                        "        else fei_rel = min(100, fei_rel + feiRel);",
                        "    }",
                        "}",
                        "//Функция присоединения корабля к базовой скриптовой группе наемников с фристейтом. ship: указатель на корабль.",
                        "function JoinDefaultMercGroup(dword ship) {",
                        "    if(ShipType(ship) == 'Merc') {",
                        "        if(ShipPilotRace(ship) == Maloc) ShipJoin(gReds, ship);",
                        "        else if(ShipPilotRace(ship) == Fei) ShipJoin(gFeis, ship);",
                        "        else ShipJoin(gAtlant, ship);",
                        "    }",
                        "    else ShipJoin(gFrees, ship);",
                        "    ChangeState('MercNormal', ship);",
                        "}"
                    ],
                    "#": 136,
                    "Type": "Top",
                    "Parent": -1,
                    "Pos.x": 60,
                    "Pos.y": 1035
                },
                {
                    "Name": "",
                    "Code.Type": "Turn",
                    "Code": [
                        "if(!ShipIsTakeoff(Player())) {",
                        "  GTL = GalaxyTechLevel(); //Каждый ход обновляем переменную с текущим ГТУ",
                        "  if(free_id && !IdToShip(free_id)) { //Наемник погиб не выполнив контракт",
                        "      if(GroupCount(MercCenter)) CustomEther('ContractCancel', 5, '', Format(CT(\"Script.Mod_ShuMercs.25\"),\"<0>\",free_name,\"<1>\",target_name));",
                        "      free_id = 0;",
                        "      target_id = 0;",
                        "  }",
                        "  if(!GroupCount(Raid))",
                        "  {",
                        "      if(raid_status == 1)",
                        "      {",
                        "          s = GalaxyStar(raid_star);",
                        "          stroka = Format(CT(\"Script.Mod_ShuMercs.37\"),\"<0>\",Name(s));",
                        "          CustomEther('ContractCancel', 5, '', stroka);",
                        "          stroka = '';",
                        "          stroka3 = '';",
                        "          raid_status = 0;",
                        "      }",
                        "      else if(raid_status == 2)",
                        "      {",
                        "          s = GalaxyStar(raid_star);",
                        "          stroka = Format(CT(\"Script.Mod_ShuMercs.36\"),\"<0>\",Name(s));",
                        "          stroka = stroka + stroka3;",
                        "          CustomEther('ContractCancel', 4, '', stroka);",
                        "          stroka = '';",
                        "          stroka3 = '';",
                        "          raid_status = 0;",
                        "      }",
                        "  }",
                        "  if(CurTurn() > rospusk_raida)",
                        "  {",
                        "      i = 0;",
                        "      for(j = GroupCount(Raid) - 1; j >= 0; j = j - 1)",
                        "      {",
                        "          s = GroupShip(Raid, j);",
                        "          if(GetShipRuins(s) == GroupToShip(MercCenter)) {",
                        "              i = 1;",
                        "          }",
                        "          else {",
                        "              i = 0;",
                        "              break;",
                        "          }",
                        "      }",
                        "      if(i) {",
                        "          //Вроде как этот цикл накидывает на склад ЦН добычу за каждый корабль наёмника, переживший рейд",
                        "          cur_ruin = GroupToShip(MercCenter);",
                        "          for(j = GroupCount(Raid) - 1; j >= 0; j = j - 1)",
                        "          {",
                        "              ship = GroupShip(Raid, j);",
                        "              raid_status = 2;",
                        "              //Сколько добычи привёз из рейда наёмник",
                        "              if(ShipPilotRace(ship) == Fei) rand = Rnd(2, 5);",
                        "              else rand = Rnd(1, 4);",
                        "  ",
                        "              for(i = 0; i < rand; i = i + 1)",
                        "              {",
                        "                  coef = Rnd(1, 100);",
                        "                  //Если рейд был на клисанскую систему",
                        "                  if(subowner == 10)",
                        "                  {",
                        "                      if(coef <= 60) s = CreateCustomCountableItem('kProtoplasm', Rnd(5, 40), 1);",
                        "                      else s = CreateQuestItem('KlissanRemains' + Rnd(1, int(CT('Script.Mod_ShuKlissan.KlissanRemainsCount'))), None);",
                        "                      SetName(s, '<color=15,252,15>' + Name(s) + '</color>');",
                        "                      EqCustomFaction(s, 'Klissan');",
                        "                      stroka3 = stroka3 + CT(\"Script.Mod_ShuMercs.195\") + '<clr>' + Name(s) + '<clrEnd>';",
                        "                      AddItemToStorage(cur_ruin, s);",
                        "                  }",
                        "                  //Если рейд был на пиратскую(?) систему",
                        "                  else if(subowner == 5)",
                        "                  {",
                        "                      if(coef <= 20) s = CreateEquipment(Rnd(t_FuelTanks, t_Weapon4), Rnd(30, 80), Rnd(1, GalaxyTechLevel() - 1), Rnd(0, 4));",
                        "                      else s = CreateGoods(Rnd(0, 7), Rnd(1, 40));",
                        "                      stroka3 = stroka3 + CT(\"Script.Mod_ShuMercs.195\") + '<clr>' + Name(s) + '<clrEnd>';",
                        "                      AddItemToStorage(cur_ruin, s);",
                        "                  }",
                        "                  //Если рейд был на доминаторскую систему",
                        "                  else",
                        "                  {",
                        "                      if(coef <= 30) s = CreateNodes(Rnd(10, 60));",
                        "                      else if(coef <= 60) s = CreateEquipment(Rnd(t_FuelTanks, t_Weapon8), Rnd(25, 80), Rnd(1, GalaxyTechLevel() - 1), Kling);",
                        "                      else s = CreateQuestItem('Remains_' + Rnd(0, 8), Kling);",
                        "                      ItemSubrace(s, subowner);",
                        "                      stroka3 = stroka3 + CT(\"Script.Mod_ShuMercs.195\") + '<clr>' + Name(s) + '<clrEnd>';",
                        "                      AddItemToStorage(cur_ruin, s);",
                        "                  }",
                        "              }",
                        "  ",
                        "              //Выживший наёмник из рейда убивается кодом (как-то хуёво это тут сделано)",
                        "              OrderLock(ship, 0);",
                        "              if(ShipStar(Player()) == ShipStar(ship))",
                        "              {",
                        "                  TransferShip(ship, PlanetPirateClan());",
                        "                  ShipJoin(ToDestroy, ship);",
                        "              }",
                        "              else ShipDestroy(ship);",
                        "          }",
                        "      }",
                        "  }",
                        "  //Игрока кто-то заказал",
                        "  if (GroupCount(MercCenter)) {",
                        "    if (CurTurn() >= playerHuntTimer) {",
                        "      //Чем хуже отношения с планетами и кораблями - тем больше шанс на то, что игрока закажут",
                        "      rand = 100 - GlobalRelationsPlanets(Player(), 0, 1+2+4+8+16); //Коалиция",
                        "      rand = rand + 100 - RelationToRanger(PlanetPirateClan(), Player()); //Пираты",
                        "      rand = rand + 100 - GlobalRelationsShips(Player(), 0, 1+4+8+16+32, 1+2+4+8+16); //Коалиционные корабли",
                        "      if (Rnd(1, 1000) <= rand) {",
                        "        playerHuntTimer = Rnd(1460, 1825);",
                        "        playerHuntPrice = 2 * GalaxyMoney(3, 4) * (100 + rand) / 100;",
                        "        if (ShipStrengthInAverageRanger(Player()) <= 1) rand = 1;",
                        "        else if (ShipStrengthInAverageRanger(Player()) <= 2) rand = Rnd(1, 2);",
                        "        else if (ShipStrengthInAverageRanger(Player()) <= 3) rand = Rnd(2, 3);",
                        "        else if (ShipStrengthInAverageRanger(Player()) <= 4) rand = Rnd(3, 4);",
                        "        else rand = Rnd(5, 6);",
                        "        //Если у игрока плохие отношения с организациями - они возьмут контракт. В противном случае, это будут фрилансеры.",
                        "        if (fei_rel < 20 && GroupCount(FeiLeader)) tint1 = 2;",
                        "        else if (red_rel < 20 && GroupCount(RedLeader)) tint1 = 1;",
                        "        else if (atlant_rel < 20 && GroupCount(AtlantLeader)) tint1 = 0;",
                        "        else tint1 = 3;",
                        "        for (i = 0; i < rand; i = i + 1) {",
                        "          ship = BuyMerc(tint1, 3, GroupToShip(MercCenter));",
                        "          ShipJoin(PursuePlayerGroup, ship);",
                        "        }",
                        "      } else playerHuntTimer = CurTurn() + 180;",
                        "    }",
                        "  }",
                        "  //Переделать вместе с диалогом",
                        "  if(atlant_call < CurTurn()) atlant_call = CurTurn();",
                        "  if(red_call < CurTurn()) red_call = CurTurn();",
                        "  if(fei_call < CurTurn()) fei_call = CurTurn();",
                        "  ",
                        "  if (!GroupCount(MercCenter)) {",
                        "    if (!merc_timer) merc_timer = CurTurn() + Rnd(360, 480);",
                        "    else {",
                        "      if (ControlledSystems(0) + ControlledSystems(2) > 3) {",
                        "        if (CurTurn() >= merc_timer) {",
                        "          star = StarNearbyStars(PlanetToStar(GetShipHomePlanet(Player())), Rnd(1, 25));",
                        "          if (star != GalaxyStar(71) && //Нифигац",
                        "            star != PlanetToStar(PlanetPirateClan()) && //Тортугац",
                        "            star != ShipStar(Player()) &&",
                        "            !StarBattle(star) &&",
                        "            StarRuins(star) < 3 &&",
                        "            StarOwner(star) != 1 &&",
                        "            StarCustomFaction(star) == ''",
                        "          ) {",
                        "            merc_timer = 0;",
                        "            cur_ruin = BuildCustomRuins(star, 'MB', 5);",
                        "            SetName(cur_ruin, CT(\"Script.Mod_ShuMercs.34\"));",
                        "            if (GroupCount(AtlantLeader) || GroupCount(RedLeader) || GroupCount(FeiLeader) || !first_build) {",
                        "              tstr1 = CT(\"Script.Mod_ShuMercs.220\");",
                        "            } else {",
                        "              ShipType(cur_ruin, 'Manaan');",
                        "              tstr1 = CT(\"Script.Mod_ShuMercs.219\");",
                        "            }",
                        "            tstr2 = '</color>' + Format(CT('GalaxyNews.CreateNewObject.MB'), '<'+'Star>', Name(star), '<'+'Type>', '</color>'+tstr1, '<'+'Name>', ShortName(cur_ruin));",
                        "            NewsAdd(tstr2);",
                        "            AddPlanetNews(tstr2);",
                        "            ShipPilotRace(cur_ruin, People);",
                        "            ShipOwner(cur_ruin, People);",
                        "            ItemSize(ShipItems(cur_ruin, 0), 5500);",
                        "            HullHP(cur_ruin, 5500);",
                        "            ShipSpecialBonuses(cur_ruin, bonWRadius, 150);",
                        "            ShipSpecialBonuses(cur_ruin, bonHull, 5);",
                        "            ShipSpecialBonuses(cur_ruin, bonDroid, 20);",
                        "            ShipSpecialBonuses(cur_ruin, bonDef, 5);",
                        "            ShipSkill(cur_ruin, 0, 6);",
                        "            ShipSkill(cur_ruin, 1, 0);",
                        "            GiveExtremeEq(cur_ruin, t_Weapon1, 2, 1);",
                        "            GiveExtremeEq(cur_ruin, t_Weapon1, 2, 1);",
                        "            GiveExtremeEq(cur_ruin, t_Weapon1, 2, 1);",
                        "            GiveExtremeEq(cur_ruin, t_Weapon1, 2, 1);",
                        "            GiveExtremeEq(cur_ruin, t_Weapon1, 2, 1);",
                        "            GiveExtremeEq(cur_ruin, t_DefGenerator, 2, 100);",
                        "            GiveExtremeEq(cur_ruin, t_RepairRobot, 2, 100);",
                        "            ArrangeItems(cur_ruin);",
                        "            Chameleon(cur_ruin, 'Ruins.MB');",
                        "            ShipJoin(MercCenter, cur_ruin);",
                        "            //ЦН был построен в первый раз, выставляется стартовое отношение группировок к игроку",
                        "            if (!first_build) {",
                        "              first_build = 1;",
                        "              atlant_rel = 50;",
                        "              red_rel = 50;",
                        "              fei_rel = 50;",
                        "              if (ShipPilotRace(Player()) == Maloc) ChangeRelations(0, 5, -5);",
                        "              else if (ShipPilotRace(Player()) == Peleng) ChangeRelations(5, -5, -5);",
                        "              else if (ShipPilotRace(Player()) == People) ChangeRelations(5, -5, 0);",
                        "              else if (ShipPilotRace(Player()) == Fei) ChangeRelations(0, -5, 5);",
                        "              else ChangeRelations(-5, -5, -5);",
                        "              if (StatusPlayer() == 1) ChangeRelations(5, -5, 5); //Торговец",
                        "              else if (StatusPlayer() == 0) ChangeRelations(-5, 5, 5); //Воин",
                        "              else if (StatusPlayer() == -1) ChangeRelations(5, 0, -5); //Пират",
                        "            }",
                        "          } else merc_timer = CurTurn() + 30;",
                        "        }",
                        "      }",
                        "    }",
                        "  }",
                        "  //Этот кусок пока не трогал",
                        "  cur_ruin = GroupToShip(MercCenter);",
                        "  if(!cur_ruin)",
                        "  {",
                        "      Reds = 0;",
                        "      Atlant = 0;",
                        "      Feis = 0;",
                        "  }",
                        "  else",
                        "  {",
                        "    if (GroupCount(AtlantLeader)) {",
                        "      if (Rnd(1, 100) <= 11) Atlant = min(25, Atlant + 1);",
                        "    }",
                        "    if (GroupCount(RedLeader)) {",
                        "      if (Rnd(1, 100) <= 8) Reds = min(15, Reds + 1);",
                        "    }",
                        "    if (GroupCount(FeiLeader)) {",
                        "      if (Rnd(1, 100) <= 6) Feis = min(10, Feis + 1);",
                        "    }",
                        "    if (Rnd(1, 100) <= 5) Frees = min(10, Frees + 1);",
                        "  ",
                        "      if(Rnd(1, 100) <= 9)",
                        "      {",
                        "          i = ControlledSystems(0) + ControlledSystems(2) - 2;",
                        "  ",
                        "          if(i > 100) i = 0;",
                        "          if(i == 0)",
                        "          {",
                        "              num1 = 0;",
                        "              num2 = 0;",
                        "              num3 = 0;",
                        "              num4 = 0;",
                        "          }",
                        "          else if(i == 1)",
                        "          {",
                        "              num1 = 5;",
                        "              num2 = 3;",
                        "              num3 = 2;",
                        "              num4 = 5;",
                        "          }",
                        "          else if(i == 2)",
                        "          {",
                        "              num1 = 6;",
                        "              num2 = 4;",
                        "              num3 = 3;",
                        "              num4 = 6;",
                        "          }",
                        "          else if(i == 3)",
                        "          {",
                        "              num1 = 7;",
                        "              num2 = 4;",
                        "              num3 = 3;",
                        "              num4 = 7;",
                        "          }",
                        "          else if(i < 5)",
                        "          {",
                        "              num1 = 8;",
                        "              num2 = 5;",
                        "              num3 = 3;",
                        "              num4 = 8;",
                        "          }",
                        "          else if(i < 7)",
                        "          {",
                        "              num1 = 11;",
                        "              num2 = 7;",
                        "              num3 = 4;",
                        "              num4 = 11;",
                        "          }",
                        "          else if(i < 10)",
                        "          {",
                        "              num1 = 13;",
                        "              num2 = 8;",
                        "              num3 = 5;",
                        "              num4 = 13;",
                        "          }",
                        "          else if(i < 15)",
                        "          {",
                        "              num1 = 16;",
                        "              num2 = 10;",
                        "              num3 = 6;",
                        "              num4 = 16;",
                        "          }",
                        "          else if(i < 20)",
                        "          {",
                        "              num1 = 18;",
                        "              num2 = 11;",
                        "              num3 = 7;",
                        "              num4 = 18;",
                        "          }",
                        "          else",
                        "          {",
                        "              num1 = 20;",
                        "              num2 = 12;",
                        "              num3 = 8;",
                        "              num4 = 20;",
                        "          }",
                        "  ",
                        "          if(!GroupCount(AtlantLeader) && !GroupCount(RedLeader) && !GroupCount(FeiLeader))",
                        "          {",
                        "              num4 = num4 / 2;",
                        "          }",
                        "  ",
                        "          rand = Rnd(1, 4);",
                        "          if(rand == 1 && GroupCount(AtlantLeader) && GroupCount(gAtlant) < num1)",
                        "          {",
                        "              ship = BuyMerc(0, 3, GroupToShip(MercCenter));",
                        "              ShipJoin(gAtlant, ship);",
                        "          }",
                        "          else if(rand == 2 && GroupCount(RedLeader) && GroupCount(gReds) < num2)",
                        "          {",
                        "              ship = BuyMerc(1, 3, GroupToShip(MercCenter));",
                        "              ShipJoin(gReds, ship);",
                        "          }",
                        "          else if(rand == 3 && GroupCount(FeiLeader) && GroupCount(gFeis) < num3)",
                        "          {",
                        "              ship = BuyMerc(2, 3, GroupToShip(MercCenter));",
                        "              ShipJoin(gFeis, ship);",
                        "          }",
                        "          else if(rand == 4 && GroupCount(gFrees) < num4)",
                        "          {",
                        "              ship = BuyMerc(3, 3, GroupToShip(MercCenter));",
                        "              ShipJoin(gFrees, ship);",
                        "          }",
                        "      }",
                        "  }",
                        "  //Переделать с использованием массива leaderStatus",
                        "  if(spawn_leader < 10)",
                        "  {",
                        "      spawn_leader = 10;",
                        "      s = PlanetToStar(PlanetPirateClan());",
                        "      for(i = 0; i < StarPlanets(s); i = i + 1)",
                        "      {",
                        "          pl = StarPlanets(s, i);",
                        "          if(PlanetOwner(pl) == None)",
                        "          {",
