                {
                    "Name": "",
                    "Code.Type": "Turn",
                    "Code": [
                        "target_ship = tempArray[GAnswerData];",
                        "ArrayClear(tempArray);",
                        "if (ShipStrengthInAverageRanger(target_ship) >= ShipStrengthInAverageRanger(ship) * 1.50) {",
                        "  dState = 1;",
                        "} else if (ShipStrengthInAverageRanger(target_ship) >= ShipStrengthInAverageRanger(ship) * 1.35) {",
                        "  dState = 2;",
                        "  coef = 200;",
                        "} else if (ShipStrengthInAverageRanger(target_ship) >= ShipStrengthInAverageRanger(ship) * 1.20) {",
                        "  dState = 3;",
                        "  coef = 150;",
                        "} else if (ShipStrengthInAverageRanger(target_ship) >= ShipStrengthInAverageRanger(ship) * 0.85) {",
                        "  dState = 4;",
                        "  coef = 110;",
                        "} else {",
                        "  dState = 5;",
                        "  coef = 75;",
                        "}",
                        "",
                        "if (NoTargetToShip(target_ship) == 1) {",
                        "  dState = 7;",
                        "}",
                        "",
                        "if (ShipType(target_ship) == 'AtlantLeader' || ShipType(target_ship) == 'RedLeader' || ShipType(target_ship) == 'FeiLeader') {",
                        "  dState = 7;",
                        "}",
                        "if (ShipType(target_ship) == 'Tranclucator') {",
                        "  dState = 7;",
                        "}",
                        "if (ShipType(target_ship) == 'Merc' || ShipType(target_ship) == 'Freelancer') {",
                        "  if (!GroupCount(MercCenter)) dState = dState;",
                        "  else if (ShipStar(target_ship) != ShipStar(GroupToShip(MercCenter))) dState = dState;",
                        "  else dState = 8;",
                        "}",
                        "if (target_ship == ship ||",
                        "  target_ship == Terron() ||",
                        "  target_ship == Keller() ||",
                        "  target_ship == Blazer() ||",
                        "  target_ship == Player() ||",
                        "  ShipOwner(target_ship) == Kling ||",
                        "  ObjectType(target_ship) == 4",
                        ") {",
                        "  dState = 7;",
                        "}",
                        "if (target_ship == GroupToShip(MercCenter)) {",
                        "  dState = 7;",
                        "}",
                        "if (ShipIsPartner(target_ship) == ship || ShipIsPartner(ship) == target_ship) {",
                        "  dState = 9;",
                        "}",
                        "",
                        "if (ShipType(ship) == 'Merc' && ShipType(target_ship) == 'Merc') {",
                        "  if (ShipPilotRace(ship) == ShipPilotRace(target_ship)) dState = 9;",
                        "  else if (",
                        "    ShipPilotRace(ship) > Maloc && ShipPilotRace(ship) < Fei &&",
                        "    ShipPilotRace(target_ship) > Maloc && ShipPilotRace(ship) < Fei",
                        "  ) dState = 9;",
                        "}",
                        "",
                        "if (ShipStar(target_ship) == GalaxyStar(71) || ShipStar(target_ship) == PlanetToStar(PlanetPirateClan())) {",
                        "  dState = 6;",
                        "}",
                        "cost = GalaxyMoney(3) * coef / 100;",
                        "",
                        "if (merc_type == 1) {",
                        "  cost = cost * coef2 / 100;",
                        "  if (ShipPilotRace(ship) == Maloc) rel = red_rel / 2;",
                        "  else if (ShipPilotRace(ship) == Fei) rel = fei_rel / 2;",
                        "  else rel = atlant_rel / 2;",
                        "}",
                        "coef = 100 - rel;",
                        "cost = cost * coef / 100;",
                        "if(dState==8) {",
                        "  DChange(56);",
                        "  exit;",
                        "}",
                        "if(dState==9) {",
                        "  DChange(57);",
                        "  exit;",
                        "}",
                        "if(dState==1) {",
                        "  DChange(13);",
                        "  exit;",
                        "}",
                        "if(dState==2 && merc_type==1) {",
                        "  DChange(14);",
                        "  exit;",
                        "}",
                        "if(dState==3 && merc_type==1) {",
                        "  DChange(15);",
                        "  exit;",
                        "}",
                        "if(dState==4 && merc_type==1) {",
                        "  DChange(16);",
                        "  exit;",
                        "}",
                        "if(dState==5 && merc_type==1) {",
                        "  DChange(17);",
                        "  exit;",
                        "}",
                        "if(dState==2 && merc_type==2) {",
                        "  DChange(20);",
                        "  exit;",
                        "}",
                        "if(dState==3 && merc_type==2) {",
                        "  DChange(21);",
                        "  exit;",
                        "}",
                        "if(dState==4 && merc_type==2) {",
                        "  DChange(22);",
                        "  exit;",
                        "}",
                        "if(dState==5 && merc_type==2) {",
                        "  DChange(23);",
                        "  exit;",
                        "}",
                        "if(dState == 6) {",
                        "  DChange(18);",
                        "  exit;",
                        "}",
                        "if(dState == 7) {",
                        "  DChange(19);",
                        "  exit;",
                        "}"
