                    "#": 455,
                    "Type": "Top",
                    "Parent": -1,
                    "Pos.x": 700,
                    "Pos.y": 865
                },
                {
                    "Name": "",
                    "Code.Type": "Turn",
                    "Code": [
                        "for(j=0; j<SqNom; j=j+1) {",
                        "    if(Squad == 1) {",
                        "        cur_ship=BuyMerc(0, 1, GroupToShip(MercCenter));",
                        "        ShipJoin(gAtlant,cur_ship);",
                        "        Atlant=Atlant-1;",
                        "        ChangeRelations(1, Rnd(-1, 0), Rnd(-1, 0));",
                        "    }",
                        "    else if(Squad == 2) {",
                        "        cur_ship=BuyMerc(1, 1, GroupToShip(MercCenter));",
                        "        ShipJoin(gReds,cur_ship);",
                        "        Reds=Reds-1;",
                        "        ChangeRelations(Rnd(-1, 0), 1, -1);",
                        "    }",
                        "    else if(Squad == 3) {",
                        "        cur_ship=BuyMerc(2, 1, GroupToShip(MercCenter));",
                        "        ShipJoin(gFeis,cur_ship);",
                        "        Feis=Feis-1;",
                        "        ChangeRelations(Rnd(-1, 0), -1, 1);",
                        "    }",
                        "    else if(Squad == 4) {",
                        "        cur_ship=BuyMerc(3, 1, GroupToShip(MercCenter));",
                        "        ShipJoin(gFrees,cur_ship);",
                        "        Frees=Frees-1;",
                        "    }",
                        "    ShipSetPartner(cur_ship, Player(), days);",
                        "    ShipJoin(gEscort, cur_ship);",
                        "}",
                        "",
                        "ShipMoney(Player(), ShipMoney(Player()) - cost);",
                        "Sound('Sound.Buy');"
                    ],
