                        "  //Нерабочий код (больше нигде не используется, а отношения можно задать более компактно)",
                        "  if(!GroupCount(AtlantLeader) && !atlant_dead)",
                        "  {",
                        "      atlant_dead = 1;",
                        "      Atlant = 0;",
                        "      atlant_rel = 0;",
                        "  }",
                        "  if(!GroupCount(RedLeader) && !red_dead)",
                        "  {",
                        "      red_dead = 1;",
                        "      Reds = 0;",
                        "      red_rel = 0;",
                        "      fei_rel = 100;",
                        "  }",
                        "  if(!GroupCount(FeiLeader) && !fei_dead)",
                        "  {",
                        "      fei_dead = 1;",
                        "      Feis = 0;",
                        "      red_rel = 100;",
                        "      fei_rel = 0;",
                        "  }",
                        "  //Удалить этот кусок после убийства лидеров",
                        "  if(!GroupCount(AtlantLeader)) Atlant = 0;",
                        "  if(!GroupCount(RedLeader)) Reds = 0;",
                        "  if(!GroupCount(FeiLeader)) Feis = 0;",
                        "  //Где-то здесь в конце будет код с перебором галаивентов на убийство наемников. сюда же вынести убийство лидеров",
                        "  ",
                        "  //Ухудшение отношений за убийство наемников",
                        "  for (i = GalaxyEvents() - 1; i >= 0; i = i - 1) {",
                        "    if (GalaxyEventDate(i) < CurTurn()) break;",
                        "    if (GalaxyEventType(i) == 'PlayerKillsShip' || GalaxyEventType(i) == 'PlayerAssistKillsShip' || GalaxyEventType(i) == 'PlayerCompanionKillsShip' || GalaxyEventType(i) == 'PlayerCompanionAssistKillsShip') {",
                        "      if (GalaxyEventsTextData(i, 2) == 'Merc') {",
                        "        if (GalaxyEventData(i, 3) == Maloc) {",
                        "          ChangeRelations(Rnd(1, 2), -5, 3);",
                        "        } else if (GalaxyEventData(i, 3) == Fei) {",
                        "          ChangeRelations(Rnd(1, 2), 3, -6);",
                        "        } else {",
                        "          ChangeRelations(-4, Rnd(1, 2), Rnd(1, 2));",
                        "        }",
                        "      }",
                        "    } else if (GalaxyEventType(i) == 'PlayerTranclucatorKillsShip' || GalaxyEventType(i) == 'PlayerTranclucatorAssistKillsShip') {",
                        "      if (GalaxyEventsTextData(i, 3) == 'Merc') {",
                        "        if (GalaxyEventData(i, 3) == Maloc) {",
                        "          ChangeRelations(Rnd(1, 2), -5, 3);",
                        "        } else if (GalaxyEventData(i, 3) == Fei) {",
                        "          ChangeRelations(Rnd(1, 2), 3, -6);",
                        "        } else {",
                        "          ChangeRelations(-4, Rnd(1, 2), Rnd(1, 2));",
                        "        }",
                        "      }",
                        "    }",
                        "  }",
                        "  //Проверка на атаку своих из рейда/военной операции или же наемника с контрактом",
                        "  if (GroupCount(Raid)) { //Рейд",
                        "    check = 0;",
                        "    for (i = 0; i < GroupCount(Raid); i = i + 1) {",
                        "      ship = GroupShip(Raid, i);",
                        "      if (Hit(ship, 0)) {",
                        "        check = 1;",
                        "        break;",
                        "      }",
                        "    }",
                        "    if (check) {",
                        "      raid_status = 0;",
                        "      CustomEther('ContractCancel', 5, '', Format(CT(\"Script.Mod_ShuMercs.201\"),\"<0>\",Name(GalaxyStar(raid_star))));",
                        "      if (ShipType(ship) == 'Merc') {",
                        "        if (ShipPilotRace(ship) == Maloc) ChangeRelations(Rnd(1, 2), -5, 3);",
                        "        else if (ShipPilotRace(ship) == Fei) ChangeRelations(Rnd(1, 2), 3, -6);",
                        "        else ChangeRelations(-4, Rnd(1, 2), Rnd(1, 2));",
                        "      }",
                        "      for (i = GroupCount(Raid) - 1; i >= 0; i = i - 1) {",
                        "        ship = GroupShip(Raid, i);",
                        "        if (OrderLock(ship)) OrderLock(ship, 0);",
                        "        if (NoScanToShip(ship)) NoScanToShip(ship, 0); //Удалить потом",
                        "        JoinDefaultMercGroup(ship);",
                        "      }",
                        "    }",
                        "  }",
                        "  if (GroupCount(Attack)) { //Военная операция (кроме групп Beg, BegN, т.к. их нужность под вопросом)",
                        "    check = 0;",
                        "    for (i = 0; i < GroupCount(Attack); i = i + 1) {",
                        "      ship = GroupShip(Attack, i);",
                        "      if (Hit(ship, 0)) {",
                        "        check = 1;",
                        "        break;",
                        "      }",
                        "    }",
                        "    if (check) {",
                        "      CustomEther('ContractCancel', 5, '', Format(CT(\"Script.Mod_ShuMercs.200\"),\"<0>\",Name(GalaxyStar(attack_star))));",
                        "      if (ShipType(ship) == 'Merc') {",
                        "        if (ShipPilotRace(ship) == Maloc) ChangeRelations(Rnd(1, 2), -5, 3);",
                        "        else if (ShipPilotRace(ship) == Fei) ChangeRelations(Rnd(1, 2), 3, -6);",
                        "        else ChangeRelations(-4, Rnd(1, 2), Rnd(1, 2));",
                        "      }",
                        "      for (i = GroupCount(Attack) - 1; i >= 0; i = i - 1) {",
                        "        ship = GroupShip(Attack, i);",
                        "        if (OrderLock(ship)) OrderLock(ship, 0);",
                        "        JoinDefaultMercGroup(ship);",
                        "      }",
                        "    }",
                        "  }",
                        "  if (GroupCount(ContractGroup)) { //Исполнитель контракта на убийство",
                        "    ship = GroupToShip(ContractGroup);",
                        "    if (Hit(ship, 0)) {",
                        "      CustomEther('ContractCancel', 5, '', Format(CT(\"Script.Mod_ShuMercs.199\"),\"<0>\",free_name,\"<1>\",target_name));",
                        "      JoinDefaultMercGroup(ship);",
                        "      free_timer = 0;",
                        "      free_id = 0;",
                        "      target_id = 0;",
                        "      if (ShipType(ship) == 'Merc') {",
                        "        if (ShipPilotRace(ship) == Maloc) ChangeRelations(Rnd(1, 2), -5, 3);",
                        "        else if (ShipPilotRace(ship) == Fei) ChangeRelations(Rnd(1, 2), 3, -6);",
                        "        else ChangeRelations(-4, Rnd(1, 2), Rnd(1, 2));",
                        "      }",
                        "    }",
                        "  }",
                        "}"
                    ],
                    "#": 137,
                    "Type": "Top",
                    "Parent": -1,
                    "Pos.x": 120,
                    "Pos.y": 1035
                },
                {
                    "Name": "",
                    "Code.Type": "DialogBegin",
                    "Code": [
                        "//Если игрок начал разговор с кораблём в космосе",
                        "cur_ship = GetTalkShip();",
                        "if(cur_ship)",
                        "{",
                        "    //Игрок инициировал разговор с NPC в космосе",
                        "    if(!TalkByAI())",
                        "    {",
                        "        if(ShipType(cur_ship) == 'Merc' || ShipType(cur_ship) == 'Freelancer')",
                        "        {",
                        "            if(ShipGroup(cur_ship)==PursuePlayerGroup) AddDialogOverride('PlayerHuntMain', 10);",
                        "            //Если игрок не идентифицируется кораблём как доминатор",
                        "            if(ShipTypeN(cur_ship) == t_Pirate || PlayerChameleonCurType() == -1)",
                        "            {",
                        "                //Если корабль - наёмник",
                        "                if(ShipType(cur_ship) == 'Merc')",
                        "                {",
                        "                    //if(ShipInScript(cur_ship, 0))",
                        "                    //{",
                        "                    if(!free_id)",
                        "                    {",
                        "                        //Если наёмник не является партнёром игрока",
                        "                        if(ShipIsPartner(cur_ship) != Player())",
                        "                        {",
                        "                            tint1 = ShipGroup(cur_ship);",
                        "                            if(tint1 == gReds || tint1 == gAtlant || tint1 == gFeis)",
                        "                            {",
                        "                                if(CurTurn() >= free_timer) AddDialogInject('MercHire', '', CT(\"Script.Mod_ShuMercs.40\"), 1);",
                        "                                else AddDialogInject('MercHire', '', Format(CT(\"Script.Mod_ShuMercs.39\"),\"<0>\",free_timer - CurTurn()), 1);",
                        "                                AddDialogBlock(Format(CT(\"Script.Mod_ShuMercs.39\"),\"<0>\",free_timer - CurTurn()), 1);",
                        "                                merc_type = 1;",
                        "                            }",
                        "                        }",
                        "                    }",
                        "",
                        "                    for(i = 0; i <= 3; i = i + 1)",
                        "                    {",
                        "                        if(!i) tstr1 = CT('Talk.Pirate.PlayerSend');",
                        "                        else tstr1 = CT('Talk.Pirate.PlayerSend' + i);",
                        "                        tstr1 = Format(DeleteTags(tstr1), '<clr>', '', '<clrEnd>', '');",
                        "                        AddDialogBlock(tstr1, 2);",
                        "                    }",
                        "                    tstr1 = Format(DeleteTags(CT('Talk.Partner.PlayerSend')), '<clr>', '', '<clrEnd>', '');",
                        "                    AddDialogBlock(tstr1, 2);",
                        "                    if(RelationToRanger(cur_ship, Player()) < 10)",
                        "                    {",
                        "                        for(i = 0; i <= 4; i = i + 1)",
                        "                        {",
                        "                            if(!i) tstr1 = CT('Talk.Truce.PlayerSend');",
                        "                            else tstr1 = CT('Talk.Truce.PlayerSend' + i);",
                        "                            tstr1 = Format(DeleteTags(tstr1), '<clr>', '', '<clrEnd>', '');",
                        "                            AddDialogBlock(tstr1, 2);",
                        "                        }",
                        "                        for(i = 0; i <= 3; i = i + 1)",
                        "                        {",
                        "                            if(!i) tstr1 = CT('Talk.Truce.RangerSend');",
                        "                            else tstr1 = CT('Talk.Truce.RangerSend' + i);",
                        "                            tstr1 = Format(DeleteTags(tstr1), '<clr>', '', '<clrEnd>', '');",
                        "                            AddDialogBlock(tstr1, 2);",
                        "                        }",
                        "                    }",
                        "                    //}",
                        "                }",
                        "                //Если корабль - фрилансер",
                        "                else",
                        "                {",
                        "                    if(!free_id)",
                        "                    {",
                        "                        //Если фрилансер не является партнёром игрока",
                        "                        if(ShipIsPartner(cur_ship) != Player())",
                        "                        {",
                        "                            if(CurTurn() >= free_timer) AddDialogInject('MercHire', '', CT(\"Script.Mod_ShuMercs.40\"), 1);",
                        "                            else AddDialogInject('MercHire', '', Format(CT(\"Script.Mod_ShuMercs.39\"),\"<0>\",free_timer - CurTurn()), 1);",
                        "                            AddDialogBlock(Format(CT(\"Script.Mod_ShuMercs.39\"),\"<0>\",free_timer - CurTurn()), 1);",
                        "                            merc_type = 2;",
                        "                        }",
                        "                    }",
                        "                }",
                        "            }",
                        "        }",
                        "    }",
                        "    //Замена диалогов для преследущих игрока наемников, т.к. они все равно не отстанут",
                        "    else {",
                        "        if(ShipGroup(cur_ship)==PursuePlayerGroup) {",
                        "            if(GetTalkType()== TalkGoods || GetTalkType() == TalkMoney) AddDialogOverride('PlayerHuntMoney', 10);",
                        "            else if(GetTalkType() == TalkTruce) AddDialogOverride('PlayerHuntTruce', 10);",
                        "        }",
                        "    }",
                        "}",
                        "else",
                        "{",
                        "    //Если игрок находится на мостике",
                        "    cur_ruin = GetShipRuins(Player());",
                        "    if(cur_ruin)",
                        "    {",
                        "        tint1 = PlayerBridge();",
                        "        if(tint1)",
                        "        {",
                        "            //Если игрок находится на главном экране мостика",
                        "            if(tint1 <= 3)",
                        "            {",
                        "                if(free_id) AddDialogInject('FreeContract', '', CT(\"Script.Mod_ShuMercs.38\"), 1);",
                        "            }",
                        "        }",
                        "    }",
                        "}",
                        "//Диалоги в центре наёмников",
                        "cur_ruin = GetShipRuins(Player());",
                        "if(cur_ruin)",
                        "{",
                        "    //Если игрок находится на ЦН, либо в \"свободном порту\" (то же самое, что и ЦН, только после уничтожения всех лидеров наёмников)",
                        "    if(ShipType(cur_ruin) == 'MB' || ShipType(cur_ruin) == 'Manaan')",
                        "    {",
                        "        //Задаём приветственный текст",
                        "        if(ShipType(cur_ruin) == 'MB')",
                        "        {",
                        "            dialogs_path = 'MercCenterDialogs';",
                        "            tstr1 = '</color>' + Format(CT('Script.Mod_ShuMercs.' + dialogs_path + '.Greeting'),",
                        "                                  '<Name' + '>', ShipName(cur_ruin),",
                        "                                  '<RelationAtlants' + '>', atlant_rel,",
                        "                                  '<RelationRedAxes' + '>', red_rel,",
                        "                                  '<RelationFaeys' + '>', fei_rel",
                        "                                 );",
                        "",
                        "        }",
                        "        else",
                        "        {",
                        "            dialogs_path = 'FreePortDialogs';",
                        "            tstr1 = '</color>' + Format(CT('Script.Mod_ShuMercs.' + dialogs_path + '.Greeting'),",
                        "                                  '<Name' + '>', ShipName(cur_ruin)",
                        "                                 );",
                        "        }",
                        "",
                        "        if(IsScriptActive('Mod_ShuMercsHQ'))",
                        "        {",
                        "            //Если игрок находится в процессе выбора имени для своей организации наёмников",
                        "            //(если BuildOwnBase_InProcess == 5, то запрашивать имя не будут, но просто добавил сюда условие на всякий случай)",
                        "            check = GetValueFromScript('Mod_ShuMercsHQ', 'BuildOwnBase_InProcess');",
                        "            if(check >= 3 && check <= 5)",
                        "            {",
                        "                if(GetData(0, Player()) == 1)",
                        "                {",
                        "                    AddDialogOverride('Mod_ShuMercsHQ:BuildOwnBase_Name', 1000);",
                        "                    exit;",
                        "                }",
                        "            }",
                        "            //Дополнительная реплика к приветствию для повторного строительства своей базы",
                        "            else if(check == -2)",
                        "            {",
                        "                tstr1 = tstr1 + CT(\"Script.Mod_ShuMercs.195\") + CT('Script.Mod_ShuMercs.CreatingPlayerOrgDialogs.TwiceIntro');",
                        "            }",
                        "        }",
                        "",
                        "        AddDialogBlock('HideIt', 2);",
                        "        AddDialogInject('HideIt', tstr1, 'HideIt', 100, 1);",
                        "",
                        "        //Нанять наёмников",
                        "        tstr1 = CT('Script.Mod_ShuMercs.' + dialogs_path + '.PlayerAskHireMercs');",
                        "        AddDialogInject('MB_HireMercs', '', tstr1, 25);",
                        "",
                        "        //Тренировать партнёра",
                        "        tstr1 = CT('Script.Mod_ShuMercs.' + dialogs_path + '.PlayerAskPartnerTraining');",
                        "        AddDialogInject('MB_PartnerTraining', '', tstr1, 20);",
                        "",
                        "        //Сменить корпус партнёру",
                        "        tstr1 = CT('Script.Mod_ShuMercs.' + dialogs_path + '.PlayerAskPartnerChangeHull');",
                        "        AddDialogInject('MB_PartnerChangeHull', '', tstr1, 15);",
                        "",
                        "        if(ShipType(cur_ruin) == 'MB' && IsScriptActive('Mod_ShuMercsHQ'))",
                        "        {",
                        "            //BuildOwnBase_InProcess == -2 - станция игрока разрушена, возможна повторная постройка",
                        "            //BuildOwnBase_InProcess == -1 - игрок уже просмотрел первый вариант диалога, повторно проматывать весь текст не придется",
                        "            //BuildOwnBase_InProcess == 0 - станция игрока ещё ни разу не строилась, диалог на ЦН ещё не триггерился",
                        "            //BuildOwnBase_InProcess == 1 - подготовка к постройке станции, нужно выбрать систему",
                        "            //BuildOwnBase_InProcess == 2 - подготовка к постройке станции, система выбрана, нужно получить разрешения",
                        "            //BuildOwnBase_InProcess == 3 - подготовка к постройке станции, все разрешения были получены, игрок отправляется на ЦН",
                        "            //BuildOwnBase_InProcess == 4 - игрок уже посетил ЦН после сбора бумаг, но строить штаб отказался, а потому во второй раз получит немного иной диалог",
                        "            //BuildOwnBase_InProcess == 5 - игрок уже строил штаб, но тот был разрушен, игрок получает третий вариант диалога",
                        "            //BuildOwnBase_InProcess == 6 - штаб построен",
                        "            check = GetValueFromScript('Mod_ShuMercsHQ', 'BuildOwnBase_InProcess');",
                        "            if(check <= 0)",
                        "            {",
                        "                if(!check) tstr1 = '</color>' + CT('Script.Mod_ShuMercs.CreatingPlayerOrgDialogs.MBPlayerAsk1');",
                        "                else if(check == -1) tstr1 = '</color>' + CT('Script.Mod_ShuMercs.CreatingPlayerOrgDialogs.MBPlayerAskAgain1');",
                        "                else tstr1 = '</color>' + CT('Script.Mod_ShuMercs.CreatingPlayerOrgDialogs.MBPlayerAskTwice1');",
                        "                AddDialogInject('Mod_ShuMercsHQ:OwnBaseDialogMB', '', tstr1, 10);",
                        "            }",
                        "            //Этот ответ игрока запускает диалог с непосредственным строительством собственного штаба наёмников",
                        "            else if(check >= 3 && check <= 5)",
                        "            {",
                        "                if(check == 3) tstr1 = '</color>' + CT('Script.Mod_ShuMercs.CreatingPlayerOrgDialogs.MBPlayerAskBuild');",
                        "                else if(check == 4) tstr1 = '</color>' + CT('Script.Mod_ShuMercs.CreatingPlayerOrgDialogs.MBPlayerAskBuildAgain');",
                        "                else tstr1 = '</color>' + CT('Script.Mod_ShuMercs.CreatingPlayerOrgDialogs.MBPlayerAskBuildTwice');",
                        "                AddDialogInject('Mod_ShuMercsHQ:OwnBaseDialogMB', '', tstr1, 10);",
                        "            }",
                        "            //Диалог о переименовании организации наёмников игрока",
                        "            else if(check == 6)",
                        "            {",
                        "                tstr1 = '</color>' + CT('Script.Mod_ShuMercs.CreatingPlayerOrgDialogs.PlayerAskRename');",
                        "                AddDialogInject('Mod_ShuMercsHQ:OwnBaseRenameDialogMB', '', tstr1, 10);",
                        "            }",
                        "        }",
                        "",
                        "        //Поправить отношения с наёмниками",
                        "        if(ShipType(cur_ruin) == 'MB' && !cur_call)",
                        "        {",
                        "            tstr1 = CT('Script.Mod_ShuMercs.' + dialogs_path + '.PlayerAskFixRelations');",
                        "            AddDialogInject('MB_FixRelations', '', tstr1, 5);",
                        "        }",
                        "    }",
                        "}"
                    ],
                    "#": 138,
                    "Type": "Top",
                    "Parent": -1,
                    "Pos.x": 180,
                    "Pos.y": 1035
                },
                {
                    "Name": "",
                    "Code.Type": "Turn",
                    "Code": [
                        "if (ShipType(CurShip) == 'Merc') {",
                        "  if (ShipPilotRace(CurShip) == Maloc) {",
                        "    RelationToRanger(CurShip, Player(), red_rel);",
                        "    if (!GroupCount(RedLeader)) ShipType(CurShip, 'Freelancer');",
                        "  } else if (ShipPilotRace(CurShip) == Fei) {",
                        "    RelationToRanger(CurShip, Player(), fei_rel);",
                        "    if (!GroupCount(FeiLeader)) ShipType(CurShip, 'Freelancer');",
                        "  } else {",
                        "    RelationToRanger(CurShip, Player(), atlant_rel);",
                        "    if (!GroupCount(AtlantLeader)) ShipType(CurShip, 'Freelancer');",
                        "  }",
                        "}",
                        "if(0) {",
                        "  if(Id(CurShip) == free_id) {",
                        "    i = IdToShip(target_id);",
                        "    s = CurShip;",
                        "    if(ShipInNormalSpace(s) && i) {",
                        "      if(ShipStar(s) == ShipStar(i)) {",
                        "        ChangeState(15);",
                        "        exit;",
                        "      }",
                        "      if(ShipStar(s) != ShipStar(i)) {",
                        "        ChangeState(14);",
                        "        exit;",
                        "      }",
                        "    }",
                        "    if(!i || !free_id || CurTurn() > free_timer - 30) {",
                        "      target_id = 0;",
                        "      OrderLock(CurShip, 0);",
                        "      ",
                        "      if(!free_id && CurTurn() <= free_timer - 30) {",
                        "          if(GroupCount(MercCenter)) Ether(4, '', Format(CT(\"Script.Mod_ShuMercs.109\"),\"<0>\",free_name,\"<1>\",target_name));",
                        "      }",
                        "      else if(CurTurn() > free_timer - 30 && GroupCount(MercCenter)) {",
                        "          Ether(5, '', Format(CT(\"Script.Mod_ShuMercs.108\"),\"<0>\",free_name,\"<1>\",target_name));",
                        "      }",
                        "      free_id = 0;",
                        "      ChangeState(0);",
                        "      exit;",
                        "    }",
                        "  }",
                        "}"
                    ],
                    "#": 332,
                    "Type": "Top",
                    "Parent": -1,
                    "Pos.x": 80
                },
                {
                    "Name": "",
                    "Code.Type": "Turn",
                    "Code": [
                        "if(ShipGetBad(CurShip)==Player())",
                        "{",
                        "    s=CurShip;",
                        "    ShipSetBad(CurShip,0);",
                        "    TruceBetweenShips(CurShip,Player());",
                        "    exit;",
                        "}",
                        "",
                        "if(GetShipRuins(CurShip))OrderTakeOff(CurShip);",
                        "",
                        "raid_status=1;",
                        "",
                        "if(ShipType(CurShip)=='Merc')",
                        "{",
                        "    if(ShipPilotRace(CurShip)==0 && !GroupCount(RedLeader))ShipType(CurShip,'Freelancer');",
                        "    else if((ShipPilotRace(CurShip)==1 || ShipPilotRace(CurShip)==2) && !GroupCount(AtlantLeader))ShipType(CurShip,'Freelancer');",
                        "    else if(ShipPilotRace(CurShip)==3 && !GroupCount(FeiLeader))ShipType(CurShip,'Freelancer');",
                        "}",
                        "",
                        "if(ShipType(CurShip)=='Merc' || ShipType(CurShip)=='AtlantLeader' || ShipType(CurShip)=='RedLeader' || ShipType(CurShip)=='FeiLeader')",
                        "{",
                        "    if(ShipPilotRace(CurShip)==0)RelationToRanger(CurShip,Player(),red_rel);",
                        "    else if(ShipPilotRace(CurShip)==3)RelationToRanger(CurShip,Player(),fei_rel);",
                        "    else RelationToRanger(CurShip,Player(),atlant_rel);",
                        "}",
                        "",
                        "if(!GroupCount(MercCenter) && ShipType(CurShip)=='Merc')",
                        "{",
                        "    OrderLock(CurShip,0);",
                        "    if(ShipPilotRace(CurShip)==3)ShipJoin(gFeis,CurShip);",
                        "    else if(ShipPilotRace(CurShip)==0)ShipJoin(gReds,CurShip);",
                        "    else ShipJoin(gAtlant,CurShip);",
                        "}",
                        "if(ShipInNormalSpace(CurShip)) {",
                        "  ChangeState(2);",
                        "  exit;",
                        "}"
                    ],
                    "#": 333,
                    "Type": "Top",
                    "Parent": -1,
                    "Pos.x": 160
                },
                {
                    "Name": "",
                    "Code.Type": "Turn",
                    "Code": [
                        "if(ShipGetBad(CurShip)==Player())",
                        "{",
                        "    s=CurShip;",
                        "    ShipSetBad(CurShip,0);",
                        "    TruceBetweenShips(CurShip,Player());",
                        "    exit;",
                        "}",
                        "",
                        "OrderJump(CurShip,GalaxyStar(raid_star));",
                        "",
                        "if(ShipType(CurShip)=='Merc')",
                        "{",
                        "    if(ShipPilotRace(CurShip)==0 && !GroupCount(RedLeader))ShipType(CurShip,'Freelancer');",
                        "    else if((ShipPilotRace(CurShip)==1 || ShipPilotRace(CurShip)==2) && !GroupCount(AtlantLeader))ShipType(CurShip,'Freelancer');",
                        "    else if(ShipPilotRace(CurShip)==3 && !GroupCount(FeiLeader))ShipType(CurShip,'Freelancer');",
                        "}",
                        "",
