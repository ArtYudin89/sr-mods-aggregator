                    "Name": "",
                    "Code.Type": "Turn",
                    "Code": [
                        "tint2=ShipPartners(Player())+PlayerPirates();",
                        "//Добавляем ответы с выбором числа наёмников, которых игрок может нанять в подчинение",
                        "for(i=1; i<=6; i=i+1)",
                        "{",
                        "    if(i == 1)tstr1=CT(\"Script.Mod_ShuMercs.119\");",
                        "    else if(i == 2)tstr1=CT(\"Script.Mod_ShuMercs.120\");",
                        "    else if(i == 3)tstr1=CT(\"Script.Mod_ShuMercs.121\");",
                        "    else if(i == 4)tstr1=CT(\"Script.Mod_ShuMercs.122\");",
                        "    else if(i == 5)tstr1=CT(\"Script.Mod_ShuMercs.123\");",
                        "    else if(i == 6)tstr1=CT(\"Script.Mod_ShuMercs.124\");",
                        "",
                        "    if(tint2 <= (6-i) && Soldats >= i)InjectAnswer('HireMBChoose',tstr1,i);",
                        "    else",
                        "    {",
                        "        AddDialogBlock(tstr1,1);",
                        "        InjectAnswer('HireMBChoose',tstr1,i);",
                        "    }",
                        "}",
                        "DAnswer('restart~'+CT(\"Script.Mod_ShuMercs.114\"));"
                    ],
                    "#": 384,
                    "Type": "Top",
                    "Parent": -1,
                    "Pos.x": 130,
                    "Pos.y": 670
                },
                {
                    "Name": "",
                    "Code.Type": "Turn",
                    "Code": [
                        "if(Squad!=1 && Soldats>=3 && Squad!=4 && ShipSkill(Player(),5)>=2 && ShipRank(Player())>=3 || Squad!=4 && Squad!=1 && Soldats>=3 && ShipSkill(Player(),5)>=2 && GetShipPirateRank(Player())>=3) {",
                        "  if(CurTurn()>=timer_attack) {",
                        "    DAdd(5);",
                        "  }",
                        "  if(CurTurn()<timer_attack) {",
                        "    DAdd(51);",
                        "  }",
                        "}",
                        "DAdd(6);",
                        "if(ShipRank(Player())>=1 && Squad!=2 && Soldats>=3 || Squad!=2 && GetShipPirateRank(Player())>=1 && Soldats>=3) {",
                        "  if(Squad == 3) i = timer_raid + 60;",
                        "  else i = timer_raid;",
                        "  if(CurTurn() >= i) {",
                        "    DAdd(8);",
                        "  }",
                        "  if(CurTurn() < i) {",
                        "    DAdd(50);",
                        "  }",
                        "}",
                        "DAdd(4);",
                        "DAdd(0);"
                    ],
