                        "\t\tif(PlanetWarriors(temp_dword_2)<=0)temp_str=temp_str+CT(\"Script.Mod_ExpCB.179\");",
                        "\t\t//Добавляем разделитель, если текущая планета не последняя в системе",
                        "\t\t//temp_str=temp_str+\"<br>\"+DefSplt;",
                        "\t\tif(j!=LastPlanet)temp_str=temp_str+CT(\"Script.Mod_ExpCB.16\")+CT(\"Script.Mod_ExpCB.16\");",
                        "\t}",
                        "\t//Сравниваем количество военных кораблей в системе и на планетах, вычисляем точное количество военных кораблей в системе",
                        "\tfor(j=0;j<StarShips(temp_dword);j=j+1)",
                        "\t{",
                        "\t\ttemp_dword_3=StarShips(temp_dword,j);",
                        "\t\ttemp_str2=ShipType(temp_dword_3);",
                        "\t\t//Считаем все корабли в космическом пространстве системы",
                        "\t\t//По Id сверяем корабли на планете и в системе, дабы не произошёл двойной зачёт одного и того же корабля",
                        "\t\t//Да, именно так работает функция StarShips - может учесть корабль на планете, а может не учесть",
                        "\t\tif(temp_str2=='Warrior')",
                        "\t\t{",
                        "\t\t\tif(ShipSubType(temp_dword_3)==0)",
                        "\t\t\t{",
                        "\t\t\t\tif(findsubstr(CheckById,'$'+Id(temp_dword_3)+'$')==-1)",
                        "\t\t\t\t{",
                        "\t\t\t\t\tShipsInSys=ShipsInSys+1;",
                        "\t\t\t\t\tNShipInSys[3]=NShipInSys[3]+1;",
