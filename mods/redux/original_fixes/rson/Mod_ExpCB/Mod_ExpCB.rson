                        "\tShipsInSys=0;",
                        "\ttemp_str=Format(CT(\"Script.Mod_ExpCB.212\"),\"<0>\",StarName(temp_dword),\"<1>\",ConName(StarToCon(temp_dword)));",
                        "\t//Вычисляем номер последней обитаемой планеты системы",
                        "\tfor(j=0;j<StarPlanets(temp_dword);j=j+1)",
                        "\t{",
                        "\t\tif(PlanetOwner(StarPlanets(temp_dword,j))==6)continue;",
