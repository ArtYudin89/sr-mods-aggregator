                {
                    "Name": "",
                    "Code.Type": "Turn",
                    "Code": [
                        "//Добавляем ответы игрока для приобретения микромодулей:",
                        "//1 - ММ первого уровня",
                        "//2 - ММ второго уровня",
                        "//3 - ММ третьего уровня",
                        "//temp_int_1 - общее число нодов игрока в \"наличке\" (трюм + склад)",
                        "//temp_int_2 - число нодов игрока на его счету",
                        "//modules[i, 0] - номер бонуса ММ соответствующего N уровня",
                        "//modules[i, 1] - пиратская стоимость текущего ММ при оплате \"наличкой\" с учётом скидки",
                        "//modules[i, 2] - пиратская стоимость текущего ММ при оплате с нод-счёта с учётом скидки",
                        "j = 0;",
                        "for(i = 1; i <= 3; i = i + 1)",
                        "{",
                        "    //Если игрок может купить ММ чисто за \"наличку\", добавляем соответствующий вариант",
                        "\tif(temp_int_1 >= modules[i, 1])",
                        "\t{",
                        "        temp_str = Format(CT('FormRuins.CB.TakeNod.BuyCashIn'), '<Cost' + '>', modules[i, 1], '<Name' + '>', BonusName(modules[i, 0]));",
                        "\t\tInjectAnswer('BuyMMNoCount', temp_str, i);",
                        "\t\tj = 1;",
                        "\t}",
                        "    else",
                        "\t{",
                        "\t\t//Если в \"наличке\" у игрока не пусто",
                        "\t\tif(temp_int_1)",
                        "\t\t{",
                        "\t\t\t//Если нод-счёт игрока не пуст",
                        "\t\t\tif(temp_int_2)",
                        "\t\t\t{",
                        "\t\t\t\t//Пересчитываем возможность приобретения ММ за \"наличку\" + за ноды со счёта",
                        "\t\t\t\ttemp_int = modules[i, 1] - temp_int_1;",
                        "\t\t\t\ttemp_int = round(1.5 * temp_int);",
                        "\t\t\t\t//Если игрок может купить ММ за \"наличку\" + за ноды со счёта, добавляем соответствующий вариант",
                        "\t\t\t\tif(temp_int_2 >= temp_int)",
                        "\t\t\t\t{",
                        "                    modules[0, i] = temp_int;",
                        "                    temp_str = Format(CT('FormRuins.CB.TakeNod.BuyCashInPlusCount'), '<Cost1' + '>', temp_int_1, '<Cost2' + '>', temp_int, '<Name' + '>', BonusName(modules[i, 0]));",
                        "\t\t\t\t\tInjectAnswer('BuyMMPartCount', temp_str, i);",
                        "",
                        "\t\t\t\t\tj = 1;",
                        "\t\t\t\t}",
                        "\t\t\t}",
                        "\t\t}",
                        "\t\t//Если \"наличка\" игрока пуста",
                        "\t\telse",
                        "\t\t{",
                        "\t\t\t//Если игрок может купить ММ чисто за ноды со счёта, добавляем соответствующий вариант",
                        "\t\t\tif(temp_int_2 >= modules[i, 2])",
                        "\t\t\t{",
                        "                temp_str = Format(CT('FormRuins.CB.TakeNod.BuyCount'), '<Cost' + '>', modules[i, 2], '<Name' + '>', BonusName(modules[i, 0]));",
                        "\t\t\t\tInjectAnswer('BuyMMFullCount', temp_str, i);",
                        "",
                        "\t\t\t\tj = 1;",
                        "\t\t\t}",
                        "\t\t}",
                        "\t}",
                        "",
                        "    //Если покупка ММ для игрока в принципе невозможна, добавляем заблокированный вариант",
                        "\tif(!j)",
                        "\t{",
                        "\t\ttemp_str = Format(CT('FormRuins.CB.TakeNod.BuyCashIn'), '<Cost' + '>', modules[i, 1], '<Name' + '>', BonusName(modules[i, 0]), '');",
                        "\t\tAddDialogBlock(temp_str, 1);",
                        "\t\tInjectAnswer('Blocked', temp_str, i);",
                        "\t}",
                        "}",
                        "DAdd(4);"
                    ],
