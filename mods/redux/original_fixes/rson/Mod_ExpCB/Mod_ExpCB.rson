                        "\t\t{",
                        "\t\t\tif(findsubstr(CheckById,'$'+Id(temp_dword_3)+'$')==-1)",
                        "\t\t\t{",
                        "\t\t\t\tShipsInSys=ShipsInSys+1;",
                        "\t\t\t\tNShipInSys[12]=NShipInSys[12]+1;",
                        "\t\t\t}",
                        "\t\t}",
                        "\t\telse if(temp_str2=='Dreadnought')",
                        "\t\t{",
                        "\t\t\tif(findsubstr(CheckById,'$'+Id(temp_dword_3)+'$')==-1)",
                        "\t\t\t{",
                        "\t\t\t\tShipsInSys=ShipsInSys+1;",
                        "\t\t\t\tNShipInSys[18]=NShipInSys[18]+1;",
                        "\t\t\t}",
                        "\t\t}",
                        "\t}",
                        "\t//Общее число военных кораблей в системе",
                        "\ttemp_int_1=temp_int_1+(ShipsInSys-WarsOnWing);",
                        "\t//Общее число обычных военных в системе",
                        "\tNShipInSys[1]=NShipInSys[1]+(NShipInSys[3]-NShipInSys[2]);",
                        "\t//Общее число флагманов в системе",
                        "\tNShipInSys[4]=NShipInSys[4]+(NShipInSys[6]-NShipInSys[5]);",
                        "\t//Общее число ополченцев в системе",
                        "\tNShipInSys[7]=NShipInSys[7]+(NShipInSys[9]-NShipInSys[8]);",
                        "\t//Общее число элитных военных в системе",
                        "\tNShipInSys[10]=NShipInSys[10]+(NShipInSys[12]-NShipInSys[11]);",
                        "\t//Общее число баттлстаров в системе",
                        "\t//NShipInSys[13]=NShipInSys[13]+(NShipInSys[15]-NShipInSys[14]);",
                        "\t//Общее число прокси в системе",
                        "\tNShipInSys[16]=NShipInSys[16]+(NShipInSys[18]-NShipInSys[17]);",
                        "\t//Дописываем строке \"подвал\", содержащий общее число всех кораблей в системе",
                        "\tif(temp_int_1!=0)",
                        "\t{",
                        "\t\ttemp_str=temp_str+CT(\"Script.Mod_ExpCB.16\")+CT(\"Script.Mod_ExpCB.16\")+DefSplt+CT(\"Script.Mod_ExpCB.16\")+CT(\"Script.Mod_ExpCB.222\")+CT(\"Script.Mod_ExpCB.16\")+DefSplt;",
                        "\t\tif(NShipInSys[7]!=0)temp_str=temp_str+Format(CT(\"Script.Mod_ExpCB.174\"),\"<0>\",NShipInSys[7]);",
                        "\t\tif(NShipInSys[1]!=0)temp_str=temp_str+Format(CT(\"Script.Mod_ExpCB.197\"),\"<0>\",NShipInSys[1]);",
                        "\t\tif(NShipInSys[10]!=0)temp_str=temp_str+Format(CT(\"Script.Mod_ExpCB.196\"),\"<0>\",NShipInSys[10]);",
                        "\t\tif(NShipInSys[4]!=0)temp_str=temp_str+Format(CT(\"Script.Mod_ExpCB.252\"),\"<0>\",NShipInSys[4]);",
                        "\t\t//if(NShipInSys[13]!=0)temp_str=temp_str+\"<br>Баттлстаров: <NShipInSys[13]>\";",
                        "\t\tif(NShipInSys[16]!=0)temp_str=temp_str+Format(CT(\"Script.Mod_ExpCB.249\"),\"<0>\",NShipInSys[16]);",
                        "\t}",
                        "\telse temp_str=temp_str+CT(\"Script.Mod_ExpCB.213\");",
                        "\t//Заполняем основной массив temp_array с подробной информацией о системах",
                        "\tArrayAdd(temp_array,temp_str);",
                        "\t//Составляем и добавляем в массив temp_array_2 строчки краткого обзора списка систем",
                        "\tif(temp_int_1!=0)temp_str=Format(CT(\"Script.Mod_ExpCB.192\"),\"<0>\",StarName(temp_dword),\"<1>\",ConName(StarToCon(temp_dword)),\"<2>\",temp_int_1);",
                        "\tif(temp_int_1==0)temp_str=Format(CT(\"Script.Mod_ExpCB.191\"),\"<0>\",StarName(temp_dword),\"<1>\",ConName(StarToCon(temp_dword)));",
                        "\tArrayAdd(temp_array_2,temp_str);",
                        "\t//Добавляем в массив temp_array_3 список систем для подстановки в ответы",
                        "\t//Сраная \"трёхметровая\" Витта Прайонис удостоилась отдельной проверки",
                        "\tif(StarName(temp_dword)==CT(\"Script.Mod_ExpCB.210\"))ArrayAdd(temp_array_3,CT(\"Script.Mod_ExpCB.209\"));",
                        "\telse ArrayAdd(temp_array_3,CT(\"Script.Mod_ExpCB.208\")+Format(' <0>',\"<0>\",StarName(temp_dword)));",
                        "\t//Добавляем вспомогательный массив с числом кораблей в системах",
                        "\tArrayAdd(temp_array_4,temp_int_1);",
                        "\ttemp_str='';",
                        "\tCheckById='';",
                        "\ttemp_int_1=0;",
                        "\tWarsOnWing=0;",
                        "\tShipsInSys=0;",
                        "\tLastPlanet=0;",
                        "\tArrayClear(NShipInSys);",
                        "}",
                        "temp_str='';",
                        "//Функция сортировки массивов работает странно",
                        "//В итоге я решил не сортировать вообще, т.к. не вижу особого смысла",
                        "//ArraySort(temp_array,temp_array_4);",
                        "//ArraySort(temp_array_2,temp_array_4);",
                        "//ArraySort(temp_array_3,temp_array_4);",
                        "",
                        "//Расставляем разделители в списке систем",
                        "for(i = 1; i < ArrayDim(temp_array_2); i = i + 1)",
                        "{",
                        "\ttemp_str = temp_str + Format('<0>',\"<0>\",temp_array_2[i]);",
                        "\tif((i + 2) <= ArrayDim(temp_array_2))",
                        "\t{",
                        "\t\tif(GetGameOptions('FontDialog') == 0) temp_str = temp_str + CT(\"Script.Mod_ExpCB.16\") + '------------------------------' + CT(\"Script.Mod_ExpCB.16\");",
                        "\t\telse if(GetGameOptions('FontDialog') == 1) temp_str = temp_str + CT(\"Script.Mod_ExpCB.16\") + '--------------------------' + CT(\"Script.Mod_ExpCB.16\");",
                        "\t\telse if(GetGameOptions('FontDialog') == 2) temp_str = temp_str + CT(\"Script.Mod_ExpCB.16\") + '---------------------------' + CT(\"Script.Mod_ExpCB.16\");",
                        "\t\telse temp_str = temp_str + CT(\"Script.Mod_ExpCB.16\") + '--------------------------' + CT(\"Script.Mod_ExpCB.16\");",
                        "\t}",
                        "}",
                        "//Вычисляем количество всех военных кораблей в галактике",
                        "ArrayAdd(temp_array_4, 0);",
                        "for(i = 1; i < ArrayDim(temp_array_4); i = i + 1)",
                        "{",
                        "\tif((i - 1) != temp_array_4[ArrayDim(temp_array_4) - 1]) temp_array_4[ArrayDim(temp_array_4) - 1] = temp_array_4[ArrayDim(temp_array_4) - 1] + temp_array_4[i - 1];",
                        "}",
                        "",
                        "//Выставляем реплику в зависимости от того барон или не барон игрок",
                        "//А также в зависимости от того, производилась ли сегодня оплата разведданных",
                        "if(temp_int_2 == 0)",
                        "{",
                        "\tSpeechRec = '</color>' + Format(CT(\"Script.Mod_ExpCB.239\"),\"<0>\",temp_str,\"<1>\",temp_array_4[ArrayDim(temp_array_4) - 1]);",
                        "}",
                        "if(PayCheck != 0) temp_int_2 = -1;",
                        "if(temp_int_2 == -1)",
                        "{",
                        "\tSpeechRec = '</color>' + Format(CT(\"Script.Mod_ExpCB.238\"),\"<0>\",temp_str,\"<1>\",temp_array_4[ArrayDim(temp_array_4) - 1]);",
                        "}",
                        "if(temp_int_2 > 0)",
                        "{",
                        "\tSpeechRec = Format(CT(\"Script.Mod_ExpCB.141\"),\"<0>\",temp_int_2);",
                        "\tAnswerRec = CT(\"Script.Mod_ExpCB.219\");",
                        "}",
                        "DChange(4);",
                        "exit;"
