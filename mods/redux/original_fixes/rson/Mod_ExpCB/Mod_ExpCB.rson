                        "\t\t\t\t\t\t\t\ttemp_int_1=temp_int_1-1;",
                        "\t\t\t\t\t\t\t}",
                        "\t\t\t\t\t\t}",
                        "\t\t\t\t\t\t//А это её конец",
                        "\t\t\t\t\t}",
                        "\t\t\t\t\tif(ShipSubType(temp_dword_3)==1)",
                        "\t\t\t\t\t{",
