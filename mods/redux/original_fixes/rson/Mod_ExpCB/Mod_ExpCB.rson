                        "\t\ttemp_str=temp_str+DefSplt+CT(\"Script.Mod_ExpCB.16\")+Format(CT(\"Script.Mod_ExpCB.200\"),\"<0>\",PlanetName(temp_dword_2))+CT(\"Script.Mod_ExpCB.16\")+DefSplt;",
                        "\t\t//Проверяем наличие на планете военных кораблей",
                        "\t\tif(PlanetWarriors(temp_dword_2)>=1)",
                        "\t\t{",
                        "\t\t\ttemp_int_1=temp_int_1+PlanetWarriors(temp_dword_2);",
                        "\t\t\t//Формируем строчку подробной информации о кораблях на планете",
                        "\t\t\tfor(k=0;k<=(PlanetWarriors(temp_dword_2)-1);k=k+1)",
                        "\t\t\t{",
                        "\t\t\t\ttemp_dword_3=PlanetWarriors(temp_dword_2,k);",
                        "\t\t\t\ttemp_str2=ShipType(temp_dword_3);",
                        "\t\t\t\t//Считаем \"истребители\"",
                        "\t\t\t\t//Я пытался подставить функцию проверки статуса в иниткод, но в ней не сработала подстановка аргументов",
                        "\t\t\t\t//В итоге забил и просто продублировал её шесть раз",
                        "\t\t\t\tif(temp_str2=='Warrior')",
                        "\t\t\t\t{",
                        "\t\t\t\t\tif(ShipSubType(temp_dword_3)==0)",
                        "\t\t\t\t\t{",
                        "\t\t\t\t\t\tTypeName=CT(\"Script.Mod_ExpCB.199\");",
                        "\t\t\t\t\t\t//Здесь начинается та самая функция",
                        "\t\t\t\t\t\tif(ShipInPlanet(temp_dword_3,temp_dword_2)==1)",
                        "\t\t\t\t\t\t{",
                        "\t\t\t\t\t\t\tEndLine=CT(\"Script.Mod_ExpCB.150\")+'</color>';",
                        "\t\t\t\t\t\t\tNShipInSys[1]=NShipInSys[1]+1;",
                        "\t\t\t\t\t\t\t//Заполняем строку с Id всех кораблей на планетах",
                        "\t\t\t\t\t\t\t//Позже она понадобиться для перепроверки работы кривой функции StarShips",
                        "\t\t\t\t\t\t\tif(CheckById=='')CheckById=CheckById+'$'+Id(temp_dword_3)+'$';",
                        "\t\t\t\t\t\t\telse CheckById=CheckById+',$'+Id(temp_dword_3)+'$';",
