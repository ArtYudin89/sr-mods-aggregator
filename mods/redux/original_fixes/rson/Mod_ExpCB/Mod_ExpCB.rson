                    "#": 98,
                    "Type": "Top",
                    "Parent": -1,
                    "Pos.x": 460,
                    "Pos.y": 590
                },
                {
                    "Name": "",
                    "Code.Type": "Turn",
                    "Code": [
                        "ShipMoney(Player(), ShipMoney(Player()) - temp_int_2);",
                        "Sound('Sound.Buy');",
                        "ThanksForMoney = CT(\"Script.Mod_ExpCB.207\");",
                        "PayCheck = 1;",
                        "ThanksForMoney = '';",
                        "",
                        "ArrayClear(temp_array);",
                        "ArrayClear(temp_array_2);",
                        "ArrayClear(temp_array_3);",
                        "ArrayClear(temp_array_4);",
                        "temp_str = '';",
                        "//Задаём длину разделительной \"дефисной линии\" в зависимости от установленного в игре шрифта",
                        "if(GetGameOptions('FontDialog') == 0) DefSplt = '-------------------------------------------------------------';",
                        "else if(GetGameOptions('FontDialog') == 1) DefSplt =  '------------------------------------------';",
                        "else if(GetGameOptions('FontDialog') == 2) DefSplt = '-----------------------------------------';",
                        "else DefSplt = '-------------------------------------';",
                        "",
                        "//Высчитываем цену запроса разведсводки (250 и 150 здесь эмулируют 2.5% и 1.5%)",
                        "temp_int_2 = ((ShipMoney(Player()) * (250 - ((ShipStatus(Player(), 1) * 150) / 100))) / 100) / 100;",
                        "",
                        "//Разброс минимальной цены в зависимости от пиратского рейтинга",
                        "if(temp_int_2 < 500 && ShipStatus(Player(), 1) >= 66) temp_int_2 = 500;",
                        "if(temp_int_2 < 750 && (ShipStatus(Player(), 1) < 66 && ShipStatus(Player(), 1) >= 33)) temp_int_2 = 750;",
                        "if(temp_int_2 < 1000 && ShipStatus(Player(), 1) < 33) temp_int_2 = 1000;",
                        "//Проверяем, не барон ли в данный момент игрок",
                        "if(GetShipPirateRank(Player()) >= 7) temp_int_2 = 0;",
                        "",
                        "//Циклы поиска информации о числе и типах военных кораблей",
                        "for(i = 0; i < GalaxyStars(); i = i + 1)",
                        "{",
                        "\ttemp_dword = GalaxyStar(i);",
                        "\tif(StarOwner(temp_dword) != 0) continue;",
                        "\tArrayClear(NShipInSys);",
                        "",
                        "\tfor(j = 1; j <= 18; j = j + 1) ArrayAdd(NShipInSys, 0);",
                        "\ttemp_int_1=0;",
                        "\tWarsOnWing=0;",
                        "\tShipsInSys=0;",
                        "\ttemp_str=Format(CT(\"Script.Mod_ExpCB.212\"),\"<0>\",StarName(temp_dword),\"<1>\",ConName(StarToCon(temp_dword)));",
                        "\t//Вычисляем номер последней обитаемой планеты системы",
                        "\tfor(j=0;j<StarPlanets(temp_dword);j=j+1)",
                        "\t{",
                        "\t\tif(PlanetOwner(StarPlanets(temp_dword,j))==6)continue;",
                        "\t\tLastPlanet=j;",
                        "\t}",
                        "\t//Перебираем все планеты в системе, составляем список",
                        "\tfor(j=0;j<StarPlanets(temp_dword);j=j+1)",
                        "\t{",
                        "\t\ttemp_dword_2=StarPlanets(temp_dword,j);",
                        "\t\tif(PlanetOwner(temp_dword_2)==6)continue;",
                        "\t\ttemp_str=temp_str+DefSplt+CT(\"Script.Mod_ExpCB.16\")+Format(CT(\"Script.Mod_ExpCB.200\"),\"<0>\",PlanetName(temp_dword_2))+CT(\"Script.Mod_ExpCB.16\")+DefSplt;",
                        "\t\t//Проверяем наличие на планете военных кораблей",
                        "\t\tif(PlanetWarriors(temp_dword_2)>=1)",
                        "\t\t{",
                        "\t\t\ttemp_int_1=temp_int_1+PlanetWarriors(temp_dword_2);",
                        "\t\t\t//Формируем строчку подробной информации о кораблях на планете",
                        "\t\t\tfor(k=0;k<=(PlanetWarriors(temp_dword_2)-1);k=k+1)",
                        "\t\t\t{",
                        "\t\t\t\ttemp_dword_3=PlanetWarriors(temp_dword_2,k);",
                        "\t\t\t\ttemp_str2=ShipType(temp_dword_3);",
                        "\t\t\t\t//Считаем \"истребители\"",
                        "\t\t\t\t//Я пытался подставить функцию проверки статуса в иниткод, но в ней не сработала подстановка аргументов",
                        "\t\t\t\t//В итоге забил и просто продублировал её шесть раз",
                        "\t\t\t\tif(temp_str2=='Warrior')",
                        "\t\t\t\t{",
                        "\t\t\t\t\tif(ShipSubType(temp_dword_3)==0)",
                        "\t\t\t\t\t{",
                        "\t\t\t\t\t\tTypeName=CT(\"Script.Mod_ExpCB.199\");",
                        "\t\t\t\t\t\t//Здесь начинается та самая функция",
                        "\t\t\t\t\t\tif(ShipInPlanet(temp_dword_3,temp_dword_2)==1)",
                        "\t\t\t\t\t\t{",
                        "\t\t\t\t\t\t\tEndLine=CT(\"Script.Mod_ExpCB.150\")+'</color>';",
                        "\t\t\t\t\t\t\tNShipInSys[1]=NShipInSys[1]+1;",
                        "\t\t\t\t\t\t\t//Заполняем строку с Id всех кораблей на планетах",
                        "\t\t\t\t\t\t\t//Позже она понадобиться для перепроверки работы кривой функции StarShips",
                        "\t\t\t\t\t\t\tif(CheckById=='')CheckById=CheckById+'$'+Id(temp_dword_3)+'$';",
                        "\t\t\t\t\t\t\telse CheckById=CheckById+',$'+Id(temp_dword_3)+'$';",
                        "\t\t\t\t\t\t}",
                        "\t\t\t\t\t\telse",
                        "\t\t\t\t\t\t{",
                        "\t\t\t\t\t\t\t//Если корабль не на планете, то проверяем в какой он системе",
                        "\t\t\t\t\t\t\tif(ShipInStar(temp_dword_3,temp_dword)==1)",
                        "\t\t\t\t\t\t\t{",
                        "\t\t\t\t\t\t\t\tEndLine=CT(\"Script.Mod_ExpCB.149\")+'</color>';",
                        "\t\t\t\t\t\t\t\tNShipInSys[1]=NShipInSys[1]+1;",
                        "\t\t\t\t\t\t\t\tNShipInSys[2]=NShipInSys[2]+1;",
                        "\t\t\t\t\t\t\t\tWarsOnWing=WarsOnWing+1;",
                        "\t\t\t\t\t\t\t}",
                        "\t\t\t\t\t\t\telse",
                        "\t\t\t\t\t\t\t{",
                        "\t\t\t\t\t\t\t\tEndLine=CT(\"Script.Mod_ExpCB.202\")+' '+StarName(ShipStar(temp_dword_3))+'</color>';",
                        "\t\t\t\t\t\t\t\ttemp_int_1=temp_int_1-1;",
                        "\t\t\t\t\t\t\t}",
                        "\t\t\t\t\t\t}",
                        "\t\t\t\t\t\t//А это её конец",
                        "\t\t\t\t\t}",
                        "\t\t\t\t\tif(ShipSubType(temp_dword_3)==1)",
                        "\t\t\t\t\t{",
                        "\t\t\t\t\t\tTypeName=CT(\"Script.Mod_ExpCB.253\");",
                        "\t\t\t\t\t\tif(ShipInPlanet(temp_dword_3,temp_dword_2)==1)",
                        "\t\t\t\t\t\t{",
                        "\t\t\t\t\t\t\tEndLine=CT(\"Script.Mod_ExpCB.150\")+'</color>';",
                        "\t\t\t\t\t\t\tNShipInSys[4]=NShipInSys[4]+1;",
                        "\t\t\t\t\t\t\tif(CheckById=='')CheckById=CheckById+'$'+Id(temp_dword_3)+'$';",
                        "\t\t\t\t\t\t\telse CheckById=CheckById+',$'+Id(temp_dword_3)+'$';",
                        "\t\t\t\t\t\t}",
                        "\t\t\t\t\t\telse",
                        "\t\t\t\t\t\t{",
                        "\t\t\t\t\t\t\t//Если корабль не на планете, то проверяем в какой он системе",
                        "\t\t\t\t\t\t\tif(ShipInStar(temp_dword_3,temp_dword)==1)",
                        "\t\t\t\t\t\t\t{",
                        "\t\t\t\t\t\t\t\tEndLine=CT(\"Script.Mod_ExpCB.149\")+'</color>';",
                        "\t\t\t\t\t\t\t\tNShipInSys[4]=NShipInSys[4]+1;",
                        "\t\t\t\t\t\t\t\tNShipInSys[5]=NShipInSys[5]+1;",
                        "\t\t\t\t\t\t\t\tWarsOnWing=WarsOnWing+1;",
                        "\t\t\t\t\t\t\t}",
                        "\t\t\t\t\t\t\telse",
                        "\t\t\t\t\t\t\t{",
                        "\t\t\t\t\t\t\t\tEndLine=CT(\"Script.Mod_ExpCB.202\")+' '+StarName(ShipStar(temp_dword_3))+'</color>';",
                        "\t\t\t\t\t\t\t\ttemp_int_1=temp_int_1-1;",
                        "\t\t\t\t\t\t\t}",
                        "\t\t\t\t\t\t}",
                        "\t\t\t\t\t}",
                        "\t\t\t\t}",
                        "\t\t\t\telse if(temp_str2=='Militiaman1' || temp_str2=='Militiaman2' || temp_str2=='Militiaman3')",
                        "\t\t\t\t{",
                        "\t\t\t\t\tTypeName=CT(\"Script.Mod_ExpCB.163\");",
                        "\t\t\t\t\tif(ShipInPlanet(temp_dword_3,temp_dword_2)==1)",
                        "\t\t\t\t\t{",
                        "\t\t\t\t\t\tEndLine=CT(\"Script.Mod_ExpCB.150\")+'</color>';",
                        "\t\t\t\t\t\tNShipInSys[7]=NShipInSys[7]+1;",
                        "\t\t\t\t\t\tif(CheckById=='')CheckById=CheckById+'$'+Id(temp_dword_3)+'$';",
                        "\t\t\t\t\t\telse CheckById=CheckById+',$'+Id(temp_dword_3)+'$';",
                        "\t\t\t\t\t}",
                        "\t\t\t\t\telse",
                        "\t\t\t\t\t{",
                        "\t\t\t\t\t\t//Если корабль не на планете, то проверяем в какой он системе",
                        "\t\t\t\t\t\tif(ShipInStar(temp_dword_3,temp_dword)==1)",
                        "\t\t\t\t\t\t{",
                        "\t\t\t\t\t\t\tEndLine=CT(\"Script.Mod_ExpCB.149\")+'</color>';",
                        "\t\t\t\t\t\t\tNShipInSys[7]=NShipInSys[7]+1;",
                        "\t\t\t\t\t\t\tNShipInSys[8]=NShipInSys[8]+1;",
                        "\t\t\t\t\t\t\tWarsOnWing=WarsOnWing+1;",
                        "\t\t\t\t\t\t}",
                        "\t\t\t\t\t\telse",
                        "\t\t\t\t\t\t{",
                        "\t\t\t\t\t\t\tEndLine=CT(\"Script.Mod_ExpCB.202\")+' '+StarName(ShipStar(temp_dword_3))+'</color>';",
                        "\t\t\t\t\t\t\ttemp_int_1=temp_int_1-1;",
                        "\t\t\t\t\t\t}",
                        "\t\t\t\t\t}",
                        "\t\t\t\t}",
                        "\t\t\t\telse if(temp_str2=='EliteWarrior')",
                        "\t\t\t\t{",
                        "\t\t\t\t\tTypeName=CT(\"Script.Mod_ExpCB.198\");",
                        "\t\t\t\t\tif(ShipInPlanet(temp_dword_3,temp_dword_2)==1)",
                        "\t\t\t\t\t{",
                        "\t\t\t\t\t\tEndLine=CT(\"Script.Mod_ExpCB.150\")+'</color>';",
                        "\t\t\t\t\t\tNShipInSys[10]=NShipInSys[10]+1;",
                        "\t\t\t\t\t\tif(CheckById=='')CheckById=CheckById+'$'+Id(temp_dword_3)+'$';",
                        "\t\t\t\t\t\telse CheckById=CheckById+',$'+Id(temp_dword_3)+'$';",
                        "\t\t\t\t\t}",
                        "\t\t\t\t\telse",
                        "\t\t\t\t\t{",
                        "\t\t\t\t\t\t//Если корабль не на планете, то проверяем в какой он системе",
                        "\t\t\t\t\t\tif(ShipInStar(temp_dword_3,temp_dword)==1)",
                        "\t\t\t\t\t\t{",
                        "\t\t\t\t\t\t\tEndLine=CT(\"Script.Mod_ExpCB.149\")+'</color>';",
                        "\t\t\t\t\t\t\tNShipInSys[10]=NShipInSys[10]+1;",
                        "\t\t\t\t\t\t\tNShipInSys[11]=NShipInSys[11]+1;",
                        "\t\t\t\t\t\t\tWarsOnWing=WarsOnWing+1;",
                        "\t\t\t\t\t\t}",
                        "\t\t\t\t\t\telse",
                        "\t\t\t\t\t\t{",
                        "\t\t\t\t\t\t\tEndLine=CT(\"Script.Mod_ExpCB.202\")+' '+StarName(ShipStar(temp_dword_3))+'</color>';",
                        "\t\t\t\t\t\t\ttemp_int_1=temp_int_1-1;",
                        "\t\t\t\t\t\t}",
                        "\t\t\t\t\t}",
                        "\t\t\t\t}",
                        "\t\t\t\telse if(temp_str2=='Dreadnought')",
                        "\t\t\t\t{",
                        "\t\t\t\t\tTypeName=CT(\"Script.Mod_ExpCB.251\");",
                        "\t\t\t\t\tif(ShipInPlanet(temp_dword_3,temp_dword_2)==1)",
                        "\t\t\t\t\t{",
                        "\t\t\t\t\t\tEndLine=CT(\"Script.Mod_ExpCB.150\")+'</color>';",
                        "\t\t\t\t\t\tNShipInSys[16]=NShipInSys[16]+1;",
                        "\t\t\t\t\t\tif(CheckById=='')CheckById=CheckById+'$'+Id(temp_dword_3)+'$';",
                        "\t\t\t\t\t\telse CheckById=CheckById+',$'+Id(temp_dword_3)+'$';",
                        "\t\t\t\t\t}",
                        "\t\t\t\t\telse",
                        "\t\t\t\t\t{",
                        "\t\t\t\t\t\t//Если корабль не на планете, то проверяем в какой он системе",
                        "\t\t\t\t\t\tif(ShipInStar(temp_dword_3,temp_dword)==1)",
                        "\t\t\t\t\t\t{",
                        "\t\t\t\t\t\t\tEndLine=CT(\"Script.Mod_ExpCB.149\")+'</color>';",
                        "\t\t\t\t\t\t\tNShipInSys[16]=NShipInSys[16]+1;",
                        "\t\t\t\t\t\t\tNShipInSys[17]=NShipInSys[17]+1;",
                        "\t\t\t\t\t\t\tWarsOnWing=WarsOnWing+1;",
                        "\t\t\t\t\t\t}",
                        "\t\t\t\t\t\telse",
                        "\t\t\t\t\t\t{",
                        "\t\t\t\t\t\t\tEndLine=CT(\"Script.Mod_ExpCB.202\")+' '+StarName(ShipStar(temp_dword_3))+'</color>';",
                        "\t\t\t\t\t\t\ttemp_int_1=temp_int_1-1;",
                        "\t\t\t\t\t\t}",
                        "\t\t\t\t\t}",
                        "\t\t\t\t}",
                        "\t\t\t\ttemp_str=temp_str+CT(\"Script.Mod_ExpCB.16\")+(k+1)+'. '+Name(temp_dword_3)+CT(\"Script.Mod_ExpCB.16\")+Format(CT(\"Script.Mod_ExpCB.152\"),\"<0>\",TypeName)+CT(\"Script.Mod_ExpCB.16\")+CT(\"Script.Mod_ExpCB.151\")+Format(' <0>',\"<0>\",EndLine);",
                        "\t\t\t\tif(k+1!=PlanetWarriors(temp_dword_2))temp_str=temp_str+CT(\"Script.Mod_ExpCB.16\");",
                        "\t\t\t}",
                        "\t\t}",
                        "\t\t//Если боевых кораблей на планете нет, то маркируем её как \"беззащитную\"",
                        "\t\tif(PlanetWarriors(temp_dword_2)<=0)temp_str=temp_str+CT(\"Script.Mod_ExpCB.179\");",
                        "\t\t//Добавляем разделитель, если текущая планета не последняя в системе",
                        "\t\t//temp_str=temp_str+\"<br>\"+DefSplt;",
                        "\t\tif(j!=LastPlanet)temp_str=temp_str+CT(\"Script.Mod_ExpCB.16\")+CT(\"Script.Mod_ExpCB.16\");",
                        "\t}",
                        "\t//Сравниваем количество военных кораблей в системе и на планетах, вычисляем точное количество военных кораблей в системе",
                        "\tfor(j=0;j<StarShips(temp_dword);j=j+1)",
                        "\t{",
                        "\t\ttemp_dword_3=StarShips(temp_dword,j);",
                        "\t\ttemp_str2=ShipType(temp_dword_3);",
                        "\t\t//Считаем все корабли в космическом пространстве системы",
                        "\t\t//По Id сверяем корабли на планете и в системе, дабы не произошёл двойной зачёт одного и того же корабля",
                        "\t\t//Да, именно так работает функция StarShips - может учесть корабль на планете, а может не учесть",
                        "\t\tif(temp_str2=='Warrior')",
                        "\t\t{",
                        "\t\t\tif(ShipSubType(temp_dword_3)==0)",
                        "\t\t\t{",
                        "\t\t\t\tif(findsubstr(CheckById,'$'+Id(temp_dword_3)+'$')==-1)",
                        "\t\t\t\t{",
                        "\t\t\t\t\tShipsInSys=ShipsInSys+1;",
                        "\t\t\t\t\tNShipInSys[3]=NShipInSys[3]+1;",
                        "\t\t\t\t}",
                        "\t\t\t}",
                        "\t\t\telse if(ShipSubType(temp_dword_3)==1)",
                        "\t\t\t{",
                        "\t\t\t\tif(findsubstr(CheckById,'$'+Id(temp_dword_3)+'$')==-1)",
                        "\t\t\t\t{",
                        "\t\t\t\t\tShipsInSys=ShipsInSys+1;",
                        "\t\t\t\t\tNShipInSys[6]=NShipInSys[6]+1;",
                        "\t\t\t\t}",
                        "\t\t\t}",
                        "\t\t}",
                        "\t\telse if(temp_str2=='Militiaman1' || temp_str2=='Militiaman2' || temp_str2=='Militiaman3')",
                        "\t\t{",
                        "\t\t\tif(findsubstr(CheckById,'$'+Id(temp_dword_3)+'$')==-1)",
                        "\t\t\t{",
                        "\t\t\t\tShipsInSys=ShipsInSys+1;",
                        "\t\t\t\tNShipInSys[9]=NShipInSys[9]+1;",
                        "\t\t\t}",
                        "\t\t}",
                        "\t\telse if(temp_str2=='EliteWarrior')",
                        "\t\t{",
                        "\t\t\tif(findsubstr(CheckById,'$'+Id(temp_dword_3)+'$')==-1)",
                        "\t\t\t{",
                        "\t\t\t\tShipsInSys=ShipsInSys+1;",
                        "\t\t\t\tNShipInSys[12]=NShipInSys[12]+1;",
                        "\t\t\t}",
                        "\t\t}",
                        "\t\telse if(temp_str2=='Dreadnought')",
                        "\t\t{",
                        "\t\t\tif(findsubstr(CheckById,'$'+Id(temp_dword_3)+'$')==-1)",
                        "\t\t\t{",
                        "\t\t\t\tShipsInSys=ShipsInSys+1;",
                        "\t\t\t\tNShipInSys[18]=NShipInSys[18]+1;",
                        "\t\t\t}",
                        "\t\t}",
                        "\t}",
                        "\t//Общее число военных кораблей в системе",
                        "\ttemp_int_1=temp_int_1+(ShipsInSys-WarsOnWing);",
                        "\t//Общее число обычных военных в системе",
                        "\tNShipInSys[1]=NShipInSys[1]+(NShipInSys[3]-NShipInSys[2]);",
                        "\t//Общее число флагманов в системе",
                        "\tNShipInSys[4]=NShipInSys[4]+(NShipInSys[6]-NShipInSys[5]);",
                        "\t//Общее число ополченцев в системе",
                        "\tNShipInSys[7]=NShipInSys[7]+(NShipInSys[9]-NShipInSys[8]);",
                        "\t//Общее число элитных военных в системе",
                        "\tNShipInSys[10]=NShipInSys[10]+(NShipInSys[12]-NShipInSys[11]);",
                        "\t//Общее число баттлстаров в системе",
                        "\t//NShipInSys[13]=NShipInSys[13]+(NShipInSys[15]-NShipInSys[14]);",
                        "\t//Общее число прокси в системе",
                        "\tNShipInSys[16]=NShipInSys[16]+(NShipInSys[18]-NShipInSys[17]);",
                        "\t//Дописываем строке \"подвал\", содержащий общее число всех кораблей в системе",
                        "\tif(temp_int_1!=0)",
                        "\t{",
                        "\t\ttemp_str=temp_str+CT(\"Script.Mod_ExpCB.16\")+CT(\"Script.Mod_ExpCB.16\")+DefSplt+CT(\"Script.Mod_ExpCB.16\")+CT(\"Script.Mod_ExpCB.222\")+CT(\"Script.Mod_ExpCB.16\")+DefSplt;",
                        "\t\tif(NShipInSys[7]!=0)temp_str=temp_str+Format(CT(\"Script.Mod_ExpCB.174\"),\"<0>\",NShipInSys[7]);",
                        "\t\tif(NShipInSys[1]!=0)temp_str=temp_str+Format(CT(\"Script.Mod_ExpCB.197\"),\"<0>\",NShipInSys[1]);",
                        "\t\tif(NShipInSys[10]!=0)temp_str=temp_str+Format(CT(\"Script.Mod_ExpCB.196\"),\"<0>\",NShipInSys[10]);",
                        "\t\tif(NShipInSys[4]!=0)temp_str=temp_str+Format(CT(\"Script.Mod_ExpCB.252\"),\"<0>\",NShipInSys[4]);",
                        "\t\t//if(NShipInSys[13]!=0)temp_str=temp_str+\"<br>Баттлстаров: <NShipInSys[13]>\";",
                        "\t\tif(NShipInSys[16]!=0)temp_str=temp_str+Format(CT(\"Script.Mod_ExpCB.249\"),\"<0>\",NShipInSys[16]);",
                        "\t}",
                        "\telse temp_str=temp_str+CT(\"Script.Mod_ExpCB.213\");",
                        "\t//Заполняем основной массив temp_array с подробной информацией о системах",
                        "\tArrayAdd(temp_array,temp_str);",
                        "\t//Составляем и добавляем в массив temp_array_2 строчки краткого обзора списка систем",
                        "\tif(temp_int_1!=0)temp_str=Format(CT(\"Script.Mod_ExpCB.192\"),\"<0>\",StarName(temp_dword),\"<1>\",ConName(StarToCon(temp_dword)),\"<2>\",temp_int_1);",
                        "\tif(temp_int_1==0)temp_str=Format(CT(\"Script.Mod_ExpCB.191\"),\"<0>\",StarName(temp_dword),\"<1>\",ConName(StarToCon(temp_dword)));",
                        "\tArrayAdd(temp_array_2,temp_str);",
                        "\t//Добавляем в массив temp_array_3 список систем для подстановки в ответы",
                        "\t//Сраная \"трёхметровая\" Витта Прайонис удостоилась отдельной проверки",
                        "\tif(StarName(temp_dword)==CT(\"Script.Mod_ExpCB.210\"))ArrayAdd(temp_array_3,CT(\"Script.Mod_ExpCB.209\"));",
                        "\telse ArrayAdd(temp_array_3,CT(\"Script.Mod_ExpCB.208\")+Format(' <0>',\"<0>\",StarName(temp_dword)));",
                        "\t//Добавляем вспомогательный массив с числом кораблей в системах",
                        "\tArrayAdd(temp_array_4,temp_int_1);",
                        "\ttemp_str='';",
                        "\tCheckById='';",
                        "\ttemp_int_1=0;",
                        "\tWarsOnWing=0;",
                        "\tShipsInSys=0;",
                        "\tLastPlanet=0;",
                        "\tArrayClear(NShipInSys);",
                        "}",
                        "temp_str='';",
                        "//Функция сортировки массивов работает странно",
                        "//В итоге я решил не сортировать вообще, т.к. не вижу особого смысла",
                        "//ArraySort(temp_array,temp_array_4);",
                        "//ArraySort(temp_array_2,temp_array_4);",
                        "//ArraySort(temp_array_3,temp_array_4);",
                        "",
                        "//Расставляем разделители в списке систем",
                        "for(i = 1; i < ArrayDim(temp_array_2); i = i + 1)",
                        "{",
                        "\ttemp_str = temp_str + Format('<0>',\"<0>\",temp_array_2[i]);",
                        "\tif((i + 2) <= ArrayDim(temp_array_2))",
                        "\t{",
                        "\t\tif(GetGameOptions('FontDialog') == 0) temp_str = temp_str + CT(\"Script.Mod_ExpCB.16\") + '------------------------------' + CT(\"Script.Mod_ExpCB.16\");",
                        "\t\telse if(GetGameOptions('FontDialog') == 1) temp_str = temp_str + CT(\"Script.Mod_ExpCB.16\") + '--------------------------' + CT(\"Script.Mod_ExpCB.16\");",
                        "\t\telse if(GetGameOptions('FontDialog') == 2) temp_str = temp_str + CT(\"Script.Mod_ExpCB.16\") + '---------------------------' + CT(\"Script.Mod_ExpCB.16\");",
                        "\t\telse temp_str = temp_str + CT(\"Script.Mod_ExpCB.16\") + '--------------------------' + CT(\"Script.Mod_ExpCB.16\");",
                        "\t}",
                        "}",
                        "//Вычисляем количество всех военных кораблей в галактике",
                        "ArrayAdd(temp_array_4, 0);",
                        "for(i = 1; i < ArrayDim(temp_array_4); i = i + 1)",
                        "{",
