                    "Code.Type": "Turn",
                    "Code": [
                        "if(total_nod) {",
                        "  DAdd(22);",
                        "}",
                        "if(!total_nod) {",
                        "  if(total_cost<=ShipMoney(Player())) {",
                        "    DAdd(24);",
                        "  }",
                        "}"
                    ],
                    "#": 159,
                    "Type": "Top",
