                    ],
                    "#": 41,
                    "Type": "Top",
                    "Parent": -1,
                    "Pos.x": 0,
                    "Pos.y": 710
                },
                {
                    "Name": "",
                    "Code.Type": "DialogBegin",
                    "Code": [
                        "//Если игрок является бароном, находится на Роджерии, и Роджерия под контролем пиратов",
                        "curPlanet=GetShipPlanet(Player());",
                        "if(curPlanet) {",
                        "    if(curPlanet==PlanetPirateClan()) {",
                        "        if(PlanetOwner(PlanetPirateClan())==PirateClan) {",
                        "            if(ShipOwner(Player())==PirateClan && GetShipPirateRank(Player())>=7) {",
                        "                AddDialogOverride('RGDialog',21);",
                        "            }",
                        "        }",
                        "    }",
                        "}"
                    ],
                    "#": 42,
                    "Type": "Top",
                    "Parent": -1,
                    "Pos.x": 180,
                    "Pos.y": 710
                },
                {
                    "Name": "",
                    "Code.Type": "Turn",
                    "Code": [
                        "//Направляем всех на Роджерию",
                        "if(!OrderLock(CurShip)) OrderLock(CurShip,1);",
                        "if(ShipStar(CurShip)!=tSystem) {",
                        "    if(GetShipPlanet(CurShip)) OrderTakeOff(CurShip);",
                        "    else if(ShipInNormalSpace(CurShip)) OrderJump(CurShip,tSystem);",
                        "}",
                        "else if(ShipInNormalSpace(CurShip)) OrderLanding(CurShip,PlanetPirateClan());",
                        "if(GroupIn(Attackers,PlanetPirateClan())) {",
                        "  ChangeState(2);",
                        "  exit;",
                        "}"
                    ],
                    "#": 117,
                    "Type": "Top",
                    "Parent": -1,
                    "Pos.x": 80
                },
                {
                    "Name": "",
                    "Code.Type": "Turn",
                    "Code": [
                        "//Чиним и заправляем корабли, а также заставляем пару раз закупиться, после чего отправляем в систему",
                        "if(OrderLock(CurShip)) OrderLock(CurShip,0);",
                        "ShipRepairEq(CurShip);",
                        "ShipRefuel(CurShip);",
                        "ShipRefit(CurShip);",
                        "ShipRefit(CurShip);",
                        "if(ShipOwner(ShipGetBad(CurShip))==7) TruceBetweenShips(CurShip,ShipGetBad(CurShip));",
                        "if(GetShipPlanet(CurShip)) OrderTakeOff(CurShip);",
                        "else if(ShipInNormalSpace(CurShip) && ShipStar(CurShip)==tSystem) OrderJump(CurShip,GalaxyStar(attackTargetId));",
                        "else if(ShipInNormalSpace(CurShip) && ShipStar(CurShip)==GalaxyStar(attackTargetId)) {ChangeState('Attack',CurShip);ShipKillFactionInCurSystem(CurShip,1,100);}",
                        "if(GroupIn(Attackers,GalaxyStar(attackTargetId))) {",
                        "  ChangeState(3);",
                        "  exit;",
                        "}"
                    ],
                    "#": 118,
                    "Type": "Top",
                    "Parent": -1,
                    "Pos.x": 160
                },
                {
                    "Name": "",
                    "Code.Type": "Turn",
                    "Code": [
                        "//Выбор случайной цели для атаки",
                        "if(ShipInNormalSpace(CurShip) && ShipOrder(CurShip)!=6) {",
                        "    if(OrderLock(CurShip)) OrderLock(CurShip,0);",
                        "    curInfo=ShipFindCustomShipInfoByType(CurShip,'TargetIdInfo');",
                        "    //Лезем в инфошку за целью",
                        "    if(curInfo>-1) {",
                        "        enemyId=ShipCustomShipInfoData(CurShip,curInfo,1);",
                        "        if(enemyId) {",
                        "            if(IdToShip(enemyId)) {",
                        "                if(ShipStar(IdToShip(enemyId))==ShipStar(CurShip) && ShipInNormalSpace(IdToShip(enemyId))) {",
                        "                    ShipSetBad(CurShip,IdToShip(enemyId));",
                        "                    OrderFollowShip(CurShip,IdToShip(enemyId),1,10);",
                        "                }",
                        "                else enemyId=0;",
                        "            }",
                        "            else enemyId=0;",
                        "        }",
                        "    }",
                        "    else enemyId=0;",
                        "    //Если нет цели для атаки, выбираем случайную в пределах системы",
                        "    //Обновляем данные о кораблях в системе",
                        "    if(!enemyId) {",
                        "        if(lastCheckDate!=CurTurn()) {",
                        "            ArrayClear(enemiesArr);",
                        "            for(i=0;i<StarShips(GalaxyStar(attackTargetId));i=i+1) {",
                        "                tShip=StarShips(GalaxyStar(attackTargetId),i);",
                        "                if(ShipOwner(tShip)==7) continue;",
                        "                if(tShip==Player()) continue;",
                        "                if(ShipTypeN(tShip)==t_PB || ShipTypeN(tShip)==t_CB) continue;",
                        "                if(ShipTypeN(tShip)==t_MC || ShipType(tShip)=='TC') continue;",
                        "                if(ShipType(tShip)=='MB' || ShipType(tShip)=='Manaan') continue;",
                        "                ArrayAdd(enemiesArr,Id(tShip));",
                        "            }",
                        "            lastCheckDate=CurTurn();",
                        "        }",
                        "        //Ищем ближайший корабль",
                        "        distance=100000;",
                        "        for(i=1;i<ArrayDim(enemiesArr)-1;i=i+1) {",
                        "            tShip=IdToShip(enemiesArr[i]);",
                        "            if(tShip) {",
                        "                if(Dist(CurShip,tShip)<distance) {",
                        "                    distance=Dist(CurShip,tShip);",
                        "                    ShipSetBad(CurShip,tShip);",
                        "        \t\t\tOrderFollowShip(CurShip,tShip,1,10);",
                        "    \t    \t\tif(curInfo>-1) ShipCustomShipInfoData(CurShip,curInfo,1,Id(tShip));",
                        "    \t\t\t    else ShipAddCustomShipInfo(CurShip,'TargetIdInfo','NoShow',Id(tShip));",
                        "                }",
                        "            }",
                        "        }",
                        "    }",
                        "}",
                        "//Маркер для отступления",
                        "if(HullDamage(CurShip)>80) {",
                        "\tShipOut(CurShip);",
                        "\tShipJoin(Retreaters,CurShip);",
                        "}",
                        "if(StarOwner(GalaxyStar(attackTargetId))==2) {",
                        "  ChangeState(5);",
                        "  exit;",
                        "}"
                    ],
                    "#": 119,
                    "Type": "Top",
                    "Parent": -1,
                    "Pos.x": 320
                },
                {
                    "Name": "",
                    "Code.Type": "Turn",
                    "Code": [
                        "//Если корабль долетел до Тортугаца - выводим его из скрипта, удаляем инфошку",
                        "if(ShipInNormalSpace(CurShip)) {",
                        "    if(ShipStar(CurShip)==tSystem) {",
                        "        OrderLock(CurShip,0);",
                        "        if(ShipFindCustomShipInfoByType(CurShip,'TargetIdInfo')>-1) ShipDeleteCustomShipInfo(CurShip,'TargetIdInfo');",
                        "        ShipOut(CurShip);",
                        "    }",
                        "    else {",
                        "        if(StarOwner(GalaxyStar(attackTargetId))!=2) {",
                        "            if(HullDamage(CurShip)>50) OrderForsage(CurShip,1);",
                        "            OrderJump(CurShip,tSystem);",
                        "        }",
                        "        else {",
                        "        \tShipOut(CurShip);",
                        "\t        ShipJoin(Attackers,CurShip);",
                        "            ChangeState('TakeReward',CurShip);",
                        "        }",
                        "    }",
                        "}"
                    ],
                    "#": 120,
                    "Type": "Top",
                    "Parent": -1,
                    "Pos.x": 400
                },
                {
                    "Name": "",
                    "Code.Type": "Turn",
                    "Code": [
                        "//Направляем выжившие корабли на ближайшую к звезде обитаемую планету",
                        "//Чиним и награждаем деньгами + улучшением, удаляем инфошку",
                        "ArrayClear(enemiesArr);",
                        "OrderLanding(CurShip,FindPlanet(GalaxyStar(attackTargetId),'NotNone',0,0));",
                        "if(GetShipPlanet(CurShip)) {",
                        "    ShipRepairEq(CurShip);",
                        "    HullHP(CurShip,ItemSize(ShipItems(CurShip,0)));",
                        "    ShipMoney(CurShip,ShipMoney(CurShip)+GalaxyMoney(4));",
                        "    ShipImproveItems(CurShip,1);",
                        "    if(ShipFindCustomShipInfoByType(CurShip,'TargetIdInfo')>-1) ShipDeleteCustomShipInfo(CurShip,'TargetIdInfo');",
                        "    ShipOut(CurShip);",
                        "}"
                    ],
                    "#": 121,
                    "Type": "Top",
                    "Parent": -1,
                    "Pos.x": 560
                },
