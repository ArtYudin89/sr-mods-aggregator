                },
                {
                    "Name": "",
                    "Code.Type": "Turn",
                    "Code": [
                        "DAdd(26);"
                    ],
                    "#": 162,
                    "Type": "Top",
                    "Parent": -1,
                    "Pos.x": 1480,
                    "Pos.y": 545
                },
                {
                    "Name": "",
                    "Code.Type": "Turn",
                    "Code": [
                        "if(GroupCount(Attackers)) {",
                        "  DChange(1);",
                        "  exit;",
                        "}",
                        "if(!GroupCount(Attackers)) {",
                        "  //Поиск пригодных пиратов в Дицее",
                        "  //Условия: корабли с клановой принадлежностью, не гражданские (отсеиваем контрабандистов) не партнеры игрока, не в скрипте, не в гипере",
                        "  ArrayClear(piratesArr);",
                        "  tCon=StarToCon(PlanetToStar(PlanetPirateClan()));",
                        "  for(int i=0;i<ConStars(tCon);i=i+1) {",
                        "      tSystem=ConStar(tCon,i);",
                        "      for(j=0;j<StarShips(tSystem);j=j+1) {",
                        "          tShip=StarShips(tSystem,j);",
                        "          if(!ShipOnSidePirateClan(tShip)) continue;",
                        "          if(ShipTypeN(tShip)==t_Transport) continue;",
                        "          if(tShip==Player()) continue;",
                        "          if(ShipIsPartner(tShip)) continue;",
                        "          if(ShipInScript(tShip)) continue;",
                        "          if(ShipInHyperSpace(tShip)) continue;",
                        "          ArrayAdd(piratesArr,Id(tShip));",
                        "      }",
                        "  }",
                        "  if(ArrayDim(piratesArr)<=1) {",
                        "    DChange(2);",
                        "    exit;",
                        "  }",
                        "  if(ArrayDim(piratesArr)>1) {",
                        "    DChange(3);",
                        "    exit;",
                        "  }",
                        "}"
                    ],
                    "#": 163,
                    "Type": "Top",
                    "Parent": -1,
                    "Pos.x": -20,
                    "Pos.y": 615
                },
                {
                    "Name": "",
                    "Code.Type": "Turn",
                    "Code": [
                        "repair_type=2;",
                        "if (cur_ruin_id!=0) {",
                        "    ShipDestroy(IdToShip(cur_ruin_id));",
                        "}",
                        "cur_ruin=BuildRuins(GalaxyStar(71),t_PB);",
                        "TransferShip(cur_ruin,StarPlanets(GalaxyStar(71),1));",
                        "//Пришлось заюзать костыль с невидимой, чтобы в следующей операции подхватился ее тип,",
                        "//ибо копаться в коде Уханыча и выправлять условия я желанием не горел. Можно ведь и сломать что-нибудь.",
                        "//И, да, она прячется на незаселенке в Тортугаце, чтобы игрок ее не мог обнаружить ни на карте, ни через поиск.;",
                        "ArrayClear(items_to_repair);",
                        "domik_wpn_cost=0;",
                        "art_cost=0;",
                        "total_nod=0;",
                        "item_cost=0;",
                        "total_cost=0;",
                        "for(i=0;i<ShipItems(Player());i=i+1) {",
                        "    cur_item=ShipItems(Player(),i);",
                        "    if(!i) {",
                        "\t    if(HullDamage(Player())>0) {",
                        "    \t\titem_cost=((ItemCost(cur_item)*HullDamage(Player())*1000)/40)/100+10;",
                        "    \t\titem_cost=item_cost/10000;",
                        "    \t\titem_cost=item_cost*10;",
                        "    \t\tmax_durability=HullDamage(Player());",
                        "    \t\tArrayAdd(items_to_repair,cur_item);",
                        "    \t}",
                        "    \tcontinue;",
                        "    }",
                        "    if(ItemType(cur_item)>=t_Weapon13 && ItemType(cur_item)<=t_Weapon15 && ShipType(cur_ruin)=='WB') continue;",
                        "    if((!ItemIsInSet(cur_item) || !ItemIsInUse(cur_item)) && repair_type==0) continue;",
                        "    if(!ItemIsInUse(cur_item) && repair_type==2) continue;",
                        "\tif(ItemType(cur_item)>t_Hull && ItemType(cur_item)<t_Protoplasm) {",
                        "\t\tif(ItemDurability(cur_item)<=90) {",
                        "\t\t\ttemp_int=(ItemCost(cur_item)*1000/20)+(((ItemCost(cur_item)*1000)/7)/100)*(100-ItemDurability(cur_item))+10000;",
                        "\t\t\tif(ItemDurability(cur_item)<1) temp_int=(temp_int*13)/10;",
                        "\t\t\ttemp_int=temp_int/10000;",
                        "\t\t\ttemp_int=temp_int*10;",
                        "\t\t\titem_cost=item_cost+temp_int;",
                        "\t\t\tArrayAdd(items_to_repair,cur_item);",
                        "\t\t\tif(ItemType(cur_item)>=t_Weapon13 && ItemType(cur_item)<=t_Weapon15) {",
                        "\t\t\t\tdomik_wpn_cost=domik_wpn_cost+temp_int;",
                        "\t\t\t\ttotal_nod=total_nod+temp_int;",
                        "            }",
                        "\t\t}",
                        "\t}",
                        "\tif(max_durability<100-ItemDurability(cur_item)) max_durability=100-ItemDurability(cur_item);",
                        "}",
                        "if(ShipType(cur_ruin)!='WB') {",
                        "\tfor(i=0;i<ShipArts(Player());i=i+1) {",
                        "\t\tcur_item=ShipArts(Player(),i);",
                        "\t\tif(!ItemCanBeBroken(cur_item)) continue;",
                        "\t\tif((!ItemIsInSet(cur_item) || !ItemIsInUse(cur_item)) && repair_type==0) continue;",
                        "\t\tif(!ItemIsInUse(cur_item) && repair_type==2) continue;",
                        "\t\tif(max_durability<100-ItemDurability(cur_item)) max_durability=100-ItemDurability(cur_item);",
                        "\t\tif(ItemDurability(cur_item)<=90) {",
                        "\t\t\ttemp_int=(ItemCost(cur_item)*1000/10)+(((ItemCost(cur_item)*1000)/5)/100)*(100-ItemDurability(cur_item))+10000;",
                        "\t\t\tif(ItemDurability(cur_item)<1) temp_int=(temp_int*13)/10;",
                        "\t\t\ttemp_int=temp_int/10000;",
                        "\t\t\ttemp_int=temp_int*10;",
                        "\t\t\ttemp_int=temp_int*2;",
                        "\t\t\tart_cost=art_cost+temp_int;",
                        "\t\t\tArrayAdd(items_to_repair,cur_item);",
                        "\t\t}",
                        "\t\tif(max_durability<100-ItemDurability(cur_item)) max_durability=100-ItemDurability(cur_item);",
                        "\t}",
                        "}",
                        "if(repair_type==1) {",
                        "\tfor(j=0;j<ShipArts(Player());j=j+1) {",
                        "\t\tif(ItemType(ShipArts(Player(),j))==t_ArtefactTranclucator) {",
                        "\t\t\tcur_trank=ArtTranclucatorToShip(ShipArts(Player(),j));",
                        "\t\t\tfor(i=0;i<ShipItems(cur_trank);i=i+1) {",
                        "\t\t\t\tcur_item=ShipItems(cur_trank,i);",
                        "\t\t\t\tif(!i) {",
                        "\t\t\t\t\tif(HullDamage(cur_trank)>0) {",
                        "\t\t\t\t\t\ttemp_int=((ItemCost(cur_item)*HullDamage(cur_trank)*1000)/40)/100+10;",
                        "\t\t\t\t\t\ttemp_int=temp_int/10000;",
                        "\t\t\t\t\t\ttemp_int=temp_int*10;",
                        "\t\t\t\t\t\titem_cost=item_cost+temp_int;",
                        "\t\t\t\t\t\tArrayAdd(items_to_repair,cur_item);",
                        "\t\t\t\t\t\tif(max_durability<HullDamage(cur_trank)) max_durability=HullDamage(cur_trank);",
                        "\t\t\t\t\t}",
                        "\t\t\t\t\tcontinue;",
                        "\t\t\t\t}",
                        "\t\t\t\tif(ItemType(cur_item)>=t_Weapon13 && ItemType(cur_item)<=t_Weapon15 && ShipType(cur_ruin)=='WB') continue;",
                        "\t\t\t\tif(ItemType(cur_item)>t_Hull && ItemType(cur_item)<t_Protoplasm) {",
                        "\t\t\t\t\tif(ItemDurability(cur_item)<=90) {",
                        "\t\t\t\t\t\ttemp_int=(ItemCost(cur_item)*1000/20)+(((ItemCost(cur_item)*1000)/7)/100)*(100-ItemDurability(cur_item))+10000;",
                        "\t\t\t\t\t\tif(ItemDurability(cur_item)<1) temp_int=(temp_int*13)/10;",
                        "\t\t\t\t\t\ttemp_int=temp_int/10000;",
                        "\t\t\t\t\t\ttemp_int=temp_int*10;",
                        "\t\t\t\t\t\titem_cost=item_cost+temp_int;",
                        "\t\t\t\t\t\tArrayAdd(items_to_repair,cur_item);",
                        "\t\t\t\t\t\tif(ItemType(cur_item)>=t_Weapon13 && ItemType(cur_item)<=t_Weapon15) {",
                        "\t\t\t\t\t\t\tdomik_wpn_cost=domik_wpn_cost+temp_int;",
                        "\t\t\t\t\t\t\ttotal_nod=total_nod+temp_int;",
                        "\t\t\t\t\t\t}",
                        "\t\t\t\t\t}",
                        "\t\t\t\t}",
                        "\t\t\t\tif(max_durability<100-ItemDurability(cur_item)) max_durability=100-ItemDurability(cur_item);",
                        "\t\t\t}",
                        "\t\t\tif(ShipType(cur_ruin)!='WB') {",
                        "\t\t\t\tfor(i=0;i<ShipArts(cur_trank);i=i+1) {",
                        "\t\t\t\t\tcur_item=ShipArts(cur_trank,i);",
                        "\t\t\t\t\tif(!ItemCanBeBroken(cur_item)) continue;",
                        "\t\t\t\t\tif((!ItemIsInSet(cur_item) || !ItemIsInUse(cur_item)) && repair_type==0) continue;",
                        "\t\t\t\t\tif(!ItemIsInUse(cur_item) && repair_type==2) continue;",
                        "\t\t\t\t\tif(max_durability<100-ItemDurability(cur_item)) max_durability=100-ItemDurability(cur_item);",
                        "\t\t\t\t\tif(ItemDurability(cur_item)<=90) {",
                        "\t\t\t\t\t\ttemp_int=(ItemCost(cur_item)*1000/10)+(((ItemCost(cur_item)*1000)/5)/100)*(100-ItemDurability(cur_item))+10000;",
                        "\t\t\t\t\t\tif(ItemDurability(cur_item)<1) temp_int=(temp_int*13)/10;",
                        "\t\t\t\t\t\ttemp_int=temp_int/10000;",
                        "\t\t\t\t\t\ttemp_int=temp_int*10;",
                        "\t\t\t\t\t\ttemp_int=temp_int*2;",
                        "\t\t\t\t\t\tart_cost=art_cost+temp_int;",
                        "\t\t\t\t\t\tArrayAdd(items_to_repair,cur_item);",
                        "\t\t\t\t\t}",
                        "\t\t\t\t\tif(max_durability<100-ItemDurability(cur_item)) max_durability=100-ItemDurability(cur_item);",
                        "\t\t\t\t}",
                        "\t\t\t}",
                        "\t\t}",
                        "\t}",
                        "}",
                        "ShipDestroy(cur_ruin);",
                        "total_cost=item_cost+art_cost;",
                        "total_nod=total_nod/400;",
                        "no_nod=1;",
                        "if(max_durability<=10) {",
                        "  DChange(30);",
                        "  exit;",
                        "}",
                        "if(max_durability>10) {",
                        "  total_cost=(total_cost*95)/100;",
                        "  total_nod=(total_nod*95)/100;",
                        "  domik_wpn_cost=(domik_wpn_cost*84)/100;",
                        "  discount=85;",
                        "  temp_int=total_cost;",
                        "  total_cost=total_cost-total_cost*discount/100;",
                        "  total_nod=total_nod-total_nod*discount/100;",
                        "  domik_wpn_cost=domik_wpn_cost-domik_wpn_cost*discount/100;",
                        "  if(!total_cost) {",
                        "    DChange(30);",
                        "    exit;",
                        "  }",
                        "  if(total_cost) {",
                        "    DChange(31);",
                        "    exit;",
                        "  }",
                        "}"
                    ],
                    "#": 164,
                    "Type": "Top",
                    "Parent": -1,
                    "Pos.x": 100,
                    "Pos.y": 615
                },
                {
                    "Name": "",
                    "Code.Type": "Turn",
                    "Code": [
                        "//Выбор систем для атаки",
                        "//Выбираются непиратские неоспариваемые системы в радиусе 50 пк. от Роджерии",
                        "ArrayClear(systemsArr);",
                        "for(i=1;i<GalaxyStars();i=i+1) {",
                        "    tSystem=StarNearbyStars(ShipStar(Player()),i);",
                        "    if(StarOwner(tSystem)==2) continue;",
                        "    if(StarBattle(tSystem)) continue;",
                        "    if(Dist2Star(tSystem,PlanetToStar(PlanetPirateClan()))>2550) continue;",
                        "    ArrayAdd(systemsArr,tSystem);",
                        "}",
                        "if(ArrayDim(systemsArr)<=1) {",
                        "  DChange(4);",
                        "  exit;",
                        "}",
                        "if(ArrayDim(systemsArr)>1) {",
                        "  RunChildForm('Galaxy');",
                        "  if(ShipOrder(Player())==7) {",
                        "      tSystem=ShipOrderObj(Player());",
                        "      OrderNone(Player());",
                        "  }",
                        "  if(StarOwner(tSystem)==2) {",
                        "    DChange(5);",
                        "    exit;",
                        "  }",
                        "  if(StarBattle(tSystem)) {",
                        "    DChange(7);",
                        "    exit;",
                        "  }",
                        "  if(Dist2Star(tSystem,PlanetToStar(PlanetPirateClan()))>2550) {",
                        "    DChange(6);",
                        "    exit;",
                        "  }",
                        "  if(!StarBattle(tSystem) && StarOwner(tSystem)!=2 && Dist2Star(tSystem,PlanetToStar(PlanetPirateClan()))<2550) {",
                        "    //Выбор числа пиратов",
                        "    pirateCost=GalaxyMoney(2,3);",
                        "    maxCount=ShipMoney(Player())/pirateCost;",
                        "    piratesHired=CountBox('Bm.Items.2Hull_F_s',CT(\"Script.Mod_ShuRG.18\"),0,ArrayDim(piratesArr)-1,pirateCost,1,maxCount);",
                        "    if(piratesHired) {",
                        "      DChange(9);",
                        "      exit;",
                        "    }",
                        "    if(!piratesHired) {",
                        "      DChange(8);",
                        "      exit;",
                        "    }",
                        "  }",
                        "}"
                    ],
                    "#": 165,
                    "Type": "Top",
                    "Parent": -1,
                    "Pos.x": 340,
                    "Pos.y": 615
                },
                {
                    "Name": "",
                    "Code.Type": "Turn",
                    "Code": [
                        "ArrayClear(piratesArr);",
                        "ArrayClear(systemsArr);"
                    ],
                    "#": 166,
                    "Type": "Top",
                    "Parent": -1,
                    "Pos.x": 460,
                    "Pos.y": 615
                },
                {
                    "Name": "",
                    "Code.Type": "Turn",
                    "Code": [
                        "ShipMoney(Player(),ShipMoney(Player())-pirateCost*piratesHired);",
                        "Sound('Sound.Buy');",
                        "attackTargetId=Id(tSystem)-1;",
                        "for(i=1;i<=piratesHired;i=i+1) {",
                        "    tShip=IdToShip(piratesArr[i]);",
                        "    if(tShip) ShipJoin(Attackers,tShip);",
                        "}",
                        "tSystem=PlanetToStar(PlanetPirateClan());",
                        "ArrayClear(piratesArr);",
                        "ArrayClear(systemsArr);",
                        "DChange(10);",
                        "exit;"
                    ],
                    "#": 167,
                    "Type": "Top",
                    "Parent": -1,
                    "Pos.x": 580,
                    "Pos.y": 615
                },
                {
                    "Name": "",
                    "Code.Type": "Turn",
                    "Code": [
                        "DChange(20);",
                        "exit;"
                    ],
                    "#": 168,
                    "Type": "Top",
                    "Parent": -1,
                    "Pos.x": 1060,
                    "Pos.y": 615
                },
                {
                    "Name": "",
                    "Code.Type": "Turn",
                    "Code": [
                        "DChange(19);",
                        "exit;"
                    ],
                    "#": 169,
                    "Type": "Top",
                    "Parent": -1,
                    "Pos.x": 1180,
                    "Pos.y": 615
                },
                {
                    "Name": "",
                    "Code.Type": "Turn",
                    "Code": [
                        "//Перебираем все корабли в системе, подходящие заносим в массив",
                        "for(i=GroupCount(Attackers)-1;i>=0;i=i-1) {",
                        "    tShip=GroupShip(Attackers,i);",
                        "    if(ShipInNormalSpace(tShip)) {",
                        "        if(lastCheckDate!=CurTurn()) {",
                        "            ArrayClear(enemiesArr);",
                        "            for(j=0;j<StarShips(GalaxyStar(attackTargetId));j=j+1) {",
                        "                tShip2=StarShips(GalaxyStar(attackTargetId),j);",
                        "                if(ShipOwner(tShip2)==7) continue;",
                        "                if(tShip2==Player()) continue;",
                        "                if(ShipTypeN(tShip2)==t_PB || ShipTypeN(tShip2)==t_CB) continue;",
                        "                if(ShipTypeN(tShip2)==t_MC || ShipType(tShip2)=='TC') continue;",
                        "                if(ShipType(tShip2)=='MB' || ShipType(tShip2)=='Manaan') continue;",
                        "                ArrayAdd(enemiesArr,Id(tShip2));",
                        "            }",
                        "            lastCheckDate=CurTurn();",
                        "        }",
                        "        //Перебираем всех врагов в массиве, ищем ближайший корабль, нашли - отдаем приказ атаковать",
                        "        distance=100000;",
                        "        for(j=1;j<ArrayDim(enemiesArr)-1;j=j+1) {",
                        "            tShip2=IdToShip(enemiesArr[j]);",
                        "            if(tShip2) {",
                        "                if(Dist(tShip,tShip2)<distance) {",
                        "                    distance=Dist(tShip,tShip2);",
                        "                    ShipSetBad(tShip,tShip2);",
                        "        \t\t\tOrderFollowShip(tShip,tShip2,1,10);",
                        "    \t    \t\tif(curInfo>-1) ShipCustomShipInfoData(tShip,curInfo,1,Id(tShip2));",
                        "    \t\t\t    else ShipAddCustomShipInfo(tShip,'TargetIdInfo','NoShow',Id(tShip2));",
                        "                }",
                        "            }",
                        "        }",
                        "    }",
                        "}",
                        "DChange(22);",
                        "exit;"
                    ],
                    "#": 170,
                    "Type": "Top",
                    "Parent": -1,
                    "Pos.x": 1420,
                    "Pos.y": 615
                },
                {
                    "Name": "",
                    "Code.Type": "Turn",
                    "Code": [
                        "//Переводим корабль в группу отступающих, при необходимости включаем форсаж",
                        "tSystem=PlanetToStar(PlanetPirateClan());",
                        "if(HullDamage(GetTalkShip())>50) OrderForsage(GetTalkShip(),1);",
                        "ShipOut(GetTalkShip());",
                        "ShipJoin(Retreaters,GetTalkShip());",
                        "DChange(21);",
                        "exit;"
                    ],
                    "#": 171,
                    "Type": "Top",
                    "Parent": -1,
                    "Pos.x": 1540,
                    "Pos.y": 615
                },
                {
                    "Name": "",
                    "Code.Type": "Turn",
                    "Code": [
                        "//То же самое, но для всех кораблей в группе",
                        "for(i=GroupCount(Attackers)-1;i>=0;i=i-1) {",
                        "    tShip=GroupShip(Attackers,i);",
                        "    ShipOut(tShip);",
                        "    ShipJoin(Retreaters,tShip);",
                        "}"
                    ],
                    "#": 172,
                    "Type": "Top",
                    "Parent": -1,
                    "Pos.x": 1660,
                    "Pos.y": 615
                },
                {
                    "Name": "",
                    "Code.Type": "Turn",
                    "Code": [
                        "//То же самое, но для всех кораблей в группе",
                        "for(i=GroupCount(Attackers)-1;i>=0;i=i-1) {",
                        "    tShip=GroupShip(Attackers,i);",
                        "    if(ShipInNormalSpace(tShip) && ShipStar(tShip)==GalaxyStar(attackTargetId)) {",
                        "        if(OrderLock(tShip)) OrderLock(tShip,0);",
                        "        curInfo=ShipFindCustomShipInfoByType(tShip,'TargetIdInfo');",
                        "        if(curInfo>-1) ShipCustomShipInfoData(tShip,curInfo,1,enemyId);",
                        "        else ShipAddCustomShipInfo(tShip,'TargetIdInfo','NoShow',enemyId);",
                        "        ShipSetBad(tShip,IdToShip(enemyId));",
                        "        OrderFollowShip(tShip,IdToShip(enemyId),1,10);",
                        "    }",
                        "}"
                    ],
                    "#": 173,
                    "Type": "Top",
                    "Parent": -1,
                    "Pos.x": 100,
                    "Pos.y": 640
                },
                {
                    "Name": "",
                    "Code.Type": "Turn",
                    "Code": [
                        "if(HullDamage(GetTalkShip())>80) {",
                        "  tRnd=Rnd(0,3);",
                        "  if(!tRnd) {",
                        "    DChange(26);",
                        "    exit;",
                        "  }",
                        "  if(tRnd==1) {",
                        "    DChange(27);",
                        "    exit;",
                        "  }",
                        "  if(tRnd==2) {",
                        "    DChange(28);",
                        "    exit;",
                        "  }",
                        "  if(tRnd==3) {",
                        "    DChange(29);",
                        "    exit;",
                        "  }",
                        "}",
                        "if(HullDamage(GetTalkShip())<=80) {",
                        "  //Возвращаем корабль в бой",
                        "  ShipOut(GetTalkShip());",
                        "  ShipJoin(Attackers,GetTalkShip());",
                        "  ChangeState('Attack',GetTalkShip());",
                        "  if(OrderForsage(GetTalkShip())) OrderForsage(GetTalkShip(),0);",
                        "  DChange(25);",
                        "  exit;",
                        "}"
                    ],
                    "#": 174,
                    "Type": "Top",
                    "Parent": -1,
                    "Pos.x": 340,
                    "Pos.y": 640
                },
                {
                    "Name": "",
                    "Code.Type": "Turn",
                    "Code": [
                        "//То же самое, но для всех кораблей в группе",
                        "for(i=GroupCount(Retreaters)-1;i>=0;i=i-1) {",
                        "    tShip=GroupShip(Retreaters,i);",
                        "        if(ShipInNormalSpace(tShip)) {",
                        "            if(HullDamage(tShip)<=80) {",
                        "            if(OrderForsage(tShip)) OrderForsage(tShip,0);",
                        "            ShipOut(tShip);",
                        "            ShipJoin(Attackers,tShip);",
                        "            ChangeState('Attack',tShip);",
                        "        }",
                        "    }",
                        "}"
                    ],
                    "#": 175,
                    "Type": "Top",
                    "Parent": -1,
                    "Pos.x": 460,
                    "Pos.y": 640
                },
                {
                    "Name": "",
                    "Code.Type": "Turn",
                    "Code": [
                        "DChange(32);",
                        "exit;"
                    ],
                    "#": 176,
                    "Type": "Top",
                    "Parent": -1,
                    "Pos.x": 820,
                    "Pos.y": 640
                },
                {
                    "Name": "",
                    "Code.Type": "Turn",
                    "Code": [
                        "DChange(33);",
                        "exit;"
                    ],
                    "#": 177,
                    "Type": "Top",
                    "Parent": -1,
                    "Pos.x": 940,
                    "Pos.y": 640
                },
                {
                    "Name": "",
                    "Code.Type": "Turn",
                    "Code": [
                        "no_nod=0;",
                        "for(i=1;i<ArrayDim(items_to_repair);i=i+1) {",
                        "    if(no_nod) {",
                        "        if(ItemType(items_to_repair[i])==t_Weapon13 || ItemType(items_to_repair[i])==t_Weapon14 || ItemType(items_to_repair[i])==t_Weapon15) continue;",
                        "    }",
                        "    if(ItemType(items_to_repair[i])==t_Hull) {",
                        "        HullHP(items_to_repair[i],ItemSize(items_to_repair[i]));",
                        "        continue;",
                        "\t}",
                        "\tItemDurability(items_to_repair[i],100);",
                        "}",
                        "ArrayClear(items_to_repair);",
                        "Sound('Sound.Repair');",
                        "ShipMoney(Player(),ShipMoney(Player())-total_cost);",
                        "GetNodesFromShip(Player(),total_nod);",
                        "DChange(34);",
                        "exit;"
                    ],
                    "#": 178,
                    "Type": "Top",
                    "Parent": -1,
                    "Pos.x": 1060,
                    "Pos.y": 640
                },
                {
                    "Name": "",
                    "Code.Type": "Turn",
                    "Code": [
                        "no_nod=1;",
                        "total_cost=total_cost-domik_wpn_cost;",
                        "total_nod=0;",
                        "for(i=1;i<ArrayDim(items_to_repair);i=i+1) {",
                        "    if(no_nod) {",
                        "        if(ItemType(items_to_repair[i])==t_Weapon13 || ItemType(items_to_repair[i])==t_Weapon14 || ItemType(items_to_repair[i])==t_Weapon15) continue;",
                        "    }",
                        "    if(ItemType(items_to_repair[i])==t_Hull) {",
                        "        HullHP(items_to_repair[i],ItemSize(items_to_repair[i]));",
                        "        continue;",
                        "\t}",
                        "\tItemDurability(items_to_repair[i],100);",
                        "}",
                        "ArrayClear(items_to_repair);",
                        "Sound('Sound.Repair');",
                        "ShipMoney(Player(),ShipMoney(Player())-total_cost);",
                        "GetNodesFromShip(Player(),total_nod);",
                        "DChange(34);",
                        "exit;"
                    ],
                    "#": 179,
                    "Type": "Top",
                    "Parent": -1,
                    "Pos.x": 1180,
                    "Pos.y": 640
                }
            ],
