                {
                    "Name": "",
                    "Code.Type": "Turn",
                    "Code": [
                        "//Атакуем выбранный игроком корабль, записываем его id в инфошку",
                        "enemyId=Id(StarShips(ShipStar(GetTalkShip()),GAnswerData));",
                        "if(OrderLock(GetTalkShip())) OrderLock(GetTalkShip(),0);",
                        "curInfo=ShipFindCustomShipInfoByType(GetTalkShip(),'TargetIdInfo');",
                        "if(curInfo>-1) ShipCustomShipInfoData(GetTalkShip(),curInfo,1,enemyId);",
                        "else ShipAddCustomShipInfo(GetTalkShip(),'TargetIdInfo','NoShow',enemyId);",
                        "ShipSetBad(GetTalkShip(),IdToShip(enemyId));",
                        "OrderFollowShip(GetTalkShip(),IdToShip(enemyId),1,10);",
                        "DChange(23);",
                        "exit;"
                    ],
