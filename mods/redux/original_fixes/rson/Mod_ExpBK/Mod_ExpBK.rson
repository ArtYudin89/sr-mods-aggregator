                        "            {",
                        "                MessageBox(CT(\"Script.Mod_ExpBK.91\"));",
                        "            }",
                        "            else",
                        "            {",
                        "                if(ShipMoney(Player()) - ((temp_int + (PlayerDebt() - temp_int)) + ((temp_int + (PlayerDebt() - temp_int)) * 5) / 100) < 0)",
                        "                {",
                        "                    MessageBox(CT(\"Script.Mod_ExpBK.89\"));",
