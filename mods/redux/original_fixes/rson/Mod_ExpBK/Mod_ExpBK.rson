            "Items": [],
            "Operations": [
                {
                    "Name": "",
                    "Code.Type": "Global",
                    "Code": [
                        "GRun();"
                    ],
                    "#": 42,
                    "Type": "Top",
                    "Parent": -1,
                    "Pos.x": 0,
                    "Pos.y": 735
                },
                {
                    "Name": "",
                    "Code.Type": "Init",
                    "Code": [
                        "for(i = 1; i < 9; i = i + 1) type_name[i] = CT('Items.Goods.Name.' + i);",
                        "news_ok = 0;",
                        "",
                        "//Стартовый перебор числа БЦ в Галактике",
                        "for(i = 0; i < GalaxyStars(); i = i + 1)",
                        "{",
                        "    temp_dword = GalaxyStar(i);",
                        "    if(!StarRuins(temp_dword, 'BK')) continue;",
                        "    TotalBKCount = TotalBKCount + 1;",
                        "}",
                        "if(TotalBKCount) BKexist = 1;",
                        "",
                        "//Функция расчёта накопленных процентов для текущего состояния депозитного счёта",
                        "function DepositPercentCalc()",
                        "{",
                        "    temp_float = 1.0 + 0.0001 * PlayerDepositPercent() / 12; //Считаем X",
                        "    temp_float = exp((1.0 * PlayerDepositDay() / 365 * 12) * ln(temp_float)); //Считаем Y и возводим X в степень Y",
                        "    temp_int_5 = round(min(temp_float * PlayerDeposit(), 100000000)); //Применяем получившийся процент к сумме на счету и округляем результат",
                        "}"
                    ],
                    "#": 43,
                    "Type": "Top",
                    "Parent": -1,
                    "Pos.x": 60,
                    "Pos.y": 735
                },
                {
                    "Name": "",
                    "Code.Type": "Turn",
                    "Code": [
                        "if(!ShipIsTakeoff(Player())) {",
                        "  //Значения переменной BKexist",
                        "  //BKexist == 0 - в галактике не осталось БЦ",
                        "  //BKexist == 1 - в галактике есть БЦ",
                        "  //BKexist == 2 - ---",
                        "  //BKexist == 3 - в галактике есть БЦ, а игрок допустил уже две просрочки по текущему кредиту",
                        "  ",
                        "  //Проверяем галасобытия и ищем среди них уничтожения и постройки БЦ",
                        "  for(i = GalaxyEvents() - 1; i >= 0; i = i - 1)",
                        "  {",
                        "      if(GalaxyEventDate(i) < CurTurn()) break;",
                        "      if(GalaxyEventType(i) == 'RuinsCreated')",
                        "      {",
                        "          if(GalaxyEventData(i, 0) == t_BK)",
                        "          {",
                        "              if(GalaxyEventsTextData(i, 1) == '')",
                        "              {",
                        "                  //Проверяем появление нового БЦ в Галактике",
                        "                  temp_dword = GalaxyStar(GalaxyEventData(i, 2) - 1);",
                        "                  if(StarRuins(temp_dword, 'BK'))",
                        "                  {",
                        "                      //Если ранее все БЦ были уничтожены, то обновляем маркер",
                        "                      if(!BKexist) BKexist = 1;",
                        "                      TotalBKCount = TotalBKCount + 1;",
                        "                  }",
                        "              }",
                        "          }",
                        "      }",
                        "      else if(GalaxyEventType(i) == 'RuinsDestroyed')",
                        "      {",
                        "          if(GalaxyEventData(i, 0) ==  t_BK)",
                        "          {",
                        "              if(GalaxyEventsTextData(i, 1) == '')",
                        "              {",
                        "                  TotalBKCount = TotalBKCount - 1;",
                        "                  if(!TotalBKCount)",
                        "                  {",
                        "                      BKexist = 0;",
                        "                      //Удаляем торговую лицензию игрока, если она у него была",
                        "                      if(~ShipFindCustomShipInfoByType(Player(), 'Trade_license'))",
                        "                      {",
                        "                          ShipDeleteCustomShipInfo(Player(), 'Trade_license');",
                        "                          NewsAdd(CT(\"Script.Mod_ExpBK.110\"));",
                        "                      }",
                        "                  }",
                        "              }",
                        "          }",
                        "      }",
                        "  }",
                        "  ",
                        "  //Вывод торговых новостей в уведомление",
                        "  if(IsScriptActive('Mod_ExpPilotBridge') || BKexist == 1)",
                        "  {",
                        "      if(news_ok)",
                        "      {",
                        "          temp_str = CT(\"Script.Mod_ExpBK.190\") + CT(\"Script.Mod_ExpBK.32\") + ' ' + CT(\"Script.Mod_ExpBK.32\");",
                        "          temp_int = 0;",
                        "          for(i = PlanetNews() - 1; i > PlanetNews() - 7; i = i - 1)",
                        "          {",
                        "              if(PlanetNewsDate(i))",
                        "              {",
                        "                  if(PlanetNewsType(i) >= 6 && PlanetNewsType(i) <= 17)",
                        "                  {",
                        "                      temp_int = temp_int + 1;",
                        "                      temp_str = temp_str + '<clr>' + GameDateTxtByTurn(PlanetNewsDate(i)) + '<clrEnd>' + CT(\"Script.Mod_ExpBK.32\") + '<clrEnd>' + PlanetNewsText(i) + '<clr>' + CT(\"Script.Mod_ExpBK.32\") + ' ' + CT(\"Script.Mod_ExpBK.32\");",
                        "                  }",
                        "              }",
                        "          }",
                        "          if(temp_int) CustomEther('News', 7, '1E51413E-F50F-45DA-B75D-0F73E5C02AFD', temp_str);",
                        "      }",
                        "  }",
                        "  ",
                        "  //Вывод новости о необходимости продления лицензии",
                        "  if(~ShipFindCustomShipInfoByType(Player(),'Trade_license'))",
                        "  {",
                        "      temp_int = ShipCustomShipInfoData(Player(), 'Trade_license', 1);",
                        "      //За три месяца",
                        "      if((temp_int - CurTurn()) == 90) NewsAdd(CT(\"Script.Mod_ExpBK.189\"));",
                        "      //За месяц",
                        "      else if((temp_int - CurTurn()) == 30) NewsAdd(CT(\"Script.Mod_ExpBK.188\"));",
                        "  }",
                        "  //Взведение таймера потери лицензии при наборе свыше 2-х просрочек по кредиту",
                        "  if(BKexist != 3)",
                        "  {",
                        "      if(PlayerDebtCnt() > 2)",
                        "      {",
                        "          BKexist = 3;",
                        "          if(~ShipFindCustomShipInfoByType(Player(),'Trade_license')) TrLCount = -8;",
                        "      }",
                        "  }",
                        "  //Обнуление таймера потери лицензии при погашении кредита",
                        "  else",
                        "  {",
                        "      if(!PlayerDebtCnt())",
                        "  ",
                        "          BKexist = 2;",
                        "          TrLCount = 1;",
                        "      }",
                        "  }",
                        "  //Таймер потери лицензии при наборе свыше 2-х просрочек по кредиту",
                        "  if(BKexist == 3 && TrLCount < 0)",
                        "  {",
                        "      TrLCount = TrLCount + 1;",
                        "      temp_int = ShipFindCustomShipInfoByType(Player(), 'Trade_license');",
                        "      if(!TrLCount && ~temp_int)",
                        "      {",
                        "          ShipSpecialBonuses(Player(), bonSkill4, ShipSpecialBonuses(Player(), bonSkill4) - 1);",
                        "          ShipDeleteCustomShipInfo(Player(), 'Trade_license');",
                        "          NewsAdd(CT(\"Script.Mod_ExpBK.149\"));",
                        "          TrLCount = 1;",
                        "      }",
                        "      if(TrLCount != 1 && temp_int == -1)",
                        "      {",
                        "          TrLCount = 1;",
                        "      }",
                        "  }",
                        "}"
                    ],
                    "#": 44,
                    "Type": "Top",
                    "Parent": -1,
                    "Pos.x": 120,
                    "Pos.y": 735
                },
                {
                    "Name": "",
                    "Code.Type": "DialogBegin",
                    "Code": [
                        "cur_ruin = GetShipRuins(Player());",
                        "if(cur_ruin)",
                        "{",
                        "    temp_str = ShipType(cur_ruin);",
                        "    if(temp_str == 'BK')",
                        "    {",
                        "        //temp_int_3  == -1 - у игрока есть действующая, ещё не истекающая торговая лицензия",
                        "        //temp_int_3  ==  1 - торговая лицензия истечёт через месяц",
                        "        //temp_int_3  ==  0 - у игрока нет торговой лицензии",
                        "        temp_int_3 = -1;",
                        "        //Проверка на истечение лицензии",
                        "        temp_int = ShipFindCustomShipInfoByType(Player(), 'Trade_license');",
                        "        if(~temp_int)",
                        "        {",
                        "            temp_int = ShipCustomShipInfoData(Player(), temp_int, 1);",
                        "            if(temp_int - CurTurn() <= 29) temp_int_3 = 1;",
                        "        }",
                        "        //Проверка на наличие действующей лицензии",
                        "        else temp_int_3 = 0;",
                        "",
                        "        //Подключение диалогов на БЦ в зависимости от соблюдения различных условий",
                        "        if(!temp_int_3 && ShipStatus(Player(), 0) >= 30 && !LTradeLicenseCheck && BKexist != 3)",
                        "        {",
                        "            AddDialogInject('TradeLicense', CT(\"Script.Mod_ExpBK.107\"),CT(\"Script.Mod_ExpBK.123\"), 0);",
                        "        }",
                        "        if(!temp_int_3 && ShipStatus(Player(), 0) >= 30 && LTradeLicenseCheck == 1 && BKexist != 3)",
                        "        {",
                        "            AddDialogInject('TradeLicense', CT(\"Script.Mod_ExpBK.124\"),CT(\"Script.Mod_ExpBK.125\"), 0);",
                        "        }",
                        "        if(temp_int_3 == 1 && BKexist != 3)",
                        "        {",
                        "            temp_str = Format(CT(\"Script.Mod_ExpBK.129\"),\"<0>\",temp_int - CurTurn() + 2);",
                        "            if((temp_int - CurTurn() + 2) == 1) temp_str = CT(\"Script.Mod_ExpBK.128\");",
                        "            AddDialogInject('TradeLicense', Format(CT(\"Script.Mod_ExpBK.127\"),\"<0>\",temp_str),CT(\"Script.Mod_ExpBK.117\"), 0);",
                        "        }",
                        "        //Если у игрока есть торговая лицензия",
                        "        if(~ShipFindCustomShipInfoByType(Player(), 'Trade_license'))",
                        "        {",
                        "            AddDialogInject('BuyTerminalBK', '', CT(\"Script.Mod_ExpBK.192\"), 0);",
                        "        }",
                        "        //Если мод ExpPilotBridge отключён (иначе вывод новостей можно будет включить на мостике)",
                        "        if(!IsScriptActive('Mod_ExpPilotBridge'))",
                        "        {",
                        "            AddDialogInject('TradeNewsBK', '', CT(\"Script.Mod_ExpBK.70\"), 0);",
                        "        }",
                        "    }",
                        "    else if(PlayerBridge())",
                        "    {",
                        "        if(BKexist)",
                        "        {",
                        "            if(IsScriptActive('Mod_ExpPilotBridge'))",
                        "            {",
                        "                if(PlayerBridge() == 14)",
                        "                {",
                        "                    AddDialogInject('', CT(\"Script.Mod_ExpBK.191\"), 'BlockThisAnswer', 100);",
                        "                    AddDialogBlock('BlockThisAnswer', 2);",
                        "",
                        "                    AddDialogInject('Deposit', '', CT(\"Script.Mod_ExpBK.194\"), 15);",
                        "",
                        "                    if(!PlayerDeposit()) AddDialogBlock(CT(\"Script.Mod_ExpBK.194\"), 1);",
                        "                    AddDialogInject('Loan', '', CT(\"Script.Mod_ExpBK.195\"), 10);",
                        "",
                        "                    if(!PlayerDebt()) AddDialogBlock(CT(\"Script.Mod_ExpBK.195\"), 1);",
                        "                    AddDialogInject('BuyTerminalBK', '', CT(\"Script.Mod_ExpBK.192\"), 5);",
                        "",
                        "                    //Если у игрока нет торговой лицензии",
                        "                    if(ShipFindCustomShipInfoByType(Player(),'Trade_license') == -1) AddDialogBlock(CT(\"Script.Mod_ExpBK.192\"), 1);",
                        "",
                        "                    //Запоминание номер мостика с Галанетом для возможности автоматического возврата на него в случае закрытия всех доп. диалогов БЦ",
                        "                    LBridgeCheck = 14;",
                        "                }",
                        "            }",
                        "            else",
                        "            {",
                        "                if(PlayerBridge() == 1 || PlayerBridge() == 2)",
                        "                {",
                        "                    AddDialogInject('Deposit','',CT(\"Script.Mod_ExpBK.194\"), 0);",
                        "",
                        "                    if(!PlayerDeposit()) AddDialogBlock(CT(\"Script.Mod_ExpBK.194\"), 1);",
                        "                    AddDialogInject('Loan','',CT(\"Script.Mod_ExpBK.195\"), 0);",
                        "",
                        "                    if(!PlayerDebt()) AddDialogBlock(CT(\"Script.Mod_ExpBK.195\"), 1);",
                        "                    AddDialogInject('BuyTerminalBK', '', CT(\"Script.Mod_ExpBK.192\"), 0);",
                        "",
                        "                    //Если у игрока нет торговой лицензии",
                        "                    if(ShipFindCustomShipInfoByType(Player(),'Trade_license') == -1) AddDialogBlock(CT(\"Script.Mod_ExpBK.192\"), 1);",
                        "",
                        "                    //Запоминание номер мостика для возможности автоматического возврата на него в случае закрытия всех доп. диалогов БЦ",
                        "                    if(PlayerBridge() == 1) LBridgeCheck = 1;",
                        "                    else LBridgeCheck = 2;",
                        "                }",
                        "            }",
                        "        }",
                        "        DefSplt = '';",
                        "    }",
                        "}",
                        "if(!IsScriptActive('Mod_ExpPilotBridge')) {",
                        "  if(PlayerBridge() >= 1 && PlayerBridge() <= 3) {",
                        "    if(!news_ok)",
                        "    {",
                        "        temp_str=CT(\"Script.Mod_ExpBK.170\");",
                        "        if(GetGameOptions('FontDialog')<3)AddDialogInject('TradeNews_ON',Format(CT(\"Script.Mod_ExpBK.95\"),\"<0>\",temp_str),CT(\"Script.Mod_ExpBK.169\"),10);",
                        "        if(GetGameOptions('FontDialog')==3)AddDialogInject('TradeNews_ON',Format(CT(\"Script.Mod_ExpBK.95\"),\"<0>\",temp_str),CT(\"Script.Mod_ExpBK.168\"),10);",
                        "    }",
                        "    else",
                        "    {",
                        "        temp_str=CT(\"Script.Mod_ExpBK.167\");",
                        "        if(GetGameOptions('FontDialog')<3)AddDialogInject('TradeNews_OFF',Format(CT(\"Script.Mod_ExpBK.95\"),\"<0>\",temp_str),CT(\"Script.Mod_ExpBK.166\"),10);",
                        "        if(GetGameOptions('FontDialog')==3)AddDialogInject('TradeNews_OFF',Format(CT(\"Script.Mod_ExpBK.95\"),\"<0>\",temp_str),CT(\"Script.Mod_ExpBK.165\"),10);",
                        "    }",
                        "  }",
                        "}",
                        "if(IsScriptActive('Mod_ExpPilotBridge')) {",
                        "  if(PlayerBridge() == 12) {",
                        "    if(!news_ok)",
                        "    {",
                        "        temp_str=CT(\"Script.Mod_ExpBK.170\");",
                        "        if(GetGameOptions('FontDialog')<3)AddDialogInject('TradeNews_ON',Format(CT(\"Script.Mod_ExpBK.95\"),\"<0>\",temp_str),CT(\"Script.Mod_ExpBK.169\"),10);",
                        "        if(GetGameOptions('FontDialog')==3)AddDialogInject('TradeNews_ON',Format(CT(\"Script.Mod_ExpBK.95\"),\"<0>\",temp_str),CT(\"Script.Mod_ExpBK.168\"),10);",
                        "    }",
                        "    else",
                        "    {",
                        "        temp_str=CT(\"Script.Mod_ExpBK.167\");",
                        "        if(GetGameOptions('FontDialog')<3)AddDialogInject('TradeNews_OFF',Format(CT(\"Script.Mod_ExpBK.95\"),\"<0>\",temp_str),CT(\"Script.Mod_ExpBK.166\"),10);",
                        "        if(GetGameOptions('FontDialog')==3)AddDialogInject('TradeNews_OFF',Format(CT(\"Script.Mod_ExpBK.95\"),\"<0>\",temp_str),CT(\"Script.Mod_ExpBK.165\"),10);",
                        "    }",
                        "  }",
                        "}"
                    ],
