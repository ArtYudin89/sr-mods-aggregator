                },
                {
                    "Name": "",
                    "Code.Type": "Turn",
                    "Code": [
                        "choose_planet = GAnswerData;",
                        "if(GetGameOptions('FontDialog') == '0') temp_str=CT('FormInfo.td_otstup_4')+CT(\"Script.Mod_ExpBK.183\")+CT('FormInfo.td_otstup_5')+CT(\"Script.Mod_ExpBK.182\")+CT(\"Script.Mod_ExpBK.32\");",
                        "else if(GetGameOptions('FontDialog') == '1') temp_str=CT('FormInfo.td_otstup_4')+CT(\"Script.Mod_ExpBK.183\")+CT('FormInfo.td_otstup_6')+CT(\"Script.Mod_ExpBK.182\")+CT(\"Script.Mod_ExpBK.32\");",
                        "else if(GetGameOptions('FontDialog') == '2') temp_str=CT('FormInfo.td_otstup_4')+CT(\"Script.Mod_ExpBK.183\")+CT('FormInfo.td_otstup_7')+CT(\"Script.Mod_ExpBK.182\")+CT(\"Script.Mod_ExpBK.32\");",
                        "else temp_str=CT('FormInfo.td_otstup_4')+CT(\"Script.Mod_ExpBK.183\")+CT('FormInfo.td_otstup_8')+CT(\"Script.Mod_ExpBK.182\")+CT(\"Script.Mod_ExpBK.32\");",
                        "for(i = 0; i < 8; i = i + 1)",
                        "{",
                        "    temp_int = GoodsAdd(choose_planet, i, 0);",
                        "    if(!temp_int) temp_str_6 = '<color=255,0,0>' + temp_int + '</color>';",
                        "    else temp_str_6=temp_int;",
                        "    if(temp_int<10)temp_str_2='       '+temp_str_6;",
                        "    if(temp_int>9 && temp_int<100)temp_str_2='     '+temp_str_6;",
                        "    if(temp_int>99 && temp_int<1000)temp_str_2='   '+temp_str_6;",
                        "    if(temp_int>999 && temp_int<10000)temp_str_2=' '+temp_str_6;",
                        "    if(temp_int>9999 && temp_int<100000)temp_str_2=temp_str_6;",
                        "    temp_int=GoodsBuyPrice(choose_planet,i);",
                        "    if(temp_int<10)temp_str_3='/      '+temp_int;",
                        "    if(temp_int>9 && temp_int<100)temp_str_3='/    '+temp_int;",
                        "    if(temp_int>99 && temp_int<1000)temp_str_3='/  '+temp_int;",
                        "    if(temp_int>999 && temp_int<10000)temp_str_3='/'+temp_int;",
                        "    if(temp_int>9999 && temp_int<100000)temp_str_3=temp_int;",
                        "    if(ShipType(GetShipRuins(Player()))=='BK')",
                        "    {",
                        "        temp_int=GoodsBuyPrice(choose_planet,i);",
                        "        temp_int_5=round(Commission*temp_int);",
                        "        if(temp_int_5==temp_int)temp_int=temp_int_5+1;",
                        "        else temp_int=temp_int_5;",
                        "        if(temp_int<10)temp_str_4='    ('+temp_int+')';",
                        "        if(temp_int>9 && temp_int<100)temp_str_4='   ('+temp_int+')';",
                        "        if(temp_int>99 && temp_int<1000)temp_str_4=' ('+temp_int+')';",
                        "    }",
                        "    if(ShipType(GetShipRuins(Player()))!='BK')",
                        "    {",
                        "        temp_int=GoodsBuyPrice(choose_planet,i);",
                        "        temp_int_5=round(Commission*temp_int);",
                        "        if(temp_int_5==temp_int)temp_int=temp_int_5+1;",
                        "        else temp_int=temp_int_5;",
                        "        if(temp_int<10)temp_str_4='    ('+temp_int+')';",
                        "        if(temp_int>9 && temp_int<100)temp_str_4='   ('+temp_int+')';",
                        "        if(temp_int>99 && temp_int<1000)temp_str_4=' ('+temp_int+')';",
                        "    }",
                        "    if(ShipGoodsIllegalOnPlanet(Player(),i,choose_planet)==0)",
                        "    {",
                        "        temp_str=temp_str+'<color=0,50,200>'+type_name[i+1]+':</color><clrEnd>'+CT('FormInfo.td_otstup_1')+temp_str_2+CT('FormInfo.td_otstup_2')+temp_str_3+'<color=120,120,120>'+temp_str_4+'</color>'+CT(\"Script.Mod_ExpBK.32\");",
                        "    }",
                        "    if(ShipGoodsIllegalOnPlanet(Player(),i,choose_planet)==1)",
                        "    {",
                        "        temp_str=temp_str+'<color=255,0,0>'+type_name[i+1]+':</color><clrEnd>'+CT('FormInfo.td_otstup_1')+temp_str_2+CT('FormInfo.td_otstup_2')+temp_str_3+'<color=120,120,120>'+temp_str_4+'</color>'+CT(\"Script.Mod_ExpBK.32\");",
                        "    }",
                        "}",
                        "DChange(8);",
                        "exit;"
                    ],
                    "#": 114,
                    "Type": "Top",
                    "Parent": -1,
                    "Pos.x": 100,
                    "Pos.y": 450
                },
                {
                    "Name": "",
                    "Code.Type": "Turn",
                    "Code": [
                        "type = GAnswerData;",
                        "",
                        "buy_count=GoodsAdd(choose_planet,type-1,0)+1;",
                        "buy_count=min(GoodsAdd(choose_planet,type-1,0),buy_count);",
                        "temp_int=GoodsBuyPrice(choose_planet,type-1);",
                        "if(ShipType(GetShipRuins(Player()))=='BK')",
                        "{",
                        "    temp_str_6=temp_int;",
                        "    temp_int_5=round(Commission*temp_int);",
                        "    if(temp_int_5==temp_int)temp_int=temp_int_5+1;",
                        "    else temp_int=temp_int_5;",
                        "}",
                        "if(ShipType(GetShipRuins(Player()))!='BK')",
                        "{",
                        "    temp_str_6=temp_int;",
                        "    temp_int_5=round(Commission*temp_int);",
                        "    if(temp_int_5==temp_int)temp_int=temp_int_5+1;",
                        "    else temp_int=temp_int_5;",
                        "}",
                        "if(type==1)",
                        "{",
                        "    temp_int_1=int(ShipMoney(Player())/temp_int);",
                        "    buy_count=CountBox('Bm.Items.2Food',CT(\"Script.Mod_ExpBK.100\"),1,buy_count,temp_int,1,temp_int_1,buy_count,ShipMoney(Player()));",
                        "}",
                        "else if(type==2)",
                        "{",
                        "    temp_int_1=int(ShipMoney(Player())/temp_int);",
                        "    buy_count=CountBox('Bm.Items.2Medicine',CT(\"Script.Mod_ExpBK.100\"),1,buy_count,temp_int,1,temp_int_1,buy_count,ShipMoney(Player()));",
                        "}",
                        "else if(type==3)",
                        "{",
                        "    temp_int_1=int(ShipMoney(Player())/temp_int);",
                        "    buy_count=CountBox('Bm.Items.2Technics',CT(\"Script.Mod_ExpBK.100\"),1,buy_count,temp_int,1,temp_int_1,buy_count,ShipMoney(Player()));",
                        "}",
                        "else if(type==4)",
                        "{",
                        "    temp_int_1=int(ShipMoney(Player())/temp_int);",
                        "    buy_count=CountBox('Bm.Items.2Luxury',CT(\"Script.Mod_ExpBK.100\"),1,buy_count,temp_int,1,temp_int_1,buy_count,ShipMoney(Player()));",
                        "}",
                        "else if(type==5)",
                        "{",
                        "    temp_int_1=int(ShipMoney(Player())/temp_int);",
                        "    buy_count=CountBox('Bm.Items.2Minerals',CT(\"Script.Mod_ExpBK.100\"),1,buy_count,temp_int,1,temp_int_1,buy_count,ShipMoney(Player()));",
                        "}",
                        "else if(type==6)",
                        "{",
                        "    temp_int_1=int(ShipMoney(Player())/temp_int);",
                        "    buy_count=CountBox('Bm.Items.2Alcohol',CT(\"Script.Mod_ExpBK.100\"),1,buy_count,temp_int,1,temp_int_1,buy_count,ShipMoney(Player()));",
                        "}",
                        "else if(type==7)",
                        "{",
                        "    temp_int_1=int(ShipMoney(Player())/temp_int);",
                        "    buy_count=CountBox('Bm.Items.2Arms',CT(\"Script.Mod_ExpBK.100\"),1,buy_count,temp_int,1,temp_int_1,buy_count,ShipMoney(Player()));",
                        "}",
                        "else if(type==8)",
                        "{",
                        "    temp_int_1=int(ShipMoney(Player())/temp_int);",
                        "    buy_count=CountBox('Bm.Items.2Narcotics',CT(\"Script.Mod_ExpBK.100\"),1,buy_count,temp_int,1,temp_int_1,buy_count,ShipMoney(Player()));",
                        "}",
                        "buy_cost = buy_count * temp_int;",
                        "if(GetGameOptions('FontDialog') == '0') DefSplt = '</color>-------------------------------------------------------------';",
                        "else if(GetGameOptions('FontDialog') == '1') DefSplt = '</color>------------------------------------------';",
                        "else if(GetGameOptions('FontDialog') == '2') DefSplt = '</color>-----------------------------------------';",
                        "else DefSplt = '</color>-------------------------------------';",
                        "if(buy_count > 0) {",
                        "  DChange(9);",
                        "  exit;",
                        "}",
                        "if(buy_count <= 0) {",
                        "  DChange(8);",
                        "  exit;",
                        "}"
                    ],
                    "#": 115,
                    "Type": "Top",
                    "Parent": -1,
                    "Pos.x": 220,
                    "Pos.y": 450
                },
                {
                    "Name": "",
                    "Code.Type": "Turn",
                    "Code": [
                        "//Если закупка происходит на мостике",
                        "if(PlayerBridge())",
                        "{",
                        "    temp_str_5 = '7%';",
