                        "}",
                        "",
                        "//Совершаем прыжок (ебаная нумерация систем начинается с 0)",
                        "if(GetData(1))",
                        "{",
                        "    if(!ShipInNormalSpace(CurShip))",
                        "    {",
                        "        OrderTakeOff(CurShip);",
                        "        exit;",
                        "    }",
                        "",
                        "    object = GalaxyStar(GetData(1) - 1);",
