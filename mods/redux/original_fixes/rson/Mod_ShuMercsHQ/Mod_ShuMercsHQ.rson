                        "                tstr2 = '</color>' + CT('Talk.Exit');",
                        "            }",
                        "            else",
                        "            {",
                        "                cur_star = GalaxyStar(ActiveQuestsHQArray[1, 8] - 1);",
                        "                //Если квест по захвату ещё в процессе",
                        "                if(StarOwner(cur_star) != 2)",
                        "                {",
                        "                    tstr1 = '</color>' + CT(ActiveQuestsHQArray[1, 3] + '.SupportGreeting');",
                        "                    tstr2 = '</color>' + CT('Talk.Exit');",
