                        "                    for(i = 1; i <= Rnd(GetParFromString(ActiveQuestsHQArray[ActiveQuestHQ, 8], ',', 0, 0), GetParFromString(ActiveQuestsHQArray[ActiveQuestHQ, 8], ',', 1, 0)); i = i + 1)",
