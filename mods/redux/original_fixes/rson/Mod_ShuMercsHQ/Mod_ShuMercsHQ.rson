                        "//Ищем в системе любые враждебные пиратам корабли и станции, выбираем ближайший, и атакуем",
                        "int closest_dist = 500000;",
                        "target = 0;",
                        "for(i = 0; i < StarShips(cur_star); i = i + 1)",
                        "{",
