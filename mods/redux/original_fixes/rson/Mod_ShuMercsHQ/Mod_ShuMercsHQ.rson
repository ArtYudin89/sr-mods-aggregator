                        "                if(GroupToShip(PlayerHQ)) tstr1 = tstr1 + CT(\"Script.Mod_ShuMercsHQ.193\") + '<clr><clrEnd>' + CT(\"Script.Mod_ShuMercsHQ.193\") + CT(ActiveQuestsHQArray[ActiveQuestHQ, 3] + '.QuestNoteFailed');",
                        "                else tstr1 = tstr1 + CT(\"Script.Mod_ShuMercsHQ.193\") + '<clr><clrEnd>' + CT(\"Script.Mod_ShuMercsHQ.193\") + CT('Script.Mod_ShuMercs.PlayerMercsOrgMsg.QuestNoteHQDestroyed');",
