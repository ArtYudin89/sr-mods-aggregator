                        "    if(ShipInHyperSpace(ship)) continue;",
                        "    //Сразу пропускаем все про-коалиционные и нейтральные корабли и станции",
                        "    int stand = ShipStanding(ship);",
                        "    if(stand >= 1 && stand <= 6) continue;",
