                },
                {
                    "Name": "",
                    "Code.Type": "Turn",
                    "Code": [
                        "//Игрока собираются посадить/расстрелять за провал запугивания, сбежать не выйдет",
                        "if(check <= 4)",
                        "{",
                        "    if(!(status & 64))",
