                        "    tstr2 = tstr2 + CT(\"Script.Mod_ShuMercsHQ.193\") + CT('Quest.ShuMercs.QuestsHQ.Special.GluonGunsInvention.QuestNoteTitle');",
                        "    tstr2 = tstr2 + CT(\"Script.Mod_ShuMercsHQ.193\") + '<clr><clrEnd>' + CT(\"Script.Mod_ShuMercsHQ.193\") + CT('Quest.ShuMercs.QuestsHQ.Special.GluonGunsInvention.QuestNoteInProcess2');",
                        "    CustomEther('QuestInProcess_PlayerMercsOrg', 3, 'Quest.ShuMercs.QuestsHQ.Special.GluonGunsInvention', tstr2, cur_ruin);",
