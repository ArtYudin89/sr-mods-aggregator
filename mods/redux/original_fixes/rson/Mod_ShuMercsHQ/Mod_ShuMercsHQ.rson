                        "        tstr1 = '</color>' + CT('Script.Mod_ShuMercs.CreatingPlayerOrgDialogs.PlanetGovCoalThreatFail');",
                        "        tstr2 = '</color>' + CT('Script.Mod_ShuMercs.CreatingPlayerOrgDialogs.PlanetGovCoalThreatFailP');",
