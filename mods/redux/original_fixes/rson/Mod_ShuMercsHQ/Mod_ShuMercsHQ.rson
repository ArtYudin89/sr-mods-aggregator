                        "                    tstr1 = '</color>' + CT(ActiveQuestsHQArray[1, 3] + '.AttackersGreetingFoe');",
                        "                    tstr2 = '</color>' + CT('Talk.Exit');",
                        "                }",
                        "                else",
                        "                {",
                        "                    tstr1 = '</color>' + CT(ActiveQuestsHQArray[1, 3] + '.AttackersGreetingEnd');",
                        "                    tstr2 = '</color>' + CT('Talk.Exit');",
                        "                }",
