                        "        }",
                        "        else if(~findsubstr(ActiveQuestsHQArray[1, 3], '.AttackCoalition.'))",
                        "        {",
                        "            tstr1 = '</color>' + CT(ActiveQuestsHQArray[1, 3] + '.AttackersGreeting');",
                        "            tstr2 = '</color>' + CT('Talk.Exit');",
