                        "                else",
                        "                {",
                        "                    tstr1 = '</color>' + CT(ActiveQuestsHQArray[1, 3] + '.SupportGreetingAfterWin');",
                        "                    tstr2 = '</color>' + CT('Talk.Exit');",
