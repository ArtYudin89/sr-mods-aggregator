                        "        //4 - любые корабли на планетах и нейтральных станциях",
                        "        if(ShipInNormalSpace(ship) && ShipTypeN(ship) == t_Pirate && obj_type != 5)",
                        "        {",
                        "            closest_dist = dist;",
                        "            target = ship;",
                        "        }",
                        "        else if(!target)",
                        "        {",
                        "            if(ShipInNormalSpace(ship) && obj_type != 5)",
                        "            {",
                        "                closest_dist = dist;",
                        "                target = ship;",
                        "            }",
                        "            else if(!target)",
