                    "Pos.x": 190,
                    "Pos.y": 475
                },
                {
                    "Name": "",
                    "Code.Type": "Turn",
                    "Code": [
                        "cur_star = GAnswerData;",
                        "tstr1 = '</color>' + Format(CT('Script.Mod_ShuMercs.CreatingPlayerOrgDialogs.BridgeMBAnswer3'), '<Star' + '>', Name(cur_star));",
                        "DChange(7);",
