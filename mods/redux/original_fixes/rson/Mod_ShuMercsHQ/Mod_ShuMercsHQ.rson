                        "                                for(i = 0; i < GroupCount(QuestSupport); i = i + 1)",
                        "                                {",
                        "                                    tdwd1 = GroupShip(QuestSupport, i);",
                        "                                    SetData(66, 0, tdwd1); //Ставим пиратам маркер на самоликвидацию",
                        "                                    SetData(ActiveQuestsHQArray[ActiveQuestHQ, 10], 1, tdwd1);",
                        "                                }",
