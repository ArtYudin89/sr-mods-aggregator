                        "    {",
                        "        OrderJump(CurShip, object);",
                        "    }",
                        "    else",
                        "    {",
                        "        SetData(0, 1);",
                        "        //Если стоит маркер на автоматический перевод корабля в режим контроля стейтом",
                        "        if(GetData(0) == 32)",
                        "        {",
                        "            OrderLock(CurShip, 0);",
                        "            SetData(33, 0);",
                        "            exit;",
                        "        }",
                        "    }",
                        "}",
                        "//Садимся на планету/станцию",
                        "else if(GetData(2))",
