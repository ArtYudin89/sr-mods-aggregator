                        "            ActiveQuestsHQArray[ActiveQuestHQ, 4] = Format(CT(ActiveQuestsHQArray[ActiveQuestHQ, 3] + '.QuestNoteTitle'), '<TargetStar' + '>', Name(cur_star), '255,240,100');",
