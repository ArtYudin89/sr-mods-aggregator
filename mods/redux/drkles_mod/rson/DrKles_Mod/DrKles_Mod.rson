                    "Ruins": "",
                    "+Planet": "Planet1",
                    "+State": 0,
                    "Type": "TGroup",
                    "Pos.x": 80,
                    "Pos.y": 250,
                    "Parent": -1,
                    "#": 22
                }
            ],
            "Items": [
                {
                    "Type": "TItem",
                    "Name": "iGoods",
                    "Class": 5,
                    "Item.Type": 0,
                    "Size": 10,
                    "Level": 1,
                    "Radius": 150,
                    "Owner": 6,
                    "Useless": "",
                    "+Place": "",
                    "Pos.x": 0,
                    "Pos.y": 205,
                    "Parent": -1,
                    "#": 21
                }
            ],
            "Operations": [
                {
                    "Name": "",
                    "Code.Type": "Global",
                    "Code": [
                        "if(GRunFrom==3 && CurTurn()-GLastTurnRun(GScriptName)>684) {",
                        "  if(!ill_Run) {",
                        "    GRun();",
                        "  }",
                        "}"
                    ],
                    "#": 23,
                    "Type": "Top",
                    "Parent": -1,
                    "Pos.x": 0,
                    "Pos.y": 635
                },
                {
                    "Name": "",
                    "Code.Type": "Init",
                    "Code": [
                        "vBegin=CurTurn();",
                        "NoTargetToShip(GroupToShip(ill), 3); //Запрет на ограбление для ИИ",
                        "UpsurgeGoods(Planet2, t_Technics); //На планете назначения начинается распродажа техники;"
                    ],
                    "#": 24,
                    "Type": "Top",
                    "Parent": -1,
                    "Pos.x": 60,
                    "Pos.y": 635
                },
                {
                    "Name": "",
                    "Code.Type": "Turn",
                    "Code": [
                        "//vState :",
                        "//0-Игрок еще не разговаривал",
                        "//1-Игрок отказался",
                        "//2-Игрок согласился",
                        "//3-Подбор груза",
                        "//4-Игрок привез технику, но не дал нпс",
                        "if(!vMedOk) { //Фиксируем факт покупки техники на нужной планете",
                        "  if(vState==2) {",
                        "    for(i=GalaxyEvents()-1; i>=0; i=i-1) {",
                        "      if(GalaxyEventDate(i)<CurTurn()) break;",
                        "      if(GalaxyEventType(i)=='PlayerBuysGoodsFromPlanet') {",
                        "        if(GalaxyEventData(i, 0)==t_Technics && GalaxyEventData(i, 3)==Id(Planet2)) vMedOk=1;",
                        "      }",
                        "    }",
                        "  }",
                        "}",
                        "if (GZadanieStatus == 1 && zadanie_timer>0)",
                        "{",
                        "    zadanie_timer = zadanie_timer - 1;",
                        "    Ether(3, 'Petrovish', Format(CT(\"Script.DrKles_Mod.48\"),\"<0>\",Name(Planet2),\"<1>\",Name(Star2),\"<2>\",Name(GroupToShip(ill)),\"<3>\",Name(Star1),\"<4>\",GameDateTxtByTurn(vEnd),\"<5>\",zadanie_timer), GroupToShip(ill));",
                        "}"
                    ],
                    "#": 25,
                    "Type": "Top",
                    "Parent": -1,
                    "Pos.x": 120,
                    "Pos.y": 635
                },
                {
                    "Name": "",
                    "Code.Type": "Turn",
                    "Code": [
                        "if(!vState) {",
                        "  if(CountTurn(Player(), GroupToShip(ill))<784) {",
                        "    Ether(1, '', Format(CT(\"Script.DrKles_Mod.47\"),\"<0>\",Name(CurShip)), CurShip);",
                        "  }",
                        "}",
                        "if((CurTurn()-vBegin)>vMaxDay) { //Если время на выполнение задания истекло, корабль взрывается, задание проваливается",
                        "  ShipDestroy(CurShip);",
                        "  if(vState==2) {",
                        "    Ether(5, 'Petrovish', Format(CT(\"Script.DrKles_Mod.41\"),\"<0>\",Name(Planet2),\"<1>\",Name(Star2),\"<2>\",Name(GroupToShip(ill)),\"<3>\",Name(Star1),\"<4>\",GameDateTxtByTurn(vEnd)), GroupToShip(ill));",
                        "  }",
                        "}",
                        "else if(vState==1) { //То же самое, что и выше, но с выводом сообщения",
                        "  if((CurTurn()-vBegin)>=vMaxDay) {",
                        "    Ether(1, 'Nesi-Klushi-Seihas budem shinit eto barahlo', Format(CT(\"Script.DrKles_Mod.42\"),\"<0>\",Name(CurShip)), CurShip);",
                        "    ShipDestroy(CurShip);",
                        "  }",
                        "}",
                        "if(ShipInNormalSpace(CurShip)) {",
                        "  ShipFuel(GroupToShip(ill), 1);",
                        "  if(ShipInStar(Player(), Star1)) {",
                        "    if(Dist(CurShip, Player())<600) { //Начало первого диалога (просьба о помощи)",
                        "      if(vState==0) {",
                        "        Dialog(dTalk, ill);",
                        "      }",
                        "      if(vState==2) { //Начало второго диалога (игрок согласился помочь)",
                        "        if(vMedOk) {",
                        "          Dialog(dTalk, ill);",
                        "        }",
                        "      }",
                        "    }",
                        "  }",
                        "}",
                        "SetName(CurShip,'Артемий Тестировщик');",
                        "ShipFace(CurShip,4);",
                        "OrderForsage(CurShip,2);",
                        "if(vState==3) {",
                        "    ChangeState(1);",
                        "    exit;",
                        "}"
                    ],
                    "#": 63,
                    "Type": "Top",
                    "Parent": -1,
                    "Pos.x": 80
                },
                {
                    "Name": "",
                    "Code.Type": "Turn",
                    "Code": [
                        "if((CurTurn()-vBegin)>4) {",
                        "  //Если время на выполнение задания истекло, корабль взрывается, задание проваливается",
                        "  Ether(5, 'Petrovish', Format(CT(\"Script.DrKles_Mod.41\"),\"<0>\",Name(Planet2),\"<1>\",Name(Star2),\"<2>\",Name(GroupToShip(ill)),\"<3>\",Name(Star1),\"<4>\",GameDateTxtByTurn(vEnd)), GroupToShip(ill));",
                        "  ShipDestroy(CurShip);",
                        "  GZadanieStatus = 0;",
                        "}",
                        "if(GoodsCount(CurShip,2)) {",
                        "  if(!vMedOk) { //Если техника не с нужной планеты, корабль взрывается",
                        "    if(ShipInNormalSpace(Player()) && ShipInStar(Player(), Star1)) {",
                        "      Dialog(dEnd, ill);",
                        "      ShipDestroy(CurShip);",
                        "    }",
                        "  }",
                        "  GZadanieStatus = 0;",
                        "  if(vMedOk) vEndDialogOk=0;",
                        "  ChangeState(2);",
                        "  exit;",
                        "}"
                    ],
                    "#": 64,
                    "Type": "Top",
                    "Parent": -1,
                    "Pos.x": 160
                },
                {
                    "Name": "",
                    "Code.Type": "Turn",
                    "Code": [
                        "if(!vEndDialogOk) {",
                        "  if(ShipInNormalSpace(Player()) && ShipInStar(Player(), Star1)) {",
                        "    vEndDialogOk=Dialog(dEnd, ill);",
                        "  }",
                        "}",
                        "if(EndState) {",
                        "  NoTargetToShip(GroupToShip(ill), 0);",
                        "  ShipOut();",
                        "}",
                        "GZadanieStatus = 0;"
                    ],
                    "#": 65,
                    "Type": "Top",
