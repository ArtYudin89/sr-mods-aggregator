                    "Pos.x": 240
                },
                {
                    "Name": "",
                    "Code.Type": "Turn",
                    "Code": [
                        "if(vState==4) {",
                        "  DChange(14);",
                        "  exit;",
                        "}",
                        "if(vState==1) {",
                        "  DChange(13);",
                        "  exit;",
                        "}",
                        "if(vState==2) {",
                        "  if(vMedOk) {",
                        "    if(Dist(CurShip,Player())<500) {",
                        "      DChange(6);",
                        "      exit;",
                        "    }",
                        "    DChange(5);",
                        "    exit;",
                        "  }",
                        "  if((CurTurn()-vBegin)>=vMaxDay/2) {",
                        "    if(Dist(CurShip,Player())<500) {",
                        "      DChange(6);",
                        "      exit;",
                        "    }",
                        "    DChange(5);",
                        "    exit;",
                        "  }",
                        "  DChange(4);",
                        "  exit;",
                        "}",
                        "if(vState==0) {",
                        "  DChange(0);",
                        "  exit;",
                        "}"
