    "Visual.Objects": [
        {
            "ConstellationCount": 0,
            "DialogAnswers": [
                {
                    "Name": "",
                    "Pos.x": 0,
                    "Pos.y": 540,
                    "Type": "TDialogAnswer",
                    "Parent": -1,
                    "#": 47,
                    "Msg": "Такая жизнь, увы! Большинство не хочет разбираться с решением чужих проблем, только со своими собственными. Так а что случилось-то? Вижу, ты тут буксуешь на месте и не торопишься совершать посадку на какую-либо планету или станцию.",
                    "AMsg.Num": "0",
                    "_orig_danswer": "DAnswer(CT(\"Script.DrKles_Mod.38\"))"
                },
                {
                    "Name": "",
                    "Pos.x": 120,
                    "Pos.y": 540,
                    "Type": "TDialogAnswer",
                    "Parent": -1,
                    "#": 48,
                    "Msg": "Слушай, невовремя ты меня набрал, обратись к кому-нибудь другому, пожалуйста. Ещё своих дел хватает.",
                    "AMsg.Num": "1",
                    "_orig_danswer": "DAnswer(CT(\"Script.DrKles_Mod.19\"))"
                },
                {
                    "Name": "exit",
                    "Pos.x": 240,
                    "Pos.y": 540,
                    "Type": "TDialogAnswer",
                    "Parent": -1,
                    "#": 49,
                    "Msg": "",
                    "AMsg.Num": "2",
                    "_orig_danswer": "DAnswer('exit')"
                },
                {
                    "Name": "",
                    "Pos.x": 360,
                    "Pos.y": 540,
                    "Type": "TDialogAnswer",
                    "Parent": -1,
                    "#": 50,
                    "Msg": "Хорошо, я постараюсь уложиться в срок. Держись тут!",
                    "AMsg.Num": "3",
                    "_orig_danswer": "DAnswer(CT(\"Script.DrKles_Mod.20\"))"
                },
                {
                    "Name": "exit",
                    "Pos.x": 480,
                    "Pos.y": 540,
                    "Type": "TDialogAnswer",
                    "Parent": -1,
                    "#": 51,
                    "Msg": "",
                    "AMsg.Num": "4",
                    "_orig_danswer": "DAnswer('exit')"
                },
                {
                    "Name": "",
                    "Pos.x": 600,
                    "Pos.y": 540,
                    "Type": "TDialogAnswer",
                    "Parent": -1,
                    "#": 52,
                    "Msg": "Да, конечно, дружище. Держи!",
                    "AMsg.Num": "5",
                    "_orig_danswer": "DAnswer(CT(\"Script.DrKles_Mod.21\"))"
                },
                {
                    "Name": "",
                    "Pos.x": 720,
                    "Pos.y": 540,
                    "Type": "TDialogAnswer",
                    "Parent": -1,
                    "#": 53,
                    "Msg": "У меня есть техника, только не с этой планеты. Она сгодится?",
                    "AMsg.Num": "6",
                    "_orig_danswer": "DAnswer(CT(\"Script.DrKles_Mod.22\"))"
                },
                {
                    "Name": "",
                    "Pos.x": 840,
                    "Pos.y": 540,
                    "Type": "TDialogAnswer",
                    "Parent": -1,
                    "#": 54,
                    "Msg": "К сожалению, нет. Я был занят другими более важными делами. Прости...",
                    "AMsg.Num": "7",
                    "_orig_danswer": "DAnswer(CT(\"Script.DrKles_Mod.23\"))"
                },
                {
                    "Name": "exit",
                    "Pos.x": 960,
