                        "DAdd(2);"
                    ],
                    "#": 39,
                    "Type": "Top",
                    "Parent": -1,
                    "Pos.x": 280,
                    "Pos.y": 470
                },
                {
                    "Name": "",
                    "Code.Type": "Turn",
                    "Code": [
                        "DAdd(0);"
                    ],
                    "#": 40,
                    "Type": "Top",
                    "Parent": -1,
                    "Pos.x": 430,
                    "Pos.y": 470
                },
                {
                    "Name": "",
                    "Code.Type": "Turn",
                    "Code": [
                        "DAdd(6);",
                        "DAdd(7);",
                        "DAdd(8);"
                    ],
                    "#": 41,
                    "Type": "Top",
                    "Parent": -1,
                    "Pos.x": 580,
                    "Pos.y": 470
                },
                {
                    "Name": "",
                    "Code.Type": "Turn",
                    "Code": [
                        "ShipMoney(Player(), ShipMoney(Player()) - cost_sponsor);",
                        "Sound('Sound.Buy');",
                        "",
                        "ItemExtraSpecialsAddByType(ShipEqInSlot(Player(),t_Hull),FindBonusByNameInCfg('Cat_Corvette_FragilityMinus'));",
                        "",
                        "//Блокируем бесконечный зачар",
                        "if(ItemExtraSpecialsCountByType(ShipEqInSlot(Player(),t_Hull),FindBonusByNameInCfg('Cat_Corvette_FragilityMinus')) > 2) state = 2;",
                        "DChange(2);",
                        "exit;"
                    ],
                    "#": 42,
                    "Type": "Top",
                    "Parent": -1,
                    "Pos.x": 100,
                    "Pos.y": 540
                },
                {
                    "Name": "",
                    "Code.Type": "Turn",
                    "Code": [
                        "DChange(4);",
                        "exit;"
                    ],
                    "#": 43,
                    "Type": "Top",
                    "Parent": -1,
                    "Pos.x": 340,
                    "Pos.y": 540
                },
                {
                    "Name": "",
                    "Code.Type": "Turn",
                    "Code": [
                        "cost = 1000;",
                        "ShipMoney(Player(), ShipMoney(Player()) - cost_sponsor);",
                        "Sound('Sound.Buy');",
                        "",
                        "state = 1;",
                        "",
                        "hull = CreateHull(0,cost,GalaxyTechLevel(),People,-1);",
                        "ItemCost(hull,ItemCost(hull)+cost_sponsor);",
                        "LinkItemToScript(hull,hullik);",
                        "ItemOnActCode(hull,GenerateCodeStringFromBlock('ActCodeBlocksList.Cat_Corvette_OnActCode'));",
                        "SpecialToEquipment(FindBonusByNameInCfg('Cat_Corvette'),hull);",
                        "ShipAddCustomShipInfo(Player(),'CatCorvette_Buffs',0,cost*0.25);",
                        "",
                        "AddItemToStorage(GetShipRuins(Player()),hull);",
                        "DChange(3);",
                        "exit;"
                    ],
                    "#": 44,
                    "Type": "Top",
