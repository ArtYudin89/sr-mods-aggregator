            "Operations": [
                {
                    "Name": "",
                    "Code.Type": "Global",
                    "Code": [
                        "GRun();"
                    ],
                    "#": 16,
                    "Type": "Top",
                    "Parent": -1,
                    "Pos.x": 0,
                    "Pos.y": 610
                },
                {
                    "Name": "",
                    "Code.Type": "DialogBegin",
                    "Code": [
                        "if(GalaxyTechLevel() > 4) {",
                        "  if(ShipRank(Player()) > 5) {",
                        "    if(!ShipOnSidePirateClan(Player())) {",
                        "      if(ShipStatistic(Player(),3) > 4) {",
                        "        if(!PlayerBridge()) {",
                        "          if(GetShipRuins(Player())) {",
                        "            if(state == 0) {",
                        "              if(ShipType(GetShipRuins(Player())) == 'WB') {",
                        "                AddDialogInject('DialogTC1', CT(\"Script.Cat_Corvette.209\"), CT(\"Script.Cat_Corvette.208\"), 1);",
                        "                cost_sponsor = GalaxyMoney(4,4) * 15;",
                        "              }",
                        "            }",
                        "            if(state == 1) {",
                        "              if(~HullSpecial(Player())) {",
                        "                if(HullSpecial(Player()) == FindBonusByNameInCfg('Cat_Corvette')) {",
                        "                  if(ShipType(GetShipRuins(Player())) == 'TC') {",
                        "                    AddDialogInject('DialogTC1.5', '', CT(\"Script.Cat_Corvette.207\"), 1);",
                        "                    cost_sponsor = GalaxyMoney(4,4) * 4;",
                        "                  }",
                        "                }",
                        "              }",
                        "            }",
                        "          }",
                        "        }",
                        "      }",
                        "    }",
                        "  }",
                        "}"
                    ],
                    "#": 17,
                    "Type": "Top",
                    "Parent": -1,
                    "Pos.x": 180,
                    "Pos.y": 610
                },
                {
                    "Name": "",
                    "Code.Type": "Turn",
                    "Code": [
                        "DChange(0);",
                        "exit;"
                    ],
                    "#": 35,
                    "Type": "Top",
                    "Parent": -1,
                    "Pos.x": -20,
                    "Pos.y": 400
                },
                {
                    "Name": "",
                    "Code.Type": "Turn",
                    "Code": [
                        "DChange(1);",
                        "exit;"
                    ],
                    "#": 36,
                    "Type": "Top",
                    "Parent": -1,
                    "Pos.x": 130,
                    "Pos.y": 400
                },
                {
                    "Name": "",
                    "Code.Type": "Turn",
                    "Code": [
                        "if(ShipMoney(Player()) >= cost_sponsor) {",
                        "  DAdd(3);",
                        "}",
                        "DAdd(4);"
                    ],
                    "#": 37,
                    "Type": "Top",
                    "Parent": -1,
                    "Pos.x": -20,
                    "Pos.y": 470
                },
                {
                    "Name": "",
                    "Code.Type": "Turn",
                    "Code": [
                        "if(ShipMoney(Player()) >= cost_sponsor) {",
                        "  DAdd(1);",
                        "}",
                        "DAdd(5);"
                    ],
                    "#": 38,
                    "Type": "Top",
                    "Parent": -1,
                    "Pos.x": 130,
                    "Pos.y": 470
                },
                {
                    "Name": "",
