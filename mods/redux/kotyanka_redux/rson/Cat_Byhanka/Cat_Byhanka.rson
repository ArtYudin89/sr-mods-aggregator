                        "GRun();"
                    ],
                    "#": 33,
                    "Type": "Top",
                    "Parent": -1,
                    "Pos.x": 0,
                    "Pos.y": 660
                },
                {
                    "Name": "",
                    "Code.Type": "Init",
                    "Code": [
                        "Delivers = CT('Script.Cat_Byhanka.BuhankaCnt');",
                        "ToComplete = CT('Script.Cat_Byhanka.QuestsCnt');",
                        "hull_size = CT('Script.Cat_Byhanka.BuhankaSize');",
                        "Time =  CT('Script.Cat_Byhanka.BuhankaTime');",
                        "if(PlanetRace(ShipStatistic(Player(),10)) == 2) RaceFlag = 1;"
                    ],
                    "#": 34,
                    "Type": "Top",
                    "Parent": -1,
                    "Pos.x": 60,
                    "Pos.y": 660
                },
                {
                    "Name": "",
                    "Code.Type": "Turn",
                    "Code": [
                        "if(PlayerRun == 0 && GQuestStatus == 3) {",
                        "    PlayerRun = 1;",
                        "}",
                        "",
                        "if(CallFlag == 2 || CallFlag > 5) {",
                        "    if(PlanetOwner(IdToPlanet(LastPlanetID)) == 5) {",
                        "        Sound('Sound.NewMsg');",
                        "        NewsAdd(Format(CT(\"Script.Cat_Byhanka.55\"),'pla',CT(\"Script.Cat_Byhanka.9\")));",
                        "        LastPlanetID = EarthID; //Да, я лентяй",
                        "        Ether(4,'CargoQuestBuha',CT(\"Script.Cat_Byhanka.46\")+' '+Name(IdToPlanet(LastPlanetID))+CT(\"Script.Cat_Byhanka.37\")+' '+Name(PlanetToStar(IdToPlanet(LastPlanetID)))+Format(CT(\"Script.Cat_Byhanka.45\"),\"<0>\",MissionTime));",
                        "    }",
                        "    if(PlanetOwner(IdToPlanet(LastPlanetID)) == 6) {",
                        "        Sound('Sound.NewMsg');",
                        "        NewsAdd(Format(CT(\"Script.Cat_Byhanka.54\"),'pla',CT(\"Script.Cat_Byhanka.9\")));",
                        "        LastPlanetID = EarthID; //Да, я лентяй",
                        "        Ether(4,'CargoQuestBuha',CT(\"Script.Cat_Byhanka.46\")+' '+Name(IdToPlanet(LastPlanetID))+CT(\"Script.Cat_Byhanka.37\")+' '+Name(PlanetToStar(IdToPlanet(LastPlanetID)))+Format(CT(\"Script.Cat_Byhanka.45\"),\"<0>\",MissionTime));",
                        "    }",
                        "    ",
                        "    if(PlanetOwner(IdToPlanet(EarthID)) == 6) {",
                        "        Sound('Sound.NewMsg');",
                        "        NewsAdd(Format(CT(\"Script.Cat_Byhanka.53\"),'pla',CT(\"Script.Cat_Byhanka.52\")));",
                        "        LastPlanetID = 0;",
                        "        EarthID = 0;",
                        "        CallFlag = 5;",
                        "    ",
                        "        Ether(5,'Buhanka',Format(CT(\"Script.Cat_Byhanka.50\"),\"<0>\",ToComplete,\"<1>\",Completed,\"<2>\",ToComplete,\"<3>\",Time));",
                        "        Ether(5,'CargoQuestBuha',CT(\"Script.Cat_Byhanka.46\")+' '+Name(IdToPlanet(LastPlanetID))+CT(\"Script.Cat_Byhanka.37\")+' '+Name(PlanetToStar(IdToPlanet(LastPlanetID)))+Format(CT(\"Script.Cat_Byhanka.45\"),\"<0>\",MissionTime));",
                        "    }",
                        "}",
                        "if(!ShipIsTakeoff(Player())) {",
                        "  //CallFlag",
                        "  //0 - задание не давали",
                        "  //1 - позвали на выдачу задания",
                        "  //2 - дали задание",
                        "  //3 - игрок завалил сроки, долг передали банкам",
                        "  //4 - игрок выполнил всё, и теперь может свободно владеть Бухой",
                        "  //5 - игрок отказался от Бухи",
                        "  //6 - игрок взял спецзадание для Почты Карагона",
                        "  //7 - игрок завалил спецзадание для Почты Карагона",
                        "   SolarFreeFlag = 0;",
                        "  if(PlayerQuestsCompleted(0) >= Delivers && !CallFlag && RaceFlag) {",
                        "      for(i=0;i<GalaxyStars();i=i+1) {",
                        "          if(StarOwner(GalaxyStar(i)) == 1) continue;",
                        "          if(findsubstr(CT('Star.02'),Name(GalaxyStar(i)))) SolarFreeFlag = 1;",
                        "      }",
                        "      if(SolarFreeFlag) {",
                        "          CallFlag = 1;",
                        "          for(i=0;i<GalaxyStars();i=i+1) {",
                        "              for(j=0;j<StarPlanets(GalaxyStar(i));j=j+1) {",
                        "                  if(Name(StarPlanets(GalaxyStar(i),j)) == CT('PlanetName.Solar.2')) {",
                        "                      Ether(3,'Buhanka', Format(CT(\"Script.Cat_Byhanka.51\"),'pla',CT(\"Script.Cat_Byhanka.9\")),StarPlanets(GalaxyStar(i),j));",
                        "                      break;",
                        "                      break;",
                        "                  }",
                        "              }",
                        "          }",
                        "          Sound('Sound.NewMsg');",
                        "      }",
                        "  }",
                        "  if(CallFlag == 2 || CallFlag == 6 || CallFlag == 7) {",
                        "      if(Time != 0) Time = Time - 1;",
                        "      if(PlayerQuestsCompleted(0) - LastCompleted + CargoCmpl != Completed) {",
                        "          Completed = PlayerQuestsCompleted(0) - LastCompleted + CargoCmpl;",
                        "      }",
                        "      Ether(3,'Buhanka',Format(CT(\"Script.Cat_Byhanka.50\"),\"<0>\",ToComplete,\"<1>\",Completed,\"<2>\",ToComplete,\"<3>\",Time));",
                        "  ",
                        "      if(Time == 0 && Completed != CT('Script.Cat_Byhanka.QuestsCnt')) {",
                        "          Ether(5,'Buhanka',CT(\"Script.Cat_Byhanka.49\"));",
                        "          Sound('Sound.QuestCancel');",
                        "          PlayerDebt(PlayerDebt()+TreatyCost);",
                        "          if(PlayerDebtDate() == 0) PlayerDebtDate(CurTurn() + Rnd(200,330));",
                        "          if(PlayerDebtCnt() == 0) PlayerDebtCnt(1);",
                        "          CallFlag = 3;",
                        "          Ether(5,'CargoQuestBuha',CT(\"Script.Cat_Byhanka.46\")+' '+Name(IdToPlanet(LastPlanetID))+CT(\"Script.Cat_Byhanka.37\")+' '+Name(PlanetToStar(IdToPlanet(LastPlanetID)))+Format(CT(\"Script.Cat_Byhanka.45\"),\"<0>\",MissionTime));",
                        "      }",
                        "      if(Completed == CT('Script.Cat_Byhanka.QuestsCnt')) {",
                        "          CallFlag = 4;",
                        "          Ether(4,'Buhanka',CT(\"Script.Cat_Byhanka.48\"));",
                        "          Sound('Sound.QuestOk');",
                        "          CanSellItem(buhanka, 1);",
                        "          for(j=0;j<10;j=j+1) {",
                        "              for(i=0;ShipItems(Player())>i;i=i+1) {",
                        "                  if(ItemType(ShipItems(Player(),i)) != t_UselessItem) continue;",
                        "                  if(Name(ShipItems(Player(),i)) == CT('UselessItems.BuhaCargo.Name')) {",
                        "                      hull_size = hull_size + 1; //Ну не пропадать же зазря переменной!",
                        "                      FreeItem(GetItemFromShip(Player(),ShipItems(Player(),i)));",
                        "                  }",
                        "              }",
                        "          }",
                        "          Ether(5,'CargoQuestBuha',CT(\"Script.Cat_Byhanka.47\"));",
                        "      }",
                        "      if(CallFlag == 6) {",
                        "          if(MissionTime != 0) {",
                        "              MissionTime = MissionTime - 1;",
                        "              Ether(3,'CargoQuestBuha',CT(\"Script.Cat_Byhanka.46\")+' '+Name(IdToPlanet(LastPlanetID))+CT(\"Script.Cat_Byhanka.37\")+' '+Name(PlanetToStar(IdToPlanet(LastPlanetID)))+Format(CT(\"Script.Cat_Byhanka.45\"),\"<0>\",MissionTime));",
                        "          }",
                        "          if(MissionTime == 0) {",
                        "              Ether(5,'CargoQuestBuha',CT(\"Script.Cat_Byhanka.46\")+' '+Name(IdToPlanet(LastPlanetID))+CT(\"Script.Cat_Byhanka.37\")+' '+Name(PlanetToStar(IdToPlanet(LastPlanetID)))+Format(CT(\"Script.Cat_Byhanka.45\"),\"<0>\",MissionTime));",
                        "              Sound('Sound.QuestCancel');",
                        "              CallFlag = 7;",
                        "          }",
                        "      }",
                        "  }",
                        "}"
                    ],
                    "#": 35,
                    "Type": "Top",
                    "Parent": -1,
                    "Pos.x": 120,
                    "Pos.y": 660
                },
                {
                    "Name": "",
                    "Code.Type": "DialogBegin",
                    "Code": [
                        "if(GetShipPlanet(Player())) {",
                        "    if(CallFlag == 1 && Name(GetShipPlanet(Player())) == CT('PlanetName.Solar.2')) {",
                        "        AddDialogInject('Buha','',CT(\"Script.Cat_Byhanka.60\"),100);",
                        "        if(ShipWealth(Player()) >= 10000000) TreatyCost = 100000000;",
                        "        if(ShipWealth(Player()) < 10000000) TreatyCost = 50000000;",
                        "        if(ShipWealth(Player()) < 3000000) TreatyCost = 25000000;",
                        "        if(ShipWealth(Player()) < 1500000) TreatyCost = 10000000;",
                        "        if(ShipWealth(Player()) < 1000000) TreatyCost = 4000000;",
                        "        if(ShipWealth(Player()) < 600000) TreatyCost = 2000000;",
                        "        if(ShipWealth(Player()) < 300000) TreatyCost = 1000000;",
                        "    }",
                        "    if(CallFlag == 2 && IdToPlanet(LastPlanetID) == GetShipPlanet(Player()) && ControlledSystems(0) + ControlledSystems(2) >= 8) {",
                        "        AddDialogInject('QuestTake','',CT(\"Script.Cat_Byhanka.59\"),100);",
                        "    }",
                        "    if((CallFlag == 6 || CallFlag == 7) && IdToPlanet(LastPlanetID) == GetShipPlanet(Player()) && ControlledSystems(0) + ControlledSystems(2) >= 8) {",
                        "        if(PlayerRun) AddDialogInject('QuestCompletedFake','',CT(\"Script.Cat_Byhanka.58\"),100);",
                        "        else AddDialogInject('QuestCompleted','',CT(\"Script.Cat_Byhanka.57\"),100);",
                        "        if(Name(GetShipPlanet(Player())) == CT('PlanetName.Solar.2')) {",
                        "            AddDialogInject('EarthInfo','',CT(\"Script.Cat_Byhanka.56\"),100);",
                        "        }",
                        "    }",
                        "}"
                    ],
                    "#": 36,
                    "Type": "Top",
                    "Parent": -1,
                    "Pos.x": 180,
                    "Pos.y": 660
                },
                {
                    "Name": "",
