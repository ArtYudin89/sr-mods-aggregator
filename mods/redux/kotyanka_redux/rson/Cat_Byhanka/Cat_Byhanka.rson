                    "_orig_danswer": "DAnswer('restart~'+CT(\"Script.Cat_Byhanka.88\"))"
                },
                {
                    "Name": "restart",
                    "Pos.x": 360,
                    "Pos.y": 590,
                    "Type": "TDialogAnswer",
