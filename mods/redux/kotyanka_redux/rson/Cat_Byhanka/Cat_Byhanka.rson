                },
                {
                    "Name": "planet",
                    "Pos.x": 120,
                    "Pos.y": 565,
                    "Type": "TDialogAnswer",
                    "Parent": -1,
                    "#": 66,
                    "Msg": "Знаете, что-то не хочется мне работать на дядю...\r\nВольная жизнь дороже любого \"спец-корпуса\"!",
                    "AMsg.Num": "1",
                    "_orig_danswer": "DAnswer('planet~'+CT(\"Script.Cat_Byhanka.24\"))"
                },
                {
                    "Name": "",
                    "Pos.x": 240,
                    "Pos.y": 565,
                    "Type": "TDialogAnswer",
                    "Parent": -1,
                    "#": 67,
                    "Msg": "Я согласен, где подписать?",
                    "AMsg.Num": "2",
                    "_orig_danswer": "DAnswer(CT(\"Script.Cat_Byhanka.26\"))"
                },
                {
                    "Name": "restart",
                    "Pos.x": 360,
                    "Pos.y": 565,
                    "Type": "TDialogAnswer",
                    "Parent": -1,
                    "#": 68,
                    "Msg": "Мне по два раза повторять не надо!",
                    "AMsg.Num": "3",
                    "_orig_danswer": "DAnswer('restart~'+CT(\"Script.Cat_Byhanka.27\"))"
                },
                {
                    "Name": "",
                    "Pos.x": 480,
                    "Pos.y": 565,
                    "Type": "TDialogAnswer",
                    "Parent": -1,
                    "#": 69,
                    "Msg": "Грузите быстрей, моё время не бесплатное!",
                    "AMsg.Num": "4",
                    "_orig_danswer": "DAnswer(CT(\"Script.Cat_Byhanka.28\"))"
                },
                {
                    "Name": "planet",
                    "Pos.x": 600,
                    "Pos.y": 565,
                    "Type": "TDialogAnswer",
                    "Parent": -1,
                    "#": 70,
                    "Msg": "Извините, сейчас не время для почты!",
                    "AMsg.Num": "5",
                    "_orig_danswer": "DAnswer('planet~'+CT(\"Script.Cat_Byhanka.29\"))"
                },
                {
                    "Name": "hangar",
