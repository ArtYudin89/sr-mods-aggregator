                    "Pos.x": -20,
                    "Pos.y": 400
                },
                {
                    "Name": "",
                    "Code.Type": "Turn",
                    "Code": [
                        "DChange(3);",
                        "exit;"
                    ],
                    "#": 93,
                    "Type": "Top",
                    "Parent": -1,
                    "Pos.x": 100,
                    "Pos.y": 400
                },
                {
                    "Name": "",
                    "Code.Type": "Turn",
                    "Code": [
                        "CallFlag = 2;",
                        "cost = 0;",
                        "hull_size = 0;",
                        "",
                        "for(j=0;j<10;j=j+1) {",
                        "    for(i=0;ShipItems(Player())>i;i=i+1) {",
                        "        if(ItemType(ShipItems(Player(),i)) != t_UselessItem) continue;",
                        "        //if(Name(ShipItems(Player(),i)) == CT('UselessItems.BuhaCargo.Name')) {",
                        "        //    hull_size = hull_size + 1; //Ну не пропадать же зазря переменной!",
                        "        //    cost = cost + ItemCost(ShipItems(Player(),i));",
                        "        //}",
                        "",
                        "        if(Name(ShipItems(Player(),i)) == CT('UselessItems.BuhaCargo.Name')) {",
                        "            hull_size = hull_size + 1; //Ну не пропадать же зазря переменной!",
                        "            FreeItem(GetItemFromShip(Player(),ShipItems(Player(),i)));",
                        "        }",
                        "    }",
                        "}",
                        "",
                        "cost = hull_size * (10000 + Completed * 1000);",
                        "if(MissionTime == 0 && hull_size > 0) cost = cost/2;",
                        "if(MissionTime != 0 && hull_size > CargoCount) {",
                        "  ShipMoney(Player(),ShipMoney(Player())+cost);",
                        "  Sound('Sound.QuestOk');",
                        "  DChange(15);",
                        "  exit;",
                        "}",
                        "if(MissionTime != 0 && hull_size == CargoCount) {",
                        "  ShipMoney(Player(),ShipMoney(Player())+cost);",
                        "  Sound('Sound.QuestOk');",
                        "  DChange(4);",
                        "  exit;",
                        "}",
                        "if(MissionTime != 0 && hull_size != CargoCount && hull_size > 0) {",
                        "  ShipMoney(Player(),ShipMoney(Player())+cost);",
                        "  Sound('Sound.QuestOk');",
                        "  DChange(5);",
                        "  exit;",
                        "}",
                        "if(MissionTime == 0 && hull_size == CargoCount) {",
                        "  ShipMoney(Player(),ShipMoney(Player())+cost);",
                        "  Sound('Sound.QuestCancel');",
                        "  DChange(6);",
                        "  exit;",
                        "}",
                        "if(MissionTime == 0 && hull_size != CargoCount && hull_size > 0) {",
                        "  ShipMoney(Player(),ShipMoney(Player())+cost);",
                        "  Sound('Sound.QuestCancel');",
                        "  DChange(7);",
                        "  exit;",
                        "}",
                        "if(hull_size == 0) {",
                        "  if(MissionTime != 0) CallFlag = 6;",
                        "  if(MissionTime == 0) CallFlag = 7;",
                        "  ",
                        "  tint = tint + 1;",
                        "  if(tint >= 5) {",
                        "    if(tint2 >= 10) {",
                        "      DChange(14);",
                        "      exit;",
                        "    }",
                        "    if(tint2 < 10) {",
                        "      if(tint2 == 0) tstr = CT(\"Script.Cat_Byhanka.70\");",
                        "      if(tint2 == 1) tstr = CT(\"Script.Cat_Byhanka.69\");",
                        "      if(tint2 == 2) tstr = CT(\"Script.Cat_Byhanka.68\");",
                        "      if(tint2 == 3) tstr = CT(\"Script.Cat_Byhanka.67\");",
                        "      if(tint2 == 4) tstr = CT(\"Script.Cat_Byhanka.66\");",
                        "      if(tint2 == 5) tstr = CT(\"Script.Cat_Byhanka.65\");",
                        "      if(tint2 == 6) tstr = CT(\"Script.Cat_Byhanka.64\");",
                        "      if(tint2 == 7) tstr = CT(\"Script.Cat_Byhanka.63\");",
                        "      if(tint2 == 8) tstr = CT(\"Script.Cat_Byhanka.62\");",
                        "      if(tint2 == 9) tstr = CT(\"Script.Cat_Byhanka.61\");",
                        "      DChange(13);",
                        "      exit;",
                        "    }",
                        "  }",
                        "  if(tint < 5) {",
                        "    DChange(9);",
                        "    exit;",
                        "  }",
                        "}"
                    ],
