                },
                {
                    "Name": "planet",
                    "Pos.x": 1560,
                    "Pos.y": 565,
                    "Type": "TDialogAnswer",
                    "Parent": -1,
                    "#": 78,
                    "Msg": "Ох, ё...",
                    "AMsg.Num": "13",
                    "_orig_danswer": "DAnswer('planet~'+CT(\"Script.Cat_Byhanka.42\"))"
                },
                {
                    "Name": "",
                    "Pos.x": 1680,
                    "Pos.y": 565,
                    "Type": "TDialogAnswer",
                    "Parent": -1,
                    "#": 79,
                    "Msg": "Но я... Я не смогу никак довезти посылки! Их.. Отобрали гиперкосмические пираты!",
                    "AMsg.Num": "14",
                    "_orig_danswer": "DAnswer(CT(\"Script.Cat_Byhanka.85\"))"
                },
                {
                    "Name": "restart",
                    "Pos.x": 0,
