                },
                {
                    "Name": "",
                    "Pos.x": 720,
                    "Pos.y": 590,
                    "Type": "TDialogAnswer",
                    "Parent": -1,
                    "#": 86,
                    "Msg": "*отправиться в кабинет согласно выданному вам плану*",
                    "AMsg.Num": "21",
                    "_orig_danswer": "DAnswer(CT(\"Script.Cat_Byhanka.93\"))"
                },
                {
                    "Name": "",
                    "Pos.x": 840,
                    "Pos.y": 590,
                    "Type": "TDialogAnswer",
                    "Parent": -1,
                    "#": 87,
                    "Msg": "Ответишь ты у меня, станционный смотритель, за моё заключение в планетарное узилище! Ух, подлец!",
                    "AMsg.Num": "22",
                    "_orig_danswer": "DAnswer(CT(\"Script.Cat_Byhanka.95\"))"
                },
                {
                    "Name": "restart",
                    "Pos.x": 960,
                    "Pos.y": 590,
                    "Type": "TDialogAnswer",
                    "Parent": -1,
                    "#": 88,
                    "Msg": "Ой...",
                    "AMsg.Num": "23",
                    "_orig_danswer": "DAnswer('restart~'+CT(\"Script.Cat_Byhanka.90\"))"
                },
                {
                    "Name": "",
                    "Pos.x": 1080,
                    "Pos.y": 590,
                    "Type": "TDialogAnswer",
                    "Parent": -1,
                    "#": 89,
                    "Msg": "Куда мне нужно отправиться дальше?",
