                {
                    "Name": "",
                    "Code.Type": "Turn",
                    "Code": [
                        "Ether(5,'Buhanka',CT(\"Script.Cat_Byhanka.82\"));",
                        "Sound('Sound.NewMsg');",
                        "CallFlag = 5;"
                    ],
                    "#": 120,
                    "Type": "Top",
                    "Parent": -1,
                    "Pos.x": 100,
                    "Pos.y": 565
                },
                {
                    "Name": "",
                    "Code.Type": "Turn",
                    "Code": [
                        "Ether(3,'Buhanka',Format(CT(\"Script.Cat_Byhanka.83\"),\"<0>\",ToComplete,\"<1>\",Completed,\"<2>\",ToComplete,\"<3>\",Time));",
                        "Sound('Sound.NewMsg');",
                        "CallFlag = 2;",
                        "",
                        "hull = CreateHull(6,hull_size,GalaxyTechLevel(),People,-1,0);",
                        "bonus_num = FindBonusByName(CT('Script.Cat_Byhanka.Name'));",
                        "if(bonus_num > -1) {",
                        "    SpecialToEquipment(bonus_num, hull);",
                        "}",
                        "else {",
                        "    SFT('Саня, мы Буханку не нашли. Пипец!');",
                        "}",
                        "",
                        "ItemSize(hull, hull_size);",
                        "ItemCost(hull, CT('Script.Cat_Byhanka.BuhankaCost'));",
                        "HullHP(hull, ItemSize(hull));",
                        "AddItemToStorage(GetShipPlanet(Player()), hull);",
                        "LinkItemToScript(hull,buhanka);",
                        "LastPlanetID = Id(GetShipPlanet(Player()));",
                        "EarthID = Id(GetShipPlanet(Player()));",
                        "",
                        "LastCompleted = PlayerQuestsCompleted(0);",
                        "DChange(2);",
                        "exit;"
                    ],
                    "#": 121,
                    "Type": "Top",
                    "Parent": -1,
                    "Pos.x": 220,
                    "Pos.y": 565
                },
                {
                    "Name": "",
                    "Code.Type": "Turn",
                    "Code": [
                        "CallFlag = 6;",
                        "CargoCount = Rnd(5,12);",
                        "",
                        "ArrayClear(tarr);",
                        "ArrayDelete(tarr,0);",
                        "",
                        "for(i=0;CargoCount>i;i=i+1) {",
                        "    tdwd = CreateQuestItem('BuhaCargo',PlanetRace(GetShipPlanet(Player())));",
                        "    AddItemToShip(Player(),tdwd);",
                        "",
                        "    ItemCost(tdwd,10000 + Completed * 1000 + Rnd(100,499));",
                        "}",
                        "for(i=0;GalaxyStars()>i;i=i+1) {",
                        "    if(StarOwner(GalaxyStar(i)) == 1) continue;",
                        "    if(round(sqrt(Dist2Star(ShipStar(Player()), GalaxyStar(i)))) < 15) continue;",
                        "    if(round(sqrt(Dist2Star(ShipStar(Player()), GalaxyStar(i)))) > 50) continue;",
                        "    if(StarToCon(GalaxyStar(i)) == StarToCon(PlanetToStar(PlanetPirateClan()))) continue;",
                        "    for(j=0;StarPlanets(GalaxyStar(i))>j;j=j+1) {",
                        "        if(PlanetOwner(StarPlanets(GalaxyStar(i),j)) > 4) continue;",
                        "        ArrayAdd(tarr,StarPlanets(GalaxyStar(i),j));",
                        "    }",
                        "}",
                        "",
                        "ArrayAdd(tarr,1,'Fix');",
                        "if(ArrayDim(tarr) > 1) {",
                        "    ArrayDelete(tarr,'Fix');",
                        "    ArrayRandomize(50,tarr);",
                        "",
                        "    LastPlanetID = Id(tarr[min(round(ArrayDim(tarr)/2),1)]);",
                        "    MissionTime = CT('Script.Cat_Byhanka.CargoTime');",
                        "",
                        "    Ether(3,'CargoQuestBuha',CT(\"Script.Cat_Byhanka.46\")+' '+Name(IdToPlanet(LastPlanetID))+CT(\"Script.Cat_Byhanka.37\")+' '+Name(PlanetToStar(IdToPlanet(LastPlanetID)))+Format(CT(\"Script.Cat_Byhanka.45\"),\"<0>\",MissionTime),IdToPlanet(LastPlanetID));",
                        "    Sound('Sound.NewMsg');",
                        "    ArrayAdd(tarr,1,'Fix');",
                        "}",
                        "if(ArrayDim(tarr) < 2) {",
                        "  DChange(21);",
                        "  exit;",
                        "}",
                        "if(ArrayDim(tarr) > 1) {",
                        "  DChange(8);",
                        "  exit;",
                        "}"
                    ],
                    "#": 122,
                    "Type": "Top",
                    "Parent": -1,
                    "Pos.x": 460,
                    "Pos.y": 565
                },
                {
                    "Name": "",
                    "Code.Type": "Turn",
                    "Code": [
                        "for(i=0;ShipItems(Player())>i;i=i+1) {",
                        "    if(ItemType(ShipItems(Player(),i)) != t_UselessItem) continue;",
                        "",
                        "    if(Name(ShipItems(Player(),i)) == CT('UselessItems.BuhaCargo.Name')) {",
                        "        FreeItem(GetItemFromShip(Player(),ShipItems(Player(),i)));",
                        "    }",
                        "}",
                        "Completed = Completed + 1;",
                        "Ether(4,'CargoQuestBuha',CT(\"Script.Cat_Byhanka.46\")+' '+Name(IdToPlanet(LastPlanetID))+CT(\"Script.Cat_Byhanka.37\")+' '+Name(PlanetToStar(IdToPlanet(LastPlanetID)))+Format(CT(\"Script.Cat_Byhanka.45\"),\"<0>\",MissionTime));",
                        "CargoCmpl = CargoCmpl + 1;",
                        "tint = 0;",
                        "tint2 = 0;"
                    ],
