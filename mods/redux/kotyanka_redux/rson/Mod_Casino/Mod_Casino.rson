                    "Code": [
                        "GRun();"
                    ],
                    "#": 17,
                    "Type": "Top",
                    "Parent": -1,
                    "Pos.x": 0,
                    "Pos.y": 660
                },
                {
                    "Name": "",
                    "Code.Type": "Init",
                    "Code": [
                        "win_chance2=RndObject(1,100,Player());",
                        "cup=RndObject(1,3,Player());"
                    ],
                    "#": 18,
                    "Type": "Top",
                    "Parent": -1,
                    "Pos.x": 60,
                    "Pos.y": 660
                },
                {
                    "Name": "",
                    "Code.Type": "Turn",
                    "Code": [
                        "if(findsubstr(GameDateTxtByTurn(CurTurn()),CT(\"Script.Mod_Casino.135\"))==0 || findsubstr(GameDateTxtByTurn(CurTurn()),CT(\"Script.Mod_Casino.134\"))==0) {",
                        "    count1=0;",
                        "    count2=0;",
                        "}",
                        "if(k!=1) {",
                        "    win_chance=RndObject(1,10000,Player());",
                        "    k=1;",
                        "}",
                        "if(findsubstr(GameDateTxtByTurn(CurTurn()),CT(\"Script.Mod_Casino.133\"))==0 || findsubstr(GameDateTxtByTurn(CurTurn()),CT(\"Script.Mod_Casino.132\"))==0) {",
                        "    count1=0;",
                        "    count2=0;",
                        "}",
                        "",
                        "//win_chance - шанс выигрыша в казике, он генерится раз в миллиард столетий",
                        "//win_chance2 - шанс выигрыша у напёрсточника;"
                    ],
                    "#": 19,
                    "Type": "Top",
                    "Parent": -1,
                    "Pos.x": 120,
                    "Pos.y": 660
                },
                {
                    "Name": "",
                    "Code.Type": "DialogBegin",
                    "Code": [
                        "if(GetShipRuins(Player())) {",
                        "    if(ShipType(GetShipRuins(Player()))=='BK') {",
                        "        AddDialogInject('Casino_BK',Format(CT(\"Script.Mod_Casino.137\"),\"<0>\",casino_BK),CT(\"Script.Mod_Casino.83\"),0);",
                        "    }",
                        "    if(ShipType(GetShipRuins(Player()))=='PB' || ShipType(GetShipRuins(Player()))=='CB') {",
                        "        AddDialogInject('Casino_Pirate',Format(CT(\"Script.Mod_Casino.136\"),\"<0>\",casino_Pirate),CT(\"Script.Mod_Casino.83\"),0);",
                        "    }",
                        "}"
                    ],
                    "#": 20,
                    "Type": "Top",
                    "Parent": -1,
                    "Pos.x": 180,
                    "Pos.y": 660
                },
                {
                    "Name": "",
                    "Code.Type": "Turn",
                    "Code": [
                        "cur_count1=1-count1;",
                        "if(ShipMoney(Player())>=5000 && cur_count1==1) {",
                        "  DChange(1);",
                        "  exit;",
                        "}",
                        "if(ShipMoney(Player())>=5000 && cur_count1==0) {",
                        "  DChange(9);",
                        "  exit;",
                        "}",
                        "if(ShipMoney(Player())<5000 && cur_count1==1) {",
                        "  DChange(0);",
                        "  exit;",
                        "}",
                        "if(ShipMoney(Player())<5000 && cur_count1==0) {",
                        "  DChange(8);",
                        "  exit;",
                        "}"
                    ],
                    "#": 80,
                    "Type": "Top",
