                    "Msg": "У тебя недостаточно денег даже для <clr>минимальной ставки<clrEnd>. Приходи, когда разбогатеешь.",
                    "DMsg.Num": "26",
                    "_orig_dtext": "DText(CT(\"Script.Mod_Casino.126\"))"
                }
