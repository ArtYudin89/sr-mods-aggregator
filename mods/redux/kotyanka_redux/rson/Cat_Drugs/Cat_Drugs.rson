                        "    if(EquipmentImageName(item) == 'Usl_Drug06') InjectAnswer('Sell',CT(\"Script.Cat_Drugs.7\")+' '+Name(item)+' ('+(ItemCost(item)*125/100)+' cr.)',item);",
                        "    if(EquipmentImageName(item) == 'Usl_Drug07') InjectAnswer('Sell',CT(\"Script.Cat_Drugs.7\")+' '+Name(item)+' ('+(ItemCost(item)*125/100)+' cr.)',item);",
