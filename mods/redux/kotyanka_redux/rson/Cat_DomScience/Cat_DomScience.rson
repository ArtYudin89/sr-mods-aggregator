            "Operations": [
                {
                    "Name": "",
                    "Code.Type": "Global",
                    "Code": [
                        "GRun();"
                    ],
                    "#": 18,
                    "Type": "Top",
                    "Parent": -1,
                    "Pos.x": 0,
                    "Pos.y": 635
                },
                {
                    "Name": "",
                    "Code.Type": "Init",
                    "Code": [
                        "//Раздаём уникальные блоки памяти доминаторским боссам",
                        "item = CreateQuestItem('Remains_CatMem');",
                        "UselessItemData(item,1,777);",
                        "ItemOwner(item,Kling);",
                        "ItemSubrace(item,0);",
                        "ShipAddDropItem(Blazer(),item);",
                        "item = CreateQuestItem('Remains_CatMem');",
                        "UselessItemData(item,1,888);",
                        "ItemOwner(item,Kling);",
                        "ItemSubrace(item,1);",
                        "ShipAddDropItem(Keller(),item);",
                        "item = CreateQuestItem('Remains_CatMem');",
                        "UselessItemData(item,1,999);",
                        "ItemOwner(item,Kling);",
                        "ItemSubrace(item,2);",
                        "ShipAddDropItem(Terron(),item);",
                        "",
                        "function AddDropUselessToShips() {",
                        "    unknown ships_arr;",
                        "    int arr_count = BuildListOfNewShips(ships_arr, lastShipId, 1+32, 32, 1, '',  '');",
                        "    //Если найден хотя бы один корабль, выдаем юзлессы",
                        "    if(arr_count)",
                        "    {",
                        "        for(int i = 0; i < arr_count; i = i + 1)",
                        "        {",
                        "            //Выбираем корабль",
                        "            dword ship = ships_arr[i];",
                        "            if(IsPlayer(ship)) continue;",
                        "            if(ShipOwner(ship) != Kling) exit;",
                        "",
                        "            //Устанавливаем шанс на выдачу какого-либо иного юзлесса",
                        "            int chance_items = 0;",
                        "",
                        "            if(ShipSubType(ship) == 1) {",
                        "                chance_items = 3;",
                        "            }",
                        "            if(ShipSubType(ship) == 2) {",
                        "                chance_items = 5;",
                        "            }",
                        "            if(ShipSubType(ship) == 3) {",
                        "                chance_items = 10;",
                        "            }",
                        "            if(ShipSubType(ship) == 4) {",
                        "                chance_items = 15;",
                        "            }",
                        "            if(ShipSubType(ship) == 5) {",
                        "                chance_items = 25;",
                        "            }",
                        "            if(ShipSubType(ship) == 6) {",
                        "                chance_items = 40;",
                        "            }",
                        "            if(ShipSubType(ship) == 7) {",
                        "                chance_items = 1;",
                        "            }",
                        "",
                        "            //Случайно определяем шанс выдачи",
                        "            if(RndObject(1, 100, ship) <= chance_items) {",
                        "                item = CreateQuestItem('Remains_CatMem');",
                        "                ItemSubrace(item,ShipSubrace(ship,-1));",
                        "                UselessItemData(item,1,Rnd(1,CT('Script.Cat_DomScience.AcrynsArchive.Count')));",
                        "                ItemOwner(item,Kling);",
                        "                ItemCost(item,GalaxyMoney(4,4));",
                        "                ShipAddDropItem(ship, item);",
                        "            }",
                        "        }",
                        "    }",
                        "}",
                        "",
                        "//Добавляет диалог сдачи модулей",
                        "function FindModule() {",
                        "    int crist_found = 0;",
                        "    int cnt111 = ShipItems(Player());",
                        "    for(i = 1; i < cnt111; i = i + 1)",
                        "    {",
                        "        item = ShipItems(Player(), i);",
                        "        if(ItemType(item) != t_UselessItem) continue;",
                        "        if(~findsubstr(EquipmentImageName(item),'CatMem')) crist_found = crist_found + 1;",
                        "    }",
                        "",
                        "    result = crist_found;",
                        "}",
                        "",
                        "//Добавляет новый модуль в массив на исследование",
                        "function AddToArray(int type, dayss, subrace) {",
                        "    ArrayAdd(Acryn,type);",
                        "    ArrayAdd(Days,dayss);",
                        "    ArrayAdd(Race,subrace);",
                        "    ArrayAdd(RuinType,ShipType(GetShipRuins(Player())));",
                        "}",
                        "",
                        "//Добавляет диалог получения результата исследования",
                        "function FindResearched() {",
                        "    int cnt2;",
                        "    result = 0;",
                        "    if(ArrayDim(Days) > 1) {",
                        "        for(i=1;(ArrayDim(Days)-1)>i;i=i+1) {",
                        "",
                        "            if(Days[i] == -1) {",
                        "                if(RuinType[i] == ShipType(GetShipRuins(Player()))) {",
                        "                    result = 1;",
                        "                }",
                        "            }",
                        "        }",
                        "    }",
                        "}",
                        "",
                        "//Сохраняет значения оборудования Келлера и Террона, т.к. не одними же акринами едиными!",
                        "if(Keller()) kellerDroid = GetEquipmentStats(ShipEqInSlot(Keller(),t_RepairRobot),0);",
                        "if(Terron()) terronDef = GetEquipmentStats(ShipEqInSlot(Keller(),t_DefGenerator),0);",
                        "",
                        "//Немного \"инитнем\" массив",
                        "ArrayClear(Modules);",
                        "ArrayDelete(Modules,0);",
                        "",
                        "ArrayAdd(Modules,'Basa');"
                    ],
                    "#": 19,
                    "Type": "Top",
                    "Parent": -1,
                    "Pos.x": 60,
                    "Pos.y": 635
                },
                {
                    "Name": "",
                    "Code.Type": "Turn",
                    "Code": [
                        "if(CurrentMods('ShusRangers\\\\ShuDomiks')) {",
                        "    if(GalaxyShipId() > lastShipId) {",
                        "        AddDropUselessToShips();",
                        "        //Обновляем Id последнего рождённого корабля",
                        "        lastShipId = GalaxyShipId();",
                        "    }",
                        "}",
                        "",
                        "if(ArrayDim(Days) > 1) {",
                        "    for(i=1;(ArrayDim(Days)-1)>i;i=i+1) {",
                        "        if(Days[i] > 0) Days[i] = Days[i] - 1;",
                        "        else if(!Days[i]) {",
                        "            Days[i] = -1;",
                        "            Sound('Sound.NewMsg');",
                        "            NewsAdd(CT(\"Script.Cat_DomScience.0\"));",
                        "        }",
                        "    }",
                        "}"
                    ],
                    "#": 20,
                    "Type": "Top",
                    "Parent": -1,
                    "Pos.x": 120,
                    "Pos.y": 635
                },
                {
                    "Name": "",
                    "Code.Type": "DialogBegin",
                    "Code": [
                        "if(GetShipRuins(Player())) {",
                        "    if(!DomiksDefeated()) {",
                        "        if(FindModule()) {",
                        "            if(!CurrentMods('Evolution\\\\EvoSB')) {",
                        "                if(ShipType(GetShipRuins(Player())) == 'SB') {",
                        "                    AddDialogInject('UnlockSB','',CT(\"Script.Cat_DomScience.2\"),15);",
                        "                }",
                        "            }",
                        "            if(ShipType(GetShipRuins(Player())) == 'DD') {",
                        "                AddDialogInject('UnlockDD','',CT(\"Script.Cat_DomScience.2\"),15);",
                        "            }",
                        "        }",
                        "    }",
                        "    if(FindResearched()) {",
                        "        AddDialogInject('CreateSB','',CT(\"Script.Cat_DomScience.1\"),16);",
                        "    }",
                        "}"
