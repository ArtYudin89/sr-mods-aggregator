                },
                {
                    "Name": "",
                    "Code.Type": "Turn",
                    "Code": [
                        "if(ShipType(GetShipRuins(Player())) == 'SB') {",
                        "  DChange(0);",
                        "  exit;",
                        "}",
                        "if(ShipType(GetShipRuins(Player())) == 'DD') {",
                        "  DChange(1);",
                        "  exit;",
                        "}"
                    ],
                    "#": 103,
                    "Type": "Top",
                    "Parent": -1,
                    "Pos.x": 580,
                    "Pos.y": 540
                },
                {
                    "Name": "",
                    "Code.Type": "Turn",
                    "Code": [
                        "if(!RndObject(0,9,Player())) {",
                        "  GiveReward(Player(),ShipOwner(GetShipRuins(Player())),1);",
                        "  Sound('Sound.QuestOk');",
                        "  DChange(6);",
                        "  exit;",
                        "}"
                    ],
                    "#": 104,
                    "Type": "Top",
                    "Parent": -1,
                    "Pos.x": 700,
                    "Pos.y": 540
                },
                {
                    "Name": "",
                    "Code.Type": "Turn",
                    "Code": [
                        "if(Acryn[GAnswerData] < 1) Acryn[GAnswerData] = Rnd(1,CT('Script.Cat_DomScience.AcrynsArchive.Count'));",
                        "",
                        "item = CreateEquipmentWithSpecial(FindBonusByNameInCfg(CT('Script.Cat_DomScience.AcrynsArchive.'+Acryn[GAnswerData])),Rnd(20,25),GalaxyTechLevel(),Kling);",
                        "ItemSubrace(item,Race[GAnswerData]);",
                        "AddItemToShip(Player(),item);",
                        "ArrayDelete(Race,GAnswerData);",
                        "ArrayDelete(Days,GAnswerData);",
                        "ArrayDelete(Acryn,GAnswerData);",
                        "ArrayDelete(RuinType,GAnswerData);",
                        "ShipMoney(Player(),ShipMoney(Player())-(GalaxyMoney(4,4)*3));",
                        "Sound('Sound.Buy');",
                        "DChange(13);",
                        "exit;"
                    ],
                    "#": 105,
                    "Type": "Top",
                    "Parent": -1,
                    "Pos.x": 1060,
                    "Pos.y": 540
                },
                {
                    "Name": "",
                    "Code.Type": "Turn",
                    "Code": [
                        "item = CreateEquipment(Rnd(t_FuelTanks,t_DefGenerator),Rnd(20,25),GalaxyTechLevel(),Kling);",
                        "ItemSubrace(item,Race[GAnswerData]);",
                        "AddItemToShip(Player(),item);",
                        "ArrayDelete(Race,GAnswerData);",
                        "ArrayDelete(Days,GAnswerData);",
                        "ArrayDelete(Acryn,GAnswerData);",
                        "ArrayDelete(RuinType,GAnswerData);",
                        "ShipMoney(Player(),ShipMoney(Player())-GalaxyMoney(4,4));",
                        "Sound('Sound.Buy');",
                        "DChange(12);",
                        "exit;"
                    ],
                    "#": 106,
                    "Type": "Top",
                    "Parent": -1,
                    "Pos.x": 1300,
                    "Pos.y": 540
                },
                {
                    "Name": "",
                    "Code.Type": "Turn",
                    "Code": [
                        "int cnt = 0;",
                        "while(1) {",
                        "    item = ShipEqInSlot(Player(),Rnd(t_FuelTanks,t_DefGenerator));",
                        "    if(ItemLevel(item) < 7) {",
                        "        ItemLevel(item,ItemLevel(item)+2);",
                        "        break;",
                        "    }",
                        "    if(cnt > 100) {",
                        "        if(ItemLevel(item) < 8) {",
                        "            ItemLevel(item,min(ItemLevel(item)+2,8));",
                        "            break;",
                        "        }",
                        "        else if(!ItemImprovement(item)) {",
                        "            ItemImprovement(item,3);",
                        "            cnt = cnt + 50;",
                        "        }",
                        "    }",
                        "",
                        "    if(cnt > 250) break;",
                        "",
                        "    cnt = cnt + 1;",
                        "}",
                        "ShipMoney(Player(),ShipMoney(Player())-(GalaxyMoney(4,4)*3/4));",
                        "Sound('Sound.Repair');",
                        "ArrayDelete(Race,GAnswerData);",
                        "ArrayDelete(Days,GAnswerData);",
                        "ArrayDelete(Acryn,GAnswerData);",
                        "ArrayDelete(RuinType,GAnswerData);",
                        "DChange(14);",
                        "exit;"
                    ],
