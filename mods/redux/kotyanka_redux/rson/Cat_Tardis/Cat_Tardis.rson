                        "GRun();"
                    ],
                    "#": 30,
                    "Type": "Top",
                    "Parent": -1,
                    "Pos.x": 0,
                    "Pos.y": 635
                },
                {
                    "Name": "",
                    "Code.Type": "Init",
                    "Code": [
                        "state = 1;",
                        "planets_needed = CT('Script.Cat_Tardis.Settings.PlanetsCount');",
                        "quest_created = 0;",
                        "chance = 0;",
                        "",
                        "function g_LinkTardis(hull) {",
                        "    LinkItemToScript(hull,tardis);",
                        "    ItemOnActCode(hull,GenerateCodeStringFromBlock('ActCodeBlocksList.CatTardisActCode'));",
                        "}",
                        "",
                        "function g_GenerateGift() {",
                        "    dword item;",
                        "    int rand;",
                        "    int coun;",
                        "",
                        "    //Найдёт ли игрок что-нибудь на складе?",
                        "    rand = RndObject(1,1000,ShipEqInSlot(Player(),t_Hull));",
                        "    if(rand < 3 + GalaxyDiffLevels(7)/50) {",
                        "        //Определяем тип \"награды\"",
                        "        rand = RndObject(1,3,ShipEqInSlot(Player(),t_Hull));",
                        "        if(rand == 1) {",
                        "            //Выдают оборудку",
                        "            item = CreateEquipment(RndObject(t_FuelTanks,t_Weapon18,ShipEqInSlot(Player(),t_Hull)),RndObject(15,30,ShipEqInSlot(Player(),t_Hull)),RndObject(1,8,ShipEqInSlot(Player(),t_Hull)),RndObject(Maloc,PirateClan,ShipEqInSlot(Player(),t_Hull)));",
                        "            ItemSubrace(item,RndObject(0,2,ShipEqInSlot(Player(),t_Hull)));",
                        "            AddItemToShip(Player(),item);",
                        "        }",
                        "        else {",
                        "            //Выдают сыпучие",
                        "            rand = RndObject(1,4,ShipEqInSlot(Player(),t_Hull));",
                        "            if(rand == 1) {",
                        "                AddItemToShip(Player(),CreateNodes(RndObject(5,200,ShipEqInSlot(Player(),t_Hull)),RndObject(0,2,ShipEqInSlot(Player(),t_Hull))));",
                        "            }",
                        "            else {",
                        "                rand = RndObject(t_Food,t_Narcotics,ShipEqInSlot(Player(),t_Hull));",
                        "                if(rand == t_Food) AddItemToShip(Player(),CreateGoods(rand,RndObject(150,400,ShipEqInSlot(Player(),t_Hull))));",
                        "                if(rand == t_Medicine) AddItemToShip(Player(),CreateGoods(rand,RndObject(30,100,ShipEqInSlot(Player(),t_Hull))));",
                        "                if(rand == t_Technics) AddItemToShip(Player(),CreateGoods(rand,RndObject(90,200,ShipEqInSlot(Player(),t_Hull))));",
                        "                if(rand == t_Luxury) AddItemToShip(Player(),CreateGoods(rand,RndObject(20,75,ShipEqInSlot(Player(),t_Hull))));",
                        "                if(rand == t_Minerals) AddItemToShip(Player(),CreateGoods(rand,RndObject(400,1000,ShipEqInSlot(Player(),t_Hull))));",
                        "                if(rand == t_Alcohol) AddItemToShip(Player(),CreateGoods(rand,RndObject(120,250,ShipEqInSlot(Player(),t_Hull))));",
                        "                if(rand == t_Arms) AddItemToShip(Player(),CreateGoods(rand,RndObject(15,50,ShipEqInSlot(Player(),t_Hull))));",
                        "                if(rand == t_Narcotics) AddItemToShip(Player(),CreateGoods(rand,RndObject(5,20,ShipEqInSlot(Player(),t_Hull))));",
                        "            }",
                        "        }",
                        "        ",
                        "        Sound('Sound.NewMsg');",
                        "        NewsAdd(CT(\"Script.Cat_Tardis.216\"));",
                        "    }",
                        "}"
                    ],
                    "#": 31,
                    "Type": "Top",
                    "Parent": -1,
                    "Pos.x": 60,
                    "Pos.y": 635
                },
                {
                    "Name": "",
                    "Code.Type": "Turn",
                    "Code": [
                        "if(state==3) {",
                        "    if(!quest_created) {",
                        "        if(ItemExist(clock)){",
                        "            if(ItemIn(clock, Player())){",
                        "                ether_iden = 'tardis_activate_quest';",
                        "                Ether(3,'tardis_activate_quest',CT(\"Script.Cat_Tardis.217\"));",
                        "                quest_created = 1;",
                        "",
                        "            }",
                        "        }",
                        "    }",
                        "}",
                        "//Проверяем игрок на планете или нет",
                        "if(GetShipPlanet(Player())) {",
                        "    //Проверяем не заспавнены ли часы уже",
                        "    if(!clock_create) {",
                        "        //Проверяем незаселёнка ли это",
                        "        /*if(PlanetOwner(GetShipPlanet(Player()))==6){",
                        "            //Проверяем есть ли уже планета в списке посещенных",
                        "            if(ArrayFind(planets_visited,Id(GetShipPlanet(Player())))<0){",
                        "                //Добавляем планету в список посещённых",
                        "                ArrayAdd(planets_visited,Id(GetShipPlanet(Player())));*/",
                        "                //Проверяем количество планет",
                        "                if(ArrayDim(GPlanetsVisited)>1/*planets_needed*/) {",
                        "                    //Проверяем ГТУ",
                        "                    if(state < 2) {",
                        "                        if(GalaxyTechLevel()>=5) {",
                        "                            state = 2;",
                        "                            chance = 50;",
                        "                        }",
                        "                    }",
                        "                    else",
                        "                    {",
                        "                        if(chance <=100) {",
                        "                            chance = chance + 5;",
                        "                        }",
                        "",
                        "                    }",
                        "                    if(Rnd(1,100)<=chance) {",
                        "                        item = CreateQuestItem('Clock');",
                        "                        ItemSize(item,1);",
                        "                        LinkItemToScript(item,clock);",
                        "                        star = StarNearbyStars(PlanetToStar(GetShipHomePlanet(Player())), Rnd(10, 30));",
                        "                        while(StarToCon(star) == StarToCon(PlanetToStar(PlanetPirateClan()))) star = StarNearbyStars(PlanetToStar(GetShipHomePlanet(Player())), Rnd(10, 30));",
                        "                        for(i = 0; i < StarPlanets(star); i = i + 1)",
                        "                        {",
                        "                            spawn_planet = StarPlanets(star, i);",
                        "                            if(PlanetOwner(spawn_planet) != 6) continue;",
                        "                            ArrayAdd(array_spawn_planets, spawn_planet);",
                        "                            planetgen = planetgen+ 1;",
                        "                        }",
                        "                        if(planetgen) {",
                        "                            spawn_planet = array_spawn_planets[Rnd(1, planetgen)];",
                        "                            AddItemToPlanet(spawn_planet, item);",
                        "",
                        "                            state = 3;",
                        "                            clock_create = 1;",
                        "",
                        "                        }",
                        "",
                        "                    }",
                        "                }",
                        "//            }",
                        "//        }",
                        "    }",
                        "}"
                    ],
                    "#": 32,
                    "Type": "Top",
                    "Parent": -1,
                    "Pos.x": 120,
                    "Pos.y": 635
                },
                {
                    "Name": "",
                    "Code.Type": "DialogBegin",
                    "Code": [
                        "if(PlayerBridge() == 3) {",
                        "    if(~ShipFindCustomShipInfoByType(Player(),'Tardis')) {",
                        "        if(ShipCustomShipInfoData(Player(),'Tardis',1)) {",
                        "            AddDialogInject('TardisControl','', CT(\"Script.Cat_Tardis.219\"), 1);",
                        "        }",
                        "    }",
                        "}",
                        "if(GetShipRuins(Player())) {",
                        "    if(ShipType(GetShipRuins(Player())) == 'SB') {",
                        "        if(ItemExist(clock)) {",
                        "            if(ItemIn(clock, Player())) {",
                        "                AddDialogInject('ActivateClockTardis', '', CT(\"Script.Cat_Tardis.218\"), 1);",
                        "            }",
                        "        }",
                        "    }",
                        "}"
                    ],
                    "#": 33,
                    "Type": "Top",
                    "Parent": -1,
                    "Pos.x": 180,
                    "Pos.y": 635
                },
                {
                    "Name": "",
                    "Code.Type": "Turn",
                    "Code": [
                        "if(ShipPilotRace(Player())==People) {",
                        "  DChange(0);",
                        "  exit;",
                        "}",
                        "if(ShipPilotRace(Player())!=People) {",
                        "  DChange(2);",
                        "  exit;",
                        "}"
                    ],
                    "#": 68,
                    "Type": "Top",
                    "Parent": -1,
                    "Pos.x": -20,
                    "Pos.y": 400
                },
                {
                    "Name": "",
                    "Code.Type": "Turn",
                    "Code": [
                        "temp = ShipCustomShipInfoData(Player(),'TardisEnergy',1);",
                        "if(energymod==1){",
                        "    tempstr= CT(\"Script.Cat_Tardis.213\");",
                        "    tempup= ShipSkill(Player(),2)*10/2;",
                        "}",
                        "else if(energymod==2) {",
                        "    tempstr= CT(\"Script.Cat_Tardis.212\");",
                        "    tempup= ShipSkill(Player(),2)*10;",
                        "}",
                        "else {",
                        "    tempstr= CT(\"Script.Cat_Tardis.211\");",
                        "    tempup= ShipSkill(Player(),2)*10*2;",
                        "}",
                        "if(defstat==0){",
                        "    tempstra = CT(\"Script.Cat_Tardis.210\");",
                        "}",
                        "else {",
                        "    tempstra = CT(\"Script.Cat_Tardis.209\");",
                        "}",
                        "DChange(3);",
                        "exit;"
                    ],
                    "#": 69,
                    "Type": "Top",
                    "Parent": -1,
                    "Pos.x": 250,
                    "Pos.y": 400
                },
                {
                    "Name": "",
                    "Code.Type": "Turn",
                    "Code": [
                        "DAdd(0);"
                    ],
