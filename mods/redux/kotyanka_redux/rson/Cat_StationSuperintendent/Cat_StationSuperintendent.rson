                },
                {
                    "Name": "",
                    "Code.Type": "Turn",
                    "Code": [
                        "if(i != 13) {",
                        "    tdwd = BuildRuins(temp_star,i);",
                        "}",
                        "else {",
                        "    tdwd = RunFunctionFromScript('Mod_ExpPilotBridge','BuyTC',temp_star);",
                        "}",
                        "tstr = 'Cat_StationSuperintendent_StarForse';",
                        "cost = j;",
                        "if(tstr != '') ItemExtraSpecialsAddByType(ShipEqInSlot(tdwd,t_Hull),FindBonusByNameInCfg(tstr));",
                        "Sound('Sound.Buy');",
                        "ShipMoney(Player(),ShipMoney(Player())-cost);",
                        "NoLanding(tdwd,1);",
                        "ArrayAdd(BuildingList,Id(tdwd));",
                        "ShipAddCustomShipInfo(tdwd,'Cat_SAS_Build','NoShow');",
                        "ShipCustomShipInfoData(tdwd,'Cat_SAS_Build',1,Rnd(20,40));",
                        "",
                        "if(ShipType(tdwd) != 'TC'){",
                        "    tstr = Format(CT('GalaxyNews.CreateNewObject.'+ShipType(tdwd)+Rnd(1,2)),'<Star'+'>',Name(ShipStar(tdwd)),'<Name'+'>',Name(tdwd),'<Sector'+'>',Name(StarToCon(ShipStar(tdwd))));",
                        "    AddPlanetNews(tstr,41);",
                        "    NewsAdd(tstr);",
                        "    Sound('Sound.NewMsg');",
                        "}",
                        "",
                        "l=Rnd(3,5);",
                        "for(i=0;i<l;i=i+1) {",
                        "    SpawnBuilder(tdwd);",
                        "}",
                        "",
                        "ChangeGlobalRelationsPlanets(Player(),0,2,15,159);",
                        "",
                        "//Собираем строчки для окошка",
                        "tstr = Name(temp_star);",
                        "",
                        "j=0;",
                        "for(k=0;StarRuins(temp_star)>k;k=k+1) {",
                        "    if(ShipType(StarRuins(temp_star,k)) == 'WB') j=j+1;",
                        "}",
                        "",
                        "if(StarRuins(temp_star) - j >= 3) tstr2 = CT(\"Script.Cat_StationSuperintendent.25\");",
                        "else if(StarOwner(temp_star) != 0 && StarOwner(temp_star) != 2) tstr2 = CT(\"Script.Cat_StationSuperintendent.24\");",
                        "else if(StarOwner(temp_star) == 2 && !CoalitionDefeated()) tstr2 = CT(\"Script.Cat_StationSuperintendent.23\");",
                        "else tstr2 = '';",
                        "",
                        "cost = GalaxyMoney(4,4) * 2;",
                        "DChange(4);",
                        "exit;"
                    ],
