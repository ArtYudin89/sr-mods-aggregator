            "Items": [],
            "Operations": [
                {
                    "Name": "",
                    "Code.Type": "Global",
                    "Code": [
                        "GRun();"
                    ],
                    "#": 19,
                    "Type": "Top",
                    "Parent": -1,
                    "Pos.x": 0,
                    "Pos.y": 585
                },
                {
                    "Name": "",
                    "Code.Type": "Init",
                    "Code": [
                        "function SpawnBuilder(dword ruin) {",
                        "    dword tdwd2 = BuyTranclucator(NearCivilPlanet(ruin));",
                        "    ShipOwner(tdwd2,ShipOwner(Player()));",
                        "    ShipPilotRace(tdwd2,ShipPilotRace(Player()));",
                        "    ShipJoin(BuildersGroup,tdwd2,'',Id(ruin));",
                        "    SetName(tdwd2,CT(\"Script.Cat_StationSuperintendent.2\")+' '+CT(\"Script.Cat_StationSuperintendent.1\")+'-'+Rnd(200,600)+CT(\"Script.Cat_StationSuperintendent.0\"));",
                        "    ShipAddCustomShipInfo(tdwd2,'Builder','NoShow');",
                        "    NoTalkToShip(tdwd2,1);",
                        "",
                        "    dword tdwd3 = BuyWarrior(NearCivilPlanet(ruin));",
                        "    OrderNone(tdwd3);",
                        "    OrderLock(tdwd3,1);",
                        "    TranclucatorData(tdwd2,'Proprietor',tdwd3);",
                        "}",
                        "",
                        "function g_SpawnBuilder(dword ruin) {",
                        "    dword tdwd2 = BuyTranclucator(NearCivilPlanet(ruin));",
                        "    ShipOwner(tdwd2,ShipOwner(Player()));",
                        "    ShipPilotRace(tdwd2,ShipPilotRace(Player()));",
                        "    ShipJoin(BuildersGroup,tdwd2,'',Id(ruin));",
                        "    SetName(tdwd2,CT(\"Script.Cat_StationSuperintendent.2\")+' '+CT(\"Script.Cat_StationSuperintendent.1\")+'-'+Rnd(200,600)+CT(\"Script.Cat_StationSuperintendent.0\"));",
                        "    ShipAddCustomShipInfo(tdwd2,'Builder','NoShow');",
                        "    NoTalkToShip(tdwd2,1);",
                        "",
                        "    dword tdwd3 = BuyWarrior(NearCivilPlanet(ruin));",
                        "    OrderNone(tdwd3);",
                        "    OrderLock(tdwd3,1);",
                        "    TranclucatorData(tdwd2,'Proprietor',tdwd3);",
                        "}",
                        "",
                        "function DeleteTranc(dword tranc) {",
                        "    //OrderLock(tranc,0);",
                        "    //ShipOut(tranc);",
                        "    ChangeState('DestroyIt',tranc);",
                        "",
                        "    //Не забываем про этого обормота",
                        "    dword ship = TranclucatorData(tranc,'Proprietor');",
                        "    if(ship > 0) ShipDestroy(ship);",
                        "}"
                    ],
                    "#": 20,
                    "Type": "Top",
                    "Parent": -1,
                    "Pos.x": 60,
                    "Pos.y": 585
                },
                {
                    "Name": "",
                    "Code.Type": "Turn",
                    "Code": [
                        "if(ArrayDim(BuildingList) > 1) {",
                        "    for(i=1;i<(ArrayDim(BuildingList)-1);i=i+1) {",
                        "        if(BuildingList[i] == 0) {",
                        "            continue;",
                        "        }",
                        "        else {",
                        "            tdwd2 = IdToShip(BuildingList[i]);",
                        "            if(tdwd2 < 1) {",
                        "                ArrayDelete(BuildingList,i);",
                        "            }",
                        "            else if(ShipFindCustomShipInfoByType(tdwd2,'Cat_SAS_Build') == -1) {",
                        "                ArrayDelete(BuildingList,i);",
                        "            }",
                        "            else if(ShipCustomShipInfoData(tdwd2,'Cat_SAS_Build',2) <= 1) {",
                        "                ShipDeleteCustomShipInfo(tdwd2,'Cat_SAS_Build');",
                        "                ArrayDelete(BuildingList,i);",
                        "            }",
                        "        }",
                        "    }",
                        "}"
                    ],
                    "#": 21,
                    "Type": "Top",
                    "Parent": -1,
                    "Pos.x": 120,
                    "Pos.y": 585
                },
                {
                    "Name": "",
                    "Code.Type": "DialogBegin",
                    "Code": [
                        "if(PlayerBridge() == 13) {",
                        "    AddDialogInject('BuildRuina','',CT(\"Script.Cat_StationSuperintendent.3\"),20);",
                        "}"
                    ],
                    "#": 22,
                    "Type": "Top",
                    "Parent": -1,
                    "Pos.x": 180,
                    "Pos.y": 585
                },
                {
                    "Name": "",
                    "Code.Type": "Turn",
                    "Code": [
                        "if(~IdToShip(ShipData())) {",
                        "    if(ShipFindCustomShipInfoByType(IdToShip(ShipData()),'Cat_SAS_Build') == -1) {",
                        "        DeleteTranc(CurShip);",
                        "    }",
                        "    else {",
                        "        GoodsAdd(CurShip,t_Technics,Rnd(20,50));",
                        "        ShipImproveItems(CurShip,0);",
                        "        ArrangeItems(CurShip);",
                        "        OrderLock(CurShip, 0);",
                        "        OrderTakeOff(CurShip);",
                        "    }",
                        "}",
                        "else {",
                        "    DeleteTranc(CurShip);",
                        "}",
                        "ChangeState(3);",
                        "exit;",
                        "if(0) {",
                        "  ChangeState(4);",
                        "  exit;",
                        "}"
                    ],
                    "#": 47,
                    "Type": "Top",
                    "Parent": -1,
                    "Pos.x": 80
                },
                {
                    "Name": "",
                    "Code.Type": "Turn",
                    "Code": [
                        "if(ShipInNormalSpace(CurShip)) {",
                        "    OrderLock(CurShip, 1);",
                        "    OrderLanding(CurShip, NearCivilPlanet(CurShip));",
                        "}",
                        "if(GetShipPlanet(CurShip)) {",
                        "  ChangeState(1);",
                        "  exit;",
                        "}"
                    ],
                    "#": 48,
                    "Type": "Top",
                    "Parent": -1,
                    "Pos.x": 160
                },
                {
                    "Name": "",
                    "Code.Type": "Turn",
                    "Code": [
                        "if(ShipInNormalSpace(CurShip)) {",
                        "    if(~IdToShip(ShipData())) {",
                        "        if(!OrderLock(CurShip)) OrderLanding(CurShip, IdToShip(ShipData()));",
                        "        OrderLock(CurShip,1);",
                        "        if(ShipFindCustomShipInfoByType(IdToShip(ShipData()),'Cat_SAS_Build') == -1) {",
                        "            OrderLock(CurShip,0);",
                        "            ShipOut(CurShip);",
                        "        }",
                        "    }",
                        "    else {",
                        "        DeleteTranc(CurShip);",
                        "    }",
                        "}",
                        "else if(GetShipPlanet(CurShip)) {",
                        "    OrderLock(CurShip, 0);",
                        "    OrderTakeOff(CurShip);",
                        "}",
                        "if(GetShipRuins(CurShip)) {",
                        "  if(NoLanding(GetShipRuins(CurShip))) {",
                        "      if(~IdToShip(ShipData())) {",
                        "          if(~ShipFindCustomShipInfoByType(IdToShip(ShipData()),'Cat_SAS_Build')) {",
                        "              GoodsAdd(CurShip,t_Technics,-GoodsAdd(CurShip,t_Technics,0));",
                        "              ShipCustomShipInfoData(IdToShip(ShipData()),'Cat_SAS_Build',1,ShipCustomShipInfoData(IdToShip(ShipData()),'Cat_SAS_Build',1) - 1);",
                        "              OrderLock(CurShip, 0);",
                        "              OrderTakeOff(CurShip);",
                        "          }",
                        "          else {",
                        "              OrderLock(CurShip, 0);",
                        "              OrderTakeOff(CurShip);",
                        "          }",
                        "      }",
                        "      else {",
                        "          OrderLock(CurShip, 1);",
                        "          OrderTakeOff(CurShip);",
                        "      }",
                        "  }",
                        "  else {",
                        "      //Не забываем про этого обормота",
                        "      dword ship = TranclucatorData(tranc,'Proprietor');",
                        "      if(ship > 0) ShipDestroy(ship);",
                        "      ",
                        "      ShipOut(CurShip);",
                        "      ShipDestroy(CurShip);",
                        "  }",
                        "  ChangeState(2);",
                        "  exit;",
                        "}"
                    ],
                    "#": 49,
                    "Type": "Top",
                    "Parent": -1,
                    "Pos.x": 240
                },
                {
                    "Name": "",
                    "Code.Type": "Turn",
                    "Code": [
                        "if(ShipInNormalSpace(CurShip)) {",
                        "    if(~IdToShip(ShipData())) {",
                        "        if(!OrderLock(CurShip)) OrderLanding(CurShip, NearCivilPlanet(CurShip));",
                        "        OrderLock(CurShip, 1);",
                        "    }",
                        "    else {",
                        "        OrderLock(CurShip,0);",
                        "        ShipDestroy(CurShip,1);",
                        "    }",
                        "}"
                    ],
                    "#": 50,
                    "Type": "Top",
                    "Parent": -1,
                    "Pos.x": 320
                },
                {
                    "Name": "",
                    "Code.Type": "Turn",
                    "Code": [
                        "if(!CoalitionDefeated()) {",
                        "  DChange(0);",
                        "  exit;",
                        "}",
                        "if(CoalitionDefeated()) {",
                        "  DChange(1);",
                        "  exit;",
                        "}"
                    ],
                    "#": 51,
                    "Type": "Top",
                    "Parent": -1,
                    "Pos.x": -20,
                    "Pos.y": 375
                },
                {
                    "Name": "",
                    "Code.Type": "Turn",
                    "Code": [
                        "temp_sec = GalaxySectors(GAnswerData);",
                        "tstr = Name(temp_sec);",
                        "DChange(3);",
                        "exit;"
                    ],
                    "#": 52,
                    "Type": "Top",
                    "Parent": -1,
                    "Pos.x": 130,
                    "Pos.y": 375
                },
                {
                    "Name": "",
                    "Code.Type": "Turn",
                    "Code": [
                        "temp_star = GAnswerData;",
                        "tstr = Name(GAnswerData);",
                        "j=0;",
                        "for(k=0;StarRuins(temp_star)>k;k=k+1) {",
                        "    if(ShipType(StarRuins(temp_star,k)) == 'WB') j=j+1;",
                        "}",
                        "",
                        "if(StarRuins(temp_star) - j >= 3) tstr2 = CT(\"Script.Cat_StationSuperintendent.25\");",
                        "else if(StarOwner(temp_star) != 0 && StarOwner(temp_star) != 2) tstr2 = CT(\"Script.Cat_StationSuperintendent.24\");",
                        "else if(StarOwner(temp_star) == 2 && !CoalitionDefeated()) tstr2 = CT(\"Script.Cat_StationSuperintendent.23\");",
                        "else tstr2 = '';",
                        "",
                        "cost = GalaxyMoney(4,4) * 3;",
                        "DChange(4);",
                        "exit;"
                    ],
                    "#": 53,
                    "Type": "Top",
                    "Parent": -1,
                    "Pos.x": 250,
                    "Pos.y": 375
                },
                {
                    "Name": "",
                    "Code.Type": "Turn",
                    "Code": [
                        "i = GAnswerData;",
                        "tstr = '</color>' + CT('MicroModuls.Cat_StationSuperintendent_Structure.ExText');",
                        "tstr2 = '</color>' + CT('MicroModuls.Cat_StationSuperintendent_StarForse.ExText');",
                        "tstr3 = '</color>' + CT('MicroModuls.Cat_StationSuperintendent_Stronghold.ExText');",
                        "l = round(cost*CT('MicroModuls.Cat_StationSuperintendent_Structure.Cost')/100);",
                        "j = round(cost*CT('MicroModuls.Cat_StationSuperintendent_StarForse.Cost')/100);",
                        "k = round(cost*CT('MicroModuls.Cat_StationSuperintendent_Stronghold.Cost')/100);",
                        "DChange(5);",
                        "exit;"
                    ],
                    "#": 54,
                    "Type": "Top",
                    "Parent": -1,
                    "Pos.x": 370,
                    "Pos.y": 375
                },
                {
                    "Name": "",
                    "Code.Type": "Turn",
                    "Code": [
                        "DAdd(0);",
                        "DAdd(1);"
                    ],
                    "#": 55,
                    "Type": "Top",
                    "Parent": -1,
                    "Pos.x": -20,
                    "Pos.y": 445
                },
                {
                    "Name": "",
                    "Code.Type": "Turn",
                    "Code": [
                        "DAdd(0);",
                        "DAdd(1);"
                    ],
                    "#": 56,
                    "Type": "Top",
                    "Parent": -1,
                    "Pos.x": 130,
                    "Pos.y": 445
                },
                {
                    "Name": "",
                    "Code.Type": "Turn",
                    "Code": [
                        "for(i = 0;GalaxySectors() >= i;i = i + 1) {",
                        "    if(!GalaxySectors(i)) continue;",
                        "    if(SectorVisible(GalaxySectors(i)) && StarToCon(ShipStar(Player())) == GalaxySectors(i)) InjectAnswer('Sector',Name(GalaxySectors(i))+CT(\"Script.Cat_StationSuperintendent.26\"),i);",
                        "    else continue;",
                        "}",
                        "for(i = 0;GalaxySectors() >= i;i = i + 1) {",
                        "    if(!GalaxySectors(i)) continue;",
                        "    if(SectorVisible(GalaxySectors(i)) && StarToCon(ShipStar(Player())) == GalaxySectors(i)) continue;",
                        "    else if (SectorVisible(GalaxySectors(i))) InjectAnswer('Sector',Name(GalaxySectors(i)),i);",
                        "}",
                        "DAdd(0);"
                    ],
                    "#": 57,
                    "Type": "Top",
                    "Parent": -1,
                    "Pos.x": 280,
                    "Pos.y": 445
                },
                {
                    "Name": "",
                    "Code.Type": "Turn",
                    "Code": [
                        "for(i = 0;ConStars(temp_sec) >= i;i = i + 1) {",
                        "    if(!ConStar(temp_sec,i)) continue;",
                        "    if(ShipStar(Player()) == ConStar(temp_sec,i)) InjectAnswer('Systems',Name(ConStar(temp_sec,i))+CT(\"Script.Cat_StationSuperintendent.26\"),ConStar(temp_sec,i));",
                        "    else continue;",
                        "}",
                        "for(i = 0;ConStars(temp_sec) >= i;i = i + 1) {",
                        "    if(!ConStar(temp_sec,i)) continue;",
                        "    if(ShipStar(Player()) == ConStar(temp_sec,i)) continue;",
                        "    else InjectAnswer('Systems',Name(ConStar(temp_sec,i)),ConStar(temp_sec,i));",
                        "}",
                        "DAdd(0);"
                    ],
                    "#": 58,
                    "Type": "Top",
                    "Parent": -1,
                    "Pos.x": 430,
                    "Pos.y": 445
                },
                {
                    "Name": "",
                    "Code.Type": "Turn",
                    "Code": [
                        "j = 0;",
                        "for(k=0;StarShips(temp_star)>k;k=k+1) {",
                        "    if(ShipType(StarShips(temp_star,k)) == 'WB') j=j+1;",
                        "}",
                        "",
                        "if(StarRuins(temp_star) - j < 3 && StarCustomFaction(temp_star) == '') {",
                        "    if(!CoalitionDefeated() && !ShipOnSidePirateClan(Player()) && StarOwner(temp_star) == 0) {",
                        "        if(StarRuins(temp_star,'RC') == 0 && ShipMoney(Player()) >= cost) InjectAnswer('Build',CT(\"Script.Cat_StationSuperintendent.13\"),6);",
                        "        if(StarRuins(temp_star,'SB') == 0 && ShipMoney(Player()) >= cost) InjectAnswer('Build',CT(\"Script.Cat_StationSuperintendent.12\"),9);",
                        "        if(StarRuins(temp_star,'BK') == 0 && ShipMoney(Player()) >= cost) InjectAnswer('Build',CT(\"Script.Cat_StationSuperintendent.11\"),10);",
                        "    }",
                        "    if(StarRuins(temp_star,'MC') == 0 && StarOwner(temp_star) != 1 && ShipMoney(Player()) >= cost) InjectAnswer('Build',CT(\"Script.Cat_StationSuperintendent.10\"),11);",
                        "    if(ShipOnSidePirateClan(Player())) {",
                        "        if(StarRuins(temp_star,'PB') != 1 && ShipMoney(Player()) >= cost && StarOwner(temp_star) != 1) InjectAnswer('Build',CT(\"Script.Cat_StationSuperintendent.9\"),7);",
                        "        if(StarOwner(temp_star) == 2 && ShipMoney(Player()) >= cost) InjectAnswer('Build',CT(\"Script.Cat_StationSuperintendent.8\"),12);",
                        "    }",
                        "    if(CurrentMods('Expansion\\\\ExpTC') /*&& CurrentMods('Expansion\\\\ExpPilotBridge')*/) {",
                        "        if(StarRuins(temp_star,'TC') == 0 && StarOwner(temp_star) != 1 && ShipMoney(Player()) >= cost) InjectAnswer('Build',CT(\"Script.Cat_StationSuperintendent.27\"),13);",
                        "    }",
                        "}",
                        "",
                        "//Слава системам Мажино!",
                        "",
                        "if(StarOwner(temp_star) == 0 && ShipMoney(Player()) >= cost && j<6 && !ShipOnSidePirateClan(Player()) && StarCustomFaction(temp_star) == '') {",
                        "    InjectAnswer('Build',CT(\"Script.Cat_StationSuperintendent.14\"),8);",
                        "}",
                        "DAdd(2);"
                    ],
