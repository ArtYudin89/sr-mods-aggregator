            "Operations": [
                {
                    "Name": "",
                    "Code.Type": "Global",
                    "Code": [
                        "if(GalaxyTechLevel() >= 6) {",
                        "  if(ShipRank(Player()) >= 7 || GetShipPirateRank(Player()) >= 5) {",
                        "    GRun();",
                        "  }",
                        "}"
                    ],
                    "#": 24,
                    "Type": "Top",
                    "Parent": -1,
                    "Pos.x": 0,
                    "Pos.y": 660
                },
                {
                    "Name": "",
                    "Code.Type": "Init",
                    "Code": [
                        "bad_special_name = CT('Settings.bad_special_name');",
                        "good_special_name = CT('Settings.good_special_name');",
                        "",
                        "cost = CT('Settings.cost');",
                        "upgrade_cost = CT('Settings.upgrade_cost');",
                        "hull_cost_1 = CT('Settings.hull_cost_1');",
                        "hull_cost_2 = CT('Settings.hull_cost_2');",
                        "",
                        "research_time = CT('Settings.research_time');",
                        "",
                        "item_size = CT('Settings.item_size');",
                        "hull_size_bad= CT('Settings.hull_size_bad');",
                        "hull_size_good = CT('Settings.hull_size_good');",
                        "",
                        "",
                        "dword quest_item = CreateQuestItem('Cat_Dragon_Egg', None);",
                        "ItemSize(quest_item, Rnd(0.5 * item_size, 1.5 * item_size));",
                        "LinkItemToScript(quest_item, Egg);",
                        "",
                        "dword star = StarNearbyStars(ShipStar(Player()), Rnd(25, 35));",
                        "int i = 0;",
                        "for (i = 0; i < StarPlanets(star); i = i + 1) {",
                        "    if (PlanetOwner(StarPlanets(star, i)) == None) {",
                        "        AddItemToPlanet(StarPlanets(star, i), quest_item);",
                        "        SFT(Name(StarPlanets(star, i)) + Name(star) + ' label');",
                        "        break;",
                        "    }",
                        "}"
                    ],
                    "#": 25,
                    "Type": "Top",
                    "Parent": -1,
                    "Pos.x": 60,
                    "Pos.y": 660
                },
                {
                    "Name": "",
                    "Code.Type": "Turn",
                    "Code": [
                        "if(state == 1) {",
                        "  if(CurTurn() >= research_start_date + research_time) {",
                        "    if(IdToShip(base_id)) {",
                        "      Ether(0, '', Format(CT(\"Script.Dragon.185\"),\"<0>\",base_name));",
                        "      state = 2;",
                        "    }",
                        "  }",
                        "  if(!IdToShip(base_id)) {",
                        "    Ether(0, '', Format(CT(\"Script.Dragon.184\"),\"<0>\",base_name));",
                        "    state = -1;",
                        "  }",
                        "}"
                    ],
                    "#": 26,
                    "Type": "Top",
                    "Parent": -1,
                    "Pos.x": 120,
                    "Pos.y": 660
                },
                {
                    "Name": "",
                    "Code.Type": "DialogBegin",
                    "Code": [
                        "if(GetShipRuins(Player())) {",
                        "  if(!PlayerBridge()) {",
                        "    if(state == 0) {",
                        "      if(ItemExist(Egg)) {",
                        "        if(ItemIn(Egg, Player())) {",
                        "          if(ShipType(GetShipRuins(Player())) == 'SB') {",
                        "            AddDialogInject('DialogSB1', '', CT(\"Script.Dragon.230\"), 1);",
                        "          }",
                        "          if(ShipType(GetShipRuins(Player())) != 'SB') {",
                        "            AddDialogInject('WrongBase1', '', CT(\"Script.Dragon.230\"), 1);",
                        "          }",
                        "        }",
                        "      }",
                        "    }",
                        "    if(state == 1) {",
                        "      if(Id(GetShipRuins(Player())) == base_id) {",
                        "        AddDialogInject('DialogSB1.5', '', CT(\"Script.Dragon.229\"), 1);",
                        "      }",
                        "      if(Id(GetShipRuins(Player())) != base_id) {",
                        "        if(ShipType(GetShipRuins(Player())) == 'SB') {",
                        "          AddDialogInject('WrongBase1.5', '', CT(\"Script.Dragon.229\"), 1);",
                        "        }",
                        "      }",
                        "    }",
                        "    if(state == 2) {",
                        "      if(Id(GetShipRuins(Player())) == base_id) {",
                        "        AddDialogInject('DialogSB2', '', CT(\"Script.Dragon.229\"), 1);",
                        "      }",
                        "      if(Id(GetShipRuins(Player())) != base_id) {",
                        "        if(ShipType(GetShipRuins(Player())) == 'SB') {",
                        "          AddDialogInject('WrongBase2', '', CT(\"Script.Dragon.229\"), 1);",
                        "        }",
                        "      }",
                        "    }",
                        "    if(state == 3) {",
                        "      if(Id(GetShipRuins(Player())) == base_id) {",
                        "        AddDialogInject('DialogSB3', '', CT(\"Script.Dragon.228\"), 1);",
                        "      }",
                        "      if(Id(GetShipRuins(Player())) != base_id) {",
                        "        if(ShipType(GetShipRuins(Player())) == 'SB') {",
                        "          AddDialogInject('WrongBase3', '', CT(\"Script.Dragon.228\"), 1);",
                        "        }",
                        "      }",
                        "    }",
                        "    if(state == 4) {",
                        "      if(CurTurn() >= timer + 3 * 365) {",
                        "        if(ItemExist(hull_bad)) {",
                        "          if(ItemIn(hull_bad, Player())) {",
                        "            if(ShipType(GetShipRuins(Player())) == 'SB') {",
                        "              AddDialogInject('DialogSB4', '', CT(\"Script.Dragon.227\"), 1);",
                        "            }",
                        "          }",
                        "        }",
                        "      }",
                        "    }",
                        "  }",
                        "}"
                    ],
