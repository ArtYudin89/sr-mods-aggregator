                        "}",
                        "",
                        "ItemSize(hull, hull_size_bad);",
                        "ItemCost(hull, hull_cost_1);",
                        "HullHP(hull, ItemSize(hull));",
                        "AddItemToStorage(GetShipRuins(Player()), hull);",
                        "LinkItemToScript(hull, hull_bad);",
                        "CanSellItem(hull_bad, 0);",
                        "DChange(3);",
                        "exit;"
