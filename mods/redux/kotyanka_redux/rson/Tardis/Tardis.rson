            "Operations": [
                {
                    "Name": "",
                    "Code.Type": "Global",
                    "Code": [
                        "GRun();"
                    ],
                    "#": 26,
                    "Type": "Top",
                    "Parent": -1,
                    "Pos.x": 0,
                    "Pos.y": 635
                },
                {
                    "Name": "",
                    "Code.Type": "Init",
                    "Code": [
                        "state = 1;",
                        "planets_needed = 30;",
                        "quest_created = 0;",
                        "chance = 0;"
                    ],
                    "#": 27,
                    "Type": "Top",
                    "Parent": -1,
                    "Pos.x": 60,
                    "Pos.y": 635
                },
                {
                    "Name": "",
                    "Code.Type": "Turn",
                    "Code": [
                        "if(state==3) {",
                        "    if(!quest_created) {",
                        "        if(ItemExist(clock)){",
                        "            if(ItemIn(clock, Player())){",
                        "                ether_iden = 'tardis_activate_quest';",
                        "                Ether(3,'tardis_activate_quest','Активировать часы и вспомнить всё');",
                        "                quest_created = 1;",
                        "",
                        "            }",
                        "        }",
                        "    }",
                        "}",
                        "//Проверяем игрок на планете или нет",
                        "if(GetShipPlanet(Player())) {",
                        "    //Проверяем не заспавнены ли часы уже",
                        "    if(!clock_create){",
                        "",
                        "        //Проверяем незаселёнка ли это",
                        "        if(PlanetOwner(GetShipPlanet(Player()))==6){",
                        "            //Проверяем есть ли уже планета в списке посещенных",
                        "            if(ArrayFind(planets_visited,Id(GetShipPlanet(Player())))<0){",
                        "                //Добавляем планету в список посещённых",
                        "                ArrayAdd(planets_visited,Id(GetShipPlanet(Player())));",
                        "                //Проверяем количество планет",
                        "                if(ArrayDim(planets_visited)>planets_needed){",
                        "                    //Проверяем ГТУ",
                        "                    if(state < 2) {",
                        "                        if(GalaxyTechLevel()>=5){",
                        "                            state = 2;",
                        "                            chance = 50;",
                        "                        }",
                        "                    }",
                        "                    else",
                        "                    {",
                        "                        if(chance <=100) {",
                        "                            chance = chance + 5;",
                        "                        }",
                        "",
                        "                    }",
                        "                    if(Rnd(1,100)<=chance) {",
                        "                        item = CreateQuestItem('Clock');",
                        "                        ItemSize(item,1);",
                        "                        LinkItemToScript(item,clock);",
                        "                        star = StarNearbyStars(PlanetToStar(GetShipHomePlanet(Player())), Rnd(10, 30));",
                        "                        while(StarToCon(star) == StarToCon(PlanetToStar(PlanetPirateClan()))) star = StarNearbyStars(PlanetToStar(GetShipHomePlanet(Player())), Rnd(10, 30));",
                        "                        for(i = 0; i < StarPlanets(star); i = i + 1)",
                        "                        {",
                        "                            spawn_planet = StarPlanets(star, i);",
                        "                            if(PlanetOwner(spawn_planet) != 6) continue;",
                        "                            ArrayAdd(array_spawn_planets, spawn_planet);",
                        "                            planetgen = planetgen+ 1;",
                        "                        }",
                        "                        if(planetgen) {",
                        "                            spawn_planet = array_spawn_planets[Rnd(1, planetgen)];",
                        "                            AddItemToPlanet(spawn_planet, item);",
                        "",
                        "                            state = 3;",
                        "                            clock_create = 1;",
                        "",
                        "                        }",
                        "",
                        "                    }",
                        "                }",
                        "            }",
                        "        }",
                        "    }",
                        "}"
                    ],
                    "#": 28,
                    "Type": "Top",
                    "Parent": -1,
                    "Pos.x": 120,
                    "Pos.y": 635
                },
                {
                    "Name": "",
                    "Code.Type": "DialogBegin",
                    "Code": [
                        "if(!PlayerBridge()) {",
                        "  if(GetShipRuins(Player())) {",
                        "    if(state == 3) {",
                        "      if(ItemExist(clock)) {",
                        "        if(ItemIn(clock, Player())) {",
                        "          if(ShipType(GetShipRuins(Player())) == 'SB') {",
                        "            AddDialogInject('ActivateClockTardis', '', CT(\"Script.Tardis.187\"), 1);",
                        "          }",
                        "        }",
                        "      }",
                        "    }",
                        "  }",
                        "}",
                        "if(GetShipRuins(Player())) {",
                        "  if(PlayerBridge()==3) {",
                        "    if(ShipFindCustomShipInfoByType(Player(),'Tardis')>0) {",
                        "      if(ShipCustomShipInfoData(Player(),'Tardis',1)) {",
                        "        AddDialogInject('TardisControl','', CT(\"Script.Tardis.191\"), 1);",
                        "      }",
                        "    }",
                        "  }",
                        "}"
                    ],
                    "#": 29,
                    "Type": "Top",
                    "Parent": -1,
                    "Pos.x": 180,
                    "Pos.y": 635
                },
                {
                    "Name": "",
                    "Code.Type": "Turn",
                    "Code": [
                        "if(ShipPilotRace(Player())==People) {",
                        "  DChange(0);",
                        "  exit;",
                        "}",
                        "if(ShipPilotRace(Player())!=People) {",
                        "  DChange(2);",
                        "  exit;",
                        "}"
                    ],
                    "#": 64,
                    "Type": "Top",
                    "Parent": -1,
                    "Pos.x": -20,
                    "Pos.y": 400
                },
                {
                    "Name": "",
                    "Code.Type": "Turn",
                    "Code": [
                        "temp = ShipCustomShipInfoData(Player(),'TardisEnergy',1);",
                        "if(energymod==1){",
                        "    tempstr= CT(\"Script.Tardis.213\");",
                        "    tempup= ShipSkill(Player(),2)*10/2;",
                        "}",
                        "else if(energymod==2) {",
                        "    tempstr= CT(\"Script.Tardis.212\");",
                        "    tempup= ShipSkill(Player(),2)*10;",
                        "}",
                        "else {",
                        "    tempstr= CT(\"Script.Tardis.211\");",
                        "    tempup= ShipSkill(Player(),2)*10*2;",
                        "}",
                        "if(defstat==0){",
                        "    tempstra = CT(\"Script.Tardis.210\");",
                        "}",
                        "else {",
                        "    tempstra = CT(\"Script.Tardis.209\");",
                        "}",
                        "DChange(3);",
                        "exit;"
                    ],
                    "#": 65,
                    "Type": "Top",
                    "Parent": -1,
                    "Pos.x": 250,
                    "Pos.y": 400
                },
                {
                    "Name": "",
                    "Code.Type": "Turn",
                    "Code": [
                        "DAdd(0);"
                    ],
                    "#": 66,
                    "Type": "Top",
                    "Parent": -1,
                    "Pos.x": -20,
                    "Pos.y": 470
                },
                {
                    "Name": "",
                    "Code.Type": "Turn",
                    "Code": [
                        "DAdd(2);"
                    ],
                    "#": 67,
                    "Type": "Top",
                    "Parent": -1,
                    "Pos.x": 130,
                    "Pos.y": 470
                },
                {
                    "Name": "",
                    "Code.Type": "Turn",
                    "Code": [
                        "EtherDelete(ether_iden);",
                        "Ether(5,'tardis_activate_quest','Активировать часы и вспомнить всё');",
                        "FreeItem(GetItemFromShip(Player(), FindItemInShip(Player(), clock)));",
                        "DAdd(1);"
                    ],
                    "#": 68,
