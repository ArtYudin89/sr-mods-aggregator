                    "Code.Type": "Turn",
                    "Code": [
                        "if(ShipInNormalSpace(Player())) {",
                        "    RunChildForm('Galaxy');",
                        "    if(ShipOrder(Player()) == 7) {",
                        "        if(PlayerBridge()) PlayerBridge(0);",
                        "        ShipOrderData1(Player(), 1);",
                        "        ShipCustomShipInfoData(Player(),'TardisEnergy',1,ShipCustomShipInfoData(Player(),'TardisEnergy',1)-800);",
                        "        ForceNextDay();",
                        "        exit;",
                        "    }",
                        "}",
                        "else {",
                        "    MessageBox(CT(\"Script.Tardis.215\"));",
                        "    exit;",
                        "}"
