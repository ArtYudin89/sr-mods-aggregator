                    "Pos.x": 430,
                    "Pos.y": 470
                },
                {
                    "Name": "",
                    "Code.Type": "Turn",
                    "Code": [
                        "if(ShipCustomShipInfoData(Player(),'TardisEnergy',1)>=500) {",
                        "  DAdd(11);",
                        "  DAdd(12);",
                        "}",
                        "if(ShipCustomShipInfoData(Player(),'TardisEnergy',1)<500) {",
                        "  DAdd(16);",
                        "  DAdd(17);",
                        "}",
                        "DAdd(13);"
                    ],
