                        "StrLvlHullAcrin[1] = CT(\"Script.Cat_ZelPirates.216\");",
                        "StrLvlHullAcrin[2] = CT(\"Script.Cat_ZelPirates.215\");",
                        "StrLvlHullAcrin[3] = CT(\"Script.Cat_ZelPirates.214\");",
                        "StrLvlHullAcrin[4] = CT(\"Script.Cat_ZelPirates.213\");",
