                        "//",
                        "StrLvlFreq = newarray(5);",
                        "StrLvlFreq[0] = CT(\"Script.Cat_ZelPirates.242\");",
                        "StrLvlFreq[1] = CT(\"Script.Cat_ZelPirates.241\");",
                        "StrLvlFreq[2] = CT(\"Script.Cat_ZelPirates.240\");",
                        "StrLvlFreq[3] = CT(\"Script.Cat_ZelPirates.239\");",
                        "StrLvlFreq[4] = CT(\"Script.Cat_ZelPirates.238\");",
                        "",
                        "StrNRangers = newarray(5);",
