                        "StrNRangers[1] = CT(\"Script.Cat_ZelPirates.236\");",
                        "StrNRangers[2] = CT(\"Script.Cat_ZelPirates.235\");",
                        "StrNRangers[3] = CT(\"Script.Cat_ZelPirates.234\");",
                        "StrNRangers[4] = CT(\"Script.Cat_ZelPirates.233\");",
                        "",
                        "StrNItems = newarray(5);",
                        "StrNItems[0] = CT(\"Script.Cat_ZelPirates.197\");",
                        "StrNItems[1] = CT(\"Script.Cat_ZelPirates.232\");",
                        "StrNItems[2] = CT(\"Script.Cat_ZelPirates.195\");",
                        "StrNItems[3] = CT(\"Script.Cat_ZelPirates.231\");",
                        "StrNItems[4] = CT(\"Script.Cat_ZelPirates.230\");",
                        "",
                        "StrLvlSkills = newarray(5);",
                        "StrLvlSkills[0] = CT(\"Script.Cat_ZelPirates.229\");",
                        "StrLvlSkills[1] = CT(\"Script.Cat_ZelPirates.228\");",
                        "StrLvlSkills[2] = CT(\"Script.Cat_ZelPirates.227\");",
                        "StrLvlSkills[3] = CT(\"Script.Cat_ZelPirates.226\");",
                        "StrLvlSkills[4] = CT(\"Script.Cat_ZelPirates.225\");",
                        "",
                        "StrLvlUpgrade = newarray(5);",
                        "StrLvlUpgrade[0] = CT(\"Script.Cat_ZelPirates.164\");",
                        "StrLvlUpgrade[1] = CT(\"Script.Cat_ZelPirates.163\");",
                        "StrLvlUpgrade[2] = CT(\"Script.Cat_ZelPirates.224\");",
                        "StrLvlUpgrade[3] = CT(\"Script.Cat_ZelPirates.223\");",
                        "StrLvlUpgrade[4] = CT(\"Script.Cat_ZelPirates.222\");",
                        "",
                        "StrLvlHullSize = newarray(5);",
                        "StrLvlHullSize[0] = CT(\"Script.Cat_ZelPirates.186\");",
                        "StrLvlHullSize[1] = CT(\"Script.Cat_ZelPirates.221\");",
                        "StrLvlHullSize[2] = CT(\"Script.Cat_ZelPirates.220\");",
                        "StrLvlHullSize[3] = CT(\"Script.Cat_ZelPirates.219\");",
