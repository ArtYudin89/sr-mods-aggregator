                },
                {
                    "Name": "",
                    "Pos.x": 1200,
                    "Pos.y": 545,
                    "Type": "TDialogMsg",
                    "Parent": -1,
                    "#": 84,
                    "Msg": "Верховный, вы уверены? Повернуть приказ вспять будет проблематично.",
