                },
                {
                    "Name": "",
                    "Code.Type": "Turn",
                    "Code": [
                        "if(CoalitionDefeated()) {",
                        "    NewsAdd(CT(\"Script.Cat_ZelPirates.265\"));",
                        "    AddPlanetNews(CT(\"Script.Cat_ZelPirates.265\"),87);",
                        "}",
                        "else {",
                        "    NewsAdd(CT(\"Script.Cat_ZelPirates.264\"));",
                        "    AddPlanetNews(CT(\"Script.Cat_ZelPirates.264\"),87);",
                        "}",
                        "Sound('Sound.NewMsg');",
                        "",
                        "for(i=0;GalaxyStars()>i;i=i+1) {",
                        "    item = GalaxyStar(i);",
                        "    if(StarOwner(item) != 2) continue;",
                        "    if(StarOwner(item) == 2 && StarBattle(item)) continue;",
                        "    int g = 0;",
                        "    for(j=0;StarShips(item)>j;j=j+1) {",
                        "        ship = StarShips(item,j);",
                        "        if(ShipOwner(ship) != 7) continue;",
                        "        if(ShipTypeN(ship) != t_Warrior || ShipTypeN(ship) != t_Pirate) continue;",
                        "        if(ShipInScript(ship)) continue;",
                        "        if(!g) {",
                        "            g = 1;",
                        "            continue;",
                        "        }",
                        "        if(g) {",
                        "            ShipJoin(GroupLand,ship);",
                        "            g = 0;",
                        "            continue;",
                        "        }",
                        "    }",
                        "}",
                        "",
                        "LandState = 1;",
                        "LandCD = RndObject(200,350,PlanetPirateClan());"
                    ],
