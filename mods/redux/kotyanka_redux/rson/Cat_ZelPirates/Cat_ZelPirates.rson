                },
                {
                    "Name": "",
                    "Pos.x": 1050,
                    "Pos.y": 545,
                    "Type": "TDialogMsg",
                    "Parent": -1,
                    "#": 83,
                    "Msg": "Рады приветствовать вас, Верховный!\r\n\r\nНаше братство радо слушать ваши мудрые речи и дальновидные приказания!\r\n\r\nКого будем грабить сегодня?",
                    "DMsg.Num": "19",
