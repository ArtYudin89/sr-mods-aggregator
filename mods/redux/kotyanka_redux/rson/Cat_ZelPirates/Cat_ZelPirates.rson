                {
                    "Name": "",
                    "Code.Type": "Turn",
                    "Code": [
                        "if(PirateWin() != 3 && PirateWin() != 4 && PlanetExtraFlags(PlanetPirateClan()) < 1) {",
                        "    if (CurTurn() >= buy_date + BuildingTime()) {",
                        "        // Обновляем дату постройки",
                        "        buy_date = CurTurn();",
                        "        // Покупаем NRangers рейнджеров на каждом ЦР",
                        "        for (j = 0; j < GalaxyStars(); j = j + 1) {",
                        "            if (StarRuins(GalaxyStar(j),'PB')) {",
                        "                for (k = 0; k < NRangers; k = k + 1) {",
                        "                    BuyNewRanger(StarRuins(GalaxyStar(j),'PB'), k);",
                        "                }",
                        "            }",
                        "        }",
                        "    }",
                        "}",
                        "if(debug) {",
                        "  SFT('CurTurn: ' + CurTurn() + ' Building time: ' + BuildingTime() + ' Build date: ' + buy_date + BuildingTime() + ' Last build: ' + buy_date);",
                        "}",
                        "if(LandState == 2) {",
                        "    if(LandCD) LandCD = LandCD - 1;",
                        "    else LandState = 0;",
                        "}",
                        "if(AttackState == 1) {",
                        "    if(AttackCD) AttackCD = AttackCD - 1;",
                        "    else {",
                        "        Sound('Sound.NewMsg');",
                        "        NewsAdd(CT(\"Script.Cat_ZelPirates.243\"));",
                        "        AttackState = 2;",
                        "    }",
                        "",
                        "    for(i=0;GalaxyStars()>i;i=i+1) {",
                        "        item = GalaxyStar(i);",
                        "        if(StarOwner(item) != 2) continue;",
                        "        if(StarOwner(item) == 2 && StarBattle(item)) continue;",
                        "        int g = 0;",
                        "        for(j=0;StarShips(item)>j;j=j+1) {",
                        "            ship = StarShips(item,j);",
                        "            if(ShipOwner(ship) != 7) continue;",
                        "            if(ShipTypeN(ship) != t_Warrior || ShipTypeN(ship) != t_Pirate) continue;",
                        "            if(ShipInScript(ship)) continue;",
                        "            ShipJoin(GroupPirates,ship);",
                        "        }",
                        "    }",
                        "}",
                        "if(CustodCD) CustodCD = CustodCD - 1;",
                        "",
                        "if(!GroupCount(GroupLand) && LandState == 1) LandState = 2;"
                    ],
                    "#": 53,
                    "Type": "Top",
                    "Parent": -1,
                    "Pos.x": 120,
                    "Pos.y": 785
                },
                {
                    "Name": "",
                    "Code.Type": "DialogBegin",
                    "Code": [
                        "if(ShipOnSidePirateClan(Player())) {",
                        "  //SFT('Cat_ZelPirates logging: Dialog 1');",
                        "  if(GetShipPlanet(Player())) {",
                        "    if(GetShipPlanet(Player()) == PlanetPirateClan()) {",
                        "      if(GetShipPirateRank(Player()) == 7) {",
                        "          if(!CurrentMods('ShusRangers\\\\ShuRG')) {",
                        "              AddDialogOverride('Baron', 99);",
                        "          }",
                        "      }",
                        "      if(accepted) AddDialogInject('Verbovka2', '', CT(\"Script.Cat_ZelPirates.286\"), 5);",
                        "      else AddDialogInject('Begin', '', CT(\"Script.Cat_ZelPirates.285\"), 5);",
                        "    }",
                        "  }",
                        "  if(GetShipRuins(Player())) {",
                        "    //SFT('Cat_ZelPirates logging: Dialog 2');",
                        "    if(ShipType(GetShipRuins(Player())) == 'PB') {",
                        "      if(accepted) AddDialogInject('Verbovka2', '', CT(\"Script.Cat_ZelPirates.286\"), 5);",
                        "      else AddDialogInject('Begin', '', CT(\"Script.Cat_ZelPirates.285\"), 5);",
                        "      //SFT('Cat_ZelPirates logging: Dialog 3');",
                        "    }",
                        "  }",
                        "}"
                    ],
                    "#": 54,
                    "Type": "Top",
                    "Parent": -1,
                    "Pos.x": 180,
                    "Pos.y": 785
                },
                {
                    "Name": "",
                    "Code.Type": "Turn",
                    "Code": [
                        "if(ShipInNormalSpace(CurShip)) {",
                        "  if(ShipStar(CurShip) != PlanetToStar(PlanetPirateClan())) {",
                        "    OrderJump(CurShip,PlanetToStar(PlanetPirateClan()));",
                        "    if(ShipStar(CurShip) == PlanetToStar(PlanetPirateClan())) {",
                        "      ChangeState(3);",
                        "      exit;",
                        "    }",
                        "  }",
                        "}",
                        "if(GetShipPlanet(CurShip) || GetShipRuins(CurShip)) {",
                        "  OrderTakeOff(CurShip);",
                        "}",
                        "if(ShipStar(CurShip) == PlanetToStar(PlanetPirateClan())) {",
                        "  ChangeState(3);",
                        "  exit;",
                        "}"
                    ],
                    "#": 147,
                    "Type": "Top",
                    "Parent": -1,
                    "Pos.x": 80
                },
                {
                    "Name": "",
                    "Code.Type": "Turn",
                    "Code": [
                        "if(ShipInNormalSpace(CurShip)) {",
                        "  OrderLanding(CurShip,NearCivilPlanet(CurShip));",
                        "  if(GetShipPlanet(CurShip)) {",
                        "    ShipMoney(Player(),ShipMoney(Player())+ShipMoney(CurShip));",
                        "    NewsAdd(CT(\"Script.Cat_ZelPirates.248\")+' '+Name(CurShip)+' '+CT(\"Script.Cat_ZelPirates.247\")+' '+Name(GetShipPlanet(CurShip))+' '+CT(\"Script.Cat_ZelPirates.246\")+' '+ShipMoney(CurShip)+' '+CT(\"Script.Cat_ZelPirates.245\"));",
                        "    OrderNone(CurShip);",
                        "    OrderLock(CurShip);",
                        "    ShipDestroy(CurShip);",
                        "  }",
                        "}",
                        "if(GetShipPlanet(CurShip)) {",
                        "  ShipMoney(Player(),ShipMoney(Player())+ShipMoney(CurShip));",
                        "  NewsAdd(CT(\"Script.Cat_ZelPirates.248\")+' '+Name(CurShip)+' '+CT(\"Script.Cat_ZelPirates.247\")+' '+Name(GetShipPlanet(CurShip))+' '+CT(\"Script.Cat_ZelPirates.246\")+' '+ShipMoney(CurShip)+' '+CT(\"Script.Cat_ZelPirates.245\"));",
                        "  OrderNone(CurShip);",
                        "  OrderLock(CurShip);",
                        "  ShipDestroy(CurShip);",
                        "}"
                    ],
                    "#": 148,
                    "Type": "Top",
                    "Parent": -1,
                    "Pos.x": 160
                },
                {
                    "Name": "",
                    "Code.Type": "Turn",
                    "Code": [
                        "if(!GetShipPlanet(CurShip)) {",
                        "  OrderLanding(CurShip,PlanetPirateClan());",
                        "  if(GetShipPlanet(CurShip)) {",
                        "    OrderNone(CurShip);",
                        "    if(AttackState == 3) {",
                        "      ChangeState(4);",
                        "      exit;",
                        "    }",
                        "  }",
                        "}",
                        "if(GetShipPlanet(CurShip)) {",
                        "  OrderNone(CurShip);",
                        "  if(AttackState == 3) {",
                        "    ChangeState(4);",
                        "    exit;",
                        "  }",
                        "}"
                    ],
