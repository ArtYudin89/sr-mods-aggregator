                        "      ShipSpecialBonuses(CurShip,bonNull,0);",
                        "      ShipSpecialBonuses(CurShip,bonFuel,ShipSpecialBonuses(CurShip,bonFuel)+5000000);",
                        "  }",
                        "}"
