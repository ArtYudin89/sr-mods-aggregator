            "Operations": [
                {
                    "Name": "",
                    "Code.Type": "Global",
                    "Code": [
                        "if(GalaxyTechLevel() >= 7) {",
                        "  if(ShipRank(Player()) >= 6 || GetShipPirateRank(Player()) >= 6) {",
                        "    GRun();",
                        "  }",
                        "}"
                    ],
                    "#": 37,
                    "Type": "Top",
                    "Parent": -1,
                    "Pos.x": 0,
                    "Pos.y": 760
                },
                {
                    "Name": "",
                    "Code.Type": "Init",
                    "Code": [
                        "function SpawnSturmer() {",
                        "    dword cur_star = ShipStar(Player());",
                        "    dword plan;",
                        "    dword tranc;",
                        "    dword tdwd;",
                        "    int i;",
                        "    int j;",
                        "",
                        "    //Ищем планету для спавна транка",
                        "    for(i=0;StarPlanets(cur_star)>i;i=i+1) {",
                        "        plan = StarPlanets(cur_star,i);",
                        "        if(PlanetOwner(plan) == 5 || PlanetOwner(plan) == 6) continue;",
                        "        break;",
                        "    }",
                        "",
                        "    tranc = BuyTranclucator(plan,0);",
                        "    //Начинаем красить транка",
                        "    ShipOwner(tranc,People);",
                        "    ShipPilotRace(tranc,People);",
                        "    ItemOwner(ShipEqInSlot(tranc,t_Hull),People);",
                        "    Chameleon('Ship.Akrin.YamatoSturmer');",
                        "",
                        "    //На всякий случай",
                        "    if(ShipOwner(Player()) == PirateClan) ShipStanding(tranc,7);",
                        "    else ShipStanding(tranc,3);",
                        "",
                        "    //Чтобы не сношаться с графикой предметов",
                        "    NoScanToShip(tranc,1);",
                        "",
                        "    if(ShipEqInSlot(tranc,t_Radar)) {",
                        "        tdwd = ShipEqInSlot(tranc,t_Radar);",
                        "        GetItemFromShip(tranc,tdwd);",
                        "        FreeItem(tdwd);",
                        "    }",
                        "    if(ShipEqInSlot(tranc,t_Engine)) {",
                        "        tdwd = ShipEqInSlot(tranc,t_Engine);",
                        "        GetItemFromShip(tranc,tdwd);",
                        "        FreeItem(tdwd);",
                        "    }",
                        "    if(ShipEqInSlot(tranc,t_FuelTanks)) {",
                        "        tdwd = ShipEqInSlot(tranc,t_FuelTanks);",
                        "        GetItemFromShip(tranc,tdwd);",
                        "        FreeItem(tdwd);",
                        "    }",
                        "    if(ShipEqInSlot(tranc,t_Scaner)) {",
                        "        tdwd = ShipEqInSlot(tranc,t_Scaner);",
                        "        GetItemFromShip(tranc,tdwd);",
                        "        FreeItem(tdwd);",
                        "    }",
                        "    if(ShipEqInSlot(tranc,t_DefGenerator)) {",
                        "        tdwd = ShipEqInSlot(tranc,t_DefGenerator);",
                        "        GetItemFromShip(tranc,tdwd);",
                        "        FreeItem(tdwd);",
                        "    }",
                        "    if(ShipEqInSlot(tranc,t_RepairRobot)) {",
                        "        tdwd = ShipEqInSlot(tranc,t_RepairRobot);",
                        "        GetItemFromShip(tranc,tdwd);",
                        "        FreeItem(tdwd);",
                        "    }",
                        "    if(ShipEqInSlot(tranc,t_CargoHook)) {",
                        "        tdwd = ShipEqInSlot(tranc,t_CargoHook);",
                        "        GetItemFromShip(tranc,tdwd);",
                        "        FreeItem(tdwd);",
                        "    }",
                        "    for(i=0;ShipSlots(tranc,1)>i;i=i+1) {",
                        "        if(ShipEqInSlot(tranc,t_Weapon1,i)) {",
                        "            tdwd = ShipEqInSlot(tranc,t_Weapon1,i);",
                        "            GetItemFromShip(tranc,tdwd);",
                        "            FreeItem(tdwd);",
                        "        }",
                        "    }",
                        "",
                        "    //А теперь набиваем транка барахлом",
                        "    if(SturmerLvL == 1) {",
                        "        ItemSize(ShipEqInSlot(tranc,t_Hull),100);",
                        "        HullHP(tranc,100);",
                        "        tdwd = CreateEquipment(t_FuelTanks,Rnd(5,10),1,People);",
                        "        AddItemToShip(tranc,tdwd);",
                        "        ItemIsInUse(tdwd,tranc,1);",
                        "        NoDropItem(tdwd);",
                        "        tdwd = CreateEquipment(t_Radar,Rnd(7,15),3,People);",
                        "        AddItemToShip(Player(),tdwd);",
                        "        ItemIsInUse(tdwd,Player(),1);",
                        "        NoDropItem(tdwd);",
                        "        tdwd = CreateEquipment(t_Engine,Rnd(15,20),3,People);",
                        "        AddItemToShip(Player(),tdwd);",
                        "        ItemIsInUse(tdwd,Player(),1);",
                        "        NoDropItem(tdwd);",
                        "        tdwd = CreateEquipment(t_Scaner,Rnd(5,10),1,People);",
                        "        AddItemToShip(Player(),tdwd);",
                        "        ItemIsInUse(tdwd,Player(),1);",
                        "        NoDropItem(tdwd);",
                        "        tdwd = CreateCustomWeapon('YamatoMinigun1',Rnd(5,10),1,People);",
                        "        AddItemToShip(Player(),tdwd);",
                        "        ItemIsInUse(tdwd,Player(),1);",
                        "        NoDropItem(tdwd);",
                        "",
                        "        HullSpecial(tranc,FindBonusByCustomTag('Yamato_OwfulResis'));",
                        "    }",
                        "    if(SturmerLvL == 2) {",
                        "        ItemSize(ShipEqInSlot(tranc,t_Hull),200);",
                        "        HullHP(tranc,200);",
                        "        ItemSize(ShipEqInSlot(tranc,t_Hull),100);",
                        "        HullHP(tranc,100);",
                        "        tdwd = CreateEquipment(t_FuelTanks,Rnd(5,10),1,People);",
                        "        AddItemToShip(tranc,tdwd);",
                        "        ItemIsInUse(tdwd,tranc,1);",
                        "        NoDropItem(tdwd);",
                        "        tdwd = CreateEquipment(t_Radar,Rnd(7,15),6,People);",
                        "        AddItemToShip(Player(),tdwd);",
                        "        ItemIsInUse(tdwd,Player(),1);",
                        "        NoDropItem(tdwd);",
                        "        tdwd = CreateEquipment(t_Engine,Rnd(15,20),6,People);",
                        "        AddItemToShip(Player(),tdwd);",
                        "        ItemIsInUse(tdwd,Player(),1);",
                        "        NoDropItem(tdwd);",
                        "        tdwd = CreateEquipment(t_Scaner,Rnd(5,10),1,People);",
                        "        AddItemToShip(Player(),tdwd);",
                        "        ItemIsInUse(tdwd,Player(),1);",
                        "        NoDropItem(tdwd);",
                        "        tdwd = CreateEquipment(t_RepairRobot,Rnd(5,10),8,People);",
                        "        AddItemToShip(Player(),tdwd);",
                        "        ItemIsInUse(tdwd,Player(),1);",
                        "        NoDropItem(tdwd);",
                        "        tdwd = CreateCustomWeapon('YamatoMinigun2',Rnd(5,10),6,People);",
                        "        AddItemToShip(Player(),tdwd);",
                        "        ItemIsInUse(tdwd,Player(),1);",
                        "        NoDropItem(tdwd);",
                        "        tdwd = CreateCustomWeapon('YamatoMinigun2',Rnd(5,10),6,People);",
                        "        AddItemToShip(Player(),tdwd);",
                        "        ItemIsInUse(tdwd,Player(),1);",
                        "        NoDropItem(tdwd);",
                        "",
                        "        ShipSkill(tranc,0,3);",
                        "        ShipSkill(tranc,1,3);",
                        "    }",
                        "    if(SturmerLvL == 3) {",
                        "        ItemSize(ShipEqInSlot(tranc,t_Hull),300);",
                        "        HullHP(tranc,300);",
                        "        ItemSize(ShipEqInSlot(tranc,t_Hull),100);",
                        "        HullHP(tranc,100);",
                        "        tdwd = CreateEquipment(t_FuelTanks,Rnd(5,10),1,People);",
                        "        AddItemToShip(tranc,tdwd);",
                        "        ItemIsInUse(tdwd,tranc,1);",
                        "        NoDropItem(tdwd);",
                        "        tdwd = CreateEquipment(t_Radar,Rnd(7,15),8,People);",
                        "        AddItemToShip(Player(),tdwd);",
                        "        ItemIsInUse(tdwd,Player(),1);",
                        "        NoDropItem(tdwd);",
                        "        tdwd = CreateEquipment(t_Engine,Rnd(15,20),8,People);",
                        "        AddItemToShip(Player(),tdwd);",
                        "        ItemIsInUse(tdwd,Player(),1);",
                        "        NoDropItem(tdwd);",
                        "        tdwd = CreateEquipment(t_Scaner,Rnd(5,10),1,People);",
                        "        AddItemToShip(Player(),tdwd);",
                        "        ItemIsInUse(tdwd,Player(),1);",
                        "        NoDropItem(tdwd);",
                        "        tdwd = CreateEquipment(t_RepairRobot,Rnd(5,10),8,People);",
                        "        AddItemToShip(Player(),tdwd);",
                        "        ItemIsInUse(tdwd,Player(),1);",
                        "        NoDropItem(tdwd);",
                        "        tdwd = CreateEquipment(t_DefGenerator,Rnd(5,10),8,People);",
                        "        AddItemToShip(Player(),tdwd);",
                        "        ItemIsInUse(tdwd,Player(),1);",
                        "        NoDropItem(tdwd);",
                        "        tdwd = CreateCustomWeapon('YamatoMinigun3',Rnd(5,10),8,People);",
                        "        AddItemToShip(Player(),tdwd);",
                        "        ItemIsInUse(tdwd,Player(),1);",
                        "        NoDropItem(tdwd);",
                        "        tdwd = CreateCustomWeapon('YamatoMinigun3',Rnd(5,10),8,People);",
                        "        AddItemToShip(Player(),tdwd);",
                        "        ItemIsInUse(tdwd,Player(),1);",
                        "        NoDropItem(tdwd);",
                        "        tdwd = CreateCustomWeapon('YamatoMinigun3',Rnd(5,10),8,People);",
                        "        AddItemToShip(Player(),tdwd);",
                        "        ItemIsInUse(tdwd,Player(),1);",
                        "        NoDropItem(tdwd);",
                        "",
                        "        ShipSkill(tranc,0,6);",
                        "        ShipSkill(tranc,1,6);",
                        "",
                        "        HullSpecial(tranc,FindBonusByCustomTag('Yamato_GoodResis'));",
                        "    }",
                        "",
                        "    //Переносим транка и отправляем его в скриптогруппу",
                        "    TransferShip(tranc,Player());",
                        "    OrderTakeOff(tranc);",
                        "    ShipJoin('GroupSturmer',tranc);",
                        "    ShipFace(tranc,99);",
                        "    ShipType(tranc, 'Sturmer');",
                        "",
                        "    //Чтобы точно не умел никуда улетать",
                        "    ShipSpecialBonuses(tranc,bonFuel,-5000000);",
                        "",
                        "    SetName(tranc,CT('Script.Yamato.SturmerName'));",
                        "}",
                        "bad_special_name = CT('Script.Yamato.Settings.bad_special_name');",
                        "good_special_name = CT('Script.Yamato.Settings.good_special_name');",
                        "",
                        "cost = CT('Script.Yamato.Settings.cost');",
                        "upgrade_cost = CT('Script.Yamato.Settings.upgrade_cost');",
                        "cost_sponsor = CT('Script.Yamato.Settings.cost_sponsor');",
                        "cost_museum = CT('Script.Yamato.Settings.cost_museum');",
                        "hull_cost_1 = CT('Script.Yamato.Settings.hull_cost_1');",
                        "hull_cost_2 = CT('Script.Yamato.Settings.hull_cost_2');",
                        "",
                        "research_time_slow = CT('Script.Yamato.Settings.research_time_slow');",
                        "research_time_fast = CT('Script.Yamato.Settings.research_time_fast');",
                        "",
                        "item_size = CT('Script.Yamato.Settings.item_size');",
                        "hull_size_bad= CT('Script.Yamato.Settings.hull_size_bad');",
                        "hull_size_good = CT('Script.Yamato.Settings.hull_size_good');",
                        "",
                        "",
                        "dword quest_item = CreateQuestItem('Cat_Yamato_Destroyed', People);",
                        "ItemSize(quest_item, Rnd(0.5 * item_size, 1.5 * item_size));",
                        "LinkItemToScript(quest_item, ShipFragment);",
                        "",
                        "dword star = StarNearbyStars(ShipStar(Player()), Rnd(25, 35));",
                        "int i = 0;",
                        "for (i = 0; i < StarPlanets(star); i = i + 1) {",
                        "    if (PlanetOwner(StarPlanets(star, i)) == None) {",
                        "        AddItemToPlanet(StarPlanets(star, i), quest_item);",
                        "        break;",
                        "    }",
                        "}"
                    ],
                    "#": 38,
                    "Type": "Top",
                    "Parent": -1,
                    "Pos.x": 60,
                    "Pos.y": 760
                },
                {
                    "Name": "",
                    "Code.Type": "Turn",
                    "Code": [
                        "if(state == 1) {",
                        "  if(CurTurn() >= research_start_date + research_time) {",
                        "    if(IdToShip(base_id)) {",
                        "      Ether(0, '', Format(CT(\"Script.Yamato.187\"),\"<0>\",base_name));",
                        "      state = 2;",
                        "    }",
                        "  }",
                        "  if(!IdToShip(base_id)) {",
                        "    Ether(0, '', Format(CT(\"Script.Yamato.159\"),\"<0>\",base_name));",
                        "    state = -1;",
                        "  }",
                        "}"
                    ],
                    "#": 39,
                    "Type": "Top",
                    "Parent": -1,
                    "Pos.x": 120,
                    "Pos.y": 760
                },
                {
                    "Name": "",
                    "Code.Type": "DialogBegin",
                    "Code": [
                        "if(PlayerBridge() == 3) {",
                        "  if(EqSpecial(ShipEqInSlot(Player(),t_Hull)) == FindBonusByNameInCfg('Cat_Yamato_Upgraded') && Costyl && ~EqSpecial(Player())) {",
                        "      AddDialogInject('Yamato_Settings','',CT(\"Script.Yamato.191\"),1000);",
                        "  }",
                        "}",
                        "if(GetShipRuins(Player()) && Costyl && EqSpecial(ShipEqInSlot(Player(),t_Hull)) == FindBonusByNameInCfg('Cat_Yamato_Upgraded') && SturmerLvL < 3) {",
                        "  if(ShipType(GetShipRuins(Player())) == 'TC') {",
                        "      if((SturmerLvL == 1 && GalaxyTechLevel() > 5) || (SturmerLvL == 2 && GalaxyTechLevel() > 7)) {",
                        "          AddDialogInject('Yamato_SturmersUpgrade','',CT(\"Script.Yamato.202\"),1000);",
                        "      }",
                        "  }",
                        "}",
                        "if(!PlayerBridge()) {",
                        "  if(GetShipRuins(Player())) {",
                        "    if(state == 0) {",
                        "      if(ItemExist(ShipFragment)) {",
                        "        if(ItemIn(ShipFragment, Player())) {",
                        "          if(ShipType(GetShipRuins(Player())) == 'WB') {",
                        "            AddDialogInject('DialogWB1', '', CT(\"Script.Yamato.190\"), 1);",
                        "          }",
                        "          if(ShipType(GetShipRuins(Player())) != 'WB') {",
                        "            AddDialogInject('WrongBase1', '', CT(\"Script.Yamato.189\"), 1);",
                        "          }",
                        "        }",
                        "      }",
                        "    }",
                        "    if(state == 1) {",
                        "      if(Id(GetShipRuins(Player())) == base_id) {",
                        "        AddDialogInject('DialogWB1.5', '', CT(\"Script.Yamato.188\"), 1);",
                        "      }",
                        "      if(Id(GetShipRuins(Player())) != base_id) {",
                        "        if(ShipType(GetShipRuins(Player())) == 'WB') {",
                        "          AddDialogInject('WrongBase1.5', '', CT(\"Script.Yamato.188\"), 1);",
                        "        }",
                        "      }",
                        "    }",
                        "    if(state == 2) {",
                        "      if(Id(GetShipRuins(Player())) == base_id) {",
                        "        AddDialogInject('DialogWB2', '', CT(\"Script.Yamato.188\"), 1);",
                        "      }",
                        "      if(Id(GetShipRuins(Player())) != base_id) {",
                        "        if(ShipType(GetShipRuins(Player())) == 'WB') {",
                        "          AddDialogInject('WrongBase2', '', CT(\"Script.Yamato.188\"), 1);",
                        "        }",
                        "      }",
                        "    }",
                        "    if(state == 3) {",
                        "      if(Id(GetShipRuins(Player())) == base_id) {",
                        "        AddDialogInject('DialogWB3', '', CT(\"Script.Yamato.79\"), 1);",
                        "      }",
                        "      if(Id(GetShipRuins(Player())) != base_id) {",
                        "        if(ShipType(GetShipRuins(Player())) == 'WB') {",
                        "          AddDialogInject('WrongBase3', '', CT(\"Script.Yamato.79\"), 1);",
                        "        }",
                        "      }",
                        "    }",
                        "    if(state == 4) {",
                        "      if(ItemExist(hull_bad)) {",
                        "        if(ItemIn(hull_bad, Player())) {",
                        "          if(ShipType(GetShipRuins(Player())) == 'TC') {",
                        "            AddDialogInject('TCUpgrade', '', CT(\"Script.Yamato.122\"), 1);",
                        "          }",
                        "        }",
                        "      }",
                        "    }",
                        "  }",
                        "}"
                    ],
                    "#": 40,
                    "Type": "Top",
                    "Parent": -1,
                    "Pos.x": 180,
                    "Pos.y": 760
                },
                {
                    "Name": "",
                    "Code.Type": "Turn",
                    "Code": [
                        "coun = 0;",
                        "",
                        "for(i=0;StarShips(ShipStar(CurShip))>i;i=i+1) {",
                        "    if(RelationToRanger(StarShips(ShipStar(CurShip),i),Player()) < 10) coun = coun + 1;",
                        "}",
                        "ChangeState(2);",
                        "exit;"
                    ],
