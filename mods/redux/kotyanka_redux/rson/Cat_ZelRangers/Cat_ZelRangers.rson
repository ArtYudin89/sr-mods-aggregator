                    "Type": "TDialogMsg",
                    "Parent": -1,
                    "#": 61,
                    "Msg": "Нашим специалистом по улучшению оборудования является <0>.",
                    "DMsg.Num": "11",
                    "_orig_dtext": "DText(Format(CT(\"Script.Cat_ZelRangers.30\"),\"<0>\",StrLvlUpgrade[LvlUpgrade-1]))"
                },
                {
                    "Name": "",
                    "Pos.x": 0,
                    "Pos.y": 520,
                    "Type": "TDialogMsg",
                    "Parent": -1,
                    "#": 62,
                    "Msg": "В параметры корабля рейнджера входит:\r\n1. Размер корпуса\r\n2. Акрин корпуса\r\n3. Уровень экипировки",
                    "DMsg.Num": "12",
                    "_orig_dtext": "DText(CT(\"Script.Cat_ZelRangers.31\"))"
                },
                {
                    "Name": "",
                    "Pos.x": 150,
