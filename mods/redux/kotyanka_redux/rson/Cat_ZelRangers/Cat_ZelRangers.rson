                    "Type": "TDialogMsg",
                    "Parent": -1,
                    "#": 63,
                    "Msg": "Этот класс рейнджеров получит <0>.",
                    "DMsg.Num": "13",
                    "_orig_dtext": "DText(Format(CT(\"Script.Cat_ZelRangers.32\"),\"<0>\",StrLvlHullSize[LvlHullSize[current_ranger]-1]))"
                },
                {
