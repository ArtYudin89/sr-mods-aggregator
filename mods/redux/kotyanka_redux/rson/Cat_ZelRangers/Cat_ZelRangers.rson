                        "StrLvlUpgrade[2] = CT(\"Script.Cat_ZelRangers.188\");",
                        "StrLvlUpgrade[3] = CT(\"Script.Cat_ZelRangers.187\");",
                        "StrLvlUpgrade[4] = CT(\"Script.Cat_ZelRangers.160\");",
                        "",
                        "StrLvlHullSize = newarray(5);",
