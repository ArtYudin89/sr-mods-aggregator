                        "StrNItems[4] = CT(\"Script.Cat_ZelRangers.208\");",
                        "",
                        "StrLvlSkills = newarray(5);",
                        "StrLvlSkills[0] = CT(\"Script.Cat_ZelRangers.207\");",
                        "StrLvlSkills[1] = CT(\"Script.Cat_ZelRangers.213\");",
                        "StrLvlSkills[2] = CT(\"Script.Cat_ZelRangers.212\");",
                        "StrLvlSkills[3] = CT(\"Script.Cat_ZelRangers.165\");",
