                    "Pos.y": 300,
                    "Parent": -1,
                    "#": 42
                }
            ],
            "Items": [],
            "Operations": [
                {
                    "Name": "",
                    "Code.Type": "Global",
                    "Code": [
                        "GRun();",
                        "//Описание некоторых переменных:",
                        "//branch - номер ветки улучшения (вне диалога не имеет смысла)",
                        "//Общие улучшения:",
                        "//    0 - количество кораблей",
                        "//    1 - частота постройки",
                        "//    2 - количество оборудки",
                        "//    3 - качество обучения",
                        "//    4 - качество оборудки",
                        "//Улучшение конкретного рейнджера",
                        "//    5 - размер корпуса",
                        "//    6 - качество акрина",
                        "//    7 - качество оборудки",
                        "//",
                        "//Переменные состояния скрипта:",
                        "//    Общие улучшения:",
                        "//        -0- NRangers",
                        "//        -1- LvlFreq",
                        "//        -2- NItem",
                        "//        -3- LvlSkills",
                        "//        -4- LvlUpgrade",
                        "//",
                        "//    Массивы улучшений для 5 рейнджеров:",
                        "//        -5- LvlHullSize[5]",
                        "//        -6- LvlHullAcrin[5]",
                        "//        -7- LvlEq[5]",
                        "//",
                        "//    money[5] - начальный капитал рейнджеров, увеличивается при каждом улучшении",
                        "//    cost_multiplier - множитель стоимости улучшений, увеличивается при каждом улучшении",
                        "//    accepted - принял ли игрок предложение",
                        "//        0 - нет (показывается диалог предложения)",
                        "//        1 - да (показывается диалог улучшения)",
                        "//    buy_date - дата следующей постройки кораблей",
                        "//",
                        "//",
                        "//Переменные для диалогового блока (вне диалога не имеют смысла):",
                        "//    branch",
                        "//    current_ranger",
                        "//    branch_level - уровень улучшения текущей ветви",
                        "//",
                        "//Константы:",
                        "//    branch_money_bonus[8] - бонус к капиталу от каждого улучшения",
                        "//    branch_cost[8] - множитель стоимости каждого улучшения",
                        "//    branch_cost_multiplier_inc[8] - приращение cost_multiplier при каждом улучшении;"
                    ],
                    "#": 43,
                    "Type": "Top",
                    "Parent": -1,
                    "Pos.x": 0,
                    "Pos.y": 685
                },
                {
                    "Name": "",
                    "Code.Type": "Init",
                    "Code": [
                        "// Функция создания рейнджера и изменения его характеристик",
                        "// rc - ЦР, на котором появится рейнджер",
                        "// n - его номер (n=0,1,2,3,4)",
                        "function BuyNewRanger(rc, n) {",
                        "    ship = BuyRanger(StarPlanets(ShipStar(rc), Rnd(0, StarPlanets(ShipStar(rc)) - 1)), money[n]);",
                        "",
                        "    str tstr;",
                        "",
                        "    if (prob(0.25)) {",
                        "        random = Rnd(Maloc, Gaal);",
                        "        ShipPilotRace(ship, random);",
                        "        ShipOwner(ship, random);",
                        "        ItemOwner(ShipItems(ship, 0), random);",
                        "        Chameleon(ship);",
                        "    }",
                        "",
                        "    // Обработка корпуса Таухито ()",
                        "    //if (Chameleon(ship, 'GraphName') == 'Ship.People.RangerOldFag') {",
                        "        //ItemOwner(ShipItems(ship, 0), None);",
                        "        //ShipPilotRace(ship, Maloc); //choice5(1,Maloc,1,Peleng,0,People,1,Fei,1,Gaal));",
                        "        //SFT('!' + Chameleon(ship, 'GraphName'));",
                        "        //Chameleon(ship, 'Ship.Maloc.Ranger');",
                        "        //HullSeries(ShipItems(ship, 0), 80);",
                        "        //SFT('!! ' + Chameleon(ship, 'GraphName'));",
                        "        //SFT('!! ' + HullSeries(ShipItems(ship, 0)));",
                        "    //}",
                        "",
                        "    // Даем корпус с нужными параметрами",
                        "    ItemSize(ShipItems(ship, 0), Rnd(0.75 * HullSize(n), 1.25 * HullSize(n)));",
                        "    power = RandomAcrynPower(LvlHullAcrin[n]); //сила акрина от 0 (нет акрина) до 4 (уникальный акрин)",
                        "    //if (test) power = 4;",
                        "    if (power != 0) {",
                        "        acryn = RandomAcryn(power, ship, ShipOwner(ship));",
                        "",
                        "        //if (power == 1) {}",
                        "        //if (power == 2) {}",
                        "        //if (power == 3) {}",
                        "        if(power == 4) {",
                        "            admirals_cnt = admirals_cnt + 1;",
                        "            ShipMoney(ship, round(6.0 * ShipMoney(ship))); // Повышаем капитал в 6.0 раз",
                        "            while (ShipRank(ship) < 7) { // Повышаем звание до Адмирала",
                        "                ShipRankPoints(ship, ShipNextRankPoints(ship));",
                        "                ShipRaiseRank(ship);",
                        "            }",
                        "            ItemSize(ShipItems(ship, 0), round(1.3 * ItemSize(ShipItems(ship, 0)))); // Увеличиваем корпус на 20%",
                        "",
                        "            tstr = Format(CT('Script.Cat_ZelRangers.AdmiralNews.'+Rnd(1,CT('Script.Cat_ZelRangers.AdmiralNews.Count'))),'name',ShortName(ship));",
                        "            AddPlanetNews(tstr);",
                        "",
                        "            NewsAdd(tstr);",
                        "            Sound('Sound.NewMsg');",
                        "",
                        "            ShipSubType(ship,2);",
                        "",
                        "            if(Rnd(1,3) == 3) {",
                        "                //Наш адмирал - грозный борец с пиратством",
                        "                int y1 = Rnd(150,300);",
                        "                int y2 = Rnd(20,35);",
                        "                int y4 = Rnd(20,50);",
                        "                ShipStatistic(ship,1,y1);",
                        "                ShipStatistic(ship,2,y2);",
                        "                ShipStatistic(ship,3,Rnd(8,15));",
                        "                ShipStatistic(ship,8,y4);",
                        "            }",
                        "            else {",
                        "                //А этот адмирал - среднестатистический борец с жомиками",
                        "                y1 = Rnd(30,50);",
                        "                y2 = Rnd(200,500);",
                        "                y4 = Rnd(20,50);",
                        "                ShipStatistic(ship,1,y1);",
                        "                ShipStatistic(ship,2,y2);",
                        "                ShipStatistic(ship,3,Rnd(8,15));",
                        "                ShipStatistic(ship,8,y4);",
                        "            }",
                        "            ShipStatistic(ship,0,ShipStatistic(ship,0)+y1+y2+y4);",
                        "            SetShipExpByType(ship,Rnd(300000,400000),0);",
                        "",
                        "            //Спецбонусы по просьбе заказчика :)",
                        "            ShipSpecialBonuses(ship,bonWEnergy,ShipSpecialBonuses(ship,bonWEnergy)+CT('Script.Cat_ZelRangers.AdmiralBuffs.Energy'));",
                        "            ShipSpecialBonuses(ship,bonWSplinter,ShipSpecialBonuses(ship,bonWSplinter)+CT('Script.Cat_ZelRangers.AdmiralBuffs.Splinter'));",
                        "            ShipSpecialBonuses(ship,bonWMissile,ShipSpecialBonuses(ship,bonWMissile)+CT('Script.Cat_ZelRangers.AdmiralBuffs.Missile'));",
                        "            ShipSpecialBonuses(ship,bonWRadius,ShipSpecialBonuses(ship,bonWRadius)+CT('Script.Cat_ZelRangers.AdmiralBuffs.WRadius'));",
                        "            ShipSpecialBonuses(ship,bonMissileSpeed,ShipSpecialBonuses(ship,bonMissileSpeed)+CT('Script.Cat_ZelRangers.AdmiralBuffs.MiSpeed'));",
                        "            ShipSpecialBonuses(ship,bonAttacks,ShipSpecialBonuses(ship,bonAttacks)+CT('Script.Cat_ZelRangers.AdmiralBuffs.Attacks'));",
                        "",
                        "            ShipSpecialBonuses(ship,bonHull,ShipSpecialBonuses(ship,bonHull)+CT('Script.Cat_ZelRangers.AdmiralBuffs.Armor'));",
                        "            ShipSpecialBonuses(ship,bonDef,ShipSpecialBonuses(ship,bonDef)+CT('Script.Cat_ZelRangers.AdmiralBuffs.Def'));",
                        "            ShipSpecialBonuses(ship,bonDroid,ShipSpecialBonuses(ship,bonDroid)+CT('Script.Cat_ZelRangers.AdmiralBuffs.Droid'));",
                        "",
                        "            ShipSpecialBonuses(ship,bonSpeed,ShipSpecialBonuses(ship,bonSpeed)+CT('Script.Cat_ZelRangers.AdmiralBuffs.Speed'));",
                        "        }",
                        "",
                        "        // Навешиваем акрин на корпус",
                        "        if(acryn != -1 && acryn != 0) {",
                        "            SpecialToEquipment(acryn, ShipItems(ship, 0));",
                        "        }",
                        "    }",
                        "    HullHP(ship, ItemSize(ShipItems(ship, 0)));",
                        "    Chameleon(ship);",
                        "",
                        "    if(HullSeries(ShipEqInSlot(ship,t_Hull)) == 'HullOldfag') {",
                        "        HullSeries(ShipEqInSlot(ship,t_Hull),-1);",
                        "        HullSeries(ShipEqInSlot(ship,t_Hull),99);",
                        "    }",
                        "",
                        "    // Удаляем всю оборудку",
                        "    for (i = ShipItems(ship) - 1; i > 0; i = i - 1) FreeItem(GetItemFromShip(ship, i));",
                        "",
                        "    // Даем новую оборудку",
                        "    GiveAllEq(ship, LvlEq[n], toDiap(NItems + (power == 4), 1, 5));",
                        "    ArrangeItems(ship);",
                        "",
                        "    // Улучшаем и тренируем рейнджера в соответствии с общими улучшениями отраслей",
                        "    UpgradeShip(ship, toDiap(LvlUpgrade + (power == 4), 1, 5));",
                        "    TrainShip(ship, toDiap(LvlSkills + (power == 4), 1, 5));",
                        "    /*int k = 0;",
                        "    if(LvlUpgrade == 1) k = 4;",
                        "    if(LvlUpgrade == 2) k = 6;",
                        "    if(LvlUpgrade == 3) k = 8;",
                        "    if(LvlUpgrade == 4) k = 10;",
                        "    if(LvlUpgrade == 5) k = 8;",
                        "",
                        "    for(i=0;i<k;i=i+1) {",
                        "        AcrynEquip(ship);",
                        "    }*/",
                        "",
                        "    ShipRefit(ship); //рефитаем после выдачи и улучшения оборудки",
                        "    for(i=0;ShipItems(ship)>i;i=i+1) {",
                        "        if(!ItemIsInUse(ShipItems(ship,i))) continue;",
                        "        if(ItemType(ShipItems(ship,i)) < t_Hull) continue;",
                        "",
                        "        if(ItemLevel(ShipItems(ship,i)) < GalaxyTechLevel() - 1) ItemLevel(ShipItems(ship,i),max(1,GalaxyTechLevel() - Rnd(0,2)));",
                        "    }",
                        "    for(i=0;ShipItems(ship)>i;i=i+1) {",
                        "        if(!ItemIsInUse(ShipItems(ship,i))) continue;",
                        "        if(ItemType(ShipItems(ship,i)) < t_Hull) continue;",
                        "",
                        "        if(ItemLevel(ShipItems(ship,i)) < GalaxyTechLevel() - 1) ItemLevel(ShipItems(ship,i),max(1,GalaxyTechLevel() - Rnd(0,2)));",
                        "    }",
                        "    for(i=0;ShipItems(ship)>i;i=i+1) {",
                        "        if(!ItemIsInUse(ShipItems(ship,i))) continue;",
                        "        if(ItemType(ShipItems(ship,i)) < t_Hull) continue;",
                        "",
                        "        if(ItemLevel(ShipItems(ship,i)) < GalaxyTechLevel() - 1) ItemLevel(ShipItems(ship,i),max(1,GalaxyTechLevel() - Rnd(0,2)));",
                        "    }",
                        "    for(i=0;ShipItems(ship)>i;i=i+1) {",
                        "        if(!ItemIsInUse(ShipItems(ship,i))) continue;",
                        "        if(ItemType(ShipItems(ship,i)) < t_Hull) continue;",
                        "",
                        "        if(ItemLevel(ShipItems(ship,i)) < GalaxyTechLevel() - 1) ItemLevel(ShipItems(ship,i),max(1,GalaxyTechLevel() - Rnd(0,2)));",
                        "    }",
                        "",
                        "    if(NItems == 5) {",
                        "        for(i=0;ShipSlots(ship,2)>i;i=i+1) {",
                        "            if(ShipEqInSlot(ship,t_Artefact,i)) continue;",
                        "            if(Rnd(1,5) == 5) {",
                        "                dword arte=CreateArt(Rnd(t_ArtefactHull,t_ArtFastRacks),ShipPilotRace(ship));",
                        "                if(ItemType(arte) == t_ArtefactTransmitter) arte=CreateArt(t_ArtefactHull,ShipPilotRace(ship));",
                        "                if(ItemType(arte) == t_ArtefactBomb) arte=CreateArt(t_ArtefactSpeed,ShipPilotRace(ship));",
                        "                if(ItemType(arte) == t_ArtefactTranclucator) arte=CreateArt(t_ArtPDTurret,ShipPilotRace(ship));",
                        "                if(ItemType(arte) == t_ArtBlackHole) arte=CreateArt(t_ArtefactAntigrav,ShipPilotRace(ship));",
                        "                if(ItemType(arte) == t_ArtDefToArms1) arte=CreateArt(t_ArtefactDroid,ShipPilotRace(ship));",
                        "                if(ItemType(arte) == t_ArtDefToArms2) arte=CreateArt(t_ArtefactNano,ShipPilotRace(ship));",
                        "                if(ItemType(arte) == t_ArtWeaponToSpeed) arte=CreateArt(t_ArtEnergyDef,ShipPilotRace(ship));",
                        "                if(ItemType(arte) == t_ArtArtefactor) arte=CreateArt(t_ArtForsage,ShipPilotRace(ship));",
                        "                ItemDurability(arte,100);",
                        "                NoDropItem(arte,1);",
                        "                AddItemToShip(ship,arte);",
                        "                ItemIsInUse(arte,ship,1);",
                        "            }",
                        "        }",
                        "    }",
                        "",
                        "    // Перемещаем рейнджера в ЦР",
                        "    TransferShip(ship, rc);",
                        "}",
                        "// Возвращает силу акрина в зависимости от уровня улучшения акрина рейнджера",
                        "function RandomAcrynPower(lvl) {",
                        "    if (lvl == 1) {",
                        "        result = choice5(",
                        "            0.800, 0,",
                        "            0.170, 1,",
                        "            0.027, 2,",
                        "            0.003, 3,",
                        "            0.000 * exp(-0.7 * admirals_cnt), 4",
                        "        );",
                        "    }",
                        "    if (lvl == 2) {",
                        "        result = choice5(",
                        "            0.400, 0,",
                        "            0.500, 1,",
                        "            0.090, 2,",
                        "            0.010, 3,",
                        "            0.001 * exp(-0.7 * admirals_cnt), 4",
                        "        );",
                        "    }",
                        "    if (lvl == 3) {",
                        "        result = choice5(",
                        "            0.050, 0,",
                        "            0.650, 1,",
                        "            0.250, 2,",
                        "            0.050, 3,",
                        "            0.003 * exp(-0.7 * admirals_cnt), 4",
                        "        );",
                        "    }",
                        "    if (lvl == 4) {",
                        "    result = choice5(",
                        "            0.010, 0,",
                        "            0.400, 1,",
                        "            0.400, 2,",
                        "            0.200, 3,",
                        "            0.006 * exp(-0.7 * admirals_cnt), 4",
                        "        );",
                        "    }",
                        "    if (lvl == 5) {",
                        "        result = choice5(",
                        "            0.001, 0,",
                        "            0.009, 1,",
                        "            0.500, 2,",
                        "            0.400, 3,",
                        "            0.050 * exp(-0.7 * admirals_cnt), 4",
                        "        );",
                        "    }",
                        "}",
                        "",
                        "// Возвращает случайный акрин по силе и расе",
                        "function RandomAcryn(power, ship, race) {",
                        "    result = -1;",
                        "    cnt = 0; // Количество бросков номера. При cnt > 100 цикл завершается",
                        "",
                        "    // Есть 4 категории акринов:",
                        "    //    1 - слабые",
                        "    //    2 - средние",
                        "    //    3 - сильные",
                        "    //    4 - уникальные (вероятность порядка 1%) (получают доп. бонусы)",
                        "",
                        "    // if ((random == <rndid>) && prob(0.20) && (race == Maloc || race == Gaal) && (race != People)) result = FindBonusByName(<str>);",
                        "    //     prob(0.20) - верно с вероятностью 20%",
                        "    //     (race == Maloc || race == Gaal) && (race != People) - условия на расы",
                        "    //     FindBonusByName(<str>); - поиск по имени",
                        "    //     FindBonusByCustomTag(<str>); - поиск по тегу",
                        "    //     FindBonusByNameInCfg(<str>); - поиск по имени раздела в ланге",
                        "    //     если использовать тот же <rndid>, то бонус перезапишется (если вероятность не снижена)",
                        "    while (result == -1 || result == 0) {",
                        "        cnt = cnt + 1;",
                        "        if (cnt > 100) break;",
                        "",
                        "        if (power == 1) {",
                        "            random = Rnd(1, 34);",
                        "            if ((random == 1)) result = FindBonusByNameInCfg('353'); //Быстрый корпус I",
                        "            if ((random == 2)) result = FindBonusByNameInCfg('357'); //Неуязвимый корпус I",
                        "            if ((random == 3)) result = FindBonusByNameInCfg('361'); //Ремонтный корпус I",
                        "            if ((random == 4)) result = FindBonusByNameInCfg('365'); //Миоплазменный корпус I",
                        "            if ((random == 5)) result = FindBonusByNameInCfg('369'); //Пигамарный корпус I",
                        "            if ((random == 6)) result = FindBonusByNameInCfg('472'); //Корпус \"Молния\" I",
                        "            if ((random == 7)) result = FindBonusByNameInCfg('476'); //Корпус \"Броненосец\" I",
                        "            if ((random == 8) && (race == Gaal)) result = FindBonusByNameInCfg('468'); //Корпус \"Честный ренегал\" I",
                        "            if ((random == 9) && (race == Peleng)) result = FindBonusByNameInCfg('460'); //Корпус \"Добрый лякуша\" I",
                        "            if ((random == 10) && (race == People)) result = FindBonusByNameInCfg('464'); //Корпус \"Мирный корсар\" I",
                        "            if ((random == 11) && (race == People)) result = FindBonusByNameInCfg('480'); //Корпус \"Ушастик\" I",
                        "            if ((random == 12)) result = FindBonusByNameInCfg('352'); // Болид",
                        "",
                        "            if ((random == 13) && prob(0.33)) result = FindBonusByCustomTag('LEOContentMod_Giperion_1_Hull'); // Гиперион I",
                        "            if ((random == 14)) result = FindBonusByCustomTag('LEOLastHulls_G2_Hull'); // Черный призрак",
                        "            if ((random == 15)) result = FindBonusByCustomTag('LEOLastHulls_G5_Hull'); // Цербер",
                        "",
                        "            if ((random == 16) && (race == Peleng)) result = FindBonusByName('Ара' + ' I');",
                        "            if ((random == 17) && (race == People || race == Maloc)) result = FindBonusByName('Бамберга' + ' I');",
                        "            if ((random == 18) && (race == Maloc)) result = FindBonusByName('Кабан' + ' I');",
                        "            if ((random == 19) && (race == Fei)) result = FindBonusByName('Ястреб' + ' I');",
                        "            if ((random == 20) && (race == Gaal)) result = FindBonusByName('Пантера' + ' I');",
                        "            if ((random == 21) && (race == People || race == Peleng)) result = FindBonusByName('Акулёнок' + ' I');",
                        "            if ((random == 22) && (race == Maloc)) result = FindBonusByNameInCfg('EvoGkvan_GkvanHull');",
                        "            if ((random == 23) && (race == Fei)) result = FindBonusByNameInCfg('Cat_Ships_Shegramer');",
                        "            if ((random == 24) && (race == People)) result = FindBonusByNameInCfg('Cat_Ships_Vyhr');",
                        "            if ((random == 25) && (race == Peleng)) result = FindBonusByNameInCfg('Cat_Ships_Beshraflac');",
                        "            if ((random == 26) && (race == Fei)) result = FindBonusByNameInCfg('Cat_Ships_Ellentanda');",
                        "            if ((random == 27)) result = FindBonusByNameInCfg('Cat_Ships_Bongrabar');",
                        "            if ((random == 28) && (race == Peleng)) result = FindBonusByNameInCfg('Cat_Ships_Chipshush');",
                        "            if ((random == 29)) result = FindBonusByNameInCfg('Cat_Ships_Sharcun');",
                        "            if ((random == 30) && (race == People)) result = FindBonusByNameInCfg('Cat_Ships_Horizont');",
                        "            if ((random == 31) && (race == People)) result = FindBonusByNameInCfg('Cat_Ships_Trackvagn');",
                        "            if ((random == 32) && (race == Maloc)) result = FindBonusByNameInCfg('Cat_Ships_Mishravec');",
                        "            if ((random == 33) && (race == People || race == Fei)) result = FindBonusByName('Cat_Ships_Unsorted_Transport');",
                        "            if ((random == 34) && (race == People)) result = FindBonusByNameInCfg('Cat_Ships_StarShip');",
                        "",
                        "        }",
                        "",
                        "        if (power == 2) {",
                        "            random = Rnd(1, 35);",
                        "            if ((random == 1)) result = FindBonusByNameInCfg('354'); //Быстрый корпус II",
                        "            if ((random == 2)) result = FindBonusByNameInCfg('358'); //Неуязвимый корпус II",
                        "            if ((random == 3)) result = FindBonusByNameInCfg('362'); //Ремонтный корпус II",
                        "            if ((random == 4)) result = FindBonusByNameInCfg('366'); //Миоплазменный корпус II",
                        "            if ((random == 5)) result = FindBonusByNameInCfg('370'); //Пигамарный корпус II",
                        "            if ((random == 6)) result = FindBonusByNameInCfg('473'); //Корпус \"Молния\" II",
                        "            if ((random == 7)) result = FindBonusByNameInCfg('477'); //Корпус \"Броненосец\" II",
                        "            if ((random == 8) && (race == Gaal)) result = FindBonusByNameInCfg('469'); //Корпус \"Честный ренегал\" II",
                        "            if ((random == 9) && (race == Peleng)) result = FindBonusByNameInCfg('461'); //Корпус \"Добрый лякуша\" II",
                        "            if ((random == 10) && (race == People)) result = FindBonusByNameInCfg('465'); //Корпус \"Мирный корсар\" II",
                        "            if ((random == 11) && (race == People)) result = FindBonusByNameInCfg('481'); //Корпус \"Ушастик\" II",
                        "            if ((random == 12)) result = FindBonusByNameInCfg('351'); // Скала",
                        "",
                        "",
                        "            if ((random == 13) && prob(0.33)) result = FindBonusByCustomTag('LEOContentMod_Giperion_2_Hull'); // Гиперион II",
                        "            if ((random == 14) && prob(0.33)) result = FindBonusByCustomTag('LEOContentMod_Giperion_3_Hull'); // Гиперион III",
                        "            if ((random == 15)) result = FindBonusByCustomTag('LEOLastHulls_G1_Hull'); // Горизонт",
                        "",
                        "            if ((random == 16) && (race == Peleng)) result = FindBonusByName('Ара' + ' II');",
                        "            if ((random == 17) && (race == People || race == Maloc)) result = FindBonusByName('Бамберга' + ' II');",
                        "            if ((random == 18) && (race == Maloc)) result = FindBonusByName('Кабан' + ' II');",
                        "            if ((random == 19) && (race == Fei)) result = FindBonusByName('Ястреб' + ' II');",
