                        "StrLvlEq[1] = CT(\"Script.Cat_ZelRangers.175\");",
                        "StrLvlEq[2] = CT(\"Script.Cat_ZelRangers.174\");",
                        "StrLvlEq[3] = CT(\"Script.Cat_ZelRangers.206\");",
