                        "StrLvlHullAcrin[0] = CT(\"Script.Cat_ZelRangers.181\");",
                        "StrLvlHullAcrin[1] = CT(\"Script.Cat_ZelRangers.180\");",
                        "StrLvlHullAcrin[2] = CT(\"Script.Cat_ZelRangers.179\");",
                        "StrLvlHullAcrin[3] = CT(\"Script.Cat_ZelRangers.178\");",
                        "StrLvlHullAcrin[4] = CT(\"Script.Cat_ZelRangers.177\");",
                        "",
                        "StrLvlEq = newarray(5);",
