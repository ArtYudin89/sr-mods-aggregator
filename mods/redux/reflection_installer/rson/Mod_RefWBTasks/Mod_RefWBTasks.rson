            "Operations": [
                {
                    "Name": "",
                    "Code.Type": "Global",
                    "Code": [
                        "GRun();"
                    ],
                    "#": 14,
                    "Type": "Top",
                    "Parent": -1,
                    "Pos.x": 0,
                    "Pos.y": 585
                },
                {
                    "Name": "",
                    "Code.Type": "Turn",
                    "Code": [
                        "if(DefSys) {",
                        "    if(ShipInNormalSpace(Player())) {",
                        "        if(ShipStar(Player()) == GalaxyStar(DefSys-1)) {",
                        "            WillBePaid = WillBePaid + daily;",
                        "            if(StarEnemyThreatLevel(GalaxyStar(DefSys-1),1) == 2) WillBePaid = WillBePaid + daily;",
                        "            Ether(3,'RefWBTask',CT(\"Script.Mod_RefWBTasks.2\")+' '+Name(GalaxyStar(DefSys-1))+' '+CT(\"Script.Mod_RefWBTasks.1\")+' '+WillBePaid+' '+CT(\"Script.Mod_RefWBTasks.0\"));",
                        "            int t;",
                        "            int achtung=0;",
                        "            if(!ShipIsTakeoff(Player())) {",
                        "                for(t=GalaxyEvents()-1; t>=0; t=t-1) {",
                        "                    if(GalaxyEventDate(t) < CurTurn()) break;",
                        "                    if(GalaxyEventType(t)=='PlayerKillsShip' || GalaxyEventType(t)=='PlayerAssistKillsShip') {",
                        "                        if(GalaxyEventsTextData(t,3) == 'PirateCorvette') WillBePaid = WillBePaid + shippy + shippy;",
                        "                        else if(GalaxyEventsTextData(t,3) == 'PirateFrigate') WillBePaid = WillBePaid + shippy + shippy + shippy;",
                        "                        else if(GalaxyEventsTextData(t,3) == 'PirateGalleon') WillBePaid = WillBePaid + shippy + shippy + shippy + shippy;",
                        "                        else if(GalaxyEventsTextData(t,3) == 'Klissan0') WillBePaid = WillBePaid + shippy + shippy + shippy + shippy + shippy;",
                        "                        else if(GalaxyEventsTextData(t,3) == 'Klissan1') WillBePaid = WillBePaid + shippy + shippy + shippy;",
                        "                        else if(GalaxyEventsTextData(t,3) == 'Klissan2') WillBePaid = WillBePaid + shippy + shippy;",
                        "                        else if(GalaxyEventsTextData(t,3) == 'Klissan3') WillBePaid = WillBePaid + shippy + shippy;",
                        "                        else if(GalaxyEventsTextData(t,3) == 'Klissan4') WillBePaid = WillBePaid + shippy;",
                        "                        else if(GalaxyEventsTextData(t,3) == 'Klissan5') WillBePaid = WillBePaid + shippy;",
                        "                        else if(GalaxyEventsTextData(t,3) == 'Neurolink') WillBePaid = WillBePaid + shippy + shippy + shippy + shippy;",
                        "                        else if(GalaxyEventsTextData(t,3) == 'Unknown') WillBePaid = WillBePaid + shippy;",
                        "                        else if(GalaxyEventData(t,3) == Pirate || GalaxyEventData(t,3) == None) WillBePaid = WillBePaid + shippy;",
                        "                        else if(GalaxyEventData(t,0) == t_Pirate) WillBePaid = WillBePaid + shippy;",
                        "                        else if(GalaxyEventData(t,0) == t_Kling && GalaxyEventData(t,5) == 0) WillBePaid = WillBePaid + shippy + shippy + shippy + shippy + shippy + shippy;",
                        "                        else if(GalaxyEventData(t,0) == t_Kling && GalaxyEventData(t,5) == 1) WillBePaid = WillBePaid + shippy + shippy + shippy;",
                        "                        else if(GalaxyEventData(t,0) == t_Kling && GalaxyEventData(t,5) == 2) WillBePaid = WillBePaid + shippy + shippy;",
                        "                        else if(GalaxyEventData(t,0) == t_Kling && GalaxyEventData(t,5) == 6) WillBePaid = WillBePaid + shippy + shippy + shippy + shippy + shippy;",
                        "                        else if(GalaxyEventData(t,0) == t_Kling && GalaxyEventData(t,5) > 2 && GalaxyEventData(t,5) != 2) WillBePaid = WillBePaid + shippy + shippy;",
                        "                        else achtung = 1;",
                        "            ",
                        "                        if(achtung) {",
                        "                            NewsAdd(CT(\"Script.Mod_RefWBTasks.3\"));",
                        "                            Ether(5,'RefWBTask','');",
                        "                            Sound('Sound.NewMsg');",
                        "                            DefSys = 0;",
                        "                            WillBePaid = 0;",
                        "                        }",
                        "                        else Ether(3,'RefWBTask',CT(\"Script.Mod_RefWBTasks.2\")+' '+Name(GalaxyStar(DefSys-1))+' '+CT(\"Script.Mod_RefWBTasks.1\")+' '+WillBePaid+' '+CT(\"Script.Mod_RefWBTasks.0\"));",
                        "                    }",
                        "                }",
                        "            }",
                        "        }",
                        "    }",
                        "    if(StarEnemyThreatLevel(GalaxyStar(DefSys-1),1) == 3) {",
                        "        NewsAdd(CT(\"Script.Mod_RefWBTasks.4\"));",
                        "        WillBePaid = WillBePaid / 2;",
                        "        Ether(5,'RefWBTask','');",
                        "        ShipMoney(Player(),ShipMoney(Player()) + WillBePaid);",
                        "        Sound('Sound.Buy');",
                        "        DefSys = 0;",
                        "        WillBePaid = 0;",
                        "    }",
                        "    if(ShipOnSidePirateClan(Player())) {",
                        "        NewsAdd(CT(\"Script.Mod_RefWBTasks.3\"));",
                        "        Ether(5,'RefWBTask','');",
                        "        Sound('Sound.NewMsg');",
                        "        DefSys = 0;",
                        "        WillBePaid = 0;",
                        "    }",
                        "}"
                    ],
                    "#": 15,
                    "Type": "Top",
                    "Parent": -1,
                    "Pos.x": 120,
                    "Pos.y": 585
                },
                {
                    "Name": "",
                    "Code.Type": "DialogBegin",
                    "Code": [
                        "if(GetShipRuins(Player())) {",
                        "    if(ShipType(GetShipRuins(Player())) == 'WB') {",
                        "        if(!DefSys) {",
                        "            if(!DomiksDefeated()) {",
                        "                AddDialogInject('WBTask',CT(\"Script.Mod_RefWBTasks.6\"),'',20);",
                        "            }",
                        "        }",
                        "        else {",
                        "            AddDialogInject('WBTaskEnd',CT(\"Script.Mod_RefWBTasks.5\"),'',20);",
                        "        }",
                        "    }",
                        "}"
                    ],
                    "#": 16,
                    "Type": "Top",
                    "Parent": -1,
                    "Pos.x": 180,
                    "Pos.y": 585
                },
                {
                    "Name": "",
                    "Code.Type": "Turn",
                    "Code": [
                        "if(ShipOnSidePirateClan(Player())) {",
                        "  DChange(0);",
                        "  exit;",
                        "}",
                        "if(!ShipOnSidePirateClan(Player())) {",
                        "  DChange(1);",
                        "  exit;",
                        "}"
                    ],
                    "#": 35,
                    "Type": "Top",
