                    "Code": [
                        "DAdd(6);",
                        "DAdd(7);"
                    ],
                    "#": 41,
                    "Type": "Top",
                    "Parent": -1,
                    "Pos.x": 580,
                    "Pos.y": 445
                },
                {
                    "Name": "",
                    "Code.Type": "Turn",
                    "Code": [
                        "DChange(2);",
                        "exit;"
                    ],
                    "#": 42,
                    "Type": "Top",
                    "Parent": -1,
                    "Pos.x": 100,
                    "Pos.y": 515
                },
                {
                    "Name": "",
                    "Code.Type": "Turn",
                    "Code": [
                        "for(i=0;GalaxyStars()>i;i=i+1) {",
                        "    star = StarNearbyStars(i);",
                        "    if(StarOwner(star) != 0) continue;",
                        "    if(round(sqrt(Dist2Star(star, ShipStar(Player())))) > 40) continue;",
                        "    coun = 0;",
                        "    for(j=0;StarShips(star)>j;j=j+1) {",
                        "        if(ShipType(StarShips(star,j)) == 'Warrior') coun = coun + 1;",
                        "        if(ShipType(StarShips(star,j)) == 'Warrior' && ShipSubType(StarShips(star,j))) coun = coun + 10;",
                        "        if(ShipType(StarShips(star,j)) == 'Ranger') coun = coun + 1;",
                        "        if(ShipType(StarShips(star,j)) == 'FemRanger') coun = coun + 1;",
                        "        if(ShipType(StarShips(star,j)) == 'Militiaman1') coun = coun + 1;",
                        "        if(ShipType(StarShips(star,j)) == 'Militiaman2') coun = coun + 1;",
                        "        if(ShipType(StarShips(star,j)) == 'Militiaman3') coun = coun + 1;",
                        "        if(ShipType(StarShips(star,j)) == 'RangerExplorer') coun = coun + 1;",
                        "        if(ShipType(StarShips(star,j)) == 'Dreadnought') coun = coun + 15;",
                        "        if(ShipType(StarShips(star,j)) == 'Freelancer') coun = coun + 1;",
                        "        if(ShipType(StarShips(star,j)) == 'Coalition_mod_tryfixbalance') coun = coun + 1;",
                        "        if(ShipType(StarShips(star,j)) == 'DefPlatform') coun = coun + 5;",
                        "        if(ShipType(StarShips(star,j)) == 'Otstupnik') coun = coun + 1;",
                        "        if(ShipType(StarShips(star,j)) == 'Inhibitor') coun = coun + 5;",
                        "        if(ShipTypeN(StarShips(star,j)) > t_Tranclucator) coun = coun + 7;",
                        "        if(StarEnemyThreatLevel(star,1) == 2) coun = coun - 10;",
                        "    }",
                        "    planets = 0;",
                        "    for(j=0;StarPlanets(star)>j;j=j+1) {",
                        "        if(PlanetOwner(StarPlanets(star,j)) == 6) continue;",
                        "        else planets = planets + 1;",
                        "    }",
                        "",
                        "    if(round(coun/planets) < 6) break;",
                        "    star = 0;",
                        "}",
                        "if(!star) {",
                        "  DChange(3);",
                        "  exit;",
                        "}",
                        "if(star) {",
                        "  daily = round(GalaxyMoney(1,3) / 4);",
                        "  shippy = round(GalaxyMoney(3,3) / 4);",
                        "  DChange(4);",
                        "  exit;",
                        "}"
                    ],
                    "#": 43,
                    "Type": "Top",
                    "Parent": -1,
                    "Pos.x": 220,
                    "Pos.y": 515
                },
