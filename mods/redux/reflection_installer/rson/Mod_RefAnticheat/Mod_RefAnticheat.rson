                        "if(!ShipIsTakeoff(Player())) {",
                        "    for(i=GalaxyEvents()-1; i>=0; i=i-1) {",
                        "        if(GalaxyEventDate(i) < CurTurn()) break;",
                        "        if(GalaxyEventType(i)=='PlayerEntersCheatCode') { //игрок использовал чит (тоби хана)",
                        "            throw 'Система Античит успешно отработала на Вашем компьютере.<br>Благодарим за использование программного обеспечения от Малокософт Инкорпорейтед';",
