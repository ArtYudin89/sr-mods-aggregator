                {
                    "Name": "",
                    "Code.Type": "Turn",
                    "Code": [
                        "if(ShipEqInSlot(Player(),t_RepairRobot) != 0) {",
                        "    tdroid=ShipEqInSlot(Player(),t_RepairRobot);",
                        "    if(DRFlag != 0) {",
                        "        if(ItemDurability(tdroid) > 0) {",
                        "            if(DRFlag == 1) {",
                        "                if(ItemDurability(tdroid) == 0) Ether(2,'',CT(\"Script.Mod_RefDroidRegimes.24\"));",
                        "                ItemDurability(tdroid,SavedDur);",
                        "                ShipSpecialBonuses(Player(),bonDroid,ShipSpecialBonuses(Player(),bonDroid) + SavedDebuff);",
                        "                DRFlag = 0;",
                        "            }",
                        "            if(DRFlag == 2) {",
                        "                ShipSpecialBonuses(Player(),bonDroid,ShipSpecialBonuses(Player(),bonDroid) - GetEquipmentStats(tdroid,0));",
                        "                DRFlag = 0;",
                        "            }",
                        "            if(DRFlag == 3) {",
                        "                ShipSpecialBonuses(Player(),bonDroid,ShipSpecialBonuses(Player(),bonDroid) - GetEquipmentStats(tdroid,0) - 80);",
