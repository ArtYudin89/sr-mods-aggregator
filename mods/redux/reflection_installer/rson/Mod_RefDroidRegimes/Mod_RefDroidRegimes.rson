                    "Parent": -1,
                    "Pos.x": 0,
                    "Pos.y": 585
                },
                {
                    "Name": "",
                    "Code.Type": "Turn",
                    "Code": [
                        "if(DRFlag != 0) {",
                        "    if(ShipEqInSlot(Player(),t_RepairRobot) != 0) {",
                        "        tdroid=ShipEqInSlot(Player(),t_RepairRobot);",
                        "        if(ItemDurability(tdroid) < 0) {",
                        "            if(DRFlag == 2) {",
                        "                ShipSpecialBonuses(Player(),bonDroid,ShipSpecialBonuses(Player(),bonDroid) - GetEquipmentStats(tdroid,0));",
                        "                DRFlag = 0;",
                        "            }",
                        "            if(DRFlag == 3) {",
                        "                ShipSpecialBonuses(Player(),bonDroid,ShipSpecialBonuses(Player(),bonDroid) - GetEquipmentStats(tdroid,0) - 80);",
                        "                DRFlag = 0;",
                        "            }",
                        "            if(DRFlag == 4) {",
                        "                if(temp_inta < 15) ShipSpecialBonuses(Player(),bonDroid,ShipSpecialBonuses(Player(),bonDroid) + 3);",
                        "                else if(temp_inta > 15) ShipSpecialBonuses(Player(),bonDroid,ShipSpecialBonuses(Player(),bonDroid) + 5);",
                        "                else if(temp_inta > 25) ShipSpecialBonuses(Player(),bonDroid,ShipSpecialBonuses(Player(),bonDroid) + 7);",
                        "                else if(temp_inta > 30) ShipSpecialBonuses(Player(),bonDroid,ShipSpecialBonuses(Player(),bonDroid) + 10);",
                        "                else if(temp_inta > 40) ShipSpecialBonuses(Player(),bonDroid,ShipSpecialBonuses(Player(),bonDroid) + 12);",
                        "                else if(temp_inta > 50) ShipSpecialBonuses(Player(),bonDroid,ShipSpecialBonuses(Player(),bonDroid) + 15);",
                        "                else if(temp_inta > 60) ShipSpecialBonuses(Player(),bonDroid,ShipSpecialBonuses(Player(),bonDroid) + 19);",
                        "                else if(temp_inta > 70) ShipSpecialBonuses(Player(),bonDroid,ShipSpecialBonuses(Player(),bonDroid) + 24);",
                        "                else if(temp_inta > 90) ShipSpecialBonuses(Player(),bonDroid,ShipSpecialBonuses(Player(),bonDroid) + 28);",
                        "                else if(temp_inta > 100) ShipSpecialBonuses(Player(),bonDroid,ShipSpecialBonuses(Player(),bonDroid) + 40);",
                        "                DRFlag = 0;",
                        "            }",
                        "        }",
                        "        else if(GetEquipmentStats(tdroid,0) != KostylOtAbuzov) {",
                        "            if(DRFlag == 1) {",
                        "                ItemDurability(tdroid,SavedDur);",
                        "                ShipSpecialBonuses(Player(),bonDroid,ShipSpecialBonuses(Player(),bonDroid) + SavedDebuff);",
                        "                DRFlag = 0;",
                        "                NewsAdd(CT(\"Script.Mod_RefDroidRegimes.17\"));",
                        "                //SFT('DR-8');",
                        "                //SFT(DRFlag);",
                        "            }",
                        "            if(DRFlag == 2) {",
                        "                ShipSpecialBonuses(Player(),bonDroid,ShipSpecialBonuses(Player(),bonDroid) - KostylOtAbuzov);",
                        "                DRFlag = 0;",
                        "                NewsAdd(CT(\"Script.Mod_RefDroidRegimes.17\"));",
                        "                //SFT('DR-7');",
                        "                //SFT(DRFlag);",
                        "            }",
                        "            if(DRFlag == 3) {",
                        "                ShipSpecialBonuses(Player(),bonDroid,ShipSpecialBonuses(Player(),bonDroid) - KostylOtAbuzov - 80);",
                        "                DRFlag = 0;",
                        "                NewsAdd(CT(\"Script.Mod_RefDroidRegimes.17\"));",
                        "                //SFT('DR-6');",
                        "                //SFT(DRFlag);",
                        "            }",
                        "            if(DRFlag == 4) {",
                        "                if(temp_inta < 15) ShipSpecialBonuses(Player(),bonDroid,ShipSpecialBonuses(Player(),bonDroid) + 3);",
                        "                else if(temp_inta > 15) ShipSpecialBonuses(Player(),bonDroid,ShipSpecialBonuses(Player(),bonDroid) + 5);",
                        "                else if(temp_inta > 25) ShipSpecialBonuses(Player(),bonDroid,ShipSpecialBonuses(Player(),bonDroid) + 7);",
                        "                else if(temp_inta > 30) ShipSpecialBonuses(Player(),bonDroid,ShipSpecialBonuses(Player(),bonDroid) + 10);",
                        "                else if(temp_inta > 40) ShipSpecialBonuses(Player(),bonDroid,ShipSpecialBonuses(Player(),bonDroid) + 12);",
                        "                else if(temp_inta > 50) ShipSpecialBonuses(Player(),bonDroid,ShipSpecialBonuses(Player(),bonDroid) + 15);",
                        "                else if(temp_inta > 60) ShipSpecialBonuses(Player(),bonDroid,ShipSpecialBonuses(Player(),bonDroid) + 19);",
                        "                else if(temp_inta > 70) ShipSpecialBonuses(Player(),bonDroid,ShipSpecialBonuses(Player(),bonDroid) + 24);",
                        "                else if(temp_inta > 90) ShipSpecialBonuses(Player(),bonDroid,ShipSpecialBonuses(Player(),bonDroid) + 28);",
                        "                else if(temp_inta > 100) ShipSpecialBonuses(Player(),bonDroid,ShipSpecialBonuses(Player(),bonDroid) + 40);",
                        "                DRFlag = 0;",
                        "                NewsAdd(CT(\"Script.Mod_RefDroidRegimes.17\"));",
                        "                //SFT('DR-5');",
                        "                //SFT(DRFlag);",
                        "            }",
                        "        }",
                        "        else {",
                        "            if(DRFlag == 1) {",
                        "                if(ShipDroidRepair(Player()) != 0) {",
                        "                    ShipSpecialBonuses(Player(),bonDroid,ShipSpecialBonuses(Player(),bonDroid) + SavedDebuff);",
                        "                    ShipSpecialBonuses(Player(),bonDroid,ShipSpecialBonuses(Player(),bonDroid) - ShipDroidRepair(Player()));",
                        "                    SavedDebuff = ShipDroidRepair(Player());",
                        "                }",
                        "            }",
                        "            if(DRFlag == 2) {",
                        "                ItemDurability(tdroid,ItemDurability(tdroid) - 2);",
                        "                if(ItemDurability(ShipEqInSlot(Player(),t_RepairRobot)) == 0) Ether(8,'',CT(\"Script.Mod_RefDroidRegimes.16\"));",
                        "            }",
                        "            if(DRFlag == 3) {",
                        "                ItemDurability(tdroid,ItemDurability(tdroid) - 15);",
                        "                if(ItemDurability(ShipEqInSlot(Player(),t_RepairRobot)) == 0) Ether(8,'',CT(\"Script.Mod_RefDroidRegimes.16\"));",
                        "            }",
                        "            if(DRFlag == 4) {",
                        "                if(ItemDurability(tdroid) < 80) {",
                        "                    if(CurTurn() % 3 == 2) ItemDurability(tdroid,ItemDurability(tdroid) + 1);",
                        "                }",
                        "            }",
                        "        }",
                        "    }",
                        "    else {",
                        "        if(DRFlag == 1) {",
                        "            ShipSpecialBonuses(Player(),bonDroid,ShipSpecialBonuses(Player(),bonDroid) + SavedDebuff);",
                        "            DRFlag = 0;",
                        "            NewsAdd(CT(\"Script.Mod_RefDroidRegimes.15\"));",
                        "            //SFT('DR-4');",
                        "            //SFT(DRFlag);",
                        "        }",
                        "        if(DRFlag == 2) {",
                        "            ShipSpecialBonuses(Player(),bonDroid,ShipSpecialBonuses(Player(),bonDroid) - KostylOtAbuzov);",
                        "            DRFlag = 0;",
                        "            NewsAdd(CT(\"Script.Mod_RefDroidRegimes.15\"));",
                        "            //SFT('DR-3');",
                        "            //SFT(DRFlag);",
                        "        }",
                        "        if(DRFlag == 3) {",
                        "            ShipSpecialBonuses(Player(),bonDroid,ShipSpecialBonuses(Player(),bonDroid) - KostylOtAbuzov - 80);",
                        "            DRFlag = 0;",
                        "            NewsAdd(CT(\"Script.Mod_RefDroidRegimes.15\"));",
                        "            //SFT('DR-2');",
                        "            //SFT(DRFlag);",
                        "        }",
                        "        if(DRFlag == 4) {",
                        "            if(temp_inta < 15) ShipSpecialBonuses(Player(),bonDroid,ShipSpecialBonuses(Player(),bonDroid) + 3);",
                        "            else if(temp_inta > 15) ShipSpecialBonuses(Player(),bonDroid,ShipSpecialBonuses(Player(),bonDroid) + 5);",
                        "            else if(temp_inta > 25) ShipSpecialBonuses(Player(),bonDroid,ShipSpecialBonuses(Player(),bonDroid) + 7);",
                        "            else if(temp_inta > 30) ShipSpecialBonuses(Player(),bonDroid,ShipSpecialBonuses(Player(),bonDroid) + 10);",
                        "            else if(temp_inta > 40) ShipSpecialBonuses(Player(),bonDroid,ShipSpecialBonuses(Player(),bonDroid) + 12);",
                        "            else if(temp_inta > 50) ShipSpecialBonuses(Player(),bonDroid,ShipSpecialBonuses(Player(),bonDroid) + 15);",
                        "            else if(temp_inta > 60) ShipSpecialBonuses(Player(),bonDroid,ShipSpecialBonuses(Player(),bonDroid) + 19);",
                        "            else if(temp_inta > 70) ShipSpecialBonuses(Player(),bonDroid,ShipSpecialBonuses(Player(),bonDroid) + 24);",
                        "            else if(temp_inta > 90) ShipSpecialBonuses(Player(),bonDroid,ShipSpecialBonuses(Player(),bonDroid) + 28);",
                        "            else if(temp_inta > 100) ShipSpecialBonuses(Player(),bonDroid,ShipSpecialBonuses(Player(),bonDroid) + 40);",
                        "            DRFlag = 0;",
                        "            NewsAdd(CT(\"Script.Mod_RefDroidRegimes.15\"));",
                        "            //SFT('DR-1');",
                        "            //SFT(DRFlag);",
                        "        }",
                        "    }",
                        "    if(!ShipInNormalSpace(Player())) {",
                        "        if(DRFlag == 2) {",
                        "            ShipSpecialBonuses(Player(),bonDroid,ShipSpecialBonuses(Player(),bonDroid) - KostylOtAbuzov);",
                        "            DRFlag = 0;",
                        "            Ether(2,'',CT(\"Script.Mod_RefDroidRegimes.23\"));",
                        "        }",
                        "        if(DRFlag == 3) {",
                        "            ShipSpecialBonuses(Player(),bonDroid,ShipSpecialBonuses(Player(),bonDroid) - KostylOtAbuzov - 80);",
                        "            DRFlag = 0;",
                        "            Ether(2,'',CT(\"Script.Mod_RefDroidRegimes.14\"));",
                        "        }",
                        "        if(DRFlag == 4) {",
                        "            if(temp_inta < 15) ShipSpecialBonuses(Player(),bonDroid,ShipSpecialBonuses(Player(),bonDroid) + 3);",
                        "            else if(temp_inta > 15) ShipSpecialBonuses(Player(),bonDroid,ShipSpecialBonuses(Player(),bonDroid) + 5);",
                        "            else if(temp_inta > 25) ShipSpecialBonuses(Player(),bonDroid,ShipSpecialBonuses(Player(),bonDroid) + 7);",
                        "            else if(temp_inta > 30) ShipSpecialBonuses(Player(),bonDroid,ShipSpecialBonuses(Player(),bonDroid) + 10);",
                        "            else if(temp_inta > 40) ShipSpecialBonuses(Player(),bonDroid,ShipSpecialBonuses(Player(),bonDroid) + 12);",
                        "            else if(temp_inta > 50) ShipSpecialBonuses(Player(),bonDroid,ShipSpecialBonuses(Player(),bonDroid) + 15);",
                        "            else if(temp_inta > 60) ShipSpecialBonuses(Player(),bonDroid,ShipSpecialBonuses(Player(),bonDroid) + 19);",
                        "            else if(temp_inta > 70) ShipSpecialBonuses(Player(),bonDroid,ShipSpecialBonuses(Player(),bonDroid) + 24);",
                        "            else if(temp_inta > 90) ShipSpecialBonuses(Player(),bonDroid,ShipSpecialBonuses(Player(),bonDroid) + 28);",
                        "            else if(temp_inta > 100) ShipSpecialBonuses(Player(),bonDroid,ShipSpecialBonuses(Player(),bonDroid) + 40);",
                        "            DRFlag = 0;",
                        "            Ether(2,'',CT(\"Script.Mod_RefDroidRegimes.13\"));",
                        "        }",
                        "    }",
                        "}"
                    ],
