                {
                    "Name": "",
                    "Code.Type": "DialogBegin",
                    "Code": [
                        "if(PlayerBridge()==12) {",
                        "  if(ShipEqInSlot(Player(),t_RepairRobot) != 0) {",
                        "      if(DRFlag == 0)",
                        "      {",
                        "          temp_str=CT(\"Script.Mod_RefDroidRegimes.8\");",
                        "      }",
                        "      else if(DRFlag == 1)",
                        "      {",
