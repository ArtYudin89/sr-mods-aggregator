                        "      }",
                        "      AddDialogInject('RefDroidd',Format(CT(\"Script.Mod_RefDroidRegimes.3\"),\"<0>\",temp_str),CT(\"Script.Mod_RefDroidRegimes.2\"),14);",
                        "  }",
                        "}"
