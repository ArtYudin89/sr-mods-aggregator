                        "            ShipSpecialBonuses(Player(),bonSkill6,ShipSpecialBonuses(Player(),bonSkill6) + 1);",
                        "            ShipSpecialBonuses(Player(),bonWRadius,ShipSpecialBonuses(Player(),bonWRadius) + 15);",
                        "            ShipSpecialBonuses(Player(),bonHookRadius,ShipSpecialBonuses(Player(),bonHookRadius) + 20);",
                        "            ShipSpecialBonuses(Player(),bonSpeed,ShipSpecialBonuses(Player(),bonSpeed) + 75);",
                        "            ShipSpecialBonuses(Player(),bonZonds,ShipSpecialBonuses(Player(),bonZonds) + 1);",
                        "            ShipSpecialBonuses(Player(),bonWEnergy,ShipSpecialBonuses(Player(),bonWEnergy) + 5);",
                        "            ShipSpecialBonuses(Player(),bonWSplinter,ShipSpecialBonuses(Player(),bonWSplinter) + 5);",
                        "            ShipSpecialBonuses(Player(),bonHook,ShipSpecialBonuses(Player(),bonHook) + 25);",
                        "            ShipSpecialBonuses(Player(),bonSkill2,ShipSpecialBonuses(Player(),bonSkill2) + 1);",
                        "        }",
                        "        if(ShipCustomShipInfoData(Player(),'RefCoffeeIllness',2) == 5) {",
                        "            ShipSpecialBonuses(Player(),bonSkill1,ShipSpecialBonuses(Player(),bonSkill1) + 1);",
                        "            ShipSpecialBonuses(Player(),bonSkill3,ShipSpecialBonuses(Player(),bonSkill3) + 1);",
                        "            ShipSpecialBonuses(Player(),bonSkill4,ShipSpecialBonuses(Player(),bonSkill4) + 1);",
                        "            ShipSpecialBonuses(Player(),bonSkill5,ShipSpecialBonuses(Player(),bonSkill5) + 1);",
                        "            ShipSpecialBonuses(Player(),bonSkill6,ShipSpecialBonuses(Player(),bonSkill6) + 1);",
                        "            ShipSpecialBonuses(Player(),bonWRadius,ShipSpecialBonuses(Player(),bonWRadius) + 15);",
                        "            ShipSpecialBonuses(Player(),bonHookRadius,ShipSpecialBonuses(Player(),bonHookRadius) + 20);",
                        "            ShipSpecialBonuses(Player(),bonSpeed,ShipSpecialBonuses(Player(),bonSpeed) + 75);",
                        "            ShipSpecialBonuses(Player(),bonZonds,ShipSpecialBonuses(Player(),bonZonds) + 1);",
                        "            ShipSpecialBonuses(Player(),bonWEnergy,ShipSpecialBonuses(Player(),bonWEnergy) + 5);",
                        "            ShipSpecialBonuses(Player(),bonWSplinter,ShipSpecialBonuses(Player(),bonWSplinter) + 5);",
                        "            ShipSpecialBonuses(Player(),bonHook,ShipSpecialBonuses(Player(),bonHook) + 25);",
                        "            ShipSpecialBonuses(Player(),bonSkill2,ShipSpecialBonuses(Player(),bonSkill2) + 1);",
                        "        }",
                        "        if(ShipCustomShipInfoData(Player(),'RefCoffeeIllness',2)) {",
                        "            ShipDeleteCustomShipInfo(Player(),'RefCoffeeIllness');",
                        "            CustomEther('BioCured',0,'',CT(\"Script.Mod_RefGovCoffee.31\"));",
                        "        }",
                        "    }",
                        "}",
                        "DChange(2);",
                        "exit;"
                    ],
                    "#": 47,
                    "Type": "Top",
                    "Parent": -1,
                    "Pos.x": 580,
                    "Pos.y": 515
                },
                {
                    "Name": "",
                    "Code.Type": "Turn",
                    "Code": [
                        "if(GetRelationPlanet(GetShipPlanet(Player()),Player()) > 80) {",
                        "  rand = Rnd(1,4);",
                        "  if(rand == 1) {",
                        "      if(PlanetEco(GetShipPlanet(Player())) == 0) tstr = CT(\"Script.Mod_RefGovCoffee.28\");",
                        "      if(PlanetEco(GetShipPlanet(Player())) == 1) tstr = CT(\"Script.Mod_RefGovCoffee.27\");",
                        "      if(PlanetEco(GetShipPlanet(Player())) == 2) tstr = CT(\"Script.Mod_RefGovCoffee.26\");",
                        "  }",
                        "  else if(rand == 2) {",
                        "      if(!CoalitionDefeated() && PlanetOwner(GetShipPlanet(Player())) == 7 && !ShipOnSidePirateClan(Player())) tstr = CT(\"Script.Mod_RefGovCoffee.25\");",
                        "      if(!CoalitionDefeated() && PlanetOwner(GetShipPlanet(Player())) == 7 && ShipOnSidePirateClan(Player())) tstr = CT(\"Script.Mod_RefGovCoffee.24\");",
                        "      if(CoalitionDefeated()) tstr = CT(\"Script.Mod_RefGovCoffee.23\");",
                        "  }",
                        "  else if(rand == 3) {",
                        "      if(PlanetGov(GetShipPlanet(Player())) == 0) tstr = CT(\"Script.Mod_RefGovCoffee.37\");",
                        "      if(PlanetGov(GetShipPlanet(Player())) == 1) tstr = CT(\"Script.Mod_RefGovCoffee.36\");",
                        "      if(PlanetGov(GetShipPlanet(Player())) == 2) tstr = CT(\"Script.Mod_RefGovCoffee.35\");",
                        "      if(PlanetGov(GetShipPlanet(Player())) == 3) tstr = CT(\"Script.Mod_RefGovCoffee.34\");",
                        "      if(PlanetGov(GetShipPlanet(Player())) == 4) tstr = CT(\"Script.Mod_RefGovCoffee.33\");",
                        "  }",
                        "  else {",
                        "      tstr = CT(\"Script.Mod_RefGovCoffee.32\");",
                        "  }",
                        "  DChange(5);",
                        "  exit;",
                        "}",
                        "if(GetRelationPlanet(GetShipPlanet(Player()),Player()) <= 80) {",
                        "  DChange(4);",
                        "  exit;",
                        "}"
                    ],
