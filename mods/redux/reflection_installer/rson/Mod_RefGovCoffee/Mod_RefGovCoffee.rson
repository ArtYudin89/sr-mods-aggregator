                    "Type": "TDialogAnswer",
                    "Parent": -1,
                    "#": 31,
                    "Msg": "Ну, тогда давайте, попробую",
                    "AMsg.Num": "5",
                    "_orig_danswer": "DAnswer(CT(\"Script.Mod_RefGovCoffee.11\"))"
                },
                {
                    "Name": "",
