            "Items": [],
            "Operations": [
                {
                    "Name": "",
                    "Code.Type": "Global",
                    "Code": [
                        "GRun();"
                    ],
                    "#": 17,
                    "Type": "Top",
                    "Parent": -1,
                    "Pos.x": 0,
                    "Pos.y": 635
                },
                {
                    "Name": "",
                    "Code.Type": "Turn",
                    "Code": [
                        "if(CurTurn() == NotifyTurn && CurTurn() != 0) {",
                        "    NotifyTurn = 0;",
                        "    if(text_date == 'No') text_date = '';",
                        "    else text_date = '<br' + '/>' + text_date;",
                        "    NewsAdd(Format(CT(\"Script.Mod_RefNotifications.33\"),'date',GameDateTxtByTurn(NotifyTurn)) + text_date);",
                        "    Sound('Sound.NewMsg');",
                        "}",
                        "if(Id(ShipStar(Player())) == NotifySysID) {",
                        "    if(text_system == 'No') text_system = '';",
                        "    else text_system = '<br' + '/>' + text_system;",
                        "    NewsAdd(Format(CT(\"Script.Mod_RefNotifications.32\"),'name',Name(GalaxyStar(NotifySysID-1))) + text_system);",
                        "    Sound('Sound.NewMsg');",
                        "    NotifySysID = 10000;",
                        "}",
                        "if(ShipIDD != 0) {",
                        "    if(ShipInStar(Player(),ShipStar(IdToShip(ShipIDD)))) {",
                        "        if(text_system == 'No') text_system = '';",
                        "        else text_system = '<br' + '/>' + text_system;",
                        "        NewsAdd(Format(CT(\"Script.Mod_RefNotifications.31\"),'name',Name(IdToShip(ShipIDD))) + text_system);",
                        "        Sound('Sound.NewMsg');",
                        "        ShipIDD = 0;",
                        "    }",
                        "}"
                    ],
                    "#": 18,
                    "Type": "Top",
                    "Parent": -1,
                    "Pos.x": 120,
                    "Pos.y": 635
                },
                {
                    "Name": "",
                    "Code.Type": "DialogBegin",
                    "Code": [
                        "if(PlayerBridge()==12) {",
                        "  AddDialogInject('NotifyDial',CT(\"Script.Mod_RefNotifications.43\"),CT(\"Script.Mod_RefNotifications.2\"),50);",
                        "}"
                    ],
                    "#": 19,
                    "Type": "Top",
                    "Parent": -1,
                    "Pos.x": 180,
                    "Pos.y": 635
                },
                {
                    "Name": "",
                    "Code.Type": "Turn",
                    "Code": [
                        "if(NotifyTurn == 0 && ShipIDD == 0 && NotifySysID == 10000) tstr = CT(\"Script.Mod_RefNotifications.38\");",
                        "else {",
                        "    tstr = '';",
                        "    if(NotifyTurn > 0) tstr = tstr + Format(CT(\"Script.Mod_RefNotifications.37\"),'date',GameDateTxtByTurn(NotifyTurn)) + CT('FormInfo.br');",
                        "    if(ShipIDD > 0) tstr = tstr + Format(CT(\"Script.Mod_RefNotifications.36\"),'ship',Name(IdToShip(ShipIDD))) + CT('FormInfo.br');",
                        "    if(NotifySysID > 0) tstr = tstr + Format(CT(\"Script.Mod_RefNotifications.35\"),'sys',Name(GalaxyStar(NotifySysID-1))) + CT('FormInfo.br');",
                        "}",
                        "DChange(0);",
                        "exit;"
                    ],
                    "#": 73,
                    "Type": "Top",
                    "Parent": -1,
                    "Pos.x": -20,
                    "Pos.y": 375
                },
                {
                    "Name": "",
                    "Code.Type": "Turn",
                    "Code": [
                        "NotifyTurn = NotifyTurn + GAnswerData;",
                        "tstr = GameDateTxtByTurn(NotifyTurn);",
                        "DChange(8);",
                        "exit;"
                    ],
                    "#": 74,
                    "Type": "Top",
                    "Parent": -1,
                    "Pos.x": 130,
                    "Pos.y": 375
                },
                {
                    "Name": "",
                    "Code.Type": "Turn",
                    "Code": [
                        "tdwd = GAnswerData;",
                        "DChange(4);",
                        "exit;"
                    ],
                    "#": 75,
                    "Type": "Top",
                    "Parent": -1,
                    "Pos.x": 250,
                    "Pos.y": 375
                },
                {
                    "Name": "",
                    "Code.Type": "Turn",
                    "Code": [
                        "NotifySysID = Id(GAnswerData);",
                        "tstr = Name(GAnswerData);",
                        "DChange(7);",
                        "exit;"
                    ],
                    "#": 76,
                    "Type": "Top",
                    "Parent": -1,
                    "Pos.x": 430,
                    "Pos.y": 375
                },
                {
