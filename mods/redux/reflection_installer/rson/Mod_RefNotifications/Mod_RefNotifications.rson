                {
                    "Name": "",
                    "Code.Type": "Turn",
                    "Code": [
                        "if(CurTurn() > 300) tint = 3300 + round((CurTurn()-300) / 365);",
                        "else tint = 3300;",
                        "tyear = 3300;",
                        "tyear = CountBox('Bm.Items.2Minerals',CT(\"Script.Mod_RefNotifications.39\"),tint,4000);",
                        "NotifyTurn = (tyear - 3300) * 365 + 300;",
                        "if(tyear >= 3000) {",
                        "  DChange(1);",
                        "  exit;",
                        "}",
                        "if(tyear < 3000) {",
                        "  DChange(0);",
                        "  exit;",
                        "}"
                    ],
                    "#": 99,
                    "Type": "Top",
                    "Parent": -1,
                    "Pos.x": -20,
                    "Pos.y": 540
                },
                {
                    "Name": "",
                    "Code.Type": "Turn",
                    "Code": [
                        "tstr = TextBox(CT(\"Script.Mod_RefNotifications.41\"));",
                        "tdwd = 0;",
                        "for(i=0;GalaxyStars()>i;i=i+1) {",
                        "    for(j=0;StarShips(GalaxyStar(i)) > j;j=j+1) {",
                        "        if(ShortName(StarShips(GalaxyStar(i),j)) == tstr) tdwd = StarShips(GalaxyStar(i),j);",
                        "        else continue;",
                        "    }",
                        "}",
                        "if(tdwd == 0) MessageBox(CT(\"Script.Mod_RefNotifications.40\"));",
                        "else {",
                        "    tstr = Name(tdwd);",
                        "    ShipIDD = Id(tdwd);",
                        "}",
                        "if(tdwd == 0) {",
                        "  DChange(0);",
                        "  exit;",
                        "}",
                        "if(tdwd != 0) {",
                        "  DChange(9);",
                        "  exit;",
                        "}"
                    ],
