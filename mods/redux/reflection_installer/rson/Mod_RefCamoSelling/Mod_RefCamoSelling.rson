                    "Code": [
                        "GRun();"
                    ],
                    "#": 6,
                    "Type": "Top",
                    "Parent": -1,
                    "Pos.x": 0,
                    "Pos.y": 585
                },
                {
                    "Name": "",
                    "Code.Type": "DialogBegin",
                    "Code": [
                        "if(DomiksDefeated() == 1) {",
                        "  if(PlayerChameleonCharges(0) > 0 || PlayerChameleonCharges(1) > 0 || PlayerChameleonCharges(2) > 0) {",
                        "    if(GetTalkShip() == 0) {",
                        "        if(GetShipRuins(Player())) {",
                        "            if(!PlayerBridge()) {",
                        "                if(ShipType(GetShipRuins(Player())) == 'WB' || ShipType(GetShipRuins(Player())) == 'CB') {",
                        "                    AddDialogInject('CamoSell','',CT(\"Script.Mod_RefCamoSelling.9\"),10);",
                        "                }",
                        "            }",
                        "        }",
                        "    }",
                        "  }",
                        "}"
                    ],
                    "#": 7,
                    "Type": "Top",
                    "Parent": -1,
                    "Pos.x": 180,
                    "Pos.y": 585
                },
                {
                    "Name": "",
                    "Code.Type": "Turn",
                    "Code": [
                        "if(ShipType(GetShipRuins(Player())) == 'WB') tstr = CT(\"Script.Mod_RefCamoSelling.11\");",
                        "else tstr = CT(\"Script.Mod_RefCamoSelling.10\");",
                        "DChange(0);",
                        "exit;"
                    ],
                    "#": 17,
                    "Type": "Top",
                    "Parent": -1,
                    "Pos.x": -20,
                    "Pos.y": 375
                },
                {
                    "Name": "",
                    "Code.Type": "Turn",
                    "Code": [
                        "if(PlayerChameleonCharges(0) > 0) {",
                        "  DAdd(0);",
                        "}",
                        "if(PlayerChameleonCharges(1) > 0) {",
                        "  DAdd(1);",
                        "}",
                        "if(PlayerChameleonCharges(2) > 0) {",
                        "  DAdd(2);",
                        "}",
                        "DAdd(3);"
                    ],
                    "#": 18,
                    "Type": "Top",
                    "Parent": -1,
                    "Pos.x": -20,
                    "Pos.y": 445
                },
                {
                    "Name": "",
                    "Code.Type": "Turn",
                    "Code": [
                        "DAdd(4);"
                    ],
                    "#": 19,
                    "Type": "Top",
                    "Parent": -1,
                    "Pos.x": 130,
                    "Pos.y": 445
                },
                {
                    "Name": "",
                    "Code.Type": "Turn",
                    "Code": [
                        "ShipMoney(Player(),ShipMoney(Player()) + PlayerChameleonCharges(0) * 30000);",
                        "PlayerChameleonCharges(0,0);",
                        "DChange(1);",
                        "exit;"
