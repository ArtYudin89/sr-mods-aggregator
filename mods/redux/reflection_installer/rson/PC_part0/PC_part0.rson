                    "Pos.x": 1060,
                    "Pos.y": 540
                },
                {
                    "Name": "",
                    "Code.Type": "Turn",
                    "Code": [
                        "ShipJoinsClan(Player());",
                        "",
                        "if(CurrentMods('Expansion\\\\ExpTraitors'))",
                        "{",
                        "    hull_gift = CreateQuestItem('ExpTraitors_PirateParrot');",
                        "    ItemSize(hull_gift, 1);",
                        "    UselessItemData(hull_gift, 1, 0);",
                        "    UselessItemData(hull_gift, 2, 1);",
                        "    UselessItemData(hull_gift, 3, -2);",
                        "    AddItemToStorage(GetShipRuins(Player()), hull_gift);",
                        "    //Догружаем сверху корпус, но послабее",
                        "    hull_gift=CreateHull(2,100+125*GalaxyTechLevel(),GalaxyTechLevel(),ShipPilotRace(Player()),-1,1);",
                        "    ItemCost(hull_gift,ItemCost(hull_gift)/2);",
                        "    AddItemToStorage(GetShipRuins(Player()),hull_gift);",
                        "",
                        "    //Снижаем отношение всех планет Коалиции (но не ниже 20) и повышаем отношение всех пиратских планет, то есть Роджерии (но не выше 45)",
                        "    ChangeGlobalRelationsPlanets(Player(), 0, 0, 20, 31);",
                        "    RelationToRanger(PlanetPirateClan(), Player(), max(45, RelationToRanger(PlanetPirateClan(), Player())));",
                        "    //ShipType(Player(), 'RangerPiratePlayer'); //Если раскомментировать смену типа здесь, то смена отношения станций и смена типа в Mod_ExpTraitors при первом вступлении в клан производиться не будет",
                        "",
                        "    GotoGov(2); //Лочим игрока в диалоге, до тех пор, пока не прокликает его до конца",
                        "    //(нужно, чтобы сработало обновление ShipType() и отношения станций к игроку из скрипта Mod_ExpTraitors)",
                        "}",
                        "else",
                        "{",
                        "    hull_gift=CreateHull(2,100+150*GalaxyTechLevel(),GalaxyTechLevel(),ShipPilotRace(Player()),-1,1);",
                        "    ItemCost(hull_gift,ItemCost(hull_gift)/2);",
                        "    AddItemToStorage(GetShipRuins(Player()),hull_gift);",
                        "}",
                        "",
                        "//Сразу проваливаем задание флагмана из мода ExpAcryn, если игрок уже успел его взять",
                        "if(CurrentMods('Expansion\\\\ExpAcryn'))",
                        "{",
                        "    //Игрок взял задание у флагмана, а потом вступил в пиратский клан - все задания провалены до конца партии",
                        "    if(ExpAcrynQuestStatus < 6)",
                        "    {",
                        "        if(~EtherState('ExpAcryn_quest_' + ExpAcrynQuestStatus))",
                        "        {",
                        "            if(GetValueFromScript('Mod_ExpAcryn', 'fl_array', ExpAcrynQuestStatus, 1) == 1) points = '';",
                        "            else points = '2';",
                        "",
                        "            if(ExpAcrynQuestStatus == 0) Ether(5, 'ExpAcryn_quest_0', CT('Script.Mod_ExpAcryn.MissionFailed') + Format(CT('Script.Mod_ExpAcryn.MalocMission' + points), '#ItemName#', GetValueFromScript('Mod_ExpAcryn', 'addItemName')));",
                        "            else if(ExpAcrynQuestStatus == 1) Ether(5, 'ExpAcryn_quest_1', CT('Script.Mod_ExpAcryn.MissionFailed') + Format(CT('Script.Mod_ExpAcryn.PelengMission' + points), '#ItemName#', GetValueFromScript('Mod_ExpAcryn', 'addItemName')));",
                        "            else if(ExpAcrynQuestStatus == 2)",
                        "            {",
                        "                Ether(5, 'ExpAcryn_quest_2', CT('Script.Mod_ExpAcryn.MissionFailed') + Format(CT('Script.Mod_ExpAcryn.PeopleMission' + points), '#ItemName#', GetValueFromScript('Mod_ExpAcryn', 'addItemName')));",
                        "                ShipDeleteCustomShipInfo(Player(), 'ExpAcryn_mimi_player_infos');",
                        "            }",
                        "            else if(ExpAcrynQuestStatus == 3) Ether(5, 'ExpAcryn_quest_3', CT('Script.Mod_ExpAcryn.MissionFailed') + Format(CT('Script.Mod_ExpAcryn.FeiMission' + points), '#ItemName#', GetValueFromScript('Mod_ExpAcryn', 'addItemName')));",
                        "            else if(ExpAcrynQuestStatus == 4) Ether(5, 'ExpAcryn_quest_4', CT('Script.Mod_ExpAcryn.MissionFailed') + Format(CT('Script.Mod_ExpAcryn.GaalMission' + points), '#ItemName#', GetValueFromScript('Mod_ExpAcryn', 'addItemName')));",
                        "        }",
                        "",
                        "        //Также понижаем его репутацию на всех планетах соответствующей расы",
                        "        for(i = 0; i < GalaxyStars(); i = i + 1)",
                        "        {",
                        "            hull_gift = GalaxyStar(i);",
                        "            if(StarOwner(hull_gift)) continue; //Не в доминаторских системах",
                        "            for(j = 0; j < StarPlanets(hull_gift); j = j + 1)",
                        "            {",
                        "                dword planet = StarPlanets(hull_gift, j);",
                        "                if(PlanetOwner(planet) != ExpAcrynQuestStatus) continue;",
                        "                RelationToRanger(planet, Player(), RelationToRanger(planet, Player()) - 30);",
                        "                if(RelationToRanger(planet, Player()) < 10) RelationToRanger(planet, Player(), 10);",
                        "            }",
                        "        }",
                        "",
                        "        ReleaseItemFromScript(GetValueFromScript('Mod_ExpAcryn', 'Q_item'));",
                        "        ExpAcrynQuestStatus = 7;",
                        "    }",
                        "}",
                        "DChange(10);",
                        "exit;"
