                        "",
                        "gov_mod = newarray(7);",
                        "gov_mod[0] = CT(\"Script.PC_part0.96\");",
                        "gov_mod[1] = CT(\"Script.PC_part0.95\");",
                        "gov_mod[2] = CT(\"Script.PC_part0.94\");",
                        "gov_mod[3] = CT(\"Script.PC_part0.93\");",
                        "gov_mod[4] = CT(\"Script.PC_part0.92\");",
                        "gov_mod[5] = CT(\"Script.PC_part0.91\");",
                        "gov_mod[6] = CT(\"Script.PC_part0.90\");"
                    ],
                    "#": 15,
                    "Type": "Top",
                    "Parent": -1,
                    "Pos.x": 60,
                    "Pos.y": 635
                },
                {
                    "Name": "",
                    "Code.Type": "Turn",
                    "Code": [
                        "//Игрок вступил в клан - скрипт завершается",
                        "if(ShipInPirateClan(Player()) && !GotoGov()) ShipOut(Player());"
                    ],
                    "#": 16,
                    "Type": "Top",
                    "Parent": -1,
                    "Pos.x": 120,
                    "Pos.y": 635
                },
                {
                    "Name": "",
                    "Code.Type": "DialogBegin",
                    "Code": [
                        "dword ruin = GetShipRuins(Player());",
                        "if(ruin)",
                        "{",
                        "    if(ShipType(ruin) == 'PB')",
                        "    {",
                        "        if(!GotoGov())",
                        "        {",
                        "            if(!ShipInPirateClan(Player()))",
                        "            {",
                        "                int check = 0;",
                        "                if(CurrentMods('Tweaks\\\\RevolutionDelayed'))",
                        "                {",
                        "                    if(GetValueFromScript('Mod_RevolutionDelayed', 'pirates_captured_first_star')) check = 1;",
                        "                }",
                        "                else check = 1;",
                        "",
                        "                if(check)",
                        "                {",
                        "                    if(~StatusPlayer()) //Если игрок по характеру не пират",
                        "                    {",
                        "                        AddDialogInject('DialogPB', CT(\"Script.PC_part0.117\"), CT(\"Script.PC_part0.70\"), 1);",
                        "                    }",
                        "                    else //Если пират",
                        "                    {",
                        "                        AddDialogInject('', CT(\"Script.PC_part0.74\"), '', 10, 1);",
                        "                        AddDialogInject('DialogPirate', Format(CT(\"Script.PC_part0.73\"),\"<0>\",ShipName(Player())), CT(\"Script.PC_part0.72\"), 9, 0);",
                        "",
                        "                        //У игрока появилась возможность приобрести саб-модем",
                        "                        if(PlayerMayTakeSubCrack())",
                        "                        {",
                        "                            AddDialogInject('', Format(CT(\"Script.PC_part0.118\"),\"<0>\",SubCrackCost()), '', 8, 0);",
                        "                        }",
                        "                    }",
                        "                }",
                        "            }",
                        "        }",
                        "        else AddDialogOverride('DialogJoinLock', 20000);",
                        "    }",
                        "}"
                    ],
                    "#": 17,
                    "Type": "Top",
                    "Parent": -1,
                    "Pos.x": 180,
                    "Pos.y": 635
                },
