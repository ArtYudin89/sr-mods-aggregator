                    "Pos.y": 585
                },
                {
                    "Name": "",
                    "Code.Type": "DialogBegin",
                    "Code": [
                        "if(ControlledSystems(2)) {",
                        "  if(GetTalkShip() == 0) {",
                        "      if(GetShipRuins(Player()) != 0) {",
                        "          if(ShipType(GetShipRuins(Player())) == 'PB') {",
                        "              AddDialogInject('RelationsFix','',CT(\"Script.Mod_RefPayForPiratesRelations.9\"),10);",
                        "          }",
                        "      }",
                        "  }",
                        "}"
                    ],
                    "#": 6,
                    "Type": "Top",
                    "Parent": -1,
                    "Pos.x": 180,
                    "Pos.y": 585
                },
                {
                    "Name": "",
                    "Code.Type": "Turn",
                    "Code": [
                        "DChange(0);",
                        "exit;"
                    ],
                    "#": 15,
                    "Type": "Top",
                    "Parent": -1,
                    "Pos.x": -20,
                    "Pos.y": 375
                },
                {
                    "Name": "",
                    "Code.Type": "Turn",
                    "Code": [
                        "DAdd(0);",
                        "DAdd(1);"
                    ],
                    "#": 16,
                    "Type": "Top",
                    "Parent": -1,
                    "Pos.x": -20,
                    "Pos.y": 445
                },
                {
                    "Name": "",
                    "Code.Type": "Turn",
                    "Code": [
                        "DAdd(2);"
                    ],
                    "#": 17,
                    "Type": "Top",
                    "Parent": -1,
                    "Pos.x": 130,
                    "Pos.y": 445
                },
                {
                    "Name": "",
                    "Code.Type": "Turn",
                    "Code": [
                        "money = 0;",
                        "while(1) {",
                        "    money = CountBox('Bm.FormShip2.SortStorageByMoneyA',CT(\"Script.Mod_RefPayForPiratesRelations.13\"),1,100,GalaxyMoney(1,3),1,round(ShipMoney(Player())/GalaxyMoney(1,3)),round(ShipMoney(Player())/GalaxyMoney(1,3)),ShipMoney(Player()));",
                        "    //SFT(money);",
                        "    if(money*GalaxyMoney(1,3) > ShipMoney(Player())) MessageBox(CT(\"Script.Mod_RefPayForPiratesRelations.16\"));",
                        "    else break;",
                        "",
                        "    if(money < 1) break;",
                        "}",
                        "//SFT(money*GalaxyMoney(1,3));",
                        "ShipMoney(Player(),ShipMoney(Player())-(money*GalaxyMoney(1,3)));",
                        "RelationToRanger(PlanetPirateClan(),Player(),RelationToRanger(PlanetPirateClan(),Player())+money);",
                        "ChangeGlobalRelationsShips(Player(),0,2,money,1+2+4+8+16+32,128);",
                        "",
                        "if(money > 30) ChangeGlobalRelationsPlanets(Player(),0,3,10,31);",
                        "if(money > 50) ChangeGlobalRelationsPlanets(Player(),0,3,10,31);",
                        "if(money > 70) ChangeGlobalRelationsPlanets(Player(),0,3,15,31);",
                        "if(money > 90) ChangeGlobalRelationsPlanets(Player(),0,3,20,31);",
                        "",
                        "Sound('Sound.Buy');",
                        "DChange(2);",
                        "exit;"
                    ],
                    "#": 18,
                    "Type": "Top",
                    "Parent": -1,
                    "Pos.x": -20,
                    "Pos.y": 515
                },
