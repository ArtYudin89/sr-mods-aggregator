                    "#": 12,
                    "Msg": "Ну, давайте, сделаем взнос",
                    "AMsg.Num": "0",
                    "_orig_danswer": "DAnswer(CT(\"Script.Mod_RefPayForPiratesRelations.12\"))"
                },
                {
                    "Name": "restart",
