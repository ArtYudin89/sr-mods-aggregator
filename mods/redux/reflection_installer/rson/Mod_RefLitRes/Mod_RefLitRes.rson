                {
                    "Name": "",
                    "Code.Type": "DialogBegin",
                    "Code": [
                        "if(PlayerBridge() == 11) {",
                        "  AddDialogInject('LitRes', '', CT(\"Script.Mod_RefLitRes.0\"), 5);",
                        "}"
                    ],
                    "#": 11,
                    "Type": "Top",
                    "Parent": -1,
