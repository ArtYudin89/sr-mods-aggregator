                    "Code": [
                        "DChange(0);",
                        "exit;"
                    ],
                    "#": 20,
                    "Type": "Top",
                    "Parent": -1,
                    "Pos.x": -20,
                    "Pos.y": 375
                },
                {
                    "Name": "",
                    "Code.Type": "Turn",
                    "Code": [
                        "temp_str = CT('BooksCategory.Book'+GAnswerData+'.Description');",
                        "temp_int = GAnswerData;",
                        "temp_str2 = CT('BooksCategory.Book'+GAnswerData+'.Author');",
                        "DChange(1);",
                        "exit;"
                    ],
                    "#": 21,
                    "Type": "Top",
                    "Parent": -1,
                    "Pos.x": 100,
                    "Pos.y": 375
                },
                {
                    "Name": "",
                    "Code.Type": "Turn",
                    "Code": [
                        "if(GAnswerData >= 1) {",
                        "    temp_int2 = GAnswerData;",
                        "}",
                        "if(GAnswerData == 0) {",
                        "    temp_int2 = CountBox('Bm.ItemsUseless.2Usl_Pilot_s','Выберите нужную страницу',1,CT('BooksCategory.Book'+temp_int+'.PagesCount'));",
                        "}",
                        "DChange(2);",
                        "exit;"
                    ],
                    "#": 22,
                    "Type": "Top",
                    "Parent": -1,
                    "Pos.x": 280,
                    "Pos.y": 375
                },
                {
                    "Name": "",
                    "Code.Type": "Turn",
                    "Code": [
                        "for(i=1;CT('BooksCategory.BooksCount')>i;i=i+1) {",
                        "    InjectAnswer('BookChoosed',CT('BooksCategory.Book'+i),i);",
                        "}",
                        "DAdd(0);"
                    ],
                    "#": 23,
                    "Type": "Top",
                    "Parent": -1,
                    "Pos.x": -20,
                    "Pos.y": 445
                },
                {
                    "Name": "",
                    "Code.Type": "Turn",
                    "Code": [
                        "AddDialogInject('LitRes', '', CT(\"Script.Mod_RefLitRes.4\"), 99);",
                        "",
                        "AddDialogInject('Reading', '', CT(\"Script.Mod_RefLitRes.3\"), 1,1);",
                        "",
                        "AddDialogInject('Reading', '', CT(\"Script.Mod_RefLitRes.2\"), 2,0);",
                        "",
                        "StartMusic('Music.Quest');"
                    ],
                    "#": 24,
                    "Type": "Top",
                    "Parent": -1,
                    "Pos.x": 130,
                    "Pos.y": 445
                },
                {
                    "Name": "",
                    "Code.Type": "Turn",
                    "Code": [
                        "if(temp_int2 != 9999)",
                        "{",
                        "    temp_str=CT('BooksCategory.Book'+temp_int+'.PagesCount');",
                        "    temp_int3=temp_str;",
                        "    if(temp_int3>GAnswerData) {",
                        "        InjectAnswer('Reading',CT(\"Script.Mod_RefLitRes.7\"),GAnswerData+1);",
                        "        InjectAnswer('Reading',CT(\"Script.Mod_RefLitRes.7\"),GAnswerData+1);",
                        "        InjectAnswer('Reading',CT(\"Script.Mod_RefLitRes.7\"),GAnswerData+1);",
                        "    }",
                        "    if((GAnswerData-1)>0) {",
                        "        InjectAnswer('Reading',CT(\"Script.Mod_RefLitRes.6\"),GAnswerData-1);",
                        "        InjectAnswer('Reading',CT(\"Script.Mod_RefLitRes.6\"),GAnswerData-1);",
                        "        InjectAnswer('Reading',CT(\"Script.Mod_RefLitRes.6\"),GAnswerData-1);",
                        "    }",
                        "}",
                        "AddDialogInject('LitRes', '', CT(\"Script.Mod_RefLitRes.4\"), 99);"
                    ],
                    "#": 25,
