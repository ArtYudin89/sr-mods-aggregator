                        "ArrayDelete(bonkFlag,h);",
                        "ArrayDelete(timer,h);",
                        "ArrayDelete(namesArr,h);",
                        "ArrayDelete(penya,h);",
                        "ArrayDelete(strsArchive,y);",
                        "TotalEquip = TotalEquip - 1;",
                        "Sound('Sound.Sell');",
                        "if(TotalEquip == 0) ShipCustomShipInfoDescription(Player(),'RefRentInfo','NoShow');",
                        "for(z = 1; z < ArrayDim(timer); z = z + 1) {",
                        "    infoStr = infoStr + strsArchive[z];",
                        "}",
                        "ShipCustomShipInfoDescription(Player(),'RefRentInfo',infoStr);",
                        "DChange(16);",
                        "exit;"
