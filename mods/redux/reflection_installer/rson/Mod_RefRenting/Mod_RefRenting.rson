                {
                    "Name": "",
                    "Code.Type": "Turn",
                    "Code": [
                        "if(!ShipIsTakeoff(Player())) {",
                        "    for(i=GalaxyEvents()-1; i>=0; i=i-1) {",
                        "        if(GalaxyEventDate(i) < CurTurn()) break;",
                        "        if(GalaxyEventType(i)=='RuinsDestroyed') {",
                        "            if(GalaxyEventData(i,0) != t_BK) continue;",
                        "            BKcount = BKcount - 1;",
                        "        }",
                        "        if(GalaxyEventType(i)=='RuinsCreated') {",
                        "            if(GalaxyEventData(i,0) != t_BK) continue;",
                        "            BKcount = BKcount + 1;",
                        "        }",
                        "    }",
                        "}",
                        "for(y = 1; y < ArrayDim(timer); y = y + 1) {",
                        "    if(timer[y] > 0) {",
                        "        timer[y] = timer[y] - 1;",
                        "    }",
                        "    else if(bonkFlag[y] == 0) {",
                        "        bonk[y] = 60;",
                        "        if(PlayerMedPolicy() > 0) {",
                        "            bonk[y] = bonk[y] + 30;",
                        "            Ether(0,'',CT(\"Script.Mod_RefRenting.173\"));",
                        "        }",
                        "        else Ether(0,'',CT(\"Script.Mod_RefRenting.172\"));",
                        "        bonkFlag[y] = 1;",
                        "    }",
                        "    if(bonk[y] != 0 && bonkFlag[y] == 1) bonk[y] = bonk[y] - 1;",
                        "    if(bonk[y] == 0 && bonkFlag[y] == 1) {",
                        "        Alarm = Alarm + 1;",
                        "        Ether(0,'',CT(\"Script.Mod_RefRenting.171\"));",
                        "        bonkFlag[y] = 2;",
                        "        penya[y] = 3500;",
                        "    }",
                        "    if(bonkFlag[y] == 2) {",
                        "        if(bonk[y] == 180) {",
                        "            if(PlayerDeposit() > 0) {",
                        "                Ether(0,'',CT(\"Script.Mod_RefRenting.170\"));",
                        "                if(PlayerDeposit() > 0) bonk[y] = 0;",
                        "                if(PlayerDeposit() > 150000) bonk[y] = -60;",
                        "                if(PlayerDeposit() > 400000) bonk[y] = -90;",
                        "                if(PlayerDeposit() > 1000000) bonk[y] = -120;",
                        "                if(PlayerDeposit() > 3000000) bonk[y] = -150;",
                        "                PlayerDeposit(1);",
                        "                PlayerDepositPercent(0);",
                        "            }",
                        "            else {",
                        "                Ether(0,'',CT(\"Script.Mod_RefRenting.169\"));",
                        "                bonkFlag[y] = 3;",
                        "                bonk[y] = 0;",
                        "                if(PlayerMedPolicy() > 0) PlayerMedPolicy(0);",
                        "            }",
                        "        }",
                        "        bonk[y] = bonk[y] + 1;",
                        "    }",
                        "    if(bonkFlag[y] == 3) {",
                        "        if(bonk[y] == 90) {",
                        "            Ether(0,'',CT(\"Script.Mod_RefRenting.168\"));",
                        "            penya[y] = penya[y] + 7500;",
                        "            if(ShipRank < 6) {",
                        "                ChangeGlobalRelationsPlanets(Player(),0,3,-25,31);",
                        "                ChangeGlobalRelationsShips(Player(),0,0,30,1,31);",
                        "                ChangeGlobalRelationsShips(Player(),0,3,-20,4,31);",
                        "                ChangeGlobalRelationsShips(Player(),0,3,-30,8,31);",
                        "                ChangeGlobalRelationsShips(Player(),0,3,-30,16,31);",
                        "                ChangeGlobalRelationsShips(Player(),0,3,-30,32,31);",
                        "            }",
                        "            else {",
                        "                ChangeGlobalRelationsPlanets(Player(),0,3,-15,31);",
                        "                ChangeGlobalRelationsShips(Player(),0,0,40,1,31);",
                        "                ChangeGlobalRelationsShips(Player(),0,3,-10,4,31);",
                        "                ChangeGlobalRelationsShips(Player(),0,3,-20,8,31);",
                        "                ChangeGlobalRelationsShips(Player(),0,3,-20,16,31);",
                        "                ChangeGlobalRelationsShips(Player(),0,3,-20,32,31);",
                        "            }",
                        "            ConChangeRelationToRanger(StarToCon(ShipStar(Player())),Player(),-30);",
                        "            if(PirateWin() != 3 && PirateWin() != 4) {",
                        "                if(GetShipPirateRank < 6) ConChangeRelationToRanger(StarToCon(PlanetToStar(PlanetPirateClan())),Player(),-60);",
                        "            }",
                        "        }",
                        "    }",
                        "    if(ItemDestroy(IdToItem(EquipArr[y]))) {",
                        "        Alarm = Alarm + 1;",
                        "        SlomFlag = SlomFlag + 1;",
                        "        temp_money = ItemCost(IdToItem(EquipArr[y])) * 2;",
                        "        temp_money = temp_money + payment[y] + penya[y];",
                        "        Ether(0,'',Format(CT(\"Script.Mod_RefRenting.167\"),\"<0>\",temp_money));",
                        "        moneySlomano = moneySlomano + temp_money;",
                        "        ArrayDelete(strsArchive,y);",
                        "        if(ArrayDim(timer) > 1) {",
                        "            for(z = 1; z < ArrayDim(timer); z = z + 1) {",
                        "                infoStr = infoStr + strsArchive[z];",
                        "            }",
                        "            ShipCustomShipInfoDescription(Player(),'RefRentInfo',infoStr);",
                        "        }",
                        "        else ShipCustomShipInfoDescription(Player(),'RefRentInfo','NoShow');",
                        "        ArrayDelete(payment,y);",
                        "        ArrayDelete(EquipArr,y);",
                        "        ArrayDelete(bonk,y);",
                        "        ArrayDelete(bonkFlag,y);",
                        "        ArrayDelete(timer,y);",
                        "        ArrayDelete(namesArr,y);",
                        "        ArrayDelete(penya,y);",
                        "        TotalEquip = TotalEquip - 1;",
                        "    }",
                        "}",
                        "if(landingFlag == 1) {",
                        "    SpecialToEquipment(FindBonusByNameInCfg('Ref_RentAcryn'),IdToItem(tempid));",
                        "    ModuleToEquipment(FindBonusByNameInCfg('Ref_RentMM'),IdToItem(tempid));",
                        "    landingFlag = 0;",
                        "}"
                    ],
