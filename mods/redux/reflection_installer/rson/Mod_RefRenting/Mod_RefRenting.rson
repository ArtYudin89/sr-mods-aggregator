                        "    //",
                        "    if(i == -1 || j == -1 || k == -1 || f == -1 || w == -1) returnFlag = 1;",
                        "    //",
                        "    //Костылёнок на случай, если игрок прожмёт крестик    /\\\\ /\\\\ /\\\\",
                        "    //                                                    || || ||",
