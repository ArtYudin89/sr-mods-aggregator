                        "}",
                        "else GetItemFromShip(Player(),IdToItem(EquipArr[h]));",
                        "FreeItem(IdToItem(EquipArr[h]));",
                        "ArrayDelete(payment,h);",
                        "ArrayDelete(EquipArr,h);",
