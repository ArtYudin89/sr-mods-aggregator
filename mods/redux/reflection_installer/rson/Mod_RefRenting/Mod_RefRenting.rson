                        "        infoStr = namesArr[z];",
                        "    }",
                        "    ShipCustomShipInfoDescription(Player(),'RefRentInfo',infoStr);",
                        "}",
                        "else ShipCustomShipInfoDescription(Player(),'RefRentInfo','NoShow');",
                        "if(ShipEqInSlot(Player(),ItemType(IdToItem(EquipArr[h]))) == IdToItem(EquipArr[h])) DeleteEquipment(Player(),ItemType(IdToItem(EquipArr[h])));",
                        "else if(ItemType(IdToItem(EquipArr[h])) > 49 && ItemType(IdToItem(EquipArr[h])) < 69) {",
                        "    if(ShipEqInSlot(Player(),t_Weapon1,1) == IdToItem(EquipArr[h])) DeleteEquipment(Player(),ItemType(IdToItem(EquipArr[h])));",
