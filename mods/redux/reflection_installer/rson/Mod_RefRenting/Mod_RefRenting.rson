                        "if(j == 1) tempItem = CreateEquipment(EquipType,Rnd(30,55),i,Maloc);",
                        "if(j == 2) tempItem = CreateEquipment(EquipType,Rnd(25,40),i,Peleng);",
                        "if(j == 3) tempItem = CreateEquipment(EquipType,Rnd(25,40),i,People);",
                        "if(j == 4) tempItem = CreateEquipment(EquipType,Rnd(25,35),i,Gaal);",
                        "if(j == 5) tempItem = CreateEquipment(EquipType,Rnd(25,40),i,Fei);",
                        "if(j == 6) tempItem = CreateEquipment(EquipType,Rnd(25,45),i,PirateClan);",
                        "tempid = Id(tempItem);",
                        "dayss = dayss * 30;",
                        "ArrayAdd(timer,dayss);",
                        "if(ShipCustomShipInfoDescription(Player(),'RefRentInfo') != 'NoShow') infoStr = ShipCustomShipInfoDescription(Player(),'RefRentInfo');",
                        "infoStr = infoStr + Format('<br>') + Name(tempItem);",
                        "infoStr = infoStr + CT(\"Script.Mod_RefRenting.177\") + dayss + ' ' + CT(\"Script.Mod_RefRenting.182\")+ ' ' + GameDateTxtByTurn(CurTurn()+dayss) + ')';",
                        "ArrayAdd(namesArr,Name(tempItem));",
                        "ArrayAdd(strsArchive,Format('<br>') + Name(tempItem) + ' ' + CT(\"Script.Mod_RefRenting.177\") + ' ' + dayss+ ' ' + CT(\"Script.Mod_RefRenting.181\") + ' ' + GameDateTxtByTurn(CurTurn()+dayss) + ')');",
                        "ShipCustomShipInfoDescription(Player(),'RefRentInfo',infoStr);",
                        "SpecialToEquipment(FindBonusByNameInCfg('Ref_RentAcryn'),tempItem);",
                        "ModuleToEquipment(tdwd,tempItem);",
                        "ArrayAdd(EquipArr,tempid);",
                        "ArrayAdd(penya,0);",
                        "if(k == 2) fg = monthly * dayss / 30;",
                        "if(k == 3) fg = arendnaya + (monthly * dayss / 30) + 3500;",
                        "ArrayAdd(payment,fg);",
                        "ArrayAdd(bonk,0);",
                        "ArrayAdd(bonkFlag,0);",
                        "ArrayClear(temp_arr1);",
                        "ArrayClear(temp_arr5);",
                        "ShipMoney(Player(),ShipMoney(Player()) - money);",
                        "AddItemToShip(Player(),tempItem);",
                        "Sound('Sound.Sell');",
                        "DChange(4);",
                        "exit;"
