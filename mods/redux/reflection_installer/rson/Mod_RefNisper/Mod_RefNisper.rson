                },
                {
                    "Name": "restart",
                    "Pos.x": 1680,
                    "Pos.y": 1165,
                    "Type": "TDialogAnswer",
                    "Parent": -1,
                    "#": 419,
                    "Msg": "Я пока подумаю",
