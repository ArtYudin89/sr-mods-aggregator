                        "else tstr = CT(\"Script.Mod_RefNisper.516\")+' ' + GroupCount(ShipyardsGroup) +' '+CT(\"Script.Mod_RefNisper.515\");",
                        "DChange(149);",
                        "exit;"
                    ],
                    "#": 622,
                    "Type": "Top",
                    "Parent": -1,
                    "Pos.x": 1510,
                    "Pos.y": 675
                },
                {
                    "Name": "",
                    "Code.Type": "Turn",
                    "Code": [
                        "QuestFlag = 0;",
                        "QuestDays = 0;",
                        "dword item = IdToItem(DocsId);",
                        "NoDropItem(item,0);",
                        "FreeItem(GetItemFromShip(Player(),item));",
                        "",
                        "Sound('Sound.QuestOk');",
                        "",
                        "domLevel=2;",
                        "curDomLevel=domLevel+1;",
                        "researched=0;",
                        "daysForResearch=1;",
                        "needRen=1;",
                        "completeEther=0;",
                        "completeTask=0;",
                        "CustomEther('NisperEther',4,'NisperFlyQuest',CT(\"Script.Mod_RefNisper.456\")+' '+Name(IdToPlanet(QuestPlanId)));",
                        "CustomEther('NisperEther', 7, '', CT(\"Script.Mod_RefNisper.576\"));",
                        "",
                        "reward=CreateQuestItem('NisperBeacon',5);",
                        "ItemSize(reward,14);",
                        "EqCustomFaction(reward,'SubFaction.Nisper');",
                        "AddItemToStorage(IdToShip(DBId),reward);",
                        "DChange(153);",
                        "exit;"
                    ],
