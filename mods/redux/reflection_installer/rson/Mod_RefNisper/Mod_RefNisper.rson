                },
                {
                    "Name": "",
                    "Pos.x": 360,
                    "Pos.y": 1240,
                    "Type": "TDialogAnswer",
                    "Parent": -1,
                    "#": 453,
                    "Msg": "Отлично... Может быть, вас, тогда, довезти?",
                    "AMsg.Num": "78",
                    "_orig_danswer": "DAnswer(CT(\"Script.Mod_RefNisper.228\"))"
