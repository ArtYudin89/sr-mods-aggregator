                        "      0.30, t_Weapon5,",
                        "      0.15, t_Weapon8",
                        "    );",
                        "  }",
                        "  else if(level==4){",
                        "    eq=choice5(",
                        "      0.10, t_Weapon1,",
                        "      0.40, t_Weapon3,",
                        "      0.30, t_Weapon5,",
                        "      0.05, t_Weapon7,",
                        "      0.15, t_Weapon8",
                        "    );",
                        "  }",
                        "  else if(level==5){",
                        "    eq=choice5(",
                        "      0.5, t_Weapon1,",
                        "      0.35, t_Weapon3,",
                        "      0.35, t_Weapon5,",
                        "      0.10, t_Weapon7,",
                        "      0.15, t_Weapon8",
                        "    );",
                        "  }",
                        "  else if(level==6){",
                        "    eq=choice4(",
                        "      0.35, t_Weapon3,",
                        "      0.40, t_Weapon5,",
                        "      0.10, t_Weapon7,",
                        "      0.15, t_Weapon8",
                        "    );",
                        "  }",
                        "  else if(level==7){",
                        "    eq=choice5(",
                        "      0.30, t_Weapon3,",
                        "      0.40, t_Weapon5,",
                        "      0.10, t_Weapon7,",
                        "      0.15, t_Weapon8,",
                        "      0.05, t_Weapon9",
                        "    );",
                        "  }",
                        "  else if(level==8){",
                        "    eq=choice5(",
                        "      0.25, t_Weapon3,",
                        "      0.40, t_Weapon5,",
                        "      0.15, t_Weapon7,",
                        "      0.15, t_Weapon8,",
                        "      0.05, t_Weapon9",
                        "    );",
                        "  }",
                        "  else if(level==9){",
                        "    eq=choice5(",
                        "      0.20, t_Weapon3,",
                        "      0.40, t_Weapon5,",
                        "      0.15, t_Weapon7,",
                        "      0.20, t_Weapon8,",
                        "      0.05, t_Weapon9",
                        "    );",
                        "  }",
                        "  else if(level==10){",
                        "    eq=choice5(",
                        "      0.10, t_Weapon3,",
                        "      0.50, t_Weapon5,",
                        "      0.15, t_Weapon7,",
                        "      0.20, t_Weapon8,",
                        "      0.05, t_Weapon9",
                        "    );",
                        "  }",
                        "  else if(level==11){",
                        "    eq=choice5(",
                        "      0.10, t_Weapon3,",
                        "      0.40, t_Weapon5,",
                        "      0.15, t_Weapon7,",
                        "      0.30, t_Weapon8,",
                        "      0.05, t_Weapon9",
                        "    );",
