                        "  nearPlanet=NearCivilPlanet(CurShip);",
                        "  for (i = 0; i <= cShips; i = i + 1) {",
                        "    thisShip = StarShips(star, i);",
                        "    if (ShipInNormalSpace(thisShip)) {",
                        "      bool=GetRelationPlanet(ourPlanet, thisShip) <= 30;",
                        "      if (bool && distance > Dist(CurShip, thisShip) && ShipTypeN(thisShip)!=2) {",
                        "        potentialEnemy = thisShip;",
                        "        distance = Dist(CurShip, thisShip);",
                        "      }",
                        "    }",
                        "  }",
                        "  if (potentialEnemy != 0)",
                        "    ShipSetBad(CurShip, potentialEnemy);",
                        "  OrderLock(CurShip,1);",
                        "  if(ShipGetBad(CurShip)==0&&GetData(2,CurShip)<reloadTime&&needRen==0) {",
                        "    int turnsForComplete=GetData(0, CurShip);",
                        "    if (turnsForComplete < 1) {",
                        "      ugol = 0.01 * Rnd(0, 200);",
                        "      radius = Rnd(PlanetOrbitRadius(StarPlanets(ShipStar(CurShip), 0)) - 50, PlanetOrbitRadius(StarPlanets(ShipStar(CurShip), StarPlanets(ShipStar(CurShip)) - 1)));",
                        "      x = round(sin(ugol * pi) * radius);",
                        "      y = round(cos(ugol * pi) * radius);",
                        "      OrderMove(CurShip, x, y);",
                        "      distance=round(sqrt(sqr(abs(CoordX(CurShip)-x))+sqr(abs(CoordY(CurShip)-y))));",
                        "      int ourShipSpeed=ShipSpeed(CurShip);",
                        "      turnsForComplete=distance/ourShipSpeed+(distance%ourShipSpeed!=0);",
                        "    }",
                        "    SetData(turnsForComplete - 1, 0, CurShip);",
                        "    if(Rnd(1,(1.2-0.4*(bonusGlobal==3))*reloadTime)==1){",
                        "      power=GivePowerKlig(curDomLevel);",
                        "      if(power==1){",
                        "        SpawnTerronHelp(2);",
                        "        SpawnTerronHelp(1);",
                        "        SpawnTerronHelp(1);",
                        "      }",
                        "      else if(power==2){",
                        "        SpawnTerronHelp(4);",
                        "      }",
                        "      else if(power==3){",
                        "        SpawnTerronHelp(3);",
                        "        SpawnTerronHelp(3);",
                        "      }",
                        "      else if(power==4){",
                        "        SpawnTerronHelp(3);",
                        "        SpawnTerronHelp(2);",
                        "        SpawnTerronHelp(2);",
                        "      }",
                        "      else if(power==5){",
                        "        SpawnTerronHelp(5);",
                        "      }",
                        "      else if(power==6){",
                        "        SpawnTerronHelp(1);",
                        "        SpawnTerronHelp(1);",
                        "        SpawnTerronHelp(1);",
                        "        SpawnTerronHelp(2);",
                        "        SpawnTerronHelp(2);",
                        "        SpawnTerronHelp(2);",
                        "      }",
                        "      else if(power==7){",
                        "        SpawnTerronHelp(4);",
                        "        SpawnTerronHelp(4);",
                        "      }",
                        "      else if(power==8){",
                        "        SpawnTerronHelp(4);",
                        "        SpawnTerronHelp(3);",
                        "        SpawnTerronHelp(3);",
                        "      }",
                        "      else if(power==9){",
                        "        SpawnTerronHelp(5);",
                        "        SpawnTerronHelp(2);",
                        "        SpawnTerronHelp(2);",
                        "      }",
                        "      else if(power==10){",
                        "        SpawnTerronHelp(4);",
                        "        SpawnTerronHelp(2);",
                        "        SpawnTerronHelp(2);",
                        "        SpawnTerronHelp(2);",
                        "        SpawnTerronHelp(2);",
                        "      }",
                        "      else if(power==11){",
                        "        SpawnTerronHelp(5);",
                        "        SpawnTerronHelp(3);",
                        "        SpawnTerronHelp(3);",
                        "      }",
                        "    }",
                        "    SetData(GetData(2,CurShip)+1,2,CurShip);",
                        "  }",
                        "  if(ShipGetBad(CurShip)==0&&GetData(2,CurShip)<reloadTime&&needRen==1) {",
                        "    ChangeState(29);",
                        "    exit;",
                        "  }",
                        "  if(ShipGetBad(CurShip)>0) {",
                        "    ChangeState(15);",
                        "    exit;",
                        "  }",
                        "  if(ShipGetBad(CurShip)==0&&GetData(2,CurShip)>=reloadTime) {",
                        "    k=0;",
                        "    targetPlanet=StarPlanets(star,Rnd(0,StarPlanets(star)));",
                        "    while(PlanetOwner(targetPlanet)!=6) {",
                        "        targetPlanet=StarPlanets(star,Rnd(0,StarPlanets(star)));",
                        "        k = k + 1;",
                        "        if(k>100) break;",
                        "    }",
                        "    while(sin(PlanetOrbitalVelocity(targetPlanet)) * PlanetOrbitRadius(targetPlanet) >= ShipSpeed(CurShip) + 100) {",
                        "        targetPlanet=StarPlanets(star,Rnd(0,StarPlanets(star)));",
                        "        k = k + 1;",
                        "        if(k>200) break;",
                        "    }",
                        "    OrderLanding(CurShip,targetPlanet);",
                        "    SetData(ShipTurnBeforeEndOrder(CurShip)+1,0,CurShip);",
                        "    if(k) {",
                        "      ChangeState(17);",
                        "      exit;",
                        "    }",
                        "    if(!k) {",
                        "      SetData(0,0,CurShip);",
                        "      ChangeState(14);",
                        "      exit;",
                        "    }",
                        "  }",
                        "}"
