                {
                    "Name": "",
                    "Code.Type": "Turn",
                    "Code": [
                        "ourItemDomPlayer = GAnswerData;",
                        "if (ItemSubrace(ourItemDomPlayer) == 0)",
                        "  ItemsOnSB[0] = ItemsOnSB[0] + ItemSize(ourItemDomPlayer);",
                        "else if (ItemSubrace(ourItemDomPlayer) == 1)",
                        "  ItemsOnSB[1] = ItemsOnSB[1] + ItemSize(ourItemDomPlayer);",
                        "else",
                        "  ItemsOnSB[2] = ItemsOnSB[2] + ItemSize(ourItemDomPlayer);",
                        "int flag = 1;",
                        "for (i = 1; flag && i < ShipItems(Player()); i = i + 1) {",
                        "  if (ShipItems(Player(), i) == ourItemDomPlayer)",
                        "    flag = 0;",
                        "}",
                        "FreeItem(GetItemFromShip(Player(), i - 1));",
                        "Sound('Sound.Repair');",
                        "if(700 - ItemsOnSB[0] - ItemsOnSB[1] - ItemsOnSB[2] > 0) {",
                        "  DChange(133);",
                        "  exit;",
                        "}",
                        "if(700 - ItemsOnSB[0] - ItemsOnSB[1] - ItemsOnSB[2] <= 0) {",
                        "  planetId = Id(NearCivilPlanet(Player()));",
                        "  dword ourDB = BuildCustomRuins(ShipStar(Player()), 'DB', 2);",
                        "  DBId = Id(ourDB);",
                        "  if(BlockExist('ShipInfo.AddInfo.CustomInfos.ExpBasesAutoUpgradeInfo')) ShipAddCustomShipInfo(ourDB, 'ExpBasesAutoUpgradeInfo', 'NoShow');",
                        "  ShipOwner(ourDB, 3);",
                        "  NoShopUpdate(ourDB,2);",
                        "  ShipPilotRace(ourDB, 3);",
                        "  ShipFace(ourDB, -1);",
                        "  ShipJoin(GroupMainBase, ourDB);",
                        "  ShipCustomFaction(ourDB, 'SubFaction.Nisper');",
                        "  SetName(ourDB,CT('ShipName.SubFaction.DominatorsBase.'+Rnd(1,CT('ShipName.SubFaction.DominatorsBase.Count'))));",
                        "  Chameleon(ourDB, 'Ruins.DB');",
                        "  ",
                        "  if(BlockExist('Script.Mod_EvoDreadnought')){",
                        "    dword DBHull=ShipItems(ourDB,0);",
                        "    ItemSize(DBHull, round(ItemSize(DBHull) * 5));",
                        "    ShipSpecialBonuses(ourDB, bonResistAsteroid, 75);",
                        "    power = round((6 * 4) + (6 * PortionInDiapason(ItemLevel(DBHull), 1, 8, 1, 10)));",
                        "    ItemExtraSpecialsAddByType(DBHull, FindBonusByNameInCfg('EvoArmada_bonWRadius'), power);",
                        "    power = round((0.6 * 5) + (0.6 * PortionInDiapason(ItemLevel(DBHull), 1, 8, 1, 10)));",
                        "    ItemExtraSpecialsAddByType(DBHull, FindBonusByNameInCfg('EvoArmada_bonHull'), power);",
                        "    SetEquipmentStats(DBHull, GetEquipmentStats(DBHull, 0) + 7, 0);",
                        "    HullHP(ourDB, ItemSize(DBHull));",
                        "    ShipSpecialBonuses(ourDB, bonAttacks, 2);",
                        "    ShipAddCustomShipInfo(ourDB, 'EvoArmada_CapitalShipInfos', 'NoShow', 2);",
                        "  }",
                        "  if(BlockExist('Script.Mod_EvoArmada')){",
                        "    DBHull=ShipItems(ourDB,0);",
                        "    ItemSize(DBHull, round(ItemSize(DBHull) * (1.0 + (1.0 * 10))));",
                        "    ShipSpecialBonuses(ourDB, bonResistAsteroid, 75);",
                        "    power = round((6 * 10) + (6 * PortionInDiapason(ItemLevel(DBHull), 1, 8, 1, 10)));",
                        "    ItemExtraSpecialsAddByType(DBHull, FindBonusByNameInCfg('EvoArmada_bonWRadius'), power);",
                        "    power = round((0.6 * 10) + (0.6 * PortionInDiapason(ItemLevel(DBHull), 1, 8, 1, 10)));",
                        "    ItemExtraSpecialsAddByType(DBHull, FindBonusByNameInCfg('EvoArmada_bonHull'), power);",
                        "    SetEquipmentStats(DBHull, GetEquipmentStats(DBHull, 0) + (10 + 5), 0);",
                        "    HullHP(ourDB, ItemSize(DBHull));",
                        "    ShipSpecialBonuses(ourDB, bonAttacks, 4);",
                        "    ShipAddCustomShipInfo(ourDB, 'EvoArmada_CapitalShipInfos', 'NoShow', 4);",
                        "  }",
                        "  ",
                        "  //Создаём инфошки-доки",
                        "  ShipAddCustomShipInfo(ourDB,'RefNisper_Dock1','NoShow');",
                        "  ShipAddCustomShipInfo(ourDB,'RefNisper_Dock2','NoShow');",
                        "  ShipAddCustomShipInfo(ourDB,'RefNisper_Dock3','NoShow');",
                        "  ShipAddCustomShipInfo(ourDB,'RefNisper_Dock4','NoShow');",
                        "  ShipAddCustomShipInfo(ourDB,'RefNisper_Dock5','NoShow');",
                        "  ",
                        "  //Военный-\"владелец\" всех наших доминаторов-\"транклюкаторов\"",
                        "  ourDB=BuyWarrior(NearCivilPlanet(Player()));",
                        "  OrderLock(ourDB,1);",
                        "  OrderNone(ourDB);",
                        "  ShipTechLevelKnowledge(ourDB,8);",
                        "  proprietorId=Id(ourDB);",
                        "  Chameleon(ourDB);",
                        "  ",
                        "  if (ItemsOnSB[0] >= ItemsOnSB[1] && ItemsOnSB[0] >= ItemsOnSB[2]) bonusGlobal = 1;",
                        "  else if (ItemsOnSB[1] >= ItemsOnSB[0] && ItemsOnSB[1] >= ItemsOnSB[2]) bonusGlobal = 2;",
                        "  else if (ItemsOnSB[2] >= ItemsOnSB[1] && ItemsOnSB[2] >= ItemsOnSB[0]) bonusGlobal = 3;",
                        "  else bonusGlobal = 0;",
                        "  DChange(135);",
                        "  exit;",
                        "}"
