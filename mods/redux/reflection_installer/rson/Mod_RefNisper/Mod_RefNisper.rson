                },
                {
                    "Name": "",
                    "Code.Type": "Turn",
                    "Code": [
                        "if(domLevel==1 && !QuestFlag) {",
                        "  dword plan;",
                        "  ArrayDelete(tarr,0);",
                        "  ",
                        "  for(i=0;GalaxyStars()>i;i=i+1) {",
                        "      star = GalaxyStar(i);",
                        "      if(StarOwner(star)) continue;",
                        "      if(!SectorVisible(StarToCon(star))) continue;",
                        "      for(j=0;StarPlanets(star)>j;j=j+1) {",
                        "          plan = StarPlanets(star,j);",
                        "          if(PlanetOwner(plan) > 4) continue;",
                        "          ArrayAdd(tarr,plan);",
                        "      }",
                        "  }",
                        "  ArrayRandomize(50,tarr);",
                        "  ",
                        "  //Хачу третью планету, потому что могу",
                        "  QuestPlanId = Id(tarr[1]);",
                        "  ",
                        "  QuestDays = round((sqrt(Dist2Star(ShipStar(Player()), PlanetToStar(IdToPlanet(QuestPlanId)))))*2,10);",
                        "  DChange(151);",
                        "  exit;",
                        "}",
                        "if(domLevel==3) {",
                        "  if(PirateWin()==0) {",
                        "    power=GalaxyStars();",
                        "    if(~IdToShip(bossId)) {",
                        "        if(ObjectType(IdToShip(bossId)) == 5) {",
                        "            dword bossStar = ShipStar(IdToShip(bossId));",
                        "        }",
                        "        else bossStar = IdToPlanet(planetId);",
                        "    }",
                        "    else bossStar = IdToPlanet(planetId);",
                        "    ourPlanet=PlanetPirateClan();",
                        "    int starPirates=PlanetToStar(ourPlanet);",
                        "    int ourHullSize;",
                        "    for(i = 0; i < power; i = i + 1) {",
                        "        potentialStar = GalaxyStar(i);",
                        "        if(StarOwner(potentialStar) == 0 && BertorStars[i]==0 && potentialStar!=bossStar && !StarEnemyThreatLevel(potentialStar)) {",
                        "            idStarAttackPirates = i;",
                        "        }",
                        "    }",
                        "    if(idStarAttackPirates!=-1){",
                        "        targetStar=GalaxyStar(idStarAttackPirates);",
                        "        int ourI;",
                        "        for(ourI=0;ourI<(4+(bonusGlobal==3)*2);ourI=ourI+1){",
                        "            dom=SpawnDom(1,0);",
                        "            SetData(idStarAttackPirates,1,dom);",
                        "        }",
                        "        for(ourI=0;ourI<(3+(bonusGlobal==3)*2);ourI=ourI+1){",
                        "            dom=SpawnDom(Rnd(2,3),0);",
                        "            SetData(idStarAttackPirates,1,dom);",
                        "        }",
                        "        dom=SpawnDom(5,0);",
                        "        SetData(idStarAttackPirates,1,dom);",
                        "        BertorStars[idStarAttackPirates]=1;",
                        "        NoComeKlingToStar(GalaxyStar(idStarAttackPirates),1);",
                        "        completeTask=2;",
                        "        daysMission=0;",
                        "        daysMissionComplete=50+difficultOfPirates*4;",
                        "        CustomEther('NisperEther',3,'ZelDomiksQuest',Format('Нужно защитить систему <0> и не дать ей перейти в руки пиратского клана до конца передачи информации. Осталось дней: <1>.',\"<0>\",StarName(targetStar),\"<1>\",daysMissionComplete-daysMission));",
                        "        for(i=0;i<difficultOfPirates/2+10;i=i+1){",
                        "            dom=BuyWarrior(ourPlanet,50+20*difficultOfPirates);",
                        "            ourHullSize=300+25*difficultOfPirates;",
                        "            ourHullSize=Rnd(0.7*ourHullSize,1.3*ourHullSize);",
                        "            for(j=0;j<5;j=j+1) ShipRefit(dom,ourHullSize);",
                        "            ShipImproveItems(dom,Rnd(0,difficultOfPirates/2));",
                        "            MakeShipEnterStar(dom,targetStar,starPirates,5);",
                        "            Chameleon(dom);",
                        "        }",
                        "    }",
                        "    if(idStarAttackPirates!=-1) {",
                        "      DChange(32);",
                        "      exit;",
                        "    }",
                        "    if(idStarAttackPirates==-1) {",
                        "      DChange(31);",
                        "      exit;",
                        "    }",
                        "  }",
                        "  if(PirateWin()!=0) {",
                        "    DChange(112);",
                        "    exit;",
                        "  }",
                        "}",
                        "if(domLevel==4) {",
                        "  DChange(33);",
                        "  exit;",
                        "}",
                        "if(domLevel==2) {",
                        "  DChange(38);",
                        "  exit;",
                        "}",
                        "if(domLevel==5) {",
                        "  if(bonusAdd==0) {",
                        "    mMoney=81000+difficultOfBreaks*26335;",
                        "    mNod=945+difficultOfBreaks*283;",
                        "    DChange(41);",
                        "    exit;",
                        "  }",
                        "  if(bonusAdd==1) {",
                        "    power=GalaxyStars();",
                        "    idStarAttackPirates=-1;",
                        "    star = PlanetToStar(IdToPlanet(planetId));",
                        "    bool=0;",
                        "    if(Blazer()){",
                        "        starBlazer = ShipStar(Blazer());",
                        "        bool=1;",
                        "    }",
                        "    else starBlazer = star;",
                        "    if(Terron()){",
                        "        starTerron = ShipStar(Terron());",
                        "        bool=1;",
                        "    }",
                        "    else starTerron = star;",
                        "    if(Keller()) bool=1;",
                        "    if(PirateWin()!=0) bool=0;",
                        "    for(i = 1; bool && idStarAttackPirates == -1 && i < power; i = i + 1) {",
                        "        potentialStar = StarNearbyStars(star,i);",
                        "        if(StarOwner(potentialStar) == 1 && potentialStar!=starBlazer && potentialStar!=starTerron) {",
                        "            idStarAttackPirates = Id(potentialStar)-1;",
                        "        }",
                        "    }",
                        "    if(idStarAttackPirates!=-1) {",
                        "      ourPlanet = PlanetPirateClan();",
                        "      starPirates = PlanetToStar(ourPlanet);",
                        "      targetStar = GalaxyStar(idStarAttackPirates);",
                        "      for(ourI = 0; ourI < (4 + (bonusGlobal == 3) * 2); ourI = ourI + 1) {",
                        "          dom = SpawnDom(Rnd(1, 2), 0);",
                        "          SetData(idStarAttackPirates, 1, dom);",
                        "      }",
                        "      for(ourI = 0; ourI < (3 + (bonusGlobal == 3)*2); ourI = ourI + 1) {",
                        "          dom = SpawnDom(Rnd(3, 4), 0);",
                        "          SetData(idStarAttackPirates, 1, dom);",
                        "      }",
                        "      for(ourI = 0; ourI < (2 + (bonusGlobal == 3)); ourI = ourI + 1) {",
                        "          dom = SpawnDom(5, 0);",
                        "          SetData(idStarAttackPirates, 1, dom);",
                        "      }",
                        "      dom = SpawnDom(6, 0);",
                        "      SetData(idStarAttackPirates, 1, dom);",
                        "      completeTask = 2;",
                        "      daysMission = 0;",
                        "      daysMissionComplete = 60 + difficultOfPirates * 6;",
                        "      CustomEther('NisperEther',3,'ZelDomiksQuest',Format(CT(\"Script.Mod_RefNisper.543\"),\"<0>\",StarName(targetStar),\"<1>\",daysMissionComplete-daysMission));",
                        "      for(i = 0; i < difficultOfPirates*2 + 30; i = i + 1) {",
                        "          dom = BuyWarrior(ourPlanet, 75 + 25 * difficultOfPirates);",
                        "          ourHullSize = 350 + 30 * difficultOfPirates;",
                        "          ourHullSize = Rnd(0.7 * ourHullSize, 1.3 * ourHullSize);",
                        "          for(j = 0; j < 5; j = j + 1) ShipRefit(dom, ourHullSize);",
                        "          ShipImproveItems(dom, Rnd(0, difficultOfPirates / 2)+2);",
                        "          MakeShipEnterStar(dom, targetStar, starPirates, 1);",
                        "          Chameleon(dom);",
                        "      }",
                        "      ",
                        "      //Создаём группу тех самых \"свободных рейнджеров\", а также отряд военных (типа КВСМК подсобил, даже вон кораблей дал)",
                        "      for(i=0;i<Rnd(3,5);i=i+1) {",
                        "          dom = BuyWarrior(IdToPlanet(planetId));",
                        "          for(j = 0; j < 5; j = j + 1) ShipRefit(dom,400,300);",
                        "          ShipImproveItems(dom,1);",
                        "          ShipJoin(GroupWarriors,dom);",
                        "          SetData(idStarAttackPirates, 1, dom);",
                        "      }",
                        "      for(i=0;i<Rnd(1,4);i=i+1) {",
                        "          //Меняем расу планеты, чтобы не было чрезмерного единообразия рейнджеров",
                        "          j = PlanetRace(IdToPlanet(planetId));",
                        "          PlanetRace(IdToPlanet(planetId),Rnd(0,4));",
                        "          PlanetOwner(IdToPlanet(planetId),PlanetRace(IdToPlanet(planetId)));",
                        "          //Создаём рейнджера",
                        "          dom = BuyRanger(IdToPlanet(planetId));",
                        "          for(j = 0; j < 5; j = j + 1) ShipRefit(dom,400,350);",
                        "          ShipImproveItems(dom,7);",
                        "          ShipJoin(GroupRangers,dom);",
                        "          SetData(idStarAttackPirates, 1, dom);",
                        "          //Возвращаем расу планеты",
                        "          PlanetRace(IdToPlanet(planetId),j);",
                        "          PlanetOwner(IdToPlanet(planetId),j);",
                        "      }",
                        "      DChange(42);",
                        "      exit;",
                        "    }",
                        "    if(idStarAttackPirates==-1) {",
                        "      DChange(115);",
                        "      exit;",
                        "    }",
                        "  }",
                        "  if(bonusAdd==2) {",
                        "    numNeutralPlanets = 3 + difficultOfLucky / 2;",
                        "    numItems = numNeutralPlanets;",
                        "    idUselessItem = newarray(numNeutralPlanets);",
                        "    idNeutralPlanets=newarray(numNeutralPlanets);",
                        "    maxNeutralPlanets = 4 + difficultOfLucky;",
                        "    idUselessItem[0] = 0;",
                        "    idUselessItem[numNeutralPlanets - 1] = maxNeutralPlanets;",
                        "    numNeutralPlanets = numNeutralPlanets - 2;",
                        "    for (j = 1; numNeutralPlanets > 0;) {",
                        "      random = Rnd(1, maxNeutralPlanets - 1);",
                        "      bool = 1;",
                        "      for (i = 0; bool && i < numItems; i = i + 1) {",
                        "        if (random == idUselessItem[i])",
                        "          bool = 0;",
                        "      }",
                        "      if (bool) {",
                        "        idUselessItem[j] = random;",
                        "        numNeutralPlanets = numNeutralPlanets - 1;",
                        "        j = j + 1;",
                        "      }",
                        "    }",
                        "    star = PlanetToStar(IdToPlanet(planetId));",
                        "    for (i = 0; i < numItems; i = i + 1) {",
                        "      j = idUselessItem[i];",
                        "      targetStar = StarNearbyStars(star, j);",
                        "      ourPlanet = -1;",
                        "      while (ourPlanet == -1) {",
                        "        random = Rnd(0, StarPlanets(targetStar) - 1);",
                        "        if(PlanetOwner(StarPlanets(targetStar, random)) == None) ourPlanet = StarPlanets(targetStar, random);",
                        "      }",
                        "      idNeutralPlanets[i]=Id(ourPlanet);",
                        "      Ether(0, '', Format('<0>',\"<0>\",PlanetName(ourPlanet)));",
                        "      dword ourUselessItem = CreateQuestItem('Usl_24');",
                        "      SetName(ourUselessItem, CT(\"Script.Mod_RefNisper.542\"));",
                        "      UselessItemText(ourUselessItem, CT(\"Script.Mod_RefNisper.541\"));",
                        "      ItemSize(ourUselessItem, 15 + difficultOfLucky * 3);",
                        "      ItemOwner(ourUselessItem, 7);",
                        "      AddItemToPlanet(ourPlanet, ourUselessItem);",
                        "      idUselessItem[i] = Id(ourUselessItem);",
                        "    }",
                        "    numNeutralPlanets=0;",
                        "    completeTask = 2;",
                        "    CustomEther('NisperEther',3,'ZelDomiksQuest',Format(CT(\"Script.Mod_RefNisper.513\"),\"<0>\",numItems,\"<1>\",numNeutralPlanets));",
                        "    DChange(45);",
                        "    exit;",
                        "  }",
                        "  if(bonusAdd==3) {",
                        "    DChange(48);",
                        "    exit;",
                        "  }",
                        "}",
                        "if(domLevel==6) {",
                        "  DChange(51);",
                        "  exit;",
                        "}",
                        "if(domLevel==8) {",
                        "  DChange(55);",
                        "  exit;",
                        "}",
                        "if(domLevel==7) {",
                        "  DChange(98);",
                        "  exit;",
                        "}",
                        "if(domLevel==9) {",
                        "  if(bonusAdd==0||bonusAdd==3) {",
                        "    mMoney=218700+difficultOfBreaks*71104;",
                        "    mNod=2551+difficultOfBreaks*764;",
                        "    DChange(101);",
                        "    exit;",
                        "  }",
                        "  if(bonusAdd==2) {",
                        "    DChange(107);",
                        "    exit;",
                        "  }",
                        "  if(bonusAdd==1) {",
                        "    Sound('Fight');",
                        "    DChange(102);",
                        "    exit;",
                        "  }",
                        "}"
                    ],
