                    "Code": [
                        "QuestFlag = 1;",
                        "dword item = CreateQuestItem('Usl_PTQ68');",
                        "UselessItemText(item,CT(\"Script.Mod_RefNisper.570\"));",
                        "//LinkItemToScript(item,QuestItem);",
                        "DocsId = Id(item);",
                        "AddItemToShip(Player(),item);",
                        "NoDropItem(item,1);",
                        "ItemCost(item,GalaxyMoney(4,4));",
                        "",
                        "CustomEther('NisperEther',3,'NisperFlyQuest',CT(\"Script.Mod_RefNisper.456\")+' '+Name(IdToPlanet(QuestPlanId))+' '+CT(\"Script.Mod_RefNisper.458\")+' '+QuestDays+' '+CT(\"Script.Mod_RefNisper.457\"),Name(IdToPlanet(QuestPlanId)));",
                        "Sound('Sound.NewMsg');",
                        "DChange(152);",
                        "exit;"
