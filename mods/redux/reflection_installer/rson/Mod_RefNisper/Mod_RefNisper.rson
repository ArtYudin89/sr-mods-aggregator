                    ],
                    "#": 586,
                    "Type": "Top",
                    "Parent": -1,
                    "Pos.x": 2800
                },
                {
                    "Name": "",
                    "Code.Type": "Turn",
                    "Code": [
                        "if(GetShipRuins(CurShip)) {",
                        "  OrderLock(CurShip,1);",
                        "  ShipDestroy(CurShip);",
                        "}",
                        "if(ShipInNormalSpace(CurShip)) {",
                        "  potentialEnemy = 0;",
                        "  distance = 100000;",
                        "  star = ShipStar(CurShip);",
                        "  cShips=StarShips(star);",
                        "  ourPlanet=IdToPlanet(planetId);",
                        "  nearPlanet=NearCivilPlanet(CurShip);",
                        "  myFather=IdToShip(GetData(1,CurShip));",
                        "  OrderForsage(CurShip,0);",
                        "  for(i = 0; i <= cShips; i = i + 1) {",
                        "      thisShip = StarShips(star, i);",
                        "      if(ShipInNormalSpace(thisShip)) {",
                        "          bool=GetRelationPlanet(ourPlanet, thisShip) <= 30;",
                        "          if(bool && distance > Dist(CurShip, thisShip) && ShipTypeN(thisShip)!=2) {",
                        "              potentialEnemy = thisShip;",
                        "              distance = Dist(CurShip, thisShip);",
                        "          }",
                        "      }",
                        "  }",
                        "  if(potentialEnemy != 0) ShipSetBad(CurShip, potentialEnemy);",
                        "  OrderLock(CurShip,1);",
                        "  if(myFather) {",
                        "    if(ShipGetBad(CurShip)>0) {",
                        "      ChangeState(34);",
                        "      exit;",
                        "    }",
                        "    if(ShipGetBad(CurShip)==0) {",
                        "      if(Dist(myFather,star)<PlanetOrbitRadius(StarPlanets(ShipStar(CurShip),0))+150) {",
                        "        OrderLanding(CurShip,myFather);",
                        "      }",
                        "      if(Dist(myFather,star)>=PlanetOrbitRadius(StarPlanets(ShipStar(CurShip),0))+150) {",
                        "        OrderFollowShip(CurShip,myFather,1);",
                        "      }",
                        "    }",
                        "  }",
                        "  if(!myFather) {",
                        "    ShipDeleteCustomShipInfo(CurShip,'ZelDomiks_KligsDeath');",
                        "    ShipDeleteCustomShipInfo(CurShip,'ZelDomiks_KligsSuicide');",
                        "    ShipJoin(domiks,CurShip);",
                        "  }",
                        "}"
                    ],
                    "#": 587,
                    "Type": "Top",
                    "Parent": -1,
                    "Pos.x": 2880
                },
                {
                    "Name": "",
                    "Code.Type": "Turn",
                    "Code": [
                        "potentialEnemy = 0;",
                        "distance = 100000;",
                        "star = ShipStar(CurShip);",
                        "ourPlanet=IdToPlanet(planetId);",
                        "nearPlanet=NearCivilPlanet(CurShip);",
                        "for(i = 0; i <= cShips; i = i + 1) {",
                        "    thisShip = StarShips(star, i);",
                        "        if(ShipInNormalSpace(thisShip)) {",
                        "        bool=GetRelationPlanet(ourPlanet, thisShip) <= 30;",
                        "        if(bool && distance > Dist(CurShip, thisShip) && ShipTypeN(thisShip)!=2) {",
                        "            potentialEnemy = thisShip;",
                        "            distance = Dist(CurShip, thisShip);",
                        "        }",
                        "    }",
                        "}",
                        "if(potentialEnemy != 0) ShipSetBad(CurShip, potentialEnemy);",
                        "potentialEnemy=ShipGetBad(CurShip);",
                        "if(!ShipInNormalSpace(potentialEnemy)) {",
                        "  ShipSetBad(CurShip,0);",
                        "  ChangeState(33);",
                        "  exit;",
                        "}",
                        "if(ShipInNormalSpace(potentialEnemy)) {",
                        "  SetData(0, 0, CurShip);",
                        "  if(ChanceToWin(CurShip,potentialEnemy,1) < 0.2 && Dist(CurShip,potentialEnemy) <= 0.66*ShipSpeed(CurShip)){",
                        "      OrderFollowShip(CurShip,potentialEnemy,3);",
                        "      OrderForsage(CurShip,1);",
                        "      ShipAddCustomShipInfo(CurShip,'ZelDomiks_KligsSuicide','NoShow',Id(potentialEnemy));",
                        "  }",
                        "  else OrderFollowShip(CurShip,potentialEnemy,1);",
                        "}"
