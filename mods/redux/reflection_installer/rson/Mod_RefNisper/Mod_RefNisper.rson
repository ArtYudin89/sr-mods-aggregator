                    "Type": "TDialogAnswer",
                    "Parent": -1,
                    "#": 481,
                    "Msg": "То есть вы согласны?",
                    "AMsg.Num": "106",
                    "_orig_danswer": "DAnswer(CT(\"Script.Mod_RefNisper.244\"))"
                },
                {
                    "Name": "",
