                        "          else if(nameCustomShip==''&&ShipOwner(potentialEnemy)==7)",
                        "            pointsStar=pointsStar+0.7*ChanceToWin(potentialEnemy,IdToShip(bossId),1);",
                        "          else",
                        "            pointsStar=pointsStar+ChanceToWin(potentialEnemy,IdToShip(bossId),1);",
                        "        }",
                        "      }",
                        "      else if(StarOwner(possibleStar)==1){",
