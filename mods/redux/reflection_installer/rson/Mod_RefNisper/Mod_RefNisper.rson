                        "  if(ItemOwner(ourItemDomPlayer)==5&&!ItemIsInUse(ourItemDomPlayer)&&!ItemIsInSet(ourItemDomPlayer)){",
                        "    bool=1;",
                        "    InjectAnswer('dGiveItem',ItemFullName(ourItemDomPlayer)+Format(' (<0> cr)',\"<0>\",ItemCost(ourItemDomPlayer)/2),ourItemDomPlayer);",
                        "    DAddText(''+j+') '+ItemFullName(ourItemDomPlayer)+Format(' (<0> cr)',\"<0>\",ItemCost(ourItemDomPlayer)/2)+CT(\"Script.Mod_RefNisper.83\"));",
                        "    j=j+1;",
                        "  }",
                        "}",
                        "if(bool) DAddText(CT(\"Script.Mod_RefNisper.519\"));",
                        "else DAddText(CT(\"Script.Mod_RefNisper.518\"));",
                        "DAdd(5);"
