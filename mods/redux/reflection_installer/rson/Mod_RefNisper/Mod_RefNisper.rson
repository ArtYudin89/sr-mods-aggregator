                {
                    "Name": "",
                    "Code.Type": "Turn",
                    "Code": [
                        "robotsReady=1;",
                        "if(difficultOfMissions==1) StartRobots('Mods\\\\Reflection\\\\RefNisper\\\\DATA\\\\Map\\\\Start1.cmap',CT('Script.Mod_RefNisper.PlanetaryBattles.Start1'),CT('Script.Mod_RefNisper.PlanetaryBattles.Win1'),CT('Script.Mod_RefNisper.PlanetaryBattles.Lose1'),'','411');",
                        "else if(difficultOfMissions==2) StartRobots('Mods\\\\Reflection\\\\RefNisper\\\\DATA\\\\Map\\\\Start1.cmap',CT('Script.Mod_RefNisper.PlanetaryBattles.Start1'),CT('Script.Mod_RefNisper.PlanetaryBattles.Win1'),CT('Script.Mod_RefNisper.PlanetaryBattles.Lose1'),'','421');",
                        "else if(difficultOfMissions==3) StartRobots('Mods\\\\Reflection\\\\RefNisper\\\\DATA\\\\Map\\\\Start2.cmap',CT('Script.Mod_RefNisper.PlanetaryBattles.Start1'),CT('Script.Mod_RefNisper.PlanetaryBattles.Win1'),CT('Script.Mod_RefNisper.PlanetaryBattles.Lose1'),'','421');",
                        "else if(difficultOfMissions==4) StartRobots('Mods\\\\Reflection\\\\RefNisper\\\\DATA\\\\Map\\\\Start2.cmap',CT('Script.Mod_RefNisper.PlanetaryBattles.Start1'),CT('Script.Mod_RefNisper.PlanetaryBattles.Win1'),CT('Script.Mod_RefNisper.PlanetaryBattles.Lose1'),'','441');",
                        "else if(difficultOfMissions==5) StartRobots('Mods\\\\Reflection\\\\RefNisper\\\\DATA\\\\Map\\\\Start3.cmap',CT('Script.Mod_RefNisper.PlanetaryBattles.Start1'),CT('Script.Mod_RefNisper.PlanetaryBattles.Win1'),CT('Script.Mod_RefNisper.PlanetaryBattles.Lose1'),'','421');",
                        "else if(difficultOfMissions==6) StartRobots('Mods\\\\Reflection\\\\RefNisper\\\\DATA\\\\Map\\\\Start3.cmap',CT('Script.Mod_RefNisper.PlanetaryBattles.Start1'),CT('Script.Mod_RefNisper.PlanetaryBattles.Win1'),CT('Script.Mod_RefNisper.PlanetaryBattles.Lose1'),'','441');",
                        "else if(difficultOfMissions==7) StartRobots('Mods\\\\Reflection\\\\RefNisper\\\\DATA\\\\Map\\\\Start4.cmap',CT('Script.Mod_RefNisper.PlanetaryBattles.Start1'),CT('Script.Mod_RefNisper.PlanetaryBattles.Win1'),CT('Script.Mod_RefNisper.PlanetaryBattles.Lose1'),'','421');",
                        "else if(difficultOfMissions==8) StartRobots('Mods\\\\Reflection\\\\RefNisper\\\\DATA\\\\Map\\\\Start4.cmap',CT('Script.Mod_RefNisper.PlanetaryBattles.Start1'),CT('Script.Mod_RefNisper.PlanetaryBattles.Win1'),CT('Script.Mod_RefNisper.PlanetaryBattles.Lose1'),'','441');",
                        "else if(difficultOfMissions==9) StartRobots('Mods\\\\Reflection\\\\RefNisper\\\\DATA\\\\Map\\\\Start5.cmap',CT('Script.Mod_RefNisper.PlanetaryBattles.Start1'),CT('Script.Mod_RefNisper.PlanetaryBattles.Win1'),CT('Script.Mod_RefNisper.PlanetaryBattles.Lose1'),'','421');",
                        "else if(difficultOfMissions==10) StartRobots('Mods\\\\Reflection\\\\RefNisper\\\\DATA\\\\Map\\\\Start5.cmap',CT('Script.Mod_RefNisper.PlanetaryBattles.Start1'),CT('Script.Mod_RefNisper.PlanetaryBattles.Win1'),CT('Script.Mod_RefNisper.PlanetaryBattles.Lose1'),'','441');",
                        "isStartedDomiks=1;",
                        "FormChange('RuinsTalk');",
                        "",
                        "//Относительно рандомим третий бонус",
                        "int bl = 0;",
                        "int kl = 0;",
                        "int tr = 0;",
                        "for(i=0;GalaxyStars()>i;i=i+1) {",
                        "    if(StarOwner(GalaxyStar(i)) == 1) {",
                        "        if(!StarSeries(GalaxyStar(i))) bl = bl + 1;",
                        "        if(StarSeries(GalaxyStar(i)) == 1) kl = kl + 1;",
                        "        if(StarSeries(GalaxyStar(i)) == 2) tr = tr + 1;",
                        "    }",
                        "}",
                        "random = RndObject(1,100,GetShipRuins(Player()));",
                        "",
                        "if(random < PortionInDiapason(bl,0,ControlledSystems(1),0,100)) bonusBoss=1;",
                        "else if(random > PortionInDiapason(tr+kl+bl,0,ControlledSystems(1),0,100)) bonusBoss=3;",
                        "else bonusBoss=2;",
                        "DChange(144);",
                        "exit;"
                    ],
