                    "Code": [
                        "if(domLevel==8&&completeTask==2) {",
                        "  daysMission=daysMission-1;",
                        "  if(doneMissions[0]==2) missionsStrings[0]=CT(\"Script.Mod_RefNisper.496\")+' '+Name(GalaxyStar(0))+' '+Format(CT(\"Script.Mod_RefNisper.495\"),\"<0>\",m8MalDays);",
                        "  if(doneMissions[4]==2) missionsStrings[4]=Format(CT(\"Script.Mod_RefNisper.494\"),\"<0>\",45+4*difficultOfMissions,\"<1>\",m8GaalDays);",
                        "  CustomEther('NisperEther',3,'ZelDomiksQuest',Format(CT(\"Script.Mod_RefNisper.493\"),\"<0>\",daysMission,\"<1>\",missionsStrings[0],\"<2>\",missionsStrings[1],\"<3>\",missionsStrings[2],\"<4>\",missionsStrings[3],\"<5>\",missionsStrings[4]));",
                        "  bool=1;",
                        "  for(i=0;i<5;i=i+1){",
                        "      if(!doneMissions[i]) bool=0;",
                        "  }",
                        "  if(bool){",
                        "      completeTask=1;",
                        "      CustomEther('NisperEther',4,'ZelDomiksQuest',CT(\"Script.Mod_RefNisper.492\"));",
                        "      Sound('Sound.QuestOk');",
                        "  }",
                        "  else if(daysMission==0){",
                        "      completeTask=0;",
                        "      CustomEther('NisperEther',5,'ZelDomiksQuest',CT(\"Script.Mod_RefNisper.491\"));",
                        "      Sound('Sound.QuestCancel');",
                        "  }",
                        "}",
                        "if(domLevel==6&&completeTask==2) {",
                        "  star = ShipStar(Player());",
                        "  ",
                        "  if(ShipInHole(Player())) {",
                        "      if(!GABStatus) {",
                        "          if(!ABStarted) {",
                        "              if(Id(ShipOrderObj(Player())) == idMissionHole) {",
                        "                  dom = CreateABShip('Ship.X.' + Rnd(0, 2), 0, 150, 110);",
                        "                  ABShipModifiers(dom,'speed', 100);",
                        "                  dom = CreateABShip('Ship.X.' + Rnd(0, 2), 0, 120, 120);",
                        "                  ABShipModifiers(dom,'speed', 120);",
                        "                  dom = CreateABShip('Ship.X.' + Rnd(0, 2), 0, 120, 120);",
                        "                  ABShipModifiers(dom,'speed', 120);",
                        "                  dom = CreateABShip('Ship.X.' + Rnd(0, 2), 0, 100, 120);",
                        "                  ABShipModifiers(dom,'speed', 140);",
                        "                  dom = CreateABShip('Ship.X.' + Rnd(0, 2), 0, 100, 120);",
                        "                  ABShipModifiers(dom,'speed', 140);",
                        "  ",
                        "                  if(difficultOfHoles < 4) {",
                        "                      dom = SpawnDom(1, 0);",
                        "                      GiveABWeapon(dom, 1, Rnd(2, 3));",
                        "                      ShipDestroy(dom, 1);",
                        "                      dom = ConvertToABShip(dom, 1, 100, 100);",
                        "                      ABShipModifiers(dom, 'speed', 130);",
                        "                  }",
                        "                  if (difficultOfHoles < 7) {",
                        "                      dom = SpawnDom(1, 0);",
                        "                      GiveABWeapon(dom, 1, Rnd(2, 3));",
                        "                      ShipDestroy(dom, 1);",
                        "                      dom = ConvertToABShip(dom, 1, 100, 100);",
                        "                      ABShipModifiers(dom, 'speed', 130);",
                        "                  }",
                        "                  dom = SpawnDom(5, 0);",
                        "                  GiveABWeapon(dom, 5, 5);",
                        "                  ShipDestroy(dom, 1);",
                        "                  dom = ConvertToABShip(dom, 1, 120, 110);",
                        "                  ABShipModifiers(dom, 'speed', 130);",
                        "  ",
                        "                  ABStarted = 1;",
                        "                  completeTask=1;",
                        "                  OrderLock(Player(),0);",
                        "                  StartAB('ABMap.map_' + Rnd(1, 13));",
                        "                  Sound('Sound.NewMsg');",
                        "                  CustomEther('NisperEther',4,'ZelDomiksQuest',CT(\"Script.Mod_RefNisper.490\"));",
                        "              }",
                        "          }",
                        "      }",
                        "  }",
                        "}",
                        "if(domLevel==8&&completeTask==2&&doneMissions[4]==2) {",
                        "  m8GaalDays=m8GaalDays-1;",
                        "  if(m8GaalDays==0){",
                        "      doneMissions[4]=3;",
                        "      missionsStrings[4]=Format(CT(\"Script.Mod_RefNisper.477\"),\"<0>\",PlanetName(IdToPlanet(idPlanetsMissions[4])));",
                        "  }",
                        "}",
                        "if(domLevel==8&&completeTask==2&&doneMissions[0]==2) {",
                        "  m8MalDays=m8MalDays-1;",
                        "  if(m8MalDays==0){",
                        "      doneMissions[0]=3;",
                        "      missionsStrings[0]=Format(CT(\"Script.Mod_RefNisper.477\"),\"<0>\",PlanetName(IdToPlanet(idPlanetsMissions[0])));",
                        "  }",
                        "  else if(StarOwner(PlanetToStar(IdToPlanet(idPlanetsMissions[0]))) != 0){",
                        "      completeTask=0;",
                        "      CustomEther('NisperEther',5,'ZelDomiksQuest',CT(\"Script.Mod_RefNisper.476\"));",
                        "  }",
                        "}",
                        "if(domLevel==3&&completeTask==2) {",
                        "  daysMission = daysMission + 1;",
                        "  targetStar = GalaxyStar(idStarAttackPirates);",
                        "  ourPlanet = PlanetPirateClan();",
                        "  dword starPirates = PlanetToStar(ourPlanet);",
                        "  int ourHullSize;",
                        "  CustomEther('NisperEther',3,'ZelDomiksQuest',Format(CT(\"Script.Mod_RefNisper.487\"),\"<0>\",StarName(targetStar))+CT('FormInfo.br')+Format(CT(\"Script.Mod_RefNisper.486\"),\"<0>\",daysMissionComplete-daysMission));",
                        "  if(StarOwner(targetStar) == 0 && PirateWin() == 0) {",
                        "      if(daysMissionComplete-daysMission > 20) {",
                        "          if(Rnd(1, 4) == 1) {",
                        "              for(i = 0; i < Rnd(difficultOfPirates / 3, difficultOfPirates / 2 + 3) + 1; i = i + 1) {",
                        "                  dom = BuyWarrior(ourPlanet, 50 + 20 * difficultOfPirates);",
                        "                  ourHullSize = 300 + 25 * difficultOfPirates;",
                        "                  ourHullSize = Rnd(0.7 * ourHullSize, 1.3 * ourHullSize);",
                        "                  for(j = 0; j < Rnd(0, difficultOfPirates / 3); j = j + 1) ShipRefit(dom, ourHullSize);",
                        "                  ShipImproveItems(dom, Rnd(0, difficultOfPirates / 3));",
                        "                  MakeShipEnterStar(dom, targetStar, starPirates, 5);",
                        "                  Chameleon(dom);",
                        "              }",
                        "          }",
                        "      }",
                        "      else if(daysMissionComplete-daysMission == 20) {",
                        "          for(i = 0; i < Rnd(difficultOfPirates / 5, difficultOfPirates / 3) + 2; i = i + 1) {",
                        "              dom = BuyWarrior(ourPlanet, 150 + 50 * difficultOfPirates);",
                        "              ourHullSize = 500 + 35 * difficultOfPirates;",
                        "              ourHullSize = Rnd(0.8 * ourHullSize, 1.2 * ourHullSize);",
                        "              for(j = 0; j < 5; j = j + 1) ShipRefit(dom, ourHullSize);",
                        "              ShipImproveItems(dom, Rnd(difficultOfPirates / 3, difficultOfPirates / 2) + 2);",
                        "              MakeShipEnterStar(dom, targetStar, starPirates, 5);",
                        "              Chameleon(dom);",
                        "              ShipSpecialBonuses(dom, bonSpeed, 75 + 10 * difficultOfPirates);",
                        "              ShipSpecialBonuses(dom, bonDroid, 2 + 2 * difficultOfPirates);",
                        "              ShipSpecialBonuses(dom, bonDef, 3 + difficultOfPirates);",
                        "              ShipSpecialBonuses(dom, bonWEnergy, 5 + difficultOfPirates);",
                        "              ShipSpecialBonuses(dom, bonWSplinter, 5 + difficultOfPirates);",
                        "              ShipSpecialBonuses(dom, bonWMissile, 5 + difficultOfPirates);",
                        "          }",
                        "      }",
                        "      else if(daysMissionComplete-daysMission == 0) {",
                        "          BertorStars[idStarAttackPirates] = 0;",
                        "          NoComeKlingToStar(GalaxyStar(idStarAttackPirates), 0);",
                        "          completeTask = 1;",
                        "          Sound('Sound.QuestOk');",
                        "          CustomEther('NisperEther',4,'ZelDomiksQuest',Format(CT(\"Script.Mod_RefNisper.485\"),\"<0>\",StarName(targetStar)));",
                        "      }",
                        "  }",
                        "  else if(StarOwner(targetStar) != 0) {",
                        "      BertorStars[idStarAttackPirates] = 0;",
                        "      NoComeKlingToStar(targetStar, 0);",
                        "      completeTask = 0;",
                        "      Sound('Sound.QuestCancel');",
                        "      completeEther=0;",
                        "      researched=15;",
                        "      daysForResearch=1;",
                        "      CustomEther('NisperEther',5,'ZelDomiksQuest',Format(CT(\"Script.Mod_RefNisper.484\"),\"<0>\",StarName(targetStar)));",
                        "  }",
                        "  else {",
                        "      BertorStars[idStarAttackPirates] = 0;",
                        "      NoComeKlingToStar(targetStar, 0);",
                        "      completeTask = 1;",
                        "      Sound('Sound.QuestOk');",
                        "      CustomEther('NisperEther',4,'ZelDomiksQuest',Format(CT(\"Script.Mod_RefNisper.483\"),\"<0>\",StarName(targetStar)));",
                        "  }",
                        "}",
                        "if(domLevel==4&&completeTask==2) {",
                        "  daysMission = daysMission + 1;",
                        "  dword ourDomTrader = IdToShip(domTraderId[0]);",
                        "  if(daysMission < daysMissionComplete) {",
                        "      if(ourDomTrader) {",
                        "          int playerDayMoney = ShipCustomShipInfoData(Player(), 'ZelDomiks_MoneyPlayerInfo', 1);",
                        "          ShipCustomShipInfoData(Player(), 'ZelDomiks_MoneyPlayerInfo', 1, 0);",
                        "          playerProfit = playerProfit + playerDayMoney;",
                        "          if(playerDayMoney > 0) {",
                        "              power = 10 + Rnd(1, 3) * difficultOfMoney;",
                        "              domikProfitPlus[0] = domikProfitPlus[0] + (power * playerDayMoney / 100);",
                        "          }",
                        "          int domikDayMoney = ShipCustomShipInfoData(ourDomTrader, 'ZelDomiks_MoneyDomInfo', 1);",
                        "          ShipCustomShipInfoData(ourDomTrader, 'ZelDomiks_MoneyDomInfo', 1, 0);",
                        "          int bonusProfitDom;",
                        "          if(domikDayMoney > 0) {",
                        "              bonusProfitDom = domikProfitPlus[0] * Rnd(10, 30 + difficultOfMoney * 2) / 100;",
                        "              domikProfitPlus[0] = domikProfitPlus[0] - bonusProfitDom;",
                        "              domikProfit[0] = domikProfit[0] + domikDayMoney + bonusProfitDom;",
                        "          }",
                        "          CustomEther('NisperEther',3,'ZelDomiksQuest',Format(CT(\"Script.Mod_RefNisper.482\"),\"<0>\",playerProfit,\"<1>\",domikProfit[0],\"<2>\",daysMissionComplete-daysMission));",
                        "      }",
                        "      else {",
                        "          completeTask = 0;",
                        "          Sound('Sound.NewMsg');",
                        "          CustomEther('NisperEther',5,'ZelDomiksQuest',CT(\"Script.Mod_RefNisper.481\"));",
                        "      }",
                        "  }",
                        "  else if(daysMission == daysMissionComplete) {",
                        "      ShipDestroy(ourDomTrader, 1);",
                        "      if(playerProfit > domikProfit[0]) {",
                        "          completeTask = 1;",
                        "          Sound('Sound.QuestOk');",
                        "          CustomEther('NisperEther',4,'ZelDomiksQuest',CT(\"Script.Mod_RefNisper.480\"));",
                        "      }",
                        "      else {",
                        "          completeTask = 0;",
                        "          Sound('Sound.QuestCancel');",
                        "          CustomEther('NisperEther',5,'ZelDomiksQuest',CT(\"Script.Mod_RefNisper.479\"));",
                        "      }",
                        "  }",
                        "}",
                        "if(domLevel==9&&completeTask==2&&bonusAdd==2) {",
                        "  star = ShipStar(Player());",
                        "  int serie = StarSeries(star);",
                        "  dword planet = NearCivilPlanet(Player());",
                        "  ",
                        "  if(ShipInHole(Player())) {",
                        "      if(!GABStatus) {",
                        "          if(!ABStarted) {",
                        "              if(Id(ShipOrderObj(Player())) == idMissionHole) {",
                        "                  dom = SpawnDom(1, 0);",
                        "                  GiveABWeapon(dom, 1, Rnd(2, 3));",
                        "                  ShipDestroy(dom,1);",
                        "                  dom=ConvertToABShip(dom, 1, 100, 100);",
                        "                  ABShipModifiers(dom, 'speed', 130);",
                        "                  dom = SpawnDom(2, 0);",
                        "                  GiveABWeapon(dom, 2, Rnd(2, 3));",
                        "                  ShipDestroy(dom,1);",
                        "                  dom=ConvertToABShip(dom, 1, 100, 110);",
                        "                  ABShipModifiers(dom, 'speed', 120);",
                        "                  dom = SpawnDom(3, 0);",
                        "                  GiveABWeapon(dom, 3, Rnd(2, 3));",
                        "                  ShipDestroy(dom,1);",
                        "                  dom=ConvertToABShip(dom, 1, 110, 110);",
                        "                  ABShipModifiers(dom, 'speed', 110);",
                        "                  dom = SpawnDom(4, 0);",
                        "                  GiveABWeapon(dom, 4, Rnd(2, 3));",
                        "                  ShipDestroy(dom,1);",
                        "                  dom=ConvertToABShip(dom, 1, 110, 120);",
                        "                  ABShipModifiers(dom, 'speed', 100);",
                        "                  dom = SpawnDom(5, 0);",
                        "                  GiveABWeapon(dom, 5, Rnd(2, 3));",
                        "                  ShipDestroy(dom,1);",
                        "                  dom=ConvertToABShip(dom, 1, 120, 110);",
                        "                  ABShipModifiers(dom, 'speed', 100);",
                        "          ",
                        "                  StarSeries(star, 1);",
                        "                  dom=BuyDomikExtremal(planet,1);",
                        "                  ShipDestroy(dom,1);",
                        "                  GiveABWeapon(dom, 5, Rnd(min(5,difficultOfHoles/2), min(5,difficultOfHoles)));",
                        "                  dom=ConvertToABShip(dom, 0, 180, 120);",
                        "                  ABShipModifiers(dom,'speed', 80);",
                        "                  dom=BuyDomikExtremal(planet,2);",
                        "                  ShipDestroy(dom,1);",
                        "                  GiveABWeapon(dom, 4, Rnd(min(5,difficultOfHoles/2), min(5,difficultOfHoles)));",
                        "                  dom=ConvertToABShip(dom, 0, 160, 120);",
                        "                  ABShipModifiers(dom,'speed', 100);",
                        "                  dom=BuyDomikExtremal(planet,2);",
                        "                  ShipDestroy(dom,1);",
                        "                  GiveABWeapon(dom, 4, Rnd(min(5,difficultOfHoles/2), min(5,difficultOfHoles)));",
                        "                  dom=ConvertToABShip(dom, 0, 160, 120);",
                        "                  ABShipModifiers(dom,'speed', 100);",
                        "                  dom=BuyDomikExtremal(planet,3);",
                        "                  ShipDestroy(dom,1);",
                        "                  GiveABWeapon(dom, 3, Rnd(min(5,difficultOfHoles/2), min(5,difficultOfHoles)));",
                        "                  dom=ConvertToABShip(dom, 0, 130, 130);",
                        "                  ABShipModifiers(dom,'speed', 120);",
                        "                  dom=BuyDomikExtremal(planet,3);",
                        "                  ShipDestroy(dom,1);",
                        "                  GiveABWeapon(dom, 3, Rnd(min(5,difficultOfHoles/2), min(5,difficultOfHoles)));",
                        "                  dom=ConvertToABShip(dom, 0, 130, 130);",
                        "                  ABShipModifiers(dom,'speed', 120);",
                        "                  dom=BuyDomikExtremal(planet,3);",
                        "                  ShipDestroy(dom,1);",
                        "                  GiveABWeapon(dom, 3, Rnd(min(5,difficultOfHoles/2), min(5,difficultOfHoles)));",
                        "                  dom=ConvertToABShip(dom, 0, 130, 130);",
                        "                  ABShipModifiers(dom,'speed', 120);",
                        "                  dom=BuyDomikExtremal(planet,6);",
                        "                  ShipDestroy(dom,1);",
                        "                  GiveABWeapon(dom, 6, Rnd(min(5,difficultOfHoles/2), min(5,difficultOfHoles)));",
                        "                  dom=ConvertToABShip(dom, 0, 240, 180);",
                        "                  ABShipModifiers(dom,'speed', 60);",
                        "                  ABShipModifiers(dom,'regen', 50 + difficultOfHoles * 10);",
                        "                  ABShipModifiers(dom,'gravity', 0);",
                        "                  for(i=0;i<difficultOfHoles/2;i=i+1){",
                        "                      dom=BuyDomikExtremal(planet,7);",
                        "                      ShipDestroy(dom,1);",
                        "                      GiveABWeapon(dom, 0, Rnd(min(5,difficultOfHoles/2), min(5,difficultOfHoles)));",
                        "                      dom=ConvertToABShip(dom, 0, 80, 150);",
                        "                      ABShipModifiers(dom,'speed', 150);",
                        "                  }",
                        "          ",
                        "                  StarSeries(star, 0);",
                        "                  dom=BuyDomikExtremal(planet,3);",
                        "                  ShipDestroy(dom,1);",
                        "                  GiveABWeapon(dom, 3, Rnd(min(5,difficultOfHoles/2), min(5,difficultOfHoles)));",
                        "                  dom=ConvertToABShip(dom, 2, 130, 130);",
                        "                  ABShipModifiers(dom,'speed', 120);",
                        "                  dom=BuyDomikExtremal(planet,1);",
                        "                  ShipDestroy(dom,1);",
                        "                  GiveABWeapon(dom, 5, Rnd(min(5,difficultOfHoles/2), min(5,difficultOfHoles)));",
                        "                  dom=ConvertToABShip(dom, 2, 180, 120);",
                        "                  ABShipModifiers(dom,'speed', 80);",
                        "          ",
                        "                  StarSeries(star, 2);",
                        "                  dom=BuyDomikExtremal(planet,4);",
                        "                  ShipDestroy(dom,1);",
                        "                  GiveABWeapon(dom, 2, Rnd(min(5,difficultOfHoles/2), min(5,difficultOfHoles)));",
                        "                  dom=ConvertToABShip(dom, 3, 120, 130);",
                        "                  ABShipModifiers(dom,'speed', 130);",
                        "                  dom=BuyDomikExtremal(planet,5);",
                        "                  ShipDestroy(dom,1);",
                        "                  GiveABWeapon(dom, 1, Rnd(min(5,difficultOfHoles/2), min(5,difficultOfHoles)));",
                        "                  dom=ConvertToABShip(dom, 3, 120, 120);",
                        "                  ABShipModifiers(dom,'speed', 140);",
                        "                  dom=BuyDomikExtremal(planet,5);",
                        "                  ShipDestroy(dom,1);",
                        "                  GiveABWeapon(dom, 1, Rnd(min(5,difficultOfHoles/2), min(5,difficultOfHoles)));",
                        "                  dom=ConvertToABShip(dom, 3, 120, 120);",
                        "                  ABShipModifiers(dom,'speed', 140);",
                        "          ",
                        "                  StarSeries(star, serie);",
                        "                  ABStarted = 1;",
                        "                  completeTask=1;",
                        "                  OrderLock(Player(),0);",
                        "                  StartAB('ABMap.map_14');",
                        "                  Sound('Sound.NewMsg');",
                        "                  CustomEther('NisperEther',4,'ZelDomiksQuest',CT(\"Script.Mod_RefNisper.478\"));",
                        "              }",
                        "          }",
                        "      }",
                        "  }",
                        "}",
                        "if(isStartedDomiks==1) {",
                        "  bank = bank + (ControlledSystems(0) * exp(1.2 + 0.8 * GalaxyTechLevel()));",
                        "  if(bankPlayer>0) {",
                        "      if(bankPlayer>expenses) {",
                        "          bank=bank+expenses;",
                        "          bankPlayer=bankPlayer-expenses;",
                        "      }",
                        "      else {",
                        "          bank=bank+bankPlayer;",
                        "          bankPlayer=0;",
                        "      }",
                        "  }",
                        "  ",
                        "  playerShip = Player();",
                        "  ",
                        "  /*if(bank >= expenses) {",
                        "      bank = bank - expenses;",
                        "      days = days + 1;",
                        "      if(days >= dayBuild) {",
                        "          SpawnDom(-1, 0);",
                        "          expenses = (exp(1.5 + 0.3 * domLevel) * ((1.0 - 0.025 * (bonusGlobal == 3) * domLevel) * 1.0 * GroupCount(domiks) / 3) * (3.0 + 0.5 * domLevel) * (5.0 + 1.0 * GalaxyDiffLevels() / 250));",
                        "          buildTime = ((1.0 * GalaxyDiffLevels() / 120) + 25.0 - (0.9 * curDomLevel)) / (2.0 + ((0.1 + 0.04 * curDomLevel) * (bonusGlobal == 3)));",
                        "          dayBuild = dayBuild + buildTime - days;",
                        "          days = 0;",
                        "      }",
                        "  }*/",
                        "  ",
                        "  daysAtt = daysAtt + ((10.0 + 1.0 * GroupCount(domiks) - 1.0 * GroupCount(domiks) * (bonusGlobal == 3) * 0.33) * 0.2) / ((1.0 + 0.3 * ControlledSystems(0)) * (1.0 + 1.0 * GalaxyDiffLevels() / 1000));",
                        "  if(ShipFindCustomShipInfoByType(playerShip, 'Beacon') != -1) {",
                        "      daysAtt = 0;",
                        "      targetStar = GalaxyStar(ShipCustomShipInfoData(playerShip, 'Beacon', 1));",
                        "      ShipDeleteCustomShipInfo(playerShip, 'Beacon');",
                        "      StartAttackSystem(targetStar);",
                        "  }",
                        "  else if(daysAtt >= 120 + 30 * (bonusGlobal == 1)) {",
                        "      daysAtt = 0;",
                        "      targetStar = GiveAttackStar();",
                        "      if(targetStar != -1) StartAttackSystem(targetStar);",
                        "      else daysAtt = 0 - GroupCount(domiks) * 10;",
                        "  }",
                        "  ",
                        "  bossShip = IdToShip(bossId);",
                        "  if(!bossShip) {",
                        "      daysBuildBoss = daysBuildBoss - 1;",
                        "      if(daysBuildBoss <= 0) {",
                        "          daysBuildBoss = 100 + GalaxyDiffLevels() / 2;",
                        "          if(bonusBoss == 0) SpawnBoss();",
                        "          else if(bonusBoss == 1){",
                        "              SpawnBossBlazer();",
                        "              daysBuildBoss=daysBuildBoss/2;",
                        "          }",
                        "          else if(bonusBoss == 2) SpawnBossKeller();",
                        "          else if(bonusBoss == 3) SpawnBossTerron();",
                        "      }",
                        "  }",
                        "  ",
                        "  if(domLevel < 10) {",
                        "      if(itemsForResearch < 300) ourItemsForResearch = itemsForResearch;",
                        "      else ourItemsForResearch = 300;",
                        "      speedResearch = (75.0 + ourItemsForResearch) / 375 * (0.18 - 0.014 * difficultOfResearch) * (1.0 + 0.2 * (bonusGlobal == 2));",
                        "      int destroyItemsForResearch = Rnd(0.4 * difficultOfResearch + 1, 1.2 * difficultOfResearch + 2);",
                        "      if(domLevel < 10) daysForResearch = (1.0 * Research[domLevel] - researched) / speedResearch;",
                        "      else daysForResearch = 0;",
                        "      if(daysForResearch > 0) {",
                        "          if(itemsForResearch > destroyItemsForResearch) itemsForResearch = itemsForResearch - destroyItemsForResearch;",
                        "          else if (itemsForResearch <= destroyItemsForResearch) itemsForResearch = 0;",
                        "          researched = researched + speedResearch;",
                        "      }",
                        "      else if (completeEther == 0) {",
                        "          CustomEther('NisperEther', 7, '', CT(\"Script.Mod_RefNisper.489\"));",
                        "          completeEther = 1;",
                        "      }",
                        "  }",
                        "  ",
                        "  if(ShipInNormalSpace(playerShip) && Id(ShipItems(playerShip, 0)) == bertorHullId) {",
                        "      star = ShipStar(playerShip);",
                        "      cShips = StarShips(star);",
                        "      ourPlanet = IdToPlanet(planetId);",
                        "      power = (1.0 + 0.03 * (bonusAdd == 3) * curDomLevel) * HullSizeMax[5];",
                        "      for(i = 0; i <= cShips; i = i + 1) {",
                        "          thisShip = StarShips(star, i);",
                        "          if(ShipInNormalSpace(thisShip)) {",
                        "              if(thisShip != playerShip && HullHP(thisShip) <= power && Dist(playerShip, thisShip) <= 500 && GetRelationPlanet(ourPlanet, thisShip) > 30) {",
                        "                  if(bonusAdd == 1) ShipAddCustomShipInfo(thisShip, 'ZelDomiks_AuraB', 'NoShow');",
                        "                  else if(bonusAdd == 2) ShipAddCustomShipInfo(thisShip, 'ZelDomiks_AuraK', 'NoShow');",
                        "                  else if(bonusAdd == 3) ShipAddCustomShipInfo(thisShip, 'ZelDomiks_AuraT', 'NoShow');",
                        "                  else ShipAddCustomShipInfo(thisShip, 'ZelDomiks_Aura', 'NoShow');",
                        "              }",
                        "          }",
                        "      }",
                        "      ShipCustomShipInfoData(playerShip, 'ZelDomiks_BertorsAura', 1, 0);",
                        "      int numOfKligs = ShipCustomShipInfoData(playerShip, 'ZelDomiks_BertorsAura', 2);",
                        "      if(Rnd(1, 10 + 2 * ((bonusDomiks == 3) + (bonusGlobal == 3))) > (5 - numOfKligs + (bonusDomiks == 3) + (bonusGlobal == 3))) {",
                        "          while(numOfKligs < 5 + (bonusDomiks == 3) + (bonusGlobal == 3)) {",
                        "              SpawnKlig(Id(playerShip));",
                        "              numOfKligs = numOfKligs + 1;",
                        "          }",
                        "          ShipCustomShipInfoData(playerShip, 'ZelDomiks_BertorsAura', 2, 5 + (bonusDomiks == 3) + (bonusGlobal == 3));",
                        "      }",
                        "  }",
                        "  ",
                        "  if(!IdToShip(DBId)) {",
                        "      bossShip = IdToShip(bossId);",
                        "      if(bossShip) ShipDestroy(bossShip, 1);",
                        "      for(i = 0; i < GroupCount(bertors); i = i + 1) {",
                        "          star = GroupShip(bertors, i);",
                        "          OrderNone(star);",
                        "          OrderLock(star);",
                        "          ShipDestroy(star, 1);",
                        "      }",
                        "      for(i = 0; i < GroupCount(kligs); i = i + 1) {",
                        "          star = GroupShip(ShipyardDefKlig, i);",
                        "          OrderNone(star);",
                        "          OrderLock(star);",
                        "          ShipDestroy(star, 1);",
                        "      }",
                        "      for(i = 0; i < GroupCount(domiks); i = i + 1) {",
                        "          star = GroupShip(domiks, i);",
                        "          OrderNone(star);",
                        "          OrderLock(star);",
                        "          ShipDestroy(star, 1);",
                        "      }",
                        "      for(i = 0; i < GroupCount(domiksBes); i = i + 1) {",
                        "          star = GroupShip(domiksBes, i);",
                        "          OrderNone(star);",
                        "          OrderLock(star);",
                        "          ShipDestroy(GroupShip(domiksBes, i), 1);",
                        "      }",
                        "      for(i = 0; i < GroupCount(freeGroup); i = i + 1) {",
                        "          star = GroupShip(freeGroup, i);",
                        "          OrderNone(star);",
                        "          OrderLock(star);",
                        "          ShipDestroy(star, 1);",
                        "      }",
                        "      for(i = 0; i < GroupCount(ShipyardsGroup); i = i + 1) {",
                        "          star = GroupShip(ShipyardsGroup, i);",
                        "          OrderNone(star);",
                        "          OrderLock(star);",
                        "          ShipDestroy(star, 1);",
                        "      }",
                        "      for(i = 0; i < GroupCount(ShipyardDefKlig); i = i + 1) {",
                        "          star = GroupShip(ShipyardDefKlig, i);",
                        "          OrderNone(star);",
                        "          OrderLock(star);",
                        "          ShipDestroy(star, 1);",
                        "      }",
                        "      isStartedDomiks = 0;",
                        "      CustomEther('NisperEther', 7, '', CT(\"Script.Mod_RefNisper.488\"));",
                        "  }",
                        "  ",
                        "  //Глобалка с автообновлением для других модов",
                        "  if(~IdToShip(bossId)) {",
                        "      Nisper = bossId;",
                        "  }",
                        "  else Nisper = 0;",
                        "}",
                        "if(robotsReady==1) {",
                        "  if(GRobotStatus==2) robotsReady=3;",
                        "  else robotsReady=2;",
                        "}",
                        "if(domLevel==8&&completeTask==2&&doneMissions[3]==2) {",
                        "  if(!IdToItem(idFean)){",
                        "      completeTask=0;",
                        "      CustomEther('NisperEther',5,'ZelDomiksQuest','Кто-то уничтожил капсулу с Абером. Задание провалено.');",
                        "  }",
                        "}",
                        "if(domLevel==5&&completeTask==2&&bonusAdd==1) {",
                        "  daysMission = daysMission + 1;",
                        "  targetStar = GalaxyStar(idStarAttackPirates);",
                        "  ourPlanet = PlanetPirateClan();",
                        "  starPirates = PlanetToStar(ourPlanet);",
                        "  CustomEther('NisperEther',3,'ZelDomiksQuest',Format(CT(\"Script.Mod_RefNisper.475\"),\"<0>\",StarName(targetStar),\"<1>\",daysMissionComplete-daysMission));",
                        "  if(StarOwner(targetStar) != 2 && PirateWin() == 0) {",
                        "      if(daysMissionComplete - daysMission > 15) {",
                        "          if(Rnd(1, 3) == 1) {",
                        "              for(i = 0; i < Rnd(difficultOfPirates / 2, max(3,difficultOfPirates)) + 1; i = i + 1) {",
                        "                  dom = BuyWarrior(ourPlanet, 75 + 25 * difficultOfPirates);",
                        "                  ourHullSize = 350 + 30 * difficultOfPirates;",
                        "                  ourHullSize = Rnd(0.8 * ourHullSize, 1.2 * ourHullSize);",
                        "                  for(j = 0; j < Rnd(0, difficultOfPirates / 2) + 1; j = j + 1) ShipRefit(dom, ourHullSize);",
                        "                  ShipImproveItems(dom, Rnd(0, difficultOfPirates / 2) + 1);",
                        "                  MakeShipEnterStar(dom, targetStar, starPirates, 1);",
                        "                  Chameleon(dom);",
                        "              }",
                        "          }",
                        "      }",
                        "      else if(daysMissionComplete - daysMission == 15) {",
                        "          dom = BuyWarrior(ourPlanet, 200 + 100 * difficultOfPirates);",
                        "          ourHullSize = 700 + 50 * difficultOfPirates;",
                        "          ourHullSize = Rnd(0.9 * ourHullSize, 1.1 * ourHullSize);",
                        "          for(j = 0; j < 5; j = j + 1) ShipRefit(dom, ourHullSize);",
                        "          ShipImproveItems(dom, difficultOfPirates + 5);",
                        "          MakeShipEnterStar(dom, targetStar, starPirates, 1);",
                        "          Chameleon(dom);",
                        "          for(j = 0; j <= 5; j = j + 1) ShipSkill(dom, j, 1 + difficultOfPirates / 2);",
                        "          while(GetShipPirateRank(dom) < 6) {",
                        "            ShipPirateRankPoints(dom, ShipNextPirateRankPoints(dom));",
                        "            RaisePirateRank(dom);",
                        "          }",
                        "          ShipSpecialBonuses(dom, bonSpeed, 150 + 30 * difficultOfPirates);",
                        "          ShipSpecialBonuses(dom, bonDroid, 15 + 3 * difficultOfPirates);",
                        "          ShipSpecialBonuses(dom, bonDef, 7.5 + 1.5 * difficultOfPirates);",
                        "          ShipSpecialBonuses(dom, bonHull, 2.5 + 0.5 * difficultOfPirates);",
                        "          ShipSpecialBonuses(dom, bonWEnergy, 15 + 3 * difficultOfPirates);",
                        "          ShipSpecialBonuses(dom, bonWSplinter, 15 + 3 * difficultOfPirates);",
                        "          ShipSpecialBonuses(dom, bonWMissile, 15 + 3 * difficultOfPirates);",
                        "      }",
                        "      else if(daysMissionComplete-daysMission == 0) {",
                        "          completeTask = 1;",
                        "          Sound('Sound.QuestOk');",
                        "          idStarAttackPirates = -1;",
                        "          CustomEther('NisperEther',4,'ZelDomiksQuest',Format(CT(\"Script.Mod_RefNisper.474\"),\"<0>\",StarName(targetStar)));",
                        "      }",
                        "  }",
                        "  else if(StarOwner(targetStar) == 2) {",
                        "      completeTask = 0;",
                        "      Sound('Sound.QuestCancel');",
                        "      completeEther=0;",
                        "      idStarAttackPirates = -1;",
                        "      researched=20;",
                        "      daysForResearch=1;",
                        "      CustomEther('NisperEther',5,'ZelDomiksQuest',Format(CT(\"Script.Mod_RefNisper.473\"),\"<0>\",StarName(targetStar)));",
                        "  }",
                        "  else if(StarOwner(targetStar) == 0 || PirateWin() != 0) {",
                        "      completeTask = 1;",
                        "      Sound('Sound.QuestOk');",
                        "      idStarAttackPirates = -1;",
                        "      CustomEther('NisperEther',4,'ZelDomiksQuest',CT(\"Script.Mod_RefNisper.472\"));",
                        "  }",
                        "}",
                        "if(domLevel==5&&completeTask==2&&bonusAdd==2) {",
                        "  for(i=0;completeTask&&i<numItems;i=i+1) {",
                        "      if(idUselessItem[i]!=-1) {",
                        "          dword ourItem=IdToItem(idUselessItem[i]);",
                        "          if(!ourItem){",
                        "              completeTask=0;",
                        "              Sound('Sound.QuestCancel');",
                        "              CustomEther('NisperEther',5,'ZelDomiksQuest',CT(\"Script.Mod_RefNisper.471\"));",
                        "              completeEther=0;",
                        "              idUselessItem[i]=-1;",
                        "              for(j=0;j<numItems;j=j+1) {",
                        "                  if(idUselessItem[j]!=-1) {",
                        "                      k=0;",
                        "                      ourPlanet=IdToPlanet(idNeutralPlanets[j]);",
                        "                      while(idUselessItem[j]!=Id(PlanetItems(ourPlanet,k))) k=k+1;",
                        "                      FreeItem(GetItemFromPlanet(ourPlanet, k));",
                        "                      idUselessItem[j]=-1;",
                        "                  }",
                        "              }",
                        "          }",
                        "      }",
                        "  }",
                        "}",
                        "if(domLevel==5&&completeTask==2&&bonusAdd==3) {",
                        "  daysMission = daysMission + 1;",
                        "  if(daysMission<daysMissionComplete){",
                        "      bool=0;",
                        "      playerDayMoney=ShipCustomShipInfoData(Player(),'ZelDomiks_MoneyPlayerInfo',1);",
                        "      ShipCustomShipInfoData(Player(),'ZelDomiks_MoneyPlayerInfo',1,0);",
                        "      playerProfit=playerProfit+playerDayMoney;",
                        "      for(i=0;i<3;i=i+1){",
                        "          ourDomTrader=IdToShip(domTraderId[i]);",
                        "          if(ourDomTrader){",
                        "              bool=1;",
                        "              if(playerDayMoney>0){",
                        "                  power=Rnd(8,16)+Rnd(12,35)*difficultOfMoney/10;",
                        "                  domikProfitPlus[i]=domikProfitPlus[i]+(power*playerDayMoney/100);",
                        "              }",
                        "              domikDayMoney=ShipCustomShipInfoData(ourDomTrader,'ZelDomiks_MoneyDomInfo',1);",
                        "              ShipCustomShipInfoData(ourDomTrader,'ZelDomiks_MoneyDomInfo',1,0);",
                        "              if(domikDayMoney>0){",
                        "                  bonusProfitDom=domikProfitPlus[i]*Rnd(15,30+difficultOfMoney*2)/100;",
                        "                  domikProfitPlus[i]=domikProfitPlus[i]-bonusProfitDom;",
                        "                  domikProfit[i]=domikProfit[i]+domikDayMoney+bonusProfitDom;",
                        "              }",
                        "          }",
                        "      }",
                        "      CustomEther('NisperEther',3,'ZelDomiksQuest',Format(CT(\"Script.Mod_RefNisper.470\"),\"<0>\",playerProfit,\"<1>\",domikProfit[0],\"<2>\",domikProfit[1],\"<3>\",domikProfit[2],\"<4>\",daysMissionComplete-daysMission));",
                        "      if(!bool){",
                        "          completeTask = 0;",
                        "          Sound('Sound.QuestCancel');",
                        "          CustomEther('NisperEther',5,'ZelDomiksQuest',CT(\"Script.Mod_RefNisper.469\"));",
                        "      }",
                        "  }",
                        "  else if(daysMission==daysMissionComplete) {",
                        "      for(i=0;i<3;i=i+1) {",
                        "          ourDomTrader=IdToShip(domTraderId[i]);",
                        "          if(ourDomTrader) ShipDestroy(ourDomTrader,1);",
                        "      }",
                        "      if(playerProfit>domikProfit[0]&&playerProfit>domikProfit[1]&&playerProfit>domikProfit[2]) {",
                        "          completeTask=1;",
                        "          Sound('Sound.QuestOk');",
                        "          CustomEther('NisperEther',4,'ZelDomiksQuest',CT(\"Script.Mod_RefNisper.468\"));",
                        "      }",
                        "      else {",
                        "          completeTask = 0;",
                        "          Sound('Sound.QuestCancel');",
                        "          CustomEther('NisperEther',5,'ZelDomiksQuest',CT(\"Script.Mod_RefNisper.467\"));",
                        "      }",
                        "  }",
                        "}",
                        "if(domLevel==2&&uselessItemOnPlanet==0) {",
                        "  ourPlanet = GetShipPlanet(Player());",
                        "  if(ourPlanet) {",
                        "      if(PlanetOwner(ourPlanet) == None) {",
                        "          bool = 1;",
                        "          int idOurPlanet = Id(ourPlanet);",
                        "          for(i = 0; i < numNeutralPlanets; i = i + 1) {",
                        "              if(idOurPlanet == idNeutralPlanets[i]) bool = 0;",
                        "          }",
                        "          if(bool) {",
                        "              idNeutralPlanets[i] = idOurPlanet;",
                        "              if(Rnd(1, maxNeutralPlanets - numNeutralPlanets) == 1) {",
                        "                  dword ourUselessItem = CreateQuestItem('Usl_25');",
                        "                  SetName(ourUselessItem, CT(\"Script.Mod_RefNisper.466\"));",
                        "                  UselessItemText(ourUselessItem, CT(\"Script.Mod_RefNisper.465\"));",
                        "                  ItemSize(ourUselessItem, 20 + difficultOfLucky * 4);",
                        "                  ItemOwner(ourUselessItem,Kling);",
                        "                  ItemSubrace(ourUselessItem,Rnd(0,2));",
                        "                  AddItemToPlanet(ourPlanet, ourUselessItem);",
                        "                  idUselessItem[0] = Id(ourUselessItem);",
                        "                  uselessItemOnPlanet = 1;",
                        "              }",
                        "              else numNeutralPlanets = numNeutralPlanets + 1;",
                        "          }",
                        "      }",
                        "  }",
                        "  CustomEther('NisperEther',3,'ZelDomiksQuest',CT(\"Script.Mod_RefNisper.464\"));",
                        "}",
                        "if(domLevel==2&&idUselessItem[0]!=-1) {",
                        "  if(!IdToItem(idUselessItem[0])){",
                        "      completeTask=0;",
                        "      Sound('Sound.QuestCancel');",
                        "      idUselessItem[0]=-1;",
                        "      CustomEther('NisperEther',5,'ZelDomiksQuest',CT(\"Script.Mod_RefNisper.463\"));",
                        "  }",
                        "  else {",
                        "      Sound('Sound.NewMsg');",
                        "      CustomEther('NisperEther',3,'ZelDomiksQuest',CT(\"Script.Mod_RefNisper.462\"));",
                        "      completeTask = 1;",
                        "  }",
                        "}",
                        "if(domLevel==9&&completeTask==2&&bonusAdd==1) {",
                        "  daysMission=daysMission-1;",
                        "  if(daysMission==0){",
                        "      completeTask=0;",
                        "      CustomEther('NisperEther',5,'ZelDomiksQuest',CT(\"Script.Mod_RefNisper.461\"));",
                        "      Sound('Sound.QuestCancel');",
                        "      completeEther=0;",
                        "  }",
                        "  else if(GetShipRuins(Player())) {",
                        "      if(ShipType(GetShipRuins(Player())) == 'DB') GotoGov(2);",
                        "  }",
                        "}",
                        "if(!NewsFlag) {",
                        "    if(CurTurn()==665+GalaxyDiffLevels()+2*GalaxyDiffLevels(2) && GalaxyDominatorResearchPercent() > 10 && !DomiksDefeated()) {",
                        "        NewsAdd(CT('Script.Mod_RefNisper.FknNews'));",
                        "        AddPlanetNews(CT('Script.Mod_RefNisper.FknNews'),86);",
                        "        Sound('Sound.NewMsg');",
                        "        NewsFlag = 1;",
                        "    }",
                        "}",
                        "",
                        "if(isStartedDomiks==1) {",
                        "    if(domLevel > 2) {",
                        "        if(findsubstr(GameDateTxtByTurn(CurTurn),CT(\"Script.Mod_RefNisper.459\"))) {",
                        "            bankPlayer = bankPlayer + 35000 * max((500 - GalaxyDiffLevels())/100,1) * GalaxyTechLevel();",
                        "            itemsForResearch = itemsForResearch + Rnd(50,100);",
                        "        }",
                        "",
                        "        //Создаём верфи Ниспера",
                        "        if(GroupCount(ShipyardsGroup) < (round(ControlledSystems(0) / 5) + 1)) {",
                        "            k = 0;",
                        "            int l = 0;",
                        "            for(i=0;GalaxySectors()>i;i=i+1) {",
                        "                star = GalaxySectors(i);",
                        "                for(j=0;ConStars(star)>j;j=j+1) {",
                        "                    if(!StarOwner(ConStar(star,j))) {",
                        "                        k = k + 1;",
                        "                        break;",
                        "                    }",
                        "                }",
                        "            }",
                        "",
                        "            //Проверяем на условие \"1 верфь на сектор\"",
                        "            if(GroupCount(ShipyardsGroup) < k) {",
                        "                ArrayClear(tarr);",
                        "                ArrayDelete(tarr,0);",
                        "                for(i=0;GalaxySectors()>i;i=i+1) {",
                        "                    star = GalaxySectors(i);",
                        "                    for(j=0;GroupCount(ShipyardsGroup)>j;j=j+1) {",
                        "                        if(star == StarToCon(ShipStar(GroupShip(ShipyardsGroup,j)))) {",
                        "                            continue;",
                        "                            continue;",
                        "                        }",
                        "                    }",
                        "                    for(j=0;ConStars(star)>j;j=j+1) {",
                        "                        if(StarOwner(ConStar(star,j))) continue;",
                        "                        if(StarBattle(StarOwner(ConStar(star,j)))) continue;",
                        "                        ArrayAdd(tarr,ConStar(star,j));",
                        "                        l = l + 1;",
                        "                    }",
                        "                }",
                        "",
                        "                if(l) {",
                        "                    ArrayRandomize(150,tarr);",
                        "",
                        "                    SpawnDomShipyard(tarr[0]);",
                        "                }",
                        "            }",
                        "        }",
                        "    }",
                        "}",
                        "",
                        "if(QuestFlag) {",
                        "    if(QuestDays) {",
                        "        CustomEther('NisperEther',3,'NisperFlyQuest',CT(\"Script.Mod_RefNisper.456\")+' '+Name(IdToPlanet(QuestPlanId))+' '+CT(\"Script.Mod_RefNisper.458\")+' '+QuestDays+' '+CT(\"Script.Mod_RefNisper.457\"));",
                        "        QuestDays = QuestDays - 1;",
                        "    }",
                        "    else {",
                        "        CustomEther('NisperEther',5,'NisperFlyQuest',CT(\"Script.Mod_RefNisper.456\")+' '+Name(IdToPlanet(QuestPlanId)));",
                        "        Sound('Sound.QuestCancel');",
                        "        NewsAdd(CT(\"Script.Mod_RefNisper.455\"));",
                        "        QuestFlag = 0;",
                        "    }",
                        "}",
                        "",
                        "if(GABStatus) CustomEther('NisperEther',4,'ZelDomiksQuest','');"
                    ],
                    "#": 147,
                    "Type": "Top",
                    "Parent": -1,
                    "Pos.x": 120,
                    "Pos.y": 1460
                },
                {
                    "Name": "",
                    "Code.Type": "DialogBegin",
                    "Code": [
                        "dword playerShip = Player();",
                        "dword planet = GetShipPlanet(Player());",
                        "dword shipRuins = GetShipRuins(playerShip);",
                        "if(isStartedDomiks==1) {",
                        "    if(shipRuins) {",
                        "        if(ShipType(shipRuins) == 'DB') {",
                        "            AddDialogInject('dBank', Format(CT(\"Script.Mod_RefNisper.512\"),\"<0>\",ShipName(shipRuins)), 'Пополнить банк', 1, 1);",
                        "            AddDialogInject('dShipyard', '', CT(\"Script.Mod_RefNisper.511\"), 6);",
                        "            if(domLevel < 10) {",
                        "                  if(daysForResearch > 0) AddDialogInject('dUpgrade', '', CT(\"Script.Mod_RefNisper.510\"), 2);",
                        "                  else AddDialogInject('dGetMission', '', CT(\"Script.Mod_RefNisper.509\"), 2);",
                        "                  if(domLevel == 5 && completeTask == 2 && bonusAdd == 2) {",
                        "                      bool = 0;",
                        "                      for(i = ShipItems(playerShip) - 1; !bool && i > 0; i = i - 1) {",
                        "                          for(j = 0; !bool && j < numItems; j = j + 1) {",
                        "                              if(Id(ShipItems(playerShip, i)) == idUselessItem[j]) {",
                        "                                  bool = 1;",
                        "                                  AddDialogInject('d5MissionComplete', '', CT(\"Script.Mod_RefNisper.508\"), 3);",
                        "                              }",
                        "                          }",
                        "                      }",
                        "                  }",
                        "                  if(domLevel == 8 && completeTask == 2 && doneMissions[3] == 2) {",
                        "                      bool = 0;",
                        "                      for (i = ShipItems(playerShip) - 1; !bool && i > 0; i = i - 1) {",
                        "                          if (Id(ShipItems(playerShip, i)) == idFean) {",
                        "                              AddDialogInject('d8MissionFeanCom', '', CT(\"Script.Mod_RefNisper.507\"), 3);",
                        "                              bool = 1;",
                        "                              j = i;",
                        "                          }",
                        "                      }",
                        "                  }",
                        "                  if(domLevel == 7 && completeTask == 2) {",
                        "                      //if(!robotsReady) AddDialogInject('dRobots', '', \"Участвовать в состязании с Ниспером\", 3);",
                        "                      if(robotsReady == 2) AddDialogInject('dRobotsL', '', CT(\"Script.Mod_RefNisper.506\"), 3);",
                        "                      if(robotsReady == 3) AddDialogInject('dRobotsW', '', CT(\"Script.Mod_RefNisper.505\"), 3);",
                        "                  }",
                        "                  if(domLevel == 9 && completeTask == 2 && bonusAdd == 1) {",
                        "                      if(!robotsReady) AddDialogOverride('dRobotsF', 100);",
                        "                      else if(robotsReady == 2) AddDialogOverride('dRobotsFL', 100);",
                        "                      else if(robotsReady == 3) AddDialogOverride('dRobotsFW', 100);",
                        "                  }",
                        "            }",
                        "        }",
                        "    }",
                        "    if(GetTalkShip() && !TalkByAI()) {",
                        "        dword bossShip = IdToShip(bossId);",
                        "        dword talkShip = GetTalkShip();",
                        "        int relations = GetRelationPlanet(IdToPlanet(planetId), playerShip);",
                        "        if(bossShip == talkShip) {",
                        "            if(!bossDialog) AddDialogOverride('dDialogBossStart', 1);",
                        "            else {",
                        "                if(relations > 30 && ShipGetBad(talkShip) != playerShip) AddDialogOverride('dDialogBoss', 1);",
                        "                else AddDialogOverride('dDialogBossA', 1);",
                        "            }",
                        "        }",
                        "        else if(ShipCustomFaction(talkShip) == 'SubFaction.Nisper' && (ShipTypeN(talkShip) == 5 || ShipTypeN(talkShip) == 2)) {",
                        "            if(relations > 30 && ShipGetBad(talkShip) != playerShip) AddDialogOverride('dDialogDom', 1);",
                        "            else AddDialogOverride('dDialogDomA', 1);",
                        "        }",
                        "    }",
                        "    if(domLevel == 8 && completeTask == 2 && planet) {",
                        "        for(i = 0; i < 5; i = i + 1) {",
                        "            if(planet == IdToPlanet(idPlanetsMissions[i])) {",
                        "                if(i == 0) {",
                        "                    if(doneMissions[i] == 0) AddDialogInject('d8MissionMal', '', CT(\"Script.Mod_RefNisper.504\"), 1);",
                        "                    else if(doneMissions[i] == 3) AddDialogOverride('d8MissionMalW', 1);",
                        "                }",
                        "                else if(i == 1) {",
                        "                    if(doneMissions[i] == 0) AddDialogInject('d8MissionPel', '', CT(\"Script.Mod_RefNisper.503\"), 1);",
                        "                }",
                        "                else if(i == 2) {",
                        "                    if(doneMissions[i] == 0) {",
                        "                        if(doneMissions[0] == 1 && doneMissions[1] == 1 && doneMissions[3] == 1 && doneMissions[4] == 1) {",
                        "                            if(m8HumIs) AddDialogInject('d8MissionHumY', '', CT(\"Script.Mod_RefNisper.502\"), 1);",
                        "                            else AddDialogInject('d8MissionHum', '', CT(\"Script.Mod_RefNisper.501\"), 1);",
                        "                        }",
                        "                        else {",
                        "                            if(m8HumIs) AddDialogInject('d8MissionHumNo', '', 'Ну так что, вы согласны с предложением Научного совета?', 1);",
                        "                            else AddDialogInject('d8MissionHumN', '', CT(\"Script.Mod_RefNisper.501\"), 1);",
                        "                        }",
                        "                    }",
                        "                }",
                        "                else if(i == 3) {",
                        "                    if(doneMissions[i] == 0) AddDialogInject('d8MissionFean', '', CT(\"Script.Mod_RefNisper.500\"), 1);",
                        "                }",
                        "                else {",
                        "                    if(doneMissions[i] == 0) AddDialogInject('d8MissionGaal', '', CT(\"Script.Mod_RefNisper.499\"), 1);",
                        "                    else if(doneMissions[i] == 3) AddDialogOverride('d8MissionGaalW', 1);",
                        "                }",
                        "            }",
                        "        }",
