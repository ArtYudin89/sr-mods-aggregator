                    "Code": [
                        "tstr = '';",
                        "for(i=0;GroupCount(ShipyardsGroup)>i;i=i+1) {",
                        "    thisShip = GroupShip(ShipyardsGroup,i);",
                        "    tstr = tstr + '==============='+CT('FormInfo.br')+Name(thisShip)+CT('FormInfo.br')+CT(\"Script.Mod_RefNisper.568\")+' '+Name(StarToCon(ShipStar(thisShip)))+' '+CT(\"Script.Mod_RefNisper.567\")+' '+Name(ShipStar(thisShip))+CT('FormInfo.br')+CT(\"Script.Mod_RefNisper.566\")+HullHP(thisShip)+'/'+ItemSize(ShipEqInSlot(thisShip,t_Hull))+CT('FormInfo.br')+CT('FormInfo.br');",
                        "}",
                        "DChange(150);",
                        "exit;"
                    ],
