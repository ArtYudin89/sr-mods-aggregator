                        "          if(nameCustomShip==''&&ShipOwner(potentialEnemy)==5&&serieStar==ItemSubrace(ShipItems(potentialEnemy,0)))",
                        "            pointsStar=pointsStar-ChanceToWin(potentialEnemy,IdToShip(bossId),1);",
                        "          else if((nameCustomShip=='SubFaction.Nisper')||(nameCustomShip==''&&ShipOwner(potentialEnemy)<=4))",
                        "            pointsStar=pointsStar+ChanceToWin(potentialEnemy,IdToShip(bossId),1);",
                        "          else",
                        "            pointsStar=pointsStar+0.8*ChanceToWin(potentialEnemy,IdToShip(bossId),1);",
                        "        }",
                        "        pointsStar=1.3*pointsStar;",
                        "      }",
                        "      else if(StarOwner(possibleStar)==2&&StarToCon(possibleStar)!=pirateSector){",
                        "        for (j=0;j<StarShips(possibleStar);j=j+1){",
                        "          potentialEnemy=StarShips(possibleStar,j);",
                        "          nameCustomShip=ShipCustomFaction(potentialEnemy);",
                        "          if(nameCustomShip==''&&ShipOwner(potentialEnemy)==7)",
                        "            pointsStar=pointsStar-ChanceToWin(potentialEnemy,IdToShip(bossId),1);",
                        "          else if((nameCustomShip=='SubFaction.Nisper')||(nameCustomShip==''&&ShipOwner(potentialEnemy)<=4))",
                        "            pointsStar=pointsStar+ChanceToWin(potentialEnemy,IdToShip(bossId),1);",
