                        "  AddItemToShip(ship, CreateEquipment(eq, GiveMassWeapon(eq,0), power, 5));",
                        "}",
                        "",
                        "function GiveWeaponShtip(level, ship) {",
                        "  str eq;",
                        "  if(level==1){",
                        "    eq=choice3(",
                        "      0.25, t_Weapon1,",
                        "      0.50, t_Weapon3,",
                        "      0.25, t_Weapon5",
                        "    );",
                        "  }",
                        "  else if(level==2){",
                        "    eq=choice4(",
                        "      0.25, t_Weapon1,",
                        "      0.45, t_Weapon3,",
                        "      0.25, t_Weapon5,",
                        "      0.05, t_Weapon11",
                        "    );",
                        "  }",
                        "  else if(level==3){",
                        "    eq=choice4(",
                        "      0.20, t_Weapon1,",
                        "      0.45, t_Weapon3,",
                        "      0.25, t_Weapon5,",
                        "      0.10, t_Weapon11",
                        "    );",
                        "  }",
                        "  else if(level==4){",
                        "    eq=choice4(",
                        "      0.10, t_Weapon1,",
                        "      0.45, t_Weapon3,",
                        "      0.35, t_Weapon5,",
                        "      0.10, t_Weapon11",
                        "    );",
                        "  }",
                        "  else if(level==5){",
                        "    eq=choice5(",
                        "      0.10, t_Weapon1,",
                        "      0.35, t_Weapon3,",
                        "      0.40, t_Weapon5,",
                        "      0.05, t_Weapon10,",
