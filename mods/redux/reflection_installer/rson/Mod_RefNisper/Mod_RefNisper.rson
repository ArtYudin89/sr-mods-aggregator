                        "",
                        "function GiveAcrin(level, ship, type){",
                        "  if(type==0){",
                        "    ShipSpecialBonuses(ship,bonWRadius,(0.7+0.4*curDomLevel)*10);",
                        "    ShipSpecialBonuses(ship,bonWEnergy,(0.7+0.4*curDomLevel)*2.7);",
                        "    ShipSpecialBonuses(ship,bonWSplinter,(0.7+0.4*curDomLevel)*3.75);",
                        "    ShipSpecialBonuses(ship,bonDef,(0.7+0.2*curDomLevel)*-1.2);",
                        "    ShipSpecialBonuses(ship,bonHull,(0.7+0.2*curDomLevel)*-0.5);",
                        "  }",
                        "  else if(type==1){",
                        "    ShipSpecialBonuses(ship,bonSpeed,(0.7+0.4*curDomLevel)*1.15*30);",
                        "    ShipSpecialBonuses(ship,bonWEnergy,(0.7+0.4*curDomLevel)*1.15*2.7);",
                        "    ShipSpecialBonuses(ship,bonWRadius,(0.7+0.4*curDomLevel)*1.15*10);",
                        "    ShipSpecialBonuses(ship,bonDef,(0.7+0.2*curDomLevel)*1.15*-1.2);",
                        "    ShipSpecialBonuses(ship,bonDroid,(0.7+0.2*curDomLevel)*1.15*-5);",
                        "  }",
                        "  else if(type==2){",
                        "    ShipSpecialBonuses(ship,bonWSplinter,(0.7+0.4*curDomLevel)*1.3*3.75);",
                        "    ShipSpecialBonuses(ship,bonWMissile,(0.7+0.4*curDomLevel)*1.3*2.1);",
                        "    ShipSpecialBonuses(ship,bonDef,(0.7+0.4*curDomLevel)*1.3*1.2);",
                        "    ShipSpecialBonuses(ship,bonDroid,(0.7+0.2*curDomLevel)*1.3*-5);",
                        "    ShipSpecialBonuses(ship,bonWEnergy,(0.7+0.2*curDomLevel)*1.3*-2.7);",
                        "  }",
                        "  else if(type==3){",
                        "    ShipSpecialBonuses(ship,bonWMissile,(0.7+0.4*curDomLevel)*1.45*2.1);",
                        "    ShipSpecialBonuses(ship,bonDroid,(0.7+0.4*curDomLevel)*1.45*5);",
                        "    ShipSpecialBonuses(ship,bonSpeed,(0.7+0.4*curDomLevel)*1.45*30);",
                        "    ShipSpecialBonuses(ship,bonWSplinter,(0.7+0.2*curDomLevel)*1.45*-3.75);",
                        "    ShipSpecialBonuses(ship,bonWRadius,(0.7+0.2*curDomLevel)*1.45*-10);",
                        "  }",
                        "  else if(type==4){",
                        "    ShipSpecialBonuses(ship,bonWSplinter,(0.7+0.4*curDomLevel)*1.6*3.75);",
                        "    ShipSpecialBonuses(ship,bonDef,(0.7+0.4*curDomLevel)*1.6*1.2);",
                        "    ShipSpecialBonuses(ship,bonHull,(0.7+0.4*curDomLevel)*1.6*0.5);",
                        "    ShipSpecialBonuses(ship,bonWEnergy,(0.7+0.2*curDomLevel)*1.6*-2.7);",
                        "    ShipSpecialBonuses(ship,bonSpeed,(0.7+0.2*curDomLevel)*1.6*-30);",
                        "  }",
                        "  else if(type==5){",
                        "    ShipSpecialBonuses(ship,bonDroid,(0.7+0.4*curDomLevel)*1.75*5);",
                        "    ShipSpecialBonuses(ship,bonWEnergy,(0.7+0.4*curDomLevel)*1.75*2.7);",
                        "    ShipSpecialBonuses(ship,bonWRadius,(0.7+0.4*curDomLevel)*1.75*10);",
                        "    ShipSpecialBonuses(ship,bonWSplinter,(0.7+0.2*curDomLevel)*1.75*-3.75);",
                        "    ShipSpecialBonuses(ship,bonWMissile,(0.7+0.2*curDomLevel)*1.75*-2.1);",
                        "  }",
                        "  else if(type==6){",
                        "    ShipSpecialBonuses(ship,bonDef,(0.7+0.4*curDomLevel)*1.9*1.2);",
                        "    ShipSpecialBonuses(ship,bonDroid,(0.7+0.4*curDomLevel)*1.9*5);",
                        "    ShipSpecialBonuses(ship,bonHull,(0.7+0.4*curDomLevel)*1.9*0.5);",
                        "    ShipSpecialBonuses(ship,bonSpeed,(0.7+0.2*curDomLevel)*1.9*-30);",
                        "    ShipSpecialBonuses(ship,bonWRadius,(0.7+0.2*curDomLevel)*1.9*-10);",
                        "  }",
                        "}",
                        "",
                        "function GiveDomArts(level, ship, type){",
                        "  unknown arrayOfTheArts=newarray(14);",
                        "  arrayOfTheArts[0]=t_ArtefactSpeed;",
                        "  arrayOfTheArts[1]=t_ArtefactDroid;",
                        "  arrayOfTheArts[2]=t_ArtWeaponToSpeed;",
                        "  arrayOfTheArts[3]=t_ArtefactDef;",
                        "  arrayOfTheArts[4]=t_ArtEnergyDef;",
                        "  arrayOfTheArts[5]=t_ArtDefToEnergy;",
                        "  arrayOfTheArts[6]=t_ArtEnergyPulse;",
                        "  arrayOfTheArts[7]=t_ArtefactHull;",
                        "  arrayOfTheArts[8]=t_ArtMissileDef;",
                        "  arrayOfTheArts[9]=t_ArtDecelerate;",
                        "  arrayOfTheArts[10]=t_ArtSplinter;",
                        "  arrayOfTheArts[11]=t_ArtFastRacks;",
                        "  arrayOfTheArts[12]=t_ArtPDTurret;",
                        "  arrayOfTheArts[13]=t_ArtefactAntigrav;",
                        "  j=0;",
                        "  int countOfArts=(4.0+level)*(3.0+type)/25.0;",
                        "  countOfArts=Rnd(countOfArts-1,countOfArts+1);",
                        "  unknown arrayOfArtsOnShip=newarray(10);",
                        "  for(i=0;i<10;i=i+1)",
                        "    arrayOfArtsOnShip[i]=0;",
                        "  while(j<countOfArts){",
                        "    random=Rnd(0,13);",
                        "    bool=1;",
                        "    dword ourArt=arrayOfTheArts[random];",
                        "    for(i=0;i<4;i=i+1){",
                        "      if(arrayOfArtsOnShip[i]==ourArt)",
                        "        bool=0;",
                        "    }",
                        "    if(bool){",
                        "      arrayOfArtsOnShip[j]=ourArt;",
                        "      j=j+1;",
                        "      ourArt=CreateArt(ourArt,5);",
                        "      AddItemToShip(ship,ourArt);",
                        "    }",
                        "  }",
                        "}",
                        "// Случайное действительно число от 0.0 до 1.0 с шагом 1e-9",
                        "function random_real() {",
                        "    result = 1.0 * Rnd(0, 1000000000) / 1000000000.0;",
                        "}",
                        "",
                        "// Функции для взвешенного случайного выбора из нескольких значений (надеюсь я нигде не опечатался)",
                        "//(Маршал) Я был в ужасе от этих функций в Cat_Rangers. Теперь буду наблюдать этот ужас в RefNisper. Ну нахер",
                        "// w1 - вес, a - значение",
                        "// Сумма весов не обязательно равна 1",
                        "function choice2(w1, a, w2, b) {",
                        "    if (w1 + w2 == 0) {",
                        "        result = choice2(1.0, a, 1.0, b);",
                        "    } else {",
                        "        if (random_real() < 1.0 * w1 / (0.0 + w1 + w2)) {",
                        "            result = a;",
                        "        } else {",
                        "            result = b;",
                        "        }",
                        "    }",
                        "}",
                        "",
                        "function choice4(w1, a, w2, b, w3, c, w4, d) {",
                        "    result = choice2(",
                        "        w1 + w2, choice2(w1, a, w2, b),",
                        "        w3 + w4, choice2(w3, c, w4, d)",
                        "    );",
                        "}",
                        "",
                        "function choice8(w1, a, w2, b, w3, c, w4, d, w5, e, w6, f, w7, g, w8, h) {",
                        "    result = choice2(",
                        "        w1 + w2 + w3 + w4, choice4(w1, a, w2, b, w3, c, w4, d),",
                        "        w5 + w6 + w7 + w8, choice4(w5, e, w6, f, w7, g, w8, h)",
                        "    );",
                        "}",
                        "",
                        "//function choice16(w1, a, w2, b, w3, c, w4, d, w5, e, w6, f, w7, g, w8, h, w9, i, w10, j, w11, k, w12, l, w13, m, w14, n, w15, p, w16, p) {",
                        "//    result = choice2(",
                        "//        w1 + w2 + w3 + w4 + w5 + w6 + w7 + w8, choice8(w1, a, w2, b, w3, c, w4, d, w5, e, w6, f, w7, g, w8, h),",
                        "//        w9 + w10 + w11 + w12 + w13 + w14 + w15 + w16, choice8(w9, i, w10, j, w11, k, w12, l, w13, m, w14, n, w15, p, w16, p)",
                        "//    );",
                        "//}",
                        "",
                        "function choice3(w1, a, w2, b, w3, c) {",
                        "    result = choice4(w1, a, w2, b, w3, c, 0, 0);",
                        "}",
                        "",
                        "function choice5(w1, a, w2, b, w3, c, w4, d, w5, e) {",
                        "    result = choice8(w1, a, w2, b, w3, c, w4, d, w5, e, 0, 0, 0, 0, 0, 0);",
                        "}",
                        "",
                        "function choice6(w1, a, w2, b, w3, c, w4, d, w5, e, w6, f) {",
                        "    result = choice8(w1, a, w2, b, w3, c, w4, d, w5, e, w6, f, 0, 0, 0, 0);",
                        "}",
                        "",
                        "function choice7(w1, a, w2, b, w3, c, w4, d, w5, e, w6, f, w7, g) {",
                        "    result = choice8(w1, a, w2, b, w3, c, w4, d, w5, e, w6, f, w7, g, 0, 0);",
                        "}",
                        "",
                        "// Приводит значение val к диапазону (mn,mx)",
                        "function toDiap(val, mn, mx) {",
                        "    result = min(max(val, mn), mx);",
                        "    //result = choice3(",
                        "    //    val < mn, mn,",
                        "    //    val > mx, mx,",
                        "    //    val >= mn && val <= mx, val",
                        "    //);",
                        "}",
                        "",
                        "// Возвращает истину (1) с вероятностью p, иначе - ложь (0)",
                        "function prob(p) {",
                        "    result = choice2(1.0 - p, 0, 0.0 + p, 1);",
                        "}",
                        "",
                        "// random_real()",
                        "// choiceN(weight_i, val_i, ...)",
                        "// toDiap(val, min, max)",
                        "// prob(p)",
                        "",
