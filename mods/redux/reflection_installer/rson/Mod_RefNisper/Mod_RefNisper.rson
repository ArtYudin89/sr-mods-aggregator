                {
                    "Name": "",
                    "Pos.x": 1560,
                    "Pos.y": 1115,
                    "Type": "TDialogAnswer",
                    "Parent": -1,
                    "#": 388,
                    "Msg": "Ясно. Спасибо за ответы. Я тогда уже, пожалуй, полечу по своим делам.",
