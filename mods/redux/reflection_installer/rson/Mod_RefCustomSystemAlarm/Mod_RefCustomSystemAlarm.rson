                },
                {
                    "Name": "",
                    "Code.Type": "Turn",
                    "Code": [
                        "temp_dword = GAnswerData;",
                        "temp_str_local = Name(GAnswerData);",
                        "DChange(3);",
                        "exit;"
                    ],
                    "#": 37,
                    "Type": "Top",
                    "Parent": -1,
                    "Pos.x": 340,
                    "Pos.y": 375
                },
                {
                    "Name": "",
                    "Code.Type": "Turn",
                    "Code": [
                        "if(FlagCount >= 1) {",
                        "  DAdd(0);",
                        "}",
                        "if(FlagCount == 0) {",
                        "  DAdd(1);",
                        "}",
                        "if(FlagCount >= 2) {",
                        "  DAdd(2);",
                        "}",
                        "if(FlagCount == 1) {",
                        "  DAdd(3);",
                        "}",
                        "if(FlagCount == 3) {",
                        "  DAdd(4);",
                        "}",
                        "if(FlagCount == 2) {",
                        "  DAdd(5);",
                        "}"
                    ],
                    "#": 38,
                    "Type": "Top",
                    "Parent": -1,
                    "Pos.x": -20,
                    "Pos.y": 445
                },
                {
                    "Name": "",
                    "Code.Type": "Turn",
                    "Code": [
                        "DAdd(6);"
                    ],
                    "#": 39,
                    "Type": "Top",
                    "Parent": -1,
                    "Pos.x": 130,
                    "Pos.y": 445
                },
                {
                    "Name": "",
                    "Code.Type": "Turn",
                    "Code": [
                        "for(i = 0;ConStars(temp_dword) > i;i = i + 1) {",
                        "    if(ConStar(temp_dword,i) != ShipStatistic(Player(),10)) {",
                        "        if(StarEnemyThreatLevel(ConStar(temp_dword,i),1) > 1) continue;",
                        "        InjectAnswer('DialogSystems',Name(ConStar(temp_dword,i)),ConStar(temp_dword,i));",
                        "    }",
                        "}",
                        "InjectAnswer('AlarmDialog',CT(\"Script.Mod_RefCustomSystemAlarm.25\"),0);"
                    ],
                    "#": 40,
                    "Type": "Top",
                    "Parent": -1,
                    "Pos.x": 280,
                    "Pos.y": 445
                },
                {
                    "Name": "",
                    "Code.Type": "Turn",
                    "Code": [
                        "InjectAnswer('AlarmDialog',CT(\"Script.Mod_RefCustomSystemAlarm.25\"),0);",
                        "DAdd(7);"
                    ],
                    "#": 41,
                    "Type": "Top",
                    "Parent": -1,
                    "Pos.x": 430,
                    "Pos.y": 445
                },
                {
                    "Name": "",
                    "Code.Type": "Turn",
                    "Code": [
                        "for(i = 0;GalaxySectors() > i;i = i + 1) {",
                        "    if(!SectorVisible(GalaxySectors(i))) continue;",
                        "    InjectAnswer('DialogSector',Name(GalaxySectors(i)),GalaxySectors(i));",
                        "}",
                        "InjectAnswer('AlarmDialog',CT(\"Script.Mod_RefCustomSystemAlarm.25\"),0);"
                    ],
                    "#": 42,
                    "Type": "Top",
                    "Parent": -1,
                    "Pos.x": 580,
                    "Pos.y": 445
                },
                {
                    "Name": "",
                    "Code.Type": "Turn",
                    "Code": [
                        "if(FlagCount == 1) {",
                        "    temp_str1 = CT(\"Script.Mod_RefCustomSystemAlarm.18\");",
                        "    IDOne = 0;",
                        "    FlagCount = FlagCount - 1;",
                        "}",
                        "if(FlagCount == 2) {",
                        "    temp_str1 = temp_str2;",
                        "    IDOne = IDThree;",
                        "    FlagCount = FlagCount - 1;",
                        "    IDTwo = 0;",
                        "    temp_str3 = CT(\"Script.Mod_RefCustomSystemAlarm.18\");",
                        "}",
                        "if(FlagCount == 3) {",
