                        "GRun();"
                    ],
                    "#": 15,
                    "Type": "Top",
                    "Parent": -1,
                    "Pos.x": 0,
                    "Pos.y": 585
                },
                {
                    "Name": "",
                    "Code.Type": "Turn",
                    "Code": [
                        "int cd1, cd2 ,cd3; //кулдаун уведомления о пиздеце в системе",
                        "if(FlagCount == 1) {",
                        "    if(cd1 == 0) {",
                        "        if(StarEnemyThreatLevel(PlanetToStar(IdToPlanet(IDOne)),1) == 2) {",
                        "            cd1 = 15;",
                        "            CustomEther('Galaxy_Alert',0,'',Format(CT(\"Script.Mod_RefCustomSystemAlarm.3\"),\"<0>\",temp_str1));",
                        "        }",
                        "        if(StarEnemyThreatLevel(PlanetToStar(IdToPlanet(IDOne))) == 3) {",
                        "            CustomEther('Galaxy_Alert',0,'',Format(CT(\"Script.Mod_RefCustomSystemAlarm.2\"),\"<0>\",temp_str1));",
                        "            IDOne = 0;",
                        "            temp_str1 = CT(\"Script.Mod_RefCustomSystemAlarm.18\");",
                        "            FlagCount = FlagCount - 1;",
                        "        }",
                        "    }",
                        "}",
                        "if(FlagCount == 2) {",
                        "    if(cd1 == 0) {",
                        "        if(StarEnemyThreatLevel(PlanetToStar(IdToPlanet(IDOne)),1) == 2) {",
                        "            cd1 = 15;",
                        "            CustomEther('Galaxy_Alert',0,'',Format(CT(\"Script.Mod_RefCustomSystemAlarm.3\"),\"<0>\",temp_str1));",
                        "        }",
                        "        if(StarEnemyThreatLevel(PlanetToStar(IdToPlanet(IDOne))) == 3) {",
                        "            CustomEther('Galaxy_Alert',0,'',Format(CT(\"Script.Mod_RefCustomSystemAlarm.2\"),\"<0>\",temp_str1));",
                        "            IDOne = IDTwo;",
                        "            temp_str1 = temp_str2;",
                        "            FlagCount = FlagCount - 1;",
                        "        }",
                        "    }",
                        "    if(cd2 == 0) {",
                        "        if(StarEnemyThreatLevel(PlanetToStar(IdToPlanet(IDTwo)),1) == 2) {",
                        "            cd2 = 15;",
                        "            CustomEther('Galaxy_Alert',0,'',Format(CT(\"Script.Mod_RefCustomSystemAlarm.3\"),\"<0>\",temp_str2));",
                        "        }",
                        "        if(StarEnemyThreatLevel(PlanetToStar(IdToPlanet(IDTwo))) == 3) {",
                        "            CustomEther('Galaxy_Alert',0,'',Format(CT(\"Script.Mod_RefCustomSystemAlarm.2\"),\"<0>\",temp_str2));",
                        "            IDTwo = IDThree;",
                        "            temp_str2 = temp_str3;",
                        "            if(IDTwo == IDOne) {",
                        "                IDTwo = 0;",
                        "                temp_str2 = CT(\"Script.Mod_RefCustomSystemAlarm.18\");",
                        "            }",
                        "            FlagCount = FlagCount - 1;",
                        "        }",
                        "    }",
                        "}",
                        "if(FlagCount == 3) {",
                        "    if(cd1 == 0) {",
                        "        if(StarEnemyThreatLevel(PlanetToStar(IdToPlanet(IDOne)),1) == 2) {",
                        "            cd1 = 15;",
                        "            CustomEther('Galaxy_Alert',0,'',Format(CT(\"Script.Mod_RefCustomSystemAlarm.3\"),\"<0>\",temp_str1));",
                        "        }",
                        "        if(StarEnemyThreatLevel(PlanetToStar(IdToPlanet(IDOne))) == 3) {",
                        "            CustomEther('Galaxy_Alert',0,'',Format(CT(\"Script.Mod_RefCustomSystemAlarm.2\"),\"<0>\",temp_str1));",
                        "            IDOne = IDThree;",
                        "            temp_str1 = temp_str3;",
                        "            FlagCount = FlagCount - 1;",
                        "        }",
                        "    }",
                        "    if(cd2 == 0) {",
                        "        if(StarEnemyThreatLevel(PlanetToStar(IdToPlanet(IDTwo)),1) == 2) {",
                        "            cd2 = 15;",
                        "            CustomEther('Galaxy_Alert',0,'',Format(CT(\"Script.Mod_RefCustomSystemAlarm.3\"),\"<0>\",temp_str2));",
                        "        }",
                        "        if(StarEnemyThreatLevel(PlanetToStar(IdToPlanet(IDTwo))) == 3) {",
                        "            CustomEther('Galaxy_Alert',0,'',Format(CT(\"Script.Mod_RefCustomSystemAlarm.2\"),\"<0>\",temp_str2));",
                        "            IDTwo = IDThree;",
                        "            temp_str2 = temp_str3;",
                        "            if(IDTwo == IDOne) {",
                        "                IDTwo = 0;",
                        "                temp_str2 = CT(\"Script.Mod_RefCustomSystemAlarm.18\");",
                        "            }",
                        "            FlagCount = FlagCount - 1;",
                        "        }",
                        "    }",
                        "    if(cd3 == 0) {",
                        "        if(StarEnemyThreatLevel(PlanetToStar(IdToPlanet(IDThree)),1) == 2) {",
                        "            cd3 = 15;",
                        "            CustomEther('Galaxy_Alert',0,'',Format(CT(\"Script.Mod_RefCustomSystemAlarm.3\"),\"<0>\",temp_str3));",
                        "        }",
                        "        if(StarEnemyThreatLevel(PlanetToStar(IdToPlanet(IDThree))) == 3) {",
                        "            CustomEther('Galaxy_Alert',0,'',Format(CT(\"Script.Mod_RefCustomSystemAlarm.2\"),\"<0>\",temp_str3));",
                        "            IDThree = 0;",
                        "            temp_str3 = CT(\"Script.Mod_RefCustomSystemAlarm.18\");",
                        "            FlagCount = FlagCount - 1;",
                        "        }",
                        "    }",
                        "}",
                        "if(cd1 != 0) cd1 = cd1 - 1;",
                        "if(cd2 != 0) cd2 = cd2 - 1;",
                        "if(cd3 != 0) cd3 = cd3 - 1;"
                    ],
                    "#": 16,
                    "Type": "Top",
                    "Parent": -1,
                    "Pos.x": 120,
                    "Pos.y": 585
                },
                {
                    "Name": "",
                    "Code.Type": "DialogBegin",
                    "Code": [
                        "if(PlayerBridge()==12) {",
                        "  if(FlagCount == 0) {",
                        "      temp_str_main = CT(\"Script.Mod_RefCustomSystemAlarm.24\");",
                        "  }",
                        "  if(FlagCount == 1) {",
                        "      temp_str_main = CT(\"Script.Mod_RefCustomSystemAlarm.23\")+' ' + temp_str1;",
                        "  }",
                        "  if(FlagCount == 2) {",
                        "      temp_str_main = CT(\"Script.Mod_RefCustomSystemAlarm.22\")+' ' + temp_str1 + ' '+CT(\"Script.Mod_RefCustomSystemAlarm.20\")+' ' + temp_str2;",
                        "  }",
                        "  if(FlagCount == 3) temp_str_main = CT(\"Script.Mod_RefCustomSystemAlarm.21\")+' ' + temp_str1 + ', ' + temp_str2 + ' '+CT(\"Script.Mod_RefCustomSystemAlarm.20\")+' ' + temp_str3;",
                        "  AddDialogInject('AlarmDialog',CT(\"Script.Mod_RefCustomSystemAlarm.19\")+' ' + temp_str_main,CT(\"Script.Mod_RefCustomSystemAlarm.4\"),19);",
                        "}"
                    ],
                    "#": 17,
                    "Type": "Top",
                    "Parent": -1,
                    "Pos.x": 180,
                    "Pos.y": 585
                },
                {
                    "Name": "",
                    "Code.Type": "Turn",
                    "Code": [
                        "DChange(0);",
                        "exit;"
                    ],
                    "#": 35,
                    "Type": "Top",
                    "Parent": -1,
                    "Pos.x": -20,
                    "Pos.y": 375
                },
                {
                    "Name": "",
                    "Code.Type": "Turn",
                    "Code": [
                        "temp_dword = GAnswerData;",
