                    "Parent": -1,
                    "Pos.x": 580,
                    "Pos.y": 445
                },
                {
                    "Name": "",
                    "Code.Type": "Turn",
                    "Code": [
                        "DAdd(8);"
                    ],
                    "#": 42,
                    "Type": "Top",
                    "Parent": -1,
                    "Pos.x": 730,
                    "Pos.y": 445
                },
                {
                    "Name": "",
                    "Code.Type": "Turn",
                    "Code": [
                        "NoFlagy = 0;",
                        "tempik = ListBox('Выберите систему из списка',NamesArray);",
                        "if(tempik == -1) NoFlagy = 2;",
                        "else if(tempik == 20) NoFlagy = 2;",
                        "else {",
                        "    tempik = tempik - 1;",
                        "    if(SectorVisible(GalaxySectors(tempik))) NoFlagy = 1;",
                        "    else if(!SectorVisible(GalaxySectors(tempik))) {",
                        "        strSector = NamesArray[tempik+1];",
                        "        if(ShipMoney(Player()) > 5000000) ein = ShipMoney(Player()) / 50000;",
                        "        if(ShipMoney(Player()) < 5000000) ein = ShipMoney(Player()) / 30000;",
                        "        if(ShipMoney(Player()) < 1000000) ein = ShipMoney(Player()) / 15000;",
                        "        if(ShipMoney(Player()) < 300000) ein = ShipMoney(Player()) / 7500;",
                        "        if(ShipMoney(Player()) < 100000) ein = ShipMoney(Player()) / 5000;",
                        "        zwei = GalaxyTechLevel() * GalaxyDiffLevels(5) / 50;",
                        "        money = 30 * ein * zwei * Rnd(80,120) / 100 + 5000;",
                        "        if(ConNear(StarToCon(ShipStar(Player())),GalaxySectors(tempik))) int dab;",
                        "        else money = money * 2;",
                        "        if(ShipMoney(Player()) < money) AddDialogBlock('Да, пересылайте!',1);",
                        "        else AddDialogBlock('Да, пересылайте!',0);",
                        "    }",
                        "}",
                        "//SFT(NoFlagy);",
                        "StartFlag = 1;",
                        "if(NoFlagy == 0) {",
                        "  DChange(1);",
                        "  exit;",
                        "}",
                        "if(NoFlagy == 2) {",
                        "  DChange(5);",
                        "  exit;",
                        "}",
                        "if(NoFlagy == 1) {",
                        "  DChange(4);",
                        "  exit;",
                        "}"
                    ],
                    "#": 43,
                    "Type": "Top",
                    "Parent": -1,
                    "Pos.x": -20,
                    "Pos.y": 515
                },
                {
                    "Name": "",
                    "Code.Type": "Turn",
                    "Code": [
                        "ShipMoney(Player(),ShipMoney(Player()) - money);",
                        "SectorVisible(GalaxySectors(tempik),1);",
                        "Sound('Sound.Sell');",
                        "StartFlag = 1;",
                        "DChange(2);",
                        "exit;"
