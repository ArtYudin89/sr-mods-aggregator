                    "Code": [
                        "GRun();"
                    ],
                    "#": 16,
                    "Type": "Top",
                    "Parent": -1,
                    "Pos.x": 0,
                    "Pos.y": 585
                },
                {
                    "Name": "",
                    "Code.Type": "Init",
                    "Code": [
                        "int i;",
                        "sectorsArr = newarray(1);",
                        "for(i = 0; i < 19; i = i + 1) {",
                        "    ArrayAdd(sectorsArr,GalaxySectors(i));",
                        "}",
                        "NamesArray = newarray(1);",
                        "for(i = 0; i < 19; i = i + 1) {",
                        "    ArrayAdd(NamesArray,Name(GalaxySectors(i)));",
                        "}",
                        "ArrayAdd(NamesArray,'Вернуться к выбору','Eexit');"
                    ],
                    "#": 17,
                    "Type": "Top",
                    "Parent": -1,
                    "Pos.x": 60,
                    "Pos.y": 585
                },
                {
                    "Name": "",
                    "Code.Type": "DialogBegin",
                    "Code": [
                        "if(PlayerBridge() == 11) {",
                        "  AddDialogInject('', CT(\"Script.Mod_RefBridgeMaps.16\"), 'BlockThisAnswer', 1, 1);",
                        "  AddDialogBlock('BlockThisAnswer',2);",
                        "  AddDialogBlock(CT('FormRuins.Bridge.BridgeExit'),2);",
                        "  AddDialogInject('Dialog_Maps', '', CT(\"Script.Mod_RefBridgeMaps.2\"), 1);",
                        "}"
                    ],
                    "#": 18,
                    "Type": "Top",
                    "Parent": -1,
                    "Pos.x": 180,
                    "Pos.y": 585
                },
                {
                    "Name": "",
                    "Code.Type": "Turn",
                    "Code": [
                        "if(StartFlag == 1) temp_str = 'Вы вновь зашли на сайт Картографической Комиссии. Снова вас встретила приятная анимация перехода к чёрно-звёздному фону, и вы подумали, что не зря они ставят такие цены на звёздные карты - хотя бы смогли нанять хороших программистов и художников.';",
                        "else temp_str = 'Этот сайт отличался от других. Несмотря на, походу, уходящие далеко в века рассказы о том, какие анахронизмы, ляпы, глюки и баги встречаются на сайтах государственных учреждений, этот сайт встретил приятной анимацией постепенного перехода к чёрно-звёздному фону.';",
                        "DChange(0);",
                        "exit;"
                    ],
                    "#": 36,
                    "Type": "Top",
                    "Parent": -1,
                    "Pos.x": -20,
                    "Pos.y": 375
                },
                {
                    "Name": "",
                    "Code.Type": "Turn",
                    "Code": [
                        "DAdd(0);",
