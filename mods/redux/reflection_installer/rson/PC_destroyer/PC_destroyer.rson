                    "#": 75,
                    "Msg": "Жду с нетерпением!",
                    "AMsg.Num": "14",
                    "_orig_danswer": "DAnswer('restart~'+CT(\"Script.PC_destroyer.97\"))"
                },
                {
                    "Name": "",
                    "Pos.x": 0,
