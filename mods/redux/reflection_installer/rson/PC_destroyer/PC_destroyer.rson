                    "AMsg.Num": "27",
                    "_orig_danswer": "DAnswer(CT(\"Script.PC_destroyer.111\"))"
                },
                {
                    "Name": "block",
                    "Pos.x": 1560,
                    "Pos.y": 615,
                    "Type": "TDialogAnswer",
                    "Parent": -1,
                    "#": 89,
                    "Msg": "Совершить гипер-прыжок (недостаточно энергии)",
                    "AMsg.Num": "28",
