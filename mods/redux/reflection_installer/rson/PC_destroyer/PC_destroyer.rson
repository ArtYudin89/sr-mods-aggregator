                    "Parent": -1,
                    "Pos.x": 1030,
                    "Pos.y": 520
                },
                {
                    "Name": "",
                    "Code.Type": "Turn",
                    "Code": [
                        "if(ShipCustomShipInfoData(Player(),'RefSalamanderEnergy',1) < 10) {",
                        "  DAdd(25);",
                        "}",
                        "if(ShipCustomShipInfoData(Player(),'RefSalamanderEnergy',1) < 140) {",
                        "  DAdd(28);",
                        "}",
                        "if(ShipCustomShipInfoData(Player(),'RefSalamanderEnergy',1) >= 10) {",
                        "  DAdd(26);",
                        "}",
                        "if(ShipCustomShipInfoData(Player(),'RefSalamanderEnergy',1) >= 140) {",
                        "  DAdd(27);",
                        "}",
                        "if(~ShipFindCustomShipInfoByType(Player(),'RefSalamanderRockets')) {",
                        "  DAdd(23);",
                        "}",
                        "if(ShipFindCustomShipInfoByType(Player(),'RefSalamanderRockets') == -1) {",
                        "  DAdd(24);",
                        "}"
                    ],
