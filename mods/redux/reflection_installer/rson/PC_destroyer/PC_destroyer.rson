                },
                {
                    "Name": "",
                    "Pos.x": 120,
                    "Pos.y": 590,
                    "Type": "TDialogAnswer",
                    "Parent": -1,
                    "#": 62,
                    "Msg": "Да, у меня есть достаточное количество нодов",
