            "Items": [
                {
                    "Type": "TItem",
                    "Name": "AncientCrystal",
                    "Class": 5,
                    "Item.Type": 0,
                    "Size": 10,
                    "Level": 1,
                    "Radius": 150,
                    "Owner": 6,
