                    "Type": "TDialogAnswer",
                    "Parent": -1,
                    "#": 77,
                    "Msg": "Хорошо, скоро вернусь",
                    "AMsg.Num": "16",
                    "_orig_danswer": "DAnswer('restart~'+CT(\"Script.PC_destroyer.98\"))"
                },
                {
                    "Name": "restart",
                    "Pos.x": 240,
                    "Pos.y": 615,
                    "Type": "TDialogAnswer",
                    "Parent": -1,
                    "#": 78,
                    "Msg": "Спасибо за информацию",
                    "AMsg.Num": "17",
                    "_orig_danswer": "DAnswer('restart~'+CT(\"Script.PC_destroyer.99\"))"
                },
                {
                    "Name": "restart",
                    "Pos.x": 360,
                    "Pos.y": 615,
                    "Type": "TDialogAnswer",
                    "Parent": -1,
                    "#": 79,
                    "Msg": "Спасибо, очень жаль...",
                    "AMsg.Num": "18",
                    "_orig_danswer": "DAnswer('restart~'+CT(\"Script.PC_destroyer.55\"))"
                },
                {
                    "Name": "restart",
                    "Pos.x": 480,
                    "Pos.y": 615,
                    "Type": "TDialogAnswer",
                    "Parent": -1,
                    "#": 80,
                    "Msg": "Горе вы луковое, а не конструктора. Ну вас к махпелловой бабушке.",
                    "AMsg.Num": "19",
                    "_orig_danswer": "DAnswer('restart~'+CT(\"Script.PC_destroyer.100\"))"
                },
                {
                    "Name": "",
                    "Pos.x": 600,
                    "Pos.y": 615,
                    "Type": "TDialogAnswer",
                    "Parent": -1,
                    "#": 81,
                    "Msg": "Мне сейчас выпивка неинтересна, давай уже говори, что там с кристаллом!",
                    "AMsg.Num": "20",
                    "_orig_danswer": "DAnswer(CT(\"Script.PC_destroyer.101\"))"
                },
                {
                    "Name": "",
                    "Pos.x": 720,
                    "Pos.y": 615,
                    "Type": "TDialogAnswer",
                    "Parent": -1,
                    "#": 82,
                    "Msg": "Это всё крайне интересно и захватывающе, а что насчёт корабля?",
                    "AMsg.Num": "21",
                    "_orig_danswer": "DAnswer(CT(\"Script.PC_destroyer.102\"))"
                },
                {
                    "Name": "",
                    "Pos.x": 840,
                    "Pos.y": 615,
                    "Type": "TDialogAnswer",
                    "Parent": -1,
                    "#": 83,
                    "Msg": "В смысле \"потеряли\"?!",
                    "AMsg.Num": "22",
                    "_orig_danswer": "DAnswer(CT(\"Script.PC_destroyer.103\"))"
                },
                {
                    "Name": "",
                    "Pos.x": 960,
                    "Pos.y": 615,
                    "Type": "TDialogAnswer",
                    "Parent": -1,
                    "#": 84,
                    "Msg": "Деактивировать автоматические пусковые установки",
                    "AMsg.Num": "23",
                    "_orig_danswer": "DAnswer(CT(\"Script.PC_destroyer.104\"))"
                },
                {
                    "Name": "",
                    "Pos.x": 1080,
                    "Pos.y": 615,
                    "Type": "TDialogAnswer",
                    "Parent": -1,
                    "#": 85,
                    "Msg": "Активировать автоматические пусковые установки",
                    "AMsg.Num": "24",
                    "_orig_danswer": "DAnswer(CT(\"Script.PC_destroyer.105\"))"
                },
                {
                    "Name": "block",
                    "Pos.x": 1200,
                    "Pos.y": 615,
                    "Type": "TDialogAnswer",
                    "Parent": -1,
                    "#": 86,
                    "Msg": "Совершить варп-прыжок (недостаточно энергии)",
                    "AMsg.Num": "25",
                    "_orig_danswer": "DAnswer('block~'+CT(\"Script.PC_destroyer.106\"))"
                },
                {
                    "Name": "",
                    "Pos.x": 1320,
                    "Pos.y": 615,
                    "Type": "TDialogAnswer",
                    "Parent": -1,
                    "#": 87,
                    "Msg": "Совершить варп-прыжок",
                    "AMsg.Num": "26",
                    "_orig_danswer": "DAnswer(CT(\"Script.PC_destroyer.107\"))"
                },
                {
                    "Name": "",
                    "Pos.x": 1440,
                    "Pos.y": 615,
