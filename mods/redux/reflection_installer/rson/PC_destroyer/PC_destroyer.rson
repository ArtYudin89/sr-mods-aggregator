                }
            ],
            "Operations": [
                {
                    "Name": "",
                    "Code.Type": "Global",
                    "Code": [
                        "GRun();"
                    ],
                    "#": 29,
                    "Type": "Top",
                    "Parent": -1,
                    "Pos.x": 0,
                    "Pos.y": 685
                },
                {
                    "Name": "",
                    "Code.Type": "Init",
                    "Code": [
                        "br = CT(\"Script.PC_destroyer.77\");",
                        "",
                        "// Количество вариантов размеров ТИ",
                        "variants_cnt = 3;",
                        "",
                        "// Список посещенных планет",
                        "list_visited = newarray(1);",
                        "list_visited[0] = 0;",
                        "",
                        "// Доступные варианты размеров ТИ",
                        "hull_variants = newarray(variants_cnt + 1);",
                        "hull_variants[1] = 1;",
                        "hull_variants[2] = 2;",
                        "hull_variants[3] = 3;",
                        "",
                        "// Размеры корпусов",
                        "hull_sizes = newarray(variants_cnt + 1);",
                        "hull_sizes[1] = 700;",
                        "hull_sizes[2] = 1100;",
                        "hull_sizes[3] = 1500;",
                        "",
                        "// Модификаторы цены (в %)",
                        "hull_costs = newarray(variants_cnt + 1);",
                        "hull_costs[1] = 150;",
                        "hull_costs[2] = 200;",
                        "hull_costs[3] = 250;",
                        "",
                        "nodes_needed = 500;",
                        "num_planets_needed = 30;",
                        "research_time = 20;",
                        "",
                        "function BaseCost() {",
                        "    result = 1000000 * GalaxyTechLevel()/8 / 100;",
                        "}",
                        "",
                        "function FindCrystal() {",
                        "    int cnt = ShipItems(Player());",
                        "    for(int i = 1; i < cnt; i = i + 1)",
                        "    {",
                        "        dword item = ShipItems(Player(), i);",
                        "        if(EquipmentImageName(item) != 'Usl_AncientCrystal') continue;",
                        "        result = item;",
                        "        exit;",
                        "    }",
                        "",
                        "    result = 0;",
                        "}"
                    ],
                    "#": 30,
                    "Type": "Top",
                    "Parent": -1,
                    "Pos.x": 60,
                    "Pos.y": 685
                },
                {
                    "Name": "",
                    "Code.Type": "Turn",
                    "Code": [
                        "if(GetShipPlanet(Player())) {",
                        "  if(!crystal_created) {",
                        "    if(PlanetOwner(GetShipPlanet(Player())) == None) {",
                        "      if(ArrayFind(list_visited, Id(GetShipPlanet(Player()))) == -1) {",
                        "        ArrayAdd(list_visited, Id(GetShipPlanet(Player())));",
                        "        if(ArrayDim(list_visited) > num_planets_needed) {",
                        "          if((Rnd(1, 1000) + (1000 / num_planets_needed) * ArrayDim(list_visited)) > 2000) {",
                        "            quest_item = CreateQuestItem('Usl_AncientCrystal');",
                        "            AddItemToPlanet(GetShipPlanet(Player()), quest_item);",
                        "            LinkItemToScript(quest_item, AncientCrystal);",
                        "            crystal_created = 1;",
                        "          }",
                        "        }",
                        "      }",
                        "    }",
                        "  }",
                        "}",
                        "if(0) {",
                        "  // Для теста",
                        "  research_time = 20;",
                        "  num_planets_needed = 2;",
                        "  ",
                        "  SFT('---------------------------------------------------------------');",
                        "  SFT('--- Date: ' + GameDateTxtByTurn(CurTurn()));",
                        "  SFT('--- CurTurn: ' + CurTurn());",
                        "  SFT('--- planets visited: ' + (ArrayDim(list_visited)-1));",
                        "  SFT('--- crystal_created: ' + crystal_created);",
                        "  if(research_start_date) SFT('--- research_start_date: ' + research_start_date);",
                        "  SFT('--- message_research_complete: ' + message_research_complete);",
                        "  if(!crystal_created) SFT('--- num_planets_needed: ' + num_planets_needed);",
                        "  SFT('--- crystal in player ship: ' + ItemIn(AncientCrystal, Player()));",
                        "  SFT('--- hull_variants: ' + (ArrayDim(hull_variants)-1));",
                        "  SFT('--- hull_available: ' + hull_available);",
                        "  SFT('--- br: (' + br + ')');",
                        "  //SFT('--- : ' + 0);",
                        "}",
                        "if(research_start_date) {",
                        "  if(CurTurn() > research_start_date + research_time) {",
                        "    if(!message_research_complete) {",
                        "      if(~IdToShip(base_id)) {",
                        "        message_research_complete = 1;",
                        "        if(ShipType(IdToShip(base_id)) == 'SB') {",
                        "            Ether(",
                        "                0, '',",
                        "                Format(CT(\"Script.PC_destroyer.79\"),\"<0>\",ShipName(Player()),\"<1>\",base_name,\"<2>\",base_name)",
                        "            );",
                        "        }",
                        "        else {",
                        "            Ether(",
                        "                0, '',",
                        "                Format(CT(\"Script.PC_destroyer.113\"),\"<0>\",ShipName(Player()),\"<1>\",base_name)",
                        "            );",
                        "        }",
                        "      }",
                        "    }",
                        "  }",
                        "  if(IdToShip(base_id) < 1) {",
                        "    research_start_date = 0;",
                        "    if(!salamander) {",
                        "        if(!CoalitionDefeated()) {",
                        "            Ether(",
                        "                0, '',",
                        "                Format(CT(\"Script.PC_destroyer.78\"),\"<0>\",ShipName(Player()),\"<1>\",base_name,\"<2>\",nodes_needed / 2)",
                        "            );",
                        "            RangerBaseNodes(Player(), RangerBaseNodes(Player()) + nodes_needed / 2);",
                        "        }",
                        "    }",
                        "    else {",
                        "        Ether(",
                        "            0, '',",
                        "            Format(CT(\"Script.PC_destroyer.80\"),\"<0>\",ShipName(Player()),\"<1>\",base_name)",
                        "        );",
                        "    }",
                        "  }",
                        "}"
                    ],
                    "#": 31,
                    "Type": "Top",
                    "Parent": -1,
                    "Pos.x": 120,
                    "Pos.y": 685
                },
                {
                    "Name": "",
                    "Code.Type": "DialogBegin",
                    "Code": [
                        "if(~HullSpecial(Player())) {",
                        "    if(HullSpecial(Player()) == FindBonusByNameInCfg('RefBlackSalamander')) {",
                        "        if(PlayerBridge() == 3) {",
                        "            AddDialogInject('Salamander','',CT(\"Script.PC_destroyer.82\"),20);",
                        "        }",
                        "    }",
                        "}",
                        "",
                        "if(GetShipRuins(Player())) {",
                        "    if(ShipType(GetShipRuins(Player())) == 'SB') {",
                        "        if(FindCrystal()) {",
                        "            AddDialogInject('DialogSB1', '', CT(\"Script.PC_destroyer.64\"), 10);",
                        "        }",
                        "        else if(message_research_complete && (Id(GetShipRuins(Player())) == base_id)) {",
                        "            AddDialogInject('DialogSB2', '', CT(\"Script.PC_destroyer.63\"), 10);",
                        "        }",
                        "        else if(hull_available) {",
                        "            AddDialogInject('DialogSB2', '', CT(\"Script.PC_destroyer.62\"), 10);",
                        "        }",
                        "    }",
                        "    else if(ShipType(GetShipRuins(Player())) == 'CB') {",
                        "        if(FindCrystal()) {",
                        "            AddDialogInject('DialogCB1', '', CT(\"Script.PC_destroyer.64\"), 10);",
                        "        }",
                        "        else if(message_research_complete && (Id(GetShipRuins(Player())) == base_id) && salamander == 1) {",
                        "            AddDialogInject('DialogCB2', '', CT(\"Script.PC_destroyer.63\"), 10);",
                        "        }",
                        "    }",
                        "}"
                    ],
                    "#": 32,
                    "Type": "Top",
                    "Parent": -1,
                    "Pos.x": 180,
                    "Pos.y": 685
                },
                {
                    "Name": "",
                    "Code.Type": "Turn",
                    "Code": [
                        "DChange(0);",
                        "exit;"
                    ],
                    "#": 90,
                    "Type": "Top",
                    "Parent": -1,
                    "Pos.x": -20,
                    "Pos.y": 425
                },
                {
                    "Name": "",
                    "Code.Type": "Turn",
                    "Code": [
                        "if(Id(GetShipRuins(Player())) != base_id) {",
                        "  if(IdToShip(base_id)) {",
                        "    DChange(7);",
                        "    exit;",
                        "  }",
                        "  if(!IdToShip(base_id)) {",
                        "    hull_available = 0;",
                        "    DChange(3);",
                        "    exit;",
                        "  }",
                        "}",
                        "if(Id(GetShipRuins(Player())) == base_id) {",
                        "  base_cost = BaseCost();",
                        "  if(hull_available) {",
                        "    str extra = CT('Script.PC_destroyer.BalanceStr');",
                        "    ",
                        "    msgStr = '</color>' + CT(\"Script.PC_destroyer.115\")+extra+' '+CT(\"Script.PC_destroyer.114\");",
                        "    sepStr = '-----------------------------------------------';",
                        "    for (i = 1; i <= variants_cnt; i = i + 1)",
                        "        if (i <= hull_available)",
                        "            msgStr = msgStr + br + sepStr + br + Format(CT(\"Script.PC_destroyer.76\"),\"<0>\",hull_sizes[hull_variants[i]],\"<1>\",base_cost * hull_costs[hull_variants[i]]);",
                        "    DChange(5);",
                        "    exit;",
                        "  }",
                        "  if(message_research_complete) {",
                        "    message_research_complete = 0;",
                        "    hull_available = variants_cnt;",
                        "    research_start_date = 0;",
                        "    DChange(6);",
                        "    exit;",
                        "  }",
                        "}"
                    ],
                    "#": 91,
                    "Type": "Top",
                    "Parent": -1,
                    "Pos.x": 130,
                    "Pos.y": 425
                },
                {
                    "Name": "",
                    "Code.Type": "Turn",
                    "Code": [
                        "variant_chosen = GAnswerData;",
                        "hull_available = hull_available - 1;",
                        "ShipMoney(Player(), ShipMoney(Player()) - base_cost * hull_costs[hull_variants[variant_chosen]]);",
                        "Sound('Sound.Buy');",
                        "quest_item = CreateHull(2, hull_sizes[hull_variants[variant_chosen]], GalaxyTechLevel(), ShipOwner(GetShipRuins(Player())));",
                        "ItemCost(quest_item, base_cost * hull_costs[hull_variants[variant_chosen]]);",
                        "bonus_num = FindBonusByNameInCfg('490');",
                        "if(~bonus_num) SpecialToEquipment(bonus_num, quest_item);",
                        "AddItemToStorage(GetShipRuins(Player()), quest_item);",
                        "CapitalShipStats(quest_item, 1, 1000);",
                        "GetAchievementHULL();",
                        "ArrayDelete(hull_variants, variant_chosen);",
                        "DChange(9);",
                        "exit;"
                    ],
                    "#": 92,
                    "Type": "Top",
                    "Parent": -1,
                    "Pos.x": 280,
                    "Pos.y": 425
                },
                {
                    "Name": "",
                    "Code.Type": "Turn",
                    "Code": [
                        "DChange(10);",
                        "exit;"
                    ],
                    "#": 93,
                    "Type": "Top",
                    "Parent": -1,
                    "Pos.x": 490,
                    "Pos.y": 425
                },
                {
                    "Name": "",
                    "Code.Type": "Turn",
                    "Code": [
                        "if(Id(GetShipRuins(Player())) != base_id) {",
                        "  if(IdToShip(base_id)) {",
                        "    DChange(14);",
                        "    exit;",
                        "  }",
                        "  if(!IdToShip(base_id)) {",
                        "    DChange(15);",
                        "    exit;",
                        "  }",
                        "}",
                        "if(Id(GetShipRuins(Player())) == base_id) {",
                        "  if(message_research_complete) {",
                        "    DChange(16);",
                        "    exit;",
                        "  }",
                        "}"
                    ],
                    "#": 94,
                    "Type": "Top",
                    "Parent": -1,
                    "Pos.x": 640,
                    "Pos.y": 425
                },
                {
                    "Name": "",
                    "Code.Type": "Turn",
                    "Code": [
                        "DChange(20);",
                        "exit;"
                    ],
                    "#": 95,
                    "Type": "Top",
                    "Parent": -1,
                    "Pos.x": 790,
                    "Pos.y": 425
                },
                {
                    "Name": "",
                    "Code.Type": "Turn",
                    "Code": [
                        "DAdd(0);"
                    ],
                    "#": 96,
                    "Type": "Top",
                    "Parent": -1,
                    "Pos.x": -20,
                    "Pos.y": 495
                },
                {
                    "Name": "",
                    "Code.Type": "Turn",
                    "Code": [
                        "if(GetNodesFromShip(Player()) + RangerBaseNodes(Player()) >= nodes_needed) {",
                        "  DAdd(1);",
                        "}",
                        "DAdd(4);"
                    ],
                    "#": 97,
                    "Type": "Top",
                    "Parent": -1,
                    "Pos.x": 130,
                    "Pos.y": 495
                },
                {
                    "Name": "",
                    "Code.Type": "Turn",
                    "Code": [
                        "FreeItem(GetItemFromShip(Player(), FindCrystal()));",
                        "nodes_get = 0;",
                        "if (RangerBaseNodes(Player()) >= nodes_needed) {",
                        "    RangerBaseNodes(Player(), RangerBaseNodes(Player()) - nodes_needed);",
                        "    nodes_get = nodes_needed;",
                        "}",
                        "if (nodes_get < nodes_needed) {",
                        "    nodes_get = RangerBaseNodes(Player());",
                        "    RangerBaseNodes(Player(), 0);",
                        "}",
                        "GetNodesFromShip(Player(), nodes_needed - nodes_get);",
                        "base_id = Id(GetShipRuins(Player()));",
                        "base_name = ShipName(GetShipRuins(Player()));",
                        "research_start_date = CurTurn();",
                        "DAdd(2);"
                    ],
                    "#": 98,
                    "Type": "Top",
                    "Parent": -1,
                    "Pos.x": 280,
                    "Pos.y": 495
                },
                {
                    "Name": "",
                    "Code.Type": "Turn",
                    "Code": [
                        "DAdd(6);"
                    ],
                    "#": 99,
                    "Type": "Top",
                    "Parent": -1,
                    "Pos.x": 430,
                    "Pos.y": 495
                },
                {
                    "Name": "",
                    "Code.Type": "Turn",
                    "Code": [
                        "DAdd(3);"
                    ],
                    "#": 100,
                    "Type": "Top",
                    "Parent": -1,
                    "Pos.x": 580,
                    "Pos.y": 495
                },
                {
                    "Name": "",
                    "Code.Type": "Turn",
                    "Code": [
                        "if(0){}for(i = 1; i <= variants_cnt; i = i + 1) {",
                        "  if(ArrayDim(hull_variants) > i) {",
                        "    if(ShipMoney(Player()) >= base_cost * hull_costs[hull_variants[i]]) {",
                        "      InjectAnswer(",
                        "          'ChosingVariant'",
                        "          , Format(CT(\"Script.PC_destroyer.44\"),\"<0>\",hull_sizes[hull_variants[i]],\"<1>\",base_cost * hull_costs[hull_variants[i]])",
                        "          , i",
                        "      );",
                        "    }",
                        "  }",
                        "}",
                        "DAdd(5);"
                    ],
                    "#": 101,
                    "Type": "Top",
                    "Parent": -1,
                    "Pos.x": 730,
                    "Pos.y": 495
                },
                {
                    "Name": "",
                    "Code.Type": "Turn",
                    "Code": [
                        "DAdd(8);",
                        "DAdd(9);"
                    ],
                    "#": 102,
                    "Type": "Top",
                    "Parent": -1,
                    "Pos.x": 880,
                    "Pos.y": 495
                },
                {
                    "Name": "",
                    "Code.Type": "Turn",
                    "Code": [
                        "DAdd(7);"
                    ],
                    "#": 103,
                    "Type": "Top",
                    "Parent": -1,
                    "Pos.x": 1030,
                    "Pos.y": 495
                },
                {
                    "Name": "",
                    "Code.Type": "Turn",
                    "Code": [
                        "DAdd(10);"
                    ],
                    "#": 104,
                    "Type": "Top",
                    "Parent": -1,
                    "Pos.x": 1180,
                    "Pos.y": 495
                },
                {
                    "Name": "",
