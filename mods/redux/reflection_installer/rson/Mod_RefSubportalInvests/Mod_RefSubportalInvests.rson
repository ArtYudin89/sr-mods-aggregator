                    "Type": "TDialogAnswer",
                    "Parent": -1,
                    "#": 41,
                    "Msg": "Нет, пожалуй, не сейчас",
                    "AMsg.Num": "7",
                    "_orig_danswer": "DAnswer('restart~'+CT(\"Script.Mod_RefSubportalInvests.24\"))"
                },
                {
                    "Name": "restart",
                    "Pos.x": 960,
