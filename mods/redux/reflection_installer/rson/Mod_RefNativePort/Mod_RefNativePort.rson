            "Operations": [
                {
                    "Name": "",
                    "Code.Type": "Global",
                    "Code": [
                        "GRun();"
                    ],
                    "#": 8,
                    "Type": "Top",
                    "Parent": -1,
                    "Pos.x": 0,
                    "Pos.y": 610
                },
                {
                    "Name": "",
                    "Code.Type": "DialogBegin",
                    "Code": [
                        "if(GetTalkShip() != 0) {",
                        "    if(TalkByAI() == 0) {",
                        "        Ship = GetTalkShip();",
                        "        if (RelationToShip(Ship,Player())<10) Relation = 0;//враг",
                        "        else if (RelationToShip(Ship,Player())<30) Relation = 1;//плохое",
                        "        else if (RelationToShip(Ship,Player())<60) Relation = 2;//нормальное",
                        "        else Relation = 3;//хорошее/отличное",
                        "        if(ShipTypeN(Ship) > 0 && (ShipTypeN(Ship) <= 4) && (Relation != 0))//тут начинается ветвление",
                        "        {",
                        "            Native = PlanetName(ShipStatistic(Ship,10));",
                        "            AddDialogInject('D_'+ShipTypeN(Ship)+Relation,'',CT(\"Script.Mod_RefNativePort.22\"),1);",
                        "        }",
                        "    }",
                        "}"
                    ],
                    "#": 9,
                    "Type": "Top",
                    "Parent": -1,
                    "Pos.x": 180,
                    "Pos.y": 610
                },
