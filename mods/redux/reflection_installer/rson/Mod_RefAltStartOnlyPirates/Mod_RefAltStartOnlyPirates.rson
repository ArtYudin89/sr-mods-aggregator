            "Operations": [
                {
                    "Name": "",
                    "Code.Type": "Global",
                    "Code": [
                        "//"
                    ],
                    "#": 14,
                    "Type": "Top",
                    "Parent": -1,
                    "Pos.x": 0,
                    "Pos.y": 585
                },
                {
                    "Name": "",
                    "Code.Type": "Turn",
                    "Code": [
                        "if(CurTurn() == 25) {",
                        "  int i, v, w, j;",
                        "  dword cur_star, twd1, ruins, planet, star;",
                        "  //Переменные для запуска барахлища",
                        "  //Переменные для барахлища",
                        "  TerronToStar();",
                        "  KellerLeave();",
                        "  MS_Terron_ToStar=1;",
                        "  ShipDestroy(Keller());",
                        "  //Смерть Блазеру",
                        "  ShipDestroyType(1);",
                        "  while(PlanetForLandingID == 0) {",
                        "      cur_star = ShipStar(Blazer());",
                        "      if(StarOwner(cur_star) != 1) continue; //Исключаем все системы, кроме доминаторских",
                        "      if(StarCustomFaction(cur_star)!='') continue;",
                        "      if(StarToCon(cur_star)==StarToCon(PlanetToStar(PlanetPirateClan()))) continue; //Исключаем Тортугац и Нифигац на всякий случай",
                        "      i = StarPlanets(cur_star);",
                        "      cur_planet = StarPlanets(cur_star,Rnd(0,i-1));",
                        "      while(PlanetOwner(cur_planet)==6) {",
                        "          cur_planet = StarPlanets(cur_star,Rnd(0,i-1));",
                        "      }",
                        "      PlanetForLandingID = Id(cur_planet);",
                        "  }",
                        "  BlazerLanding(PlanetForLandingID);",
                        "  //________________________________",
                        "  //________________________________",
                        "  //Тута повышение ГТУ",
                        "  for(v = 0; v < GalaxyStars(); v = v + 1) {",
                        "      star = GalaxyStar(v);",
                        "      for(w = 0; w < StarPlanets(star); w = w + 1) {",
                        "          planet = StarPlanets(star, w);",
                        "          if(PlanetOwner(planet) == None) continue;",
                        "          UpTech(planet);",
                        "      }",
                        "      if(StarOwner(star)) {",
                        "          if(StarRuins(star)) {",
                        "              for(w = StarRuins(star) - 1; w >= 0; w = w - 1) {",
                        "                  ruins = StarRuins(star, w);",
                        "                  if(ShipTypeN(ruins) == t_CB) int dab;",
                        "                  else ClearShop(ruins);",
                        "              }",
                        "          }",
                        "          for(w = 0; w < StarPlanets(star); w = w + 1) {",
                        "              planet = StarPlanets(star, w);",
                        "              if(PlanetOwner(planet) == None) continue;",
                        "              if(PlanetOwner(planet) != PirateClan) PlanetOwner(planet, PlanetRace(planet));",
                        "              UpTech(planet);",
                        "              ClearShop(planet);",
                        "              BuyWarrior(planet);",
                        "          }",
                        "          for(j = 0; j < StarShips(star); j = j + 1) {",
                        "              planet = StarShips(star, j);",
                        "              if(ShipOwner(planet) < Kling) continue;",
                        "              if(ShipOwner(planet) == PirateClan) continue;",
                        "              if(StarShips(star, j) == Blazer()) continue;",
                        "              OrderNone(planet);",
                        "              OrderLock(planet, 1);",
                        "              ShipDestroy(planet, 1);",
                        "          }",
                        "      }",
                        "      else {",
                        "          for(w = 0; w < StarPlanets(star); w = w + 1) {",
                        "              planet = StarPlanets(star, w);",
                        "              if(PlanetOwner(planet) == None) continue;",
                        "              UpTech(planet);",
                        "              ClearShop(planet);",
                        "          }",
                        "      }",
                        "  }",
                        "  function UpTech (dword planet) {",
                        "      for(int v = 0; v < 20; v = v + 1) PlanetInventionLevel(planet, v, 7);",
                        "      PlanetCurInventionPoints(planet, PlanetCurInvention(planet), 225);",
                        "  }",
                        "  function ClearShop (dword object) {",
                        "      for(int v = ShopItems(object) - 1; v >= 0; v = v - 1) FreeItem(GetItemFromShop(object, v));",
                        "  }",
                        "}",
                        "if(CurTurn() == 290) {",
                        "  EtherDelete('BlazerWin');",
                        "  EtherDelete('KellerWin');",
                        "  EtherDelete('TerronWin');",
                        "}",
                        "if(CurTurn() == 100 || CurTurn() == 101 || CurTurn() == 102) {",
                        "  //контрольная дочистка терронско-келлерской швали",
                        "  for(i = 0; i < GalaxyStars(); i = i + 1) {",
                        "      star = GalaxyStar(i);",
                        "      for(j = 0; j < StarShips(star); j = j + 1) {",
                        "          planet = StarShips(star, j);",
                        "          if(ShipOwner(planet) != Kling) continue;",
                        "          OrderNone(planet);",
                        "          OrderLock(planet, 1);",
                        "          ShipDestroy(planet, 1);",
                        "      }",
                        "  }",
                        "}"
                    ],
