                    "Parent": -1,
                    "Pos.x": 820,
                    "Pos.y": 565
                },
                {
                    "Name": "",
                    "Code.Type": "Turn",
                    "Code": [
                        "ShipChangeStar(q,ShipStar(Player()));",
                        "//Rnd используется, чтобы переместить объект возле игрока",
                        "CoordX(q,CoordX(Player())+Rnd(-100,100));",
                        "CoordY(q,CoordY(Player())+Rnd(-100,100));",
                        "str1=Format(CT(\"Script.Mod_KitPlus.171\"),\"<0>\",Name(q));",
                        "Sound('Sound.NewMsg');",
                        "MessageBox(Format('<0>',\"<0>\",str1),5);",
                        "DChange(4);",
                        "exit;"
                    ],
                    "#": 162,
                    "Type": "Top",
                    "Parent": -1,
                    "Pos.x": 940,
                    "Pos.y": 565
                },
                {
                    "Name": "",
                    "Code.Type": "Turn",
                    "Code": [
                        "find=CT(\"Script.Mod_KitPlus.108\");",
                        "str2=TextBox(CT(\"Script.Mod_KitPlus.161\"));",
                        "if (str2!='')",
                        "{",
                        "    for(j=0;j<GalaxyStars();j=j+1) //перебирает все системы в галактике",
                        "    {",
                        "        star=GalaxyStar(j); //система, в которой сейчас воспроизводится поиск",
                        "        if (DeleteTags('<color=,,>'+DeleteTags(StarName(star))+'</color>')==str2) //если название системы соответствует тому, что написал игрок в боксе, то возвращает телепортирует объект в эту систему",
                        "        {",
                        "            find=1; //система найдена",
                        "            w=star; //возвращает систему для дальнейших операций",
                        "        }",
                        "    }",
                        "    if (!find)",
                        "    {",
                        "        Sound('Sound.DelMsg');",
                        "        MessageBox(Format(CT(\"Script.Mod_KitPlus.482\"),\"<0>\",str2),34);",
                        "    }",
                        "}",
                        "if(!find || str2=='') {",
                        "  DChange(4);",
                        "  exit;",
                        "}",
                        "if(find) {",
                        "  if (q!=Player())",
                        "      {",
                        "          if (!ShipIsTakeoff(q)) OrderTakeOff(q);",
                        "          TransferShip(q,w);",
                        "          ShipChangeStar(q,w);",
                        "      }",
                        "  else",
                        "      {",
                        "      if (PlayerBridge()>0) PlayerBridge(0);",
                        "          TransferShip(Player(),w);",
                        "          PlayerBridge(2);",
                        "          PlayerBridge(0);",
                        "          ShipChangeStar(Player(),w);",
                        "      }",
                        "  str1=Format(CT(\"Script.Mod_KitPlus.186\"),\"<0>\",Name(q),\"<1>\",Name(w));",
                        "  Sound('Sound.NewMsg');",
                        "  MessageBox(Format('<0>',\"<0>\",str1),5);",
                        "  DChange(4);",
                        "  exit;",
                        "}"
                    ],
                    "#": 163,
                    "Type": "Top",
                    "Parent": -1,
                    "Pos.x": 1060,
                    "Pos.y": 565
                },
                {
                    "Name": "",
                    "Code.Type": "Turn",
                    "Code": [
                        "v1=1;",
                        "q=Player();",
                        "DChange(2);",
                        "exit;"
                    ],
                    "#": 164,
                    "Type": "Top",
                    "Parent": -1,
                    "Pos.x": 1180,
                    "Pos.y": 565
                },
                {
                    "Name": "",
                    "Code.Type": "Turn",
                    "Code": [
                        "v3=1;",
                        "if (v2==1)",
                        "{",
                        "    j=CountBox('Bm.Items.2FuelTanks14s',CT(\"Script.Mod_KitPlus.483\"),1,6);",
                        "    //Изменяет уровень навыка объекта на выбранный",
                        "    if (j!='')",
                        "    {",
                        "        if (v3==1) ShipSkill(q,0,j); //точность",
                        "        if (v3==2) ShipSkill(q,1,j); //манёвренность",
                        "        if (v3==3) ShipSkill(q,2,j); //техника",
                        "        if (v3==4) ShipSkill(q,3,j); //торговля",
                        "        if (v3==5) ShipSkill(q,4,j); //обаяние",
                        "        if (v3==6) ShipSkill(q,5,j); //лидерство",
                        "        //Делает все навыки объекта j уровня",
                        "        if (v3==7)",
                        "            {",
                        "            for (i=0;i<6;i=i+1)",
                        "                {",
                        "                    ShipSkill(q,i,j);",
                        "                }",
                        "            }",
                        "        Sound('Sound.NewMsg');",
                        "    }",
                        "}",
                        "if (v2==2)",
                        "{",
                        "    //Сбрасывает выбранный уровень навыка объекта",
                        "    if (v3==1) ShipSkill(q,0,0); //точность",
                        "    if (v3==2) ShipSkill(q,1,0); //манёвренность",
                        "    if (v3==3) ShipSkill(q,2,0); //техника",
                        "    if (v3==4) ShipSkill(q,3,0); //торговля",
                        "    if (v3==5) ShipSkill(q,4,0); //обаяние",
                        "    if (v3==6) ShipSkill(q,5,0); //лидерство",
                        "    //Сбрасывает все навыки объекта",
                        "    if (v3==7)",
                        "    {",
                        "        for (i=0;i<6;i=i+1)",
                        "            {",
                        "                ShipSkill(q,i,0);",
                        "            }",
                        "    }",
                        "    Sound('Sound.DelMsg');",
                        "}",
                        "//;",
                        "//;",
                        "DChange(6);",
                        "exit;"
                    ],
