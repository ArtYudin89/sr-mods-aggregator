                    "#": 154,
                    "Type": "Top",
                    "Parent": -1,
                    "Pos.x": 580,
                    "Pos.y": 495
                },
                {
                    "Name": "",
                    "Code.Type": "Turn",
                    "Code": [
                        "v1=1;",
                        "str3=CT(\"Script.Mod_KitPlus.150\");",
                        "find=CT(\"Script.Mod_KitPlus.108\");",
                        "str2=TextBox(Format(CT(\"Script.Mod_KitPlus.113\"),\"<0>\",str3));",
                        "if (str2!='')",
                        "{",
                        "    //поиск корабля или базы",
                        "    if (v1==1) for(j=0;j<GalaxyStars();j=j+1) //перебирает все системы в галактике",
                        "    {",
                        "        star=GalaxyStar(j); //система, в которой сейчас воспроизводится поиск",
                        "        for (i=0;i<StarShips(star);i=i+1) //перебирает все корабли и базы в системе",
                        "        {",
                        "            shp=StarShips(star,i); //проверяет корабль/базу",
                        "            if (DeleteTags('<color=,,>'+DeleteTags(ShortName(shp))+'</color>')==str2 || DeleteTags('<color=,,>'+Name(shp)+'</color>')==str2) //если имя корабля или базы соответствует тому, что написал игрок в боксе, то возвращает корабль/базу для дальнейших операций",
                        "            {",
                        "                find=1; //корабль или база найдена",
                        "                q=shp; //возвращает корабль или базу для дальнейших операций",
                        "            }",
                        "        }",
                        "    }",
                        "    //поиск системы",
                        "    if (v1==2) for(j=0;j<GalaxyStars();j=j+1) //перебирает все системы в галактике",
                        "    {",
                        "        star=GalaxyStar(j); //система, в которой сейчас воспроизводится поиск",
                        "        if (DeleteTags('<color=,,>'+DeleteTags(StarName(star))+'</color>')==str2) //если название системы соответствует тому, что написал игрок в боксе, то возвращает систему для дальнейших операций",
                        "        {",
                        "            find=1; //система найдена",
                        "            q=star; //возвращает систему для дальнейших операций",
                        "        }",
                        "    }",
                        "    //поиск планеты",
                        "    if (v1==3) for(j=0;j<GalaxyStars();j=j+1) //перебирает все системы в галактике",
                        "    {",
                        "        star=GalaxyStar(j); //система, в которой сейчас воспроизводится поиск",
                        "        for (i=0;i<StarPlanets(star);i=i+1) //перебирает все планеты в системе",
                        "        {",
                        "            shp=StarPlanets(star,i);",
                        "            if (DeleteTags('<color=,,>'+DeleteTags(PlanetName(shp))+'</color>')==str2) //если название планеты соответствует тому, что написал игрок в боксе, то возвращает планету для дальнейших операций",
                        "            {",
                        "                find=1; //планета найдена",
                        "                q=shp; //возвращает планету для дальнейших операций",
                        "            }",
                        "        }",
                        "    }",
                        "    if (!find)",
                        "    {",
                        "        Sound('Sound.DelMsg');",
                        "        MessageBox(Format(CT(\"Script.Mod_KitPlus.479\"),\"<0>\",str2),34);",
                        "    }",
                        "    else Sound('Sound.NewMsg');",
                        "}",
                        "if(!find || str2=='') {",
                        "  //;",
                        "  DChange(1);",
                        "  exit;",
                        "}",
                        "if(find) {",
                        "  DChange(2);",
                        "  exit;",
                        "}"
                    ],
