                        "            if (DeleteTags('<color=,,>'+DeleteTags(ShortName(shp))+'</color>')==str2 || DeleteTags('<color=,,>'+Name(shp)+'</color>')==str2) //если имя корабля или базы соответствует тому, что написал игрок в боксе, то возвращает корабль/базу для дальнейших операций",
                        "            {",
                        "                find=1; //корабль или база найдена",
                        "                w=shp; //возвращает корабль или базу для дальнейших операций",
                        "            }",
                        "        }",
                        "    }",
                        "    //поиск планеты",
                        "    if (v1==2) for(j=0;j<GalaxyStars();j=j+1) //перебирает все системы в галактике",
                        "    {",
                        "        star=GalaxyStar(j); //система, в которой сейчас воспроизводится поиск",
                        "        for (i=0;i<StarPlanets(star);i=i+1) //перебирает все планеты в системе",
                        "        {",
