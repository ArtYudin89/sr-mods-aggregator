            "DialogMessages": [
                {
                    "Name": "",
                    "Pos.x": 0,
                    "Pos.y": 470,
                    "Type": "TDialogMsg",
                    "Parent": -1,
                    "#": 50,
                    "Msg": "Навыки объекта <0>:\r\n\r\nТочность: <1>\r\nМанёвренность: <2>\r\nТехника: <3>\r\n\r\nТорговля: <4>\r\nОбаяние: <5>\r\nЛидерство: <6>\r\n\r\nВыберите то, что хотите сделать с навыками.",
                    "DMsg.Num": "0",
                    "_orig_dtext": "DText(Format(CT(\"Script.Mod_KitPlus.204\"),\"<0>\",Name(q),\"<1>\",ShipSkill(q,0),\"<2>\",ShipSkill(q,1),\"<3>\",ShipSkill(q,2),\"<4>\",ShipSkill(q,3),\"<5>\",ShipSkill(q,4),\"<6>\",ShipSkill(q,5)))"
                },
                {
                    "Name": "",
                    "Pos.x": 150,
                    "Pos.y": 470,
                    "Type": "TDialogMsg",
                    "Parent": -1,
                    "#": 51,
                    "Msg": "Выберите тип объекта, с которым будете взаимодействовать и введите его название.\r\n\r\nКогда вводите название, учитывайте <clr>строчные<clrEnd> и <clr>прописные<clrEnd> буквы.",
                    "DMsg.Num": "1",
                    "_orig_dtext": "DText(CT(\"Script.Mod_KitPlus.205\"))"
                },
                {
                    "Name": "",
                    "Pos.x": 300,
                    "Pos.y": 470,
                    "Type": "TDialogMsg",
                    "Parent": -1,
                    "#": 52,
                    "Msg": "Что требуется сделать с объектом <0>?",
                    "DMsg.Num": "2",
                    "_orig_dtext": "DText(Format(CT(\"Script.Mod_KitPlus.138\"),\"<0>\",Name(q)))"
                },
                {
                    "Name": "",
                    "Pos.x": 450,
                    "Pos.y": 470,
                    "Type": "TDialogMsg",
                    "Parent": -1,
                    "#": 53,
                    "Msg": "Укажите координаты.\r\n\r\nКоординаты объекта <0>:\r\nКоордината X = <1>\r\nКоордината Y = <2>\r\n\r\n\r\nНа какие координаты вы хотите сменить:\r\nКоордината X = <3>\r\nКоордината Y = <4>",
                    "DMsg.Num": "3",
                    "_orig_dtext": "DText(Format(CT(\"Script.Mod_KitPlus.148\"),\"<0>\",Name(q),\"<1>\",CoordX(q),\"<2>\",CoordY(q),\"<3>\",coord1,\"<4>\",coord2))"
                },
                {
                    "Name": "",
                    "Pos.x": 600,
                    "Pos.y": 470,
                    "Type": "TDialogMsg",
                    "Parent": -1,
                    "#": 54,
                    "Msg": "Куда телепортировать объект <0>?",
                    "DMsg.Num": "4",
                    "_orig_dtext": "DText(Format(CT(\"Script.Mod_KitPlus.153\"),\"<0>\",Name(q)))"
                },
                {
                    "Name": "",
