                        "find=CT(\"Script.Mod_KitPlus.108\");",
                        "str2=TextBox(CT(\"Script.Mod_KitPlus.189\"));",
                        "if (str2!='')",
                        "{",
                        "    //поиск корабля или базы",
                        "    for(j=0;j<GalaxyStars();j=j+1) //перебирает все системы в галактике",
                        "    {",
                        "        star=GalaxyStar(j); //система, в которой сейчас воспроизводится поиск",
                        "        for (i=0;i<StarShips(star);i=i+1) //перебирает все корабли и базы в системе",
                        "        {",
                        "            shp=StarShips(star,i); //проверяет корабль/базу",
                        "            if (DeleteTags('<color=,,>'+DeleteTags(ShortName(shp))+'</color>')==str2 || DeleteTags('<color=,,>'+Name(shp)+'</color>')==str2) //если имя корабля или базы соответствует тому, что написал игрок в боксе, то возвращает корабль/базу для дальнейших операций",
                        "            {",
                        "                find=1; //корабль или база найдена",
                        "                w=shp; //возвращает корабль или базу для дальнейших операций",
                        "            }",
                        "        }",
                        "    }",
                        "    if (!find)",
                        "    {",
                        "        Sound('Sound.DelMsg');",
                        "        MessageBox(Format(CT(\"Script.Mod_KitPlus.479\"),\"<0>\",str2),34);",
                        "    }",
                        "}",
                        "if(!find || str2=='') {",
                        "  DChange(4);",
                        "  exit;",
                        "}",
                        "if(find) {",
                        "  if (q!=Player())",
                        "  {",
                        "      if (!ShipIsTakeoff(q)) OrderTakeOff(q);",
                        "      TransferShip(q,ShipStar(w));",
                        "      ShipChangeStar(q,ShipStar(w));",
                        "  }",
                        "  else",
                        "  {",
                        "      if(PlayerBridge()>0)PlayerBridge(0);",
                        "      TransferShip(q,ShipStar(w));",
                        "      PlayerBridge(2);",
                        "      PlayerBridge(0);",
                        "      ShipChangeStar(q,ShipStar(w));",
                        "  }",
                        "  //Rnd используется, чтобы переместить объект q возле объекта w",
                        "  CoordX(q,CoordX(w)+Rnd(-30,30));",
                        "  CoordY(q,CoordY(w)+Rnd(-30,30));",
                        "  str1=Format(CT(\"Script.Mod_KitPlus.188\"),\"<0>\",Name(q),\"<1>\",Name(w));",
                        "  Sound('Sound.NewMsg');",
                        "  MessageBox(Format('<0>',\"<0>\",str1),5);",
                        "  DChange(4);",
                        "  exit;",
                        "}"
                    ],
