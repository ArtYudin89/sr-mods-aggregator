                },
                {
                    "Name": "",
                    "Pos.x": 150,
                    "Pos.y": 495,
                    "Type": "TDialogMsg",
                    "Parent": -1,
                    "#": 63,
                    "Msg": "Выберите то, что хотите сделать с планетой <0>.\r\n\r\n--Общая информация--\r\n\r\nПланета находится в системе: <1>\r\nОтношение планеты к вам: <2> (<3>)\r\nId планеты: <4>\r\nНаселение: <5> особей\r\nРаса, владеющая планетой: <6>\r\nКоренная раса: <7>\r\nПолитический строй: <8>\r\nЭкономика: <9>\r\n\r\n--Территории--\r\n\r\n-Исследуемые-\r\nВода: <10>\r\nРавнины: <11>\r\nГоры: <12>\r\n\r\n-Исследовано-\r\nВода: <13>\r\nРавнины: <14>\r\nГоры: <15>\r\n\r\n--Прочее--\r\nРадиус: <16>\r\nРазмер: <17>\r\nСкорость вращения по орбите: <18>\r\nКоличество военных планеты: <19>\r\n\r\n--Технический уровень проектов--\r\nОбщий ТУ планеты: <20>\r\nТекущий изучаемый планетой проект: <21>\r\n\r\n-Оборудование-\r\nКорпуса: <22>\r\nТопливные баки: <23>\r\nДвигатели: <24>\r\nРадары: <25>\r\nСканеры: <26>\r\nДроиды: <27>\r\nЗахваты: <28>\r\n\r\n-Оружие-\r\nТУ промышленного лазера: <29>\r\nТУ осколочного орудия: <30>\r\nТУ лезки: <31>\r\nТУ ракетомёта: <32>\r\nТУ третона: <33>\r\nТУ волнового фазера: <34>\r\nТУ потокового бластера: <35>\r\nТУ электронного резака: <36>\r\nТУ мультирезонатора: <37>\r\nТУ атомного визиона: <38>\r\nТУ дезинтегратора: <39>\r\nТУ турбогравира: <40>",
                    "DMsg.Num": "13",
                    "_orig_dtext": "DText(Format(CT(\"Script.Mod_KitPlus.445\"),\"<0>\",Name(q),\"<1>\",Name(PlanetToStar(q)),\"<2>\",str1,\"<3>\",i,\"<4>\",Id(q),\"<5>\",PlanetPopulation(q),\"<6>\",str2,\"<7>\",str3,\"<8>\",str4,\"<9>\",str5,\"<10>\",PlanetTerrain(q,0),\"<11>\",PlanetTerrain(q,1),\"<12>\",PlanetTerrain(q,2),\"<13>\",PlanetTerrainExplored(q,0),\"<14>\",PlanetTerrainExplored(q,1),\"<15>\",PlanetTerrainExplored(q,2),\"<16>\",PlanetOrbitRadius(q),\"<17>\",PlanetSize(q),\"<18>\",PlanetOrbitalVelocity(q),\"<19>\",PlanetWarriors(q),\"<20>\",PlanetInventionLevel(q,7),\"<21>\",str6,\"<22>\",PlanetInventionLevel(q,0),\"<23>\",PlanetInventionLevel(q,1),\"<24>\",PlanetInventionLevel(q,2),\"<25>\",PlanetInventionLevel(q,3),\"<26>\",PlanetInventionLevel(q,4),\"<27>\",PlanetInventionLevel(q,5),\"<28>\",PlanetInventionLevel(q,6),\"<29>\",PlanetInventionLevel(q,8),\"<30>\",PlanetInventionLevel(q,9),\"<31>\",PlanetInventionLevel(q,10),\"<32>\",PlanetInventionLevel(q,11),\"<33>\",PlanetInventionLevel(q,12),\"<34>\",PlanetInventionLevel(q,13),\"<35>\",PlanetInventionLevel(q,14),\"<36>\",PlanetInventionLevel(q,15),\"<37>\",PlanetInventionLevel(q,16),\"<38>\",PlanetInventionLevel(q,17),\"<39>\",PlanetInventionLevel(q,18),\"<40>\",PlanetInventionLevel(q,19)))"
