                {
                    "Name": "",
                    "Code.Type": "Turn",
                    "Code": [
                        "//У игрока в трюме нашлись какие-то ММ для сдачи",
                        "if(ArrayDim(tarr1))",
                        "{",
                        "    ArraySort(tarr1['Cost'], tarr1['Item']);",
