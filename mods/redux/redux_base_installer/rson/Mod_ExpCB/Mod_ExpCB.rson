                {
                    "Name": "",
                    "Code.Type": "Turn",
                    "Code": [
                        "tstr1 = CT(\"Script.Mod_ExpCB.328\");",
                        "tstr2 = CT(\"Script.Mod_ExpCB.328\");",
                        "temp_dword = 0;",
                        "temp_dword_2 = 0;",
