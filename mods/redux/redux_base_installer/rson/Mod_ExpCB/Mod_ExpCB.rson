                        "    }",
                        "    else tstr4 = Format(tstr4,'weap'+i,CT(\"Script.Mod_ExpCB.278\"));",
                        "}",
                        "",
                        "HullHP(cur_ship,'To100');",
                        "",
                        "//Возвращаем планете её расу",
                        "PlanetRace(NearCivilPlanet(Player()),tint1);",
                        "costDisc = cost * (100 - (ShipStatus(Player(),2)/4)) / 100;",
                        "DChange(28);",
                        "exit;"
