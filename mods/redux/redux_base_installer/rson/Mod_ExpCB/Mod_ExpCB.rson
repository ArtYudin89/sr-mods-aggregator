                    "#": 268,
                    "Type": "Top",
                    "Parent": -1,
                    "Pos.x": -20,
                    "Pos.y": 765
                },
                {
                    "Name": "",
                    "Code.Type": "Turn",
                    "Code": [
                        "//Составим массив подходящих нам микромодулей",
                        "//Чтобы лишний раз не париться, сначала определим, ММ какого уровня нам нужен",
                        "k = RndObject(1,100,Player());",
                        "if(i) {",
                        "    if(l) {",
                        "        if(k > l) {",
                        "            if(k > (l + j)) k = 3;",
                        "            else k = 2;",
                        "        }",
                        "        else k = 1;",
                        "    }",
                        "    else {",
                        "        if(k > j) k = 3;",
                        "        else k = 2;",
                        "    }",
                        "}",
                        "else if(j) {",
                        "    if(k > l) k = 1;",
                        "    else k = 2;",
                        "}",
                        "else {",
                        "    k = 1;",
                        "}",
                        "//Определив уровень, собираем подходящие нам ММ",
                        "unknown array0 = newarray(1);",
                        "ArrayClear(array0);",
                        "for(i = 0; BonusCount() > i; i = i + 1) {",
                        "    if(CT('MicroModuls.'+BonusNumInCfg(i)+'.UniqueMM')) continue;",
                        "    if(CT('MicroModuls.'+BonusNumInCfg(i)+'.Special')) continue;",
                        "    if(k == 1 && BonusPriority(i) > 31) continue;",
                        "    if(k == 2 && (BonusPriority(i) < 30 || BonusPriority(i) > 69)) continue;",
                        "    if(k == 3 && BonusPriority(i) < 70) continue;",
                        "    if(EqModule(temp_dword) == i) continue;",
                        "    if(EqModule(temp_dword_2) == i) continue;",
                        "",
                        "    ArrayAdd(array0,i);",
                        "}",
                        "",
                        "//Проводим оплату",
                        "FreeItem(GetItemFromShip(Player(),temp_dword));",
                        "FreeItem(GetItemFromShip(Player(),temp_dword));",
                        "ShipMoney(Player(),ShipMoney(Player()) - temp_int);",
                        "Sound('Sound.Buy');",
                        "",
                        "k = Rnd(1,ArrayDim(array0)-1);",
                        "temp_dword = CreateMM(array0[k]);",
                        "AddItemToShip(Player(),temp_dword);",
                        "tstr1 = ItemFullName(temp_dword);",
                        "DChange(35);",
                        "exit;"
                    ],
