                        "    tdwd = ShipEqInSlot(cur_ship,t_RepairRobot);",
                        "    tstr4 = Format(tstr4,'droid',Name(tdwd)+' ('+GetEquipmentStats(tdwd,0)+' '+CT(\"Script.Mod_ExpCB.282\"));",
                        "}",
                        "else tstr4 = Format(tstr4,'hook',CT(\"Script.Mod_ExpCB.278\"));",
                        "if(ShipEqInSlot(cur_ship,t_CargoHook)) {",
                        "    tdwd = ShipEqInSlot(cur_ship,t_CargoHook);",
