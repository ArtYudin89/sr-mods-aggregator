                        "        if (GalaxyTechLevel()<=4) tint=0;",
                        "        if (GalaxyTechLevel()>4 && GalaxyTechLevel()<=6) tint=2;",
                        "        else tint=4;",
                        "        tdwd=CreateZond(tint,PirateClan);",
                        "    }",
                        "    i=3;",
                        "    ItemDurability(tdwd,Rnd(40,85));",
                        "}",
