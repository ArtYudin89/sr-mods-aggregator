            "Items": [],
            "Operations": [
                {
                    "Name": "",
                    "Code.Type": "Global",
                    "Code": [
                        "// rev_plan - запланированное кол-во денег для сбора оппозицией",
                        "// rev_money - деньги, уже собранные оппозицией",
                        "// arm_plan - запланированное кол-во оружия для сбора правительством",
                        "// has_arm - кол-во оружия, уже собранного правительством",
                        "// rev_luxury - запасы роскоши у повстанцев",
                        "",
                        "if(PirateWin() != 3 && PirateWin() != 5) {",
                        "    if(rev_date+girs<=CurTurn()) {",
                        "        StarForRevolt = 0;",
                        "        int u;",
                        "        int y;",
                        "        //Смотрим ситуацию",
                        "        if(ControlledSystems(0) > 3) {",
                        "            for(u=0;GalaxyStars()>u;u=u+1) {",
                        "                dword dwd = GalaxyStar(u);",
                        "                //Пропускаем системы, не принадлежащие Коалиции или Клану",
                        "                if(StarOwner(dwd) == 1 || StarCustomFaction(dwd) != '') continue;",
                        "                //Пропускаем пират-сектор",
                        "                if(StarToCon(dwd) == StarToCon(PlanetToStar(PlanetPirateClan()))) continue;",
                        "                if(!StarForRevolt) StarForRevolt = dwd;",
                        "                else {",
                        "                    //Чтобы был элемент рандомчика",
                        "                    if(GalaxyStar(GLastStar-1) == dwd) continue;",
                        "                    //Чтобы игроку родную систему не ломало, ибо на ней завязано слишком много",
                        "                    if(dwd == ShipStatistic(Player(),10)) continue;",
                        "                    //Считаем количество планет, чтобы ХОТЯ БЫ БЫЛО ЧТО ДЕЛИТЬ",
                        "                    int schet = 0;",
                        "                    for(y=0;StarPlanets(dwd)>y;y=y+1) {",
                        "                        if(PlanetOwner(StarPlanets(dwd,y)) != 6) schet = schet + 1;",
                        "                    }",
                        "                    if(schet < 2) continue;",
                        "                    //Подбираем наиболее близкую к Роджерии систему",
                        "                    if(round(sqrt(Dist2Star(dwd, PlanetToStar(PlanetPirateClan())))) < round(sqrt(Dist2Star(StarForRevolt, PlanetToStar(PlanetPirateClan()))))) StarForRevolt = dwd;",
                        "                }",
                        "            }",
                        "",
                        "            //Ну мало ли? Сделаем проверку",
                        "            if(StarForRevolt > 0) {",
                        "                NoComeKlingToStar(StarForRevolt, 1);",
                        "                StarForRevolt = Id(StarForRevolt);",
                        "                GRun();",
                        "            }",
                        "            else {",
                        "                //Чтобы игра не страдала каждый ход проверять это всё",
                        "                rev_date = CurTurn() - 250;",
                        "            }",
                        "        }",
                        "        else {",
                        "            //Чтобы игра не страдала каждый ход проверять это всё",
                        "            rev_date = CurTurn() - 250;",
                        "        }",
                        "    }",
                        "    else if(rev_date+girs==CurTurn()+20) {",
                        "        if(ArtefactTypeInUse(Player(),t_ArtefactAnalyzer)) {",
                        "            Sound('Sound.NewMsg');",
                        "            NewsAdd(CT(\"Script.Mod_ShuRebellion.102\"));",
                        "        }",
                        "    }",
                        "}"
                    ],
                    "#": 29,
                    "Type": "Top",
                    "Parent": -1,
                    "Pos.x": 0,
                    "Pos.y": 685
                },
                {
                    "Name": "",
                    "Code.Type": "Init",
                    "Code": [
                        "//Выставляем новое время до атаки, если была получена концовка",
                        "if(!GotEnding) {",
                        "    if(PirateWin()) {",
                        "        GotEnding = 1;",
                        "        //Изменяем время до следующего восстания, если была получена какая-то концовка в пользу пиратов (иначе просто не запустится больше скрипт)",
                        "        if(PirateWin() == 1) girs = girs - 300;",
                        "        if(PirateWin() == 2) girs = girs - 200;",
                        "        if(PirateWin() == 4) girs = girs + 600;",
                        "    }",
                        "}",
                        "",
                        "//Запоминаем звезду, чтобы приколов не было",
                        "GLastStar = StarForRevolt;",
                        "//SFT('PolRebellion: StarForRevolt is '+StarForRevolt);",
                        "//SFT('PolRebellion: name is '+Name(GalaxyStar(StarForRevolt-1)));",
                        "//Обнуляем счётчики убиенных и прочего",
                        "has_arm = 0;",
                        "rev_money = 0;",
                        "",
                        "rev_plan = GalaxyMoney(3, 3) * Rnd(4, 7); //Устанавливаем сумму, которую планируют собрать анархисты",
                        "arm_plan = 200 + GalaxyTechLevel() * 20; //Устанавливаем кол-во оружия, которое хотят получить лоялисты",
                        "rev_luxury = Rnd(65, 125) + GalaxyTechLevel() * 5; //Устанавливаем имеющуюся у оппозиции роскошь для бартера",
                        "",
                        "tdwd = GalaxyStar(StarForRevolt-1);",
                        "",
                        "//Смотрим, кто владелец системы",
                        "if(!StarOwner(tdwd)) {",
                        "    //Владелец системы - Коалиция",
                        "    tdwd2 = FindPlanet(tdwd,'NotNone');",
                        "    PlanetOwner(tdwd2,7);",
                        "    PlanetGov(tdwd2, 0);",
                        "    UpsurgeGoods(tdwd2, t_Luxury);",
                        "    DecayGoods(tdwd2, t_Arms);",
                        "    //Удаляем военных, ведь их, конечно же, восставшие первым делом \"повязали\"",
                        "    for(i=0;PlanetWarriors(tdwd2)>i;i=i+1) {",
                        "        tdwd3 = PlanetWarriors(tdwd2,i);",
                        "        if(!GetShipPlanet(tdwd3)) continue;",
                        "",
                        "        TransferShip(tdwd3,tdwd2);",
                        "        OrderLock(tdwd3);",
                        "        ShipDestroy(tdwd3);",
                        "    }",
                        "    for(i=0;StarPlanets(tdwd)>i;i=i+1) {",
                        "        tdwd3 = StarPlanets(tdwd,i);",
                        "        if(PlanetOwner(tdwd3) == 6) continue;",
                        "        if(PlanetOwner(tdwd3) == 7) continue;",
                        "        UpsurgeGoods(tdwd3, t_Minerals);",
                        "        DecayGoods(tdwd3, t_Technics);",
                        "        DecayGoods(tdwd3, t_Arms);",
                        "    }",
                        "}",
                        "else {",
                        "    //Владелец системы - гейраты",
                        "    tdwd2 = FindPlanet(tdwd,'NotNone');",
                        "    PlanetOwner(tdwd2,PlanetRace(tdwd2));",
                        "    PlanetGov(tdwd2, Rnd(3,4));",
                        "    UpsurgeGoods(tdwd2, t_Minerals);",
                        "    DecayGoods(tdwd2, t_Technics);",
                        "    DecayGoods(tdwd2, t_Arms);",
                        "    //Удаляем пиратов, ведь их, конечно же, восставшие первым делом \"повязали\"",
                        "    //Но кто ж мне облегчит задачу, надо их ручками искать",
                        "    for(i=0;StarShips(tdwd)>i;i=i+1) {",
                        "        tdwd3 = StarShips(tdwd,i);",
                        "        if(!GetShipPlanet(tdwd3)) continue;",
                        "        if(GetShipPlanet(tdwd3) != tdwd2) continue;",
                        "",
                        "        OrderLock(tdwd3);",
                        "        ShipDestroy(tdwd3);",
                        "    }",
                        "    for(i=0;StarPlanets(tdwd)>i;i=i+1) {",
                        "        tdwd3 = StarPlanets(tdwd,i);",
                        "        if(PlanetOwner(tdwd3) == 6) continue;",
                        "        if(PlanetOwner(tdwd3) != 7) continue;",
                        "        UpsurgeGoods(tdwd3, t_Luxury);",
                        "        DecayGoods(tdwd3, t_Arms);",
                        "    }",
                        "}",
                        "//Следовательно, в системе появляется 1 планета врагов",
                        "//В перспективе, это дополнительно ставит революционеров в уязвимое положение, что, собственно, логично",
                        "//И если вдруг я или кто-то ещё сделает наконец, чтобы в рандомных системах (А не только мой Фаэтон) было много",
                        "//планет, то это будет видно ещё явственней. Как мне кажется, это хорошо и круто.",
                        "",
                        "",
                        "//Спавним набор ребяток для войнушки. АЛЛАХ БАБАХ",
                        "tdwd2 = FindPlanet(GalaxyStar(StarForRevolt-1),'NotMaloc,NotPeleng,NotPeople,NotFei,NotGaal,NotNone');",
                        "j=RndObject(7,10,Player());",
                        "for(i=0;i<j;i=i+1) {",
                        "    tdwd = BuyWarrior(tdwd2, 300);",
                        "    ShipRefit(tdwd);",
                        "    //ShipJoin(Rebels, tdwd);",
                        "}",
                        "tdwd2 = FindPlanet(GalaxyStar(StarForRevolt-1),'NotPirateClan,NotNone');",
                        "//SFT('PolRebellion: '+tdwd2);",
                        "//SFT('PolRebellion: '+Name(tdwd2));",
                        "j=RndObject(5,7,Player());",
                        "for(i=0;i<j;i=i+1) {",
                        "    tdwd = BuyWarrior(tdwd2, 300);",
                        "    ShipRefit(tdwd);",
                        "    //ShipJoin(Army, tdwd);",
                        "}",
                        "",
                        "if(!StarOwner(GalaxyStar(StarForRevolt-1))) tstr = '</color>' + Format(CT('Script.Mod_ShuRebellion.RiotInCoalition'),'star',Name(GalaxyStar(StarForRevolt-1)));",
                        "else tstr = '</color>' + Format(CT('Script.Mod_ShuRebellion.RiotInClan'),'star',Name(GalaxyStar(StarForRevolt-1)));",
                        "if(SectorVisible(StarToCon(GalaxyStar(StarForRevolt-1)))) {",
                        "    AddPlanetNews(tstr,63);",
                        "    NewsAdd(tstr);",
                        "    Sound('Sound.NewMsg');",
                        "}",
                        "",
                        "EventTime = 0;"
                    ],
                    "#": 30,
                    "Type": "Top",
                    "Parent": -1,
                    "Pos.x": 60,
                    "Pos.y": 685
                },
                {
                    "Name": "",
                    "Code.Type": "Turn",
                    "Code": [
                        "if(GroupCount(RebelsLanding)) {",
                        "    j=0;",
                        "    for(i=0;GroupCount(RebelsLanding)>i;i=i+1) {",
                        "        if(GetShipPlanet(GroupShip(RebelsLanding,i))) j=j+1;",
                        "    }",
                        "",
                        "    if(GroupCount(RebelsLanding) == j) {",
                        "        //Определяем бонус к силе",
                        "        if (rev_money >= rev_plan * 0.95) tint = 10;",
                        "        else if (rev_money >= rev_plan * 0.75) tint = 9;",
                        "        else if (rev_money >= rev_plan * 0.50) tint = 8;",
                        "        else if (rev_money >= rev_plan * 0.30) tint = 7;",
                        "        else tint = 6;",
                        "        tint = GroupCount(RebelsLanding) * tint / 2 + GroupCount(Rebels) * tint / 4;",
                        "        tint2 = Rnd(1, 100);",
                        "        tdwd = GetShipPlanet(GroupToShip(RebelsLanding));",
                        "        if(tint2 <= tint)",
                        "        {",
                        "            PlanetOwner(tdwd, PirateClan);",
                        "            PlanetGov(tdwd,0);",
                        "            if(SectorVisible(StarToCon(GalaxyStar(StarForRevolt-1)))) {",
                        "                tstr = Format(CT(\"Script.Mod_ShuRebellion.81\"),\"<0>\",Name(tdwd),\"<1>\",Name(GalaxyStar(StarForRevolt-1)));",
                        "                AddPlanetNews(tstr,63);",
                        "                NewsAdd(tstr);",
                        "                Sound('Sound.NewMsg');",
                        "            }",
                        "",
                        "            for(i=(GroupCount(RebelsLanding)-1);i>=0;i=i-1) {",
                        "                SetData(1,1,GroupShip(RebelsLanding,i));",
                        "                OrderTakeOff(GroupShip(RebelsLanding,i));",
                        "                //ShipJoin(Rebels,GroupShip(RebelsLanding,i));",
                        "                //ChangeState('MainState1',GroupShip(RebelsLanding,i));",
                        "            }",
                        "        }",
                        "        if (tint2 > tint)",
                        "        {",
                        "            for(i=GroupCount(RebelsLanding);i>0;i=i-1) {",
                        "                OrderLock(GroupShip(RebelsLanding, i), 1);",
                        "                ShipDestroy(GroupShip(RebelsLanding, i));",
                        "            }",
                        "",
                        "            if(SectorVisible(StarToCon(GalaxyStar(StarForRevolt-1)))) {",
                        "                tstr = Format(CT(\"Script.Mod_ShuRebellion.80\"),\"<0>\",Name(GalaxyStar(StarForRevolt-1)),\"<1>\",Name(tdwd));",
                        "                AddPlanetNews(tstr,63);",
                        "                NewsAdd(tstr);",
                        "                Sound('Sound.NewMsg');",
                        "            }",
                        "        }",
                        "    }",
                        "}",
                        "if(GroupCount(ArmyLanding)) {",
                        "    j=0;",
                        "    for(i=0;GroupCount(ArmyLanding)>i;i=i+1) {",
                        "        if(GetShipPlanet(GroupShip(ArmyLanding,i))) j=j+1;",
                        "    }",
                        "",
                        "    if(GroupCount(ArmyLanding) == j) {",
                        "        //Определяем бонус к силе",
                        "        if (has_arm == 0) has_arm = 1;",
                        "        if (has_arm == arm_plan) tint = 13;",
                        "        else if (has_arm >= arm_plan * 0.90) tint = 12;",
                        "        else if (has_arm >= arm_plan * 0.75) tint = 11;",
                        "        else if (has_arm >= arm_plan * 0.55) tint = 10;",
                        "        else if (has_arm >= arm_plan * 0.35) tint = 9;",
                        "        else tint = 8;",
                        "        //Устанавливаем силу",
                        "        tint = GroupCount(ArmyLanding) * tint / 2 + GroupCount(Army) * tint / 4;",
                        "        tint2 = Rnd(1, 100);",
                        "        tdwd = GetShipPlanet(GroupToShip(ArmyLanding));",
                        "        if (tint2 <= tint)",
                        "        {",
                        "            PlanetOwner(tdwd, PlanetRace(tdwd));",
                        "            PlanetGov(tdwd,Rnd(3,4));",
                        "            if(SectorVisible(StarToCon(GalaxyStar(StarForRevolt-1)))) {",
                        "                tstr = Format(CT(\"Script.Mod_ShuRebellion.79\"),\"<0>\",Name(GalaxyStar(StarForRevolt-1)),\"<1>\",Name(tdwd));",
                        "                AddPlanetNews(tstr,63);",
                        "                NewsAdd(tstr);",
                        "                Sound('Sound.NewMsg');",
                        "            }",
                        "",
                        "            for(i=(GroupCount(ArmyLanding)-1);i>=0;i=i-1) {",
                        "                SetData(1,1,GroupShip(ArmyLanding,i));",
                        "                OrderTakeOff(GroupShip(ArmyLanding,i));",
                        "                //ShipJoin(Army,GroupShip(ArmyLanding,i));",
                        "                //ChangeState('MainState2',GroupShip(ArmyLanding,i));",
                        "            }",
                        "        }",
                        "        if (tint2 > tint)",
                        "        {",
                        "            for(i=GroupCount(ArmyLanding);i>0;i=i-1) {",
                        "                OrderLock(GroupShip(ArmyLanding, i), 1);",
                        "                ShipDestroy(GroupShip(ArmyLanding, i));",
                        "            }",
                        "",
                        "            if(SectorVisible(StarToCon(GalaxyStar(StarForRevolt-1)))) {",
                        "                tstr = Format(CT(\"Script.Mod_ShuRebellion.78\"),\"<0>\",Name(GalaxyStar(StarForRevolt-1)),\"<1>\",Name(tdwd));",
                        "                AddPlanetNews(tstr,63);",
                        "                NewsAdd(tstr);",
                        "                Sound('Sound.NewMsg');",
                        "            }",
                        "        }",
                        "    }",
                        "}",
                        "dword star = GalaxyStar(StarForRevolt-1);",
                        "",
                        "//Все корабли в системе привлекаются в войнушку",
                        "for(i=0;i<StarShips(star);i=i+1) {",
                        "    tdwd = StarShips(star,i);",
                        "    if(ShipInScript(tdwd)) continue;",
                        "    if((GroupCount(Army) + GroupCount(ArmyLanding)) < (GroupCount(Rebels) + GroupCount(RebelsLanding) + 20)) {",
                        "        //Дредноуты стратегически важны. Несмотря ни на что, командование не оставит их в этой системе",
                        "        if(ShipType(tdwd) == 'Dreadnought') continue;",
                        "        if(ShipType(tdwd) == 'DefPlatform') continue;",
                        "        if(ShipTypeN(tdwd) > t_Tranclucator) continue;",
                        "        if(ShipTypeN(tdwd) == t_Warrior) {",
                        "             if(!ShipInScript(tdwd)) {",
                        "                 //Линкоры стратегически важны. Несмотря ни на что, командование не оставит их в этой системе",
                        "                 if(ShipSubType(tdwd)) continue;",
                        "                 ShipJoin(Army, tdwd);",
                        "             }",
                        "        }",
                        "    }",
                        "",
                        "    if((GroupCount(Army) + GroupCount(ArmyLanding)) + 20 > (GroupCount(Rebels) + GroupCount(RebelsLanding))) {",
                        "        if(ShipTypeN(tdwd) == t_Pirate && !ShipInScript(tdwd)) ShipJoin(Rebels, tdwd);",
                        "        else if(PirateType(tdwd) && !ShipInScript(tdwd)) ShipJoin(Rebels, tdwd);",
                        "        //Изменники тоже присоединяются к веселью",
                        "        else if(ShipTypeN(tdwd) == t_Ranger && ShipOnSidePirateClan(tdwd)) ShipJoin(Rebels, tdwd);",
                        "    }",
                        "}",
                        "",
                        "//Проверяем факт победы Клана/Коалиции, если нет кораблей и планет - система уходит в зрительский зал",
                        "if(!GroupCount(Rebels) && !GroupCount(RebelsLanding)) {",
                        "    j = 0;",
                        "    for(i=0;StarPlanets(star)>i;i=i+1) {",
                        "        if(PlanetOwner(StarPlanets(star,i)) == 7) {",
                        "            j = 1;",
                        "            break;",
                        "        }",
                        "    }",
                        "",
                        "    if(!j) {",
                        "        StarOwner(star,0);",
                        "        tstr = Format(CT(\"Script.Mod_ShuRebellion.83\"),\"<0>\",Name(star));",
                        "        AddPlanetNews(tstr,63);",
                        "        NewsAdd(tstr);",
                        "        Sound('Sound.NewMsg');",
                        "        for(i=(StarRuins(GalaxyStar(StarForRevolt-1))-1);i>=0;i=i-1) {",
                        "            if(ShipStanding(StarRuins(GalaxyStar(StarForRevolt-1),i)) == 7 || ShipStanding(StarRuins(GalaxyStar(StarForRevolt-1),i)) == 8) {",
                        "                tdwd = StarRuins(GalaxyStar(StarForRevolt-1),i);",
                        "                OrderLock(tdwd,1);",
                        "                ShipDestroy(tdwd,1);",
                        "            }",
                        "        }",
                        "",
                        "        NoComeKlingToStar(star, 0);",
                        "",
                        "        AllShipOut();",
                        "        rev_date = CurTurn();",
                        "    }",
                        "}",
                        "if(!GroupCount(Army) && !GroupCount(ArmyLanding)) {",
                        "    j = 0;",
                        "    for(i=0;StarPlanets(star)>i;i=i+1) {",
                        "        if(PlanetOwner(StarPlanets(star,i)) < 5) {",
                        "            j = 1;",
                        "            break;",
                        "        }",
                        "    }",
                        "",
                        "    if(!j) {",
                        "        StarOwner(star,2);",
                        "        tstr = Format(CT(\"Script.Mod_ShuRebellion.82\"),\"<0>\",Name(star));",
                        "        AddPlanetNews(tstr,63);",
                        "        NewsAdd(tstr);",
                        "        Sound('Sound.NewMsg');",
                        "        for(i=(StarRuins(GalaxyStar(StarForRevolt-1))-1);i>=0;i=i-1) {",
                        "            if(ShipStanding(StarRuins(GalaxyStar(StarForRevolt-1),i)) == 2 || ShipStanding(StarRuins(GalaxyStar(StarForRevolt-1),i)) == 3) {",
                        "                tdwd = StarRuins(GalaxyStar(StarForRevolt-1),i);",
                        "                OrderLock(tdwd,1);",
                        "                ShipDestroy(tdwd,1);",
                        "            }",
                        "        }",
                        "",
                        "        NoComeKlingToStar(star, 0);",
                        "",
                        "        AllShipOut();",
                        "        rev_date = CurTurn();",
                        "    }",
                        "}",
                        "",
                        "//Покупаем пирата каждый тик",
                        "if(1) {",
                        "    if(!SpawnCD) {",
                        "        tdwd3 = star;",
                        "        tint = 0;",
                        "        tint2 = 0;",
                        "        for(i=0;StarPlanets(tdwd3)>i;i=i+1) {",
                        "            tdwd2 = StarPlanets(tdwd3,i);",
                        "            if(PlanetOwner(tdwd3) == 6) continue;",
                        "            if(PlanetOwner(tdwd3) == 7) tint = tint + 1;",
                        "            else tint2 = tint2 + 1;",
                        "        }",
                        "        tdwd2 = FindPlanet(tdwd3,'NotMaloc,NotPeleng,NotPeople,NotFei,NotGaal,NotNone');",
                        "        if(tdwd2 > 0) {",
                        "            if(!GroupCount(Army) && !GroupCount(ArmyLanding) && ((GroupCount(Army) + GroupCount(ArmyLanding)) < 60) && (GroupCount(Army) + GroupCount(ArmyLanding)) < (GroupCount(Rebels) + GroupCount(RebelsLanding) + 20) && tdwd2 > 0) {",
                        "                j=Rnd(1+tint2,1+tint2*2);",
                        "                for(i=0;i<j;i=i+1) {",
                        "                    tdwd = BuyWarrior(tdwd2, 300);",
                        "                    ShipRefit(tdwd);",
                        "                    ShipJoin(Rebels, tdwd);",
                        "                    //\"Расходы\" на оснащение",
                        "                    GoodsAdd(tdwd2,t_Food,-20);",
                        "                    GoodsAdd(tdwd2,t_Technics,-100);",
                        "                    GoodsAdd(tdwd2,t_Medicine,-10);",
                        "                    GoodsAdd(tdwd2,t_Arms,-25);",
                        "                    GoodsAdd(tdwd2,t_Alcohol,-20);",
                        "                    GoodsAdd(tdwd2,t_Narcotics,-5);",
                        "                }",
                        "            }",
                        "        }",
                        "        if(tdwd2 > 0) {",
                        "            tdwd2 = FindPlanet(tdwd3,'NotPirateClan,NotNone');",
                        "            if(!GroupCount(Rebels) && !GroupCount(RebelsLanding) && ((GroupCount(Rebels) + GroupCount(RebelsLanding)) < 60) && (GroupCount(Army) + GroupCount(ArmyLanding)) + 20 > (GroupCount(Rebels) + GroupCount(RebelsLanding)) && tdwd2 > 0) {",
                        "                j=Rnd(1+tint,2+tint*2);",
                        "                for(i=0;i<j;i=i+1) {",
                        "                    tdwd = BuyWarrior(tdwd2, 300);",
                        "                    ShipRefit(tdwd);",
                        "                    ShipJoin(Army, tdwd);",
                        "                    //\"Расходы\" на оснащение",
                        "                    GoodsAdd(tdwd2,t_Food,-20);",
                        "                    GoodsAdd(tdwd2,t_Technics,-100);",
                        "                    GoodsAdd(tdwd2,t_Medicine,-10);",
                        "                    GoodsAdd(tdwd2,t_Arms,-25);",
                        "                }",
                        "            }",
                        "        }",
                        "        SpawnCD = Rnd(20,35);",
                        "    }",
                        "    else SpawnCD = SpawnCD - 1;",
                        "",
                        "",
                        "    //Реакция на участие игрока в восстании",
                        "    if (ShipInStar(Player(), star)) {",
                        "        tint = GalaxyEvents();",
                        "        for (i = 0;i < tint;i = i + 1) {",
                        "            if (GalaxyEventDate(i) == CurTurn()) {",
                        "                if (GalaxyEventType(i) == 'PlayerAssistKillsShip' && GalaxyEventData(i, 0) == t_Warrior && ShipInStar(Player(), star) || GalaxyEventType(i) == 'PlayerKillsShip' && GalaxyEventData(i, 0) == t_Warrior && ShipInStar(Player(), star)) {",
                        "                    RelationToRanger(PlanetPirateClan(),Player(),RelationToRanger(PlanetPirateClan(),Player()) + Rnd(0,2));",
                        "                }",
                        "            }",
                        "        }",
                        "",
                        "        if (ShipKillFactionInCurSystem(Player(), 2) > killed_rebs) {",
                        "            tint2 = ShipKillFactionInCurSystem(Player(), 2) - killed_rebs;",
                        "            killed_rebs = ShipKillFactionInCurSystem(Player(), 2);",
                        "            while(tint2 > 0) {",
                        "                tint2 = tint2 - 1;",
                        "                ChangeGlobalRelationsPlanets(Player(), 0, 2, Rnd(1, 3), 1 + 4 + 8 + 16);",
                        "                ChangeGlobalRelationsShips(Player(), 0, 2, Rnd(0, 2), 1 + 8 + 16 + 32, 1 + 2 + 4 + 8 + 16);",
                        "                ChangeGlobalRelationsPlanets(Player(), 0, 2, -Rnd(10, 20), 128);",
                        "                tint = GroupCount(Rebels);",
                        "                for (i = 0;i < tint;i = i + 1) {",
                        "                    tdwd = GroupShip(Rebels, i);",
                        "                    RelationToRanger(tdwd, Player(), RelationToRanger(tdwd, Player()) - Rnd(30, 70));",
                        "                }",
                        "            }",
                        "        }",
                        "    }",
                        "    if(ShipInStar(Player(),star)) {",
                        "        if(GetShipPlanet(Player())) GotoGov(1);",
                        "    }",
                        "}",
                        "",
                        "EventTime = EventTime + 1;",
                        "",
                        "if(EventTime > 730) {",
                        "    for(i=0;StarPlanets(star)>i;i=i+1) {",
                        "        tdwd = StarPlanets(star,i);",
                        "        if(StarOwner(star) == 2) {",
                        "            PlanetOwner(tdwd,PirateClan);",
                        "        }",
                        "        else {",
                        "            PlanetOwner(tdwd,PlanetRace(tdwd));",
                        "        }",
                        "    }",
                        "",
                        "    if(StarOwner(star) == 2) {",
                        "        tstr = Format(CT(\"Script.Mod_ShuRebellion.82\"),\"<0>\",Name(star));",
                        "        AddPlanetNews(tstr,63);",
                        "        NewsAdd(tstr);",
                        "        Sound('Sound.NewMsg');",
                        "        PlanetOwner(tdwd,PirateClan);",
                        "    }",
                        "    else {",
                        "        tstr = Format(CT(\"Script.Mod_ShuRebellion.83\"),\"<0>\",Name(star));",
                        "        AddPlanetNews(tstr,63);",
                        "        NewsAdd(tstr);",
                        "        Sound('Sound.NewMsg');",
                        "        PlanetOwner(tdwd,PlanetRace(tdwd));",
                        "    }",
                        "",
                        "    rev_date = CurTurn();",
                        "    AllShipOut();",
                        "}"
                    ],
                    "#": 31,
                    "Type": "Top",
                    "Parent": -1,
                    "Pos.x": 120,
                    "Pos.y": 685
                },
                {
                    "Name": "",
                    "Code.Type": "DialogBegin",
                    "Code": [
                        "if(GetTalkShip()) {",
                        "    if(!TalkByAI()) {",
                        "        if(ShipInCurScript(GetTalkShip())) {",
                        "            if(ShipTypeN(GetTalkShip()) <= t_Tranclucator) {",
                        "                if(!ShipOnSidePirateClan(GetTalkShip())) AddDialogOverride('dSwat', 15);",
                        "                else AddDialogOverride('dRebel', 15);",
                        "            }",
                        "        }",
                        "    }",
                        "}",
                        "if(GetShipPlanet(Player())) {",
                        "    if(ShipInStar(Player(),GalaxyStar(StarForRevolt-1))) {",
                        "        tdwd = GetShipPlanet(Player());",
                        "        if(PlanetOwner(tdwd) == 7) {",
                        "            AddDialogOverride('TalkToRebels', 10);",
                        "        }",
                        "        else {",
                        "            AddDialogOverride('TalkToWars', 10);",
                        "        }",
                        "    }",
                        "}"
                    ],
                    "#": 32,
                    "Type": "Top",
                    "Parent": -1,
                    "Pos.x": 180,
                    "Pos.y": 685
                },
                {
                    "Name": "",
                    "Code.Type": "Turn",
                    "Code": [
                        "if(GetShipPlanet(CurShip)) {",
                        "  OrderTakeOff(CurShip);",
                        "}",
                        "if(!GetShipPlanet(CurShip) && ShipInStar(CurShip,GalaxyStar(StarForRevolt-1))) {",
                        "  if(!GroupCount(Rebels) && !GroupCount(RebelsLanding)) {",
                        "    if(GroupCount(Army) > 5) {",
                        "      if(GroupCount(ArmyLanding) >= 5) {",
                        "        ChangeState(5);",
                        "        exit;",
                        "      }",
                        "      if(GroupCount(ArmyLanding) < 5) {",
                        "        ShipJoin(ArmyLanding,CurShip);",
                        "        ChangeState('Main2',CurShip);",
                        "      }",
                        "    }",
                        "  }",
                        "  if(GroupCount(Rebels)) {",
                        "    ChangeState(4);",
                        "    exit;",
                        "  }",
                        "  if(GroupCount(RebelsLanding) && !GroupCount(Rebels)) {",
                        "    ChangeState(10);",
                        "    exit;",
                        "  }",
                        "}",
                        "if(!ShipInStar(CurShip,GalaxyStar(StarForRevolt-1))) {",
                        "  ShipOut(CurShip);",
                        "}"
