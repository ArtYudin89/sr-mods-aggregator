                        "    if (j==3) tdwd=CreateArt(t_ArtefactBomb,PirateClan);",
                        "    if (j==4) tdwd=CreateEquipment(t_Weapon17,Rnd(30,60),Rnd(GalaxyTechLevel()-1,GalaxyTechLevel()+1),PirateClan);",
