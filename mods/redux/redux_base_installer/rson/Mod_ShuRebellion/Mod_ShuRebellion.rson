                    "Pos.x": 1200,
                    "Pos.y": 590,
                    "Type": "TDialogAnswer",
                    "Parent": -1,
                    "#": 87,
                    "Msg": "Вы что-то покупаете? Или продаете?",
                    "AMsg.Num": "10",
