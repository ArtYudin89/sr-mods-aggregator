                    "Code.Type": "Turn",
                    "Code": [
                        "if(!GetShipPlanet(CurShip)) {",
                        "  if(!GetData()) {",
                        "      tdwd = FindPlanet(GalaxyStar(StarForRevolt-1),'NotPirateClan,NotNone');",
                        "      if(tdwd > 0) {",
                        "          for(i=0;GroupCount(RebelsLanding)>i;i=i+1) {",
