                },
                {
                    "Name": "",
                    "Pos.x": 240,
                    "Pos.y": 615,
                    "Type": "TDialogAnswer",
                    "Parent": -1,
                    "#": 94,
                    "Msg": "Я хотел бы внести посильный вклад финансированием постройки нового защитника системы!",
