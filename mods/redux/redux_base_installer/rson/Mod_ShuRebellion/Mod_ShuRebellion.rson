                {
                    "Name": "",
                    "Code.Type": "Turn",
                    "Code": [
                        "GotoGov(2);",
                        "SkipGreeting();",
                        "",
                        "tint = GoodsBuyPrice(GetShipPlanet(Player()),t_Arms)/3;",
                        "if(!ShipOnSidePirateClan(Player())) {",
                        "  if(RelationToShip(GetShipPlanet(Player()),Player()) > 29) {",
