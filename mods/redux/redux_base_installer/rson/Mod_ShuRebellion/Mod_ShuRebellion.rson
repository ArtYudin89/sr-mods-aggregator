                    "Parent": -1,
                    "#": 96,
                    "Msg": "Согласен",
                    "AMsg.Num": "19",
                    "_orig_danswer": "DAnswer(CT(\"Script.Mod_ShuRebellion.98\"))"
                },
                {
                    "Name": "",
                    "Pos.x": 600,
                    "Pos.y": 615,
                    "Type": "TDialogAnswer",
                    "Parent": -1,
                    "#": 97,
                    "Msg": "Да не за что",
                    "AMsg.Num": "20",
                    "_orig_danswer": "DAnswer(CT(\"Script.Mod_ShuRebellion.99\"))"
                },
                {
                    "Name": "",
                    "Pos.x": 720,
                    "Pos.y": 615,
                    "Type": "TDialogAnswer",
