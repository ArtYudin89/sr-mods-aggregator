            "Items": [],
            "Operations": [
                {
                    "Name": "",
                    "Code.Type": "Global",
                    "Code": [
                        "if(GRunFrom==3) {",
                        "  if(CurTurn()>2190) {",
                        "      if(GLastTurnRun(GScriptName)+1460<CurTurn()) {",
                        "          if(PlayerChameleonCurType()==-1) GRun();",
                        "      }",
                        "  }",
                        "}"
                    ],
                    "#": 16,
                    "Type": "Top",
                    "Parent": -1,
                    "Pos.x": 0,
                    "Pos.y": 585
                },
                {
                    "Name": "",
                    "Code.Type": "Turn",
                    "Code": [
                        "if(!sst) {",
                        "    //Запоминаем изначального владельца планеты",
                        "    planetOwner=PlanetOwner(OccupiedPlanet);",
                        "    //Создаем военных",
                        "    for(i=0;i<Rnd(5,7);i=i+1)",
                        "    {",
                        "        //Меняем владельца и расу планеты для спавна на расу из захваченной системы",
                        "        PlanetOwner(OccupiedPlanet,PlanetRace(OccupiedPlanet));",
                        "        ship=BuyWarrior(OccupiedPlanet,Rnd(200,500));",
                        "        //Оснащаем военных",
                        "        ItemSize(ShipItems(ship,0),round((0.00085*GalaxyDiffLevels()+1)*GalaxyTechLevel()*100)+Rnd(-25,45));",
                        "        if(ItemSize(ShipItems(ship,0))<250)",
                        "        ItemSize(ShipItems(ship,0),250);",
                        "        HullHP(ship,ItemSize(ShipItems(ship,0)));",
                        "        Chameleon(ship);",
                        "        for(j=0;j<5;j=j+1) ShipRefit(ship);",
                        "        for(j=0;j<3;j=j+1) {",
                        "            tint=round(0.5*GalaxyTechLevel())+Rnd(-1,2);",
                        "            ShipSkill(ship,j,tint);",
                        "        }",
                        "        if(GetEquipmentStats(ShipItems(ship,0),7))  {",
                        "            if(!ShipEqInSlot(ship,t_DefGenerator)) {",
                        "                item=CreateEquipment(t_DefGenerator,Rnd(20,45),GalaxyTechLevel(),ShipOwner(ship));",
                        "                AddItemToShip(ship,item);",
                        "                ItemIsInUse(item,ship,1);",
                        "            }",
                        "        }",
                        "        if(GetEquipmentStats(ShipItems(ship,0),5)) {",
                        "            if(!ShipEqInSlot(ship,t_RepairRobot)) {",
                        "                item=CreateEquipment(t_RepairRobot,Rnd(20,45),GalaxyTechLevel(),ShipOwner(ship));",
                        "                AddItemToShip(ship,item);",
                        "                ItemIsInUse(item,ship,1);",
                        "            }",
                        "        }",
                        "        //Рандомно улучшаем оборудование",
                        "        ShipImproveItems(ship,2*GalaxyTechLevel());",
                        "        //Устраняем возможный перевес",
                        "        ShipCalcParam(ship);",
                        "        if(ShipFreeSpace(ship)<0) {",
                        "            ItemSize(ShipItems(ship,0),ItemSize(ShipItems(ship,0))+abs(ShipFreeSpace(ship))+Rnd(1,5));",
                        "            HullHP(ship,ItemSize(ShipItems(ship,0)));",
                        "        }",
                        "        ShipJoin(Warriors,ship);",
                        "        TransferShip(ship,UnhabitablePlanet);",
                        "    }",
                        "    //Возвращаем планете первоначального владельца",
                        "    PlanetOwner(OccupiedPlanet,planetOwner);",
                        "    sst=1;",
                        "}",
                        "if(sst && !GroupCount(Warriors)) AllShipOut();"
                    ],
                    "#": 17,
                    "Type": "Top",
                    "Parent": -1,
                    "Pos.x": 120,
                    "Pos.y": 585
                },
                {
                    "Name": "",
                    "Code.Type": "Turn",
                    "Code": [
                        "if(ShipInNormalSpace(Player()) && ShipInStar(Player(),InitStar)) {",
                        "  OrderTakeOff(CurShip);",
                        "  ",
                        "  if(ShipStar(GroupToShip(Warriors))==ShipStar(Player())) {",
                        "    if(ShipInNormalSpace(Player())) {",
                        "      if(ShipInNormalSpace(GroupToShip(Warriors))) {",
                        "        if(!dlg) {",
                        "          Dialog(flot,Warriors);",
                        "          AllShipOut();",
                        "        }",
                        "      }",
                        "    }",
                        "  }",
                        "}",
                        "if(StarBattle(InitStar)) {",
                        "  OrderTakeOff(CurShip);",
                        "  AllShipOut();",
                        "}"
                    ],
                    "#": 32,
                    "Type": "Top",
                    "Parent": -1,
                    "Pos.x": 80
                },
                {
                    "Name": "",
                    "Code.Type": "Turn",
                    "Code": [
                        "if(dlg==0) {",
                        "  DChange(0);",
                        "  exit;",
                        "}",
                        "if(dlg==2) {",
                        "  DChange(1);",
                        "  exit;",
                        "}",
                        "if(dlg==1) {",
                        "  DChange(3);",
                        "  exit;",
                        "}"
                    ],
