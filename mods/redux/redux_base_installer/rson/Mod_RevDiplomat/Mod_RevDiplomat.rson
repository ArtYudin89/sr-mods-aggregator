                {
                    "Name": "",
                    "Code.Type": "DialogBegin",
                    "Code": [
                        "if(GetShipRuins(Player())) {",
                        "    if(ShipType(GetShipRuins(Player())) == 'SB') {",
                        "        if(ItemIn(iCaps,Player())) {",
                        "            if(vState==2 || vState==3 || vState==5) {",
                        "                AddDialogOverride('dSB',999);",
                        "            }",
                        "        }",
                        "    }",
                        "}"
                    ],
                    "#": 24,
                    "Type": "Top",
                    "Parent": -1,
                    "Pos.x": 180,
                    "Pos.y": 635
                },
                {
                    "Name": "",
                    "Code.Type": "Turn",
                    "Code": [
                        "if(vDialogD==0) {",
                        "  if(vState==0 && vDialogD_rep<CurTurn()) {",
                        "    Dialog(dDipl,Dip);",
                        "    vDiplStart=1;",
                        "  }",
                        "}",
                        "if(vDialogD==1 && vDaysLeft>5 && HullDamage(CurShip)>50) {",
                        "  Dialog(dDipl,Dip);",
                        "  vDialogD=3;",
                        "  vDiplStart=1;",
                        "}",
                        "if(vState==7) {",
                        "  ChangeGlobalRelationsPlanets(Player(),0,2,30,200+255);",
                        "  AllShipOut();",
                        "}",
                        "if(EndState) {",
                        "  ChangeState(3);",
                        "  exit;",
                        "}",
                        "if(!CountIn(Pirate) && vState!=7 && vState!=5) {",
                        "  Ether(1,'883FBEDA-96CA-4E3C-9C08-6C8AC17289A2',Format(CT(\"Script.Mod_RevDiplomat.0\"),\"<0>\",Name(GroupToShip(Dip))),GroupToShip(Dip),Player());",
                        "}",
                        "if(ItemIn(iCaps,Dip)) {",
                        "  if(!CountIn(Dip)) {",
                        "    vState=2;",
                        "  }",
                        "  if(HullDamage(CurShip)>95) {",
                        "    vState=2;",
                        "    DropScriptItem(CurShip,iCaps);",
                        "    ShipDestroy(GroupToShip(Dip));",
                        "  }",
                        "}"
                    ],
