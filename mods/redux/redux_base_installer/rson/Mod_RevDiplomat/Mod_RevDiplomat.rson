    "Visual.Objects": [
        {
            "ConstellationCount": 0,
            "DialogAnswers": [
                {
                    "Name": "",
                    "Pos.x": 0,
                    "Pos.y": 540,
                    "Type": "TDialogAnswer",
                    "Parent": -1,
                    "#": 59,
                    "Msg": "Э... Чего?",
                    "AMsg.Num": "0",
                    "_orig_danswer": "DAnswer(CT(\"Script.Mod_RevDiplomat.9\"))"
                },
                {
                    "Name": "exit",
                    "Pos.x": 120,
                    "Pos.y": 540,
                    "Type": "TDialogAnswer",
                    "Parent": -1,
                    "#": 60,
                    "Msg": "Держитесь, вам недолго осталось. Щас я этих пиратов разнесу",
                    "AMsg.Num": "1",
                    "_orig_danswer": "DAnswer('exit~'+CT(\"Script.Mod_RevDiplomat.10\"))"
                },
                {
                    "Name": "exit",
                    "Pos.x": 240,
                    "Pos.y": 540,
                    "Type": "TDialogAnswer",
                    "Parent": -1,
                    "#": 61,
                    "Msg": "С хамами и зажравшимися чиновниками не общаюсь",
                    "AMsg.Num": "2",
                    "_orig_danswer": "DAnswer('exit~'+CT(\"Script.Mod_RevDiplomat.46\"))"
                },
                {
                    "Name": "exit",
                    "Pos.x": 360,
                    "Pos.y": 540,
                    "Type": "TDialogAnswer",
                    "Parent": -1,
                    "#": 62,
                    "Msg": "",
                    "AMsg.Num": "3",
                    "_orig_danswer": "DAnswer('exit')"
                },
                {
                    "Name": "",
                    "Pos.x": 480,
                    "Pos.y": 540,
                    "Type": "TDialogAnswer",
                    "Parent": -1,
                    "#": 63,
                    "Msg": "Мне нужно выпилить дыру в капсуле. Говорят, там гуманоид находится",
                    "AMsg.Num": "4",
                    "_orig_danswer": "DAnswer(CT(\"Script.Mod_RevDiplomat.48\"))"
                },
                {
                    "Name": "",
                    "Pos.x": 600,
                    "Pos.y": 540,
                    "Type": "TDialogAnswer",
                    "Parent": -1,
                    "#": 64,
                    "Msg": "Ожидать окончания операции",
                    "AMsg.Num": "5",
                    "_orig_danswer": "DAnswer(CT(\"Script.Mod_RevDiplomat.13\"))"
                },
                {
                    "Name": "",
                    "Pos.x": 720,
                    "Pos.y": 540,
                    "Type": "TDialogAnswer",
                    "Parent": -1,
                    "#": 65,
                    "Msg": "Я выбираю деньги",
                    "AMsg.Num": "6",
                    "_orig_danswer": "DAnswer(CT(\"Script.Mod_RevDiplomat.14\"))"
                },
                {
                    "Name": "hangar",
                    "Pos.x": 840,
                    "Pos.y": 540,
                    "Type": "TDialogAnswer",
                    "Parent": -1,
                    "#": 66,
                    "Msg": "Пока",
                    "AMsg.Num": "7",
                    "_orig_danswer": "DAnswer('hangar~'+CT(\"Script.Mod_RevDiplomat.16\"))"
                },
                {
                    "Name": "",
                    "Pos.x": 960,
                    "Pos.y": 540,
                    "Type": "TDialogAnswer",
                    "Parent": -1,
                    "#": 67,
                    "Msg": "Мне нужно улучшить отношения",
                    "AMsg.Num": "8",
                    "_orig_danswer": "DAnswer(CT(\"Script.Mod_RevDiplomat.23\"))"
                },
                {
                    "Name": "exit",
                    "Pos.x": 1080,
                    "Pos.y": 540,
                    "Type": "TDialogAnswer",
                    "Parent": -1,
                    "#": 68,
                    "Msg": "И правда, его даже не купит никто. Сейчас выброшу, держи",
                    "AMsg.Num": "9",
                    "_orig_danswer": "DAnswer('exit~'+CT(\"Script.Mod_RevDiplomat.26\"))"
                },
                {
                    "Name": "",
                    "Pos.x": 1200,
                    "Pos.y": 540,
                    "Type": "TDialogAnswer",
                    "Parent": -1,
                    "#": 69,
                    "Msg": "Э нет, так не пойдет. Что ты можешь предложить за нее?",
                    "AMsg.Num": "10",
                    "_orig_danswer": "DAnswer(CT(\"Script.Mod_RevDiplomat.27\"))"
                },
                {
                    "Name": "exit",
                    "Pos.x": 1320,
                    "Pos.y": 540,
                    "Type": "TDialogAnswer",
                    "Parent": -1,
                    "#": 70,
                    "Msg": "Нет, ни за что не отдам",
                    "AMsg.Num": "11",
                    "_orig_danswer": "DAnswer('exit~'+CT(\"Script.Mod_RevDiplomat.28\"))"
                },
                {
                    "Name": "exit",
                    "Pos.x": 1440,
                    "Pos.y": 540,
                    "Type": "TDialogAnswer",
                    "Parent": -1,
                    "#": 71,
                    "Msg": "Я выбираю деньги",
                    "AMsg.Num": "12",
                    "_orig_danswer": "DAnswer('exit~'+CT(\"Script.Mod_RevDiplomat.14\"))"
                },
                {
                    "Name": "exit",
                    "Pos.x": 1560,
                    "Pos.y": 540,
                    "Type": "TDialogAnswer",
                    "Parent": -1,
                    "#": 72,
                    "Msg": "Давай оружие",
                    "AMsg.Num": "13",
                    "_orig_danswer": "DAnswer('exit~'+CT(\"Script.Mod_RevDiplomat.29\"))"
                },
                {
                    "Name": "exit",
                    "Pos.x": 1680,
                    "Pos.y": 540,
                    "Type": "TDialogAnswer",
                    "Parent": -1,
                    "#": 73,
                    "Msg": "Я за наркотики",
                    "AMsg.Num": "14",
                    "_orig_danswer": "DAnswer('exit~'+CT(\"Script.Mod_RevDiplomat.30\"))"
                },
                {
                    "Name": "",
                    "Pos.x": 0,
                    "Pos.y": 565,
                    "Type": "TDialogAnswer",
                    "Parent": -1,
                    "#": 74,
                    "Msg": "Отвали от него, иначе будешь иметь дело со мной!",
                    "AMsg.Num": "15",
                    "_orig_danswer": "DAnswer(CT(\"Script.Mod_RevDiplomat.34\"))"
                },
                {
                    "Name": "exit",
                    "Pos.x": 120,
                    "Pos.y": 565,
                    "Type": "TDialogAnswer",
                    "Parent": -1,
                    "#": 75,
                    "Msg": "",
                    "AMsg.Num": "16",
                    "_orig_danswer": "DAnswer('exit')"
                },
                {
                    "Name": "",
                    "Pos.x": 240,
                    "Pos.y": 565,
                    "Type": "TDialogAnswer",
                    "Parent": -1,
                    "#": 76,
                    "Msg": "С гаальцами",
                    "AMsg.Num": "17",
                    "_orig_danswer": "DAnswer(CT(\"Script.Mod_RevDiplomat.37\"))"
                },
                {
                    "Name": "",
                    "Pos.x": 360,
                    "Pos.y": 565,
                    "Type": "TDialogAnswer",
                    "Parent": -1,
                    "#": 77,
                    "Msg": "С фэянами",
                    "AMsg.Num": "18",
                    "_orig_danswer": "DAnswer(CT(\"Script.Mod_RevDiplomat.38\"))"
                },
                {
                    "Name": "",
                    "Pos.x": 480,
                    "Pos.y": 565,
                    "Type": "TDialogAnswer",
                    "Parent": -1,
                    "#": 78,
                    "Msg": "С пеленгами",
                    "AMsg.Num": "19",
                    "_orig_danswer": "DAnswer(CT(\"Script.Mod_RevDiplomat.39\"))"
                },
                {
                    "Name": "",
                    "Pos.x": 600,
                    "Pos.y": 565,
                    "Type": "TDialogAnswer",
                    "Parent": -1,
                    "#": 79,
                    "Msg": "С людьми",
                    "AMsg.Num": "20",
                    "_orig_danswer": "DAnswer(CT(\"Script.Mod_RevDiplomat.40\"))"
                },
                {
                    "Name": "",
                    "Pos.x": 720,
                    "Pos.y": 565,
                    "Type": "TDialogAnswer",
                    "Parent": -1,
                    "#": 80,
                    "Msg": "С малоками",
                    "AMsg.Num": "21",
                    "_orig_danswer": "DAnswer(CT(\"Script.Mod_RevDiplomat.41\"))"
                },
                {
                    "Name": "exit",
                    "Pos.x": 840,
                    "Pos.y": 565,
                    "Type": "TDialogAnswer",
                    "Parent": -1,
                    "#": 81,
                    "Msg": "",
                    "AMsg.Num": "22",
                    "_orig_danswer": "DAnswer('exit')"
                },
                {
                    "Name": "exit",
                    "Pos.x": 960,
                    "Pos.y": 565,
                    "Type": "TDialogAnswer",
                    "Parent": -1,
                    "#": 82,
                    "Msg": "Рад был помочь",
                    "AMsg.Num": "23",
                    "_orig_danswer": "DAnswer('exit~'+CT(\"Script.Mod_RevDiplomat.59\"))"
                },
                {
                    "Name": "exit",
                    "Pos.x": 1080,
                    "Pos.y": 565,
                    "Type": "TDialogAnswer",
                    "Parent": -1,
                    "#": 83,
                    "Msg": "",
                    "AMsg.Num": "24",
                    "_orig_danswer": "DAnswer('exit')"
                },
                {
                    "Name": "exit",
                    "Pos.x": 1200,
                    "Pos.y": 565,
                    "Type": "TDialogAnswer",
                    "Parent": -1,
                    "#": 84,
                    "Msg": "Ну, ещё посмотрим, кто жалеть будет",
                    "AMsg.Num": "25",
                    "_orig_danswer": "DAnswer('exit~'+CT(\"Script.Mod_RevDiplomat.64\"))"
                }
            ],
            "DialogMessages": [
                {
                    "Name": "",
                    "Pos.x": 0,
                    "Pos.y": 445,
                    "Type": "TDialogMsg",
                    "Parent": -1,
                    "#": 41,
                    "Msg": "<Player>, мать твою! На нас напали, убери этих ублюдков, немедленно! Иначе не поздоровится ни им, ни тебе.",
                    "DMsg.Num": "0",
                    "_orig_dtext": "DText(CT(\"Script.Mod_RevDiplomat.50\"))"
                },
                {
                    "Name": "",
                    "Pos.x": 150,
                    "Pos.y": 445,
                    "Type": "TDialogMsg",
                    "Parent": -1,
                    "#": 42,
                    "Msg": "Я высокопоставленный  чиновник с планеты <0>. За мной гонится стайка пиратов. Они могут меня уничтожить. Тебе нужно меня спасти, иначе может произойти все что угодно!\r\nСлушай, ты что, действительно такой тупой, раз не понял этого сразу, а?",
                    "DMsg.Num": "1",
                    "_orig_dtext": "DText(Format(CT(\"Script.Mod_RevDiplomat.2\"),\"<0>\",Name(Planet2)))"
                },
                {
                    "Name": "",
                    "Pos.x": 300,
                    "Pos.y": 445,
                    "Type": "TDialogMsg",
                    "Parent": -1,
                    "#": 43,
                    "Msg": "<Player>, что ты болтаешь по интеркому там?! Нас уже уничтожили почти, <0> ед. структуры осталось, и тебе хватает смелости выходить со мной связь?! \r\nЖиво убил этих пиратов, чтобы я не нервничал.",
                    "DMsg.Num": "2",
                    "_orig_dtext": "DText(Format(CT(\"Script.Mod_RevDiplomat.53\"),\"<0>\",(Hitpoints(CurShip))))"
                },
                {
                    "Name": "",
                    "Pos.x": 450,
                    "Pos.y": 445,
                    "Type": "TDialogMsg",
                    "Parent": -1,
                    "#": 44,
                    "Msg": "С чем пожаловали?",
                    "DMsg.Num": "3",
                    "_orig_dtext": "DText(CT(\"Script.Mod_RevDiplomat.43\"))"
                },
                {
                    "Name": "",
                    "Pos.x": 600,
                    "Pos.y": 445,
                    "Type": "TDialogMsg",
                    "Parent": -1,
                    "#": 45,
                    "Msg": "Скорей его сюда! Сейчас мы выпилим дверь в этой капсуле.\r\nНадеюсь, содержащийся внутри гуманоид неагрессивен? \r\nА, черт с ним, все равно спасать надо.\r\n<Player>, подождите несколько минут, сходите в бар, выпейте. Вот вам <0> cr, закажите кружку янвелба.",
                    "DMsg.Num": "4",
                    "_orig_dtext": "DText(Format(CT(\"Script.Mod_RevDiplomat.55\"),\"<0>\",5))"
                },
                {
                    "Name": "",
                    "Pos.x": 750,
                    "Pos.y": 445,
                    "Type": "TDialogMsg",
                    "Parent": -1,
                    "#": 46,
                    "Msg": "А, <Player>, похмелился уже? Ну и правильно сделал. \r\nДверь наши спецы выпилили, обнаружили там непрезентабельно выглядящего и нецензурно бранящегося посла <clr>Сатикина<clrEnd>. Несмотря на угрозы и нам, и вам, он все-таки решил отблагодарить своего спасителя. Ну и вас не обделят. Посол предлагает на выбор два вариант вознаграждения: деньги в размере <0> cr, либо же посол замолвит за вас словечко перед представителями какой-либо из рас. Выбирайте",
                    "DMsg.Num": "5",
                    "_orig_dtext": "DText(Format(CT(\"Script.Mod_RevDiplomat.54\"),\"<0>\",(GalaxyMoney(2)*1.5)))"
                },
                {
                    "Name": "",
                    "Pos.x": 900,
                    "Pos.y": 445,
                    "Type": "TDialogMsg",
                    "Parent": -1,
                    "#": 47,
                    "Msg": "Отличный выбор, <Player>!\r\nНаграда уже перечислена на ваш счёт, а наша роль в этой истории подошла к концу. Удачи.",
                    "DMsg.Num": "6",
                    "_orig_dtext": "DText(CT(\"Script.Mod_RevDiplomat.7\"))"
                },
                {
                    "Name": "",
                    "Pos.x": 1050,
                    "Pos.y": 445,
                    "Type": "TDialogMsg",
                    "Parent": -1,
                    "#": 48,
                    "Msg": "Отлично, я передам Сатикину вашу просьбу. \r\nНа этом наша роль в этой истории окончена. Прощайте.",
                    "DMsg.Num": "7",
                    "_orig_dtext": "DText(CT(\"Script.Mod_RevDiplomat.8\"))"
                },
                {
                    "Name": "",
                    "Pos.x": 1200,
                    "Pos.y": 445,
                    "Type": "TDialogMsg",
                    "Parent": -1,
                    "#": 49,
                    "Msg": "Здарова, братец. Видал я, как ты капсулу подобрал. Слушай, а зачем тебе этот кусок металла? Отдай мне, а?",
                    "DMsg.Num": "8",
                    "_orig_dtext": "DText(CT(\"Script.Mod_RevDiplomat.24\"))"
                },
                {
                    "Name": "",
                    "Pos.x": 1350,
                    "Pos.y": 445,
                    "Type": "TDialogMsg",
                    "Parent": -1,
                    "#": 50,
                    "Msg": "Да ты не такой простак, каким кажешься, <Player>!\r\nЯ могу предложить тебе <0> cr, <1> тонн оружия или <2> тонн наркотиков. Выбирай.",
                    "DMsg.Num": "9",
                    "_orig_dtext": "DText(Format(CT(\"Script.Mod_RevDiplomat.51\"),\"<0>\",(GalaxyMoney(1)),\"<1>\",55,\"<2>\",30))"
                },
                {
                    "Name": "",
                    "Pos.x": 1500,
                    "Pos.y": 445,
                    "Type": "TDialogMsg",
                    "Parent": -1,
                    "#": 51,
                    "Msg": "<Player>, отвали, я на работе.",
                    "DMsg.Num": "10",
                    "_orig_dtext": "DText(CT(\"Script.Mod_RevDiplomat.32\"))"
                },
                {
                    "Name": "",
                    "Pos.x": 1650,
                    "Pos.y": 445,
                    "Type": "TDialogMsg",
                    "Parent": -1,
                    "#": 52,
                    "Msg": "Это не по-пацански, <Player>! Ну ладно, ладно, ты вор авторитетный, не буду я больше атаковать <0>, только не бей.",
                    "DMsg.Num": "11",
                    "_orig_dtext": "DText(Format(CT(\"Script.Mod_RevDiplomat.52\"),\"<0>\",ShipName(GroupToShip(Dip))))"
                },
                {
                    "Name": "",
                    "Pos.x": 0,
                    "Pos.y": 470,
                    "Type": "TDialogMsg",
                    "Parent": -1,
                    "#": 53,
                    "Msg": "И с кем же вы желаете наладить отношения?",
                    "DMsg.Num": "12",
                    "_orig_dtext": "DText(CT(\"Script.Mod_RevDiplomat.36\"))"
                },
                {
                    "Name": "",
                    "Pos.x": 150,
                    "Pos.y": 470,
                    "Type": "TDialogMsg",
                    "Parent": -1,
                    "#": 54,
                    "Msg": "Ха-ха, оборванец. Ты на кого решил наехать? Сейчас мы с дипломатом разберёмся, и тебе дюзы надерём!",
                    "DMsg.Num": "13",
                    "_orig_dtext": "DText(CT(\"Script.Mod_RevDiplomat.49\"))"
                },
                {
                    "Name": "",
                    "Pos.x": 300,
                    "Pos.y": 470,
                    "Type": "TDialogMsg",
                    "Parent": -1,
                    "#": 55,
                    "Msg": "Спасибо за поддержку. Кстати, я переговорил со знакомыми послами других рас, так что мне удалось немного поднять твой авторитет среди правительств планет разных рас.",
                    "DMsg.Num": "14",
                    "_orig_dtext": "DText(CT(\"Script.Mod_RevDiplomat.56\"))"
                },
                {
                    "Name": "",
                    "Pos.x": 450,
                    "Pos.y": 470,
                    "Type": "TDialogMsg",
                    "Parent": -1,
                    "#": 56,
                    "Msg": "Ладно, так уж и быть, раз ты всё-таки, как-никак, спас меня, я тебе подарю капсулу. \r\nМожет, выручишь за неё что-нибудь.",
                    "DMsg.Num": "15",
                    "_orig_dtext": "DText(CT(\"Script.Mod_RevDiplomat.57\"))"
                },
                {
                    "Name": "",
                    "Pos.x": 600,
                    "Pos.y": 470,
                    "Type": "TDialogMsg",
                    "Parent": -1,
                    "#": 57,
                    "Msg": "Ох, <Player>, заставим мы тебя ещё пожалеть о твоём решении, ох держи штурвал покрепче!",
                    "DMsg.Num": "16",
                    "_orig_dtext": "DText(CT(\"Script.Mod_RevDiplomat.62\"))"
                },
                {
                    "Name": "",
                    "Pos.x": 750,
                    "Pos.y": 470,
                    "Type": "TDialogMsg",
                    "Parent": -1,
                    "#": 58,
                    "Msg": "Спасибо за помощь, <Player>!",
                    "DMsg.Num": "17",
                    "_orig_dtext": "DText(CT(\"Script.Mod_RevDiplomat.63\"))"
                }
            ],
