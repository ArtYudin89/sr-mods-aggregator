                        "      DChange(16);",
                        "      exit;",
                        "    }",
                        "  }",
                        "  if(vState==5) {",
                        "    DChange(16);",
                        "    exit;",
                        "  }",
                        "}",
                        "if(vDialogP==1) {",
                        "  DChange(8);",
                        "  exit;",
                        "}"
