            "Operations": [
                {
                    "Name": "",
                    "Code.Type": "Global",
                    "Code": [
                        "//vState==0 - исходное состояние",
                        "//vState==1 - Скрипт стартовал, Сатикин позвониил игроку",
                        "//vState==2 - Корабль Сатикина уничтожен, капсула находится в открытом космическом пространстве",
                        "//vState==3 - Игрок принёс капсулу на НБ (сделано на случай перехода игрока между формами)",
                        "//vState==4 - Игрок спас Сатикина от гейратов в виде капсулы - скрипт завершён",
                        "//vState==5 - Игрок подобрал капсулу, но отдавать гейратам её отказался. Либо же наехал на гейратов, ней будучи авторитетным гейратом",
                        "//vState==6 - Игрок согласился обменять Сатикина",
                        "//vState==7 - Игрок спас Сатикина, потребовав как авторитетный гей(рат) от этих скриптовых оборванцев отвалить",
                        "",
                        "//vState==10 - Игрока спас Сатикина от гейратов и получает в награду капсулу - скрипт завершён",
                        "",
                        "",
                        "",
                        "//vDialogP==0 - исходное состояние, игроку гейраты не звонили",
                        "//vDialogP==1 - Пираты звонят, чтобы предложить отдать им капсулу",
                        "//vDialogP==2 - Пираты позвонили, предложив отдать капсулу с Сатикиным (больше разговоров не будет);",
                        "if(vDiplStart==0) {",
                        "  if((CurTurn()+1)>1160) {",
                        "    GRun();",
                        "  }",
                        "}"
                    ],
