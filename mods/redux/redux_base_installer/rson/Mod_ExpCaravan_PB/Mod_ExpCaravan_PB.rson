                    ],
                    "#": 33,
                    "Type": "Top",
                    "Parent": -1,
                    "Pos.x": 430,
                    "Pos.y": 445
                },
                {
                    "Name": "",
                    "Code.Type": "Turn",
                    "Code": [
                        "DAdd(5);"
                    ],
                    "#": 34,
                    "Type": "Top",
                    "Parent": -1,
                    "Pos.x": 580,
                    "Pos.y": 445
                },
                {
                    "Name": "",
                    "Code.Type": "Turn",
                    "Code": [
                        "DAdd(7);"
                    ],
                    "#": 35,
                    "Type": "Top",
                    "Parent": -1,
                    "Pos.x": 730,
                    "Pos.y": 445
                },
                {
                    "Name": "",
                    "Code.Type": "Turn",
                    "Code": [
                        "for(i=ShipItems(Player())-1;i>=0;i=i-1)",
                        "{",
                        "    tdwd=ShipItems(Player(),i);",
                        "    if(ItemType(tdwd)!=t_UselessItem)continue;",
                        "    if(EquipmentImageName(tdwd)=='ExpCaravan_CargoBox')",
                        "    {",
                        "        FreeItem(GetItemFromShip(Player(),FindItemInShip(Player(),tdwd)));",
                        "        //Накидываем по 100 очков пиратского звания за каждый сданный контейнер, если игрок состоит в пиратском клане",
                        "        //Но всегда оставляем одно очко до звания недополученным, чтобы диалог ПБ не перешёл резко к повышению",
                        "        if(ShipOnSidePirateClan(Player()))",
                        "        {",
                        "            j=ShipNextPirateRankPoints(Player())-ShipPirateRankPoints(Player());",
                        "            if(j<=100)ShipPirateRankPoints(Player(),ShipNextPirateRankPoints(Player())-1);",
                        "            else ShipPirateRankPoints(Player(),ShipPirateRankPoints(Player())+100);",
                        "        }",
                        "    }",
                        "}",
                        "Sound('Sound.Sell');",
                        "ShipMoney(Player(),ShipMoney(Player())+money);",
                        "DChange(2);",
                        "exit;"
                    ],
                    "#": 36,
                    "Type": "Top",
                    "Parent": -1,
                    "Pos.x": -20,
                    "Pos.y": 515
                },
                {
                    "Name": "",
                    "Code.Type": "Turn",
                    "Code": [
                        "DChange(1);",
                        "exit;"
                    ],
                    "#": 37,
                    "Type": "Top",
                    "Parent": -1,
                    "Pos.x": 100,
                    "Pos.y": 515
                },
                {
                    "Name": "",
                    "Code.Type": "Turn",
                    "Code": [
                        "DChange(4);",
                        "exit;"
                    ],
                    "#": 38,
                    "Type": "Top",
                    "Parent": -1,
                    "Pos.x": 460,
                    "Pos.y": 515
                },
                {
                    "Name": "",
                    "Code.Type": "Turn",
                    "Code": [
                        "for(i=ShipItems(Player())-1;i>=0;i=i-1)",
                        "{",
                        "    tdwd=ShipItems(Player(),i);",
                        "    if(ItemType(tdwd)!=t_UselessItem)continue;",
                        "    if(EquipmentImageName(tdwd)=='ExpCaravan_CargoBox')",
                        "    {",
                        "        FreeItem(GetItemFromShip(Player(),FindItemInShip(Player(),tdwd)));",
                        "        //Накидываем по 2500 опыта за каждый контейнер. ",
                        "        ShipFreeExp(Player(),ShipFreeExp(Player())+2500);",
                        "    }",
                        "}",
                        "//Не забываем массово выправить отношение с игроком, а то ведь он сдал же важный груз!",
                        "ChangeGlobalRelationsShips(Player(),0,1,75,1,31);",
                        "ChangeGlobalRelationsShips(Player(),0,1,75,2,31);",
                        "ChangeGlobalRelationsShips(Player(),0,1,75,4,31);",
                        "ChangeGlobalRelationsShips(Player(),0,1,75,8,31);",
                        "ChangeGlobalRelationsShips(Player(),0,1,75,16,31);",
                        "ChangeGlobalRelationsShips(Player(),0,1,75,32,31);",
                        "ChangeGlobalRelationsPlanets(Player(),0,1,75,31);",
                        "",
                        "Sound('Sound.Sell');",
                        "ShipMoney(Player(),ShipMoney(Player())+money);",
                        "DChange(5);",
                        "exit;"
                    ],
                    "#": 39,
                    "Type": "Top",
                    "Parent": -1,
                    "Pos.x": 700,
                    "Pos.y": 515
                }
