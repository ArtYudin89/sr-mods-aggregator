            "Items": [],
            "Operations": [
                {
                    "Name": "",
                    "Code.Type": "Global",
                    "Code": [
                        "GRun();"
                    ],
                    "#": 9,
                    "Type": "Top",
                    "Parent": -1,
                    "Pos.x": 0,
                    "Pos.y": 585
                },
                {
                    "Name": "",
                    "Code.Type": "DialogBegin",
                    "Code": [
                        "if(GetShipRuins(Player())) {",
                        "  if(ShipType(GetShipRuins(Player()))=='WB') {",
                        "    j=0;",
                        "    money=0;",
                        "    for(i=0;i<ShipItems(Player());i=i+1)",
                        "    {",
                        "        tdwd=ShipItems(Player(),i);",
                        "        if(ItemType(tdwd)!=t_UselessItem)continue;",
                        "        if(EquipmentImageName(tdwd)=='ExpCaravan_CargoBox')",
                        "        {",
                        "            j=j+1;",
                        "            money=money+ItemCost(tdwd);",
                        "        }",
                        "    }",
                        "    if(j)",
                        "    {",
                        "        if(j==1)Ttext='</color>'+CT(\"Script.Mod_ExpCaravan_PB.15\");",
                        "        else Ttext='</color>'+CT(\"Script.Mod_ExpCaravan_PB.14\");",
                        "        money=money+(money*25)/400;",
                        "        AddDialogInject('WB_CargoBox','',CT(\"Script.Mod_ExpCaravan_PB.17\"),1);",
                        "    }",
                        "  }",
                        "  if(ShipType(GetShipRuins(Player()))=='PB') {",
                        "    j=0;",
                        "    money=0;",
                        "    for(i=0;i<ShipItems(Player());i=i+1)",
                        "    {",
                        "        tdwd=ShipItems(Player(),i);",
                        "        if(ItemType(tdwd)!=t_UselessItem)continue;",
                        "        if(EquipmentImageName(tdwd)=='ExpCaravan_CargoBox')",
                        "        {",
                        "            j=j+1;",
                        "            money=money+ItemCost(tdwd);",
                        "        }",
                        "    }",
                        "    if(j)",
                        "    {",
                        "        if(j==1)Ttext='</color>'+CT(\"Script.Mod_ExpCaravan_PB.15\");",
                        "        else Ttext='</color>'+CT(\"Script.Mod_ExpCaravan_PB.14\");",
                        "        money=money+(money*25)/100;",
                        "        AddDialogInject('PB_CargoBox','',CT(\"Script.Mod_ExpCaravan_PB.0\"),1);",
                        "    }",
                        "  }",
                        "}"
                    ],
                    "#": 10,
                    "Type": "Top",
                    "Parent": -1,
                    "Pos.x": 180,
                    "Pos.y": 585
                },
                {
                    "Name": "",
                    "Code.Type": "Turn",
