            "DialogMessages": [
                {
                    "Name": "",
                    "Pos.x": 0,
                    "Pos.y": 545,
                    "Type": "TDialogMsg",
                    "Parent": -1,
                    "#": 73,
                    "Msg": "<0> перемещён с вашего корабля в хранилище. Забрать его вы сможете в любое удобное для вас время на любом Центре Рейнджеров.",
                    "DMsg.Num": "0",
                    "_orig_dtext": "DText(Format(CT(\"Script.Mod_ExpRC.1\"),\"<0>\",str0))"
                },
                {
                    "Name": "",
                    "Pos.x": 150,
                    "Pos.y": 545,
                    "Type": "TDialogMsg",
                    "Parent": -1,
                    "#": 74,
                    "Msg": "<0> уже доставлен на ваш корабль.",
                    "DMsg.Num": "1",
                    "_orig_dtext": "DText(Format(CT(\"Script.Mod_ExpRC.2\"),\"<0>\",str0))"
                },
                {
                    "Name": "",
                    "Pos.x": 300,
                    "Pos.y": 545,
                    "Type": "TDialogMsg",
                    "Parent": -1,
                    "#": 75,
                    "Msg": "За каждым рейнджером закреплено отдельное хранилище микромодулей. Это позволяет получить необходимый модуль в любом из наших центров, а ненужные вам модули мы распределяем по своему усмотрению, но лишь до того момента, когда они вам понадобятся.\r\nЖелаете получить или положить микромодули в хранилище?",
                    "DMsg.Num": "2",
                    "_orig_dtext": "DText(CT(\"Script.Mod_ExpRC.25\"))"
                },
                {
                    "Name": "",
                    "Pos.x": 450,
                    "Pos.y": 545,
                    "Type": "TDialogMsg",
                    "Parent": -1,
                    "#": 76,
                    "Msg": "Выберите микромодуль, имеющийся на вашем корабле.",
                    "DMsg.Num": "3",
                    "_orig_dtext": "DText(CT(\"Script.Mod_ExpRC.4\"))"
                },
                {
                    "Name": "",
                    "Pos.x": 600,
                    "Pos.y": 545,
                    "Type": "TDialogMsg",
                    "Parent": -1,
                    "#": 77,
                    "Msg": "Выберите микромодуль, имеющийся в хранилище.",
                    "DMsg.Num": "4",
                    "_orig_dtext": "DText(CT(\"Script.Mod_ExpRC.5\"))"
                },
                {
                    "Name": "",
                    "Pos.x": 750,
                    "Pos.y": 545,
                    "Type": "TDialogMsg",
                    "Parent": -1,
                    "#": 78,
                    "Msg": "Что бы вы хотели узнать?",
