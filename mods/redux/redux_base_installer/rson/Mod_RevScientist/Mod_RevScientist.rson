            "Operations": [
                {
                    "Name": "",
                    "Code.Type": "Global",
                    "Code": [
                        "if (!GCntRun(GScriptName)) {",
                        "  if (GRunFrom == 3) {",
                        "    if (CurTurn() >= 900) GRun();",
                        "  }",
                        "}"
                    ],
                    "#": 18,
                    "Type": "Top",
                    "Parent": -1,
                    "Pos.x": 0,
                    "Pos.y": 585
                },
                {
                    "Name": "",
                    "Code.Type": "Init",
                    "Code": [
                        "//vState == 0 - начальный стейт",
                        "//vState == 1 - научка взорвана, выводится новость, капсула ждет подбора",
                        "//vState == 2 - игрок подобрал капсулу",
                        "//vState == 3 - капсула привезена на ПБ",
                        "//vState == 4 - квест пройден, сброс фазера в космос",
                        "vLastSBName = Name(GroupToShip(SBGroup));",
                        "vNewSBName = CT(\"Script.Mod_RevScientist.36\");",
                        "AddPlanetNews(Format(CT(\"Script.Mod_RevScientist.42\"),\"<0>\",vLastSBName,\"<1>\",Name(Star),\"<2>\",vNewSBName,\"<3>\",GalaxyMoney(2)));",
                        "SetName(GroupToShip(SBGroup), vNewSBName);",
                        "vTimer = CurTurn() + 10;"
                    ],
                    "#": 19,
                    "Type": "Top",
                    "Parent": -1,
                    "Pos.x": 60,
                    "Pos.y": 585
                },
                {
                    "Name": "",
                    "Code.Type": "Turn",
                    "Code": [
                        "if (ShipInStar(Player(), Star)) {",
                        "  if (vState == 1) {",
                        "      if(iCapsuleP) {",
                        "        if(!ItemIn(iCapsuleP, Player())) {",
                        "            if(Dist(iCapsuleP, Player()) <= 1000) {",
                        "                Ether(1, '8E4B1F72-8A0A-441E-9C5F-49AF80B98E36', Format(CT(\"Script.Mod_RevScientist.44\"),\"<0>\",vNewSBName));",
                        "            }",
                        "        }",
                        "        else vState = 2;",
                        "    }",
                        "    else vState = 2;",
                        "  }",
                        "}",
                        "if (vState == 1 || vState == 2) {",
                        "    if(!ItemExist(iCapsuleP)) AllShipOut();",
                        "}",
                        "if(vState == 3 && CurTurn() >= vTimer) {",
                        "    if(CountIn(PBGroup)) {",
                        "        if(ShipStar(Player()) == ShipStar(GroupToShip(PBGroup))) {",
                        "            if(Dist(Player(),GroupToShip(PBGroup))) {",
                        "                NewsAdd(CT(\"Script.Mod_RevScientist.49\"));",
                        "                Sound('Sound.NewMsg');",
                        "                vState = 4;",
                        "            }",
                        "            else {",
                        "                NewsAdd(CT(\"Script.Mod_RevScientist.48\")+Format('FormInfo.br')+CT(\"Script.Mod_RevScientist.47\")+' '+Name(GroupToShip(PBGroup)));",
                        "                Sound('Sound.NewMsg');",
                        "            }",
                        "        }",
                        "    }",
                        "}"
                    ],
                    "#": 20,
                    "Type": "Top",
                    "Parent": -1,
                    "Pos.x": 120,
                    "Pos.y": 585
                },
                {
                    "Name": "",
                    "Code.Type": "DialogBegin",
                    "Code": [
                        "if(vState == 2 && ItemIn(iCapsuleP, Player())) {",
                        "  if(CurTurn() >= vTimer) {",
                        "      if(RelationToShip(GroupToShip(PBGroup),Player()) > 29) {",
                        "          if(GetShipRuins(Player())) {",
                        "              if(GetShipRuins(Player()) == GroupToShip(PBGroup)) {",
                        "                  AddDialogOverride('dDoctor',999);",
                        "              }",
                        "          }",
                        "      }",
                        "  }",
                        "}"
                    ],
                    "#": 21,
                    "Type": "Top",
                    "Parent": -1,
                    "Pos.x": 180,
                    "Pos.y": 585
                },
                {
                    "Name": "",
                    "Code.Type": "Turn",
                    "Code": [
                        "if(!vState) {",
                        "  if(CurTurn() >= vTimer) {",
                        "    if(Dist(Player(), PlaceSB) > 200) {",
                        "      DropScriptItem(CurShip, iCapsuleP);",
                        "      //for(i=0;ShopItems(CurShip)>i;i=i+1){",
                        "      //    if(Rnd(1,5) != 5) {",
                        "      //        tdwd = ShopItems(CurShip,i);",
                        "      //        GetItemFromShop(CurShip,tdwd);",
                        "      //        DropItem(CurShip,tdwd);",
                        "      //    }",
                        "      //}",
                        "      for(i=0;StorageItems()>i;i=i+1){",
                        "          if(StorageItemLocation(StorageItems(i))!=CurShip) continue;",
                        "          if(Rnd(1,20) == 20) {",
                        "              tdwd = StorageItems(i);",
                        "              GetItemFromStorage(i);",
                        "              DropItem(CurShip,tdwd);",
                        "          }",
                        "      }",
                        "      AddPlanetNews(Format(CT(\"Script.Mod_RevScientist.45\"),\"<0>\",Name(Star),\"<1>\",vNewSBName));",
                        "      vState = 1;",
                        "      ShipDestroy(CurShip);",
                        "    }",
                        "  }",
                        "}"
                    ],
                    "#": 37,
                    "Type": "Top",
                    "Parent": -1,
                    "Pos.x": 80
                },
                {
                    "Name": "",
                    "Code.Type": "Turn",
                    "Code": [
                        "if(!ItemIn(iCapsuleP, GroupToShip(SBGroup))) {",
                        "  ChangeState(2);",
                        "  exit;",
                        "}"
                    ],
                    "#": 38,
                    "Type": "Top",
                    "Parent": -1,
                    "Pos.x": 160
                },
                {
                    "Name": "",
                    "Code.Type": "Turn",
                    "Code": [
                        "if (!ItemExist(iCapsuleP)) ShipOut(CurShip);",
                        "else if (ItemIn(iCapsuleP, Player())) ShipOut(CurShip);",
                        "else if (ItemIn(iCapsuleP, War)) AllShipOut();"
                    ],
                    "#": 39,
                    "Type": "Top",
                    "Parent": -1,
                    "Pos.x": 240
                },
                {
                    "Name": "",
                    "Code.Type": "Turn",
                    "Code": [
                        "if(vState == 4) {",
                        "    if(PirateWin() != 3) i = CreateEquipment(t_Weapon6, 10, GalaxyTechLevel(), PirateClan);",
                        "    else i = CreateEquipment(t_Weapon6, 10, GalaxyTechLevel(), People);",
                        "    ModuleToEquipment(FindBonusByNameInCfg('120'), i);",
                        "    SetName(i, '<color=255,167,84>' + CT(\"Script.Mod_RevScientist.41\") + '</color>');",
                        "    AddItemToShip(GroupToShip(PBGroup), i);",
                        "    LinkItemToScript(i, iFazer);",
                        "    DropScriptItem(CurShip, iFazer);",
                        "    ReleaseItemFromScript(iFazer);",
                        "    AllShipOut();",
                        "}"
                    ],
                    "#": 40,
                    "Type": "Top",
                    "Parent": -1,
                    "Pos.x": 320
                },
                {
                    "Name": "",
                    "Code.Type": "Turn",
                    "Code": [
                        "if(vState == 2) {",
                        "  if(ItemIn(iCapsuleP, Player())) {",
                        "    SkipGreeting();",
                        "    DChange(0);",
                        "    exit;",
                        "  }",
                        "}",
                        "if(vState == 3) {",
                        "  if(CurTurn() >= vTimer) {",
                        "    DChange(4);",
                        "    exit;",
                        "  }",
                        "}"
                    ],
