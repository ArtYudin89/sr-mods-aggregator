                },
                {
                    "Name": "",
                    "Code.Type": "Turn",
                    "Code": [
                        "cur_star = GAnswerData;",
                        "tstr1 = '</color>' + Format(CT('Script.Mod_ExpExplorers.OrderCollectDiscoveredItems.' + path + '.ChoosePlanetDistant'), '<Star'+'>', Name(cur_star));",
                        "DChange(4);",
                        "exit;"
                    ],
                    "#": 66,
                    "Type": "Top",
                    "Parent": -1,
                    "Pos.x": 1210,
                    "Pos.y": 425
                },
                {
                    "Name": "",
                    "Code.Type": "Turn",
                    "Code": [
                        "if(ObjectType(GAnswerData) == 3) tstr1 = 'p' + Id(GAnswerData);",
                        "else tstr1 = 's' + Id(GAnswerData);",
                        "",
                        "ShipAddCustomShipInfo(cur_ship, 'OrderCollectDiscoveredItems', 'NoShow', Id(cur_star), int(cur_planet), 0, tstr1, '0,0,0,0,0,0,0,0', 'Collecting');",
                        "OrderLock(cur_ship, 1);",
                        "//Приказ собирать лут с планет в другой системе",
                        "if(cur_star != ShipStar(cur_ship)) OrderJump(cur_ship, cur_star);",
                        "//Приказ собирать лут с конкретной планеты, либо со всех доступных планет по очереди",
                        "else OrderLanding(cur_ship, StarPlanets(cur_star, abs(cur_planet) - 1));",
                        "",
                        "if(cur_star == ShipStar(cur_ship)) tstr1 = '</color>' + CT('Script.Mod_ExpExplorers.OrderCollectDiscoveredItems.' + path + '.OrderConfirmed');",
                        "else tstr1 = '</color>' + Format(CT('Script.Mod_ExpExplorers.OrderCollectDiscoveredItems.' + path + '.OrderConfirmedDistant'), '<Star'+'>', Name(cur_star));",
                        "tstr2 = '</color>' + CT('Script.Mod_ExpExplorers.OrderCollectDiscoveredItems.' + path + '.PlayerDone');",
                        "DChange(5);",
                        "exit;"
