                        "    else",
                        "    {",
                        "        tstr1='</color>'+CT('Script.Mod_ExpExplorers.PirateDisagreeLowHP');",
                        "        tstr2='</color>'+CT('Script.Mod_ExpExplorers.PlayerPirateDisagree');",
                        "    }",
