                {
                    "Name": "",
                    "Code.Type": "Turn",
                    "Code": [
                        "if(ShipTypeN(cur_ship) == t_Tranclucator) cur_star = tdwd1;",
                        "cur_star = tarr[0]; //На случай, если доступная для выбора система всего одна",
                        "",
                        "if(ArrayDim(tarr) > 1 && ShipTypeN(cur_ship) != t_Tranclucator) tstr1 = '</color>' + CT('Script.Mod_ExpExplorers.OrderCollectDiscoveredItems.' + path + '.ChooseStar');",
                        "else tstr1 = '</color>' + CT('Script.Mod_ExpExplorers.OrderCollectDiscoveredItems.' + path + '.ChoosePlanet');",
                        "if(ArrayDim(tarr) > 1) {",
                        "  DChange(3);",
                        "  exit;",
                        "}",
                        "if(ArrayDim(tarr) <= 1) {",
                        "  DChange(4);",
                        "  exit;",
                        "}"
