                    "Code": [
                        "ArrayClear(tarr);",
                        "//Проверка на кастомные ЧД (оригинальные будут всегда возвращать '')",
                        "check = 1;",
                        "if(HoleMap(cur_hole) == '')",
                        "{",
                        "    //Проверка на ЧД Келлера (если её вход и выход находятся в одной системе)",
                        "    if(Keller())",
                        "    {",
                        "        if(HoleStar1(cur_hole) != HoleStar2(cur_hole)) check = 1;",
                        "        else check = 0;",
