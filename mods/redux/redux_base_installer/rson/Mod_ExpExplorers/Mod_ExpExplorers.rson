                {
                    "Name": "",
                    "Code.Type": "Turn",
                    "Code": [
                        "tstr1 = CT('Script.Mod_ExpExplorers.OrderCollectDiscoveredItems.' + path + '.PlayerSetStar');",
                        "for(int i = 0; i < ArrayDim(tarr); i = i + 1)",
                        "{",
                        "    InjectAnswer('PartnerToUninhabitedTargetPlanet', Format(tstr1, '<Star'+'>', Name(tarr[i])), tarr[i]);",
