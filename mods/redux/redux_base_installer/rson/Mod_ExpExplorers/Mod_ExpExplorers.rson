                        "        if(ArrayDim(tarr) > 2)",
                        "        {",
                        "            tstr3='</color>'+CT('Talk.Tranclucator.OrderForAll');",
                        "            tstr2='</color>'+CT('Talk.Exit');",
                        "        }",
                        "        else tstr2='</color>'+CT('Talk.Exit');",
