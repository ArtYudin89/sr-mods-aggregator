                },
                {
                    "Name": "",
                    "Code.Type": "Turn",
                    "Code": [
                        "tstr1 = CT('Script.Mod_ExpExplorers.OrderCollectDiscoveredItems.' + path + '.PlayerSetPlanet');",
                        "cnt = 0;",
                        "j = 0;",
                        "for(int i = 0; i < StarPlanets(cur_star); i = i + 1)",
                        "{",
                        "    dword planet = StarPlanets(cur_star, i);",
                        "    if(PlanetOwner(planet) != None) continue;",
                        "    if(PlanetItems(planet) <= PlanetItemsHiddency(planet, -1, '', -1))",
                        "    {",
                        "        check = 0;",
                        "        for(int l = 0; l < GetPlanetOrbitProbe(planet, -1, 0); l = l + 1)",
                        "        {",
                        "            if(GetPlanetOrbitProbe(planet, l, 0))",
                        "            {",
                        "                check = 1;",
                        "                break;",
                        "            }",
                        "        }",
                        "        if(!check) continue;",
                        "    }",
                        "",
                        "    InjectAnswer('PartnerToUninhabitedTargetDropPoint', Format(tstr1, '<Planet'+'>', Name(planet)), i + 1);",
                        "    if(!j) j = i + 1; //Запоминаем первую доступную для сбора планету в списке для отдачи приказа сбора вещей со всех планет в системе по очереди",
                        "    cnt = cnt + 1;",
                        "}",
                        "",
                        "if(cnt > 1) InjectAnswer('PartnerToUninhabitedTargetDropPoint', CT('Script.Mod_ExpExplorers.OrderCollectDiscoveredItems.' + path + '.PlayerSetAllPlanets'), -j);",
                        "DAnswer('restart~' + CT('Script.Mod_ExpExplorers.OrderCollectDiscoveredItems.' + path + '.PlayerRefused'));"
                    ],
                    "#": 74,
                    "Type": "Top",
                    "Parent": -1,
                    "Pos.x": 580,
                    "Pos.y": 520
                },
                {
                    "Name": "",
                    "Code.Type": "Turn",
                    "Code": [
                        "DAdd(6);"
                    ],
                    "#": 75,
                    "Type": "Top",
                    "Parent": -1,
                    "Pos.x": 730,
                    "Pos.y": 520
                },
                {
                    "Name": "",
                    "Code.Type": "Turn",
                    "Code": [
                        "tstr1 = CT('Script.Mod_ExpExplorers.OrderCollectDiscoveredItems.' + path + '.PlayerSetDropPointPlanet');",
                        "for(int i = 0; i < StarPlanets(cur_star); i = i + 1)",
                        "{",
                        "    dword planet = StarPlanets(cur_star, i);",
                        "    if(PlanetOwner(planet) == None) continue;",
                        "    tstr2 = Format(tstr1, '<Planet'+'>', Name(planet));",
                        "",
                        "    if(ShipTypeN(cur_ship) == t_Tranclucator)",
                        "    {",
                        "        if(RelationToRanger(planet, Player()) < 10)",
                        "        {",
                        "            tstr2 = DeleteTags(tstr2);",
                        "            AddDialogBlock(tstr2, 1);",
                        "        }",
                        "    }",
                        "    else if(RelationToShip(planet, cur_ship) < 10)",
                        "    {",
                        "        tstr2 = DeleteTags(tstr2);",
                        "        AddDialogBlock(tstr2, 1);",
                        "    }",
                        "",
                        "    InjectAnswer('PartnerToUninhabitedOrderSet', tstr2, planet);",
                        "}",
                        "",
                        "tstr1 = CT('Script.Mod_ExpExplorers.OrderCollectDiscoveredItems.' + path + '.PlayerSetDropPointStation');",
                        "for(i = 0; i < StarRuins(cur_star); i = i + 1)",
                        "{",
                        "    dword station = StarRuins(cur_star, i);",
                        "    tstr2 = Format(ShipType(station), '_licensed', '', '');",
                        "    if(tstr2 == 'Inhibitor' || tstr2 == 'BM' || tstr2 == 'SSB') continue;",
                        "    if(tstr2 == 'Handler')",
                        "    {",
                        "        if(ShipOwner(Player()) != PirateClan && GetShipPirateRank(Player()) < 7) continue;",
                        "    }",
                        "    if(tstr2 == 'CB' && (ShipOwner(Player()) != PirateClan || ShipOwner(cur_ship) != PirateClan)) continue;",
                        "    tstr2 = Format(tstr1, '<Station'+'>', Name(station));",
                        "",
                        "    if(ShipTypeN(cur_ship) == t_Tranclucator)",
                        "    {",
                        "        if(RelationToRanger(station, Player()) < 10)",
                        "        {",
                        "            tstr2 = DeleteTags(tstr2);",
                        "            AddDialogBlock(tstr2, 1);",
                        "        }",
                        "    }",
                        "    else if(RelationToShip(station, cur_ship) < 10)",
                        "    {",
                        "        tstr2 = DeleteTags(tstr2);",
                        "        AddDialogBlock(tstr2, 1);",
                        "    }",
                        "",
                        "    InjectAnswer('PartnerToUninhabitedOrderSet', tstr2, station);",
                        "}",
                        "",
                        "DAnswer('restart~' + CT('Script.Mod_ExpExplorers.OrderCollectDiscoveredItems.' + path + '.PlayerRefused'));"
                    ],
                    "#": 76,
                    "Type": "Top",
                    "Parent": -1,
                    "Pos.x": 880,
                    "Pos.y": 520
                },
                {
                    "Name": "",
                    "Code.Type": "Turn",
                    "Code": [
                        "DAdd(6);"
                    ],
                    "#": 77,
                    "Type": "Top",
                    "Parent": -1,
                    "Pos.x": 1030,
                    "Pos.y": 520
                },
                {
                    "Name": "",
                    "Code.Type": "Turn",
                    "Code": [
                        "//Игрок решил раздать общий приказ на прыжок в ЧД всем доступным партнёрам",
                        "for(i=1; i<ArrayDim(tarr); i=i+1)",
                        "{",
                        "    tdwd1=tarr[i];",
                        "    //Пропускаем корабль, с которым игрок вёл диалог, и который ранее уже получил свой приказ",
                        "    if(tdwd1 == cur_ship)continue;",
                        "    //Пропускаем корабли со слишком большими повреждениями корпуса",
                        "    if(HullDamage(tdwd1) > 85)continue;",
                        "",
                        "    //Проверяем, не выставлен ли у данного корабля приказ на указанную ЧД",
                        "    tint1=ShipFindCustomShipInfoByType(tdwd1,'OrderJumpHole_ForCompanion');",
                        "    if(tint1 > -1)",
                        "    {",
                        "        tint1=ShipCustomShipInfoData(tdwd1,tint1,2);",
                        "        if(tint1 == Id(cur_hole))continue;",
                        "    }",
                        "",
                        "    //Направляем корабль в указанную ЧД",
                        "    if(HoleStar1(cur_hole) == cur_star)",
                        "    {",
                        "        OrderMove(tdwd1,HoleX1(cur_hole),HoleY1(cur_hole));",
                        "        //Если у партнёра не было установлено приказа на полёт в ЧД",
                        "        if(tint1 == -1)ShipAddCustomShipInfo(tdwd1,'OrderJumpHole_ForCompanion','NoShow',1,Id(cur_hole),0,HoleX1(cur_hole),HoleY1(cur_hole));",
                        "        //Если приказ на полёт в другую ЧД уже был установлен",
                        "        else",
                        "        {",
                        "            ShipCustomShipInfoData(tdwd1,tint1,1,1);",
                        "            ShipCustomShipInfoData(tdwd1,tint1,2,Id(cur_hole));",
                        "            ShipCustomShipInfoTextData(tdwd1,tint1,1,HoleX1(cur_hole));",
                        "            ShipCustomShipInfoTextData(tdwd1,tint1,2,HoleY1(cur_hole));",
                        "        }",
                        "    }",
                        "    else",
                        "    {",
                        "        OrderMove(tdwd1,HoleX2(cur_hole),HoleY2(cur_hole));",
                        "        //Если у партнёра не было установлено приказа на полёт в ЧД",
                        "        if(tint1 == -1)ShipAddCustomShipInfo(tdwd1,'OrderJumpHole_ForCompanion','NoShow',1,Id(cur_hole),0,HoleX2(cur_hole),HoleY2(cur_hole));",
                        "        //Если приказ на полёт в другую ЧД уже был установлен",
                        "        else",
                        "        {",
                        "            ShipCustomShipInfoData(tdwd1,tint1,1,1);",
                        "            ShipCustomShipInfoData(tdwd1,tint1,2,Id(cur_hole));",
                        "            ShipCustomShipInfoTextData(tdwd1,tint1,1,HoleX2(cur_hole));",
                        "            ShipCustomShipInfoTextData(tdwd1,tint1,2,HoleY2(cur_hole));",
                        "        }",
                        "    }",
                        "}"
                    ],
