                        "    //Если транклюкаторов у игрока более одного, проверяем, сколько из них находятся в текущей системе",
                        "    if(PlayerTranclucators() > 1)",
                        "    {",
                        "        for(i=0; i<PlayerTranclucators(); i=i+1)",
                        "        {",
