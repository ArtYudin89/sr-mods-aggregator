            "Items": [],
            "Operations": [
                {
                    "Name": "",
                    "Code.Type": "Global",
                    "Code": [
                        "GRun();"
                    ],
                    "#": 15,
                    "Type": "Top",
                    "Parent": -1,
                    "Pos.x": 0,
                    "Pos.y": 585
                },
                {
                    "Name": "",
                    "Code.Type": "Init",
                    "Code": [
                        "if(Blazer()) {",
                        "    if(ShipFindCustomShipInfoByType(Blazer(),'Absorber')==-1) ShipAddCustomShipInfo(Blazer(),'Absorber');",
                        "}",
                        "if(Terron()) {",
                        "    if(ShipFindCustomShipInfoByType(Terron(),'Absorber')==-1) ShipAddCustomShipInfo(Terron(),'Absorber');",
                        "}",
                        "if(Keller()) {",
                        "    if(ShipFindCustomShipInfoByType(Keller(),'Absorber')==-1) ShipAddCustomShipInfo(Keller(),'Absorber');",
                        "}"
                    ],
                    "#": 16,
                    "Type": "Top",
                    "Parent": -1,
                    "Pos.x": 60,
                    "Pos.y": 585
                },
                {
                    "Name": "",
                    "Code.Type": "Turn",
                    "Code": [
                        "GTL=GalaxyTechLevel();",
                        "//Раздача абсорберов и генераторов помех",
                        "//Перебираем все новые корабли в галактике по заданным фильтрам",
                        "if(GalaxyShipId()>lastShipId) {",
                        "    tdwd=BuildListOfNewShips(tempArr,lastShipId,1+2+4+8+16+256+4096+8192,1+2+4+8+16+128,1,'','Militiaman1,,Militiaman2,Militiaman3,Rebel,RangerPirate,RangerExplorer,RangerPirateExplorer,Smuggler,EliteWarrior,Merc,Freelancer,RedLeader,AtlantLeader,FeiLeader,Khan,Headhunter,Marauder,PirateCorvette,PirateFrigate,PirateGalleon,Dreadnought,Klissan5,Klissan4,Klissan3,Klissan2,Klissan1,Machpella');",
                        "    if(tdwd) {    //Если найден хотя бы один корабль",
                        "        for(i=0;i<ArrayDim(tempArr);i=i+1) {",
                        "            tdwd=0;    //Обнуляем флаг",
                        "            chance=0;    //Обнуляем шанс выдачи",
                        "            tShip=tempArr[i];    //Выбираем корабль",
                        "            //if(ShipInScript(tShip,0)) continue; //пропуск скриптовых кораблей?",
                        "            if(IsPlayer(tShip)) continue;",
                        "            if(ShipOwner(tShip)==Kling && ShipSubType(tShip)==7) continue;    //Пропуск клигов",
                        "            if(ShipOwner(tShip)==Kling && !ShipSubType(tShip)) continue;    //Пропуск боссов",
                        "            if(~ShipFindCustomShipInfoByType(tShip, 'ShuNukes_BlockNukes')) continue;",
                        "            tStr=ShipType(tShip);",
                        "            //Абсорбер",
                        "            //Рейнджеры и производные от них",
                        "            if(tStr=='Ranger' || tStr=='RangerPirate' || tStr=='Freelancer' || tStr=='Merc' || tStr=='PlayerMerc' || tStr=='RangerExplorer' || tStr=='RangerPirateExplorer') chance=8+GTL*2;",
                        "            else if(tStr=='Smuggler') chance=4+GTL;",
                        "            else if(tStr=='Diplomat') chance=4+GTL;",
                        "            else if(tStr=='Transport' || tStr=='Liner') chance=GTL;",
                        "            else if((tStr=='Pirate' && PirateType(tShip)) || tStr=='Rebel' || tStr=='Thug' || tStr=='PirateCorvette') chance=GTL+GetShipPirateRank(tShip)*5;",
                        "            else if(tStr=='PirateFrigate') chance=GTL*4;",
                        "            else if(tStr=='Pirate' && !PirateType(tShip)) chance=GTL*2;",
                        "            else if((tStr=='Warrior' && ShipSubType(tShip)) || tStr=='Dreadnought' || tStr=='PirateGalleon') chance=GTL*10;    //Крупные корабли",
                        "            else if((tStr=='Warrior' && !ShipSubType(tShip)) || tStr=='EliteWarrior' || tStr=='Militiaman1' || tStr=='Militiaman2' || tStr=='Militiaman3') chance=GTL+ShipRank(tShip)*5;",
                        "            else if(tStr=='Khan' || tStr=='Marauder' || tStr=='Machpella' || tStr=='Handler'/* || tStr=='Klissan1' || tStr=='Klissan2' || tStr=='Klissan3' || tStr=='Klissan4' || tStr=='Klissan5'*/ || tStr=='KB' || tStr=='AtlantLeader' || tStr=='RedLeader' || tStr=='FeiLeader' || tStr=='MB' || tStr=='Inhibitor') chance=100;",
                        "            else if(ShipOwner(tShip)==5 && ShipSubType(tShip)==6) chance=GTL*10;",
                        "            else if(ShipOwner(tShip)==5 && ShipSubType(tShip)!=6) chance=11;",
                        "            else if(ObjectType(tShip)==4) chance=100;",
                        "            else chance=0;",
                        "            if(Rnd(1,100)<=chance) ShipAddCustomShipInfo(tShip,'Absorber');",
                        "            //Генератор помех",
                        "            if(tStr=='Ranger' || tStr=='RangerPirate' || tStr=='Freelancer' || tStr=='Merc' || tStr=='PlayerMerc' || tStr=='RangerExplorer' || tStr=='RangerPirateExplorer') chance=4+GTL*2;",
                        "            else if(tStr=='Smuggler') chance=8+GTL;",
                        "            else if(tStr=='Transport' || tStr=='Liner' || tStr=='Diplomat') chance=4+GTL*80/100;",
                        "            else if(tStr=='Pirate' || tStr=='Rebel' || tStr=='Thug' || tStr=='PirateCorvette' || tStr=='PirateFrigate') chance=GetShipPirateRank(tShip)*3;",
                        "            else if((tStr=='Warrior' && ShipSubType(tShip)) || tStr=='Dreadnought' || tStr=='PirateGalleon') chance=GTL*9;",
                        "            else if((tStr=='Warrior' && !ShipSubType(tShip)) || tStr=='EliteWarrior' || tStr=='Militiaman1' || tStr=='Militiaman2' || tStr=='Militiaman3') chance=ShipRank(tShip)*4;",
                        "            else if(tStr=='Khan' || tStr=='Marauder' || tStr=='Handler' || tStr=='AtlantLeader' || tStr=='RedLeader' || tStr=='FeiLeader' || tStr=='MB' || tStr=='Inhibitor' || tStr=='Salvager') chance=100;",
                        "            else if(ShipOwner(tShip)==5 && ShipSubType(tShip)==6) chance=40+GTL*5;",
                        "            else if(ShipOwner(tShip)==5 && ShipSubType(tShip)) chance=6+GTL*90/100;",
                        "            else if(ObjectType(tShip)==4) chance=100;",
                        "            else chance=0;",
                        "            if(!ShipProtectability(tShip)) chance=0;",
                        "            if(Rnd(1,100)<=chance) ShipAddCustomShipInfo(tShip,'ECM');",
                        "        }",
                        "    }",
                        "    lastShipId=GalaxyShipId();    //Обновляем Id последнего рожденного корабля",
                        "}"
                    ],
                    "#": 17,
                    "Type": "Top",
                    "Parent": -1,
                    "Pos.x": 120,
                    "Pos.y": 585
                },
                {
                    "Name": "",
                    "Code.Type": "DialogBegin",
                    "Code": [
                        "if(GetShipRuins(Player())) {",
                        "    if(!PlayerBridge()) {",
                        "        tdwd = GetShipRuins(Player());",
                        "        if(ShipType(tdwd) == 'TC') {",
                        "            if(GalaxyTechLevel() >= 5) {",
                        "                if(ShipFindCustomShipInfoByType(Player(),'ECM') == -1) {",
                        "                    AddDialogInject('BuyECM', CT(\"Script.Mod_ShuDefence.5\"), CT(\"Script.Mod_ShuDefence.4\"), 1);",
                        "                }",
                        "            }",
                        "        }",
                        "        else if (ShipType(tdwd) == 'WB') {",
                        "          if (!ShipOnSidePirateClan(Player())) {",
                        "            if(ShipFindCustomShipInfoByType(Player(),'Absorber') == -1) {",
                        "              if (ShipRank(Player()) >= 2) {",
                        "                AddDialogInject('BuyAbsorber', CT(\"Script.Mod_ShuDefence.3\"), CT(\"Script.Mod_ShuDefence.2\"), 1);",
                        "              }",
                        "            }",
                        "          }",
                        "        }",
                        "        else if(ShipType(tdwd) == 'CB') {",
                        "          if (ShipOnSidePirateClan(Player())) {",
                        "            if(ShipFindCustomShipInfoByType(Player(),'Absorber') == -1) {",
                        "              if (GetShipPirateRank(Player()) >= 2) {",
                        "                AddDialogInject('BuyAbsorber', CT(\"Script.Mod_ShuDefence.3\"), CT(\"Script.Mod_ShuDefence.2\"), 1);",
                        "              }",
                        "            }",
                        "          }",
                        "        }",
                        "    }",
                        "}"
                    ],
                    "#": 18,
                    "Type": "Top",
                    "Parent": -1,
                    "Pos.x": 180,
                    "Pos.y": 585
                },
                {
                    "Name": "",
                    "Code.Type": "Turn",
                    "Code": [
                        "sum=GalaxyMoney(4)*7*GalaxyDiffLevels(7)/100+GalaxyMoney(2);",
                        "DChange(1);",
                        "exit;"
                    ],
