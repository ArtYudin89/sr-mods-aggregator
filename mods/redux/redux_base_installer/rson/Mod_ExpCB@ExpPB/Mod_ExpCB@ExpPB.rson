                        "        InjectAnswer('SellMMDone', Format(CT('FormRuins.CB.GiveNod.PlayerOk'), '<Name'+'>', name, '<Count'+'>', '<color=0,50,200>' + tarr1['Cost', i] + '</color>', ''), i);",
