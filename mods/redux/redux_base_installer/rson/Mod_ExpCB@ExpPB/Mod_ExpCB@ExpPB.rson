                        "        temp_dword = StarShips(GalaxyStar(i),j);",
                        "        if(!ShipOnSidePirateClan(temp_dword)) continue;",
                        "        if(ShipType(temp_dword) != 'FemRanger' && ShipType(temp_dword) != 'Ranger' && ShipType(temp_dword) != 'RangerExplorer') continue;",
