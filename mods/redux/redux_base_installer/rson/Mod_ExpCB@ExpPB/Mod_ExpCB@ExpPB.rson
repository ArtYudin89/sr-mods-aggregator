                {
                    "Name": "",
                    "Code.Type": "Turn",
                    "Code": [
                        "ShipMoney(Player(),ShipMoney(Player())-GalaxyMoney(3));",
                        "Sound('Sound.Buy');",
                        "",
                        "ChangeGlobalRelationsPlanets(GAnswerData,0,0,0,159);",
                        "ChangeGlobalRelationsShips(GAnswerData,0,0,0,1+2+4+8+16+32,159);",
                        "DChange(13);",
