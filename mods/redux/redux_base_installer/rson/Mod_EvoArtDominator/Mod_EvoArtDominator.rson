                },
                {
                    "Name": "",
                    "Code.Type": "Turn",
                    "Code": [
                        "tstr = '</color>' + CT('FormRuins.SB.Scn2.PlayerReturn'); //Вернуться в отдел сдачи модулей;",
                        "DAdd(12);",
