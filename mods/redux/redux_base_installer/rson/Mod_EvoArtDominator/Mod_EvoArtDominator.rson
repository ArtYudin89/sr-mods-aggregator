                        "    input = '<clrEnd>' + CT('FormRuins.SB.Scn2.SBAnswer'); //стандартное приветствие",
                        "    input = input + CT(\"Script.Mod_EvoArtDominator.2\");",
                        "    input = input + CT('FormRuins.SB.Scn2.SBSectionInfo'); //Перечень исследуемых модулей доминаторов:",
