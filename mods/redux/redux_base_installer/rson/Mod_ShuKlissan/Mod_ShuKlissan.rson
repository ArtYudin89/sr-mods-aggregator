                {
                    "Name": "",
                    "Code.Type": "Turn",
                    "Code": [
                        "if(KlisanInvestment['MainResearch.ResearchLeft'] == 0 && KlissanInvasion['MainResearch.StagesCompleted'] < 4) InjectAnswer('InvestigEnd',CT('Script.Mod_ShuKlissan.KlissanInvestSB.SBAskForEndMain'),KlissanInvasion['MainResearch.StagesCompleted']);",
                        "else if(KlissanInvasion['MainResearch.StagesCompleted'] < 4) InjectAnswer('SellRemains',CT('Script.Mod_ShuKlissan.KlissanInvestSB.SBSellMain'),1);",
                        "",
                        "if(!KlissanInvasion['MentalCommunicator.WasReceived'] && KlisanInvestment['MentalCommunicator.ResearchLeft'] <= 0) InjectAnswer('InvestigEnd',CT('Script.Mod_ShuKlissan.KlissanInvestSB.SBAskForEndMental'),2);",
                        "else if(KlisanInvestment['MentalCommunicator.ResearchLeft'] > 0) InjectAnswer('SellRemains',CT('Script.Mod_ShuKlissan.KlissanInvestSB.SBSellMental'),2);",
                        "",
                        "if(!KlissanInvasion['ZTransmitter.WasReceived'] && KlisanInvestment['ZTransmitter.ResearchLeft'] <= 0) InjectAnswer('InvestigEnd',CT('Script.Mod_ShuKlissan.KlissanInvestSB.SBSectionEndedTransmitter'),3);",
                        "else if(KlisanInvestment['ZTransmitter.ResearchLeft'] > 0) InjectAnswer('SellRemains',CT('Script.Mod_ShuKlissan.KlissanInvestSB.SBSellTransmitter'),3);",
                        "DAdd(85);"
                    ],
                    "#": 511,
                    "Type": "Top",
                    "Parent": -1,
                    "Pos.x": 280,
                    "Pos.y": 795
                },
