                {
                    "Name": "",
                    "Code.Type": "Turn",
                    "Code": [
                        "//Если в данный момент активно задание из пиратской ветки на прибытие в ближайший ЦР, выполняем его",
                        "if(EtherState('BABB37FE-1007-4A51-A103-DB9EBEAA4C10') == 3)",
