                        "  variable1=-1;",
                        "  CurMed=CurMed+1;",
                        "  cost=0.81*GalaxyMoney(2,ShipOwner(GetShipRuins(Player())));",
                        "  item=CreateQuestItem(drugs[usl]);",
                        "  ItemCost(item,cost);",
                        "  ItemSize(item,1);",
                        "  AddItemToShip(Player(),item);",
                        "  ShipMoney(Player(),ShipMoney(Player())-cost);",
