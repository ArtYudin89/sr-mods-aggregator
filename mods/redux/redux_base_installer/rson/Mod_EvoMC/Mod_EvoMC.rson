                {
                    "Name": "",
                    "Code.Type": "Turn",
                    "Code": [
                        "if(PlayerMedPolicy() && MaxMed == CurMed) {",
                        "  DChange(2);",
                        "  exit;",
                        "}",
                        "if(PlayerMedPolicy() > 0 && (MaxMed - CurMed) > 0) {",
                        "  kov = substr(CT('UselessItems.Usl_Urine.Name'), 18, 1);",
                        "  input = '';//Очищаем строковую переменную",
                        "  if(urine == 0)input=input+Format('<br>')+'<clrEnd>---'+Format('<br>')+Format(CT('UselessItems.Usl_Urine.Name'),kov,'<clr>')+'<clrEnd><clrEnd>'+Format('<br>')+CT('UselessItems.Usl_Urine.Text');//Настойка урины",
                        "  if(variable1 > 0)input=input+Format('<br>')+'<clrEnd>---'+Format('<br>');//Разделитель перед списком болезней",
                        "  if(variable1 == 1)input=input+Format(CT('UselessItems.Usl_Drug01.Name'),kov,'<clr>')+'<clrEnd><clrEnd>'+Format('<br>')+CT('UselessItems.Usl_Drug01.Text');//Чекумаш",
                        "  if(variable1 == 2)input=input+Format(CT('UselessItems.Usl_Drug02.Name'),kov,'<clr>')+'<clrEnd><clrEnd>'+Format('<br>')+CT('UselessItems.Usl_Drug02.Text');//Святой фанатизм",
                        "  if(variable1 == 3)input=input+Format(CT('UselessItems.Usl_Drug03.Name'),kov,'<clr>')+'<clrEnd><clrEnd>'+Format('<br>')+CT('UselessItems.Usl_Drug03.Text');//Загадочая луатанация",
                        "  if(variable1 == 4)input=input+Format(CT('UselessItems.Usl_Drug04.Name'),kov,'<clr>')+'<clrEnd><clrEnd>'+Format('<br>')+CT('UselessItems.Usl_Drug04.Text');//Великий малосус",
                        "  if(variable1 == 5)input=input+Format(CT('UselessItems.Usl_Drug05.Name'),kov,'<clr>')+'<clrEnd><clrEnd>'+Format('<br>')+CT('UselessItems.Usl_Drug05.Text');//Новый молизон",
                        "  if(variable2 > 0)input=input+Format('<br>')+'<clrEnd>---'+Format('<br>');//Разделитель перед списком стимуляторов №1",
                        "  if(variable2 == 1)input=input+Format(CT('UselessItems.Usl_Drug06.Name'),kov,'<clr>')+'<clrEnd><clrEnd>'+Format('<br>')+CT('UselessItems.Usl_Drug06.Text');//Малокская сижа",
                        "  if(variable2 == 2)input=input+Format(CT('UselessItems.Usl_Drug07.Name'),kov,'<clr>')+'<clrEnd><clrEnd>'+Format('<br>')+CT('UselessItems.Usl_Drug07.Text');//Одноглазый Хамас",
                        "  if(variable2 == 3)input=input+Format(CT('UselessItems.Usl_Drug08.Name'),kov,'<clr>')+'<clrEnd><clrEnd>'+Format('<br>')+CT('UselessItems.Usl_Drug08.Text');//Звездная пыль",
                        "  if(variable2 == 4)input=input+Format(CT('UselessItems.Usl_Drug09.Name'),kov,'<clr>')+'<clrEnd><clrEnd>'+Format('<br>')+CT('UselessItems.Usl_Drug09.Text');//Супер техник",
                        "  if(variable2 == 5)input=input+Format(CT('UselessItems.Usl_Drug10.Name'),kov,'<clr>')+'<clrEnd><clrEnd>'+Format('<br>')+CT('UselessItems.Usl_Drug10.Text');//Гаалистра времени",
                        "  if(variable2 == 6)input=input+Format(CT('UselessItems.Usl_Drug11.Name'),kov,'<clr>')+'<clrEnd><clrEnd>'+Format('<br>')+CT('UselessItems.Usl_Drug11.Text');//Кровяной джогар",
                        "  if(variable3 > 0)input=input+Format('<br>')+'<clrEnd>---'+Format('<br>');//Разделитель перед списком стимуляторов №2",
                        "  if(variable3 == 1)input=input+Format(CT('UselessItems.Usl_Drug12.Name'),kov,'<clr>')+'<clrEnd><clrEnd>'+Format('<br>')+CT('UselessItems.Usl_Drug12.Text');//Рагобамский шепот",
                        "  if(variable3 == 2)input=input+Format(CT('UselessItems.Usl_Drug13.Name'),kov,'<clr>')+'<clrEnd><clrEnd>'+Format('<br>')+CT('UselessItems.Usl_Drug13.Text');//Ведущий Шахманду",
                        "  if(variable3 == 3)input=input+Format(CT('UselessItems.Usl_Drug14.Name'),kov,'<clr>')+'<clrEnd><clrEnd>'+Format('<br>')+CT('UselessItems.Usl_Drug14.Text');//Психотропный кэш",
                        "  if(variable3 == 4)input=input+Format(CT('UselessItems.Usl_Drug15.Name'),kov,'<clr>')+'<clrEnd><clrEnd>'+Format('<br>')+CT('UselessItems.Usl_Drug15.Text');//Торговая маркировка",
                        "  if(variable3 == 5)input=input+Format(CT('UselessItems.Usl_Drug16.Name'),kov,'<clr>')+'<clrEnd><clrEnd>'+Format('<br>')+CT('UselessItems.Usl_Drug16.Text');//Дубльплекс",
                        "  if(variable3 == 6)input=input+Format(CT('UselessItems.Usl_Drug17.Name'),kov,'<clr>')+'<clrEnd><clrEnd>'+Format('<br>')+CT('UselessItems.Usl_Drug17.Text');//Абсолютный статус",
                        "  ",
                        "  if(urine==0 && variable1>0 && variable2>0 && variable3>0)",
                        "  {",
                        "      unknown1=0;",
                        "      unknown2=0;",
                        "      unknown3=0;",
                        "  }",
                        "  if(!urine || variable1 > 0 || variable2 > 0 || variable3 > 0) {",
                        "    DChange(1);",
                        "    exit;",
                        "  }",
                        "  if(urine == 1 && variable1 == -1 && variable2 == -1 && variable3 == -1) {",
                        "    DChange(5);",
                        "    exit;",
                        "  }",
                        "}",
                        "if(!PlayerMedPolicy()) {",
                        "  DChange(4);",
                        "  exit;",
                        "}"
