                {
                    "Name": "",
                    "Code.Type": "Init",
                    "Code": [
                        "drugs = newarray(18);",
                        "drugs[0] = 'Usl_Urine';",
                        "drugs[1] = 'Usl_Drug01';",
                        "drugs[2] = 'Usl_Drug02';",
                        "drugs[3] = 'Usl_Drug03';",
                        "drugs[4] = 'Usl_Drug04';",
                        "drugs[5] = 'Usl_Drug05';",
                        "drugs[6] = 'Usl_Drug06';",
                        "drugs[7] = 'Usl_Drug07';",
                        "drugs[8] = 'Usl_Drug08';",
                        "drugs[9] = 'Usl_Drug09';",
                        "drugs[10] = 'Usl_Drug10';",
                        "drugs[11] = 'Usl_Drug11';",
                        "drugs[12] = 'Usl_Drug12';",
                        "drugs[13] = 'Usl_Drug13';",
                        "drugs[14] = 'Usl_Drug14';",
                        "drugs[15] = 'Usl_Drug15';",
                        "drugs[16] = 'Usl_Drug16';",
                        "drugs[17] = 'Usl_Drug17';",
                        "",
                        "//Расчёт выполнен немного странно, но в оригинале он ещё и написан коряво",
                        "function CalcTreatmentCost(int constant, int min_cost, int max_cost, float coef_percent, int seed)",
                        "{",
                        "    int cur_cost1 = 0;",
                        "    if(!constant) cur_cost1 = min_cost;",
                        "    else if(constant == 1) cur_cost1 = (min_cost + (min_cost + max_cost) / 2) / 2;",
                        "    else if(constant == 2) cur_cost1 = (min_cost + max_cost) / 2;",
                        "    else if(constant == 3) cur_cost1 = (((min_cost + max_cost) / 2) + max_cost) / 2;",
                        "    else if(constant == 4) cur_cost1 = max_cost;",
                        "    else",
                        "    {",
                        "        result = -1;",
                        "        exit;",
                        "    }",
                        "",
                        "    if(Rnd(0, 1, seed + cur_cost1))",
                        "    {",
                        "        int cur_cost2 = min(max_cost, cur_cost1 + round(coef_percent * cur_cost1));",
                        "        result = Rnd(cur_cost1, cur_cost2, seed);",
                        "    }",
                        "    else",
                        "    {",
                        "        cur_cost2 = max(min_cost, cur_cost1 - round(coef_percent * cur_cost1));",
                        "        result = Rnd(cur_cost2, cur_cost1, seed);",
                        "    }",
                        "}",
                        "",
                        "//Чтобы с минимальными потерями сделать вызов глобальным, просто скопирую",
                        "//Я не Клакс, я не буду из 100500 мест выгребать вызов функции",
                        "function g_CalcTreatmentCost(int constant, int min_cost, int max_cost, float coef_percent, int seed)",
                        "{",
                        "    int cur_cost1 = 0;",
                        "    if(!constant) cur_cost1 = min_cost;",
                        "    else if(constant == 1) cur_cost1 = (min_cost + (min_cost + max_cost) / 2) / 2;",
                        "    else if(constant == 2) cur_cost1 = (min_cost + max_cost) / 2;",
                        "    else if(constant == 3) cur_cost1 = (((min_cost + max_cost) / 2) + max_cost) / 2;",
                        "    else if(constant == 4) cur_cost1 = max_cost;",
                        "    else",
                        "    {",
                        "        result = -1;",
                        "        exit;",
                        "    }",
                        "",
                        "    if(Rnd(0, 1, seed + cur_cost1))",
                        "    {",
                        "        int cur_cost2 = min(max_cost, cur_cost1 + round(coef_percent * cur_cost1));",
                        "        result = Rnd(cur_cost1, cur_cost2, seed);",
                        "    }",
                        "    else",
                        "    {",
                        "        cur_cost2 = max(min_cost, cur_cost1 - round(coef_percent * cur_cost1));",
                        "        result = Rnd(cur_cost2, cur_cost1, seed);",
                        "    }",
                        "}",
                        "",
                        "function g_UpdateIllnessNotification()",
                        "{",
                        "    if(!illness_note)",
                        "    {",
                        "        EtherIdDelete('IllnessNotification');",
                        "        EtherDelete('IllnessNotification');",
                        "        exit;",
                        "    }",
                        "",
                        "    str text = '<color=0,255,0>' + CT('Illness.Illness.NotificationHeader') + Format('</color><br>') + '<color=127,127,127>--------------------------------------------------------------------------------------------------</color>';",
                        "    str date_stat = ArtefactTypeInUse(Player(), t_ArtBio);",
                        "    if(date_stat != '0') date_stat = CT('Illness.Illness.NotificationEndDate');",
                        "    int illness_cnt = 0;",
                        "    CT('Illness.Illness', tarr1);",
                        "    for(int i = ArrayDim(tarr1) - 1; i >= 0; i = i - 1)",
                        "    {",
                        "        //Удаляем из составленного массива все лишние элементы",
                        "        if(GetVariableType(tarr1[i]) != 9)",
                        "        {",
                        "            ArrayDelete(tarr1, i);",
                        "            continue;",
                        "        }",
                        "",
                        "        for(int j = ArrayDim(tarr1[i]) - 1; j >= 0; j = j - 1)",
                        "        {",
                        "            if(GetVariableName(tarr1[i, j]) == 'Designation')",
                        "            {",
                        "                str designation = tarr1[i, j];",
                        "                break;",
                        "            }",
                        "",
                        "            if(!j)",
                        "            {",
                        "                designation = '';",
                        "                ArrayDelete(tarr1, i);",
                        "            }",
                        "        }",
                        "        if(designation == '') continue;",
                        "",
                        "        if(designation == 'Original')",
                        "        {",
                        "            int ill_num = 1 + GetVariableName(tarr1[i]); //Сдвиг нумерации болезней в ёба-списке в Lang",
                        "            if(!ShipHealthFactor(Player(), ill_num)) ArrayDelete(tarr1, i); //Удаляем из массива те болезни, которых у игрока нет",
                        "            else",
                        "            {",
                        "                text = text + Format('<br>') + '- ' + CT('Illness.Illness.' + GetVariableName(tarr1[i]) + '.Name');",
                        "                if(date_stat != '0') text = text + ' ' + Format(date_stat, '<Date'+'>', GameDateTxtByTurn(CurTurn() + ShipHealthFactor(Player(), ill_num)), '255,240,100');",
                        "                illness_cnt = illness_cnt + 1;",
                        "            }",
                        "        }",
                        "        //Болезни из модов",
                        "        else",
                        "        {",
                        "            if(ShipFindCustomShipInfoByType(Player(), designation) == -1) ArrayDelete(tarr1, i);",
                        "            else",
                        "            {",
                        "                text = text + Format('<br>') + '- ' + CT('Illness.Illness.' + GetVariableName(tarr1[i]) + '.Name');",
                        "                if(date_stat != '0') text = text + ' ' + Format(date_stat, '<Date'+'>', GameDateTxtByTurn(ShipCustomShipInfoData(Player(), designation, 1)), '255,240,100');",
                        "                illness_cnt = illness_cnt + 1;",
                        "            }",
                        "        }",
                        "    }",
                        "",
                        "    /*",
                        "    for(int i = 0; i <= 12; i = i + 1)",
                        "    {",
                        "        if(ShipHealthFactor(Player(), i))",
                        "        {",
                        "            text = text + Format('<br>') + '- <color=255,240,100>' + CT('Illness.Illness.' + (i - 1) + '.Name') + '</color>';",
                        "            if(date_stat != '') text = text + ' ' + Format(date_stat, '<Date'+'>', GameDateTxtByTurn(CurTurn() + ShipHealthFactor(Player(), i)), '255,240,100');",
                        "            illness_cnt = illness_cnt + 1;",
                        "        }",
                        "    }",
                        "    */",
                        "",
                        "    if(illness_cnt) CustomEther('Illness', 3, 'IllnessNotification', text);",
                        "    else {",
                        "        EtherIdDelete('IllnessNotification');",
                        "        EtherDelete('IllnessNotification');",
                        "    }",
                        "}",
                        "",
                        "function g_UpdateStimulantsNotification()",
                        "{",
                        "    if(!stimulants_note)",
                        "    {",
                        "        EtherIdDelete('StimulantsNotification');",
                        "        EtherDelete('StimulantsNotification');",
                        "        exit;",
                        "    }",
                        "",
                        "    str text = '<color=0,255,0>' + CT('Illness.Stimulant.NotificationHeader') + Format('</color><br>') + '<color=127,127,127>--------------------------------------------------------------------------------------------------</color>';",
                        "    str date_stat = ArtefactTypeInUse(Player(), t_ArtBio);",
                        "    if(date_stat != '0') date_stat = CT('Illness.Stimulant.NotificationEndDate');",
                        "    int stimulants_cnt = 0;",
                        "    CT('Illness.Stimulant', tarr1);",
                        "    for(int i = ArrayDim(tarr1) - 1; i >= 0; i = i - 1)",
                        "    {",
                        "        //Удаляем из составленного массива все лишние элементы",
                        "        if(GetVariableType(tarr1[i]) != 9)",
                        "        {",
                        "            ArrayDelete(tarr1, i);",
                        "            continue;",
                        "        }",
                        "",
                        "        for(int j = ArrayDim(tarr1[i]) - 1; j >= 0; j = j - 1)",
                        "        {",
                        "            if(GetVariableName(tarr1[i, j]) == 'Designation')",
                        "            {",
                        "                str designation = tarr1[i, j];",
                        "                break;",
                        "            }",
                        "",
                        "            if(!j)",
                        "            {",
                        "                designation = '';",
                        "                ArrayDelete(tarr1, i);",
                        "            }",
                        "        }",
                        "        if(designation == '') continue;",
                        "",
                        "        if(designation == 'Original')",
                        "        {",
                        "            int stim_num = 13 + GetVariableName(tarr1[i]); //Сдвиг нумерации стимуляторов в ёба-списке в Lang",
                        "            if(!ShipHealthFactor(Player(), stim_num)) ArrayDelete(tarr1, i); //Удаляем из массива те стимуляторы, которых у игрока нет",
                        "            else",
                        "            {",
                        "                text = text + Format('<br>') + '- ' + CT('Illness.Stimulant.' + GetVariableName(tarr1[i]) + '.Name');",
                        "                if(date_stat != '0') text = text + ' ' + Format(date_stat, '<Date'+'>', GameDateTxtByTurn(CurTurn() + ShipHealthFactor(Player(), stim_num)), '255,240,100');",
                        "                stimulants_cnt = stimulants_cnt + 1;",
                        "            }",
                        "        }",
                        "        //Стимуляторы из модов",
                        "        else",
                        "        {",
                        "            if(ShipFindCustomShipInfoByType(Player(), designation) == -1) ArrayDelete(tarr1, i);",
                        "            else",
                        "            {",
                        "                text = text + Format('<br>') + '- ' + CT('Illness.Stimulant.' + GetVariableName(tarr1[i]) + '.Name');",
                        "                if(date_stat != '0') text = text + ' ' + Format(date_stat, '<Date'+'>', GameDateTxtByTurn(ShipCustomShipInfoData(Player(), designation, 1)), '255,240,100');",
                        "                stimulants_cnt = stimulants_cnt + 1;",
                        "            }",
                        "        }",
                        "    }",
                        "",
                        "    /*",
                        "    for(int i = 13; i <= 24; i = i + 1)",
                        "    {",
                        "        if(ShipHealthFactor(Player(), i))",
                        "        {",
                        "            text = text + Format('<br>') + '- <color=255,240,100>' + CT('Illness.Stimulant.' + (i - 13) + '.Name') + '</color>';",
                        "            if(date_stat != '') text = text + ' ' + Format(date_stat, '<Date'+'>', GameDateTxtByTurn(CurTurn() + ShipHealthFactor(Player(), i)), '255,240,100');",
                        "            stimulants_cnt = stimulants_cnt + 1;",
                        "        }",
                        "    }",
                        "    */",
                        "",
                        "    if(stimulants_cnt) CustomEther('Stimulants', 3, 'StimulantsNotification', text);",
                        "    else {",
                        "        EtherIdDelete('StimulantsNotification');",
                        "        EtherDelete('StimulantsNotification');",
                        "    }",
                        "}",
                        "",
                        "function PlayerActCode() //t_OnLeavingForm",
                        "{",
                        "    if(CurrentForm() == 'Ship')",
                        "    {",
                        "        if(illness_note) g_UpdateIllnessNotification();",
                        "        if(stimulants_note) g_UpdateStimulantsNotification();",
                        "    }",
                        "}"
                    ],
                    "#": 41,
                    "Type": "Top",
                    "Parent": -1,
                    "Pos.x": 60,
                    "Pos.y": 735
                },
                {
                    "Name": "",
                    "Code.Type": "Turn",
                    "Code": [
                        "//Через каждые 30 ходов доступные для покупки медикаменты меняются на случайные",
                        "vDays = vDays + 1;",
                        "if(vDays > 30)",
                        "{",
                        "    variable1 = Rnd(1, 5);",
                        "    variable2 = Rnd(1, 6);",
                        "    variable3 = Rnd(1, 6);",
                        "    urine = 0;",
                        "    vDays = 0;",
                        "}",
                        "",
                        "//Обнуляем счётчик купленных медикаментов",
                        "if(!findsubstr(GameDateTxtByTurn(CurTurn()), CT('CalendarDateTexts.January1'))) CurMed = 0;",
                        "",
                        "",
                        "int cnt=BuildListOfNewShips(tarr1,LastShipId,2,2+4+8+16+128,1,'','RangerExplorer,RangerPirate,RangerPirateExplorer,FemRanger');",
                        "if(cnt) {    //Если найден хотя бы один корабль",
                        "    for(i=0;i<ArrayDim(tarr1);i=i+1) {",
                        "        cnt=0;    //Обнуляем флаг",
                        "        cur_ship=tarr1[i];    //Выбираем корабль",
                        "        if(!cur_ship) continue;",
                        "        if(IsPlayer(cur_ship)) continue;",
                        "        tstr1=ShipType(cur_ship);",
                        "        if(RndObject(1,100,cur_ship) > 70) {",
                        "            int ill_num = Rnd(1,11);",
                        "            tstr1 = '<color=255,240,100>' + Format('<br>') + CT('Illness.Illness.' + ill_num + '.Name') + '</color>';",
                        "",
                        "            if(~ShipFindCustomShipInfoByType(cur_ship, 'EvoMC_Vaccination'))",
                        "            {",
                        "                for(i = 2; i <= 3; i = i + 1)",
                        "                {",
                        "                    if(!ShipCustomShipInfoData(cur_ship, 'EvoMC_Vaccination', i))",
                        "                    {",
                        "                        ShipCustomShipInfoTextData(cur_ship, 'EvoMC_Vaccination', i, ill_num);",
                        "                        ShipCustomShipInfoData(cur_ship, 'EvoMC_Vaccination', i, RndObject(1200, 1700, cur_ship));",
                        "                        break;",
                        "                    }",
                        "                }",
                        "            }",
                        "            else ShipAddCustomShipInfo(cur_ship, 'EvoMC_Vaccination', '', RndObject(1200, 1700, cur_ship), 0, 0, ill_num, 0, 0);",
                        "            ShipCustomShipInfoDescription(cur_ship, 'EvoMC_Vaccination', CT('ShipInfo.AddInfo.CustomInfos.EvoMC_Vaccination.Description') + tstr1);",
                        "        }",
                        "    }",
                        "",
                        "    LastShipId = GalaxyShipId();",
                        "}"
                    ],
                    "#": 42,
                    "Type": "Top",
                    "Parent": -1,
                    "Pos.x": 120,
                    "Pos.y": 735
                },
                {
                    "Name": "",
                    "Code.Type": "DialogBegin",
                    "Code": [
                        "cur_ruin = GetShipRuins(Player());",
                        "if(cur_ruin)",
                        "{",
                        "    if(ShipType(cur_ruin) == 'MC')",
                        "    {",
                        "        AddDialogBlock('HideThisAnswer', 2);",
                        "        pirateMC = StarOwner(ShipStar(cur_ruin));",
                        "",
                        "        tstr1 = CT('FormRuins.MC.Illnes.PlayerAskMedExam');",
                        "        AddDialogInject('IllnessesRemovalDialog', '', tstr1, 30);",
                        "        tstr1 = CT('Script.Mod_EvoMC.VaccinationDialog.PlayerAskVaccination');",
                        "        AddDialogInject('VaccinationsDialog', '', tstr1, 25);",
                        "        tstr1 = CT('FormRuins.MC.Stimulants.PlayerAskStim');",
                        "        AddDialogInject('StimulantsTakingDialog', '', tstr1, 20);",
                        "        tstr1 = CT('Script.Mod_EvoMC.StimulantsRemovalDialog.PlayerAskStimulantsRemoval');",
                        "        AddDialogInject('StimulantsRemovalDialog', '', tstr1, 15);",
                        "",
                        "        MaxMed = 1 + ShipRank(Player()) / 2;",
                        "        TotalMed = MaxMed - CurMed;",
                        "        AddDialogInject('DialogMC', '', CT(\"Script.Mod_EvoMC.126\"), 10);",
                        "    }",
                        "    else if(PlayerBridge() == 12)",
                        "    {",
                        "        //Включение/выключение вывода постоянных уведомлений о болезнях и стимуляторах",
                        "        if(!illness_note) AddDialogInject('IllnessNotificationOn', CT('Illness.Illness.NotificationSwitchOff'), CT('Illness.Illness.NotificationSwitchAnswerOn'), 8);",
                        "        else AddDialogInject('IllnessNotificationOff', CT('Illness.Illness.NotificationSwitchOn'), CT('Illness.Illness.NotificationSwitchAnswerOff'), 8);",
                        "",
                        "        if(!stimulants_note) AddDialogInject('StimulantsNotificationOn', CT('Illness.Stimulant.NotificationSwitchOff'), CT('Illness.Stimulant.NotificationSwitchAnswerOn'), 8);",
                        "        else AddDialogInject('StimulantsNotificationOff', CT('Illness.Stimulant.NotificationSwitchOn'), CT('Illness.Stimulant.NotificationSwitchAnswerOff'), 8);",
                        "    }",
                        "}",
                        "else",
                        "{",
                        "    cur_ship = GetTalkShip();",
                        "    if(cur_ship)",
                        "    {",
                        "        if(TalkByAI())",
                        "        {",
                        "            //Если игрока вызывает корабль, облитый уриной (ожидаемо, обливал сам игрок), подменяем реплику",
                        "            if(~ShipFindCustomShipInfoByType(cur_ship, 'EvoMC_YellowShroud'))",
                        "            {",
                        "                AddDialogOverride('YellowShroudDialog', 2552160);",
                        "            }",
                        "        }",
                        "    }",
                        "}"
