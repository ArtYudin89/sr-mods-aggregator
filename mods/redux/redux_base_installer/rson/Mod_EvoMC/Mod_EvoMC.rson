                {
                    "Name": "",
                    "Code.Type": "Turn",
                    "Code": [
                        "if(!urine || urine == 1) {",
                        "  cost = 0.8 * GalaxyMoney(2, ShipOwner(GetShipRuins(Player())));",
                        "  //input = '</color>' + Format(CT('UselessItems.Usl_Urine.Name'), kov, '<color=0,50,200>') + '</color> (<cost> cr.)';",
                        "  input = '</color>' + CT('Artefacts.CustomArtefacts.UrineTincture.NameDialog') + Format(' (<0> cr.)',\"<0>\",cost);",
                        "  if(!urine) {",
                        "    DAdd(0);",
                        "  }",
                        "  if(urine == 1) {",
                        "    DAdd(7);",
                        "  }",
                        "}",
                        "if(variable1 > 0 || unknown1 > 0) {",
                        "  cost=0.81*GalaxyMoney(2,ShipOwner(GetShipRuins(Player())));",
                        "  if(variable1==1 || unknown1==1)input='</color>'+Format(CT('UselessItems.Usl_Drug01.Name'),kov,'<color=0,50,200>')+Format('</color></color> (<0> </color> cr.)',\"<0>\",cost);//Чекумаш",
                        "  if(variable1==2 || unknown1==2)input='</color>'+Format(CT('UselessItems.Usl_Drug02.Name'),kov,'<color=0,50,200>')+Format('</color></color> (<0> </color> cr.)',\"<0>\",cost);//Святой фанатизм",
                        "  if(variable1==3 || unknown1==3)input='</color>'+Format(CT('UselessItems.Usl_Drug03.Name'),kov,'<color=0,50,200>')+Format('</color></color> (<0> </color> cr.)',\"<0>\",cost);//Загадочая луатанация",
                        "  if(variable1==4 || unknown1==4)input='</color>'+Format(CT('UselessItems.Usl_Drug04.Name'),kov,'<color=0,50,200>')+Format('</color></color> (<0> </color> cr.)',\"<0>\",cost);//Великий малосус",
                        "  if(variable1==5 || unknown1==5)input='</color>'+Format(CT('UselessItems.Usl_Drug05.Name'),kov,'<color=0,50,200>')+Format('</color></color> (<0> </color> cr.)',\"<0>\",cost);//Новый молизон;",
                        "  if(variable1>0) {",
                        "    DAdd(1);",
                        "  }",
                        "  if(unknown1>0) {",
                        "    DAdd(7);",
                        "  }",
                        "}",
                        "if(variable2 > 0 || unknown2 > 0) {",
                        "  cost=0.815*GalaxyMoney(2,ShipOwner(GetShipRuins(Player())));",
                        "  if(variable2==1 || unknown2==1)input='</color>'+Format(CT('UselessItems.Usl_Drug06.Name'),kov,'<color=0,50,200>')+Format('</color></color> (<0> </color> cr.)',\"<0>\",cost);//Малокская сижа",
                        "  if(variable2==2 || unknown2==2)input='</color>'+Format(CT('UselessItems.Usl_Drug07.Name'),kov,'<color=0,50,200>')+Format('</color></color> (<0> </color> cr.)',\"<0>\",cost);//Одноглазый Хамас",
                        "  if(variable2==3 || unknown2==3)input='</color>'+Format(CT('UselessItems.Usl_Drug08.Name'),kov,'<color=0,50,200>')+Format('</color></color> (<0> </color> cr.)',\"<0>\",cost);//Звездная пыль",
                        "  if(variable2==4 || unknown2==4)input='</color>'+Format(CT('UselessItems.Usl_Drug09.Name'),kov,'<color=0,50,200>')+Format('</color></color> (<0> </color> cr.)',\"<0>\",cost);//Супер техник",
                        "  if(variable2==5 || unknown2==5)input='</color>'+Format(CT('UselessItems.Usl_Drug10.Name'),kov,'<color=0,50,200>')+Format('</color></color> (<0> </color> cr.)',\"<0>\",cost);//Гаалистра времени",
                        "  if(variable2==6 || unknown2==6)input='</color>'+Format(CT('UselessItems.Usl_Drug11.Name'),kov,'<color=0,50,200>')+Format('</color></color> (<0> </color> cr.)',\"<0>\",cost);//Кровяной джогар;",
                        "  if(unknown2>0) {",
                        "    DAdd(7);",
                        "  }",
                        "  if(variable2>0) {",
                        "    DAdd(2);",
                        "  }",
                        "}",
                        "if(variable3 > 0 || unknown3 > 0) {",
                        "  cost=0.813*GalaxyMoney(2,ShipOwner(GetShipRuins(Player())));",
                        "  if(variable3==1 || unknown3==1)input='</color>'+Format(CT('UselessItems.Usl_Drug12.Name'),kov,'<color=0,50,200>')+Format('</color></color> (<0> </color> cr.)',\"<0>\",cost);//Рагобамский шепот",
                        "  if(variable3==2 || unknown3==2)input='</color>'+Format(CT('UselessItems.Usl_Drug13.Name'),kov,'<color=0,50,200>')+Format('</color></color> (<0> </color> cr.)',\"<0>\",cost);//Ведущий Шахманду",
                        "  if(variable3==3 || unknown3==3)input='</color>'+Format(CT('UselessItems.Usl_Drug14.Name'),kov,'<color=0,50,200>')+Format('</color></color> (<0> </color> cr.)',\"<0>\",cost);//Психотропный кэш",
                        "  if(variable3==4 || unknown3==4)input='</color>'+Format(CT('UselessItems.Usl_Drug15.Name'),kov,'<color=0,50,200>')+Format('</color></color> (<0> </color> cr.)',\"<0>\",cost);//Торговая маркировка",
                        "  if(variable3==5 || unknown3==5)input='</color>'+Format(CT('UselessItems.Usl_Drug16.Name'),kov,'<color=0,50,200>')+Format('</color></color> (<0> </color> cr.)',\"<0>\",cost);//Дубльплекс",
                        "  if(variable3==6 || unknown3==6)input='</color>'+Format(CT('UselessItems.Usl_Drug17.Name'),kov,'<color=0,50,200>')+Format('</color></color> (<0> </color> cr.)',\"<0>\",cost);//Абсолютный статус;",
                        "  if(unknown3>0) {",
                        "    DAdd(7);",
                        "  }",
                        "  if(variable3>0) {",
                        "    DAdd(3);",
                        "  }",
                        "}",
                        "DAdd(5);"
