                },
                {
                    "Name": "",
                    "Code.Type": "Turn",
                    "Code": [
                        "mm_name = EqModule(GAnswerData);",
                        "DChange(4);",
                        "exit;"
                    ],
                    "#": 135,
                    "Type": "Top",
                    "Parent": -1,
                    "Pos.x": -20,
                    "Pos.y": 475
                },
                {
                    "Name": "",
                    "Code.Type": "Turn",
                    "Code": [
                        "temp_dword=GAnswerData;",
                        "temp_int=ItemCost(temp_dword)/3+GalaxyMoney(1);",
                        "if(ItemType(temp_dword)==t_Hull && cur_art_sb2_srch_type[0]==100)mod_ok=1;",
                        "if(ItemType(temp_dword)==t_FuelTanks && cur_art_sb2_srch_type[2]==100)mod_ok=1;",
                        "if(ItemType(temp_dword)==t_Engine && cur_art_sb2_srch_type[1]==100)mod_ok=1;",
                        "if(ItemType(temp_dword)==t_Radar && cur_art_sb2_srch_type[7]==100)mod_ok=1;",
                        "if(ItemType(temp_dword)==t_Scaner && cur_art_sb2_srch_type[6]==100)mod_ok=1;",
                        "if(ItemType(temp_dword)==t_RepairRobot && cur_art_sb2_srch_type[3]==100)mod_ok=1;",
                        "if(ItemType(temp_dword)==t_CargoHook && cur_art_sb2_srch_type[4]==100)mod_ok=1;",
                        "if(ItemType(temp_dword)==t_DefGenerator && cur_art_sb2_srch_type[5]==100)mod_ok=1;",
                        "if(ItemType(temp_dword)==t_Weapon1 || ItemType(temp_dword)==t_Weapon3 || ItemType(temp_dword)==t_Weapon5 || ItemType(temp_dword)==t_Weapon6 || ItemType(temp_dword)==t_Weapon8 || ItemType(temp_dword)==t_Weapon10 || ItemType(temp_dword)==t_Weapon11 || ItemType(temp_dword)==t_Weapon12 || ItemType(temp_dword)==t_Weapon14 || ItemType(temp_dword)==t_Weapon17)",
                        "{",
                        "    if(cur_art_sb2_srch_type[8]==100)mod_ok=1;",
                        "}",
                        "if(ItemType(temp_dword)==t_Weapon2 || ItemType(temp_dword)==t_Weapon7 || ItemType(temp_dword)==t_Weapon9 || ItemType(temp_dword)==t_Weapon13 || ItemType(temp_dword)==t_Weapon16)",
                        "{",
                        "    if(cur_art_sb2_srch_type[9]==100)mod_ok=1;",
                        "}",
                        "if(ItemType(temp_dword)==t_Weapon4 || ItemType(temp_dword)==t_Weapon15 || ItemType(temp_dword)==t_Weapon18)",
                        "{",
                        "    if(cur_art_sb2_srch_type[10]==100)mod_ok=1;",
                        "}",
                        "if(mod_ok) {",
                        "  DChange(5);",
                        "  exit;",
                        "}",
                        "if(!mod_ok) {",
                        "  DChange(3);",
                        "  exit;",
                        "}"
                    ],
                    "#": 136,
                    "Type": "Top",
                    "Parent": -1,
                    "Pos.x": 370,
                    "Pos.y": 475
                },
                {
                    "Name": "",
                    "Code.Type": "Turn",
                    "Code": [
                        "if(ItemType(GAnswerData)==t_ArtefactHull || ItemType(GAnswerData)==t_ArtefactAntigrav)srch_type=cur_art_sb2_srch_type_name[0];",
                        "if(ItemType(GAnswerData)==t_ArtefactSpeed || ItemType(GAnswerData)==t_ArtefactPower || ItemType(GAnswerData)==t_ArtForsage || ItemType(GAnswerData)==t_ArtWeaponToSpeed || ItemType(GAnswerData)==t_ArtGiperJump)",
                        "{",
                        "    srch_type=cur_art_sb2_srch_type_name[1];",
                        "}",
                        "if(ItemType(GAnswerData)==t_ArtefactFuel)srch_type=cur_art_sb2_srch_type_name[2];",
                        "if(ItemType(GAnswerData)==t_ArtefactDroid || ItemType(GAnswerData)==t_ArtEnergyPulse)srch_type=cur_art_sb2_srch_type_name[3];",
                        "if(ItemType(GAnswerData)==t_ArtefactHook)srch_type=cur_art_sb2_srch_type_name[4];",
                        "if(ItemType(GAnswerData)==t_ArtefactDef)srch_type=cur_art_sb2_srch_type_name[5];",
                        "if(ItemType(GAnswerData)==t_ArtefactScaner)srch_type=cur_art_sb2_srch_type_name[6];",
                        "if(ItemType(GAnswerData)==t_ArtefactRadar || ItemType(GAnswerData)==t_ArtefactTransmitter)srch_type=cur_art_sb2_srch_type_name[7];",
                        "if(ItemType(GAnswerData)==t_ArtEnergyPulse || ItemType(GAnswerData)==t_ArtEnergyDef)srch_type=cur_art_sb2_srch_type_name[8];",
                        "if(ItemType(GAnswerData)==t_ArtSplinter || ItemType(GAnswerData)==t_ArtDecelerate)srch_type=cur_art_sb2_srch_type_name[9];",
                        "if(ItemType(GAnswerData)==t_ArtFastRacks || ItemType(GAnswerData)==t_ArtMissileDef || ItemType(GAnswerData)==t_ArtPDTurret)srch_type=cur_art_sb2_srch_type_name[10];",
                        "if(ItemType(GAnswerData)==t_ArtefactNano || ItemType(GAnswerData)==t_ArtefactAnalyzer || ItemType(GAnswerData)==t_ArtefactTranclucator || ItemType(GAnswerData)==t_ArtBio)",
                        "{",
                        "    srch_type=cur_art_sb2_srch_type_name[11];",
                        "}",
                        "if(ItemType(GAnswerData)==t_ArtefactMiniExpl)srch_type='Оружие';",
                        "if(ItemType(GAnswerData)==t_ArtDefToEnergy)",
                        "{",
                        "    if(cur_art_sb2_srch_type[8]<100 && cur_art_sb2_srch_type[5]<100)",
                        "    {",
                        "        srch_type=cur_art_sb2_srch_type_name[5]+', '+cur_art_sb2_srch_type_name[8];",
                        "    }",
                        "    if(cur_art_sb2_srch_type[8]<100 && cur_art_sb2_srch_type[5]==100)",
                        "    {",
                        "        srch_type=cur_art_sb2_srch_type_name[8];",
                        "    }",
                        "    if(cur_art_sb2_srch_type[8]==100 && cur_art_sb2_srch_type[5]<100)",
                        "    {",
                        "        srch_type=cur_art_sb2_srch_type_name[5];",
                        "    }",
                        "}",
                        "if(ItemType(GAnswerData)==t_ArtDefToArms1 || ItemType(GAnswerData)==t_ArtDefToArms2)",
                        "{",
                        "    if(cur_art_sb2_srch_type[5]<100 && cur_art_sb2_srch_type[8]<100 && cur_art_sb2_srch_type[9]<100 && cur_art_sb2_srch_type[10]<100)",
                        "    {",
                        "        srch_type=cur_art_sb2_srch_type_name[5]+', '+'Оружие';",
                        "    }",
                        "    if(cur_art_sb2_srch_type[5]<100 && cur_art_sb2_srch_type[8]==100 && cur_art_sb2_srch_type[9]==100 && cur_art_sb2_srch_type[10]==100)",
                        "    {",
                        "        srch_type=cur_art_sb2_srch_type_name[5];",
                        "    }",
                        "    if(cur_art_sb2_srch_type[5]==100)srch_type='Оружие';",
                        "}",
                        "DChange(2);",
                        "exit;"
                    ],
                    "#": 137,
                    "Type": "Top",
                    "Parent": -1,
                    "Pos.x": 760,
                    "Pos.y": 475
                },
                {
                    "Name": "",
                    "Code.Type": "Turn",
                    "Code": [
                        "temp_int_3 = FindBonusByNameInCfg('ExpSSB_Fragility20Plus');",
                        "add_cr=0;",
                        "temp_int_2=0;",
                        "for(i = ShipArts(Player()) - 1; i >= 0; i = i - 1)",
                        "{",
                        "    cur_bh_item=ShipArts(Player(),i);",
                        "    if(ItemType(cur_bh_item)<t_ArtefactHull) continue;",
                        "    if(ItemIsInUse(cur_bh_item) || ItemIsInSet(cur_bh_item)) continue;",
                        "    if(ItemExtraSpecialsCountByType(cur_bh_item,temp_int_3)>0) continue;",
                        "    add_srch=0;",
                        "    for(j = 0; j <= 29; j = j + 1)",
                        "    {",
                        "        if(ItemType(cur_bh_item)==cur_art_sb2[j] && cur_art_sb2_srch[j]<100)",
                        "        {",
                        "            if(ItemType(cur_bh_item)==t_ArtFastRacks || ItemType(cur_bh_item)==t_ArtefactHull || ItemType(cur_bh_item)==t_ArtefactSpeed || ItemType(cur_bh_item)==t_ArtefactDef || ItemType(cur_bh_item)==t_ArtefactAntigrav || ItemType(cur_bh_item)==t_ArtEnergyPulse || ItemType(cur_bh_item)==t_ArtSplinter || ItemType(cur_bh_item)==t_ArtDecelerate || ItemType(cur_bh_item)==t_ArtMissileDef || ItemType(cur_bh_item)==t_ArtForsage || ItemType(cur_bh_item)==t_ArtPDTurret)",
                        "            {",
                        "                add_srch=Rnd(8,13);",
                        "            }",
                        "            if(ItemType(cur_bh_item)==t_ArtefactFuel || ItemType(cur_bh_item)==t_ArtefactRadar || ItemType(cur_bh_item)==t_ArtefactScaner || ItemType(cur_bh_item)==t_ArtefactDroid || ItemType(cur_bh_item)==t_ArtefactHook)",
                        "            {",
                        "                add_srch=Rnd(9,16);",
                        "            }",
                        "            if(ItemType(cur_bh_item)==t_ArtefactPower || ItemType(cur_bh_item)==t_ArtEnergyDef || ItemType(cur_bh_item)==t_ArtefactNano || ItemType(cur_bh_item)==t_ArtefactMiniExpl || ItemType(cur_bh_item)==t_ArtDefToEnergy || ItemType(cur_bh_item)==t_ArtWeaponToSpeed || ItemType(cur_bh_item)==t_ArtGiperJump || ItemType(cur_bh_item)==t_ArtefactTranclucator || ItemType(cur_bh_item)==t_ArtDefToArms1 || ItemType(cur_bh_item)==t_ArtDefToArms2)",
                        "            {",
                        "                add_srch=Rnd(3,8);",
                        "            }",
                        "            if(ItemType(cur_bh_item)==t_ArtefactAnalyzer || ItemType(cur_bh_item)==t_ArtefactTransmitter || ItemType(cur_bh_item)==t_ArtArtefactor || ItemType(cur_bh_item)==t_ArtBio)",
                        "            {",
