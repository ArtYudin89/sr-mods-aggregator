                {
                    "Name": "",
                    "Code.Type": "Turn",
                    "Code": [
                        "if(ItemType(GAnswerData)==t_ArtFastRacks || ItemType(GAnswerData)==t_ArtefactHull || ItemType(GAnswerData)==t_ArtefactSpeed || ItemType(GAnswerData)==t_ArtefactDef || ItemType(GAnswerData)==t_ArtefactAntigrav || ItemType(GAnswerData)==t_ArtEnergyPulse || ItemType(GAnswerData)==t_ArtSplinter || ItemType(GAnswerData)==t_ArtDecelerate || ItemType(GAnswerData)==t_ArtMissileDef || ItemType(GAnswerData)==t_ArtForsage || ItemType(GAnswerData)==t_ArtPDTurret)",
                        "{",
                        "    add_srch=Rnd(8,13);",
                        "}",
                        "if(ItemType(GAnswerData)==t_ArtefactFuel || ItemType(GAnswerData)==t_ArtefactRadar || ItemType(GAnswerData)==t_ArtefactScaner || ItemType(GAnswerData)==t_ArtefactDroid || ItemType(GAnswerData)==t_ArtefactHook)",
                        "{",
                        "    add_srch=Rnd(9,16);",
                        "}",
                        "if(ItemType(GAnswerData)==t_ArtefactPower || ItemType(GAnswerData)==t_ArtEnergyDef || ItemType(GAnswerData)==t_ArtefactNano || ItemType(GAnswerData)==t_ArtefactMiniExpl || ItemType(GAnswerData)==t_ArtDefToEnergy || ItemType(GAnswerData)==t_ArtWeaponToSpeed || ItemType(GAnswerData)==t_ArtGiperJump || ItemType(GAnswerData)==t_ArtefactTranclucator || ItemType(GAnswerData)==t_ArtDefToArms1 || ItemType(GAnswerData)==t_ArtDefToArms2)",
                        "{",
                        "    add_srch=Rnd(3,8);",
                        "}",
                        "if(ItemType(GAnswerData)==t_ArtefactAnalyzer || ItemType(GAnswerData)==t_ArtefactTransmitter || ItemType(GAnswerData)==t_ArtArtefactor || ItemType(GAnswerData)==t_ArtBio)",
                        "{",
                        "    add_srch=Rnd(2,4);",
                        "}",
                        "if(ItemType(GAnswerData)==t_ArtefactHull || ItemType(GAnswerData)==t_ArtefactAntigrav || ItemType(GAnswerData)==t_ArtefactNano || ItemType(GAnswerData)==t_ArtefactAnalyzer || ItemType(GAnswerData)==t_ArtefactTranclucator || ItemType(GAnswerData)==t_ArtBio)",
                        "{",
                        "    cur_art_sb2_srch_type[0]=cur_art_sb2_srch_type[0]+add_srch;",
                        "}",
                        "if(ItemType(GAnswerData)==t_ArtefactSpeed || ItemType(GAnswerData)==t_ArtefactPower || ItemType(GAnswerData)==t_ArtForsage || ItemType(GAnswerData)==t_ArtWeaponToSpeed || ItemType(GAnswerData)==t_ArtefactTranclucator || ItemType(GAnswerData)==t_ArtBio || ItemType(GAnswerData)==t_ArtGiperJump || ItemType(GAnswerData)==t_ArtefactNano || ItemType(GAnswerData)==t_ArtefactAnalyzer)",
                        "{",
                        "    cur_art_sb2_srch_type[1]=cur_art_sb2_srch_type[1]+add_srch;",
                        "}",
                        "if(ItemType(GAnswerData)==t_ArtefactFuel || ItemType(GAnswerData)==t_ArtefactNano || ItemType(GAnswerData)==t_ArtefactAnalyzer || ItemType(GAnswerData)==t_ArtefactTranclucator || ItemType(GAnswerData)==t_ArtBio)",
                        "{",
                        "    cur_art_sb2_srch_type[2]=cur_art_sb2_srch_type[2]+add_srch;",
                        "}",
                        "if(ItemType(GAnswerData)==t_ArtefactRadar || ItemType(GAnswerData)==t_ArtefactHook || ItemType(GAnswerData)==t_ArtefactNano || ItemType(GAnswerData)==t_ArtefactAnalyzer || ItemType(GAnswerData)==t_ArtefactTranclucator || ItemType(GAnswerData)==t_ArtBio)",
                        "{",
                        "    cur_art_sb2_srch_type[7]=cur_art_sb2_srch_type[7]+add_srch;",
                        "}",
                        "if(ItemType(GAnswerData)==t_ArtefactScaner || ItemType(GAnswerData)==t_ArtefactNano || ItemType(GAnswerData)==t_ArtefactAnalyzer || ItemType(GAnswerData)==t_ArtefactTranclucator || ItemType(GAnswerData)==t_ArtBio)",
                        "{",
                        "    cur_art_sb2_srch_type[6]=cur_art_sb2_srch_type[6]+add_srch;",
                        "}",
                        "if(ItemType(GAnswerData)==t_ArtefactDroid || ItemType(GAnswerData)==t_ArtArtefactor || ItemType(GAnswerData)==t_ArtefactNano || ItemType(GAnswerData)==t_ArtefactAnalyzer || ItemType(GAnswerData)==t_ArtefactTranclucator || ItemType(GAnswerData)==t_ArtBio)",
                        "{",
                        "    cur_art_sb2_srch_type[3]=cur_art_sb2_srch_type[3]+add_srch;",
                        "}",
                        "if(ItemType(GAnswerData)==t_ArtefactHook || ItemType(GAnswerData)==t_ArtefactNano || ItemType(GAnswerData)==t_ArtefactAnalyzer || ItemType(GAnswerData)==t_ArtefactTranclucator || ItemType(GAnswerData)==t_ArtBio)",
                        "{",
                        "    cur_art_sb2_srch_type[4]=cur_art_sb2_srch_type[4]+add_srch;",
                        "}",
                        "if(ItemType(GAnswerData)==t_ArtefactDef || ItemType(GAnswerData)==t_ArtefactNano || ItemType(GAnswerData)==t_ArtefactAnalyzer || ItemType(GAnswerData)==t_ArtefactTranclucator || ItemType(GAnswerData)==t_ArtBio)",
                        "{",
                        "    cur_art_sb2_srch_type[5]=cur_art_sb2_srch_type[5]+add_srch;",
                        "}",
                        "if(ItemType(GAnswerData)==t_ArtEnergyPulse || ItemType(GAnswerData)==t_ArtEnergyDef || ItemType(GAnswerData)==t_ArtefactNano || ItemType(GAnswerData)==t_ArtefactAnalyzer || ItemType(GAnswerData)==t_ArtefactTranclucator || ItemType(GAnswerData)==t_ArtBio)",
                        "{",
                        "    cur_art_sb2_srch_type[8]=cur_art_sb2_srch_type[8]+add_srch;",
                        "}",
                        "if(ItemType(GAnswerData)==t_ArtSplinter || ItemType(GAnswerData)==t_ArtDecelerate || ItemType(GAnswerData)==t_ArtefactNano || ItemType(GAnswerData)==t_ArtefactAnalyzer || ItemType(GAnswerData)==t_ArtefactTranclucator || ItemType(GAnswerData)==t_ArtBio)",
                        "{",
                        "    cur_art_sb2_srch_type[9]=cur_art_sb2_srch_type[9]+add_srch;",
                        "}",
                        "if(ItemType(GAnswerData)==t_ArtFastRacks || ItemType(GAnswerData)==t_ArtMissileDef || ItemType(GAnswerData)==t_ArtPDTurret || ItemType(GAnswerData)==t_ArtefactNano || ItemType(GAnswerData)==t_ArtefactAnalyzer || ItemType(GAnswerData)==t_ArtefactTranclucator || ItemType(GAnswerData)==t_ArtBio)",
                        "{",
                        "    cur_art_sb2_srch_type[10]=cur_art_sb2_srch_type[10]+add_srch;",
                        "}",
                        "if(ItemType(GAnswerData)==t_ArtefactMiniExpl)",
                        "{",
                        "    cur_art_sb2_srch_type[8]=cur_art_sb2_srch_type[8]+add_srch;",
                        "    cur_art_sb2_srch_type[9]=cur_art_sb2_srch_type[9]+add_srch;",
                        "    cur_art_sb2_srch_type[10]=cur_art_sb2_srch_type[10]+add_srch;",
                        "}",
                        "if(ItemType(GAnswerData)==t_ArtDefToEnergy)",
                        "{",
                        "    if(add_srch>9 && cur_art_sb2_srch_type[5]<100)",
                        "    {",
                        "        cur_art_sb2_srch_type[5]=cur_art_sb2_srch_type[5]+add_srch;",
                        "    }",
                        "    if(add_srch<=9 && cur_art_sb2_srch_type[5]<100)",
                        "    {",
                        "        cur_art_sb2_srch_type[8]=cur_art_sb2_srch_type[8]+add_srch;",
                        "    }",
                        "    if(cur_art_sb2_srch_type[5]==100)",
                        "    {",
                        "        cur_art_sb2_srch_type[8]=cur_art_sb2_srch_type[8]+add_srch;",
                        "    }",
                        "    if(cur_art_sb2_srch_type[8]==100)",
                        "    {",
                        "        cur_art_sb2_srch_type[5]=cur_art_sb2_srch_type[5]+add_srch;",
                        "    }",
                        "}",
                        "if(ItemType(GAnswerData)==t_ArtDefToArms1 || ItemType(GAnswerData)==t_ArtDefToArms2)",
                        "{",
                        "    if(add_srch>9 && cur_art_sb2_srch_type[5]<100)",
                        "    {",
                        "        cur_art_sb2_srch_type[5]=cur_art_sb2_srch_type[5]+add_srch;",
                        "    }",
                        "    if(add_srch<=9 && cur_art_sb2_srch_type[5]<100)",
                        "    {",
                        "        cur_art_sb2_srch_type[8]=cur_art_sb2_srch_type[8]+add_srch;",
                        "        cur_art_sb2_srch_type[9]=cur_art_sb2_srch_type[9]+add_srch;",
                        "        cur_art_sb2_srch_type[10]=cur_art_sb2_srch_type[10]+add_srch;",
                        "    }",
                        "    if(cur_art_sb2_srch_type[5]==100)",
                        "    {",
                        "        cur_art_sb2_srch_type[8]=cur_art_sb2_srch_type[8]+add_srch;",
                        "        cur_art_sb2_srch_type[9]=cur_art_sb2_srch_type[9]+add_srch;",
                        "        cur_art_sb2_srch_type[10]=cur_art_sb2_srch_type[10]+add_srch;",
                        "    }",
                        "    if(cur_art_sb2_srch_type[8]==cur_art_sb2_srch_type[9]==cur_art_sb2_srch_type[10]==100)",
                        "    {",
                        "        cur_art_sb2_srch_type[5]=cur_art_sb2_srch_type[5]+add_srch;",
                        "    }",
                        "}",
                        "for(j=0;j<=10;j=j+1)",
                        "{",
                        "    if(cur_art_sb2_srch_type[j]>100)",
                        "    {",
                        "        cur_art_sb2_srch_type[j]=100;",
                        "    }",
                        "}",
                        "for(i=0;i<=29;i=i+1)",
                        "{",
                        "    if(ItemType(GAnswerData)==cur_art_sb2[i])",
                        "    {",
                        "        cur_art_sb2_srch[i]=cur_art_sb2_srch[i]+add_srch;",
                        "    }",
                        "}",
