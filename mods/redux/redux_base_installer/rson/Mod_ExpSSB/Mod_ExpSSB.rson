                {
                    "Name": "",
                    "Code.Type": "Turn",
                    "Code": [
                        "if(EqModule(ShipItems(Player(),0)) >= 0) ModuleToEquipment(-1,ShipItems(Player(),0));",
                        "if(ItemExtraSpecials(ShipItems(Player(),0)))",
                        "{",
                        "    for(i = ItemExtraSpecials(ShipItems(Player(), 0)) - 1; i >= 0; i = i - 1)",
                        "    {",
                        "        temp_int=ItemExtraSpecials(ShipItems(Player(),0),i);",
                        "        ItemExtraSpecialsDeleteByType(ShipItems(Player(),0),temp_int);",
                        "    }",
                        "}",
                        "",
                        "temp_dword = CreateHull(0, 100 + 175 * GalaxyTechLevel(), GalaxyTechLevel(), 6);",
                        "ItemLevel(ShipItems(Player(),0),GalaxyTechLevel());",
                        "SetEquipmentStats(ShipItems(Player(),0),GetEquipmentStats(temp_dword,0)+1,0);",
                        "ItemImprovement(ShipItems(Player(),0),2);",
                        "ItemSize(ShipItems(Player(),0),ItemSize(temp_dword));",
                        "ItemCost(ShipItems(Player(),0),ItemCost(ShipItems(Player(),0))+(ItemCost(ShipItems(Player(),0))*20)/100);",
                        "HullHP(ShipItems(Player(),0),ItemSize(temp_dword));",
                        "temp_int=(ItemCost(temp_dword)*20)/100;",
                        "FreeItem(temp_dword);",
                        "ShipMoney(Player(),ShipMoney(Player())-cost);",
                        "Sound('Sound.Repair');"
