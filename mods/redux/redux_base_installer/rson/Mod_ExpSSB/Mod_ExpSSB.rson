                },
                {
                    "Name": "",
                    "Code.Type": "Turn",
                    "Code": [
                        "mod_ok=0;",
                        "for(i=1; i<ShipItems(Player()); i=i+1)",
                        "{",
                        "    cur_bh_item=ShipItems(Player(),i);",
                        "    if(ItemOwner(cur_bh_item)!=None)continue;",
                        "    if(EqCustomFaction(cur_bh_item)!='')continue;",
                        "    if(EqModule(cur_bh_item)>=0)continue;",
                        "    if(ItemType(cur_bh_item)<=t_Hull || ItemType(cur_bh_item)>=t_Protoplasm)continue;",
                        "    if(ItemType(cur_bh_item)<t_Weapon1)",
                        "    {",
                        "        InjectAnswer('CombiningMMChooseDialogSSB',DeleteTags(Format('<0>',\"<0>\",Name(cur_bh_item))),cur_bh_item);",
                        "    }",
                        "    if(ItemType(cur_bh_item)>=t_Weapon1)",
                        "    {",
                        "        if(ItemLevel(cur_bh_item)==1)temp_str=' A';",
                        "        else if(ItemLevel(cur_bh_item)==2)temp_str=' B';",
                        "        else if(ItemLevel(cur_bh_item)==3)temp_str=' C';",
                        "        else if(ItemLevel(cur_bh_item)==4)temp_str=' D';",
                        "        else if(ItemLevel(cur_bh_item)==5)temp_str=' E';",
                        "        else if(ItemLevel(cur_bh_item)==6)temp_str=' F';",
                        "        else if(ItemLevel(cur_bh_item)==7)temp_str=' G';",
                        "        else if(ItemLevel(cur_bh_item)==8)temp_str=' H';",
                        "        InjectAnswer('CombiningMMChooseDialogSSB',DeleteTags(Format('<0>',\"<0>\",Name(cur_bh_item)))+temp_str,cur_bh_item);",
                        "    }",
                        "}",
                        "",
                        "for(temp_int=0; temp_int<ShipArts(Player()); temp_int=temp_int+1)",
                        "{",
                        "    temp_dword=ShipArts(Player(),temp_int);",
                        "    if(ItemType(temp_dword)==t_ArtefactTranclucator)",
                        "    {",
                        "        for(i=0;i<ShipItems(ArtTranclucatorToShip(temp_dword));i=i+1)",
                        "        {",
                        "            cur_bh_item=ShipItems(ArtTranclucatorToShip(temp_dword),i);",
                        "            if(ItemOwner(cur_bh_item)!=None)continue;",
                        "            if(EqCustomFaction(cur_bh_item)!='')continue;",
                        "            if(EqModule(cur_bh_item)>=0)continue;",
                        "            if(ItemType(cur_bh_item)<=t_Hull || ItemType(cur_bh_item)>=t_Protoplasm)continue;",
                        "            if(ItemType(cur_bh_item)<t_Weapon1 )",
