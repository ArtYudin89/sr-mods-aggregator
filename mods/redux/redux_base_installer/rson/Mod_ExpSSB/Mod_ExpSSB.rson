                    "Code": [
                        "temp_int=FindBonusByNameInCfg('498'); //Акринатор",
                        "for(i=0; i<ShipItems(Player()); i=i+1)",
                        "{",
                        "    cur_bh_item=ShipItems(Player(),i);",
                        "    if(ItemType(cur_bh_item)!=t_MicroModule) continue;",
                        "    if(EqModule(cur_bh_item)==temp_int) continue;",
                        "    mm_ok=0;",
                        "    for(j=0;j<=7;j=j+1)",
                        "    {",
                        "        ItemOwner(temp_dword,j);",
                        "        if(MayAddBonusToEq(EqModule(cur_bh_item),temp_dword)) mm_ok=1;",
                        "    }",
                        "    ItemOwner(temp_dword,None);",
                        "    if(mm_ok==0) continue;",
                        "    InjectAnswer('CombiningMMInjectDialogSSB',DeleteTags(Format('<0>',\"<0>\",Name(cur_bh_item))),cur_bh_item);",
                        "}",
