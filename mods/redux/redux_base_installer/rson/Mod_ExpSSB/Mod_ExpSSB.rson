            "Operations": [
                {
                    "Name": "",
                    "Code.Type": "Global",
                    "Code": [
                        "GRun();"
                    ],
                    "#": 60,
                    "Type": "Top",
                    "Parent": -1,
                    "Pos.x": 0,
                    "Pos.y": 810
                },
                {
                    "Name": "",
                    "Code.Type": "Init",
                    "Code": [
                        "//temp_dword = CreateCustomArt('pulsar', Rnd(15, 35), Rnd(2000, 8000) * GalaxyTechLevel(), 4);",
                        "//AddItemToShip(Player(), temp_dword);",
                        "//crush_ok = 8;",
                        "//temp_dword = CreateCustomArt('ppb_caller_art', Rnd(1, 2) * GalaxyTechLevel(), Rnd(2000, 8000) * GalaxyTechLevel(), 4);",
                        "//CustomArtData(temp_dword, 1, 99);",
                        "//CustomArtData(temp_dword, 3, CurTurn() - 1);",
                        "//AddItemToShip(Player(), temp_dword);",
                        "",
                        "cur_art_sb2 = newarray(31);",
                        "cur_art_sb2_srch = newarray(31);",
                        "cur_art_sb2_srch_type_name = newarray(12);",
                        "cur_art_sb2_srch_type = newarray(11);",
                        "",
                        "for(i = 0; i < 11; i = i + 1) cur_art_sb2_srch_type[i] = 0;",
                        "temp_int = 0;",
                        "for(i = t_ArtefactHull; i < t_Hull; i = i + 1)",
                        "{",
                        "    if(i != t_ArtefactBomb && i != t_ArtBlackHole)",
                        "    {",
                        "        cur_art_sb2[temp_int] = i;",
                        "        cur_art_sb2_srch[temp_int] = 0;",
                        "        temp_int = temp_int + 1;",
                        "    }",
                        "}",
                        "",
                        "cur_art_sb2_srch_type_name[0] = 'Корпус';",
                        "cur_art_sb2_srch_type_name[1] = 'Двигатель';",
                        "cur_art_sb2_srch_type_name[2] = 'Топливный бак';",
                        "cur_art_sb2_srch_type_name[3] = 'Ремонтный дроид';",
                        "cur_art_sb2_srch_type_name[4] = 'Захват';",
                        "cur_art_sb2_srch_type_name[5] = 'Защитный генератор';",
                        "cur_art_sb2_srch_type_name[6] = 'Сканер';",
                        "cur_art_sb2_srch_type_name[7] = 'Радар';",
                        "cur_art_sb2_srch_type_name[8] = 'Энергетическое оружие';",
                        "cur_art_sb2_srch_type_name[9] = 'Осколочное оружие';",
                        "cur_art_sb2_srch_type_name[10] = 'Ракетное оружие';",
                        "cur_art_sb2_srch_type_name[11] = 'Все типы';"
                    ],
                    "#": 61,
                    "Type": "Top",
                    "Parent": -1,
                    "Pos.x": 60,
                    "Pos.y": 810
                },
                {
                    "Name": "",
                    "Code.Type": "Turn",
                    "Code": [
                        "//Удалить к концу осени 2023",
                        "if(!TempVar1)",
                        "{",
                        "    cur_ruin = IdToShip(id_base);",
                        "    if(cur_ruin)",
                        "    {",
                        "        RuinsChangeType(cur_ruin, t_UB);",
                        "        ShipType(cur_ruin, 'SSB_licensed');",
                        "        ShipStanding(cur_ruin, 5);",
                        "        Chameleon(cur_ruin, 'Ruins.SSB_licensed');",
                        "    }",
                        "",
                        "    TempVar1 = 1;",
                        "}",
                        "//if(crush_ok == 8 && CurTurn() - back_4d > 10) crush_ok = 9;",
                        "if(crush_ok != 7 && ~crush_ok && crush_ok != 8)",
                        "{",
                        "    if(!crush_ok)",
                        "    {",
                        "        if(HullSpecial(Player()) != -1)",
                        "        {",
                        "            //SFT(HullSpecial(Player()));",
                        "            if(!findsubstr(BonusNumInCfg(HullSpecial(Player())), 'ExpScienceRanks_Tick'))",
                        "            {",
                        "                if(ShipInHole(Player()))",
                        "                {",
                        "                    //Прыжок в любую нормальную ЧД, не ту, которая возвращает игрока в ту же самую систему",
                        "                    if(!crush_ok)",
                        "                    {",
                        "                        if(HoleMap(ShipOrderObj(Player())) != 'SkipAB')",
                        "                        {",
                        "                            if(HoleStar1(ShipOrderObj(Player())) != HoleStar2(ShipOrderObj(Player())))",
                        "                            {",
                        "                                HoleMap(ShipOrderObj(Player()), 'NoEntry');",
                        "",
                        "                                //Создаём корабль-шаблон для добавления в ЧД зондов",
                        "                                cur_ship = BuyTranclucator(PlanetPirateClan(), 0);",
                        "                                ShipOwner(cur_ship, Gaal);",
                        "                                cur_item = ShipItems(cur_ship, 0);",
                        "                                //HullSeries(cur_item, -1);",
                        "                                //SpecialToEquipment(-1, cur_item);",
                        "                                ItemSize(cur_item, GalaxyTechLevel() * 50);",
                        "                                ItemOwner(cur_item, Gaal);",
                        "                                for(j = ShipItems(cur_ship) - 1; j > 0; j = j - 1)",
                        "                                {",
                        "                                    cur_item = ShipItems(cur_ship, j);",
                        "                                    if(ItemType(cur_item) <= t_Engine)",
                        "                                    {",
                        "                                        //SpecialToEquipment(-1, cur_item);",
                        "                                        ItemLevel(cur_item, GalaxyTechLevel());",
                        "                                        ItemSize(cur_item, 15);",
                        "                                        ItemOwner(cur_item, Gaal);",
                        "                                    }",
                        "                                    else FreeItem(GetItemFromShip(cur_ship, j));",
                        "                                }",
                        "                                ShipSpecialBonuses(cur_ship, bonSlotWeapon, 5);",
                        "                                ShipSpecialBonuses(cur_ship, bonMass, -50);",
                        "",
                        "                                //Выдаём им всем дезинтегратор",
                        "                                for(j = 1; j <= 5; j = j + 1)",
                        "                                {",
                        "                                    cur_item = CreateEquipment(t_Weapon11, 15, GalaxyTechLevel(), Gaal);",
                        "                                    AddItemToShip(cur_ship, cur_item);",
                        "                                    ItemIsInUse(cur_item, cur_ship, 1);",
                        "                                }",
                        "",
                        "                                SetName(cur_ship, CT('Script.Mod_ExpSSB.UnidentifiedProbeName'));",
                        "                                ShipType(cur_ship, 'UnidentifiedProbe');",
                        "                                //Устраняем перевес, если он вдруг есть",
                        "                                ShipImproveItems(cur_ship, 0);",
                        "                                Chameleon(cur_ship, 'Ship.Akrin.UnidentifiedProbe');",
                        "",
                        "                                tstr1 = '' + ShipTypeN(cur_ship) + ',' + ShipSubType(cur_ship) + ',' + ShipType(cur_ship) + ',' + ShipName(cur_ship) + ',' + Name(cur_ship) + ',' + ShipOwner(cur_ship);",
                        "                                for(i = 1; i <= 5; i = i + 1)",
                        "                                {",
                        "                                    if(!crush_ok)",
                        "                                    {",
                        "                                        //Создаём и добавляем в дроп к одному зонду квестовый предмет",
                        "                                        crush_ok = 1;",
                        "                                        temp_dword = CreateQuestItem('ExpSSB_UnidentifiedProbesRemnants');",
                        "                                        LinkItemToScript(temp_dword, UnidentifiedProbesRemnants);",
                        "",
                        "                                        ConvertToABShip(cur_ship, 0, 50, 80, tstr1, temp_dword);",
                        "                                    }",
                        "                                    else ConvertToABShip(cur_ship, 0, 50, 80, tstr1);",
                        "                                }",
                        "",
                        "                                ShipDestroy(cur_ship, 1); //Избавляемся от корабля-шаблона",
                        "                                StartAB('ABMap.map_2', 2);",
                        "                            }",
                        "                        }",
                        "                    }",
                        "                }",
                        "            }",
                        "        }",
                        "    }",
                        "",
                        "    if(crush_ok == 1)",
                        "    {",
                        "        if(ShipInNormalSpace(Player()))",
                        "        {",
                        "            crush_ok = 2;",
                        "            Ether(3, '040EDD5D-C8F8-4E10-B3BA-0C8B0AB0FFED', CT(\"Script.Mod_ExpSSB.165\"));",
                        "        }",
                        "    }",
                        "",
                        "    if(crush_ok == 3)",
                        "    {",
                        "        if(search_day == CurTurn())",
                        "        {",
                        "            if(IdToShip(id_base)) Ether(3, 'SSB_Q_T', Format(CT(\"Script.Mod_ExpSSB.164\"),\"<0>\",ruin_name));",
                        "        }",
                        "        if(!IdToShip(id_base))",
                        "        {",
                        "            crush_ok = -1;",
                        "            Ether(5, 'SSB_Q_T_C', Format(CT(\"Script.Mod_ExpSSB.163\"),\"<0>\",ruin_name));",
                        "        }",
                        "    }",
                        "",
                        "    if(crush_ok == 4)",
                        "    {",
                        "        if(search_day <= CurTurn())",
                        "        {",
                        "            crush_ok = -1;",
                        "            Ether(5, 'C4958375-3412-4E34-9D2D-1DF4A436F608', CT(\"Script.Mod_ExpSSB.162\") + Format('<br>') + CT(\"Script.Mod_ExpSSB.161\") + Format('<br>') + Format(CT(\"Script.Mod_ExpSSB.283\"),\"<0>\",StarName(GalaxyStar(temp_star)),\"<1>\",ShipName(Player())) + Format('<br>') + CT(\"Script.Mod_ExpSSB.282\"));",
                        "        }",
                        "    }",
                        "",
                        "    if(crush_ok == 4)",
                        "    {",
                        "        if(Id(ShipStar(Player())) == temp_star && ShipInNormalSpace(Player()))",
                        "        {",
                        "            crush_ok = 5;",
                        "            for(i = 0; i < StarHoles(ShipStar(Player())); i = i + 1)",
                        "            {",
                        "                temp_dword = StarHoles(ShipStar(Player()), i);",
                        "                if(Id(temp_dword) == hole_id) OrderMove(Player(), HoleX1(temp_dword), HoleY1(temp_dword));",
                        "            }",
                        "        }",
                        "    }",
                        "",
                        "    if(crush_ok == 5)",
                        "    {",
                        "        if(ShipOrder(Player()) == 4)",
                        "        {",
                        "            if(Id(ShipOrderObj(Player())) == hole_id && ShipInHole(Player()))",
                        "            {",
                        "                if(crush_ok == 5)",
                        "                {",
                        "                    for(i = 0; i <= 2; i = i + 1)",
                        "                    {",
                        "                        CreateABShip('Ship.X.0', 0, 100, 30);",
                        "                        CreateABShip('Ship.X.1', 0, 100, 50);",
                        "                    }",
                        "",
                        "                    //OrderJumpHole(Player(), ShipOrderObj(Player()), 2);",
                        "                    CreateABShip('Ship.X.2', 0, 100, 75);",
                        "                    CreateABShip('Ruins.SSB_licensed', 1, 300, 100, 'SSB');",
                        "                    StartAB('ABMap.map_2', 2);",
                        "                    crush_ok = 4;",
                        "                }",
                        "",
                        "                if(crush_ok == 4)",
                        "                {",
                        "                    cur_hole = ShipOrderObj(Player());",
                        "                    cur_ruin = BuildCustomRuins(GalaxyStar(temp_star - 1), 'SSB_licensed', 5);",
                        "                    ShipPilotRace(cur_ruin, Gaal);",
                        "                    ShipOwner(cur_ruin, Gaal);",
                        "                    ShipFace(cur_ruin, 'New');",
                        "                    ShipJoin(SSBGroup, cur_ruin);",
                        "                    ShipSetCoords(cur_ruin, HoleX1(cur_hole), HoleY1(cur_hole));",
                        "                    id_base = Id(cur_ruin);",
                        "                    SetName(cur_ruin, 'X24 - 0.547');",
                        "                    NoTargetToShip(cur_ruin, 1);",
                        "                    ShipOwner(cur_ruin, 4);",
                        "",
                        "                    //Запрещаем автообновление магазинов ППБ",
                        "                    NoShopUpdate(cur_ruin, 1);",
                        "                    //Очищаем магазины",
                        "                    for(i = ShopItems(cur_ruin) - 1; i >= 0; i = i - 1) FreeItem(GetItemFromShop(cur_ruin, i));",
                        "                    for(i = t_Food; i <= t_Narcotics; i = i + 1) GoodsAdd(cur_ruin, i, -GoodsAdd(cur_ruin, i, 0));",
                        "",
                        "                    ShipAddCustomShipInfo(cur_ruin, 'ShipImmortalInfo', 'NoShow');",
                        "",
                        "                    OrderJumpHole(cur_ruin, cur_hole, 10);",
                        "                    ShipOrderData1(cur_ruin, 1);",
                        "                    crush_ok = 6;",
                        "                }",
                        "            }",
                        "        }",
                        "    }",
                        "",
                        "    if(crush_ok == 6)",
                        "    {",
                        "        cur_ruin = GroupToShip(SSBGroup);",
                        "        if(!AB_base)",
                        "        {",
                        "            for(i = GalaxyEvents() - 1; i >= 0; i = i - 1)",
                        "            {",
                        "                if(GalaxyEventDate(i) < CurTurn() - 4) break;",
                        "                if(GalaxyEventType(i) == 'LabeledShipKilledInAB')",
                        "                {",
                        "                    if(GalaxyEventsTextData(i, 0) == 'SSB') AB_base = 1;",
                        "                }",
                        "            }",
                        "            if(AB_base)",
                        "            {",
                        "                Ether(5, 'C4958375-3412-4E34-9D2D-1DF4A436F608', CT(\"Script.Mod_ExpSSB.162\") + Format('<br>') + CT(\"Script.Mod_ExpSSB.161\") + Format('<br>') + Format(CT(\"Script.Mod_ExpSSB.283\"),\"<0>\",StarName(GalaxyStar(temp_star)),\"<1>\",ShipName(Player())) + Format('<br>') + CT(\"Script.Mod_ExpSSB.282\"));",
                        "                //ShipDestroy(IdToShip(id_base), 1);",
                        "                TransferShip(cur_ruin, StarPlanets(GalaxyStar(2), 0));",
                        "                crush_ok = -1;",
                        "            }",
                        "        }",
                        "",
                        "        if(cur_ruin)",
                        "        {",
                        "            if(ShipInNormalSpace(Player()) && ShipInNormalSpace(cur_ruin) && !AB_base)",
                        "            {",
                        "                while(ShipFreeSpace(Player()) < 0)",
                        "                {",
                        "                    temp_float = (RndObject(0, 360, cur_ruin) * pi) / 180.0;",
                        "                    temp_dword = GetItemFromShip(Player(), ShipItems(Player()) - 1);",
                        "                    DropItemInSystem(ShipStar(Player()), temp_dword, CoordX(Player()), CoordY(Player()), CoordX(Player()) + 100.0 * sin(temp_float), CoordY(Player()) - 100.0 * cos(temp_float));",
                        "                    ShipCalcParam(Player());",
                        "                }",
                        "",
                        "                OrderLanding(Player(), cur_ruin, 10);",
                        "                OrderLock(Player(), 1);",
                        "                back_4d = CurTurn() + 5;",
                        "                crush_ok = 7;",
                        "            }",
                        "        }",
                        "    }",
                        "}",
                        "else if(crush_ok == 8)",
                        "{",
                        "    cur_ruin = GroupToShip(SSBGroup);",
                        "    if(cur_ruin)",
                        "    {",
                        "        //Выгоняем игрока с ППБ",
                        "        if(CurTurn() == back_4d - 1)",
                        "        {",
                        "            if(GetShipRuins(Player()) == cur_ruin)",
                        "            {",
                        "                NoLanding(IdToShip(cur_ruin), 1);",
                        "                ExtremalTakeOff();",
                        "            }",
                        "        }",
                        "        //Пришло время увести ППБ обратно в гипер после первого диалога с игроком",
                        "        else if(CurTurn() == back_4d)",
                        "        {",
                        "            cur_hole = HoleCreate2(ShipStar(cur_ruin), ShipStar(cur_ruin));",
                        "            HoleX1(cur_hole, CoordX(cur_ruin));",
                        "            HoleY1(cur_hole, CoordY(cur_ruin));",
                        "            HoleX2(cur_hole, CoordX(cur_ruin));",
                        "            HoleY2(cur_hole, CoordY(cur_ruin));",
                        "            HoleMap(cur_hole, 'NoEntry');",
                        "            OrderJumpHole(cur_ruin, cur_hole, 10);",
                        "            OrderLock(cur_ruin, 1);",
                        "            blow = 1;",
                        "        }",
                        "",
                        "        //Завершение события встречи с игроком",
                        "        if(ShipInHole(cur_ruin) && blow)",
                        "        {",
                        "            //ShipDestroy(cur_ruin, 1);",
                        "            TransferShip(cur_ruin, StarPlanets(GalaxyStar(People), 0)); //На Меркурий",
                        "            blow = 0;",
                        "            crush_ok = 9;",
                        "            FirstMeetingComplete = 1;",
                        "        }",
                        "    }",
                        "}",
                        "",
                        "if(4d_turn)",
                        "{",
                        "    cur_ruin = GroupToShip(SSBGroup);",
                        "    if(CurTurn() >= 4d_turn)",
                        "    {",
                        "        if(cur_ruin)",
                        "        {",
                        "            //ShipDestroy(cur_ruin, 1);",
                        "            4d_turn = 0;",
                        "            HoleTurnCreate(ShipOrderObj(cur_ruin), 0);",
                        "            TransferShip(cur_ruin, StarPlanets(GalaxyStar(2), 0));",
                        "        }",
                        "    }",
                        "",
                        "    if(cur_ruin && 4d_turn)",
                        "    {",
                        "        if(ShipInHole(cur_ruin))",
                        "        {",
                        "            if(ShipInHole(Player()) && ShipOrderObj(Player()) == ShipOrderObj(cur_ruin))",
                        "            {",
                        "                TransferShip(Player(), cur_ruin);",
                        "                ShipOrder(cur_ruin, 0);",
                        "                4d_turn = 0;",
                        "            }",
                        "        }",
                        "    }",
                        "}"
                    ],
                    "#": 62,
                    "Type": "Top",
                    "Parent": -1,
                    "Pos.x": 120,
                    "Pos.y": 810
                },
                {
                    "Name": "",
                    "Code.Type": "DialogBegin",
                    "Code": [
                        "cur_ship = GetTalkShip();",
                        "if(cur_ship)",
                        "{",
                        "    if(ShipType(cur_ship) == 'SSB_licensed')",
                        "    {",
                        "        AddDialogOverride('OpenSpaceDialogSSB', 100);",
                        "    }",
                        "}",
                        "else",
                        "{",
                        "    cur_ruin = GetShipRuins(Player());",
                        "    if(cur_ruin)",
                        "    {",
                        "        tstr1 = Format(ShipType(cur_ruin), '_licensed', '', '');",
                        "        if(tstr1 == 'SB')",
                        "        {",
                        "            if(crush_ok == 2)",
                        "            {",
                        "                if(ItemIn(UnidentifiedProbesRemnants, Player()))",
                        "                {",
                        "                    AddDialogInject('DialogSB', '', CT(\"Script.Mod_ExpSSB.156\"), 1);",
                        "                }",
                        "            }",
                        "            else if(crush_ok == 3)",
                        "            {",
                        "                if(search_day <= CurTurn())",
                        "                {",
                        "                    if(Id(GetShipRuins(Player())) == id_base)",
                        "                    {",
                        "                        AddDialogInject('DialogSB', '', CT(\"Script.Mod_ExpSSB.155\"), 1);",
                        "                    }",
                        "                }",
                        "            }",
                        "        }",
                        "        else if(tstr1 == 'SSB')",
                        "        {",
                        "            if(crush_ok == 7)",
                        "            {",
                        "                OrderLock(Player(), 0);",
                        "                GotoGov(2);",
                        "                AddDialogOverride('FirstArrivalOverrideSSB', 100);",
                        "            }",
                        "            else",
                        "            {",
                        "                //Диалог при первом появлении игрока на ППБ",
                        "                if(!FirstMeetingComplete)",
                        "                {",
                        "                    tstr1 = '';",
                        "                    tint1 = back_4d - CurTurn() - 1;",
                        "                    if(tint1 == 1) tstr1 = '</color>' + CT(\"Script.Mod_ExpSSB.266\");",
                        "                    else if(tint1 == 2) tstr1 = '</color>' + CT(\"Script.Mod_ExpSSB.267\");",
                        "                    else if(tint1 == 3) tstr1 = '</color>' + CT(\"Script.Mod_ExpSSB.268\");",
                        "",
                        "                    //Добавляем приветственную реплику",
                        "                    AddDialogBlock(CT('FormRuins.GN.Modern.PlayerAsk'), 2); //\"Я желаю поучаствовать в развитии вашей базы\"",
                        "                    AddDialogBlock('IntroText', 2);",
                        "                    AddDialogInject('IntroText', tstr1, 'IntroText', 1000, 1);",
                        "",
                        "                    //Обычный взлёт",
                        "                    AddDialogInject('LeaveBaseDialogSSB', '', CT(\"Script.Mod_ExpSSB.271\"), 10, 0, 0, 'ExtremalTakeOff();FormChange(\\\\\\'RuinsTalk\\\\\\');');",
                        "",
                        "                    //Подпространственное перемещение игрока в желаемую систему",
                        "                    //AddDialogInject('HyperTransferDialogSSB', '', \"Подпространственное перемещение\", 5);",
                        "                }",
                        "                //Диалог при всех последующих появлениях игрока на ППБ",
                        "                else /*if(FirstMeetingComplete)*/",
                        "                {",
                        "                     tstr1 = '</color>' + CT(\"Script.Mod_ExpSSB.278\");",
                        "",
                        "                    //Добавляем приветственную реплику",
                        "                    AddDialogBlock(CT('FormRuins.GN.Modern.PlayerAsk'), 2); //\"Я желаю поучаствовать в развитии вашей базы\"",
                        "                    AddDialogBlock('IntroText', 2);",
                        "                    AddDialogInject('IntroText', tstr1, 'IntroText', 1000, 1);",
                        "",
                        "                    //Сдача артефактов на исследования",
                        "                    if(1)",
                        "                    {",
                        "                        //Сперва проверяем, что не все доступные исследования завершены",
                        "                        tint1 = 0;",
                        "                        for(i = 0; i < 11; i = i + 1)",
                        "                        {",
                        "                            if(cur_art_sb2_srch_type[i] >= 100) tint1 = tint1 + 1;",
                        "                        }",
                        "",
                        "                        if(tint1 < 11)",
                        "                        {",
                        "                            AddDialogInject('HandOverArtsDialogSSB', '', CT(\"Script.Mod_ExpSSB.286\"), 60);",
                        "                        }",
                        "                    }",
                        "",
                        "                    //Вопрос об исследовании сданных артефактов с целью получения подарка",
                        "                    if(1)",
                        "                    {",
                        "                        if(gift != 6)",
                        "                        {",
                        "                            temp_int_1 = 0;",
                        "                            for(i = 0; i < 11; i = i + 1)",
                        "                            {",
                        "                                if(cur_art_sb2_srch_type[i] > 0)",
                        "                                {",
                        "                                    temp_int_1 = temp_int_1 + cur_art_sb2_srch_type[i];",
                        "                                }",
                        "                            }",
                        "",
                        "                            temp_int_1 = temp_int_1 / 11;",
                        "                            if(gift == 0 && temp_int_1 >= 33) gift = 1;",
                        "                            if(gift == 2 && temp_int_1 >= 66) gift = 3;",
                        "                            if(gift == 4 && temp_int_1 == 100) gift = 5;",
                        "                        }",
                        "",
                        "                        if(gift == 1 || gift == 3 || gift == 5)",
                        "                        {",
                        "                            AddDialogInject('AboutArtStudiesDialogSSB', '', CT(\"Script.Mod_ExpSSB.285\"), 59);",
                        "                        }",
                        "                    }",
                        "",
                        "                    //Модернизация уровня корпуса \"Клеща\"",
                        "                    if(~HullSpecial(Player()) && cur_art_sb2_srch_type[0] == 100)",
                        "                    {",
                        "                        if(ItemLevel(ShipItems(Player(), 0)) < GalaxyTechLevel() && !findsubstr(BonusNumInCfg(HullSpecial(Player())), 'ExpScienceRanks_Tick'))",
                        "                        {",
                        "                            AddDialogInject('TickHullUpgradeDialogSSB', '', CT(\"Script.Mod_ExpSSB.207\"), 50);",
                        "                        }",
                        "                    }",
                        "",
                        "                    //Улучшение артефактов",
                        "                    if(1)",
                        "                    {",
                        "                        tint2 = 0;",
                        "                        bon_num = FindBonusByNameInCfg('ExpSSB_Fragility20Plus');",
                        "                        for(i = 0; i < ShipArts(Player()); i = i + 1)",
                        "                        {",
                        "                            cur_bh_item = ShipArts(Player(), i);",
                        "                            //Исключаем скриптовые артефакты",
                        "                            if(ItemInScript(cur_bh_item) == 1)",
                        "                            {",
                        "                                if(~EqSpecial(cur_bh_item))",
                        "                                {",
                        "                                    //Но добавляем в список на сдачу артефакты с особым параметров в акрине (на них можно повесить акрин, да)",
                        "                                    if(!CT('MicroModuls.' + BonusNumInCfg(EqSpecial(cur_bh_item)) + '.ScriptItemIgnore')) continue;",
                        "                                }",
                        "                                else continue;",
                        "                            }",
                        "",
                        "                            tint1 = ItemType(cur_bh_item);",
                        "                            if(tint1 <  t_ArtefactHull) continue;",
                        "                            if(tint1 == t_ArtefactTranclucator) continue;",
                        "                            if(tint1 == t_ArtefactBomb) continue;",
                        "                            if(tint1 == t_ArtefactTransmitter) continue;",
                        "                            if(tint1 == t_ArtDefToArms1) continue;",
                        "                            if(tint1 == t_ArtDefToArms2) continue;",
                        "                            if(tint1 == t_ArtArtefactor) continue;",
                        "                            if(ItemExtraSpecialsCountByType(cur_bh_item, bon_num)) continue;",
                        "                            tint2 = 1;",
                        "                            break;",
                        "                        }",
                        "",
                        "                        tstr1 = CT(\"Script.Mod_ExpSSB.147\");",
                        "                        if(!tint2) AddDialogBlock(tstr1, 1);",
                        "                        AddDialogInject('ArtefactImproveDialogSSB', '', tstr1, 40);",
                        "                    }",
                        "",
                        "                    //Совмещение ММ с оборудованием (а что это вообще?)",
                        "                    AddDialogInject('CombiningMMDialogSSB', '', CT(\"Script.Mod_ExpSSB.284\"), 30);",
                        "",
                        "                    //Подпространственное перемещение игрока в желаемую систему",
                        "                    AddDialogInject('HyperTransferDialogSSB', '', CT(\"Script.Mod_ExpSSB.225\"), 20);",
                        "",
                        "                    //Покидание ППБ (обработка \"взлёта\" в момент нахождения базы в гипере)",
                        "                    AddDialogInject('LeaveBaseDialogSSB', '', CT(\"Script.Mod_ExpSSB.271\"), 10);",
                        "                }",
                        "            }",
                        "        }",
                        "    }",
                        "}"
                    ],
