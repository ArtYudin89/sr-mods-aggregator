                        "    if(ShipMoney(Player())>=ItemCost(cur_bh_item)*3)InjectAnswer('ArtefactImproveRunDialogSSB',DeleteTags(Format('<0> ',\"<0>\",ItemFullName(cur_bh_item)))+Format('(<0> cr).',\"<0>\",ItemCost(cur_bh_item)*3),cur_bh_item);",
