                        "        if(ItemType(cur_bh_item)==cur_art_sb2[j] && cur_art_sb2_srch[j]<100)",
                        "        {",
                        "            temp_int=temp_int+1;",
                        "        }",
                        "    }",
                        "}",
                        "",
                        "if(temp_int >= 2) InjectAnswer('HandOverAllArtsDialogSSB', DeleteTags(CT(\"Script.Mod_ExpSSB.157\")), 1);",
                        "",
                        "for(i = 0; i < ShipArts(Player()); i = i + 1)",
                        "{",
                        "    cur_bh_item = ShipArts(Player(), i);",
                        "    //Исключаем скриптовые артефакты",
                        "    if(ItemInScript(cur_bh_item) == 1)",
                        "    {",
                        "        if(~EqSpecial(cur_bh_item))",
                        "        {",
                        "            //Но добавляем в список на сдачу артефакты с особым параметров в акрине (на них можно повесить акрин, да)",
                        "            if(!CT('MicroModuls.' + BonusNumInCfg(EqSpecial(cur_bh_item)) + '.ScriptItemIgnore')) continue;",
                        "        }",
                        "        else continue;",
                        "    }",
                        "",
                        "    //if(ItemIsInUse(cur_bh_item) || ItemIsInSet(cur_bh_item)) continue;",
                        "    if(ItemExtraSpecialsCountByType(cur_bh_item, temp_int_3) > 0) continue;",
                        "",
                        "    for(j = 0; j <= 29; j = j + 1)",
                        "    {",
                        "        if(ItemType(cur_bh_item) == cur_art_sb2[j] && cur_art_sb2_srch[j] < 100)",
                        "        {",
                        "            InjectAnswer('HandOverOneArtDialogSSB', DeleteTags(Format('<0>',\"<0>\",ItemFullName(cur_bh_item))), cur_bh_item);",
                        "        }",
                        "    }",
                        "}",
                        "",
                        "DAnswer('restart~' + CT(\"Script.Mod_ExpSSB.144\"));"
