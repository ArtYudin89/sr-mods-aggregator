                {
                    "Name": "",
                    "Code.Type": "Turn",
                    "Code": [
                        "//Если игрок запросил доступ на ППБ",
                        "if(UselessItemData(cur_bh_item, 1) < 1000) temp_str = CT(\"Script.Mod_ExpSSB.238\");",
                        "else",
                        "{",
                        "    UselessItemData(cur_bh_item, 1, 0);",
                        "    UselessItemData(cur_bh_item, 3, CurTurn() + 11);",
                        "    cur_ruin = GroupToShip(SSBGroup);",
                        "    if(!cur_ruin) throw 'Error! SSB was somehow destroyed!';",
                        "",
                        "    cur_hole = HoleCreate2(ShipStar(Player()), ShipStar(cur_ruin));",
                        "    HoleTurnCreate(cur_hole, HoleTurnCreate(cur_hole) - 198);",
                        "    HoleMap(cur_hole, 'SkipAB');",
                        "    PlayerTransCoordX = CoordX(Player()) + RndObject(-100, 100, cur_ruin);",
                        "    PlayerTransCoordY = CoordY(Player()) + RndObject(-100, 100, cur_ruin);",
                        "    HoleX1(cur_hole, PlayerTransCoordX);",
                        "    HoleY1(cur_hole, PlayerTransCoordY);",
                        "    HoleX2(cur_hole, CoordX(cur_ruin));",
                        "    HoleY2(cur_hole, CoordY(cur_ruin));",
                        "",
                        "    if(CoordX(Player()) >= -300 && CoordX(Player()) <= 300 && CoordY(Player()) >= -300 && CoordY(Player()) <= 300)",
                        "    {",
                        "        HoleX1(cur_hole, CoordX(Player()) - 300);",
                        "        HoleY1(cur_hole, CoordY(Player()) + 300);",
                        "    }",
                        "    MakeShipEnterStar(cur_ruin, ShipStar(Player()), ShipStar(cur_ruin), 1);",
                        "    OrderJumpHole(cur_ruin, cur_hole, 10);",
                        "    ShipOrderData1(cur_ruin, 50);",
                        "    OrderLock(cur_ruin, 1);",
                        "    4d_turn = CurTurn() + 2;",
                        "    temp_str = CT(\"Script.Mod_ExpSSB.272\");",
                        "}",
                        "DChange(18);",
                        "exit;"
