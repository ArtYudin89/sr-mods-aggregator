                        "            if(ItemType(cur_bh_item)>=t_Weapon1 )",
                        "            {",
                        "                if(ItemLevel(cur_bh_item)==1)temp_str=' A';",
                        "                else if(ItemLevel(cur_bh_item)==2)temp_str=' B';",
                        "                else if(ItemLevel(cur_bh_item)==3)temp_str=' C';",
                        "                else if(ItemLevel(cur_bh_item)==4)temp_str=' D';",
                        "                else if(ItemLevel(cur_bh_item)==5)temp_str=' E';",
                        "                else if(ItemLevel(cur_bh_item)==6)temp_str=' F';",
                        "                else if(ItemLevel(cur_bh_item)==7)temp_str=' G';",
                        "                else if(ItemLevel(cur_bh_item)==8)temp_str=' H';",
                        "                InjectAnswer('CombiningMMChooseDialogSSB',DeleteTags(Format('<0>',\"<0>\",Name(cur_bh_item))+temp_str+CT(\"Script.Mod_ExpSSB.158\")),cur_bh_item);",
                        "            }",
                        "        }",
                        "    }",
                        "}",
