            "Items": [],
            "Operations": [
                {
                    "Name": "",
                    "Code.Type": "Global",
                    "Code": [
                        "GRun();"
                    ],
                    "#": 14,
                    "Type": "Top",
                    "Parent": -1,
                    "Pos.x": 0,
                    "Pos.y": 610
                },
                {
                    "Name": "",
                    "Code.Type": "DialogBegin",
                    "Code": [
                        "if(GetShipRuins(Player())>0) {",
                        "  if(!PlayerBridge()) {",
                        "    if(mmwb==0) {",
                        "      if(ShipType(GetShipRuins(Player()))=='WB') {",
                        "        if(ShipStatistic(Player(),1)+ShipStatistic(Player(),2)-ShipStatistic(Player(),5)>=300 && ShipRank(Player())>=4) {",
                        "          module_num=FindBonusByNameInCfg('EvoMMUnique_Relicter');",
                        "          module_name=BonusName(module_num);",
                        "          module_cost=16140*GalaxyTechLevel()+GalaxyMoney(4,4);",
                        "          AddDialogInject('DialogWBSuperModule',Format(CT(\"Script.Mod_EvoMMUnique.23\"),\"<0>\",module_name),CT(\"Script.Mod_EvoMMUnique.0\"),1);",
                        "        }",
                        "      }",
                        "    }",
                        "  }",
                        "}",
                        "if(GetShipRuins(Player())>0) {",
                        "  if(!PlayerBridge()) {",
                        "    if(mmrc==0) {",
                        "      if(ShipType(GetShipRuins(Player()))=='RC') {",
                        "        if(ShipStatistic(Player(),2)-ShipStatistic(Player(),4)-ShipStatistic(Player(),5)-ShipStatistic(Player(),6)>=250) {",
                        "          module_num=FindBonusByNameInCfg('EvoMMUnique_Structurizer');",
                        "          module_name=BonusName(module_num);",
                        "          module_cost=400000+(GalaxyTechLevel()*10000)-(ShipStatistic(Player(),2)*100)-(ShipStatistic(Player(),1)*100)+GalaxyMoney(3,4);",
                        "          AddDialogInject('DialogRCSuperModule',Format(CT(\"Script.Mod_EvoMMUnique.4\"),\"<0>\",module_name),CT(\"Script.Mod_EvoMMUnique.0\"),1);",
                        "        }",
                        "      }",
                        "    }",
                        "  }",
                        "}",
                        "if(GetShipRuins(Player())>0) {",
                        "  if(!PlayerBridge()) {",
                        "    if(mmmc==0) {",
                        "      if(ShipType(GetShipRuins(Player()))=='MC') {",
                        "        if(ShipStatistic(Player(),3)>=30) {",
                        "          module_num=FindBonusByNameInCfg('EvoMMUnique_Droiser');",
                        "          module_name=BonusName(module_num);",
                        "          module_cost=400000+(GalaxyTechLevel()*10000)-(ShipRank(Player())*1000)-(ShipStatistic(Player(),3)*1000)+GalaxyMoney(3,4);",
                        "          AddDialogInject('DialogMCSuperModule',Format(CT(\"Script.Mod_EvoMMUnique.3\"),\"<0>\",module_name),CT(\"Script.Mod_EvoMMUnique.0\"),1);",
                        "        }",
                        "      }",
                        "    }",
                        "  }",
                        "}",
                        "if(GetShipRuins(Player())>0) {",
                        "  if(!PlayerBridge()) {",
                        "    if(mmsb==0) {",
                        "      if(ShipType(GetShipRuins(Player()))=='SB') {",
                        "        if(GalaxyTechLevel()>=6 && GetShipExpByType(Player(),1)>50000) {",
                        "          module_num=FindBonusByNameInCfg('EvoMMUnique_Rediarcher');",
                        "          module_name=BonusName(module_num);",
                        "          module_cost=16140*GalaxyTechLevel()+GalaxyMoney(4,4);",
                        "          AddDialogInject('DialogSBSuperModule',Format(CT(\"Script.Mod_EvoMMUnique.18\"),\"<0>\",module_name),CT(\"Script.Mod_EvoMMUnique.0\"),1);",
                        "        }",
                        "      }",
                        "    }",
                        "  }",
                        "}",
                        "if(GetShipRuins(Player())>0) {",
                        "  if(!PlayerBridge()) {",
                        "    if(mmpb==0) {",
                        "      if(ShipType(GetShipRuins(Player()))=='PB') {",
                        "        if(ShipStatistic(Player(),4)+ShipStatistic(Player(),5)-ShipStatistic(Player(),1)*2>=300 && ShipStatus(Player(),1)>=100) {",
                        "          module_num=FindBonusByNameInCfg('EvoMMUnique_Demplifier');",
                        "          module_name=BonusName(module_num);",
                        "          module_cost=300000+(GalaxyTechLevel()*50000)-(GetShipPirateRank(Player())*1000)-(ShipStatistic(Player(),5)*1000)+GalaxyMoney(3,4);",
                        "          AddDialogInject('DialogPBSuperModule',Format(CT(\"Script.Mod_EvoMMUnique.1\"),\"<0>\",module_name),CT(\"Script.Mod_EvoMMUnique.0\"),1);",
                        "        }",
                        "      }",
                        "    }",
                        "  }",
                        "}",
                        "if(GetShipRuins(Player())>0) {",
                        "  if(!PlayerBridge()) {",
                        "    if(mmbk==0) {",
                        "      if(ShipType(GetShipRuins(Player()))=='BK') {",
                        "        if(ShipStatus(Player(),0)>=100 && GetShipExpByType(Player())>=10000) {",
                        "          module_num=FindBonusByNameInCfg('EvoMMUnique_Enricher');",
                        "          module_name=BonusName(module_num);",
                        "          module_cost=16140*GalaxyTechLevel()+ShipWealth(Player())/10+GalaxyMoney(3,4);",
                        "          AddDialogInject('DialogBKSuperModule',Format(CT(\"Script.Mod_EvoMMUnique.17\"),\"<0>\",module_name),CT(\"Script.Mod_EvoMMUnique.0\"),1);",
                        "        }",
                        "      }",
                        "    }",
                        "  }",
                        "}"
                    ],
