                    "Code": [
                        "if(GetProgramm(11) && GetProgramm(5)) {",
                        "  DAdd(49);",
                        "}",
                        "if(!GetProgramm(11) || !GetProgramm(5)) {",
                        "  DAdd(50);",
                        "}",
                        "DAdd(0);"
                    ],
                    "#": 174,
                    "Type": "Top",
                    "Parent": -1,
                    "Pos.x": 280,
                    "Pos.y": 495
                },
                {
                    "Name": "",
                    "Code.Type": "Turn",
                    "Code": [
                        "FreeItem(GetItemFromShip(Player(),tdw2));",
                        "for (i=0; i<ShipItems(GroupToShip(TrancGroup)); i=i+1) {",
                        "    tdw=ShipItems(GroupToShip(TrancGroup),i);",
                        "    ItemDurability(tdw,0);",
                        "    if(Rnd(1,5)==5) ShipAddDropItem(GroupToShip(TrancGroup),tdw);",
                        "}",
                        "for (i=0; i<ShipArts(GroupToShip(TrancGroup));i=i+1) {",
                        "    tdw=ShipArts(GroupToShip(TrancGroup),i);",
                        "    ItemDurability(tdw,0);",
                        "    if(Rnd(1,3)==3) ShipAddDropItem(GroupToShip(TrancGroup),tdw);",
                        "}",
                        "trancDstate=2;",
                        "trancSdTimer = trancSdTimer + 365;",
                        "DAdd(3);"
                    ],
