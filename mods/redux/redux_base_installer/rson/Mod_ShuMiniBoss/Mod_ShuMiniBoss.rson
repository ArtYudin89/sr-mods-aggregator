                {
                    "Name": "",
                    "Code.Type": "Turn",
                    "Code": [
                        "for (i=1; i<ShipItems(Player()); i=i+1) {",
                        "    tdw=ShipItems(Player(),i);",
                        "    if (ItemType(tdw)==t_UselessItem && Name(tdw)==CT(\"Script.Mod_ShuMiniBoss.18\")){ tdw2=i; break; }",
                        "    else tdw2=0;",
                        "}",
                        "if(!tdw2) {",
                        "  DAdd(1);",
                        "}",
                        "if(tdw2) {",
                        "  DAdd(2);",
                        "}",
                        "DAdd(4);"
                    ],
