            "Operations": [
                {
                    "Name": "",
                    "Code.Type": "Global",
                    "Code": [
                        "if(!GCntRun(GScriptName)) GRun();"
                    ],
                    "#": 44,
                    "Type": "Top",
                    "Parent": -1,
                    "Pos.x": 0,
                    "Pos.y": 760
                },
                {
                    "Name": "",
                    "Code.Type": "Init",
                    "Code": [
                        "diffBonus=GalaxyDiffLevels()/50; //Влияет на количество дополнительных врагов в функциях SpawnSquad, SpawnDomiks",
                        "trancType=Rnd(0,2); //Тип безумного транклюкатора. 0 - ракетный, 1,2 - обычный",
                        "eliteSqType=Rnd(0,2); //Тип элитных наемников. 0 - ракетный, 1,2 - обычный",
                        "eliteSqTimer=Rnd(5193,6845); //Таймер появления элитных наемников",
                        "jackTimer=Rnd(2855,3150); //Таймер появления Безбашенного Джека",
                        "bolideTimer=Rnd(3650,5800); //Таймер появления рейнджера на болиде",
                        "marauderTimer=Rnd(3850,4530); //Таймер появления мародёра",
                        "ArrayClear(tArr); //Очистка массива",
                        "//Функция выбора случайной коалиционной планеты.",
                        "//Возвращает указатель на планету, либо 0.",
                        "function SelectPlanet() {",
                        "    dword planet, tStar;",
                        "    int i,j;",
                        "    for(i=0;i<GalaxyStars();i=i+1) {",
                        "        tStar=GalaxyStar(i);",
                        "        if(StarBattle(tStar)) continue; //Пропуск оспариваемых систем",
                        "        if(StarOwner(tStar)) continue; //Пропуск некоалиционных систем",
                        "        for(j=0;j<StarPlanets(tStar);j=j+1) {",
                        "            planet=StarPlanets(tStar,j);",
                        "            ",
                        "            if(PlanetOwner(planet)==Kling) continue;",
                        "            if(PlanetOwner(planet)==None) continue;",
                        "",
                        "            ArrayAdd(tArr,planet);",
                        "        }",
                        "    }",
                        "    if(ArrayDim(tArr)<=1) planet=0; //Если в массиве нет подходящих планет, возвращаем 0",
                        "    else planet=tArr[Rnd(1,ArrayDim(tArr)-1)]; //Случайный выбор",
                        "    ArrayClear(tArr);",
                        "    result=planet;",
                        "}",
                        "//Функция создания безумного транклюкатора",
                        "function BuyMadTranc(dword spawnPlanet, dword trancType) {",
                        "    int i;",
                        "    dword tdw, acrynLevel, tChance;",
                        "    dword ship=BuyTranclucator(spawnPlanet,0);",
                        "    ItemSize(ShipItems(ship,0),100*GalaxyTechLevel()+Rnd(9,43));",
                        "    HullHP(ship,'To100');",
                        "    Chameleon(ship);",
                        "    ShipJoin(TrancGroup,ship);",
                        "    ShipMoney(ship,1000000);",
                        "    for(i=0;i<10;i=i+1) ShipRefit(ship);",
                        "    for(i=0;i<3;i=i+1) ShipSkill(ship,i,2+diffBonus/2);",
                        "    for(i=0;i<2;i=i+1) {",
                        "        tdw=CreateMM(FindBonusByNameInCfg('204')); //Универс",
                        "        ShipAddDropItem(ship,tdw);",
                        "    }",
                        "    //Выдаем радар, сканер",
                        "    //Это пиздец, а не сканер и радар. Вы количество дамага хоть видели?!",
                        "    ShipSpecialBonuses(ship,bonSlotRadar,1);",
                        "    tdw=CreateEquipment(t_Radar,25,GalaxyTechLevel(),Rnd(0,4));",
                        "    AddItemToShip(ship,tdw);",
                        "    ItemIsInUse(tdw,ship,1);",
                        "    ShipSpecialBonuses(ship,bonSlotScaner,1);",
                        "    tdw=CreateEquipment(t_Scaner,25,GalaxyTechLevel(),Rnd(0,4));",
                        "    AddItemToShip(ship,tdw);",
                        "    ItemIsInUse(tdw,ship,1);",
                        "    //Акринация оборудования",
                        "    if(GalaxyTechLevel()<=5 && GalaxyDiffLevels()<=150) acrynLevel=0;",
                        "    else acrynLevel=1;",
                        "    EqAcrynation(ship,trancType,acrynLevel);",
                        "    tChance=50; //Шанс на дроп артефакта после смерти",
                        "    if(Rnd(1, 1000) >= (500 + GalaxyDiffLevels())) GiveArt(ship,t_ArtefactSpeed,tChance); //Пси-ускоритель",
                        "    if(Rnd(1, 1000) >= (500 + GalaxyDiffLevels())) GiveArt(ship,t_ArtefactAntigrav,tChance); //Антигравитатор",
                        "    //Ракетный транк. Выдаем ракетометы и ралс + проглот",
                        "    if(!trancType) {",
                        "        for(i=1;6>i;i=i+1) {",
                        "            while(ShipCntWeapon(ship)) FreeItem(GetItemFromShip(ship,ShipWeapon(ship,1)));",
                        "        }",
                        "        for(i=0;i<ShipSlots(ship,1);i=i+1) {",
                        "            tdw=CreateEquipment(t_Weapon4,Rnd(20,40),GalaxyTechLevel(),6);",
                        "            AddItemToShip(ship,tdw);",
                        "            ItemIsInUse(tdw,ship,1);",
                        "        }",
                        "        GiveArt(ship,t_ArtEnergyDef,tChance);",
                        "    }",
                        "    //Осколочный/энергетический. Выдаем убиватора и жупи + младшего дроида",
                        "    else {",
                        "        GiveArt(ship,t_ArtefactHull,tChance);",
                        "        GiveArt(ship,t_ArtefactDroid,tChance);",
                        "        if(IsScriptActive('Mod_RevAcryn') && GalaxyDiffLevels()>=250) SpecialToEquipment(FindBonusByNameInCfg('RevAcryn_Ubivator7'),ShipEqInSlot(ship,t_Radar));",
                        "    }",
                        "    //Улучшение оборудования, проверка на перевес",
                        "    EqTLUpgrade(ship);",
                        "    //ShipImproveItems(ship,3*GalaxyTechLevel()); а хрен там, это полный квардец",
                        "    GiveFreeSpace(ship);",
                        "    //На всякий случай принудительно одеваем транку все оборудование",
                        "    for(i=1;i<ShipItems(ship);i=i+1) {",
                        "        if(!ItemIsInUse(ShipItems(ship,i))) ItemIsInUse(ShipItems(ship,i),ship,1);",
                        "    }",
                        "    //Выставляем игрока в качестве цели, чиним оборудование",
                        "    ShipSetBad(ship,Player());",
                        "    ShipRepairEq(ship);",
                        "}",
                        "//Функция создания и оснащения элитных охотников за головами",
                        "//Параметр - планета для создания",
                        "//Первый созданный корабль будет рейнджером-главарем, остальные - пиратами",
                        "function SpawnEliteSquad(dword spawnPlanet) {",
                        "    dword ship, tdw, acrynLevel, tChance;",
                        "    int i, j;",
                        "    for(i=0;i<6;i=i+1) {",
                        "        if(!i) {",
                        "            ship=BuyRanger(spawnPlanet,1000);",
                        "            ShipSubType(ship, 1); //Характер пирата",
                        "            ShipStatus(ship, 0, 20); //Торговый рейтинг",
                        "            ShipStatus(ship, 1, 60); //Пиратский рейтинг",
                        "            ShipStatus(ship, 2, 20); //Военный рейтинг",
                        "            ShipJoin(SquadLeader,ship);",
                        "            SpecialToEquipment(FindBonusByNameInCfg('360'),ShipItems(ship,0));",
                        "            ShipSkill(ship,5,6);",
                        "        }",
                        "        else {",
                        "            ship=BuyPirate(spawnPlanet,1000);",
                        "            ShipJoin(EliteSquad,ship);",
                        "            if(!eliteSqType) SpecialToEquipment(FindBonusByNameInCfg('372'),ShipItems(ship,0));",
                        "            else SpecialToEquipment(FindBonusByNameInCfg('368'),ShipItems(ship,0));",
                        "        }",
                        "        ItemSize(ShipItems(ship,0),round((0.00085*GalaxyDiffLevels()+1)*GalaxyTechLevel()*100)+Rnd(-25,45));",
                        "        if(ItemSize(ShipItems(ship,0))<250) ItemSize(ShipItems(ship,0),250);",
                        "        HullHP(ship,'To100');",
                        "        Chameleon(ship);",
                        "        for(j=0;j<3;j=j+1) ShipSkill(ship,j,Rnd(4,6));",
                        "        for(j=0;j<10;j=j+1) ShipRefit(ship);",
                        "        //Обязательно выдаем радар, т.к. ракетное оружие",
                        "        ShipSpecialBonuses(ship,bonSlotRadar,1);",
                        "        if(!ShipEqInSlot(ship,t_Radar)) {",
                        "            tdw=CreateEquipment(t_Radar,Rnd(15,50),GalaxyTechLevel(),Rnd(0,4));",
                        "            AddItemToShip(ship,tdw);",
                        "            ItemIsInUse(tdw,ship,1);",
                        "        }",
                        "        //Если в корпусе открыт слот дроида, но самого дроида нет - выдаем",
                        "        if(GetEquipmentStats(ShipItems(ship,0),5)) {",
                        "            if(!ShipEqInSlot(ship,t_RepairRobot)) {",
                        "                tdw=CreateEquipment(t_RepairRobot,Rnd(20,40),GalaxyTechLevel(),Rnd(0,4));",
                        "                AddItemToShip(ship,tdw);",
                        "                ItemIsInUse(tdw,ship,1);",
                        "            }",
                        "        }",
                        "        //Аналогично для ГЗП",
                        "        if(GetEquipmentStats(ShipItems(ship,0),7))  {",
                        "            if(!ShipEqInSlot(ship,t_DefGenerator)) {",
                        "                tdw=CreateEquipment(t_DefGenerator,Rnd(20,40),GalaxyTechLevel(),Rnd(0,4));",
                        "                AddItemToShip(ship,tdw);",
                        "                ItemIsInUse(tdw,ship,1);",
                        "            }",
                        "        }",
                        "        //Ракетное вооружение, пигамарное оборудование",
                        "        if(!eliteSqType) {",
                        "            //Убираем экипированное оружие",
                        "            for(j=1;j<=5;j=j+1) {",
                        "                if(ShipEqInSlot(ship,t_Weapon1,j))",
                        "                    FreeItem(GetItemFromShip(ship,ShipEqInSlot(ship,t_Weapon1,j)));",
                        "            }",
                        "            //Выдаем ракетометы \"торпедо\" или лирекроны",
                        "            if(IsScriptActive('Mod_ShuMM') & Rnd(1,3) != 1) {",
                        "                for(j=0;j<5;j=j+1) {",
                        "                    tdw=CreateCustomWeapon('MissileLauncherTorpedo',Rnd(28,45),GalaxyTechLevel(),4);",
                        "                    if(GalaxyDiffLevels()>249) {",
                        "                        if(GalaxyTechLevel() > 6) ModuleToEquipment(FindBonusByNameInCfg('210'),tdw);",
                        "                        else if(GalaxyTechLevel() < 4) ModuleToEquipment(FindBonusByNameInCfg('23'),tdw);",
                        "                        else ModuleToEquipment(FindBonusByNameInCfg('21'),tdw);",
                        "                        ItemImprovement(tdw,2);",
                        "                    }",
                        "                    SpecialToEquipment(FindBonusByNameInCfg('ShuMM_Torpedo'),tdw);",
                        "                    AddItemToShip(ship,tdw);",
                        "                    ItemIsInUse(tdw,ship,1);",
                        "                }",
                        "            }",
                        "            else {",
                        "                for(j=0;j<5;j=j+1) {",
                        "                    tdw=CreateEquipment(t_Weapon18,Rnd(28,45),GalaxyTechLevel(),7);",
                        "                     if(GalaxyDiffLevels()>249) {",
                        "                        if(GalaxyTechLevel() > 6) ModuleToEquipment(FindBonusByNameInCfg('210'),tdw);",
                        "                        else if(GalaxyTechLevel() < 4) ModuleToEquipment(FindBonusByNameInCfg('23'),tdw);",
                        "                        else ModuleToEquipment(FindBonusByNameInCfg('21'),tdw);",
                        "                        ItemImprovement(tdw,2);",
                        "                    }",
                        "                    AddItemToShip(ship,tdw);",
                        "                    ItemIsInUse(tdw,ship,1);",
                        "                }",
                        "            }",
                        "        }",
                        "        //Акринация",
                        "        if(GalaxyDiffLevels()<=249) acrynLevel=0;",
                        "        else acrynLevel=1;",
                        "        EqAcrynation(ship,eliteSqType,acrynLevel);",
                        "        //Артефакты",
                        "        tChance=40; //Шанс на дроп артефакта после смерти",
                        "        if(!eliteSqType) GiveArt(ship,t_ArtFastRacks,tChance); //Ралс",
                        "        else {",
                        "            if(Rnd(1,100)>50) GiveArt(ship,t_ArtefactNano,tChance); //Нанитоиды",
                        "            else GiveArt(ship,t_ArtefactDroid,tChance); //Дроид младший",
                        "        }",
                        "        if(Rnd(1,100)>50) GiveArt(ship,t_ArtEnergyDef,tChance); //Проглот",
                        "        else GiveArt(ship,t_ArtefactMiniExpl,tChance); //Локализатор взрывной волны",
                        "        if(Rnd(1,100)>50) GiveArt(ship,t_ArtPDTurret,tChance); //аЭгис",
                        "        else GiveArt(ship,t_ArtefactAntigrav,tChance); //Антигравитатор",
                        "        if(Rnd(1,100)>50) GiveArt(ship,t_ArtefactHull,tChance); //Жупи",
                        "        else GiveArt(ship,t_ArtefactSpeed,tChance); //Пси-ускоритель",
                        "        //Улучшения, устранение перевеса",
                        "        EqTLUpgrade(ship);",
                        "        ShipImproveItems(ship,3*GalaxyTechLevel());",
                        "        GiveFreeSpace(ship);",
                        "        //На всякий случай, принудительно одеваем все оборудование",
                        "        for(j=1;j<ShipItems(ship);j=j+1) {",
                        "            if(!ItemIsInUse(ShipItems(ship,j))) ItemIsInUse(ShipItems(ship,j),ship,1);",
                        "        }",
                        "        //Рандомное добавление юзлессов в дроп",
                        "        if(Rnd(1,100)<=50)ShipAddDropItem(ship,CreateQuestItem('Usl_PTQ70',Rnd(0,4)));",
                        "        if(Rnd(1,100)<=50)ShipAddDropItem(ship,CreateQuestItem('OperatedProbe',Rnd(0,4)));",
                        "        if(Rnd(1,100)<=50)ShipAddDropItem(ship,CreateQuestItem('Usl_RandomItem_04',Rnd(0,4)));",
                        "        MakeShipEnterStar(ship,ShipStar(Player()),ShipStar(ship),1);",
                        "        ShipSetBad(ship,Player());",
                        "    }",
                        "}",
                        "//Функция создания мародера",
                        "function BuyMarauder() {",
                        "    dword ship;",
                        "    int i;",
                        "    ship=BuyPirate(PlanetPirateClan(),350);",
                        "    ItemSize(ShipItems(ship,0),1000);",
                        "    HullHP(ship,1000);",
                        "    SpecialToEquipment(FindBonusByNameInCfg('ShuMiniBoss_MarauderHull'),ShipItems(ship,0));",
                        "    Chameleon(ship);",
                        "    ShipType(ship,'Marauder');",
                        "    GiveRewardByNom(ship,39);    //Черное сердце",
                        "    GiveRewardByNom(ship,37);    //Черная метка",
                        "    for(i=0;i<6;i=i+1) ShipSkill(ship,i,6);",
                        "    for(i=0;i<6;i=i+1) ShipRefit(ship);",
                        "    while(GetShipPirateRank(ship)<5) RaisePirateRank(ship);",
                        "    EqTLUpgrade(ship);",
                        "    ShipImproveItems(ship,3*GalaxyTechLevel());",
                        "    if(IsScriptActive('Mod_EvoTranc')) {",
                        "        BuyTrancs(ship);",
                        "    }",
                        "}",
                        "//Функция создания Безбашенного Джека",
                        "function BuyBadassJack() {",
                        "    dword ship, tChance;",
                        "    int i;",
                        "    ship=BuyPirate(PlanetPirateClan(),1000);",
                        "    Chameleon(ship,'Ship.People.Ranger');    //Камуфляж человеческого рейнджера",
                        "    SetName(ship,CT(\"Script.Mod_ShuMiniBoss.117\"));",
                        "    ShipJoin(JackGroup,ship);",
                        "    ItemSize(ShipItems(ship,0),(250+50*GalaxyTechLevel())+Rnd(-25,35));",
                        "    HullHP(ship,'To100');",
                        "    for(i=0;i<10;i=i+1) ShipRefit(ship);",
                        "    for(i=0;i<6;i=i+1) ShipSkill(ship,i,Rnd(4,6));",
                        "    while(GetShipPirateRank(ship)<4) RaisePirateRank(ship);",
                        "    GiveRewardByNom(ship,39);    //Черное сердце",
                        "    GiveRewardByNom(ship,37);    //Черная метка",
                        "    ShipSpecialBonuses(ship,bonSlotArt,4);",
                        "    EqTLUpgrade(ship);",
                        "    ShipImproveItems(ship,3*GalaxyTechLevel());",
                        "    tChance=40;    //Шанс на дроп артефакта после смерти",
                        "    GiveArt(ship,t_ArtefactSpeed,tChance);    //Пси-ускоритель",
                        "    GiveArt(ship,t_ArtefactAntigrav,tChance);    //Антигравитатор",
                        "    if(Rnd(1,100)>50) GiveArt(ship,t_ArtEnergyPulse,tChance);    //Пятерик",
                        "    else GiveArt(ship,t_ArtefactMiniExpl,tChance);    //Локализатор взрывной волны",
                        "    if(Rnd(1,100)>50) GiveArt(ship,t_ArtPDTurret,tChance); //аЭгис",
                        "    else GiveArt(ship,t_ArtefactHull,tChance);    //Жупи",
                        "    ShipAddDropItem(ship,CreateQuestItem('Usl_Pilot',Peleng));    //Лицензия-юзлесс в дропе",
                        "    ShipAddDropItem(ship,CreateQuestItem('Usl_73',PirateClan));    //Пиратский флаг в дропе",
                        "    GiveFreeSpace(ship);",
                        "    TransferShip(ship,NearCivilPlanet(Player()));",
                        "    ShipSetBad(ship,Player());",
                        "}",
                        "//Функция создания рейнджера на болиде. Первый параметр - указатель на планету для создания",
                        "//Второй параметр - указатель на звезду, откуда вылетит болид",
                        "function BuyBolide(dword spawnPlanet, dword fromStar) {",
                        "    dword ship, tItem, tChance;",
                        "    int i;",
                        "    ship=BuyRanger(spawnPlanet,200);",
                        "    RangerExcludedFromRating(ship,1);",
                        "    SpecialToEquipment(FindBonusByNameInCfg('352'),ShipItems(ship,0)); //Болид",
                        "    Chameleon(ship);",
                        "    ShipJoin(BolideGroup,ship);",
                        "    while(ShipRank(ship)<5) {    //Звание \"Ас\"",
                        "        ShipRankPoints(ship,5000);",
                        "        ShipRaiseRank(ship);",
                        "    }",
                        "    for(i=0;i<5;i=i+1) ShipRefit(ship);",
                        "    for(i=0;i<3;i=i+1) GiveReward(ship,ShipPilotRace(ship),Rnd(1,2));",
                        "    ShipFreeExp(ship,Rnd(55000,75000));",
                        "    GiveFreeSpace(ship);",
                        "    ShipAddDropItem(ship,CreateQuestItem('Usl_40',Fei)); //Жучки",
                        "    ShipAddDropItem(ship,CreateQuestItem('OperatedProbe',Peleng)); //Шпионский зонд",
                        "    ShipAddDropItem(ship,CreateQuestItem('Usl_RandomItem_04',People)); //Кейс с документами",
                        "    for(i=ShipItems(ship);i>=0;i=i-1) {    //Ломаем все оборудование",
                        "        tItem=ShipItems(ship,i);",
                        "        ItemDurability(tItem,Rnd(0,15));",
                        "        if(ItemType(tItem)==t_Engine) ItemDurability(tItem,0); //Отдельно ломаем двигатель",
                        "    }",
                        "    MakeShipEnterStar(ship,ShipStar(Player()),fromStar,1);",
                        "}",
                        "//Функция создания группы доминаторов, преследуюищх рейнджера на болиде.",
                        "//Параметр - указатель на планету для создания",
                        "function SpawnDomiks(dword spawnPlanet) {",
                        "    dword ship, subtype, star;",
                        "    int i;",
                        "    star=PlanetToStar(spawnPlanet);",
                        "    for(i=0;i<(7+diffBonus);i=i+1) {",
                        "        if(i<5) subtype=5;  //Штип",
                        "        else if(i<8) subtype=4;  //Менок",
                        "        else if(i<10) subtype=3;  //Смерш",
                        "        else subtype=Rnd(1,4);  //Рандом от менка до эквентора",
                        "        ship=BuyDomikExtremal(spawnPlanet,subtype);",
                        "        MakeShipEnterStar(ship,ShipStar(Player()),star,Rnd(2,3));",
                        "    }",
                        "}",
                        "//Функция создания транклюкаторов для мародера при активном моде EvoTranc, параметр - указатель на корабль",
                        "//Практически полная копия функции MakeTrancOwnerFrom() из EvoTranc",
                        "function BuyTrancs(dword ship) {",
                        "    //tNumber - Число будущих транклюкаторов у хозяина",
                        "    //tTranc - Создаваемый транклюкатор",
                        "    //tArt - На всякий случай отдельно запоминаем его артефакт",
                        "    //cur_item - Корпус транклюкатора",
                        "    //temp_int_2 и temp_int_3 - номера бонусов",
                        "    //cost - Просто вспомогательный интеджер",
                        "    //temp_int_4 - Уровень корпуса транклюкатора",
                        "    //temp_int_5 - Временная числовая переменная для запоминания броска кости",
                        "    //TextCorr - Строка с Id всех имеющихся у хозяина транклюкаторов, вид: *1*Id*2*Id*3*Id*4*Id*5*Id*6*Id*7*",
                        "    //TextCorr2 - Строка вида 'NNYRRN' о запущенных транклюкаторах: Y/N/R (Yes - запущен/No - не запущен/Return - возвращается)",
                        "    //TextCorr3 - Статус всех транков (6 цифр): Z - транка в трюме нет, N - транк в порядке, R - нужен ремонт, U - транк устарел",
                        "    //TextCorr4, TextCorr5, SpecialUpCheck - Прочие вспомогательные строчные переменные",
                        "    //TextCorr6 - вспомогательная переменная для статуса",
                        "    //Урон",
                        "    MusashiDamageArray[1]=100;",
                        "    MusashiDamageArray[2]=100;",
                        "    MusashiDamageArray[3]=100;",
                        "    MusashiDamageArray[4]=100;",
                        "    MusashiDamageArray[5]=125;",
                        "    MusashiDamageArray[6]=160;",
                        "    MusashiDamageArray[7]=200;",
                        "    MusashiDamageArray[8]=260;",
                        "    //И дальность для орудия \"Мусаси\"",
                        "    MusashiRangeArray[1]=200;",
                        "    MusashiRangeArray[2]=200;",
                        "    MusashiRangeArray[3]=200;",
                        "    MusashiRangeArray[4]=200;",
                        "    MusashiRangeArray[5]=240;",
                        "    MusashiRangeArray[6]=280;",
                        "    MusashiRangeArray[7]=350;",
                        "    MusashiRangeArray[8]=450;",
                        "    dword tNumber,tTranc,tArt,cur_item,cost,SpecialUpCheck;",
                        "    int temp_int_2, temp_int_3, temp_int_4, temp_int_5;",
                        "    str TextCorr='*1*';",
                        "    str TextCorr2='';",
                        "    str TextCorr3='';",
                        "    str TextCorr4='';",
                        "    str TextCorr5='';",
                        "    str TextCorr6;",
                        "    if(GetShipPlanet(ship) || GetShipRuins(ship))SpecialUpCheck=1;",
                        "    tNumber=6;",
                        "    temp_int_2 = FindBonusByCustomTag('EvoTranc_TrancItemAcrin');",
                        "    temp_int_3 = FindBonusByCustomTag('EvoTranc_TrancWeaponAcrin');",
                        "    //Создаём транклюкаторов",
                        "    for(int i=1;i<=tNumber;i=i+1) {",
                        "        //Статус по умолчанию нормальный",
                        "        TextCorr6='N';",
                        "        tArt=CreateArt(t_ArtefactTranclucator,7);",
                        "        ItemSize(tArt,ItemSize(tArt)+Rnd(-9,25));",
                        "        tTranc=ArtTranclucatorToShip(tArt);",
                        "        TranclucatorData(tTranc,'ArtSize',ItemSize(tArt));",
                        "        TranclucatorData(tTranc,'Proprietor',ship);",
                        "        AddItemToShip(ship,tArt);",
                        "        NoDropItem(tArt,1);",
                        "        cur_item=ShipItems(tTranc,0);",
                        "        temp_int_4=ItemLevel(cur_item);",
                        "        if(SpecialUpCheck) {",
                        "            ShipMoney(tTranc,ShipMoney(ship)*2);",
                        "            for(int j=0;j<5;j=j+1) ShipRefit(tTranc);",
                        "            ShipMoney(tTranc,0);",
                        "        }",
                        "        else TextCorr6='U';",
                        "        ShipImproveItems(tTranc,Rnd(1,3));",
                        "        //Небольшой шанс на уменьшение оборудки транка",
                        "        for(j=1;j<ShipItems(tTranc);j=j+1) {",
                        "            cur_item=ShipItems(tTranc,j);",
                        "            if(ItemSize(cur_item)>1) {",
                        "                if(Rnd(1,100)<=temp_int_4+7) {",
                        "                    if(ItemExtraSpecialsCountByType(cur_item,temp_int_2)==-1 && ItemExtraSpecialsCountByType(cur_item,temp_int_3)==-1) {",
                        "                        ItemSize(cur_item,ItemSize(cur_item)/2);",
                        "                        //Вещь не должна получится легче одной тонны, ни при каких условиях",
                        "                        if(!ItemSize(cur_item))ItemSize(cur_item,1);",
                        "                        //Добавляем быстроизнашивающий спецакрин",
                        "                        if(ItemType(cur_item)>=t_FuelTanks && ItemType(cur_item)<=t_DefGenerator)ItemExtraSpecialsAddByType(cur_item,temp_int_2);",
                        "                        else ItemExtraSpecialsAddByType(cur_item,temp_int_3);",
                        "                        SetName(cur_item,Name(cur_item)+CT('Script.Mod_EvoTranc.ForTrancs'));",
                        "                    }",
                        "                }",
                        "            }",
                        "        }",
                        "        cur_item=ShipItems(tTranc,0);",
                        "        //Шанс на установку Мусаси",
                        "        if(temp_int_4>=4) {",
                        "            if(Rnd(1,100)<=temp_int_4)",
                        "                ShipAddCustomShipInfo(tTranc,'TrancAddGunInfo','',MusashiDamageArray[temp_int_4],MusashiRangeArray[temp_int_4],100,'0');",
                        "        }",
                        "        //Шанс на установку Джэбэ",
                        "        if(temp_int_4>=5) {",
                        "            if(Rnd(1,100)<=temp_int_4-2)",
                        "                ShipAddCustomShipInfo(tTranc,'TrancBuffAttackInfo','',0,0,0,'',CT('Script.Mod_EvoTranc.RedMus'));",
                        "        }",
                        "        //Шанс на установку Мангуста",
                        "        if(temp_int_4>=4) {",
                        "            if(Rnd(1,100)<=temp_int_4)",
                        "                ShipAddCustomShipInfo(tTranc,'TrancDefShieldInfo','',0,0,0,CT('Script.Mod_EvoTranc.RedDef'));",
                        "        }",
                        "        //Шанс на установку Херувима",
                        "        if(temp_int_4>=6) {",
                        "            if(Rnd(1,100)<=temp_int_4-3)",
                        "                ShipAddCustomShipInfo(tTranc,'TrancInvincibilityInfo','',0,0,0,'',CT('Script.Mod_EvoTranc.RedChe'));",
                        "        }",
                        "        //Шанс на установку фейкового навигационного компьютера (является лишь маркером и не несёт в себе исполняемого акткода)",
                        "        if(ShipFindCustomShipInfoByType(tTranc,'TrancFakeNavComputerInfo')==-1) {",
                        "            if(temp_int_4>=3) {",
                        "                if(Rnd(1,100)<=45) {",
                        "                    ShipAddCustomShipInfo(tTranc,'TrancFakeNavComputerInfo');",
                        "                    ItemCost(cur_item,round(1.15*ItemCost(cur_item)));",
                        "                }",
                        "            }",
                        "        }",
                        "        //Устраняем возможный обвес транклюкатора",
                        "        ShipCalcParam(tTranc);",
                        "        if(ShipFreeSpace(tTranc)<0) {",
                        "            ItemSize(cur_item,ItemSize(cur_item)+(-1*ShipFreeSpace(tTranc))+Rnd(37,49));",
                        "        }",
                        "        else if(ShipFreeSpace(tTranc)<40) {",
                        "            ItemSize(cur_item,ItemSize(cur_item)+Rnd(21,37));",
                        "        }",
                        "        //Перекраска транка под цвет расы хозяина",
                        "        Chameleon(tTranc,'Ship.TranclucatorWhite');",
                        "        TranclucatorData(tTranc,'ArtSysName','ArtTranclucatorWhite');",
                        "        EquipmentImageName(tArt,'ArtTranclucatorWhite');",
                        "        TextCorr = TextCorr + Id(tTranc) + '*' + (i + 1) + '*';",
                        "        TextCorr2 = TextCorr2 + 'N';",
                        "        TextCorr3 = TextCorr3 + TextCorr6;",
                        "        TranclucatorData(tTranc, 'AutoArrange', 1);",
                        "        for(j=0;j<3;j=j+1) ShipSkill(tTranc,j,Rnd(0,6));",
                        "        if(temp_int_4 < 8) ShipAddCustomShipInfo(tTranc, 'TrancNPCAddInfo', 'NoShow', -1, 0, 0, '', '0', 'N');",
                        "        else ShipAddCustomShipInfo(tTranc, 'TrancNPCAddInfo', 'NoShow', CurTurn() + Rnd(297, 403), 0, 0, '', '', 'N');",
                        "        HullHP(tTranc, ItemSize(cur_item));",
                        "        if(Rnd(1,100)<=93) {",
                        "            cost=CT('TrancNames.Total');",
                        "            TextCorr5='';",
                        "            //Делаем перебор по уже заданным именам, выбираем наименее заезженные",
                        "            while(TextCorr5=='') {",
                        "                TextCorr4=Rnd(10,cost);",
                        "                if(findsubstr(GTrancNameRand,'.'+TextCorr4+'.')==-1) {",
                        "                    TextCorr5=CT('TrancNames.'+TextCorr4);",
                        "                    GTrancNameRand=GTrancNameRand+'.'+TextCorr4+'.';",
                        "                    if(count(GTrancNameRand)>180)GTrancNameRand=substr(GTrancNameRand,4,180);",
                        "                }",
                        "            }",
                        "            //Задаём транклюкатору новое имя",
                        "            SetName(tTranc, TextCorr5);",
                        "        }",
                        "    }",
                        "    //Устраняем возможный перевес хозяина",
                        "    GiveFreeSpace(ship);",
                        "    //Делаем бросок на установку биомодуля \"Адмирал\", если мод ExpImplants также подключён",
                        "    if(tNumber) {",
                        "        if(IsScriptActive('Mod_ExpImplants')) {",
                        "            if(GalaxyTechLevel() >= 5) {",
                        "                if(Rnd(1, 100) <= 12) {",
                        "                    //Если у корабля уже имеются импланты",
                        "                    temp_int_5 = ShipFindCustomShipInfoByType(ship, 'bioMM_NPC');",
                        "                    if(temp_int_5 > -1) {",
                        "                        //То проверяем, что ему хватает места в одной из рук",
                        "                        temp_int_4 = ShipCustomShipInfoData(ship, temp_int_5, 2);",
                        "                        if(temp_int_4) {",
                        "                            //Занимаем под \"Адмирал\" одну свободную руку капитана",
                        "                            ShipCustomShipInfoData(ship,temp_int_5,2,temp_int_4-1);",
                        "                            //Дополняем описание инфошки с биомодулями",
                        "                            TextCorr5=ShipCustomShipInfoDescription(ship,temp_int_5);",
                        "                            //С определённым шансом окрашиваем имя биомодуля в \"пиратский\" цвет",
                        "                            if(ShipTypeN(ship) == t_Pirate)temp_int_4=77;",
                        "                            else temp_int_4=17;",
                        "                            if(Rnd(1,100) <= temp_int_4)TextCorr5=TextCorr5+CT(\"Script.Mod_ShuMiniBoss.115\")+CT('Script.Mod_ExpImplants.Hand')+' '+CT('Biomodules.PirateBiomoduleNameColor')+CT('Biomodules.5_gtu.10.Name')+'</color>';",
                        "                            else TextCorr5=TextCorr5+CT(\"Script.Mod_ShuMiniBoss.115\")+CT('Script.Mod_ExpImplants.Hand')+' <color=255,240,100>'+CT('Biomodules.5_gtu.10.Name')+'</color>';",
                        "                            ShipCustomShipInfoDescription(ship,temp_int_5,TextCorr5);",
                        "                            //И добавляем доп. инфошку конкретно для данного биомодуля",
                        "                            ShipAddCustomShipInfo(ship,CT('Biomodules.5_gtu.10.AddNPCInfo'),'NoShow');",
                        "                        }",
                        "                    }",
                        "                    //А если нет, то устанавливаем \"Адмирал\" на чистую",
                        "                    else {",
                        "                        //Описание инфошки с биомодулями",
                        "                        TextCorr5=CT('ShipInfo.AddInfo.CustomInfos.bioMM_NPC.Description');",
                        "                        //С определённым шансом окрашиваем имя биомодуля в \"пиратский\" цвет",
                        "                        if(ShipTypeN(ship) == t_Pirate)temp_int_4=77;",
                        "                        else temp_int_4=17;",
                        "                        if(Rnd(1,100) <= temp_int_4)TextCorr5=TextCorr5+CT(\"Script.Mod_ShuMiniBoss.115\")+CT('Script.Mod_ExpImplants.Hand')+' '+CT('Biomodules.PirateBiomoduleNameColor')+CT('Biomodules.5_gtu.10.Name')+'</color>';",
                        "                        else TextCorr5=TextCorr5+CT(\"Script.Mod_ShuMiniBoss.115\")+CT('Script.Mod_ExpImplants.Hand')+' <color=255,240,100>'+CT('Biomodules.5_gtu.10.Name')+'</color>';",
                        "                        //Добавляем новую инфошку",
                        "                        temp_int_5=ShipAddCustomShipInfo(ship,'bioMM_NPC',TextCorr5);",
                        "                        //Заполняем информацию о доступных для установки биомодулей конечностях в зависимости от расы пилота",
                        "                        temp_int_4=ShipPilotRace(ship);",
                        "                        //Мозг",
                        "                        if(temp_int_4 == 3) ShipCustomShipInfoData(ship,temp_int_5,1,4);",
                        "                        else ShipCustomShipInfoData(ship,temp_int_5,1,2);",
                        "                        //Руки",
                        "                        if(temp_int_4 == 1) ShipCustomShipInfoData(ship,temp_int_5,2,3);",
                        "                        else ShipCustomShipInfoData(ship,temp_int_5,2,1);",
                        "                        //Глаза",
                        "                        if(temp_int_4 == 4) ShipCustomShipInfoData(ship,temp_int_5,3,3);",
                        "                        else ShipCustomShipInfoData(ship,temp_int_5,3,2);",
                        "                        //ГТУ момента установки биомодуля (текущий ГТУ)",
                        "                        ShipCustomShipInfoTextData(ship,temp_int_5,3,GalaxyTechLevel());",
                        "                        //Добавляем доп. инфошку конкретно для данного биомодуля",
                        "                        ShipAddCustomShipInfo(ship,CT('Biomodules.5_gtu.10.AddNPCInfo'),'NoShow');",
                        "                    }",
                        "                }",
                        "            }",
                        "        }",
                        "    }",
                        "    //И под конец вешаем на нового хозяина его персональную инфошку",
                        "    ShipAddCustomShipInfo(ship,'TrancNPCOwnerInfo','NoShow',Rnd(207,459),1,tNumber,TextCorr,TextCorr2,TextCorr3);",
                        "    //А также добавляем ему предмет, который будет занимать место в трюме на то время, пока транклюкаторы находятся на вылете",
                        "    cur_item=CreateQuestItem('WeightReserve',0);",
                        "    ItemSize(cur_item,0);",
                        "    AddItemToShip(ship,cur_item);",
                        "    NoDropItem(cur_item,1);",
                        "    ItemIsInUse(cur_item,ship,1);",
                        "}",
                        "//Функция повышения ТУ оборудования, параметр - указатель на корабль",
                        "function EqTLUpgrade(dword ship) {",
                        "    //Функция перебирает все предметы корабля, исключая неиспользуемые и корпус,",
                        "    //Затем создается полная копия предмета (включая акрин и ММ), для корректного расчета стоимости,",
                        "    //После чего пересчитываются хар-ки оригинального предмета, копия удаляется",
                        "    dword tItem, tCopy;",
                        "    int i;",
                        "    for(i=ShipItems(ship);i>=0;i=i-1) {",
                        "        tItem=ShipItems(ship,i);",
                        "        if(!ItemIsInUse(tItem)) continue;",
                        "        if(ItemType(tItem)==t_Hull) continue;",
                        "        //Пропускаем конец списка (tItem=0)",
                        "        if(tItem) {",
                        "            if(ItemLevel(tItem)<GalaxyTechLevel()) {",
                        "                //Отдельное условие для кастомного оружия",
                        "                if(ItemType(tItem)==t_CustomWeapon)",
                        "                    tCopy=CreateCustomWeapon(CustomWeaponType(tItem),ItemSize(tItem),GalaxyTechLevel(),ItemOwner(tItem));",
                        "                else tCopy=CreateEquipment(ItemType(tItem),ItemSize(tItem),GalaxyTechLevel(),ItemOwner(tItem));",
                        "                if(EqSpecial(tItem)>-1) SpecialToEquipment(EqSpecial(tItem),tCopy);",
                        "                if(EqModule(tItem)>-1) ModuleToEquipment(EqModule(tItem),tCopy);",
                        "                ItemLevel(tItem,GalaxyTechLevel());",
                        "                ItemCost(tItem,ItemCost(tCopy));",
                        "                FreeItem(tCopy);",
                        "            }",
                        "        }",
                        "    }",
                        "}",
                        "//Функция создания и экипировки артефакта. Первый параметр - указатель на корабль,",
                        "//Второй параметр - тип артефакта, третий параметр - шанс дропа артефакта при смерти.",
                        "function GiveArt(dword ship, dword artType, dword dropChance) {",
                        "    dword tArt=CreateArt(artType,Rnd(0,4));",
                        "    AddItemToShip(ship,tArt);",
                        "    ItemIsInUse(tArt,ship,1);",
                        "    if(Rnd(1,100)>dropChance) NoDropItem(tArt,1);",
                        "}",
                        "//Функция акринации оборудования корабля в пигамарное/миоплазменное. Первый параметр - указатель на корабль",
                        "//Второй - тип акринации (0 - пигамарное, 1+ - миоплазменное), третий - уровень акринации (0 - I,II уровни, 1+ - III уровень)",
                        "function EqAcrynation(dword ship, dword type, dword level) {",
                        "    if(!type) {",
                        "        if(!level) {",
                        "            SpecialToEquipment(FindBonusByNameInCfg('394'),ShipEqInSlot(ship,t_FuelTanks));",
                        "            SpecialToEquipment(FindBonusByNameInCfg('395'),ShipEqInSlot(ship,t_Engine));",
                        "            if(ShipEqInSlot(ship,t_Radar)) SpecialToEquipment(FindBonusByNameInCfg('396'),ShipEqInSlot(ship,t_Radar));",
                        "            if(ShipEqInSlot(ship,t_Scaner)) SpecialToEquipment(FindBonusByNameInCfg('397'),ShipEqInSlot(ship,t_Scaner));",
                        "            if(ShipEqInSlot(ship,t_RepairRobot)) SpecialToEquipment(FindBonusByNameInCfg('398'),ShipEqInSlot(ship,t_RepairRobot));",
                        "            if(ShipEqInSlot(ship,t_CargoHook)) SpecialToEquipment(FindBonusByNameInCfg('399'),ShipEqInSlot(ship,t_CargoHook));",
                        "            if(ShipEqInSlot(ship,t_DefGenerator)) SpecialToEquipment(FindBonusByNameInCfg('400'),ShipEqInSlot(ship,t_DefGenerator));",
                        "        }",
                        "        else {",
                        "            SpecialToEquipment(FindBonusByNameInCfg('408'),ShipEqInSlot(ship,t_FuelTanks));",
                        "            SpecialToEquipment(FindBonusByNameInCfg('409'),ShipEqInSlot(ship,t_Engine));",
                        "            if(ShipEqInSlot(ship,t_Radar)) SpecialToEquipment(FindBonusByNameInCfg('410'),ShipEqInSlot(ship,t_Radar));",
                        "            if(ShipEqInSlot(ship,t_Scaner)) SpecialToEquipment(FindBonusByNameInCfg('411'),ShipEqInSlot(ship,t_Scaner));",
                        "            if(ShipEqInSlot(ship,t_RepairRobot)) SpecialToEquipment(FindBonusByNameInCfg('412'),ShipEqInSlot(ship,t_RepairRobot));",
                        "            if(ShipEqInSlot(ship,t_CargoHook)) SpecialToEquipment(FindBonusByNameInCfg('413'),ShipEqInSlot(ship,t_CargoHook));",
                        "            if(ShipEqInSlot(ship,t_DefGenerator)) SpecialToEquipment(FindBonusByNameInCfg('414'),ShipEqInSlot(ship,t_DefGenerator));",
                        "        }",
                        "    }",
                        "    else {",
                        "        if(!level) {",
                        "            SpecialToEquipment(FindBonusByNameInCfg('373'),ShipEqInSlot(ship,t_FuelTanks));",
                        "            SpecialToEquipment(FindBonusByNameInCfg('374'),ShipEqInSlot(ship,t_Engine));",
                        "            if(ShipEqInSlot(ship,t_Radar)) SpecialToEquipment(FindBonusByNameInCfg('375'),ShipEqInSlot(ship,t_Radar));",
                        "            if(ShipEqInSlot(ship,t_Scaner)) SpecialToEquipment(FindBonusByNameInCfg('376'),ShipEqInSlot(ship,t_Scaner));",
                        "            if(ShipEqInSlot(ship,t_RepairRobot)) SpecialToEquipment(FindBonusByNameInCfg('377'),ShipEqInSlot(ship,t_RepairRobot));",
                        "            if(ShipEqInSlot(ship,t_CargoHook)) SpecialToEquipment(FindBonusByNameInCfg('385'),ShipEqInSlot(ship,t_CargoHook));",
                        "            if(ShipEqInSlot(ship,t_DefGenerator)) SpecialToEquipment(FindBonusByNameInCfg('386'),ShipEqInSlot(ship,t_DefGenerator));",
                        "        }",
                        "        else {",
                        "            SpecialToEquipment(FindBonusByNameInCfg('387'),ShipEqInSlot(ship,t_FuelTanks));",
                        "            SpecialToEquipment(FindBonusByNameInCfg('388'),ShipEqInSlot(ship,t_Engine));",
                        "            if(ShipEqInSlot(ship,t_Radar)) SpecialToEquipment(FindBonusByNameInCfg('389'),ShipEqInSlot(ship,t_Radar));",
                        "            if(ShipEqInSlot(ship,t_Scaner)) SpecialToEquipment(FindBonusByNameInCfg('390'),ShipEqInSlot(ship,t_Scaner));",
                        "            if(ShipEqInSlot(ship,t_RepairRobot)) SpecialToEquipment(FindBonusByNameInCfg('391'),ShipEqInSlot(ship,t_RepairRobot));",
                        "            if(ShipEqInSlot(ship,t_CargoHook)) SpecialToEquipment(FindBonusByNameInCfg('392'),ShipEqInSlot(ship,t_CargoHook));",
                        "            if(ShipEqInSlot(ship,t_DefGenerator)) SpecialToEquipment(FindBonusByNameInCfg('393'),ShipEqInSlot(ship,t_DefGenerator));",
                        "        }",
                        "    }",
                        "}",
                        "//Функция устранения перевеса корабля, параметр - указатель на корабль",
                        "function GiveFreeSpace(dword ship) {",
                        "    ShipCalcParam(ship);",
                        "    if(ShipFreeSpace(ship)<0) {",
                        "        ItemSize(ShipItems(ship,0),ItemSize(ShipItems(ship,0))+abs(ShipFreeSpace(ship))+Rnd(1,5));",
                        "        HullHP(ship,'To100');",
                        "    }",
                        "}",
                        "//Функция проверки на наличие активной ситуации во избежание срабатывания нескольких ситуаций одновременно",
                        "//Возвращает 1 (есть активная ситуация) или 0 (нет активной ситуации)",
                        "function scenarioCheck() {",
                        "    dword check = 0;",
                        "    if(GroupCount(EliteSquad)) check=1; //Отряд наемников",
                        "    else if(GroupCount(JackGroup)) check=1; //Безбашенный Джек",
                        "    else if(GroupCount(TrancGroup)) check=1; //Безумный транклюкатор",
                        "    else if(GroupCount(BolideGroup)) check=1; //Рейнджер на болиде",
                        "    else check=0;",
                        "    result=check;",
                        "}",
                        "//Функция отключения скрипта, в случае прохождения игроком всех ситуаций",
                        "",
                        "function Out() {",
                        "    if(!GroupCount(EliteSquad) && !eliteSqTimer) {",
                        "        if(!GroupCount(JackGroup) && !jackTimer) {",
                        "            if(!GroupCount(TrancGroup) && trancSdTimer) {",
                        "                if(!GroupCount(BolideGroup) && !bolideTimer) AllShipOut();",
                        "            }",
                        "        }",
                        "    }",
                        "}",
                        "",
                        "//Спавним Шиксу Нёвикет (Нёви, привет :) Не думаю, что ты когда-либо увидишь это, но, возможно, тот, кто",
                        "//откроет и увидит это, получит знатную дозу умиления :3",
                        "function SpawnNeviket() {",
                        "    dword ship;",
                        "    dword star;",
                        "    dword plan = 0;",
                        "    int i;",
                        "    int j;",
                        "",
                        "    //Ищем пеленгскую планетку для спавна Нёви",
                        "    for(i=0;GalaxyStars()>i;i=i+1) {",
                        "        star = GalaxyStar(i);",
                        "        //Отсекаем некоалиционное барахло",
                        "        if(StarOwner(star) != 0) continue;",
                        "        if(StarCustomFaction(star) != '') continue;",
                        "        for(j=0;StarPlanets(star)>j;j=j+1) {",
                        "            if(PlanetOwner(StarPlanets(star,j)) == Peleng) {",
                        "                plan = StarPlanets(star,j);",
                        "                break;",
                        "            }",
                        "        }",
                        "",
                        "        if(plan) break;",
                        "    }",
                        "",
                        "    if(!plan) {",
                        "        NeviketCD = 250;",
                        "        exit;",
                        "    }",
                        "",
                        "    ship = BuyBigWarrior(plan,1000);",
                        "    ShipFace(ship,7);",
                        "    //Выставляем HP",
                        "    i = 1000 + GalaxyTechLevel()*400;",
                        "    if(ItemSize(ShipEqInSlot(ship,t_Hull)) < i) ItemSize(ShipEqInSlot(ship,t_Hull),i);",
                        "    ShipRefit(ship);",
                        "    ShipRefit(ship);",
                        "    ShipRefit(ship);",
                        "    SetName(ship,CT('Script.Mod_ShuMiniBoss.Nevi.Name'));",
                        "",
                        "    ShipJoin(GroupNeviket,ship);",
                        "",
                        "    NeviketCD = 500;",
                        "}"
                    ],
                    "#": 45,
                    "Type": "Top",
                    "Parent": -1,
                    "Pos.x": 60,
                    "Pos.y": 760
                },
                {
                    "Name": "",
                    "Code.Type": "Turn",
                    "Code": [
                        "//Условия появления элитных охотников за головами:",
                        "//Прошло ~ 15-18 лет с начала игры, коалиция не побеждена, нет других активных событий.",
                        "//Если подходящей планеты не найдено, запуск сценария переносится.",
                        "//if(eliteSqTimer) гарантирует однократый запуск сценария.",
                        "if (eliteSqTimer) {",
                        "  check = scenarioCheck();",
                        "  if (!check) {",
                        "    if (CurTurn() >= eliteSqTimer) {",
                        "      if (!CoalitionDefeated()) {",
                        "        tPlanet = SelectPlanet();",
                        "        if (tPlanet) {",
                        "          SpawnEliteSquad(tPlanet);",
                        "          tSystem = Id(PlanetToStar(tPlanet)) - 1;",
                        "          eliteSqTimer = 0;",
                        "        } else eliteSqTimer = eliteSqTimer + Rnd(167, 209);",
                        "      }",
                        "    }",
                        "  }",
                        "}",
                        "//Условия появления безумного транклюкатора: Нет других активных событий,",
                        "//Прошло ~8 годов с начала игры, родная система игрока под контролем Коалиции.",
                        "//if(!trancSdTimer) гарантирует однократный запуск сценария.",
                        "",
                        "//(2815-300)/365. Калькулятор выдал мне 6.8. ШЕСТЬ И ВОСЕМЬ!!!!",
                        "//Да даже на восьмом году игрок ещё не готов бодаться с таким противником.",
                        "if (!trancSdTimer) {",
                        "  check = scenarioCheck();",
                        "  if (!check) {",
                        "    if (CurTurn() >= 3675) {",
                        "      tPlanet = GetShipHomePlanet(Player());",
                        "      if (PlanetOwner(tPlanet) < Kling) {",
                        "        BuyMadTranc(tPlanet, trancType);",
                        "        trancSdTimer = CurTurn() + 1095;",
                        "      }",
                        "    }",
                        "  }",
                        "}",
                        "//Условия появления мародёра: Пираты не проиграли войну, сработал таймер",
                        "//if(marauderTimer) гарантирует однократный запуск сценария.",
                        "if (PirateWin() != 3 && PirateWin() != 4) {",
                        "  if (marauderTimer) {",
                        "    if (CurTurn >= marauderTimer) {",
                        "      BuyMarauder();",
                        "      marauderTimer = 0;",
                        "    }",
                        "  }",
                        "}",
                        "//Условия появления Безбашенного Джека: Нет других активных событий,",
                        "//Прошло больше 7 лет с начала игры, игрок сильнее среднего рейнджера в 1.5 раза,",
                        "//Игрок перешел от пиратов к коалиции, игрок в пиратской/коалиционной системе.",
                        "//if(badassJackTimer) гарантирует однократный запуск сценария.",
                        "if (jackTimer) {",
                        "  check = scenarioCheck();",
                        "  if (!check) {",
                        "    if (CurTurn() >= jackTimer) {",
                        "      if (ShipStrengthInAverageRanger(Player()) >= 1.5) {",
                        "        for (i = GalaxyEvents() - 1; i >= 0; i = i - 1) {",
                        "          if (GalaxyEventDate(i) < CurTurn()) break;",
                        "          if (GalaxyEventType(i) == 'PlayerChangesSide') {",
                        "            if (!GalaxyEventData(i, 0)) {",
                        "              BuyBadassJack();",
                        "              jackTimer = 0;",
                        "            }",
                        "          }",
                        "        }",
                        "      }",
                        "    }",
                        "  }",
                        "}",
                        "//Условия появления рейнджера на болиде:",
                        "//Прошло 10-15 лет с начала игры, Келлер не побежден, нет других активных событий.",
                        "//if(bolideTimer) гарантирует однократный запуск сценария.",
                        "if (bolideTimer) {",
                        "  check = scenarioCheck();",
                        "  if (!check) {",
                        "    if (CurTurn() >= bolideTimer) {",
                        "      if (!DomiksDefeated(1)) {",
                        "        if (ShipInNormalSpace(Player())) {",
                        "          if (!StarOwner(ShipStar(Player()))) {",
                        "            tPlanet = SelectPlanet();",
                        "            if (tPlanet) {",
                        "              //выбор планеты",
                        "              tPlanet2 = 0;",
                        "              for (i = 1; i <= 20; i = i + 1) { //Ищем среди ближайших 20 систем келлероидную",
                        "                tSystem = StarNearbyStars(ShipStar(Player()), i);",
                        "                if (StarOwner(tSystem) != 1) continue;",
                        "                if (StarCustomFaction(tSystem) != '') continue;",
                        "                if (StarSeries(tSystem) == 1) { //Ищем доминаторскую планету",
                        "                  tPlanet2 = FindPlanet(tSystem, 'NotMaloc,NotPeleng,NotPeople,NotFei,NotGaal,NotNone,NotPirateClan');",
                        "                  break;",
                        "                }",
                        "              }",
                        "              if (tPlanet2) {",
                        "                BuyBolide(tPlanet, tSystem);",
                        "                SpawnDomiks(tPlanet2);",
                        "                //Необитаемая планета, где будет зарыт модуль",
                        "                tPlanet = FindPlanet(tSystem, 'NotMaloc,NotPeleng,NotPeople,NotFei,NotGaal,NotKling,NotPirateClan');",
                        "                bolideTimer = 0;",
                        "                tSystem = Id(tSystem) - 1; //Нужно, потому что в диалоге указатель иногда слетает",
                        "              }",
                        "            }",
                        "          }",
                        "        }",
                        "      }",
                        "    }",
                        "  }",
                        "}",
                        "//Условие самоуничтожения безумного транклюкатора",
                        "if(trancSdTimer && GroupCount(TrancGroup)) {",
                        "  if(CurTurn() >= trancSdTimer) ShipDestroy(GroupToShip(TrancGroup));",
                        "}",
                        "//Проверка на прохождение всех ситуаций",
                        "if(CurTurn() >= outTimer) {",
                        "  Out();",
                        "  outTimer = CurTurn() + 365;",
                        "}",
                        "",
                        "if(!CoalitionDefeated()) {",
                        "    if(ControlledSystems(0)) {",
                        "        if(!GroupCount(GroupNeviket)) {",
                        "            if(!GNeviket) {",
                        "                if(CurTurn() > 600) {",
                        "                    SpawnNeviket();",
                        "                }",
                        "            }",
                        "            else {",
                        "                if(NeviketCD) NeviketCD = NeviketCD - 1;",
                        "                else SpawnNeviket();",
                        "            }",
                        "        }",
                        "    }",
                        "}"
                    ],
                    "#": 46,
                    "Type": "Top",
                    "Parent": -1,
                    "Pos.x": 120,
                    "Pos.y": 760
                },
                {
                    "Name": "",
                    "Code.Type": "DialogBegin",
                    "Code": [
                        "if(GetShipRuins(Player())) {",
                        "  if(ShipType(GetShipRuins(Player()))=='SB') {",
                        "    if(ItemIn(module,Player())) {",
                        "      AddDialogInject('moduleSBDialog','',CT(\"Script.Mod_ShuMiniBoss.152\"),10);",
                        "    }",
                        "  }",
                        "}",
                        "if(GetTalkShip()) {",
                        "    if(!TalkByAI()) {",
                        "        if(ShipInCurScript(GetTalkShip())) {",
                        "            if(ShipGroup(GetTalkShip()) == GroupNeviket) {",
                        "                tdw = ShipStatistic(GetTalkShip(),10);",
                        "                i = GetRelationPlanet(tdw,Player());",
                        "    ",
                        "                if(i > 79) {",
                        "                    tStr = '</color>' + CT('Script.Mod_ShuMiniBoss.Nevi.Best.'+Rnd(1,CT('Script.Mod_ShuMiniBoss.Nevi.Best.Count')));",
                        "                }",
                        "                else if(i > 59) {",
                        "                    tStr = '</color>' + CT('Script.Mod_ShuMiniBoss.Nevi.Good.'+Rnd(1,CT('Script.Mod_ShuMiniBoss.Nevi.Good.Count')));",
                        "                }",
                        "                else if(i > 29) {",
                        "                    tStr = '</color>' + CT('Script.Mod_ShuMiniBoss.Nevi.Neutral.'+Rnd(1,CT('Script.Mod_ShuMiniBoss.Nevi.Neutral.Count')));",
                        "                }",
                        "                else if(i > 9) {",
                        "                    tStr = '</color>' + CT('Script.Mod_ShuMiniBoss.Nevi.Bad.'+Rnd(1,CT('Script.Mod_ShuMiniBoss.Nevi.Bad.Count')));",
                        "                }",
                        "                else {",
                        "                    tStr = '</color>' + CT('Script.Mod_ShuMiniBoss.Nevi.War.'+Rnd(1,CT('Script.Mod_ShuMiniBoss.Nevi.War.Count')));",
                        "                }",
                        "    ",
                        "                if(~PlayerChameleonCurType()) {",
                        "                    tStr = '</color>' + CT('Script.Mod_ShuMiniBoss.Nevi.Chameleon.'+Rnd(1,CT('Script.Mod_ShuMiniBoss.Nevi.Chameleon.Count')));",
                        "                }",
                        "    ",
                        "                tStr = Format(tStr,'HomePlanet',Name(tdw));",
                        "    ",
                        "                DText(tStr);",
                        "    ",
                        "                if(PlayerChameleonCurType() == -1) {",
                        "                    if(!ShipOnSidePirateClan(Player())) {",
                        "                        if(i > 79) {",
                        "                            AddDialogInject('DialogAgency','',CT('Script.Mod_ShuMiniBoss.Nevi.Agency.AgencyAsk'),25);",
                        "                        }",
                        "                    }",
                        "                }",
                        "            }",
                        "        }",
                        "    }",
                        "}"
