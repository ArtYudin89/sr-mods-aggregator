                        "    tdw=ShipItems(Player(),i);",
                        "    if(ItemType(tdw)==t_UselessItem && EquipmentImageName(tdw) == 'ShuBounty_Crystals'){",
                        "        tdw2=tdw;",
                        "        break;",
                        "    }",
                        "    else tdw2=0;",
                        "}",
                        "DAdd(8);",
