                    "#": 170,
                    "Type": "Top",
                    "Parent": -1,
                    "Pos.x": 850,
                    "Pos.y": 425
                },
                {
                    "Name": "",
                    "Code.Type": "Turn",
                    "Code": [
                        "tstr1 = '</color>' + CT('Script.Mod_ShuMiniBoss.Nevi.Agency.AgencyBegin');",
                        "tint1 = 0; //Маркер",
                        "tint2 = 0; //Количество \"наших\"",
                        "tint3 = 0; //Количество \"чертил\"",
                        "",
                        "dword pirate_sector = StarToCon(PlanetToStar(PlanetPirateClan()));",
                        "",
                        "//Системы, атакованные врагами",
                        "tstr1 = tstr1+'</color>' + Format('<br>') + CT('Script.Mod_ShuMiniBoss.Nevi.Agency.AgencyBlock1');",
                        "for(i=0;GalaxyStars()>i;i=i+1) {",
                        "    tdw = GalaxyStar(i);",
                        "    if(StarOwner(tdw)) continue;",
                        "    if(StarCustomFaction(tdw) != '') continue;",
                        "    if(!StarBattle(tdw)) continue;",
                        "    tint1 = 1;",
                        "    tint2 = 0;",
                        "    tint3 = 0;",
                        "",
                        "    for(j=0;StarShips(tdw)>j;j=j+1) {",
                        "        tdw2 = StarShips(tdw,j);",
                        "        if(ShipOwner(tdw2) < 5) {",
                        "            if(ShipTypeN(tdw2) == t_Warrior) tint2 = tint2 + 1;",
                        "            if(ShipTypeN(tdw2) == t_Ranger) tint2 = tint2 + 1;",
                        "        }",
                        "        else {",
                        "            if(ShipTypeN(tdw2) == t_Transport) continue;",
                        "            if(ShipTypeN(tdw2) > t_Tranclucator) continue;",
                        "            tint3 = tint3 + 1;",
                        "        }",
                        "    }",
                        "    tstr1 = tstr1+'</color>' + Format('<br>') + Format(CT('Script.Mod_ShuMiniBoss.Nevi.Agency.AgencyBlockSystemInfo'),'name',Name(tdw),'coal',tint2,'enem',tint3);",
                        "}",
                        "if(!tint1) {",
                        "    tstr1 = tstr1+'</color>' + Format('<br>') + CT('Script.Mod_ShuMiniBoss.Nevi.Agency.AgencyBlockNo');",
                        "}",
                        "tint1 = 0;",
                        "tstr1 = tstr1 + Format('<br>');",
                        "",
                        "//Системы, которые скоро подвергнутся атакам",
                        "tstr1 = tstr1+'</color>' + Format('<br>') + CT('Script.Mod_ShuMiniBoss.Nevi.Agency.AgencyBlock2');",
                        "for(i=0;GalaxyStars()>i;i=i+1) {",
                        "    tdw = GalaxyStar(i);",
                        "    if(StarOwner(tdw)) continue;",
                        "    if(StarCustomFaction(tdw) != '') continue;",
                        "    if(!StarBattle(tdw)) continue;",
                        "    if(!StarEnemyThreatLevel(tdw,1)) continue;",
                        "    tint1 = 1;",
                        "    tint2 = 0;",
                        "    tint3 = 0;",
                        "",
                        "    for(j=0;StarShips(tdw)>j;j=j+1) {",
                        "        tdw2 = StarShips(tdw,j);",
                        "        if(ShipOwner(tdw2) < 5) {",
                        "            if(ShipTypeN(tdw2) == t_Warrior) tint2 = tint2 + 1;",
                        "            if(ShipTypeN(tdw2) == t_Ranger) tint2 = tint2 + 1;",
                        "        }",
                        "        else {",
                        "            if(ShipTypeN(tdw2) == t_Transport) continue;",
                        "            if(ShipTypeN(tdw2) > t_Tranclucator) continue;",
                        "            tint3 = tint3 + 1;",
                        "        }",
                        "    }",
                        "    tstr1 = tstr1+'</color>' + Format('<br>') + Format(CT('Script.Mod_ShuMiniBoss.Nevi.Agency.AgencyBlockSystemInfo'),'name',Name(tdw),'coal',tint2,'enem',tint3);",
                        "}",
                        "if(!tint1) {",
                        "    tstr1 = tstr1+'</color>' + Format('<br>') + CT('Script.Mod_ShuMiniBoss.Nevi.Agency.AgencyBlockNo');",
                        "}",
                        "tint1 = 0;",
                        "tstr1 = tstr1 + Format('<br>');",
                        "",
                        "//Системы, захваченные врагом, но обороняемые крайне незначительными силами (меньше 10 болванок)",
                        "tstr1 = tstr1+'</color>' + Format('<br>') + CT('Script.Mod_ShuMiniBoss.Nevi.Agency.AgencyBlock3');",
                        "for(i=0;GalaxyStars()>i;i=i+1) {",
                        "    tdw = GalaxyStar(i);",
                        "    if(!StarOwner(tdw)) continue;",
                        "    if(StarBattle(tdw)) continue;",
                        "    if(!PirateWin()) {",
                        "        if(pirate_sector == StarToCon(tdw)) continue;",
                        "    }",
                        "    tint2 = 0;",
                        "    tint3 = 0;",
                        "",
                        "    for(j=0;StarShips(tdw)>j;j=j+1) {",
                        "        tdw2 = StarShips(tdw,j);",
                        "        if(StarOwner(tdw) == 1) {",
                        "            if(ShipTypeN(tdw2) == t_Kling) tint2 = tint2 + 1;",
                        "            if(ShipTypeN(tdw2) == t_Tranclucator && ShipOwner(tdw2) == Kling) tint2 = tint2 + 1;",
                        "        }",
                        "        if(StarOwner(tdw) == 2) {",
                        "            if(ShipTypeN(tdw2) == t_Kling) tint2 = tint2 + 1;",
                        "            if(ShipTypeN(tdw2) == t_Tranclucator && ShipOwner(tdw2) == Kling) tint2 = tint2 + 1;",
                        "        }",
                        "        if(ShipCustomFaction(tdw2) == StarCustomFaction(tdw)) tint2 = tint2 + 1;",
                        "    }",
                        "",
                        "    if(tint2 > 10) continue;",
                        "    tint1 = 1;",
                        "    tstr1 = tstr1+'</color>' + Format('<br>') + Format(CT('Script.Mod_ShuMiniBoss.Nevi.Agency.AgencyBlockSystemInfoWeak'),'name',Name(tdw),'enem',tint3);",
                        "}",
                        "if(!tint1) {",
                        "    tstr1 = tstr1+'</color>' + Format('<br>') + CT('Script.Mod_ShuMiniBoss.Nevi.Agency.AgencyBlockNo');",
                        "}",
                        "",
                        "//Заменяем информацией о системах",
                        "tstr2 = Format('</color>' + CT('Script.Mod_ShuMiniBoss.Nevi.Agency.'+Rnd(1,CT('Script.Mod_ShuMiniBoss.Nevi.Agency.Count'))),'info',tstr1);",
                        "tstr3 ='</color>' + CT('Script.Mod_ShuMiniBoss.Nevi.Agency.AgencyThanks');",
                        "DChange(29);",
                        "exit;"
                    ],
