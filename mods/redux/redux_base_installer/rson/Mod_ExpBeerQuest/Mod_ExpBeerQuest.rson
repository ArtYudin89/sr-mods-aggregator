                    "Pos.x": 480,
                    "Pos.y": 640,
                    "Type": "TDialogAnswer",
                    "Parent": -1,
                    "#": 89,
                    "Msg": "Жаль...",
                    "AMsg.Num": "19",
                    "_orig_danswer": "DAnswer(CT(\"Script.Mod_ExpBeerQuest.61\"))"
                },
                {
                    "Name": "restart",
                    "Pos.x": 600,
                    "Pos.y": 640,
                    "Type": "TDialogAnswer",
                    "Parent": -1,
                    "#": 90,
                    "Msg": "Да! Всегда готов!",
                    "AMsg.Num": "20",
                    "_orig_danswer": "DAnswer('restart~'+CT(\"Script.Mod_ExpBeerQuest.62\"))"
                },
                {
                    "Name": "planet",
                    "Pos.x": 720,
                    "Pos.y": 640,
                    "Type": "TDialogAnswer",
                    "Parent": -1,
                    "#": 91,
                    "Msg": "Подождите минутку... Кажется, мне нужно выйти на свежий воздух... Я сейчас...",
