                }
            ],
            "Groups": [
                {
                    "Name": "ill",
                    "Owner": 63,
                    "Group.Type": 33,
                    "CntShipMin": 1,
                    "CntShipMax": 1,
                    "SpeedMin": 100,
                    "SpeedMax": 10000,
                    "Weapon": 0,
