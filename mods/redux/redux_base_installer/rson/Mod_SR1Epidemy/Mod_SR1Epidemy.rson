                }
            ],
            "Operations": [
                {
                    "Name": "",
                    "Code.Type": "Global",
                    "Code": [
                        "if(GRunFrom==3 && CurTurn()-GLastTurnRun(GScriptName)>1095) {",
                        "  if(!ill_Run) {",
                        "    GRun();",
                        "  }",
                        "}"
                    ],
                    "#": 27,
                    "Type": "Top",
                    "Parent": -1,
                    "Pos.x": 0,
                    "Pos.y": 635
                },
                {
                    "Name": "",
                    "Code.Type": "Init",
                    "Code": [
                        "vBegin=CurTurn();",
                        "NoTargetToShip(GroupToShip(ill), 3); //Запрет на ограбление для ИИ",
                        "      if(CT(path+QuestNum+'.Goods')) {",
                        "          UpsurgeGoods(IdToPlanet(PlanId2), CT(path+QuestNum+'.Goods')); //На планете назначения начинается распродажа медикмаментов",
                        "      }",
                        "      else {",
                        "          AddItemToShop(IdToPlanet(PlanId2),CreateEquipment(CT(path+QuestNum+'.ObjectType'),Rnd(20,40),max(GalaxyTechLevel()-Rnd(0,2),0),PlanetRace(IdToPlanet(PlanId2))));",
                        "      }",
                        "//if(RelationToRanger(IdToPlanet(PlanId2),Player()) < 10) RelationToRanger(IdToPlanet(PlanId2),Player(),10); //Ну как бы...",
                        "",
                        "path = 'Talk.SR1Epidemy.';",
                        "QuestNum = Rnd(1,CT(path+'Count'));",
                        "",
                        "//Ищем потребные нам планеты",
                        "dword cur_star = ShipStar(Player());",
                        "if(!FindPlanet(cur_star,CT(path+QuestNum+'.PlanetNearRace'))) AllShipOut();",
                        "",
                        "StarId1 = Id(cur_star);",
                        "PlanId1 = Id(FindPlanet(cur_star,CT(path+QuestNum+'.PlanetNearRace')));",
                        "dword cur_star1 = 0;",
                        "",
                        "for(i=1;GalaxyStars()>i;i=i+1) {",
                        "    cur_star1 = StarNearbyStars(cur_star,i);",
                        "    if(round(sqrt(Dist2Star(cur_star1, cur_star))) < 20) continue;",
                        "    else if(round(sqrt(Dist2Star(cur_star1, cur_star))) > 45) {",
                        "        cur_star1 = 0;",
                        "        break;",
                        "    }",
                        "",
                        "    if(!FindPlanet(cur_star1,CT(path+QuestNum+'.PlanetToRace'))) {",
                        "        cur_star1 = 0;",
                        "        continue;",
                        "    }",
                        "}",
                        "",
                        "if(!cur_star1) {",
                        "    SFT('SR1Epidemy logging: script start failed due to not finding planets');",
                        "    AllShipOut();",
                        "}",
                        "else {",
                        "    StarId2 = Id(cur_star1);",
                        "    PlanId2 = Id(FindPlanet(cur_star1,CT(path+QuestNum+'.PlanetNearRace')));",
                        "}"
                    ],
                    "#": 28,
                    "Type": "Top",
                    "Parent": -1,
                    "Pos.x": 60,
                    "Pos.y": 635
                },
                {
                    "Name": "",
                    "Code.Type": "Turn",
                    "Code": [
                        "//vState :",
                        "//0-Игрок еще не разговаривал",
                        "//1-Игрок отказался",
                        "//2-Игрок согласился",
                        "//3-Подбор груза",
                        "//4-Игрок привез медикаменты, но не дал бедствующим",
                        "if(!vMedOk) { //Фиксируем факт покупки медикаментов на нужной планете",
                        "  if(vState==2) {",
                        "    for(i=GalaxyEvents()-1; i>=0; i=i-1) {",
                        "      if(GalaxyEventDate(i)<CurTurn()) break;",
                        "      if(CT(path+QuestNum+'.Goods')) {",
                        "          if(GalaxyEventType(i)=='PlayerBuysGoodsFromPlanet') {",
                        "              if(GalaxyEventData(i, 0)==CT(path+QuestNum+'.Goods') && GalaxyEventData(i, 3)==Id(IdToPlanet(PlanId2))) vMedOk=1;",
                        "          }",
                        "      }",
                        "      else {",
                        "          if(GalaxyEventType(i)=='PlayerBuysEquipment') {",
                        "              if(GalaxyEventData(i, 0)==CT(path+QuestNum+'.ObjectType') && GalaxyEventData(i, 3)==Id(IdToPlanet(PlanId2))) {",
                        "                  ItemExtraSpecialsAddByType(,'');",
                        "                  vMedOk=1;",
                        "              }",
                        "          }",
                        "      }",
                        "    }",
                        "  }",
                        "}"
                    ],
                    "#": 29,
                    "Type": "Top",
                    "Parent": -1,
                    "Pos.x": 120,
                    "Pos.y": 635
                },
                {
                    "Name": "",
                    "Code.Type": "Turn",
                    "Code": [
                        "if(!vState) {",
                        "  if(CountTurn(Player(), GroupToShip(ill))<5) {",
                        "    Ether(1, '', Format('<0><br>',\"<0>\",Name(CurShip))+CT(path+QuestNum+'.SendingEmail'), CurShip);",
                        "  }",
                        "}",
                        "if((CurTurn()-vBegin)>vMaxDay) { //Если время на выполнение задания истекло, корабль взрывается, задание проваливается",
                        "  ShipDestroy(CurShip);",
                        "  if(vState==2) {",
                        "    Ether(5, 'E3394CE0-4B64-4300-AC59-484317DF4BD4', '', GroupToShip(ill));",
                        "  }",
                        "}",
                        "else if(vState==1) { //То же самое, что и выше, но с выводом сообщения",
                        "  if((CurTurn()-vBegin)>=vMaxDay) {",
                        "    Ether(1, 'C4318BA0-921D-4A7C-9553-1C87F622D32F', Format(CT(path+QuestNum+'.NewsFailed'),'name',Name(CurShip),'player',ShortName(Player())), CurShip);",
                        "    ShipDestroy(CurShip);",
                        "  }",
                        "}",
                        "if(ShipInNormalSpace(CurShip)) {",
                        "  ShipFuel(GroupToShip(ill), 1);",
                        "  if(ShipInStar(Player(), GalaxyStar(StarId1-1))) {",
                        "    if(Dist(CurShip, Player())<500) { //Начало первого диалога (просьба о помощи)",
                        "      if(vState==0) {",
                        "        Dialog(dTalk, ill);",
                        "      }",
                        "      if(vState==2) { //Начало второго диалога (игрок согласился помочь)",
                        "        if(vMedOk) {",
                        "          Dialog(dTalk, ill);",
                        "        }",
                        "      }",
                        "    }",
                        "  }",
                        "}",
                        "ChangeState(1);",
                        "exit;"
                    ],
                    "#": 64,
                    "Type": "Top",
                    "Parent": -1,
                    "Pos.x": 80
                },
                {
                    "Name": "",
                    "Code.Type": "Turn",
                    "Code": [
                        "if((CurTurn()-vBegin)>4) {",
                        "  //Если время на выполнение задания истекло, корабль взрывается, задание проваливается",
                        "  Ether(5, 'E3394CE0-4B64-4300-AC59-484317DF4BD4', '', GroupToShip(ill));",
                        "  ShipDestroy(CurShip);",
                        "}",
                        "if(GoodsCount(CurShip,1)) {",
                        "  if(!vMedOk) { //Если медикаменты не с нужной планеты, корабль взрывается",
                        "    if(ShipInNormalSpace(Player()) && ShipInStar(Player(), GalaxyStar(StarId1-1))) {",
                        "      Dialog(dEnd, ill);",
                        "      ShipDestroy(CurShip);",
                        "    }",
                        "  }",
                        "  if(vMedOk) vEndDialogOk=0;",
                        "  ChangeState(2);",
                        "  exit;",
                        "}"
                    ],
                    "#": 65,
                    "Type": "Top",
                    "Parent": -1,
                    "Pos.x": 160
                },
                {
                    "Name": "",
                    "Code.Type": "Turn",
                    "Code": [
                        "if(!vEndDialogOk) {",
                        "  if(ShipInNormalSpace(Player()) && ShipInStar(Player(), GalaxyStar(StarId1-1))) {",
                        "    vEndDialogOk=Dialog(dEnd, ill);",
                        "  }",
                        "}",
                        "if(EndState) {",
                        "  NoTargetToShip(GroupToShip(ill), 0);",
                        "  ShipOut();",
                        "}"
                    ],
                    "#": 66,
                    "Type": "Top",
                    "Parent": -1,
                    "Pos.x": 240
                },
                {
                    "Name": "",
                    "Code.Type": "Turn",
                    "Code": [
                        "if(vState==0) {",
                        "  tstr1 = '</color>' + Format(CT(path+QuestNum+'.TextMainAskForHelp'),'plan1',Name(IdToPlanet(PlanId1)),'GalaxyStar(StarId1-1)',Name(GalaxyStar(StarId1-1)),'plan2',Name(IdToPlanet(PlanId2)),'GalaxyStar(StarId1-1)',Name(GalaxyStar(StarId2-1)),'money',GalaxyMoney(2),'name',Name(Player()));",
                        "  tstr2 = '</color>' + Format(CT(path+QuestNum+'.TextMainRefuse'),'plan1',Name(IdToPlanet(PlanId1)),'GalaxyStar(StarId1-1)',Name(GalaxyStar(StarId1-1)),'plan2',Name(IdToPlanet(PlanId2)),'GalaxyStar(StarId1-1)',Name(GalaxyStar(StarId2-1)),'money',GalaxyMoney(2),'name',Name(Player()));",
                        "  tstr3 = '</color>' + Format(CT(path+QuestNum+'.TextMainAgree1'),'plan1',Name(IdToPlanet(PlanId1)),'GalaxyStar(StarId1-1)',Name(GalaxyStar(StarId1-1)),'plan2',Name(IdToPlanet(PlanId2)),'GalaxyStar(StarId1-1)',Name(GalaxyStar(StarId2-1)),'money',GalaxyMoney(2),'name',Name(Player()));",
                        "  DChange(0);",
                        "  exit;",
                        "}",
                        "if(vState==4) {",
                        "  tstr1 = '</color>' + CT(path+QuestNum+'.TextDying');",
                        "  DChange(14);",
                        "  exit;",
                        "}",
                        "if(vState==1) {",
                        "  tstr1 = '</color>' + CT(path+QuestNum+'.TextRefused');",
                        "  DChange(13);",
                        "  exit;",
                        "}",
                        "if(vState==2) {",
                        "  tstr1 = '</color>' + Format(CT(path+QuestNum+'.TextWeWait'),'plan1',Name(IdToPlanet(PlanId1)),'GalaxyStar(StarId1-1)',Name(GalaxyStar(StarId1-1)),'plan2',Name(IdToPlanet(PlanId2)),'GalaxyStar(StarId1-1)',Name(GalaxyStar(StarId2-1)),'money',GalaxyMoney(2),'name',Name(Player()));",
                        "  DChange(4);",
                        "  exit;",
                        "  if((CurTurn()-vBegin)>=vMaxDay/2) {",
                        "    tstr1 = '</color>' + Format(CT(path+QuestNum+'.TextFlyNearer'),'plan1',Name(IdToPlanet(PlanId1)),'GalaxyStar(StarId1-1)',Name(GalaxyStar(StarId1-1)),'plan2',Name(IdToPlanet(PlanId2)),'GalaxyStar(StarId1-1)',Name(GalaxyStar(StarId2-1)),'money',GalaxyMoney(2),'name',Name(Player()));",
                        "    DChange(5);",
                        "    exit;",
                        "    if(Dist(CurShip,Player())<500) {",
                        "      tstr3 = '</color>' + Format(CT(path+QuestNum+'.TextMainA3'),'plan1',Name(IdToPlanet(PlanId1)),'GalaxyStar(StarId1-1)',Name(GalaxyStar(StarId1-1)),'plan2',Name(IdToPlanet(PlanId2)),'GalaxyStar(StarId1-1)',Name(GalaxyStar(StarId2-1)),'money',GalaxyMoney(2),'name',Name(Player()));",
