                    "Pos.x": 240
                },
                {
                    "Name": "",
                    "Code.Type": "Turn",
                    "Code": [
                        "if(!Hit(CurShip) && PelengWasAttackedFlag) {",
                        "  AllShipOut();",
                        "}",
                        "if(ItemIn(Zond,GroupToShip(Peleng))) {",
                        "  ChangeState(2);",
                        "  exit;",
                        "}",
                        "if(!PelengWasAttackedFlag) {",
                        "  if(Hit()) {",
                        "    ChangeGlobalRelationsShips(Player(),GroupToShip(Peleng),0,0,ffffh,ffffh);",
                        "    ChangeState(6);",
                        "    exit;",
                        "  }",
                        "}"
