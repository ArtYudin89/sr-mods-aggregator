                        "    if(vTalkRnd<330) {",
                        "      DChange(3);",
                        "      exit;",
                        "    }",
                        "    if((vTalkRnd>=330) && (vTalkRnd<660)) {",
                        "      DChange(4);",
                        "      exit;",
                        "    }",
                        "    if(vTalkRnd>=660) {",
                        "      DChange(5);",
                        "      exit;",
                        "    }",
                        "  }",
                        "  if(vTalkPelengTimesCnt==0) {",
                        "    script02_Run=script02_Run+1;",
                        "    DChange(0);",
                        "    exit;",
                        "  }",
                        "}",
