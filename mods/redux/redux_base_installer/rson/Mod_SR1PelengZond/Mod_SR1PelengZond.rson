                }
            ],
            "Operations": [
                {
                    "Name": "",
                    "Code.Type": "Global",
                    "Code": [
                        "if(GRunFrom==3) {",
                        "    if(GalaxyTechLevel() > 2) {",
                        "        if((CurTurn()-GLastTurnRun(GScriptName,0))>1030) {",
                        "            GRun();",
                        "        }",
                        "    }",
                        "}"
                    ],
                    "#": 20,
                    "Type": "Top",
                    "Parent": -1,
                    "Pos.x": 0,
                    "Pos.y": 635
                },
                {
                    "Name": "",
                    "Code.Type": "Init",
                    "Code": [
                        "function PelengActcode() {",
                        "    if(ScriptItemActionType(t_OnStep)) exit;",
                        "    PelengWasAttackedFlag = 1;",
                        "    ShipSetBad(ScriptItemActShip(),ScriptItemActObject1());",
                        "}",
                        "",
                        "SetName(GroupToShip(Peleng),CT(\"Script.Mod_SR1PelengZond.0\"));",
                        "vBeginTurn=CurTurn();"
                    ],
                    "#": 21,
                    "Type": "Top",
                    "Parent": -1,
                    "Pos.x": 60,
                    "Pos.y": 635
                },
                {
                    "Name": "",
                    "Code.Type": "Turn",
                    "Code": [
                        "if(CurTurn() - vBeginTurn == 30) {",
                        "    if(GroupCount(Peleng) && GroupCount(Base)) {",
                        "        for(i=0;i<3;i=i+1) {",
                        "            tdwd = BuyWarrior(NearCivilPlanet(GroupToShip(Base)));",
                        "            ShipJoin(Defenders,tdwd);",
                        "        }",
                        "    }",
                        "}",
                        "if(ItemIn(Zond,Player())) {",
                        "  if(!ShipInStar(Player(),Star1)) {",
                        "    if(ShipInNormalSpace(Player())) {",
                        "      ItemDestroy(Zond,2);",
                        "      ShipOut(Player());",
                        "      ShipOut(GroupToShip(Peleng));",
                        "      ShipOut(GroupToShip(Base));",
                        "      Exit;",
                        "      if(EtherState('CA27AECF-033D-47F8-ACAE-C7F7BF607914')==3) {",
                        "        Ether(5,'CA27AECF-033D-47F8-ACAE-C7F7BF607914',CT(\"Script.Mod_SR1PelengZond.2\"));",
                        "      }",
                        "    }",
                        "  }",
                        "}",
                        "if(!ShipInStar(Player(),Star1)) {",
                        "  ItemDestroy(Zond,1);",
                        "  ShipOut(Player());",
                        "  ShipOut(GroupToShip(Peleng));",
                        "  ShipOut(GroupToShip(Base));",
                        "  Exit;",
                        "}",
                        "if(!CountIn(Base)) {",
                        "  if(vBaseTalkState==2) {",
                        "    if(!ItemExist(Zond)) {",
                        "      ShipOut(Player());",
                        "      ShipOut(GroupToShip(Peleng));",
                        "      ShipOut(GroupToShip(Base));",
                        "      Exit;",
                        "      if(EtherState('CA27AECF-033D-47F8-ACAE-C7F7BF607914')==3) {",
                        "        Ether(5,'CA27AECF-033D-47F8-ACAE-C7F7BF607914',CT(\"Script.Mod_SR1PelengZond.2\"));",
                        "      }",
                        "    }",
                        "  }",
                        "}",
                        "if(CountIn(Peleng)) {",
                        "  if(!ItemExist(Zond)) {",
                        "    ChangeGlobalRelationsShips(Player(),GroupToShip(Peleng),0,0,ffffh,ffffh);",
                        "    ShipSetBad(GroupToShip(Peleng),Player());",
                        "    ShipOut(Player());",
                        "    ShipOut(GroupToShip(Peleng));",
                        "    ShipOut(GroupToShip(Base));",
                        "    Exit;",
                        "    if(EtherState('CA27AECF-033D-47F8-ACAE-C7F7BF607914')==3) {",
                        "      Ether(5,'CA27AECF-033D-47F8-ACAE-C7F7BF607914',CT(\"Script.Mod_SR1PelengZond.2\"));",
                        "    }",
                        "  }",
                        "}"
                    ],
                    "#": 22,
                    "Type": "Top",
                    "Parent": -1,
                    "Pos.x": 120,
                    "Pos.y": 635
                },
                {
                    "Name": "",
                    "Code.Type": "Turn",
                    "Code": [
                        "if(vBaseTalkState==2) {",
                        "  if(ShipInNormalSpace(Player())) {",
                        "    if((CurTurn()-vBeginTurn)>5) {",
                        "      ItemDestroy(Zond,2);",
                        "    }",
                        "  }",
                        "  if(!ItemExist(Zond)) {",
                        "    if(!Hit(CurShip)) {",
                        "      if(Dialog(dBaseTalk,Base)) {",
                        "        ShipOut(Player());",
                        "        ShipOut(GroupToShip(Peleng));",
                        "        ShipOut(GroupToShip(Base));",
                        "        Exit;",
                        "        if(EtherState('CA27AECF-033D-47F8-ACAE-C7F7BF607914')==3) {",
                        "          Ether(5,'CA27AECF-033D-47F8-ACAE-C7F7BF607914',CT(\"Script.Mod_SR1PelengZond.2\"));",
                        "        }",
                        "      }",
                        "    }",
                        "    if(Hit(CurShip)) {",
                        "      if(Dialog(dBaseTalk,Base)) {",
                        "        if(Dialog(dBaseTalk,Base)) {",
                        "          ShipOut(Player());",
                        "          ShipOut(GroupToShip(Peleng));",
                        "          ShipOut(GroupToShip(Base));",
                        "          Exit;",
                        "          if(EtherState('CA27AECF-033D-47F8-ACAE-C7F7BF607914')==3) {",
                        "            Ether(5,'CA27AECF-033D-47F8-ACAE-C7F7BF607914',CT(\"Script.Mod_SR1PelengZond.2\"));",
                        "          }",
                        "        }",
                        "      }",
                        "    }",
                        "  }",
                        "}",
                        "if(vBaseTalkState==1) {",
                        "  if(!CountIn(Peleng)) {",
                        "    Dialog(dBaseTalk,Base);",
                        "  }",
                        "}"
                    ],
                    "#": 64,
                    "Type": "Top",
                    "Parent": -1,
                    "Pos.x": 80
                },
                {
                    "Name": "",
                    "Code.Type": "Turn",
                    "Code": [
                        "if(!Hit(CurShip) && PelengWasAttackedFlag) {",
                        "  ChangeState(4);",
                        "  exit;",
                        "}",
                        "if(ItemIn(Zond,Player())) {",
                        "  Dialog(dPelengTalk,Peleng);",
                        "  vBeginTurn=CurTurn();",
                        "}",
                        "if(vPelengTalkState==2) {",
                        "  ChangeState(3);",
                        "  exit;",
                        "}",
                        "if(Hit()) {",
                        "  ChangeGlobalRelationsShips(Player(),GroupToShip(Peleng),0,0,ffffh,ffffh);",
                        "  ChangeState(5);",
                        "  exit;",
                        "}",
                        "if(ItemIn(Zond,CurShip)) {",
                        "  if(Dist(GroupToShip(Base),CurShip)<150) {",
                        "    DropScriptItem(CurShip,Zond);",
                        "  }",
                        "}",
                        "if(!ItemIn(Zond,Player())) {",
                        "  if(vScript02Activated==1) {",
                        "    if((CurTurn()-vBeginTurn)>10) {",
                        "      ShipOut(Player());",
                        "      ShipOut(GroupToShip(Peleng));",
                        "      ShipOut(GroupToShip(Base));",
                        "      Exit;",
                        "      if(EtherState('CA27AECF-033D-47F8-ACAE-C7F7BF607914')==3) {",
                        "        Ether(5,'CA27AECF-033D-47F8-ACAE-C7F7BF607914',CT(\"Script.Mod_SR1PelengZond.2\"));",
                        "      }",
                        "    }",
                        "  }",
                        "}"
                    ],
                    "#": 65,
                    "Type": "Top",
                    "Parent": -1,
                    "Pos.x": 160
                },
                {
                    "Name": "",
                    "Code.Type": "Turn",
                    "Code": [
                        "if(vPelengTalkState==1) {",
                        "  ChangeState(4);",
                        "  exit;",
                        "}",
                        "if(vPelengTalkState==2) {",
                        "  if(ShipInNormalSpace(Player())) {",
                        "    vBeginTurn=CurTurn();",
                        "  }",
                        "}",
                        "if(Hit()) {",
                        "  ChangeGlobalRelationsShips(Player(),GroupToShip(Peleng),0,0,ffffh,ffffh);",
                        "  ChangeState(7);",
                        "  exit;",
                        "}"
                    ],
