                },
                {
                    "Name": "",
                    "Code.Type": "Turn",
                    "Code": [
                        "if(ShipInHyperSpace(CurShip))",
                        "{",
                        "    //Если стартовую систему захватили враги и возвращаться военному некуда",
                        "    if(StarOwner(PlayerStar)) ShipOut(CurShip);",
                        "}",
