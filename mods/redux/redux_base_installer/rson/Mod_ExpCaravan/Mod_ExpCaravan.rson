                        "    else if(RelationToRanger(tdw, Player()) >= 10 && RelationToRanger(tdw, Player()) < 75) tstr = '</color>' + CT(\"Script.Mod_ExpCaravan.16\");",
                        "    else tstr = '</color>' + CT(\"Script.Mod_ExpCaravan.15\");",
                        "}",
                        "else tstr = '</color>' + CT(\"Script.Mod_ExpCaravan.15\");",
                        "DChange(0);",
