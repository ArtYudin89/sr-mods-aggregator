                {
                    "Name": "",
                    "Code.Type": "Turn",
                    "Code": [
                        "//Пират сбежал, а если ему повезло, то ещё и прихватил с собой контейнер",
                        "if(ShipInHyperSpace(CurShip))",
                        "{",
                        "    if(ItemIn(Cargo_1, CurShip)) cargoStolen = cargoStolen + 1;",
