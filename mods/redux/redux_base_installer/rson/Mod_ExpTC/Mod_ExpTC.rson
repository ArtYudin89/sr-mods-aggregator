                {
                    "Name": "",
                    "Code.Type": "Turn",
                    "Code": [
                        "for(i=0;ShipItems(Player())>i;i=i+1) {",
                        "    if(ItemType(ShipItems(Player(),i)) == t_Engine) {",
                        "        if(ready == 1) continue;",
                        "        if(ready == 3) continue;",
                        "        if(ItemIsInUse(ShipItems(Player(),i))) continue;",
                        "        if(ItemIsInSet(ShipItems(Player(),i))) continue;",
                        "        if(ready == 2) ready = 3;",
                        "        else ready = 1;",
                        "    }",
                        "    if(ItemType(ShipItems(Player(),i)) == t_FuelTanks) {",
                        "        if(ready == 2) continue;",
                        "        if(ready == 3) continue;",
                        "        if(ItemIsInUse(ShipItems(Player(),i))) continue;",
                        "        if(ItemIsInSet(ShipItems(Player(),i))) continue;",
                        "        if(ready == 1) ready = 3;",
                        "        else ready = 2;",
                        "    }",
                        "",
                        "    if(ready == 3) break;",
                        "}",
                        "DChange(31);",
                        "exit;"
                    ],
