                        "    else if(i == 5) temp_str = 'Droid';",
                        "    else if(i == 6) temp_str = 'Hook';",
                        "    else if(i == 7) temp_str = 'DefGenerator';",
                        "    else if(i == 8) temp_str = 'Forsage';",
                        "",
                        "    if(ItemExtraSpecialsCountByType(ShipItems(Player(), 0), FindBonusByNameInCfg('ExpTC_AddSlot' + temp_str))) {",
                        "        temp_dword_2 = temp_dword_2 + 12;",
                        "    }",
                        "    if(ItemExtraSpecialsCountByType(ShipItems(Player(), 0), FindBonusByNameInCfg('ExpTC_DeleteSlot' + temp_str))) {",
                        "        temp_dword_2 = temp_dword_2 - 5;",
                        "    }",
                        "}",
