                        "if(ShipEqInSlot(temp_dword_3,t_Engine)) FreeItem(GetItemFromShip(temp_dword_3,ShipEqInSlot(temp_dword_3,t_Engine)));",
                        "if(ShipEqInSlot(temp_dword_3,t_FuelTanks)) FreeItem(GetItemFromShip(temp_dword_3,ShipEqInSlot(temp_dword_3,t_FuelTanks)));",
                        "temp_dword = GetItemFromVault('ExpTC_TrancEngine');",
                        "AddItemToShip(temp_dword_3,temp_dword);",
                        "ItemIsInUse(temp_dword,temp_dword_3,1);",
                        "temp_dword = GetItemFromVault('ExpTC_TrancFuelTanks');",
                        "AddItemToShip(temp_dword_3,temp_dword);",
                        "ItemIsInUse(temp_dword,temp_dword_3,1);",
                        "ArrangeItems(temp_dword_3);",
                        "DChange(33);",
                        "exit;"
