                    "_orig_danswer": "DAnswer('hangar~'+CT(\"Script.Mod_RevDominatorSpy.45\"))"
                },
                {
                    "Name": "exit",
                    "Pos.x": 120,
                    "Pos.y": 540,
                    "Type": "TDialogAnswer",
                    "Parent": -1,
                    "#": 72,
                    "Msg": "",
                    "AMsg.Num": "1",
                    "_orig_danswer": "DAnswer('exit')"
                },
                {
                    "Name": "",
                    "Pos.x": 240,
                    "Pos.y": 540,
                    "Type": "TDialogAnswer",
                    "Parent": -1,
                    "#": 73,
                    "Msg": "Мне твои планы сдала здешняя научная база. Не знаю, откуда ей о них стало известно - меня интересует лишь твой груз. Зонд выбрасывай, пока не стало поздно",
                    "AMsg.Num": "2",
                    "_orig_danswer": "DAnswer(CT(\"Script.Mod_RevDominatorSpy.53\"))"
                },
                {
                    "Name": "",
                    "Pos.x": 360,
                    "Pos.y": 540,
                    "Type": "TDialogAnswer",
                    "Parent": -1,
                    "#": 74,
                    "Msg": "Интересуюсь, конечно. Но вознаграждением больше",
                    "AMsg.Num": "3",
                    "_orig_danswer": "DAnswer(CT(\"Script.Mod_RevDominatorSpy.47\"))"
                },
                {
                    "Name": "",
                    "Pos.x": 480,
                    "Pos.y": 540,
                    "Type": "TDialogAnswer",
                    "Parent": -1,
                    "#": 75,
                    "Msg": "И я должен буду уничтожить этого робота?",
                    "AMsg.Num": "4",
                    "_orig_danswer": "DAnswer(CT(\"Script.Mod_RevDominatorSpy.19\"))"
                },
                {
                    "Name": "",
                    "Pos.x": 600,
                    "Pos.y": 540,
                    "Type": "TDialogAnswer",
                    "Parent": -1,
                    "#": 76,
                    "Msg": "А как же остальные доминаторы?",
                    "AMsg.Num": "5",
                    "_orig_danswer": "DAnswer(CT(\"Script.Mod_RevDominatorSpy.20\"))"
                },
                {
                    "Name": "hangar",
                    "Pos.x": 720,
                    "Pos.y": 540,
                    "Type": "TDialogAnswer",
                    "Parent": -1,
                    "#": 77,
                    "Msg": "Ждите, скоро все данные будут собраны",
                    "AMsg.Num": "6",
                    "_orig_danswer": "DAnswer('hangar~'+CT(\"Script.Mod_RevDominatorSpy.48\"))"
                },
                {
                    "Name": "hangar",
                    "Pos.x": 840,
                    "Pos.y": 540,
                    "Type": "TDialogAnswer",
                    "Parent": -1,
                    "#": 78,
                    "Msg": "Вылетаю",
                    "AMsg.Num": "7",
                    "_orig_danswer": "DAnswer('hangar~'+CT(\"Script.Mod_RevDominatorSpy.40\"))"
                },
                {
