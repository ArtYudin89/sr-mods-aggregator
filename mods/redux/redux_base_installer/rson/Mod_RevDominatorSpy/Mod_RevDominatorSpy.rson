                    "Code": [
                        "if(!Run) {",
                        "    if(GLastTurnRun(GScriptName) == 0 || GLastTurnRun(GScriptName) + 2000 < CurTurn()) {",
                        "        if(GRunFrom==3) {",
                        "            if(CurTurn()>1342) {",
                        "                GRun();",
