                    "Code": [
                        "//Чтобы наверняка не было NameError",
                        "tstr = Format(CT(\"Script.Mod_RevDominatorSpy.96\"),'name',Name(PelengSpy));",
                        "if(Hitpoints(CurShip)<200 && Dist(PlaceSB,CurShip)<3000) {",
                        "  Dialog(dDiplomat,PelengSpy);",
                        "}",
                        "if(ShipInStar(CurShip,Star1)) {",
                        "  ChangeState(2);",
                        "  exit;",
                        "}"
                    ],
                    "#": 82,
                    "Type": "Top",
                    "Parent": -1,
                    "Pos.x": 80
                },
                {
                    "Name": "",
                    "Code.Type": "Turn",
                    "Code": [
                        "if(Hitpoints(CurShip)<200 && Dist(PlaceSB,CurShip)<3000) {",
                        "  Dialog(dDiplomat,PelengSpy);",
                        "}",
                        "if(ItemIn(iOP,Player())) {",
                        "  ShipSetBad(GroupToShip(PelengSpy),Player());",
                        "  ShipOut(GroupToShip(PelengSpy));",
                        "}",
                        "if(vZondDaysPe>=30) {",
                        "  ChangeState(5);",
                        "  exit;",
                        "}",
                        "if(!ItemExist(iOP)) {",
                        "  ShipSetBad(GroupToShip(PelengSpy),Player());",
                        "  if(GroupToShip(BigShip))ShipOut(GroupToShip(BigShip));",
                        "  if(GroupToShip(SmallShip))",
                        "      {",
                        "      for(i=GroupCount(SmallShip)-1;i>=0;i=i-1)ShipOut(GroupShip(SmallShip,i));",
                        "      }",
                        "  if(GroupToShip(BSB))ShipOut(GroupToShip(BSB));",
                        "  if(GroupToShip(PelengSpy))",
                        "      {",
                        "      NoTargetToShip(GroupToShip(PelengSpy),0);",
                        "      ShipOut(GroupToShip(PelengSpy));",
                        "      }",
                        "}"
