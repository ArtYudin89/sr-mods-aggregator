                        "if(!vStartScript) {",
                        "  vStartScript=1;",
                        "  //спавн штипов нужной подрасы",
                        "  for(i=12;i>0;i=i-1) ShipJoin(SmallShip,BuyDomikExtremal(PlanetDom,5));",
                        "  ShipDestroy(GroupToShip(SmallShip),1);",
                        "  //спавним эквентора нужной подрасы",
                        "  ShipJoin(BigShip,BuyDomikExtremal(PlanetDom,1));",
                        "  ShipDestroy(GroupToShip(BigShip),1);",
                        "}",
                        "if(MyProbe==1) { //Заполнение зонда информацией",
                        "  if(!vHitK1) {",
                        "    if(CountIn(BigShip)) {",
                        "      if(ItemExist(iOP)) {",
                        "        if(ShipInStar(Player(),StarDom)) {",
                        "          if(Dist(POP,GroupToShip(BigShip))<300) {",
                        "            if(!ItemIn(iOP,Player())) {",
                        "              vHour=Rnd(0,23);",
                        "              vMin=Rnd(0,59);",
                        "              vSec=Rnd(0,59);",
                        "              if(vZondMemory>=96) { //Вывод уведомление о возвращении на базу",
                        "                CustomEther('Scanned',2,'008DB316-DEE1-4BE1-A6BF-875942EC3671',Format(CT(\"Script.Mod_RevDominatorSpy.83\"),\"<0>\",GameDateTxtByTurn(CurTurn()),\"<1>\",vHour,\"<2>\",vMin,\"<3>\",vSec));",
                        "              }",
                        "              if(vZondMemory<96) { //Вывод уведомления о прогрессе сбора информации",
                        "                CustomEther('Scanned',2,'008DB316-DEE1-4BE1-A6BF-875942EC3671',Format(CT(\"Script.Mod_RevDominatorSpy.82\"),\"<0>\",GameDateTxtByTurn(CurTurn()),\"<1>\",vHour,\"<2>\",vMin,\"<3>\",vSec,\"<4>\",vZondMemory,\"<5>\",(100-vZondMemory)));",
                        "                vZondDaysPl=vZondDaysPl+1;",
                        "                if(vStateDom<4) vZondMemory=vZondMemory+Rnd(3,7);",
                        "              }",
                        "            }",
                        "          }",
                        "        }",
                        "      }",
                        "    }",
                        "  }",
                        "}",
                        "if(vZondDaysPl>=30) { //Если зонд собирал информацию 30 дней",
                        "  vStateDom=3; //Задание выполнено, время возвращаться на НБ",
                        "}",
                        "if(vStateDom==4) { //Отсчет 5 дней до взрыва зонда после сдачи на НБ",
                        "  vZondDaysPl=vZondDaysPl+1;",
                        "  if(vStateDom<4) vZondMemory=vZondMemory+3;",
                        "  if(vZondDaysPl>=5) {",
                        "    vStateDom=5;",
                        "    ItemDestroy(iOP,2);",
                        "  }",
                        "}",
                        "if(vStateDom!=2) { //Игрок еще не получил зонд",
                        "  if(!playerKillsSpy) {",
                        "    for(i=GalaxyEvents()-1; i>=0; i=i-1) {  //Перебираем все сегодняшние ивенты, в которых игрок, его транклюкатор или напарник, уничтожает или помогает в уничтожении корабля",
                        "      if(GalaxyEventDate(i)<CurTurn()) break;",
                        "      if(GalaxyEventType(i)=='PlayerKillsShip' || GalaxyEventType(i)=='PlayerAssistKillsShip' || GalaxyEventType(i)=='PlayerTranclucatorKillsShip' || GalaxyEventType(i)=='PlayerTranclucatorAssistKillsShip' || GalaxyEventType(i)=='PlayerCompanionKillsShip' || GalaxyEventType(i)=='PlayerCompanionAssistKillsShip') {",
                        "        if(GalaxyEventData(i,2)!=spyId) continue;  //Пропускаем все, что не относится к шпиону",
                        "        else {  //Фиксируем факт уничтожения/помощи",
                        "          playerKillsSpy=1;",
                        "          break;",
                        "        }",
                        "      }",
                        "    }",
                        "  }",
                        "  if(ItemExist(iOP)) { //Зонд существует",
                        "    if(ItemIn(iOP,Player())) { //Игрок подобрал зонд",
                        "      vStateDom=2;",
                        "      MyProbe=1;",
                        "      Ether(3,'RevDomSpyEther',Format(CT(\"Script.Mod_RevDominatorSpy.34\"),\"<0>\",Name(StarDom),\"<1>\",Name(GroupToShip(BigShip)),\"<2>\",90));",
                        "      if(playerKillsSpy) ChangeGlobalRelationsPlanets(Player(),0,3,20,2);",
                        "    }",
                        "  }",
                        "}",
                        "if(!ItemExist(iOP)) {",
                        "  if(vStateDom<4) {",
                        "    if(GroupToShip(BigShip))ShipOut(GroupToShip(BigShip));",
                        "    if(GroupToShip(SmallShip))",
                        "        {",
                        "        for(i=GroupCount(SmallShip)-1;i>=0;i=i-1)ShipOut(GroupShip(SmallShip,i));",
                        "        }",
                        "    if(GroupToShip(BSB))ShipOut(GroupToShip(BSB));",
                        "    if(GroupToShip(PelengSpy))",
                        "        {",
                        "        NoTargetToShip(GroupToShip(PelengSpy),0);",
                        "        ShipOut(GroupToShip(PelengSpy));",
                        "        }",
                        "    if(vStateDom==1) {",
                        "      vStateDom=128;",
                        "      Ether(5,'RevDomSpyEther','');",
                        "    }",
                        "  }",
                        "}",
                        "if(ItemExist(iOP)) {",
                        "  if(!ItemIn(iOP,PelengSpy)) {",
                        "    vZondDaysPe=vZondDaysPe+1;",
                        "  }",
                        "}",
                        "if(!CountIn(BigShip)) {",
                        "  NoTargetToShip(GroupToShip(SmallShip),0);",
                        "  ShipOut(GroupToShip(SmallShip));",
                        "  if(vStateDom<6) {",
                        "    if(GroupToShip(BigShip))ShipOut(GroupToShip(BigShip));",
                        "    if(GroupToShip(SmallShip))",
                        "        {",
                        "        for(i=GroupCount(SmallShip)-1;i>=0;i=i-1)ShipOut(GroupShip(SmallShip,i));",
                        "        }",
                        "    if(GroupToShip(BSB))ShipOut(GroupToShip(BSB));",
                        "    if(GroupToShip(PelengSpy))",
                        "        {",
                        "        NoTargetToShip(GroupToShip(PelengSpy),0);",
                        "        ShipOut(GroupToShip(PelengSpy));",
                        "        }",
                        "    if(vStateDom==1) {",
                        "      vStateDom=128;",
                        "      Ether(5,'RevDomSpyEther','');",
                        "    }",
                        "  }",
                        "}",
                        "if(!CountIn(BSB)) {",
                        "  if(vStateDom<6) {",
                        "    if(GroupToShip(BigShip))ShipOut(GroupToShip(BigShip));",
                        "    if(GroupToShip(SmallShip))",
                        "        {",
                        "        for(i=GroupCount(SmallShip)-1;i>=0;i=i-1)ShipOut(GroupShip(SmallShip,i));",
                        "        }",
                        "    if(GroupToShip(BSB))ShipOut(GroupToShip(BSB));",
                        "    if(GroupToShip(PelengSpy))",
                        "        {",
                        "        NoTargetToShip(GroupToShip(PelengSpy),0);",
                        "        ShipOut(GroupToShip(PelengSpy));",
                        "        }",
                        "    if(vStateDom==1) {",
                        "      vStateDom=128;",
                        "      Ether(5,'RevDomSpyEther','');",
                        "    }",
                        "  }",
                        "}",
                        "if(!ZondFlag) {",
                        "  if(ItemIn(iOP,Player())) {",
                        "    ZondFlag=1;",
                        "    Ether(1,'17BF4B00-296B-4D1B-A38D-AB51D64DE1EE',CT(\"Script.Mod_RevDominatorSpy.91\"));",
                        "  }",
                        "}"
                    ],
