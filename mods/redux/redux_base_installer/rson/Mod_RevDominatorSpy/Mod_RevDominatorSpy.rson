                        "DAdd(9);"
                    ],
                    "#": 101,
                    "Type": "Top",
                    "Parent": -1,
                    "Pos.x": 1330,
                    "Pos.y": 470
                },
                {
                    "Name": "",
                    "Code.Type": "Turn",
                    "Code": [
                        "DAdd(10);"
                    ],
                    "#": 102,
                    "Type": "Top",
                    "Parent": -1,
                    "Pos.x": 1480,
                    "Pos.y": 470
                },
                {
                    "Name": "",
                    "Code.Type": "Turn",
                    "Code": [
                        "vStateDom=-1;",
                        "if(GroupToShip(BigShip)) ShipOut(GroupToShip(BigShip));",
                        "if(GroupToShip(SmallShip)) {",
                        "  for(i=GroupCount(SmallShip)-1;i>=0;i=i-1) ShipOut(GroupShip(SmallShip,i));",
                        "}",
                        "if(GroupToShip(BSB)) ShipOut(GroupToShip(BSB));",
                        "if(GroupToShip(PelengSpy)) {",
                        "  NoTargetToShip(GroupToShip(PelengSpy),0);",
                        "  ShipOut(GroupToShip(PelengSpy));",
                        "}",
                        "AllShipOut();",
                        "Run = 0;"
                    ],
                    "#": 103,
                    "Type": "Top",
                    "Parent": -1,
                    "Pos.x": -20,
                    "Pos.y": 540
                },
                {
                    "Name": "",
                    "Code.Type": "Turn",
                    "Code": [
                        "DChange(10);",
                        "exit;"
                    ],
                    "#": 104,
                    "Type": "Top",
                    "Parent": -1,
                    "Pos.x": 220,
                    "Pos.y": 540
                },
                {
                    "Name": "",
                    "Code.Type": "Turn",
                    "Code": [
                        "DChange(3);",
                        "exit;"
                    ],
                    "#": 105,
                    "Type": "Top",
                    "Parent": -1,
                    "Pos.x": 340,
                    "Pos.y": 540
                },
                {
                    "Name": "",
                    "Code.Type": "Turn",
                    "Code": [
                        "if(CountIn(PelengSpy)) {",
                        "  //Часто пеленг находится не пойми где. Особенно интересно, когда пеленг находится в пиратской системе.",
                        "  //То есть через пять секунд погибнет. Или ещё чего. В общем, всё не слава богу бывает, и ломать из-за этого скрипт...",
                        "  //Это было бы неправильно. Поэтому делаем дополнительные проверки на все случаи жизни.",
                        "  NoFlag = 0;",
                        "  ",
                        "  if(StarOwner(ShipStar(GroupToShip(PelengSpy))) == 2) {",
                        "      if(ShipOrder(GroupToShip(PelengSpy)) != 7) {",
                        "          if(ShipOrder(GroupToShip(PelengSpy)) == 5) {",
                        "              if(ShipTurnBeforeEndOrder(GroupToShip(PelengSpy)) > 2) NoFlag = 1;",
                        "          }",
                        "          else NoFlag = 1;",
                        "          ReleaseItemFromScript(iOP);",
                        "      } //Если пеленг у пиратов и явно не сваливает, то он не жилец. Точка.",
                        "  }",
                        "  ",
                        "  if(NoFlag == 1) {",
                        "      ShipOut(GroupToShip(PelengSpy));",
                        "      ReleaseItemFromScript(iOP);",
                        "  }",
                        "  if(!NoFlag) {",
                        "    DChange(4);",
                        "    exit;",
                        "  }",
                        "  if(NoFlag) {",
                        "    DChange(8);",
                        "    exit;",
                        "  }",
                        "}",
                        "if(!CountIn(PelengSpy)) {",
                        "  DChange(8);",
                        "  exit;",
                        "}"
                    ],
                    "#": 106,
                    "Type": "Top",
                    "Parent": -1,
                    "Pos.x": 460,
                    "Pos.y": 540
                },
                {
                    "Name": "",
                    "Code.Type": "Turn",
                    "Code": [
                        "DChange(5);",
                        "exit;"
                    ],
                    "#": 107,
                    "Type": "Top",
                    "Parent": -1,
                    "Pos.x": 580,
                    "Pos.y": 540
                },
                {
                    "Name": "",
                    "Code.Type": "Turn",
                    "Code": [
                        "vZondMemory=0;",
                        "vStateDom=1;",
                        "if(!GroupCount(PelengSpy)) { //Если шпион где-то умер, даем игроку зонд",
                        "  if(ItemExist(iOP)) ReleaseItemFromScript(iOP);",
                        "  item=CreateQuestItem('OperatedProbe', Peleng);",
                        "  LinkItemToScript(item, iOP);",
                        "  AddItemToShip(Player(), item);",
                        "  vStateDom=2;",
                        "  MyProbe=1;",
                        "  Unzond = 1;",
                        "  Ether(3,'RevDomSpyEther',Format(CT(\"Script.Mod_RevDominatorSpy.34\"),\"<0>\",Name(StarDom),\"<1>\",Name(GroupToShip(BigShip)),\"<2>\",90));",
                        "}",
                        "else {",
                        "  Ether(3,'RevDomSpyEther',Format(CT(\"Script.Mod_RevDominatorSpy.34\"),\"<0>\",Name(StarDom),\"<1>\",Name(GroupToShip(BigShip)),\"<2>\",90));",
                        "}"
                    ],
                    "#": 108,
                    "Type": "Top",
                    "Parent": -1,
                    "Pos.x": 700,
                    "Pos.y": 540
                },
                {
                    "Name": "",
                    "Code.Type": "Turn",
                    "Code": [
                        "vStateDom=4;",
                        "vZondDaysPl=0;"
                    ],
                    "#": 109,
                    "Type": "Top",
                    "Parent": -1,
                    "Pos.x": 820,
                    "Pos.y": 540
                },
                {
                    "Name": "",
                    "Code.Type": "Turn",
                    "Code": [
                        "Sound('Sound.Buy');",
                        "vStateDom=6;",
                        "ShipMoney(Player(),ShipMoney(Player())+(vZondMemory*25)*(GalaxyMoney(0)/80));",
                        "if(GroupToShip(BigShip))ShipOut(GroupToShip(BigShip));",
                        "if(GroupToShip(SmallShip)) {",
                        "    for(i=GroupCount(SmallShip)-1;i>=0;i=i-1)ShipOut(GroupShip(SmallShip,i));",
                        "}",
                        "item=ScriptItemToItem(iOP);",
                        "ReleaseItemFromScript(iOP);",
                        "FreeItem(GetItemFromShip(Player(), item));",
                        "i=CreateQuestItem('SB_scaner',ShipOwner(GetShipRuins(Player())));",
                        "ItemSize(i,CT('UselessItems.SB_scaner.Size'));",
                        "//LinkItemToScript(i,SB_scaner);",
                        "AddItemToShip(Player(),i);",
                        "if(GroupToShip(BSB))ShipOut(GroupToShip(BSB));",
                        "if(GroupToShip(PelengSpy))ShipOut(GroupToShip(PelengSpy));",
                        "Run = 0;"
                    ],
                    "#": 110,
                    "Type": "Top",
                    "Parent": -1,
                    "Pos.x": 940,
                    "Pos.y": 540
                },
                {
                    "Name": "",
                    "Code.Type": "Turn",
                    "Code": [
                        "DropScriptItem(CurShip,iOP);",
                        "vStateDom=2;",
                        "MyProbe=1;",
                        "RelationToRanger(GroupToShip(PelengSpy),Player(),10);",
                        "NoTargetToShip(GroupToShip(PelengSpy),0);",
                        "ShipOut();"
                    ],
                    "#": 111,
                    "Type": "Top",
                    "Parent": -1,
                    "Pos.x": 1180,
                    "Pos.y": 540
                }
            ],
