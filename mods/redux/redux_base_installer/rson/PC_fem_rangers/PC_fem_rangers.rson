                        "              }",
                        "          }",
                        "          else if(tstr1 == 'PlayerTranclucatorKillsShip')",
                        "          {",
                        "              if(GalaxyEventData(counter2, 2) == enemy_id[counter])",
                        "              {",
                        "                  if(GalaxyEventData(counter2, 2) == Id(ShipStar(Player())))",
                        "                  {",
                        "                      player_helps = player_helps + 2;",
                        "                  }",
                        "              }",
                        "          }",
                        "  ",
                        "          counter2 = counter2 - 1;",
                        "      }",
                        "  ",
                        "      ArrayDelete(enemy_id, counter);",
                        "  }",
                        "  ",
                        "  //Проверка на то, что игрок или его напарник/транк уничтожил спецагентку",
                        "  while(cur_num > GroupCount(GroupFem))",
                        "  {",
                        "      counter = 0;",
                        "      while(fem_id[counter] && IdToShip(fem_id[counter])) counter = counter + 1;",
                        "  ",
                        "      counter2 = GalaxyEvents() - 1;",
                        "      while(counter2 >= 0)",
                        "      {",
                        "          if(GalaxyEventDate(counter2) < CurTurn()) break;",
                        "  ",
                        "          tstr1 = GalaxyEventType(counter2);",
                        "          if(tstr1 == 'PlayerKillsShip')",
                        "          {",
                        "              if(GalaxyEventData(counter2, 2) == fem_id[counter])",
                        "              {",
                        "                  player_hate = 1;",
                        "              }",
                        "          }",
                        "          else if(tstr1 == 'PlayerAssistKillsShip')",
                        "          {",
                        "              if(GalaxyEventData(counter2, 2) == fem_id[counter])",
                        "              {",
                        "                  player_hate = 1;",
                        "              }",
                        "          }",
                        "          else if(tstr1 == 'PlayerCompanionKillsShip')",
                        "          {",
                        "              if(GalaxyEventData(counter2, 2) == fem_id[counter])",
                        "              {",
                        "                  if(GalaxyEventData(counter2, 2) == Id(ShipStar(Player())))",
                        "                  {",
                        "                      player_hate = 1;",
                        "                  }",
                        "              }",
                        "          }",
                        "          else if(tstr1 == 'PlayerCompanionAssistKillsShip')",
                        "          {",
                        "              if(GalaxyEventData(counter2, 2) == fem_id[counter])",
                        "              {",
                        "                  if(GalaxyEventData(counter2, 2) == Id(ShipStar(Player())))",
                        "                  {",
                        "                      player_hate = 1;",
                        "                  }",
                        "              }",
                        "          }",
                        "          else if(tstr1 == 'PlayerTranclucatorKillsShip')",
                        "          {",
                        "              if(GalaxyEventData(counter2, 2) == fem_id[counter])",
                        "              {",
                        "                  if(GalaxyEventData(counter2, 2) == Id(ShipStar(Player())))",
                        "                  {",
                        "                      player_hate = 1;",
                        "                  }",
                        "              }",
                        "          }",
                        "  ",
                        "          counter2 = counter2 - 1;",
                        "      }",
                        "  ",
                        "      fem_id[counter] = 0;",
                        "      quest_data1[counter] = 0;",
                        "      quest_data2[counter] = 0;",
                        "      cur_num = cur_num - 1;",
                        "  }",
                        "  ",
                        "  //Проверка на шанс создания новой спецагентки",
                        "  if(!pirate_side_chosen)",
                        "  {",
                        "      if(!CoalitionDefeated())",
                        "      {",
                        "          check = 0;",
                        "          if(CurrentMods('Tweaks\\\\RevolutionDelayed'))",
                        "          {",
                        "              if(GetValueFromScript('Mod_RevolutionDelayed', 'pirates_begin_turn') <= CurTurn()) check = 1;",
                        "          }",
                        "          else check = 1;",
                        "  ",
                        "          if(check)",
                        "          {",
                        "              if(GroupCount(GroupFem) < min(max_num, 1 + max_num * ControlledSystems(0) / 60))",
                        "              {",
                        "                  quest_planet = 0;",
                        "                  counter = 0;",
                        "                  while(!quest_planet && counter < 5)",
                        "                  {",
                        "                      quest_star = GalaxyStar(Rnd(1, 1000) % GalaxyStars());",
                        "                      quest_planet = StarPlanets(quest_star, RndObject(1, 1000, quest_star) % StarPlanets(quest_star));",
                        "                      if(StarOwner(quest_star)) quest_planet = 0; //Выбираем только коалиционные системы",
                        "                      counter = counter + 1;",
                        "                  }",
                        "  ",
                        "                  if(quest_planet)",
                        "                  {",
                        "                      //Малокши будут появляться реже, т.к. для них доступно меньше портретов",
                        "                      tint1 = /*PlanetRace(quest_planet);",
                        "                      if(tint1 == Maloc)",
                        "                      {",
                        "                          if(RndObject(1, 100, quest_planet) <= 66) tint1 = -1;",
                        "                      }",
                        "                      else if(tint1 != People) tint1 =*/ -1;",
                        "  ",
                        "                      if(~tint1)",
                        "                      {",
                        "                          if(PlanetEco(quest_planet) == 2)",
                        "                          {",
                        "                              if(quest_planet != GetShipPlanet(Player()))",
                        "                              {",
                        "                                  //Создаём новую спецагентку",
                        "                                  g_SpawnFemRanger(quest_planet, tint1);",
                        "                              }",
                        "                          }",
                        "                      }",
                        "                  }",
                        "              }",
                        "          }",
                        "      }",
                        "  }",
                        "  ",
                        "  //Суммируем статы и меняем репутацию игрока в зависимости от совершённых им грабежей/убийств кораблей",
                        "  if(CurrentMods('Expansion\\\\ExpPilotBridge'))",
                        "  {",
                        "      player_ranger_kills = GRangStat + 2 * (GRangSpecStat + G_MCStat + G_RCStat + G_SBStat);",
                        "      //Общий счётчик GWarStat",
                        "      player_warrior_kills = GWarMilitStat + GWarPrivStat + 2 * (GWarFlagStat + GWarDreadStat + G_MBStat + G_IngBStat);",
                        "      //GCivilStat",
                        "      player_transport_kills = GCoalTranStat + GCoalLinStat + GCoalDipStat;",
                        "  ",
                        "      //Общий счётчик GPirStat",
                        "      player_pirate_kills = GPirFreeStat + GPirClanStat + GPirRebStat + GRangPirStat + GPirThugStat + GPirKhanStat + GPirCorvStat + 2 * (GPirFrigStat + GPirGallStat + G_PBStat + G_PCBStat) + GPirSmugStat / 2;",
                        "  }",
                        "  else",
                        "  {",
                        "      player_transport_kills = ShipStatistic(Player(), 4);",
                        "      player_pirate_kills = ShipStatistic(Player(), 1);",
                        "      player_warrior_kills = ShipStatistic(Player(), 5);",
                        "      player_ranger_kills = ShipStatistic(Player(), 6);",
                        "  }",
                        "  ",
                        "  str path = 'Script.PC_fem_rangers.SpecialAgentsRelations.';",
                        "  relation_shift = int(CT(path+'BeingInClanRelation')) * ShipInPirateClan(Player()) + agent_counter * int(CT(path+'CompletedMissionRelation')) + min(5, GetShipPirateRank(Player())) * int(CT(path+'ForPirateRankRelation'));",
                        "  relation_shift = relation_shift + int(CT(path+'PerPirateRelation')) * player_pirate_kills + int(CT(path+'PerHelpedFemRanger')) * player_helps;",
                        "  relation_shift = relation_shift + int(CT(path+'PerEachRobbedRelation')) * player_robs + int(CT(path+'PerKilledTransport')) * player_transport_kills + int(CT(path+'PerKilledWarrior')) * player_warrior_kills + int(CT(path+'PerKilledRanger')) * player_ranger_kills;",
                        "  max_relation = (1 - player_hate) * (100 + relation_shift);",
                        "  //max_relation = 100;",
                        "}",
                        "if(GroupCount(GroupShuCenter) && (quest_status==13)) {",
                        "  quest_ship=GroupToShip(GroupShuCenter);",
                        "  if(!ShipInNormalSpace(quest_ship) && BK_enters_BH) {",
                        "    BK_enters_BH=2;",
                        "    if (!GetShipPlanet(quest_ship) && (ShipOrderData1(quest_ship)<=1)){TransferShip(quest_ship,FindPlanet(ShipStar(quest_ship),'NotMaloc,NotPeleng,NotPeople,NotFei,NotGaal,NotPirateClan',0,100));}",
                        "    quest_hole=0;",
                        "    counter=0;",
                        "    while (counter<StarHoles(ShipStar(quest_ship))){",
                        "    if (Id(StarHoles(ShipStar(quest_ship),counter))==hole_id){",
                        "    if (HoleTurnCreate(StarHoles(ShipStar(quest_ship),counter))==hole_create_turn){",
                        "    quest_hole=StarHoles(ShipStar(quest_ship),counter);}}",
                        "    counter=counter+1;}",
                        "    if(ShipInHyperSpace(Player()) && (ShipOrderObj(Player())==quest_hole) && (quest_status==13)) {",
                        "      if (GABStatus==0){",
                        "      if (!GetShipPlanet(quest_ship)){TransferShip(quest_ship,FindPlanet(ShipStar(quest_ship),'NotMaloc,NotPeleng,NotPeople,NotFei,NotGaal,NotPirateClan',0,100));}",
                        "      ConvertToABShip(quest_ship);",
                        "      //CreateABShip('Ruins.BK',0,1000,150);",
                        "      CreateABShip('Ship.Peleng.PirateClan',0,100,150);",
                        "      CreateABShip('Ship.Peleng.PirateClan',0,100,150);",
                        "      CreateABShip('Ship.Peleng.PirateClan',0,100,150);",
                        "      ab_starts=1;",
                        "      StartAB('ABMap.map_2');//1-15",
                        "      }",
                        "    }",
                        "  }",
                        "}"
