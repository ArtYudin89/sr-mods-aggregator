            "Operations": [
                {
                    "Name": "",
                    "Code.Type": "Global",
                    "Code": [
                        "GRun();"
                    ],
                    "#": 163,
                    "Type": "Top",
                    "Parent": -1,
                    "Pos.x": 0,
                    "Pos.y": 1485
                },
                {
                    "Name": "",
                    "Code.Type": "Init",
                    "Code": [
                        "bonus_mm = newarray(1);",
                        "",
                        "ModInit();",
                        "mod_init_done = 1;",
                        "function ModInit()",
                        "{",
                        "    free(fem_names);",
                        "    fem_names = newarray(5, 1);",
                        "",
                        "    ArrayDelete(fem_names[0], 0);",
                        "    for(i = 1; i <= CT('Script.PC_fem_rangers.SecretAgentNames.Maloc.Count'); i = i + 1)",
                        "    {",
                        "        ArrayAdd(fem_names[0], CT('Script.PC_fem_rangers.SecretAgentNames.Maloc.' + i));",
                        "    }",
                        "    ArrayDelete(fem_names[2], 0);",
                        "    for(i = 1; i <= CT('Script.PC_fem_rangers.SecretAgentNames.People.Count'); i = i + 1)",
                        "    {",
                        "        ArrayAdd(fem_names[2], CT('Script.PC_fem_rangers.SecretAgentNames.People.' + i));",
                        "    }",
                        "",
                        "    free(hull_names);",
                        "    hull_names = newarray(5, 1);",
                        "",
                        "    ArrayDelete(hull_names[0], 0);",
                        "    ArrayAdd(hull_names[0], 'EvoFemRangers_SecretAgentMaloc1', 'GTL1'); //Корпус \"Ужастик\" II",
                        "    ArrayAdd(hull_names[0], 'EvoFemRangers_SecretAgentMaloc1', 'GTL2');",
                        "    ArrayAdd(hull_names[0], 'EvoFemRangers_SecretAgentMaloc2', 'GTL3');",
                        "    ArrayAdd(hull_names[0], 'EvoFemRangers_SecretAgentMaloc2', 'GTL4'); //Корпус \"Ужастик\" III",
                        "    ArrayAdd(hull_names[0], 'EvoFemRangers_SecretAgentMaloc3', 'GTL5');",
                        "    ArrayAdd(hull_names[0], 'EvoFemRangers_SecretAgentMaloc3', 'GTL6');",
                        "    ArrayAdd(hull_names[0], 'EvoFemRangers_SecretAgentMaloc4', 'GTL7'); //Корпус \"Ужастик\" IV",
                        "    ArrayAdd(hull_names[0], 'EvoFemRangers_SecretAgentMaloc4', 'GTL8');",
                        "",
                        "    ArrayDelete(hull_names[2], 0);",
                        "    ArrayAdd(hull_names[2], '480', 'GTL1'); //Корпус \"Ушастик\" II",
                        "    ArrayAdd(hull_names[2], '480', 'GTL2');",
                        "    ArrayAdd(hull_names[2], '481', 'GTL3');",
                        "    ArrayAdd(hull_names[2], '481', 'GTL4'); //Корпус \"Ушастик\" III",
                        "    ArrayAdd(hull_names[2], '482', 'GTL5');",
                        "    ArrayAdd(hull_names[2], '482', 'GTL6');",
                        "    ArrayAdd(hull_names[2], '483', 'GTL7'); //Корпус \"Ушастик\" IV",
                        "    ArrayAdd(hull_names[2], '483', 'GTL8');",
                        "}",
                        "",
                        "item_names = newarray(1);",
                        "item_names[0] = 'Usl_RandomItem_01';",
                        "ArrayAdd(item_names, 'Usl_RandomItem_02');",
                        "ArrayAdd(item_names,'Usl_RandomItem_03');",
                        "ArrayAdd(item_names, 'Usl_RandomItem_04');",
                        "",
                        "bonus_arts = newarray(1);",
                        "bonus_arts[0] = t_ArtefactHull;",
                        "ArrayAdd(bonus_arts, t_ArtefactFuel);",
                        "ArrayAdd(bonus_arts, t_ArtefactSpeed);",
                        "ArrayAdd(bonus_arts, t_ArtefactPower);",
                        "ArrayAdd(bonus_arts, t_ArtefactRadar);",
                        "ArrayAdd(bonus_arts, t_ArtefactScaner);",
                        "ArrayAdd(bonus_arts, t_ArtefactDroid);",
                        "ArrayAdd(bonus_arts, t_ArtefactNano);",
                        "ArrayAdd(bonus_arts, t_ArtefactHook);",
                        "ArrayAdd(bonus_arts, t_ArtefactDef);",
                        "ArrayAdd(bonus_arts, t_ArtefactMiniExpl);",
                        "ArrayAdd(bonus_arts, t_ArtefactAntigrav);",
                        "ArrayAdd(bonus_arts, t_ArtDefToEnergy);",
                        "ArrayAdd(bonus_arts, t_ArtEnergyPulse);",
                        "ArrayAdd(bonus_arts, t_ArtEnergyDef);",
                        "ArrayAdd(bonus_arts, t_ArtSplinter);",
                        "ArrayAdd(bonus_arts, t_ArtDecelerate);",
                        "ArrayAdd(bonus_arts, t_ArtMissileDef);",
                        "ArrayAdd(bonus_arts, t_ArtForsage);",
                        "ArrayAdd(bonus_arts, t_ArtWeaponToSpeed);",
                        "ArrayAdd(bonus_arts, t_ArtGiperJump);",
                        "ArrayAdd(bonus_arts, t_ArtDefToArms1);",
                        "ArrayAdd(bonus_arts, t_ArtDefToArms2);",
                        "ArrayAdd(bonus_arts, t_ArtArtefactor);",
                        "ArrayAdd(bonus_arts, t_ArtBio);",
                        "",
                        "max_num = 5;",
                        "fem_id = newarray(max_num);",
                        "quest_data1 = newarray(max_num);",
                        "quest_data2 = newarray(max_num);",
                        "trust_value = newarray(max_num);",
                        "counter = 0;",
                        "",
                        "while(counter < max_num)",
                        "{",
                        "    fem_id[counter] = 0;",
                        "    quest_data1[counter] = 0;",
                        "    quest_data2[counter] = 0;",
                        "    trust_value[counter] = 0;",
                        "    counter = counter + 1;",
                        "}",
                        "",
                        "enemy_id = newarray(1);",
                        "new_enemies = newarray(1);",
                        "locations = newarray(1);",
                        "",
                        "planet_list = newarray(20);",
                        "planet_list2 = newarray(20);",
                        "planet_statuses = newarray(20);",
                        "",
                        "//Для внешних запросов",
                        "function g_GetFemRangers(int num = -1)",
                        "{",
                        "    if(~num) result = GroupShip(GroupFem, num);",
                        "    else result = GroupCount(GroupFem);",
                        "}",
                        "",
                        "function g_CreateHybridDroid()",
                        "{",
                        "    quest_item = CreateEquipment(t_RepairRobot, 20, 8, 2);",
                        "    bon = FindBonusByCustomTag('A1D1M1');",
                        "    if(bon > -1) SpecialToEquipment(bon, quest_item);",
                        "    LinkItemToScript(quest_item, HybridDroid);",
                        "",
                        "    result = quest_item;",
                        "}",
                        "",
                        "//Бесповоротно фейлит квест с нормальным получением гибридного дроида",
                        "function g_FailHybridDroidAcception()",
                        "{",
                        "    player_hate = 1;",
                        "    quest_status = 4;",
                        "}",
                        "",
                        "//Создаём новую спецагентку (будет добавлена в скрипт по всем правилам)",
                        "function g_SpawnFemRanger(dword planet = 0, int race = 2 /*People*/)",
                        "{",
                        "    if(!planet) planet = NearCivilPlanet(Player());",
                        "",
                        "    dword fem_ranger = BuyRanger(planet);",
                        "    ShipType(fem_ranger, 'FemRanger');",
                        "",
                        "    int bon = FindBonusByNameInCfg(hull_names[race, 'GTL' + GalaxyTechLevel()]);",
                        "    if(~bon) SpecialToEquipment(bon, ShipItems(fem_ranger, 0));",
                        "    else throw 'Secret Agent has hull acryn at the very spawn.';",
                        "",
                        "    ShipRefit(fem_ranger);",
                        "    ShipRefit(fem_ranger);",
                        "    ShipRefit(fem_ranger);",
                        "",
                        "    if(race == People) Chameleon(fem_ranger, 'Ship.AkrinFemale.SecretAgentPeople');",
                        "    else /*if(race == Maloc)*/ Chameleon(fem_ranger, 'Ship.AkrinFemale.J');",
                        "",
                        "    int counter = 0;",
                        "    while(counter < ShipItems(fem_ranger))",
                        "    {",
                        "        dword item = ShipItems(fem_ranger, counter);",
                        "        if(ItemType(item) >= t_Weapon1)",
                        "        {",
                        "            if(ItemType(item) <= t_Weapon12)",
                        "            {",
                        "                if(ItemType(item) != t_Weapon4)",
                        "                {",
                        "                    FreeItem(GetItemFromShip(fem_ranger, counter));",
                        "                    item = CreateEquipment(t_Weapon4, 10 + RndObject(1, 10, fem_ranger), GalaxyTechLevel(), 2);",
                        "                    AddItemToShip(fem_ranger, item);",
                        "                }",
                        "            }",
                        "        }",
                        "        counter = counter + 1;",
                        "    }",
                        "",
                        "    item = CreateEquipment(t_Weapon4, 10 + RndObject(1, 10, fem_ranger), GalaxyTechLevel(), 2);",
                        "    AddItemToShip(fem_ranger, item);",
                        "    ShipImproveItems(fem_ranger, 2 * GalaxyTechLevel());",
                        "",
                        "    //Выбираем для спецагентки более уникальное имя",
                        "    counter = RndObject(1, 1000, fem_ranger) % ArrayDim(fem_names[race]);",
                        "    int name_used = 1;",
                        "    while(name_used)",
                        "    {",
                        "        counter = counter + 1;",
                        "        if(counter >= ArrayDim(fem_names[race])) counter = 0;",
                        "",
                        "        int counter2 = 0;",
                        "        name_used = 0;",
                        "        if(ShipName(Player()) == fem_names[race, counter]) name_used = 1;",
                        "        while(counter2 < GroupCount(GroupFem) && !name_used)",
                        "        {",
                        "            //Если данное имя уже используется какой-то живой спецагенткой той же расы",
                        "            if(ShipName(GroupShip(GroupFem,counter2)) == fem_names[race, counter])",
                        "            {",
                        "                name_used = 1;",
                        "                break;",
                        "            }",
                        "            counter2 = counter2 + 1;",
                        "        }",
                        "    }",
                        "    SetName(fem_ranger, fem_names[race, counter]);",
                        "",
                        "    //Определяем номер портрета, выбираем уникальный",
                        "    if(race == People)",
                        "    {",
                        "        tint2 = 37;",
                        "        tint3 = 47;",
                        "        int face_pool = 10;",
                        "        counter = 36 + RndObject(1, 1000, fem_ranger) % 8;",
                        "    }",
                        "    else /*if(race == Maloc)*/",
                        "    {",
                        "        tint2 = 26;",
                        "        tint3 = 28;",
                        "        face_pool = 3;",
                        "        counter = 25 + RndObject(1, 1000, fem_ranger) % 8;",
                        "    }",
                        "",
                        "    int face_used = 1;",
                        "    while(face_used && face_pool)",
                        "    {",
                        "        counter = counter + 1;",
                        "        if(counter > tint3) counter = tint2; //Сбрасываем в начало списка доступных портретов",
                        "",
                        "        counter2 = 0;",
                        "        face_used = 0;",
                        "        while(counter2 < GroupCount(GroupFem) && !face_used)",
                        "        {",
                        "            cur_ship = GroupShip(GroupFem, counter2);",
                        "            if(ShipPilotRace(cur_ship) == race)",
                        "            {",
                        "                //Если данный номер портрета уже используется какой-то живой спецагенткой той же расы",
                        "                if(ShipFace(cur_ship) == counter)",
                        "                {",
                        "                    face_used = 1;",
                        "                    break;",
                        "                }",
                        "            }",
                        "            counter2 = counter2 + 1;",
                        "        }",
                        "",
                        "        //Чтобы не зациклилось намертво, если агенток определённой расы окажется больше, чем доступных портретов",
                        "        face_pool = face_pool - 1;",
                        "    }",
                        "    ShipFace(fem_ranger, counter);",
                        "",
                        "    //Упор в торговое поведение, чтобы реже гибли в боях за системы",
                        "    if(race == People)",
                        "    {",
