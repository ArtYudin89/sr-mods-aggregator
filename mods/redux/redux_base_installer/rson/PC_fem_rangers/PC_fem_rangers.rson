                        "    OrderMove(CurShip,CoordX(CurShip)+Rnd(-50,50),CoordY(CurShip)+Rnd(-50,50));}",
                        "    quest_data1[ship_num]=0;",
                        "    quest_data2[ship_num]=0;",
                        "    OrderLock(CurShip,0);",
                        "    temp_curship=CurShip;",
                        "    ShipFreeFlight(CurShip);",
                        "    ChangeState(3,temp_curship);",
                        "    exit;",
                        "  }",
