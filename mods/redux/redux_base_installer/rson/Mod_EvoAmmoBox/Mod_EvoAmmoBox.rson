                    "Pos.y": 445
                },
                {
                    "Name": "",
                    "Code.Type": "Turn",
                    "Code": [
                        "for(i=1;i<ShipItems(Player());i=i+1) {",
                        "    tdw=ShipItems(Player(),i);",
                        "    if(ItemType(tdw)!=t_UselessItem)continue;",
                        "    tstr1=EquipmentImageName(tdw);",
                        "    if(tstr1=='Container_lirekron' || tstr1=='Container_missile' || tstr1=='Container_sphere' || tstr1=='Container_torpedo') {",
                        "        tdw2=UselessItemData(tdw,1)-UselessItemData(tdw,2);",
                        "        if(tdw2) {",
                        "            tstr1=Name(tdw)+Format('  <0> cr.',\"<0>\",rCost*tdw2);",
                        "            if(ShipMoney(Player())<(rCost*tdw2)) AddDialogBlock(tstr1,1);",
                        "            InjectAnswer('RearmAmmoBox',tstr1,tdw);",
                        "        }",
                        "    }",
                        "}",
                        "DAdd(7);"
                    ],
