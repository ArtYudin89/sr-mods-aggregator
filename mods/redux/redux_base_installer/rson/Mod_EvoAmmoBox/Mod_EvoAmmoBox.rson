            "Items": [],
            "Operations": [
                {
                    "Name": "",
                    "Code.Type": "Global",
                    "Code": [
                        "GRun();"
                    ],
                    "#": 20,
                    "Type": "Top",
                    "Parent": -1,
                    "Pos.x": 0,
                    "Pos.y": 585
                },
                {
                    "Name": "",
                    "Code.Type": "Turn",
                    "Code": [
                        "if(CurTurn()%300==0) {",
                        "    cur_count1=3+ShipRank(Player());",
                        "    cur_count2=2+ShipRank(Player());",
                        "    cur_count3=1+ShipRank(Player());",
                        "    cur_count4=ShipRank(Player());",
                        "}"
                    ],
                    "#": 21,
                    "Type": "Top",
                    "Parent": -1,
                    "Pos.x": 120,
                    "Pos.y": 585
                },
                {
                    "Name": "",
                    "Code.Type": "DialogBegin",
                    "Code": [
                        "if(GetShipRuins(Player())) {",
                        "    if(!PlayerBridge()) {",
                        "        if(ShipType(GetShipRuins(Player()))=='WB') {",
                        "            AddDialogInject('AmmoBox',CT(\"Script.Mod_EvoAmmoBox.72\"),CT(\"Script.Mod_EvoAmmoBox.71\"),1);",
                        "        }",
                        "    }",
                        "}"
                    ],
                    "#": 22,
                    "Type": "Top",
                    "Parent": -1,
                    "Pos.x": 180,
                    "Pos.y": 585
                },
                {
                    "Name": "",
                    "Code.Type": "Turn",
                    "Code": [
                        "cost1=1.05*GalaxyMoney(2,ShipOwner(GetShipRuins(Player())));",
                        "cost2=1.2*GalaxyMoney(2,ShipOwner(GetShipRuins(Player())));",
                        "cost3=1.12*GalaxyMoney(2,ShipOwner(GetShipRuins(Player())));",
                        "cost4=1.3*GalaxyMoney(2,ShipOwner(GetShipRuins(Player())));",
                        "DChange(0);",
                        "exit;"
                    ],
                    "#": 42,
                    "Type": "Top",
                    "Parent": -1,
                    "Pos.x": -20,
                    "Pos.y": 375
                },
                {
                    "Name": "",
                    "Code.Type": "Turn",
                    "Code": [
                        "//Списываем деньги со счета игрока и пополняем контейнеры",
                        "tdw2=(UselessItemData(GAnswerData,1)-UselessItemData(GAnswerData,2))*rCost;",
                        "ShipMoney(Player(),ShipMoney(Player())-tdw2);",
                        "Sound('Sound.Buy');",
                        "UselessItemData(GAnswerData,2,UselessItemData(GAnswerData,1));",
                        "DChange(2);",
                        "exit;"
                    ],
                    "#": 43,
                    "Type": "Top",
                    "Parent": -1,
                    "Pos.x": 100,
                    "Pos.y": 375
                },
                {
                    "Name": "",
                    "Code.Type": "Turn",
                    "Code": [
                        "tint=0;",
                        "tstr2='';",
                        "if(GetGameOptions('FontDialog')==0)tstr3='<clrEnd>-------------------------------------------------------------';",
                        "else if(GetGameOptions('FontDialog')==1)tstr3='<clrEnd>------------------------------------------';",
                        "else if(GetGameOptions('FontDialog')==2)tstr3='<clrEnd>-----------------------------------------';",
                        "else tstr3='<clrEnd>-------------------------------------';",
                        "//Цена за пополнение",
                        "tdw=GalaxyTechLevel();",
                        "if(tdw<2) tdw=2;",
                        "else if(tdw>7) tdw=7;",
                        "rCost=10+(tdw-2)*18;",
                        "//Если у игрока есть неполные контейнеры - добавляем диалог об их пополнении",
                        "for(i=1;i<ShipItems(Player());i=i+1) {",
                        "    tdw=ShipItems(Player(),i);",
                        "    if(ItemType(tdw)!=t_UselessItem)continue;",
                        "    tstr1=EquipmentImageName(tdw);",
                        "    if(tstr1=='Container_lirekron' || tstr1=='Container_missile' || tstr1=='Container_sphere' || tstr1=='Container_torpedo') {",
                        "        tdw2=UselessItemData(tdw,1)-UselessItemData(tdw,2);",
                        "        if(tdw2) {",
                        "            tint=tint+1;",
                        "            tstr2=tstr2+'</color>'+tint+') '+Name(tdw)+Format(' <0></color>',\"<0>\",UselessItemData(tdw,2))+'/'+Format('<0></color>',\"<0>\",UselessItemData(tdw,1))+Format(' за <0> cr.',\"<0>\",rCost*tdw2)+CT(\"Script.Mod_EvoAmmoBox.64\");",
                        "        }",
                        "    }",
                        "}",
                        "if(tint) {",
                        "  DAdd(6);",
                        "}",
                        "if(cur_count1==0) AddDialogBlock(CT(\"Script.Mod_EvoAmmoBox.42\"),1);",
                        "if(cur_count2==0) AddDialogBlock(CT(\"Script.Mod_EvoAmmoBox.43\"),1);",
                        "if(cur_count3==0) AddDialogBlock(CT(\"Script.Mod_EvoAmmoBox.44\"),1);",
                        "if(cur_count4==0) AddDialogBlock(CT(\"Script.Mod_EvoAmmoBox.45\"),1);",
                        "if(cost4<=ShipMoney(Player()) && cur_count4) {",
                        "  DAdd(5);",
                        "}",
                        "if(cost4>ShipMoney(Player()) || !cur_count4) {",
                        "  DAdd(8);",
                        "}",
                        "if(cost3<=ShipMoney(Player()) && cur_count3) {",
                        "  DAdd(4);",
                        "}",
                        "if(cost3>ShipMoney(Player()) || !cur_count3) {",
                        "  DAdd(9);",
                        "}",
                        "if(cost2<=ShipMoney(Player()) && cur_count2) {",
                        "  DAdd(3);",
                        "}",
                        "if(cost2>ShipMoney(Player()) || !cur_count2) {",
                        "  DAdd(10);",
                        "}",
                        "if(cost1<=ShipMoney(Player()) && cur_count1) {",
                        "  DAdd(0);",
                        "}",
                        "if(cost1>ShipMoney(Player()) || !cur_count1) {",
                        "  DAdd(11);",
                        "}",
                        "DAdd(1);"
                    ],
                    "#": 44,
                    "Type": "Top",
                    "Parent": -1,
                    "Pos.x": -20,
                    "Pos.y": 445
                },
                {
                    "Name": "",
                    "Code.Type": "Turn",
                    "Code": [
                        "if(cost4<=ShipMoney(Player()) && cur_count4) {",
                        "  DAdd(5);",
                        "}",
                        "if(cost4>ShipMoney(Player()) || !cur_count4) {",
                        "  DAdd(8);",
                        "}",
                        "if(cost3<=ShipMoney(Player()) && cur_count3) {",
