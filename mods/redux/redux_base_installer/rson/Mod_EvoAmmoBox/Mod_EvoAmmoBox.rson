                        "}",
                        "DAdd(7);"
                    ],
                    "#": 47,
                    "Type": "Top",
                    "Parent": -1,
                    "Pos.x": 430,
                    "Pos.y": 445
                },
                {
                    "Name": "",
                    "Code.Type": "Turn",
                    "Code": [
                        "tdw=CreateQuestItem('Container_lirekron');",
                        "ItemSize(tdw,20+GalaxyTechLevel()*2+Rnd(-2,4));",
                        "UselessItemData(tdw,1,ItemSize(tdw));",
                        "UselessItemData(tdw,2,ItemSize(tdw));",
                        "UselessItemData(tdw,3,Rnd(3,4));//сколько раз можно зарядить этой коробкой",
                        "AddItemToShip(Player(),tdw);",
                        "ShipMoney(Player(),ShipMoney(Player())-cost1);",
