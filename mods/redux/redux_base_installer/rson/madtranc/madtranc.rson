                    "Parent": -1,
                    "Pos.x": -20,
                    "Pos.y": 520
                },
                {
                    "Name": "",
                    "Code.Type": "Turn",
                    "Code": [
                        "DAdd(4);"
                    ],
                    "#": 93,
                    "Type": "Top",
                    "Parent": -1,
                    "Pos.x": 130,
                    "Pos.y": 520
                },
                {
                    "Name": "",
                    "Code.Type": "Turn",
                    "Code": [
                        "for (i=1; i<ShipItems(Player()); i=i+1)",
                        "{",
                        "s=ShipItems(Player(),i);",
                        "if (ItemType(s)==t_UselessItem && Name(s)==CT(\"Script.madtranc.2\")){ dState=i; break; }",
                        "else dState=0;",
                        "}",
                        "//SFT('dialog state is '+dState);",
                        "if(!dState) {",
                        "  DAdd(11);",
                        "}",
                        "if(dState) {",
                        "  DAdd(5);",
                        "}",
                        "DAdd(0);",
                        "DAdd(1);",
                        "DAdd(3);",
                        "DAdd(4);"
                    ],
                    "#": 94,
                    "Type": "Top",
                    "Parent": -1,
                    "Pos.x": 280,
                    "Pos.y": 520
                },
                {
                    "Name": "",
                    "Code.Type": "Turn",
                    "Code": [
                        "DAdd(4);"
                    ],
                    "#": 95,
                    "Type": "Top",
                    "Parent": -1,
                    "Pos.x": 430,
                    "Pos.y": 520
                },
                {
                    "Name": "",
                    "Code.Type": "Turn",
                    "Code": [
                        "trancstage=1;",
                        "DAdd(6);"
                    ],
                    "#": 96,
                    "Type": "Top",
                    "Parent": -1,
                    "Pos.x": 580,
                    "Pos.y": 520
                },
                {
                    "Name": "",
                    "Code.Type": "Turn",
                    "Code": [
                        "for (i=1; i<ShipItems(Player()); i=i+1)",
                        "{",
                        "s=ShipItems(Player(),i);",
                        "if (ItemType(s)==t_UselessItem && Name(s)==CT(\"Script.madtranc.6\")){ dState=i; break; }",
                        "else dState=0;",
                        "}",
                        "if(dState) {",
                        "  DAdd(8);",
                        "}",
                        "if(!dState) {",
                        "  DAdd(10);",
                        "}",
                        "DAdd(7);"
                    ],
                    "#": 97,
                    "Type": "Top",
                    "Parent": -1,
                    "Pos.x": 730,
                    "Pos.y": 520
                },
                {
                    "Name": "",
                    "Code.Type": "Turn",
                    "Code": [
                        "for (i=0; i<ShipItems(GroupToShip(HanPirates)); i=i+1)",
                        "{",
                        "s=ShipItems(GroupToShip(HanPirates),i);",
                        "if (ItemType(s)==t_RepairRobot || ItemType(s)==t_DefGenerator) FreeItem(GetItemFromShip(GroupToShip(HanPirates),i));",
                        "}",
                        "NoTalkToShip(GroupToShip(HanPirates),1);",
                        "",
                        "trancstage=2;",
                        "DAdd(9);"
                    ],
                    "#": 98,
                    "Type": "Top",
