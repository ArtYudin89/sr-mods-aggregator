                    "Pos.x": 0,
                    "Pos.y": 660
                },
                {
                    "Name": "",
                    "Code.Type": "Init",
                    "Code": [
                        "pirate_planets = newarray(1);"
                    ],
                    "#": 65,
                    "Type": "Top",
                    "Parent": -1,
                    "Pos.x": 60,
                    "Pos.y": 660
                },
                {
                    "Name": "",
                    "Code.Type": "Turn",
                    "Code": [
                        "if(!ShipIsTakeoff(Player())) {",
                        "  if(was_meet && !GroupCount(HanPirates)) {",
                        "    ShipOut(Player());",
                        "  }",
                        "  if(GroupCount(HanPirates) && !GroupCount(thatone)) {",
                        "    ShipJoin(thatone,Player());",
                        "  }",
                        "  t1=t1+1;",
                        "  if (t1>=1500 && !was_meet)",
                        "  {",
                        "  if (GroupCount(HanPirates)<1)",
                        "  {",
                        "  ArrayClear(pirate_planets);",
                        "  st=GalaxyStars();",
                        "  for(st_num=0;st_num<st;st_num=st_num+1)",
                        "  {",
                        "  if (!ControlledSystems(0)) break;",
                        "  cur_star=GalaxyStar(st_num);",
                        "  if (StarOwner(cur_star)==0)",
                        "  {",
                        "  pl=StarPlanets(cur_star);",
                        "  for (i=0;i<pl;i=i+1)",
                        "  {",
                        "  cur_pl=StarPlanets(cur_star,i);",
                        "  if (PlanetOwner(cur_pl)<5) ArrayAdd(pirate_planets,cur_pl);",
                        "  }",
                        "  }",
                        "  }",
                        "  if (ArrayDim(pirate_planets)<=1) exit;",
                        "  cur_pl=GetShipHomePlanet(Player());",
                        "  if (PlanetOwner(cur_pl)>4) exit;",
                        "  t1=0;",
                        "  stating=1;",
                        "  for (i=0;i<stating;i=i+1)",
                        "  {",
                        "  turn_meet=CurTurn();",
                        "  was_meet=1;",
                        "  s=BuyTranclucator(cur_pl);",
                        "  ShipJoin(HanPirates,s);",
                        "  loot1=CreateQuestItem('Usl_11',6);",
                        "  loot2=CreateQuestItem('Remains_22',6);",
                        "  loot3=CreateQuestItem('Remains_8',6);",
                        "  loot4=CreateQuestItem('Usl_Robots',6);",
                        "  loot5=CreateQuestItem('Remains_0',6);",
                        "  loot6=CreateQuestItem('Remains_10',6);",
                        "  loot7=CreateQuestItem('Remains_5',6);",
                        "  loot8=CreateQuestItem('Remains_22',6);",
                        "  loot9=CreateQuestItem('OperatedProbe',6);",
                        "  loot10=CreateQuestItem('Usl_RandomItem_04',6);",
                        "  ShipAddDropItem(s,loot1);",
                        "  ShipAddDropItem(s,loot2);",
                        "  ShipAddDropItem(s,loot3);",
                        "  ShipAddDropItem(s,loot4);",
                        "  ShipAddDropItem(s,loot5);",
                        "  ShipAddDropItem(s,loot6);",
                        "  ShipAddDropItem(s,loot7);",
                        "  ShipAddDropItem(s,loot8);",
                        "  ShipAddDropItem(s,loot9);",
                        "  ShipAddDropItem(s,loot10);",
                        "  a=CreateArt(t_ArtefactHull,6);",
                        "  a2=CreateArt(t_ArtFastRacks,6);",
                        "  a3=CreateArt(t_ArtefactDroid,6);",
                        "  a4=CreateArt(t_ArtefactNano,6);",
                        "  a5=CreateArt(t_ArtefactDef,6);",
                        "  a6=CreateArt(t_ArtPDTurret,6);",
                        "  a7=CreateArt(t_ArtefactSpeed,6);",
                        "  a8=CreateArt(t_ArtefactMiniExpl,6);",
                        "  a9=CreateArt(t_ArtefactAntigrav,6);",
                        "  a10=CreateArt(t_ArtEnergyDef,6);",
                        "  a11=CreateArt(t_ArtEnergyPulse,6);",
                        "  a12=CreateArt(t_ArtDecelerate,6);",
                        "  a13=CreateArt(t_ArtMissileDef,6);",
                        "  engine=CreateEquipment(t_Engine,70,GalaxyTechLevel(),6);",
                        "  fuel=CreateEquipment(t_FuelTanks,70,GalaxyTechLevel(),6);",
                        "  droid=CreateEquipment(t_RepairRobot,70,GalaxyTechLevel(),6);",
                        "  hook=CreateEquipment(t_CargoHook,70,GalaxyTechLevel(),6);",
                        "  def=CreateEquipment(t_DefGenerator,70,GalaxyTechLevel(),6);",
                        "  scan=CreateEquipment(t_Scaner,70,GalaxyTechLevel(),6);",
                        "  radar=CreateEquipment(t_Radar,70,GalaxyTechLevel(),6);",
                        "  mm1=CreateMM(FindBonusByName('Универс'));",
                        "  ShipAddDropItem(s,mm1);",
                        "  mm1=CreateMM(FindBonusByName('Универс'));",
                        "  ShipAddDropItem(s,mm1);",
                        "  mm1=CreateMM(FindBonusByName('Универс'));",
                        "  ShipAddDropItem(s,mm1);",
                        "  ShipSpecialBonuses(s,bonSlotRadar,1);",
                        "  ShipSpecialBonuses(s,bonSlotScaner,1);",
                        "  AddItemToShip(s,engine);",
                        "  AddItemToShip(s,fuel);",
                        "  AddItemToShip(s,droid);",
                        "  AddItemToShip(s,hook);",
                        "  AddItemToShip(s,def);",
                        "  AddItemToShip(s,radar);",
                        "  AddItemToShip(s,scan);",
                        "  AddItemToShip(s,a);",
                        "  AddItemToShip(s,a3);",
                        "  AddItemToShip(s,a4);",
                        "  AddItemToShip(s,a10);",
                        "  ShipSkill(GroupToShip(HanPirates),0,6);",
                        "  ShipSkill(GroupToShip(HanPirates),1,6);",
                        "  ShipSkill(GroupToShip(HanPirates),2,6);",
                        "  ShipSkill(GroupToShip(HanPirates),3,6);",
                        "  ShipSkill(GroupToShip(HanPirates),4,6);",
                        "  ShipSkill(GroupToShip(HanPirates),5,6);",
                        "  if(GalaxyTechLevel()<=5)",
                        "  {",
                        "  w1=CreateEquipment(t_Weapon4,Rnd(70,100),GalaxyTechLevel(),6);",
                        "  AddItemToShip(s,w1);",
                        "  w2=CreateEquipment(t_Weapon4,Rnd(70,100),GalaxyTechLevel(),6);",
                        "  AddItemToShip(s,w2);",
                        "  w3=CreateEquipment(t_Weapon4,Rnd(70,100),GalaxyTechLevel(),6);",
                        "  AddItemToShip(s,w3);",
                        "  w4=CreateEquipment(t_Weapon4,Rnd(70,100),GalaxyTechLevel(),6);",
                        "  AddItemToShip(s,w4);",
                        "  w5=CreateEquipment(t_Weapon4,Rnd(70,100),GalaxyTechLevel(),6);",
                        "  AddItemToShip(s,w5);",
                        "  SpecialToEquipment(FindBonusByName('Нанобролитовый двигатель I'),engine);",
                        "  SpecialToEquipment(FindBonusByName('Ультрасплавный топливный бак I'),fuel);",
                        "  SpecialToEquipment(FindBonusByName('Нанобролитовый дроид I'),droid);",
                        "  SpecialToEquipment(FindBonusByName('Ультрасплавный захват I'),hook);",
                        "  SpecialToEquipment(FindBonusByName('Нанобролитовый генератор защиты I'),def);",
                        "  SpecialToEquipment(FindBonusByName('Ультрасплавный радар I'),radar);",
                        "  SpecialToEquipment(FindBonusByName('Ультрасплавный сканер I'),scan);",
                        "  }",
                        "  else",
                        "  {",
                        "  w1=CreateEquipment(t_Weapon11,Rnd(70,100),GalaxyTechLevel(),6);",
                        "  AddItemToShip(s,w1);",
                        "  w2=CreateEquipment(t_Weapon11,Rnd(70,100),GalaxyTechLevel(),6);",
                        "  AddItemToShip(s,w2);",
                        "  w3=CreateEquipment(t_Weapon11,Rnd(70,100),GalaxyTechLevel(),6);",
                        "  AddItemToShip(s,w3);",
                        "  w4=CreateEquipment(t_Weapon9,Rnd(70,100),GalaxyTechLevel(),6);",
                        "  AddItemToShip(s,w4);",
                        "  w5=CreateEquipment(t_Weapon9,Rnd(70,100),GalaxyTechLevel(),6);",
                        "  AddItemToShip(s,w5);",
                        "  SpecialToEquipment(FindBonusByName('Нанобролитовый двигатель III'),engine);",
                        "  SpecialToEquipment(FindBonusByName('Ультрасплавный топливный бак III'),fuel);",
                        "  SpecialToEquipment(FindBonusByName('Нанобролитовый дроид III'),droid);",
                        "  SpecialToEquipment(FindBonusByName('Ультрасплавный захват III'),hook);",
                        "  SpecialToEquipment(FindBonusByName('Нанобролитовый генератор защиты III'),def);",
                        "  SpecialToEquipment(FindBonusByName('Ультрасплавный радар III'),radar);",
                        "  SpecialToEquipment(FindBonusByName('Ультрасплавный сканер III'),scan);",
                        "  }",
                        "  //Повышаем размер корпуса в соответствие с ГТУ",
                        "  a=ShipItems(s,0);",
                        "  ItemSize(ShipItems(s,0),270*GalaxyTechLevel()+Rnd(9,43));",
                        "  //Устраняем возможный перевес",
                        "  ShipCalcParam(s);",
                        "  if(ShipFreeSpace(s)<0)ItemSize(a,ItemSize(a)+abs(ShipFreeSpace(s))+Rnd(1,5));",
                        "  HullHP(a,ItemSize(a));",
                        "  //Выставляем игрока в качестве цели, чиним оборудование и сортируем вещи на борту",
                        "  ShipSetBad(s,Player());",
                        "  ShipRepairEq(s);",
                        "  ArrangeItems(s);",
                        "  }",
                        "  }",
                        "  }",
                        "}"
                    ],
                    "#": 66,
                    "Type": "Top",
                    "Parent": -1,
                    "Pos.x": 120,
                    "Pos.y": 660
                },
                {
                    "Name": "",
                    "Code.Type": "DialogBegin",
                    "Code": [
                        "if(GetTalkShip())",
                        "{",
                        "    if(!TalkByAI())",
                        "    {",
                        "        if(ShipInCurScript(GetTalkShip())) AddDialogOverride('dTrank', 20);",
                        "    }",
                        "}"
                    ],
