            "Items": [],
            "Operations": [
                {
                    "Name": "",
                    "Code.Type": "Global",
                    "Code": [
                        "if(GCntRun(GScriptName)<3) {",
                        "  if(GRunFrom==3) {",
                        "    if((CurTurn()-GLastTurnRun(GScriptName, 0))>2000) {",
                        "      if(ShipStrengthInAverageRanger(Player())>=1.5) {",
                        "        if(ShipOnSidePirateClan(Player()) && ShipStatistic(Player(), 1)>=50) GRun();",
                        "      }",
                        "    }",
                        "  }",
                        "}"
                    ],
                    "#": 13,
                    "Type": "Top",
                    "Parent": -1,
                    "Pos.x": 0,
                    "Pos.y": 585
                },
                {
                    "Name": "",
                    "Code.Type": "Init",
                    "Code": [
                        "//Условия появления отряда пиратов:",
                        "//Событие сработало меньше трех раз, игрок сильнее среднего рейнджера в 1.5 раза,",
                        "//Игрок состоит в клане, убил > 50 пиратов",
                        "diffBonus=GalaxyDiffLevels()/50; //Влияет на количество дополнительных врагов",
                        "flag=0;",
                        "//Функция выбора случайной коалиционной планеты.",
                        "//Возвращает указатель на планету, либо 0.",
                        "function SelectPlanet() {",
                        "    dword planet, tStar;",
                        "    int i, j;",
                        "    for(i=0; i<GalaxyStars(); i=i+1) {",
                        "        tStar=GalaxyStar(i);",
                        "        if(StarBattle(tStar)) continue; //Пропуск оспариваемых систем",
                        "\t\tif(StarOwner(tStar)) continue; //Пропуск некоалиционных систем",
                        "\t\tfor(j=0; j<StarPlanets(tStar); j=j+1) {",
                        "\t\t\tplanet=StarPlanets(tStar, j);",
                        "\t\t\tif(PlanetOwner(planet)<Kling) ArrayAdd(tArr, planet);",
                        "\t\t}",
                        "    }",
                        "    if(ArrayDim(tArr)<=1) planet=0; //Если в массиве нет подходящих планет, возвращаем 0",
                        "    else planet=tArr[Rnd(1, ArrayDim(tArr)-1)]; //Случайный выбор",
                        "    ArrayClear(tArr);",
                        "    result=planet;",
                        "}",
                        "//Функция создания и оснащения отряда для охоты на игрока",
                        "//Параметр - указатель на планету для создания",
                        "function SpawnSquad(dword spawnPlanet) {",
                        "    int i, j, tint;",
                        "    dword planetOwner=PlanetOwner(spawnPlanet); //Запоминаем начального владельца планеты",
                        "    dword planetRace=PlanetRace(spawnPlanet);",
                        "    dword ship, item;",
                        "    for(i=0; i<(5+(diffBonus*2)); i=i+1) {",
                        "        tint=Rnd(0, 4);",
                        "        //Меняем расу планеты на случайную, меняем владельца планеты",
                        "        //Создаем пирата, присваиваем ранг и присоеднияем к нужной группе",
                        "        PlanetRace(spawnPlanet, tint);",
                        "        PlanetOwner(spawnPlanet, PirateClan);",
                        "        ship=BuyPirate(spawnPlanet, 1000);",
                        "        ShipJoin(PirateSquad, ship);",
                        "        while(GetShipPirateRank(ship)<4) RaisePirateRank(ship);",
                        "        //Оснащение корабля и прокачка навыков",
                        "        ItemSize(ShipItems(ship,0),round((0.00085*GalaxyDiffLevels()+1)*GalaxyTechLevel()*100)+Rnd(-25,45));",
                        "        if(ItemSize(ShipItems(ship,0))<250) ItemSize(ShipItems(ship,0),250);",
                        "        Chameleon(ship);",
                        "        for(j=0; j<3; j=j+1) ShipSkill(ship, j, Rnd(4,6));",
                        "        for(j=0; j<5; j=j+1) ShipRefit(ship);",
                        "        //Если в корпусе открыт слот дроида, но самого дроида нет - выдаем",
                        "        if(GetEquipmentStats(ShipItems(ship, 0), 5)) {",
                        "            if(!ShipEqInSlot(ship, t_RepairRobot)) {",
                        "                item=CreateEquipment(t_RepairRobot, Rnd(20,40), GalaxyTechLevel(), PirateClan);",
                        "                AddItemToShip(ship, item);",
                        "                ItemIsInUse(item, ship,1);",
                        "            }",
                        "        }",
                        "        //Аналогично для ГЗП",
                        "        if(GetEquipmentStats(ShipItems(ship, 0), 7))  {",
                        "            if(!ShipEqInSlot(ship,t_DefGenerator)) {",
                        "                item=CreateEquipment(t_DefGenerator, Rnd(20,40), GalaxyTechLevel(), PirateClan);",
                        "                AddItemToShip(ship, item);",
                        "                ItemIsInUse(item, ship, 1);",
                        "            }",
                        "        }",
                        "        //Усиление следующих отрядов",
                        "        if(GalaxyDiffLevels()>=250) EqTLUpgrade(ship);",
                        "        else if(GalaxyDiffLevels()>=150) {",
                        "            if(Rnd(1,100)>50) EqTLUpgrade(ship);",
                        "        }",
                        "        ShipImproveItems(ship, 3*GalaxyTechLevel());",
                        "        GiveFreeSpace(ship);",
                        "        MakeShipEnterStar(ship, ShipStar(Player()), ShipStar(ship), 1);",
                        "        ShipSetBad(ship, Player());",
                        "        //Возвращаем планете первоначального владельца и расу",
                        "        PlanetRace(spawnPlanet, planetRace);",
                        "        PlanetOwner(spawnPlanet, planetOwner);",
                        "    }",
                        "}",
                        "//Функция повышения ТУ оборудования, параметр - указатель на корабль",
                        "function EqTLUpgrade(dword ship) {",
                        "    //Функция перебирает все предметы корабля, исключая неиспользуемые и корпус,",
                        "    //Затем создается полная копия предмета (включая акрин и ММ), для корректного расчета стоимости,",
                        "    //После чего пересчитываются хар-ки оригинального предмета, копия удаляется",
                        "    dword tItem, tCopy; int i;",
                        "    for(i=ShipItems(ship); i>=0; i=i-1) {",
                        "\t    tItem=ShipItems(ship, i);",
                        "\t\tif(!ItemIsInUse(tItem)) continue;",
                        "\t\tif(ItemType(tItem)==t_Hull) continue;",
                        "\t\t//Пропускаем конец списка (tItem=0)",
                        "\t\tif(tItem) {",
                        "\t\t\tif(ItemLevel(tItem)<GalaxyTechLevel()) {",
                        "\t\t\t\t//Отдельное условие для кастомного оружия",
                        "\t\t\t\tif(ItemType(tItem)==t_CustomWeapon) tCopy=CreateCustomWeapon(CustomWeaponType(tItem), ItemSize(tItem), GalaxyTechLevel(), ItemOwner(tItem));",
                        "\t\t\t\telse tCopy=CreateEquipment(ItemType(tItem), ItemSize(tItem), GalaxyTechLevel(), ItemOwner(tItem));",
                        "\t\t\t\tif(EqSpecial(tItem)>-1) SpecialToEquipment(EqSpecial(tItem), tCopy);",
                        "\t\t\t\tif(EqModule(tItem)>-1) ModuleToEquipment(EqModule(tItem), tCopy);",
                        "\t\t\t\tItemLevel(tItem, GalaxyTechLevel());",
                        "\t\t\t\tItemCost(tItem, ItemCost(tCopy));",
                        "\t\t\t\tFreeItem(tCopy);",
                        "\t\t    }",
                        "\t    }",
                        "    }",
                        "}",
                        "//Функция устранения перевеса корабля, параметр - указатель на корабль",
                        "function GiveFreeSpace(dword ship) {",
                        "    ShipCalcParam(ship);",
                        "    if(ShipFreeSpace(ship)<0) {",
                        "        ItemSize(ShipItems(ship,0),ItemSize(ShipItems(ship,0))+abs(ShipFreeSpace(ship))+Rnd(1,5));",
                        "        HullHP(ship,ItemSize(ShipItems(ship,0)));",
                        "    }",
                        "}"
                    ],
                    "#": 14,
                    "Type": "Top",
                    "Parent": -1,
                    "Pos.x": 60,
                    "Pos.y": 585
                },
                {
                    "Name": "",
                    "Code.Type": "Turn",
                    "Code": [
                        "if(!flag) {",
                        "    tPlanet=SelectPlanet();",
                        "    if(tPlanet) {",
                        "    \tSpawnSquad(tPlanet);",
                        "    \ttSystem=Id(PlanetToStar(tPlanet))-1;",
                        "    \tpirDstate=0;",
                        "        flag=1;",
                        "    }",
                        "}",
                        "if(!GroupCount(PirateSquad)) AllShipOut();"
                    ],
                    "#": 15,
                    "Type": "Top",
                    "Parent": -1,
                    "Pos.x": 120,
                    "Pos.y": 585
                },
                {
                    "Name": "",
                    "Code.Type": "Turn",
                    "Code": [
                        "if(ShipInNormalSpace(CurShip) && ShipInNormalSpace(Player())) {",
                        "  if(ShipStar(Player())==ShipStar(CurShip)) {",
                        "    if(Dist(CurShip, Player())<200 && !pirDstate) {",
                        "      Dialog(pirDialog, PirateSquad);",
                        "      if(pirDstate==1) {",
                        "        ChangeState(2);",
                        "        exit;",
                        "      }",
                        "      if(pirDstate==2) {",
                        "        ChangeState(3);",
                        "        exit;",
                        "      }",
                        "    }",
                        "  }",
                        "}",
                        "if(pirDstate==2) {",
                        "  ChangeState(3);",
                        "  exit;",
                        "}",
                        "if(pirDstate==1) {",
                        "  ChangeState(2);",
                        "  exit;",
                        "}"
                    ],
                    "#": 36,
                    "Type": "Top",
                    "Parent": -1,
                    "Pos.x": 80
                },
                {
                    "Name": "",
                    "Code.Type": "Turn",
                    "Code": [
                        "//Если игрок заплатил - миримся с пиратами и отправляем их в другую систему",
                        "if(ShipGetBad(CurShip)==Player()) TruceBetweenShips(CurShip, Player());",
                        "RelationToRanger(CurShip, Player(), 50);",
                        "OrderJump(CurShip, GalaxyStar(tSystem));",
                        "//Вывод кораблей из скрипта",
                        "if(ShipInStar(CurShip, GalaxyStar(tSystem)) && ShipInNormalSpace(CurShip)) ShipOut(CurShip);"
                    ],
                    "#": 37,
                    "Type": "Top",
                    "Parent": -1,
                    "Pos.x": 160
                },
                {
                    "Name": "",
                    "Code.Type": "Turn",
                    "Code": [
                        "if(ShipStar(Player())!=ShipStar(CurShip)) {",
                        "  if(ShipInNormalSpace(Player())) MakeShipEnterStar(CurShip, ShipStar(Player()), ShipStar(CurShip), Rnd(1,5));",
                        "}"
                    ],
                    "#": 38,
                    "Type": "Top",
                    "Parent": -1,
                    "Pos.x": 240
                },
