                        "  DChange(0);",
                        "  exit;",
                        "}",
                        "if(pirDstate==1) {",
                        "  DChange(1);",
                        "  exit;",
                        "}",
                        "if(pirDstate==2) {",
                        "  DChange(2);",
                        "  exit;",
                        "}"
