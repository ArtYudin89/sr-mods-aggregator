                        "GRun();"
                    ],
                    "#": 30,
                    "Type": "Top",
                    "Parent": -1,
                    "Pos.x": 0,
                    "Pos.y": 610
                },
                {
                    "Name": "",
                    "Code.Type": "Init",
                    "Code": [
                        "//код был занесен в function для использования в циклах",
                        "function BonCalc() {",
                        "    eqbon=EqSpecial(shipeq);",
                        "    if (eqbon!=-1 && eqbon!=0) //если оборудование отсутсвует в слоте, то EqSpecial возвращает 0, если есть и на нём нету акрина, то -1",
                        "    {",
                        "        bonvalue=BonusValue(eqbon,itbon);",
                        "        cntbon=cntbon+bonvalue;",
                        "        if (bonvalue!=0)",
                        "        {",
                        "            j=j+1;",
                        "            if (bonvalue>0)",
                        "            {",
                        "                if (bonvalue>0 && j==1) {",
                        "                    bonhist=CT(\"Script.Mod_AShipBonusInfo.81\")+bonvalue+CT(\"Script.Mod_AShipBonusInfo.55\");",
                        "                    eqhist=CT(\"Script.Mod_AShipBonusInfo.81\")+iteq+CT(\"Script.Mod_AShipBonusInfo.55\");",
                        "                }",
                        "                else {",
                        "                    bonhist=bonhist+CT(\"Script.Mod_AShipBonusInfo.119\")+bonvalue+CT(\"Script.Mod_AShipBonusInfo.55\");",
                        "                    eqhist=eqhist+CT(\"Script.Mod_AShipBonusInfo.119\")+iteq+CT(\"Script.Mod_AShipBonusInfo.55\");",
                        "                }",
                        "            }",
                        "            else if (bonvalue<0) {",
                        "                bonhist=bonhist+CT(\"Script.Mod_AShipBonusInfo.80\")+bonvalue+CT(\"Script.Mod_AShipBonusInfo.55\");",
                        "                eqhist=eqhist+CT(\"Script.Mod_AShipBonusInfo.236\")+iteq+CT(\"Script.Mod_AShipBonusInfo.55\");",
                        "            }",
                        "        }",
                        "    }",
                        "}",
                        "",
                        "function BonCalc2() {",
                        "    text=CT(\"Script.Mod_AShipBonusInfo.281\");",
                        "    text=text+Format(CT(\"Script.Mod_AShipBonusInfo.282\"),\"<0>\",Name(target),\"<1>\",Name(ShipStar(target)));",
                        "    text=text+CT(\"Script.Mod_AShipBonusInfo.24\");",
                        "    for (i=1;i<=32;i=i+1)",
                        "    {",
                        "        cntbon=0; //сброс переменной со значением бонуса оборудования, чтобы значение предыдущего бонуса не суммировалось с бонусом последующего",
                        "        j=0;",
                        "        bonhist=CT(\"Script.Mod_AShipBonusInfo.112\");",
                        "        eqhist=CT(\"Script.Mod_AShipBonusInfo.112\");",
                        "        history=CT(\"Script.Mod_AShipBonusInfo.112\");",
                        "        //переменная i нужна для порядка показа и считывания конкретных бонусов",
                        "        //Оборудование",
                        "        if (i==1) itbon=bonHull;",
                        "        //if (i==2) itbon=bonFuel;",
                        "        if (i==2) itbon=bonSpeed;",
                        "        if (i==3) itbon=bonJump;",
                        "        if (i==4) itbon=bonRadar;",
                        "        if (i==5) itbon=bonScan;",
                        "        if (i==6) itbon=bonDroid;",
                        "        if (i==7) itbon=bonHook;",
                        "        if (i==8) itbon=bonHookRadius;",
                        "        if (i==9) itbon=bonHookMaxSpeed;",
                        "        if (i==10) itbon=bonHookMinSpeed;",
                        "        if (i==11) itbon=bonDef;",
                        "        if (i==12) itbon=bonMass;",
                        "        //Оружие",
                        "        if (i==13) itbon=bonWEnergy;",
                        "        if (i==14) itbon=bonWSplinter;",
                        "        if (i==15) itbon=bonWMissile;",
                        "        if (i==16) itbon=bonWRadius;",
                        "        //Навыки",
                        "        if (i==17) itbon=bonSkill1;",
                        "        if (i==18) itbon=bonSkill2;",
                        "        if (i==19) itbon=bonSkill3;",
                        "        if (i==20) itbon=bonSkill4;",
                        "        if (i==21) itbon=bonSkill5;",
                        "        if (i==22) itbon=bonSkill6;",
                        "        //Слоты",
                        "        if (i==23) itbon=bonSlotRadar;",
                        "        if (i==24) itbon=bonSlotScaner;",
                        "        if (i==25) itbon=bonSlotDroid;",
                        "        if (i==26) itbon=bonSlotHook;",
                        "        if (i==27) itbon=bonSlotDef;",
                        "        if (i==28) itbon=bonSlotWeapon;",
                        "        if (i==29) itbon=bonSlotArt;",
                        "        if (i==30) itbon=bonSlotForsage;",
                        "        //Разное",
                        "        if (i==31) itbon=bonStimCapacity;",
                        "        if (i==32) itbon=bonZonds;",
                        "",
                        "        if (opspecbon) {",
                        "            specbon=ShipSpecialBonuses(target,itbon); //значение этого спец. бонуса (если больше 0, то положительное, если меньше, то негативное)",
                        "            if (specbon!=0) {",
                        "                if (specbon>0) specbon=CT(\"Script.Mod_AShipBonusInfo.84\")+specbon+CT(\"Script.Mod_AShipBonusInfo.55\"); //сумма спец. бонуса больше 0, т.е. положительная",
                        "                else if (specbon<0) specbon=CT(\"Script.Mod_AShipBonusInfo.83\")+specbon+CT(\"Script.Mod_AShipBonusInfo.55\"); //сумма спец. бонуса меньше 0, т.е. отрицательная",
                        "            }",
                        "            else specbon='';",
                        "        }",
                        "",
                        "        for (h=t_Hull;h<=t_DefGenerator;h=h+1) //перебор оборудования",
                        "        {",
                        "            shipeq=ShipEqInSlot(target,h);",
                        "            if (h==t_Hull) iteq=CT(\"Script.Mod_AShipBonusInfo.192\");",
                        "            if (h==t_FuelTanks) iteq=CT(\"Script.Mod_AShipBonusInfo.191\");",
                        "            if (h==t_Engine) iteq=CT(\"Script.Mod_AShipBonusInfo.190\");",
                        "            if (h==t_Radar) iteq=CT(\"Script.Mod_AShipBonusInfo.189\");",
                        "            if (h==t_Scaner) iteq=CT(\"Script.Mod_AShipBonusInfo.188\");",
                        "            if (h==t_RepairRobot) iteq=CT(\"Script.Mod_AShipBonusInfo.187\");",
                        "            if (h==t_CargoHook) iteq=CT(\"Script.Mod_AShipBonusInfo.186\");",
                        "            if (h==t_DefGenerator) iteq=CT(\"Script.Mod_AShipBonusInfo.185\");",
                        "            BonCalc();",
                        "        }",
                        "",
                        "        for (h=1;h<=5;h=h+1) //перебор оружий",
                        "        {",
                        "            shipeq=ShipEqInSlot(target,t_Weapon1,h);",
                        "            if (h==1) iteq=CT(\"Script.Mod_AShipBonusInfo.184\");",
                        "            if (h==2) iteq=CT(\"Script.Mod_AShipBonusInfo.183\");",
                        "            if (h==3) iteq=CT(\"Script.Mod_AShipBonusInfo.182\");",
                        "            if (h==4) iteq=CT(\"Script.Mod_AShipBonusInfo.181\");",
                        "            if (h==5) iteq=CT(\"Script.Mod_AShipBonusInfo.180\");",
                        "            BonCalc();",
                        "        }",
                        "",
                        "        if (cntbon==0); eqbon=CT(\"Script.Mod_AShipBonusInfo.79\");",
                        "        if (cntbon>0) eqbon=CT(\"Script.Mod_AShipBonusInfo.81\")+cntbon+CT(\"Script.Mod_AShipBonusInfo.55\");",
                        "        if (cntbon<0) eqbon=CT(\"Script.Mod_AShipBonusInfo.80\")+cntbon+CT(\"Script.Mod_AShipBonusInfo.55\");",
                        "",
                        "        if (opbonhist && opeqhist) history=CT(\"Script.Mod_AShipBonusInfo.114\")+bonhist+CT(\"Script.Mod_AShipBonusInfo.233\")+eqhist+CT(\"Script.Mod_AShipBonusInfo.109\");",
                        "        else if (!opbonhist && opeqhist) history=CT(\"Script.Mod_AShipBonusInfo.114\")+eqhist+CT(\"Script.Mod_AShipBonusInfo.109\");",
                        "        else if (opbonhist && !opeqhist) history=CT(\"Script.Mod_AShipBonusInfo.114\")+bonhist+CT(\"Script.Mod_AShipBonusInfo.109\");",
                        "",
                        "        if (history==CT(\"Script.Mod_AShipBonusInfo.259\")) history=CT(\"Script.Mod_AShipBonusInfo.112\");",
                        "        else if (history==CT(\"Script.Mod_AShipBonusInfo.232\")) history=CT(\"Script.Mod_AShipBonusInfo.112\");",
                        "",
                        "        if (i==1) text=text+Format(CT(\"Script.Mod_AShipBonusInfo.229\"),\"<0>\",eqbon,\"<1>\",history,\"<2>\",specbon);",
                        "        // if (i==2) text=text+\"К объему топл. бака: <eqbon><history><specbon><br>\";",
                        "        if (i==2) text=text+Format(CT(\"Script.Mod_AShipBonusInfo.243\"),\"<0>\",eqbon,\"<1>\",history,\"<2>\",specbon);",
                        "        if (i==3) text=text+Format(CT(\"Script.Mod_AShipBonusInfo.242\"),\"<0>\",eqbon,\"<1>\",history,\"<2>\",specbon);",
                        "        if (i==4) text=text+Format(CT(\"Script.Mod_AShipBonusInfo.225\"),\"<0>\",eqbon,\"<1>\",history,\"<2>\",specbon);",
                        "        if (i==5) text=text+Format(CT(\"Script.Mod_AShipBonusInfo.241\"),\"<0>\",eqbon,\"<1>\",history,\"<2>\",specbon);",
                        "        if (i==6) text=text+Format(CT(\"Script.Mod_AShipBonusInfo.223\"),\"<0>\",eqbon,\"<1>\",history,\"<2>\",specbon);",
                        "        if (i==7) text=text+Format(CT(\"Script.Mod_AShipBonusInfo.240\"),\"<0>\",eqbon,\"<1>\",history,\"<2>\",specbon);",
                        "        if (i==8) text=text+Format(CT(\"Script.Mod_AShipBonusInfo.221\"),\"<0>\",eqbon,\"<1>\",history,\"<2>\",specbon);",
                        "        if (i==9) text=text+Format(CT(\"Script.Mod_AShipBonusInfo.239\"),\"<0>\",eqbon,\"<1>\",history,\"<2>\",specbon);",
                        "        if (i==10) text=text+Format(CT(\"Script.Mod_AShipBonusInfo.238\"),\"<0>\",eqbon,\"<1>\",history,\"<2>\",specbon);",
                        "        if (i==11) text=text+Format(CT(\"Script.Mod_AShipBonusInfo.237\"),\"<0>\",eqbon,\"<1>\",history,\"<2>\",specbon);",
                        "        if (i==12) text=text+Format(CT(\"Script.Mod_AShipBonusInfo.217\"),\"<0>\",eqbon,\"<1>\",history,\"<2>\",specbon);",
                        "        if (i==13) {",
                        "            text=text+CT(\"Script.Mod_AShipBonusInfo.23\");",
                        "            text=text+Format(CT(\"Script.Mod_AShipBonusInfo.216\"),\"<0>\",eqbon,\"<1>\",history,\"<2>\",specbon);",
                        "        }",
                        "        if (i==14) text=text+Format(CT(\"Script.Mod_AShipBonusInfo.215\"),\"<0>\",eqbon,\"<1>\",history,\"<2>\",specbon);",
                        "        if (i==15) text=text+Format(CT(\"Script.Mod_AShipBonusInfo.214\"),\"<0>\",eqbon,\"<1>\",history,\"<2>\",specbon);",
                        "        if (i==16) text=text+Format(CT(\"Script.Mod_AShipBonusInfo.213\"),\"<0>\",eqbon,\"<1>\",history,\"<2>\",specbon);",
                        "        if (i==17) {",
                        "            text=text+CT(\"Script.Mod_AShipBonusInfo.130\");",
                        "            text=text+Format(CT(\"Script.Mod_AShipBonusInfo.212\"),\"<0>\",eqbon,\"<1>\",history,\"<2>\",specbon);",
                        "        }",
                        "        if (i==18) text=text+Format(CT(\"Script.Mod_AShipBonusInfo.211\"),\"<0>\",eqbon,\"<1>\",history,\"<2>\",specbon);",
                        "        if (i==19) text=text+Format(CT(\"Script.Mod_AShipBonusInfo.210\"),\"<0>\",eqbon,\"<1>\",history,\"<2>\",specbon);",
                        "        if (i==20) text=text+Format(CT(\"Script.Mod_AShipBonusInfo.209\"),\"<0>\",eqbon,\"<1>\",history,\"<2>\",specbon);",
                        "        if (i==21) text=text+Format(CT(\"Script.Mod_AShipBonusInfo.208\"),\"<0>\",eqbon,\"<1>\",history,\"<2>\",specbon);",
                        "        if (i==22) text=text+Format(CT(\"Script.Mod_AShipBonusInfo.207\"),\"<0>\",eqbon,\"<1>\",history,\"<2>\",specbon);",
                        "        if (i==23) {",
                        "            text=text+CT(\"Script.Mod_AShipBonusInfo.144\");",
                        "            text=text+Format(CT(\"Script.Mod_AShipBonusInfo.206\"),\"<0>\",eqbon,\"<1>\",history,\"<2>\",specbon);",
                        "        }",
                        "        if (i==24) text=text+Format(CT(\"Script.Mod_AShipBonusInfo.205\"),\"<0>\",eqbon,\"<1>\",history,\"<2>\",specbon);",
                        "        if (i==25) text=text+Format(CT(\"Script.Mod_AShipBonusInfo.204\"),\"<0>\",eqbon,\"<1>\",history,\"<2>\",specbon);",
                        "        if (i==26) text=text+Format(CT(\"Script.Mod_AShipBonusInfo.203\"),\"<0>\",eqbon,\"<1>\",history,\"<2>\",specbon);",
                        "        if (i==27) text=text+Format(CT(\"Script.Mod_AShipBonusInfo.202\"),\"<0>\",eqbon,\"<1>\",history,\"<2>\",specbon);",
                        "        if (i==28) text=text+Format(CT(\"Script.Mod_AShipBonusInfo.201\"),\"<0>\",eqbon,\"<1>\",history,\"<2>\",specbon);",
                        "        if (i==29) text=text+Format(CT(\"Script.Mod_AShipBonusInfo.200\"),\"<0>\",eqbon,\"<1>\",history,\"<2>\",specbon);",
                        "        if (i==30) text=text+Format(CT(\"Script.Mod_AShipBonusInfo.199\"),\"<0>\",eqbon,\"<1>\",history,\"<2>\",specbon);",
                        "        if (i==31) {",
                        "            text=text+CT(\"Script.Mod_AShipBonusInfo.134\");",
                        "            text=text+Format(CT(\"Script.Mod_AShipBonusInfo.266\"),\"<0>\",eqbon,\"<1>\",history,\"<2>\",specbon);",
                        "        }",
                        "        if (i==32) text=text+Format(CT(\"Script.Mod_AShipBonusInfo.197\"),\"<0>\",eqbon,\"<1>\",history,\"<2>\",specbon);",
                        "    }",
                        "    Sound('Sound.NewMsg');",
                        "    Ether(7,'',text);",
                        "}"
                    ],
                    "#": 31,
                    "Type": "Top",
                    "Parent": -1,
                    "Pos.x": 60,
                    "Pos.y": 610
                },
                {
                    "Name": "",
                    "Code.Type": "Turn",
                    "Code": [
                        "if(IsScriptActive('Mod_ExpPilotBridge')) {",
                        "  if(PlayerBridge()==10) {",
                        "    AddDialogInject('aBonusInfo','',CT(\"Script.Mod_AShipBonusInfo.276\"),3);",
                        "  }",
                        "}",
                        "if(!IsScriptActive('Mod_ExpPilotBridge')) {",
                        "  if(GetShipRuins(Player()) || GetShipPlanet(Player())) {",
                        "    AddDialogInject('aBonusInfo','',CT(\"Script.Mod_AShipBonusInfo.276\"),3);",
                        "  }",
                        "}"
                    ],
                    "#": 32,
                    "Type": "Top",
                    "Parent": -1,
                    "Pos.x": 120,
                    "Pos.y": 610
                },
                {
                    "Name": "",
                    "Code.Type": "Turn",
                    "Code": [
                        "if (opspecbon) str1=CT(\"Script.Mod_AShipBonusInfo.245\");",
                        "else str1=CT(\"Script.Mod_AShipBonusInfo.244\");",
                        "",
                        "if (opbonhist) str2=CT(\"Script.Mod_AShipBonusInfo.245\");",
                        "else str2=CT(\"Script.Mod_AShipBonusInfo.244\");",
                        "",
                        "if (opeqhist) str3=CT(\"Script.Mod_AShipBonusInfo.245\");",
                        "else str3=CT(\"Script.Mod_AShipBonusInfo.244\");",
                        "DChange(0);",
                        "exit;"
                    ],
                    "#": 53,
                    "Type": "Top",
                    "Parent": -1,
                    "Pos.x": -20,
                    "Pos.y": 400
                },
                {
                    "Name": "",
                    "Code.Type": "Turn",
                    "Code": [
                        "target=GAnswerData;",
                        "text=CT(\"Script.Mod_AShipBonusInfo.281\");",
                        "text=text+Format(CT(\"Script.Mod_AShipBonusInfo.282\"),\"<0>\",Name(target),\"<1>\",Name(ShipStar(target)));",
                        "text=text+CT(\"Script.Mod_AShipBonusInfo.24\");",
                        "for (i=1;i<=32;i=i+1)",
                        "{",
                        "    cntbon=0; //сброс переменной со значением бонуса оборудования, чтобы значение предыдущего бонуса не суммировалось с бонусом последующего",
                        "    j=0;",
