                        "InjectAnswer('aCalc',CT(\"Script.Mod_AShipBonusInfo.267\"),Player());",
                        "InjectAnswer('aShipBonusInfo',CT(\"Script.Mod_AShipBonusInfo.268\"),0);",
                        "InjectAnswer('aBonusInfo',CT(\"Script.Mod_AShipBonusInfo.264\"),0);",
                        "if(!opspecbon) {",
                        "  DAdd(0);",
                        "}",
                        "if(opspecbon) {",
                        "  DAdd(1);",
                        "}",
                        "if(!opbonhist) {",
                        "  DAdd(2);",
                        "}",
                        "if(opbonhist) {",
                        "  DAdd(3);",
                        "}",
                        "if(!opeqhist) {",
                        "  DAdd(4);",
                        "}",
                        "if(opeqhist) {",
                        "  DAdd(5);",
                        "}"
                    ],
