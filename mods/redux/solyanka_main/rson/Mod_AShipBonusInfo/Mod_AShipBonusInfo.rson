                {
                    "Name": "",
                    "Code.Type": "Turn",
                    "Code": [
                        "find=0;",
                        "input=TextBox(CT(\"Script.Mod_AShipBonusInfo.284\"));",
                        "if (input!='') {",
                        "    for(i=0;i<GalaxyStars();i=i+1) //перебирает все системы в галактике",
                        "    {",
                        "        star=GalaxyStar(i); //система, в которой сейчас воспроизводится поиск",
                        "        if (DeleteTags('<color=,,>'+StarName(star)+'</color>')==input) //если название системы соответствует тому, что написал игрок в боксе, то возвращает систему для дальнейших операций",
                        "        {",
                        "            find=1; //система найдена",
                        "            itstar=star; //возвращает систему для дальнейших операций",
                        "        }",
                        "    }",
                        "    if (!find)",
                        "    {",
                        "        Sound('Sound.DelMsg');",
                        "        MessageBox(Format('Система <0> не найдена. Вы уверены, что правильно ввели название?',\"<0>\",input),34);",
                        "    }",
                        "    else Sound('Sound.NewMsg');",
                        "}",
                        "if(find) {",
                        "  DChange(2);",
                        "  exit;",
                        "}"
                    ],
