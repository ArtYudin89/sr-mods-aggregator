                {
                    "Name": "",
                    "Code.Type": "Turn",
                    "Code": [
                        "if(BlockExist('Script.Mod_EvoArmada')) {",
                        "    if(bArray[17,3]!=1) InjectAnswer('addImp0',CT(\"Script.mod_defstation.123\"),1);",
                        "    else InjectAnswer('addImp0',CT(\"Script.mod_defstation.122\"),-1);",
                        "}",
                        "if(bArray[17,3]!=0) InjectAnswer('addImp0',CT(\"Script.mod_defstation.121\"),0);",
                        "else InjectAnswer('addImp0',CT(\"Script.mod_defstation.120\"),-1);",
                        "InjectAnswer('addImp0',CT(\"Script.mod_defstation.89\"),100000);"
                    ],
