                    "Pos.x": 1030,
                    "Pos.y": 545
                },
                {
                    "Name": "",
                    "Code.Type": "Turn",
                    "Code": [
                        "tSystem=ShipStar(GetTalkShip());",
                        "for(i=0;i<StarPlanets(tSystem);i=i+1) {",
                        "    tPlanet=StarPlanets(tSystem,i);",
                        "    if(PlanetOwner(tPlanet)==None) continue;",
                        "    InjectAnswer('DPLanding',Format(CT(\"Script.mod_defstation.104\"),\"<0>\",Name(StarPlanets(tSystem,i))),i);",
                        "}",
                        "DAdd(23);"
                    ],
                    "#": 168,
                    "Type": "Top",
                    "Parent": -1,
                    "Pos.x": 1180,
                    "Pos.y": 545
                },
                {
                    "Name": "",
                    "Code.Type": "Turn",
                    "Code": [
                        "ShipMoney(Player(),ShipMoney(Player())-int1);",
                        "cPlanet=GetShipPlanet(Player());",
                        "cStar=ShipStar(Player());",
                        "dwd0=BuyWarrior(cPlanet);",
                        "TransferShip(dwd0,cStar);",
                        "int0=1;",
                        "while(int0==1) {",
                        "    int0=0;",
                        "    if(Rnd(0,1)==1)spawnX=Rnd(600,1200);",
                        "    else spawnX=Rnd(-600,-1200);",
                        "    if(Rnd(0,1)==1)spawnY=Rnd(600,1200);",
                        "    else spawnY=Rnd(-600,-1200);",
                        "    ShipSetCoords(dwd0,spawnX,spawnY);",
                        "    for(i=0;i<StarRuins(cStar);i=i+1) {",
                        "        dwd1=StarRuins(cStar,i);",
                        "        if(Dist(dwd0,dwd1)>300)continue;",
                        "        int0=1;",
                        "        break;",
                        "    }",
                        "    if(CountIn(CoalDefPla,cStar)!=0) {",
                        "        for(i=0;i<GroupCount(CoalDefPla);i=i+1) {",
                        "            dwd1=GroupShip(CoalDefPla,i);",
                        "            if(ShipStar(dwd1)!=cStar)continue;",
                        "            if(Dist(dwd0,dwd1)>300)continue;",
                        "            int0=1;",
                        "            break;",
                        "        }",
                        "    }",
                        "    if(CountIn(ClanDefPla,cStar)!=0) {",
                        "        for(i=0;i<GroupCount(ClanDefPla);i=i+1) {",
                        "            dwd1=GroupShip(ClanDefPla,i);",
                        "            if(ShipStar(dwd1)!=cStar)continue;",
                        "            if(Dist(dwd0,dwd1)>300)continue;",
                        "            int0=1;",
                        "            break;",
                        "        }",
                        "    }",
                        "}",
                        "Chameleon(dwd0,'Ruins.AMod_PE_DefPlatformBld');",
                        "NoTalkToShip(dwd0,1);",
                        "ShipJoin(NewPlatform,dwd0);",
                        "//Ether(0,'123','<spawnX>_<spawnY>');",
                        "int0=0;",
                        "for(i=0;i<ConStars(StarToCon(cStar));i=i+1) {",
                        "    dwd1=ConStar(StarToCon(cStar),i);",
                        "    if(CountIn(CoalDefPla,dwd1)!=0)int0=int0+CountIn(CoalDefPla,dwd1);",
                        "}",
                        "int0=int0+1;",
                        "str0=Name(StarToCon(cStar))+' -'+int0+'-';",
                        "SetName(dwd0,str0);",
                        "ShipSkill(dwd0,0,6);",
                        "ShipSkill(dwd0,1,6);",
                        "ShipType(dwd0,'DefPlatform');",
                        "NoDropToShip(dwd0,1);",
                        "NoTargetToShip(dwd0,1);",
                        "ShipSpecialBonuses(dwd0,bonWRadius,150);",
                        "//Дополнительные залпы при подключеннном EvoArmada",
                        "if(BlockExist('Script.Mod_EvoArmada')) {",
                        "    if(bArray[17,3]==1) ShipSpecialBonuses(dwd0,bonAttacks,2);",
                        "    else ShipSpecialBonuses(dwd0,bonAttacks,1);",
                        "}",
                        "ShipTechLevelKnowledge(dwd0,GalaxyTechLevel());",
                        "HullType(ShipEqInSlot(dwd0,t_Hull),8);",
                        "HullSeries(ShipEqInSlot(dwd0,t_Hull),-1);",
                        "ItemSize(ShipEqInSlot(dwd0,t_Hull),bArray[0,3]);",
                        "ItemCost(ShipEqInSlot(dwd0,t_Hull),bArray[0,2]);",
                        "ItemLevel(ShipEqInSlot(dwd0,t_Hull),GalaxyTechLevel());",
                        "//1 - таймер до перезарядки ракетных орудий",
                        "//2 - таймер до следующего обновления",
                        "//3 - таймер до отката телепорта или -1",
                        "//Text 1 - маркер и текущих передвижениях станции: 'Teleport' или 'Move'",
                        "//Text 2 - система назначения прыжка или X-координата при простом полёте к точке",
                        "//Text 3 - Y-координата при простом полёте к точке",
                        "ShipAddCustomShipInfo(dwd0,'DefStationInfo','NoShow',30,182,CurTurn()+160);",
                        "if(bArray[17,3]) ShipCustomShipInfoData(dwd0,'DefStationInfo',3,-1); //флаг отсутствия портального генератора",
                        "for(i=ShipItems(dwd0)-1;i>0;i=i-1) {",
                        "    FreeItem(GetItemFromShip(dwd0,i));",
                        "}",
                        "for(i=0;i<5;i=i+1) {",
                        "    dwd0=BuyTransport(cPlanet,2);",
                        "    ShipOwner(dwd0,PlanetOwner(cPlanet));",
                        "    Chameleon(dwd0,'Ship.Tranclucator');",
                        "    TransferShip(dwd0,cStar);",
                        "    ShipSetCoords(dwd0,spawnX+Rnd(-300,300),spawnY+Rnd(-300,300));",
                        "    ShipJoin(Builders,dwd0);",
                        "    HullType(ShipEqInSlot(dwd0,t_Hull),8);",
                        "    HullSeries(ShipEqInSlot(dwd0,t_Hull),-1);",
                        "    ShipSkill(dwd0,2,6);",
                        "    ShipType(dwd0,'Builder');",
                        "    NoTargetToShip(dwd0,1);",
                        "}",
                        "bldState=1;",
                        "vaultItem=0;",
                        "for(i=t_FuelTanks;i<t_Weapon1;i=i+1) {",
                        "    int0=i-t_Hull;",
                        "    if(bArray[int0,3]==-1) {",
                        "        tempItem=CreateEquipment(i,50,GalaxyTechLevel(),PlanetOwner(cPlanet));",
                        "        vaultItem=vaultItem+1;",
                        "        PutItemInVault('AMod_PE_'+vaultItem,tempItem);",
                        "    }",
                        "}",
                        "if (GalaxyTechLevel() == 1) int0 = t_Weapon1; // Промышленный лазер",
                        "else if (GalaxyTechLevel() == 2) int0 = t_Weapon3; // Лезка",
                        "else if (GalaxyTechLevel() == 3) int0 = t_Weapon3; // Лезка",
                        "else if (GalaxyTechLevel() == 4) int0 = t_Weapon6; // Волновой фазер",
                        "else if (GalaxyTechLevel() == 5) int0 = t_Weapon6; // Волновой фазер",
                        "else if (GalaxyTechLevel() == 6) int0 = t_Weapon9; // Мультирезонатор",
                        "else if (GalaxyTechLevel() == 7) int0 = t_Weapon10; // Атомный визион",
                        "else int0 = t_Weapon12; // Турбогравир",
                        "for(i=8;i<13;i=i+1) {",
                        "    if(bArray[i,3]==-1) {",
                        "        tempItem=CreateEquipment(int0,100,GalaxyTechLevel(),PlanetOwner(cPlanet));",
                        "        vaultItem=vaultItem+1;",
                        "        PutItemInVault('AMod_PE_'+vaultItem,tempItem);",
                        "    }",
                        "}",
                        "for(i=StorageItems()-1;i>-1;i=i-1) {",
                        "    if(StorageItemLocation(i)!=cPlanet)continue;",
                        "    int0=0;",
                        "    for(j=1;j<17;j=j+1) {",
                        "        if(bArray[j,3]!=i)continue;",
                        "        int0=1;",
                        "        break;",
                        "    }",
                        "    if(int0==0)continue;",
                        "    tempItem=GetItemFromStorage(i);",
                        "    vaultItem=vaultItem+1;",
                        "    PutItemInVault('AMod_PE_'+vaultItem,tempItem);",
                        "}",
                        "DChange(4);",
                        "exit;"
                    ],
                    "#": 169,
                    "Type": "Top",
                    "Parent": -1,
                    "Pos.x": -20,
                    "Pos.y": 615
                },
                {
                    "Name": "",
                    "Code.Type": "Turn",
                    "Code": [
                        "if(ShipRank(Player())<3 && GetShipPirateRank(Player())<3) {",
                        "  DChange(14);",
                        "  exit;",
                        "}",
                        "if(ShipRank(Player())>=3 || GetShipPirateRank(Player())>=3) {",
                        "  //Сравниваем расстояние от солнца до самой дальней планеты в системе, не летим слишком далеко за ее пределы",
                        "  tPlanet=FindPlanet(ShipStar(GetTalkShip()),'',100,100);",
                        "  temp_dwordX=Dist(ShipStar(GetTalkShip()),tPlanet);",
                        "  //Ищем в списке артов защитки рефлектор",
                        "  reflectorCheck=0;",
                        "  for(i=ShipArts(GetTalkShip())-1;i>-1;i=i-1) {",
                        "      dwd0=ShipArts(GetTalkShip(),i);",
                        "      if(EquipmentImageName(dwd0)=='RNDart_02') reflectorCheck=1;",
                        "  }",
                        "  if(Dist(Player(),ShipStar(GetTalkShip()))>round(1.25*temp_dwordX)) {",
                        "    DChange(28);",
                        "    exit;",
                        "  }",
                        "  if(Dist(Player(),ShipStar(Player()))<600 && !reflectorCheck) {",
                        "    DChange(29);",
                        "    exit;",
                        "  }",
                        "  if(Dist(Player(),ShipStar(GetTalkShip()))<=round(1.25*temp_dwordX)) {",
                        "    OrderMove(GetTalkShip(),CoordX(Player()),CoordY(Player()));",
                        "    OrderLock(GetTalkShip(),1);",
                        "    ShipCustomShipInfoTextData(GetTalkShip(),int1,1,'Move');",
                        "    ShipCustomShipInfoTextData(GetTalkShip(),int1,2,CoordX(Player()));",
                        "    ShipCustomShipInfoTextData(GetTalkShip(),int1,3,CoordY(Player()));",
                        "    DChange(11);",
                        "    exit;",
                        "  }",
                        "}"
                    ],
                    "#": 170,
                    "Type": "Top",
                    "Parent": -1,
                    "Pos.x": 820,
                    "Pos.y": 615
                },
                {
                    "Name": "",
                    "Code.Type": "Turn",
                    "Code": [
                        "if(!ShipOnSidePirateClan(GetTalkShip())) {",
                        "  if(ShipOnSidePirateClan(Player())) {",
                        "    DChange(26);",
                        "    exit;",
                        "  }",
                        "  if(!ShipOnSidePirateClan(Player())) {",
                        "    if(ShipRank(Player())<6) {",
                        "      DChange(23);",
                        "      exit;",
                        "    }",
                        "    if(ShipRank(Player())>=6) {",
                        "      //;",
                        "      if(ShipCustomShipInfoData(GetTalkShip(),int1,3)>CurTurn()) {",
                        "        DChange(16);",
                        "        exit;",
                        "      }",
                        "      if(ShipCustomShipInfoData(GetTalkShip(),int1,3)<=CurTurn()) {",
                        "        DChange(27);",
                        "        exit;",
                        "      }",
                        "    }",
                        "  }",
                        "}",
                        "if(ShipOnSidePirateClan(GetTalkShip())) {",
                        "  if(ShipOnSidePirateClan(Player())) {",
                        "    if(GetShipPirateRank(Player())>=6) {",
                        "      //;",
                        "      if(ShipCustomShipInfoData(GetTalkShip(),int1,3)>CurTurn()) {",
                        "        DChange(16);",
                        "        exit;",
                        "      }",
                        "      if(ShipCustomShipInfoData(GetTalkShip(),int1,3)<=CurTurn()) {",
                        "        DChange(27);",
                        "        exit;",
                        "      }",
                        "    }",
                        "    if(GetShipPirateRank(Player())<6) {",
                        "      DChange(24);",
                        "      exit;",
                        "    }",
                        "  }",
                        "  if(!ShipOnSidePirateClan(Player())) {",
                        "    DChange(25);",
                        "    exit;",
                        "  }",
                        "}"
                    ],
                    "#": 171,
                    "Type": "Top",
                    "Parent": -1,
                    "Pos.x": 940,
                    "Pos.y": 615
                },
                {
                    "Name": "",
                    "Code.Type": "Turn",
                    "Code": [
                        "RunChildForm('Galaxy');",
                        "if(ShipOrder(Player())==7) {",
                        "    tSystem=ShipOrderObj(Player());",
                        "    OrderNone(Player());",
                        "}",
                        "int0=0;",
                        "tCon=StarToCon(tSystem);",
                        "//Если прыжок совершается в другой сектор, считаем станции",
                        "if(tCon!=StarToCon(ShipStar(GetTalkShip()))) {",
                        "    for(i=0;i<ConStars(tCon);i=i+1) {",
                        "        temp_dwordX=ConStar(tCon,i);",
                        "        for(j=0;j<StarShips(temp_dwordX);j=j+1) {",
                        "            tShip=StarShips(temp_dwordX,j);",
                        "            if(ShipType(tShip)=='DefPlatform') int0=int0+1;",
                        "        }",
                        "    }",
                        "    //Учитываем все телепортирующиеся станции",
                        "    for(i=GroupCount(CoalDefPla)-1;i>=0;i=i-1) {",
                        "        tShip=GroupShip(CoalDefPla,i);",
                        "        if(ShipOrder(tShip)==7) {",
                        "            if(StarToCon(ShipOrderObj(tShip))==tCon) int0=int0+1;",
                        "        }",
                        "    }",
                        "    for(i=GroupCount(ClanDefPla)-1;i>=0;i=i-1) {",
                        "        tShip=GroupShip(ClanDefPla,i);",
                        "        if(ShipOrder(tShip)==7) {",
                        "            if(StarToCon(ShipOrderObj(tShip))==tCon) int0=int0+1;",
                        "        }",
                        "    }",
                        "}",
                        "if(Dist2Star(tSystem,ShipStar(GetTalkShip()))<=930 && int0<maxStation) {",
                        "  DChange(13);",
                        "  exit;",
                        "}",
                        "if(Dist2Star(tSystem,ShipStar(GetTalkShip()))>930) {",
                        "  DChange(12);",
                        "  exit;",
                        "}",
                        "if(int0>=maxStation) {",
                        "  DChange(22);",
                        "  exit;",
                        "}"
                    ],
                    "#": 172,
                    "Type": "Top",
                    "Parent": -1,
                    "Pos.x": 1420,
                    "Pos.y": 615
                },
                {
                    "Name": "",
                    "Code.Type": "Turn",
                    "Code": [
                        "if(ShipOnSidePirateClan(GetTalkShip())) {",
                        "  if(!ShipOnSidePirateClan(Player())) {",
                        "    DChange(20);",
                        "    exit;",
                        "  }",
                        "  if(ShipOnSidePirateClan(Player())) {",
                        "    if(GetShipPirateRank(Player())<6) {",
                        "      DChange(19);",
                        "      exit;",
                        "    }",
                        "    if(GetShipPirateRank(Player())>=6) {",
                        "      DChange(32);",
                        "      exit;",
                        "    }",
                        "  }",
                        "}",
                        "if(!ShipOnSidePirateClan(GetTalkShip())) {",
                        "  if(!ShipOnSidePirateClan(Player())) {",
                        "    if(ShipRank(Player())>=6) {",
                        "      DChange(32);",
                        "      exit;",
                        "    }",
                        "    if(ShipRank(Player())<6) {",
                        "      DChange(18);",
                        "      exit;",
                        "    }",
                        "  }",
                        "  if(ShipOnSidePirateClan(Player())) {",
                        "    DChange(17);",
                        "    exit;",
                        "  }",
                        "}"
                    ],
                    "#": 173,
                    "Type": "Top",
                    "Parent": -1,
                    "Pos.x": 100,
                    "Pos.y": 640
                },
                {
                    "Name": "",
                    "Code.Type": "Turn",
                    "Code": [
                        "if(OrderLock(CurShip)) OrderLock(CurShip,0);",
                        "ShipOut(CurShip);",
                        "if(ShipOwner(CurShip)!=7) ShipJoin(CoalDefPla,CurShip);",
                        "else ShipJoin(ClanDefPla,CurShip);"
                    ],
                    "#": 174,
                    "Type": "Top",
                    "Parent": -1,
                    "Pos.x": 340,
                    "Pos.y": 640
                }
