            "Items": [],
            "Operations": [
                {
                    "Name": "",
                    "Code.Type": "Global",
                    "Code": [
                        "GRun();"
                    ],
                    "#": 36,
                    "Type": "Top",
                    "Parent": -1,
                    "Pos.x": 0,
                    "Pos.y": 710
                },
                {
                    "Name": "",
                    "Code.Type": "Init",
                    "Code": [
                        "if(GalaxyDiffLevels()<150)maxStation=1;",
                        "if(GalaxyDiffLevels()>149 && GalaxyDiffLevels()<200)maxStation=2;",
                        "if(GalaxyDiffLevels()>199 && GalaxyDiffLevels()<350)maxStation=3;",
                        "if(GalaxyDiffLevels()>349)maxStation=4;",
                        "strBR=substr(CT('Cheat.Ok'),0,2);",
                        "buildId=newarray(3);",
                        "buildId[1]=0;",
                        "buildId[2]=0;",
                        "bArray=newarray(19,5);",
                        "//bArray 0 корпус",
                        "//bArray 1 бак",
                        "//bArray 2 двигатель",
                        "//bArray 3 радар",
                        "//bArray 4 сканер",
                        "//bArray 5 дроид",
                        "//bArray 6 захват",
                        "//bArray 7 гзп",
                        "//bArray 8 пуха 1",
                        "//bArray 9 пуха 2",
                        "//bArray 10 пуха 3",
                        "//bArray 11 пуха 4",
                        "//bArray 12 пуха 5",
                        "//bArray 13 арт 1",
                        "//bArray 14 арт 2",
                        "//bArray 15 арт 3",
                        "//bArray 16 арт 4",
                        "//bArray 17 слот портального генератора",
                        "//bArray [i,0] название предмета(запоминаем)",
                        "//bArray [i,1] название предмета(текст)",
                        "//bArray [i,2] цена предмета",
                        "//bArray [i,3] номер предмета на складе или -1(для корпуса прочность)",
                        "//bArray [i,4] Id предмета на складе",
                        "//bArray[17,3]==-1 - ничего, ==0 - портальный генератор, ==1 - доп. залп в EvoArmada",
                        "for(i=0;i<19;i=i+1) {",
                        "    for(j=2;j<5;j=j+1)bArray[i,j]=0;",
                        "}",
                        "//Функция снятия улучшения и изъятия ММ из предмета",
                        "function Deupgrade(dword item) {",
                        "    dword cloneItem;",
                        "    int cloneAcryn=-1;",
                        "    int cloneModule=-1;",
                        "    int spNum;",
                        "    int status=0;",
                        "    str spName;",
                        "    //Создается предмет-копия",
                        "    if(ItemType(item)!=t_CustomWeapon) cloneItem=CreateEquipment(ItemType(item),ItemSize(item),ItemLevel(item),ItemOwner(item));",
                        "    else cloneItem=CreateCustomWeapon(CustomWeaponType(item),ItemSize(item),ItemLevel(item),ItemOwner(item));",
                        "    if(EqSpecial(item)!=-1) { //если на оригинале есть акрин, запоминаем его номер",
                        "        cloneAcryn=EqSpecial(item);",
                        "        EqSpecial(item,-1);",
                        "    }",
                        "    if(ItemExtraSpecials(item)) { //ищем спецакрин, указывающий на то, что предмет уже был с улучшением/ММ",
                        "        for(int i=ItemExtraSpecials(item)-1;i>-1;i=i-1) {",
                        "            spNum=ItemExtraSpecials(item,i);",
                        "            spName=BonusNumInCfg(spNum);",
                        "            if(spName=='AMod_DefStation_WasModule') {",
                        "                status=status+2; //запоминаем, что в предмете был ММ",
                        "                ItemExtraSpecialsDeleteByType(item,spNum); //удаляем спецакрин",
                        "            }",
                        "            if(spName=='AMod_DefStation_WasImprovement') {",
                        "                status=status+4; //запоминаем, что предмет был улучшен",
                        "                ItemExtraSpecialsDeleteByType(item,spNum); //удаляем спецакрин",
                        "            }",
                        "        }",
                        "    }",
                        "    if(status & 2) cloneModule=EqModule(item); //если в предмете был ММ, запоминаем номер бонуса",
                        "    ModuleToEquipment(-1,item); //изымаем ММ для корректного расчета статов",
                        "    if(!(status & 4)) { //если на предмете изначально не было улучшения - снимаем улучшение",
                        "        if(ItemType(item)>=t_Weapon1 && ItemType(item)<=t_CustomWeapon) {",
                        "            SetEquipmentStats(item,GetEquipmentStats(cloneItem,0),0);",
                        "            SetEquipmentStats(item,GetEquipmentStats(cloneItem,1),1);",
                        "            SetEquipmentStats(item,GetEquipmentStats(cloneItem,2),2);",
                        "        }",
                        "        else if(ItemType(item)==t_Engine || ItemType(item)==t_CargoHook) {",
                        "            SetEquipmentStats(item,GetEquipmentStats(cloneItem,0),0);",
                        "            SetEquipmentStats(item,GetEquipmentStats(cloneItem,1),1);",
                        "        }",
                        "        else SetEquipmentStats(item,GetEquipmentStats(cloneItem,0),0);",
                        "    }",
                        "    if(cloneAcryn>=0) { //копируем акрин",
                        "        EqSpecial(item,cloneAcryn);",
                        "        EqSpecial(cloneItem,cloneAcryn);",
                        "    }",
                        "    if(cloneModule>=0) { //копируем ММ, если он был изначально",
                        "        ModuleToEquipment(cloneModule,item);",
                        "        ModuleToEquipment(cloneModule,cloneItem);",
                        "    }",
                        "    ItemCost(item,ItemCost(cloneItem)); //расчет стоимости",
                        "    FreeItem(cloneItem); //копия нам больше не нужна",
                        "}"
                    ],
                    "#": 37,
                    "Type": "Top",
                    "Parent": -1,
                    "Pos.x": 60,
                    "Pos.y": 710
                },
                {
                    "Name": "",
                    "Code.Type": "Turn",
                    "Code": [
                        "if(bldState==1) {",
                        "  if(!GroupToShip(NewPlatform)) {",
                        "    bldState=0;",
                        "    for(i=1;i<=vaultItem;i=i+1) {",
                        "        dwd0=GetItemFromVault('AMod_PE_'+i);",
                        "        if(dwd0)FreeItem(dwd0);",
                        "    }",
                        "  }",
                        "}"
                    ],
                    "#": 38,
                    "Type": "Top",
                    "Parent": -1,
                    "Pos.x": 120,
                    "Pos.y": 710
                },
                {
                    "Name": "",
                    "Code.Type": "DialogBegin",
                    "Code": [
                        "if(GetShipPlanet(Player())>0) {",
                        "  if(PlanetOwner(GetShipPlanet(Player()))!=6) {",
                        "    cStar=ShipStar(Player());",
                        "    cPlanet=GetShipPlanet(Player());",
                        "    if(cPlanet!=PlanetPirateClan())",
                        "    {",
                        "        if(StarBattle(cStar))",
                        "        {",
                        "            if(PlanetOwner(cPlanet)==7)AddDialogInject('battleClan','',CT(\"Script.mod_defstation.56\"),2);",
                        "            if(PlanetOwner(cPlanet)<5)AddDialogInject('battleCoal','',CT(\"Script.mod_defstation.56\"),2);",
                        "        }",
                        "        else",
                        "        {",
                        "            if(PlanetOwner(cPlanet)==7)",
                        "            {",
                        "                if(RelationToRanger(PlanetPirateClan(),Player())<30)AddDialogInject('badRelation','',CT(\"Script.mod_defstation.56\"),2);",
                        "                else AddDialogInject('defStation','',CT(\"Script.mod_defstation.56\"),2);",
                        "            }",
                        "            else",
                        "            {",
                        "                if(RelationToRanger(cPlanet,Player())<30)AddDialogInject('badRelation','',CT(\"Script.mod_defstation.56\"),2);",
                        "                else AddDialogInject('defStation','',CT(\"Script.mod_defstation.56\"),2);",
                        "            }",
                        "        }",
                        "    }",
                        "  }",
                        "}",
                        "if(GetTalkShip()) {",
                        "  if(ShipFindCustomShipInfoByType(GetTalkShip(),'DefStationInfo')>-1) {",
                        "    if(ShipGetBad(GetTalkShip())!=Player() && RelationToRanger(GetTalkShip(),Player())>9) {",
                        "      AddDialogOverride('DefStationDialog',9000);",
                        "    }",
                        "    if(ShipGetBad(GetTalkShip())==Player() || RelationToRanger(GetTalkShip(),Player())<10) {",
                        "      AddDialogOverride('DefStationNone',9000);",
                        "    }",
                        "  }",
                        "}"
                    ],
                    "#": 39,
                    "Type": "Top",
                    "Parent": -1,
                    "Pos.x": 180,
                    "Pos.y": 710
                },
                {
                    "Name": "",
                    "Code.Type": "Turn",
                    "Code": [
                        "for(i=ShipItems(CurShip)-1;i>0;i=i-1) {",
                        "    dwd0=ShipItems(CurShip,i);",
                        "    if(!ItemIsInUse(dwd0)) FreeItem(GetItemFromShip(CurShip,i));",
                        "    else {",
                        "        if(ItemDurability(dwd0)<31) ItemDurability(dwd0,100);",
                        "    }",
                        "}",
                        "for(i=ShipArts(CurShip)-1;i>-1;i=i-1) {",
                        "    dwd0=ShipArts(CurShip,i);",
                        "    if(!ItemIsInUse(dwd0)) FreeItem(GetArtFromShip(CurShip,i));",
                        "    else {",
                        "        if(ItemDurability(dwd0)<31) ItemDurability(dwd0,100);",
                        "    }",
                        "}"
                    ],
                    "#": 117,
                    "Type": "Top",
                    "Parent": -1,
                    "Pos.x": 80
                },
                {
                    "Name": "",
                    "Code.Type": "Turn",
                    "Code": [
                        "if(!GroupToShip(NewPlatform)) {",
                        "  if(!OrderLock(CurShip))",
                        "  {",
                        "      OrderLanding(CurShip,GetShipHomePlanet(CurShip),1);",
                        "      OrderLock(CurShip,1);",
                        "  }",
                        "  if(GetShipPlanet(CurShip)>0)",
                        "  {",
                        "      OrderLock(CurShip,0);",
                        "      OrderNone(CurShip,1);",
                        "      OrderLock(CurShip,1);",
                        "      ShipDestroy(CurShip,1);",
                        "  }",
                        "}",
                        "if(GroupToShip(NewPlatform)) {",
                        "  HullHP(GroupToShip(NewPlatform),HullHP(GroupToShip(NewPlatform))+Rnd(10,20));",
                        "}"
                    ],
                    "#": 118,
                    "Type": "Top",
                    "Parent": -1,
                    "Pos.x": 160
                },
                {
                    "Name": "",
                    "Code.Type": "Turn",
                    "Code": [
                        "if(HullHP(CurShip)<bArray[0,3])HullHP(CurShip,HullHP(CurShip)+Rnd(10,20));",
                        "if(HullHP(CurShip)>=bArray[0,3]) {",
                        "    Chameleon(CurShip,'Ruins.AMod_PE_DefPlatform');",
                        "    NoTalkToShip(CurShip,0);",
                        "    bldState=0;",
                        "    for(i=0;i<GroupCount(Builders);i=i+1) {",
                        "        dwd0=GroupShip(Builders,i);",
                        "        OrderLanding(dwd0,GetShipHomePlanet(dwd0),1);",
                        "        OrderLock(dwd0,1);",
                        "    }",
                        "    HullHP(CurShip,bArray[0,3]);",
                        "    ShipOut(CurShip);",
                        "    if(ShipOwner(CurShip)!=7) ShipJoin(CoalDefPla,CurShip);",
                        "    else ShipJoin(ClanDefPla,CurShip);",
                        "    for(i=1;i<=vaultItem;i=i+1) {",
                        "        tempItem=GetItemFromVault('AMod_PE_'+i);",
                        "        AddItemToShip(CurShip,tempItem);",
                        "        if(ItemImprovement(tempItem)) ItemExtraSpecialsAddByType(tempItem,FindBonusByNameInCfg('AMod_DefStation_WasImprovement'),1);",
                        "        if(~EqModule(tempItem)) ItemExtraSpecialsAddByType(tempItem,FindBonusByNameInCfg('AMod_DefStation_WasModule'),1);",
                        "    }",
                        "    ArrangeItems(CurShip);",
