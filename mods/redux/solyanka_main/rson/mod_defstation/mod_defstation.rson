                        "    if(CountIn(CoalDefPla,dwd0)!=0)int0=int0+CountIn(CoalDefPla,dwd0);",
                        "    if(CountIn(ClanDefPla,dwd0)!=0)int0=int0+CountIn(ClanDefPla,dwd0);",
                        "}",
                        "if(int0>=maxStation && !GroupToShip(NewPlatform)) {",
                        "  DChange(1);",
                        "  exit;",
                        "}",
                        "if(GroupToShip(NewPlatform) || GroupToShip(Builders)) {",
                        "  DChange(5);",
                        "  exit;",
                        "}",
                        "if(int0<maxStation && !GroupToShip(NewPlatform)) {",
                        "  cPlanet=GetShipPlanet(Player());",
                        "  if(buildId[1]!=Id(cPlanet) && buildId[2]!=CurTurn()) {",
                        "      buildId[1]=Id(cPlanet);",
                        "      buildId[2]=CurTurn();",
                        "      tempItem=CreateHull(8,1000,GalaxyTechLevel(),PlanetOwner(cPlanet),-1);",
                        "      bArray[0,1]=Name(tempItem);",
                        "      bArray[0,2]=0.8*ItemCost(tempItem);",
                        "      bArray[0,3]=1000;",
                        "      FreeItem(tempItem);",
                        "      for(i=t_FuelTanks;i<t_Weapon1;i=i+1) {",
                        "          tempItem=CreateEquipment(i,100,GalaxyTechLevel(),PlanetOwner(cPlanet));",
                        "          int0=i-t_Hull;",
                        "          bArray[int0,0]=Name(tempItem);",
                        "          bArray[int0,1]=Name(tempItem);",
                        "          bArray[int0,2]=ItemCost(tempItem);",
                        "          bArray[int0,3]=-1;",
                        "          FreeItem(tempItem);",
                        "      }",
                        "      if(GalaxyTechLevel()==1) int0=t_Weapon1; // Промышленный лазер",
                        "      else if(GalaxyTechLevel()==2) int0=t_Weapon3; // Лезка",
                        "      else if(GalaxyTechLevel()==3) int0=t_Weapon3; // Лезка",
                        "      else if(GalaxyTechLevel()==4) int0=t_Weapon6; // Волновой фазер",
                        "      else if(GalaxyTechLevel()==5) int0=t_Weapon6; // Волновой фазер",
                        "      else if(GalaxyTechLevel()==6) int0=t_Weapon9; // Мультирезонатор",
                        "      else if(GalaxyTechLevel()==7) int0=t_Weapon10; // Атомный визион",
                        "      else if(GalaxyTechLevel()==8) int0=t_Weapon12; // Турбогравир",
                        "      for(i=8;i<13;i=i+1) {",
                        "          tempItem=CreateEquipment(int0,60,GalaxyTechLevel(),PlanetOwner(cPlanet));",
                        "          bArray[i,0]=Name(tempItem);",
                        "          bArray[i,1]=Name(tempItem);",
                        "          bArray[i,2]=ItemCost(tempItem);",
                        "          bArray[i,3]=-1;",
                        "          FreeItem(tempItem);",
                        "      }",
                        "      for(i=13;i<18;i=i+1) {",
                        "          bArray[i,0]=CT(\"Script.mod_defstation.113\");",
                        "          bArray[i,1]=CT(\"Script.mod_defstation.113\");",
                        "          bArray[i,2]=0;",
                        "          bArray[i,3]=-1;",
                        "      }",
                        "      bArray[17,2]=75; //отдельно выставляем коэффициент для пустого слота модификации",
                        "  }",
                        "  int1=bArray[0,2]; //начальная стоимость корпуса",
                        "  int1=bArray[17,2]*int1/100; //коэффициент для модификации корпуса",
                        "  for(i=1;i<17;i=i+1) { //перебираем все предметы в массиве",
                        "      if(bArray[i,3]!=-1) { //если игрок менял стандартное оборудование",
                        "          dwd0=StorageItems(bArray[i,3]); //проверяем, совпадает ли Id предмета на складе с Id в массиве",
                        "          if(dwd0) {",
                        "              if(Id(dwd0)!=bArray[i,4]) bArray[i,3]=-1;",
                        "          } else bArray[i,3]=-1; //если не совпадает/предмета нет на складе - удаляем номер из массива",
                        "          if(bArray[i,3]==-1) bArray[i,1]=bArray[i,0]; //и возвращаем стандартный текст",
                        "      }",
                        "      if(i<13) { //стоимость артефактов не учитывается",
                        "          if(bArray[i,3]==-1) int1=int1+(bArray[i,2]+(bArray[i,2]*20/100)); //цена стандартного оборудования",
                        "      }",
                        "  }",
                        "  GAnswerData=0;",
                        "  changeEq=0;",
                        "  DChange(0);",
                        "  exit;",
                        "}"
