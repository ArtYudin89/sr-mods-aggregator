                    "Code": [
                        "for(i=0;i<StorageItems();i=i+1) { //Перебираем все предметы на складе",
                        "    if(StorageItemLocation(i)!=cPlanet)continue;",
                        "    int0=0;",
                        "    for(j=1;j<17;j=j+1) {",
                        "        if(bArray[j,3]!=i)continue;",
                        "        int0=1;",
                        "        break;",
                        "    }",
                        "    if(int0==1)continue;",
                        "    dwd0=StorageItems(i);",
                        "    if(changeEq>0 && changeEq<8) { //слоты оборудования",
                        "        if(ItemType(dwd0)!=t_Hull+changeEq)continue;",
                        "    }",
                        "    if(changeEq>7 && changeEq<13) { //оружейные слоты",
                        "        if(ItemType(dwd0)<t_Weapon1 || ItemType(dwd0)>t_CustomWeapon)continue;",
                        "    }",
                        "    if(changeEq>12) { //слоты артефактов",
                        "        if(ItemType(dwd0)<t_Artefact || ItemType(dwd0)>=t_Hull)continue;",
                        "        if(ItemType(dwd0)==t_ArtefactTransmitter)continue;",
                        "        if(ItemType(dwd0)==t_ArtefactBomb)continue;",
                        "        if(ItemType(dwd0)==t_ArtefactTranclucator)continue;",
                        "        if(ItemType(dwd0)==t_ArtBlackHole)continue;",
                        "        if(ItemType(dwd0)==t_ArtDefToArms1)continue;",
                        "        if(ItemType(dwd0)==t_ArtDefToArms2)continue;",
                        "        int0=0;",
                        "        for(j=13;j<17;j=j+1) {",
                        "            if(bArray[j,3]==-1)continue;",
                        "            dwd1=StorageItems(bArray[j,3]);",
                        "            if(ItemType(dwd0)!=ItemType(dwd1))continue;",
                        "            int0=1;",
                        "            break;",
                        "        }",
                        "        if(int0==1)continue;",
                        "    }",
                        "    InjectAnswer('choseEq',Name(dwd0)+Format(' <0> ',\"<0>\",ItemSize(dwd0))+CT(\"Script.mod_defstation.119\"),i);",
                        "}",
