                },
                {
                    "Name": "",
                    "Code.Type": "Turn",
                    "Code": [
                        "if(GetShipPlanet(CurShip)) {",
                        "  tStr='';",
                        "  for(i=ShipItems(CurShip)-1;i>0;i=i-1) {",
                        "      tempItem=ShipItems(CurShip,i);",
                        "      Deupgrade(tempItem);",
                        "      GetItemFromShip(CurShip,tempItem);",
                        "      AddItemToStorage(GetShipPlanet(CurShip),tempItem);",
                        "      tStr=tStr+'</color>- <color=255,240,100>'+Name(tempItem)+'</color>'+Format(CT(\"Script.mod_defstation.109\"),\"<0>\",ItemSize(tempItem))+CT(\"Script.mod_defstation.108\");",
                        "  }",
                        "  if(ShipArts(CurShip)) {",
                        "      for(i=ShipArts(CurShip)-1;i>-1;i=i-1) {",
                        "          tempItem=ShipArts(CurShip,i);",
                        "          GetArtFromShip(CurShip,tempItem);",
                        "          SFT(Name(tempItem));",
                        "          AddItemToStorage(GetShipPlanet(CurShip),tempItem);",
                        "          tStr=tStr+'</color>- <color=255,240,100>'+Name(tempItem)+'</color>'+Format(CT(\"Script.mod_defstation.109\"),\"<0>\",ItemSize(tempItem))+CT(\"Script.mod_defstation.108\");",
                        "      }",
                        "  }",
                        "  Ether(7,'',Format(CT(\"Script.mod_defstation.111\"),\"<0>\",Name(CurShip),\"<1>\",Name(GetShipPlanet(CurShip)),\"<2>\",tStr));",
