            "Operations": [
                {
                    "Name": "",
                    "Code.Type": "Global",
                    "Code": [
                        "if(GalaxyTechLevel()>=5) GRun();"
                    ],
                    "#": 51,
                    "Type": "Top",
                    "Parent": -1,
                    "Pos.x": 0,
                    "Pos.y": 785
                },
                {
                    "Name": "",
                    "Code.Type": "Init",
                    "Code": [
                        "difCoef=GalaxyDiffLevels()/100;",
                        "arksNumb=0;",
                        "strBR=substr(CT('Cheat.Ok'),0,2);",
                        "gunName=newarray(6);",
                        "gunName[0]='ArksGun';",
                        "QState=newarray(4);",
                        "arr0=newarray(1);",
                        "arrTC=newarray(11);",
                        "research=newarray(11);",
                        "arcArray=newarray(4,4);",
                        "spwnDate=newarray(4,11);",
                        "",
                        "//Задаём цены из ланга (в обломках арксов) для покупки батлкрузера и лазерганов к нему",
                        "needForHull=CT('Items.Weapon.BattlecruiserConfig.BattlecruiserScrapCost');",
                        "needForLaserGun=CT('Items.Weapon.BattlecruiserConfig.LaserMissileScrapCost');",
                        "for(i=1;i<4;i=i+1)",
                        "\t{",
                        "\tQState[i]=0;",
                        "\tarcArray[i,1]=0;",
                        "\tarcArray[i,2]=0;",
                        "\tarcArray[i,3]=0;",
                        "\tfor(j=0;j<11;j=j+1)",
                        "\t\t{",
                        "\t\tarrTC[j]=0;",
                        "\t\tresearch[j]=0;",
                        "\t\tspwnDate[i,j]=0;",
                        "\t\t}",
                        "\t}",
                        "QState[0]=3;",
                        "function SpawnArkShip(tStar,tCount,tStarAtt)",
                        "{",
                        "\tfor(funct_i=0;funct_i<StarPlanets(tStar);funct_i=funct_i+1)",
                        "\t{",
                        "\t\tfunct_dwd2=StarPlanets(tStar,funct_i);",
                        "\t\tif(PlanetOwner(funct_dwd2)!=6)break;",
                        "\t}",
                        "\tStarSeries(tStar,1);",
                        "\tfor(funct_i=0;funct_i<tCount;funct_i=funct_i+1)",
                        "\t{",
                        "\t\tarksNumb=arksNumb+1;",
                        "\t\tfunct_dwd0=BuyDomikExtremal(funct_dwd2);",
                        "\t\twhile(ShipSubType(funct_dwd0)==6)",
                        "\t\t{",
                        "\t\t\tOrderNone(funct_dwd0,1);",
                        "\t\t\tOrderLock(funct_dwd0,1);",
                        "\t\t\tShipDestroy(funct_dwd0,1);",
                        "\t\t\tfunct_dwd0=BuyDomikExtremal(funct_dwd2);",
                        "\t\t}",
                        "\t\tShipOwner(funct_dwd0,0);",
                        "\t\tShipJoin(Invaders,funct_dwd0);",
                        "\t\tShipCustomFaction(funct_dwd0,'AMod_Invaders');",
                        "\t\tShipFace(funct_dwd0,0);",
                        "\t\tNoScanToShip(funct_dwd0,1);",
                        "    //Спавнится Рондар 1",
                        "\t\tif(ShipSubType(funct_dwd0)==5)",
                        "\t\t{",
                        "\t\t\tfunct_int0=Rnd(0,2);",
                        "\t\t\tfor(funct_j=0;funct_j<funct_int0;funct_j=funct_j+1)",
                        "\t\t\t{",
                        "\t\t\t\tfunct_dwd1=CreateCustomCountableItem('AMod_InvadersParts',Rnd(2,20),1);",
                        "\t\t\t\tEqCustomFaction(funct_dwd1,'AMod_Invaders');",
                        "\t\t\t    ShipAddDropItem(funct_dwd0,funct_dwd1);",
                        "\t\t\t}",
                        "\t\t\tShipSkill(funct_dwd0,0,4);",
                        "\t\t\tShipSkill(funct_dwd0,1,2);",
                        "\t\t\tItemSize(ShipEqInSlot(funct_dwd0,t_Hull),Rnd(150,250));",
                        "\t\t\tShipRepairEq(funct_dwd0);",
                        "\t\t\tShipType(funct_dwd0,'AMod_Invaders0');",
                        "\t\t\tSpecialToEquipment(FindBonusByCustomTag('InvadersHull1'),ShipEqInSlot(funct_dwd0,t_Hull));",
                        "\t\t\tChameleon(funct_dwd0);",
                        "\t\t\tShipAddCustomShipInfo(funct_dwd0,'AMod_Invaders0','NoShow',difCoef*100);",
                        "\t\t\tSetName(funct_dwd0,'<color=255,130,0>Рондар -'+arksNumb+'-</color>');",
                        "\t\t\tfor(funct_j=0;funct_j<1;funct_j=funct_j+1)",
                        "\t\t\t{",
                        "\t\t\t\tfunct_dwd1=CreateCustomWeapon('pulse_gun',0,GalaxyTechLevel(),5);",
                        "\t\t\t\tEqCustomFaction(funct_dwd1,'AMod_Invaders');",
                        "\t\t\t\tif(difCoef>=3)ItemImprovement(funct_dwd1,2,1);",
                        "\t\t\t\tSetEquipmentStats(funct_dwd1,Rnd(300,400),2);",
                        "\t\t\t\tAddItemToShip(funct_dwd0,funct_dwd1);",
                        "\t\t\t\tItemIsInUse(funct_dwd1,funct_dwd0,funct_j+1);",
                        "\t\t\t\tNoDropItem(funct_dwd1,1);",
                        "\t\t\t}",
                        "\t\t\tfor(funct_j=0;funct_j<1;funct_j=funct_j+1)",
                        "\t\t\t{",
                        "\t\t\t\tfunct_dwd1=CreateCustomWeapon('Dom_dual_laser',0,GalaxyTechLevel(),5);",
                        "\t\t\t\tEqCustomFaction(funct_dwd1,'AMod_Invaders');",
                        "\t\t\t\tif(difCoef>=3)ItemImprovement(funct_dwd1,2,1);",
                        "\t\t\t\tSetEquipmentStats(funct_dwd1,Rnd(300,400),2);",
                        "\t\t\t\tAddItemToShip(funct_dwd0,funct_dwd1);",
                        "\t\t\t\tItemIsInUse(funct_dwd1,funct_dwd0,funct_j+1);",
                        "\t\t\t\tNoDropItem(funct_dwd1,1);",
                        "\t\t\t}",
                        "\t\t\tfor(funct_j=0;funct_j<1;funct_j=funct_j+1)",
                        "\t\t\t{",
                        "\t\t\t\tfunct_dwd1=CreateCustomWeapon('FusionQuasar',0,GalaxyTechLevel(),5);",
                        "\t\t\t\tEqCustomFaction(funct_dwd1,'AMod_Invaders');",
                        "\t\t\t\tif(difCoef>=3)ItemImprovement(funct_dwd1,2,1);",
                        "\t\t\t\tSetEquipmentStats(funct_dwd1,Rnd(300,400),2);",
                        "\t\t\t\tAddItemToShip(funct_dwd0,funct_dwd1);",
                        "\t\t\t\tItemIsInUse(funct_dwd1,funct_dwd0,funct_j+1);",
                        "\t\t\t\tNoDropItem(funct_dwd1,1);",
                        "\t\t\t}",
                        "\t\t\tfor(funct_j=0;funct_j<1;funct_j=funct_j+1)",
                        "\t\t\t{",
                        "\t\t\t\tfunct_dwd1=CreateCustomWeapon('Dom_laser',0,GalaxyTechLevel(),5);",
                        "\t\t\t\tEqCustomFaction(funct_dwd1,'AMod_Invaders');",
                        "\t\t\t\tif(difCoef>=3)ItemImprovement(funct_dwd1,2,1);",
                        "\t\t\t\tSetEquipmentStats(funct_dwd1,Rnd(300,400),2);",
                        "\t\t\t\tAddItemToShip(funct_dwd0,funct_dwd1);",
                        "\t\t\t\tItemIsInUse(funct_dwd1,funct_dwd0,funct_j+1);",
                        "\t\t\t\tNoDropItem(funct_dwd1,1);",
                        "\t\t\t}",
                        "\t\t\tfor(funct_j=0;funct_j<1;funct_j=funct_j+1)",
                        "\t\t\t{",
