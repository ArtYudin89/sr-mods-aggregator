            "Items": [],
            "Operations": [
                {
                    "Name": "",
                    "Code.Type": "Global",
                    "Code": [
                        "GRun();"
                    ],
                    "#": 35,
                    "Type": "Top",
                    "Parent": -1,
                    "Pos.x": 0,
                    "Pos.y": 610
                },
                {
                    "Name": "",
                    "Code.Type": "Turn",
                    "Code": [
                        "if(findsubstr(GameDateTxtByTurn(CurTurn()),'1 ' + CT('Month.01'))==0)",
                        "{",
                        "    count1=0;",
                        "    count2=0;",
                        "    count3=0;",
                        "}",
                        "if(ShipFindCustomShipInfoByType(Player(),'BoosterS')>-1 && SA == 0) {",
                        "  SA=1;",
                        "  SAT=4;",
                        "}",
                        "if(ShipFindCustomShipInfoByType(Player(),'BoosterF')>-1 && FA == 0) {",
                        "  FA=1;",
                        "  FAT=4;",
                        "}",
                        "if(ShipFindCustomShipInfoByType(Player(),'BoosterD')>-1 && DA == 0) {",
                        "  DA=1;",
                        "  DAT=4;",
                        "}",
                        "if(ShipFindCustomShipInfoByType(Player(),'BoosterR')>-1 && RA == 0) {",
                        "  RA=1;",
                        "  RAT=4;",
                        "}",
                        "if(CurTurn()+SAT != CurTurn() && SA==1) {",
                        "  SAT=SAT-1;",
                        "}",
                        "if(CurTurn()+FAT != CurTurn() && FA==1) {",
                        "  FAT=FAT-1;",
                        "}",
                        "if(CurTurn()+DAT != CurTurn() && DA==1) {",
                        "  DAT=DAT-1;",
                        "}",
                        "if(CurTurn()+RAT != CurTurn() && RA==1) {",
                        "  RAT=RAT-1;",
                        "}",
                        "if(CurTurn()+SAT == CurTurn() && SA==1) {",
                        "  SA=0;",
                        "  ShipDeleteCustomShipInfo(Player(),'BoosterS');",
                        "  Ether(0,'',CT(\"Script.Mod_GTLBHGadgets.65\"));",
                        "}",
                        "if(CurTurn()+FAT == CurTurn() && FA==1) {",
                        "  FA=0;",
                        "  ShipDeleteCustomShipInfo(Player(),'BoosterF');",
                        "  Ether(0,'',CT(\"Script.Mod_GTLBHGadgets.64\"));",
                        "}",
                        "if(CurTurn()+DAT == CurTurn() && DA==1) {",
                        "  DA=0;",
                        "  ShipDeleteCustomShipInfo(Player(),'BoosterD');",
                        "  Ether(0,'',CT(\"Script.Mod_GTLBHGadgets.63\"));",
                        "}",
                        "if(CurTurn()+RAT == CurTurn() && RA==1) {",
                        "  RA=0;",
                        "  ShipDeleteCustomShipInfo(Player(),'BoosterR');",
                        "  Ether(0,'',CT(\"Script.Mod_GTLBHGadgets.62\"));",
                        "}"
                    ],
                    "#": 36,
                    "Type": "Top",
                    "Parent": -1,
                    "Pos.x": 120,
                    "Pos.y": 610
                },
                {
                    "Name": "",
                    "Code.Type": "DialogBegin",
                    "Code": [
                        "if(GetShipRuins(Player())>0) {",
                        "  if(ShipType(GetShipRuins(Player()))=='SB') {",
                        "    //Тут условине нужно для определения разновидности универса.",
                        "    //Поскольку в будущем датник в ланге Mod_ExpScienceRanks",
                        "    // может менятся и там может затерется 388, то введено второе",
                        "    //Которое будет введо в случае этиъ изменений",
                        "    if ( ((CT('Script.Mod_ExpScienceRanks.388')) != '') || ((CT('Script.Mod_ExpScienceRanks.ThisIsUniverseOriginal')) != '') )",
                        "    {",
                        "        science_rank = GetValueFromScript('Mod_ExpScienceRanks','cur_science_rank');",
                        "    }",
                        "    else ",
                        "    {",
                        "        science_rank = PlayerScienceRank['CurrentRank'];",
                        "    }",
                        "    if (science_rank>2) AddDialogInject('BHGadgets',CT(\"Script.Mod_GTLBHGadgets.48\"),CT(\"Script.Mod_GTLBHGadgets.61\"),1);",
                        "  }",
                        "}"
                    ],
                    "#": 37,
                    "Type": "Top",
                    "Parent": -1,
                    "Pos.x": 180,
                    "Pos.y": 610
                },
                {
                    "Name": "",
                    "Code.Type": "Turn",
                    "Code": [
                        "if (science_rank == 0){total1=0; total2=0; total3=0; total4=0;}",
                        "else if (science_rank == 1) {total1=0; total2=0; total3=0; total4=0;}",
                        "else if (science_rank == 2) {total1=1; total2=0; total3=0; total4=0;}",
                        "else if (science_rank == 3) {total1=2; total2=1; total3=0; total4=0;}",
                        "else if (science_rank == 4) {total1=3; total2=2; total3=1; total4=1;}",
                        "else if (science_rank == 5) {total1=3; total2=3; total3=2; total4=2;}",
                        "else if (science_rank == 6) {total1=3; total2=3; total3=3; total4=3;}",
                        "else if (science_rank == 7) {total1=3; total2=3; total3=3; total4=3;}",
                        "else if (science_rank == 8) {total1=3; total2=3; total3=3; total4=3;}",
                        "cost1=5000*GalaxyTechLevel();",
                        "cost11=400;",
                        "cost2=10000*GalaxyTechLevel();",
                        "cost22=800;",
                        "cost3=15000*GalaxyTechLevel();",
                        "cost33=600;",
                        "cost4=10000*GalaxyTechLevel();",
                        "cost44=600;",
                        "Nodes=RangerBaseNodes(Player());",
                        "cur_count1=total1-count1;",
                        "cur_count2=total2-count2;",
                        "cur_count3=total3-count3;",
                        "cur_count4=total4-count4;",
                        "DChange(0);",
                        "exit;"
                    ],
                    "#": 50,
                    "Type": "Top",
                    "Parent": -1,
                    "Pos.x": -20,
                    "Pos.y": 400
                },
                {
                    "Name": "",
                    "Code.Type": "Turn",
                    "Code": [
                        "if(cur_count1==0)AddDialogBlock(CT(\"Script.Mod_GTLBHGadgets.52\"),1);",
                        "if(cur_count2==0)AddDialogBlock(CT(\"Script.Mod_GTLBHGadgets.51\"),1);",
                        "if(cur_count3==0)AddDialogBlock(CT(\"Script.Mod_GTLBHGadgets.53\"),1);",
                        "if(cur_count4==0)AddDialogBlock(CT(\"Script.Mod_GTLBHGadgets.60\"),1);",
                        "DAdd(3);",
                        "DAdd(4);",
                        "DAdd(5);",
                        "DAdd(6);",
                        "DAdd(0);"
                    ],
                    "#": 51,
                    "Type": "Top",
                    "Parent": -1,
                    "Pos.x": -20,
                    "Pos.y": 470
                },
                {
                    "Name": "",
                    "Code.Type": "Turn",
                    "Code": [
                        "DAdd(2);"
                    ],
                    "#": 52,
                    "Type": "Top",
                    "Parent": -1,
                    "Pos.x": 130,
                    "Pos.y": 470
                },
                {
                    "Name": "",
                    "Code.Type": "Turn",
                    "Code": [
                        "DAdd(1);"
                    ],
                    "#": 53,
                    "Type": "Top",
                    "Parent": -1,
                    "Pos.x": 280,
                    "Pos.y": 470
                },
                {
                    "Name": "",
                    "Code.Type": "Turn",
                    "Code": [
                        "cost1=5000*GalaxyTechLevel();",
                        "cost11=400;",
                        "cost2=10000*GalaxyTechLevel();",
                        "cost22=800;",
                        "cost3=15000*GalaxyTechLevel();",
                        "cost33=600;",
                        "cost4=10000*GalaxyTechLevel();",
                        "cost44=600;",
                        "Nodes=RangerBaseNodes(Player());",
                        "cur_count1=total1-count1;",
                        "cur_count2=total2-count2;",
                        "cur_count3=total3-count3;",
                        "cur_count4=total4-count4;",
                        "DChange(0);",
                        "exit;"
                    ],
                    "#": 54,
                    "Type": "Top",
                    "Parent": -1,
                    "Pos.x": 100,
                    "Pos.y": 540
                },
                {
                    "Name": "",
                    "Code.Type": "Turn",
                    "Code": [
                        "cur_p=1;",
                        "if(cost1<=ShipMoney(Player()) && cost11<=RangerBaseNodes(Player())) {",
                        "  if (cur_p==1)",
                        "  {",
                        "      AddItemToShip(Player(),CreateQuestItem('BoosterS'));",
                        "      ShipMoney(Player(),ShipMoney(Player())-cost1);",
                        "      RangerBaseNodes(Player(),RangerBaseNodes(Player())-cost11);",
                        "      count1=count1+1;",
                        "  }",
                        "  else if (cur_p==2)",
                        "  {",
                        "      AddItemToShip(Player(),CreateQuestItem('BoosterF'));",
                        "      ShipMoney(Player(),ShipMoney(Player())-cost2);",
                        "      RangerBaseNodes(Player(),RangerBaseNodes(Player())-cost22);",
                        "      count2=count2+1;",
                        "  }",
                        "  else if (cur_p==3)",
                        "  {",
                        "      AddItemToShip(Player(),CreateQuestItem('BoosterD'));",
                        "      ShipMoney(Player(),ShipMoney(Player())-cost3);",
                        "      RangerBaseNodes(Player(),RangerBaseNodes(Player())-cost33);",
                        "      count3=count3+1;",
                        "  }",
                        "  else if (cur_p==4)",
                        "  {",
                        "      AddItemToShip(Player(),CreateQuestItem('BoosterR'));",
                        "      ShipMoney(Player(),ShipMoney(Player())-cost4);",
                        "      RangerBaseNodes(Player(),RangerBaseNodes(Player())-cost44);",
                        "      count4=count4+1;",
                        "  }",
                        "  Sound('Sound.Buy');",
                        "  DChange(2);",
                        "  exit;",
                        "}",
                        "if(cost1>ShipMoney(Player()) || cost11>RangerBaseNodes(Player())) {",
                        "  DChange(1);",
                        "  exit;",
                        "}"
                    ],
                    "#": 55,
                    "Type": "Top",
                    "Parent": -1,
                    "Pos.x": 340,
                    "Pos.y": 540
