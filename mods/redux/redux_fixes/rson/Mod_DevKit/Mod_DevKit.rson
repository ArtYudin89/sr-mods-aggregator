                {
                    "Name": "",
                    "Code.Type": "Turn",
                    "Code": [
                        "cur_item = CreateEquipment(t_RepairRobot, 20, 8, 2);",
                        "LinkItemToScript(cur_item);",
                        "ItemOnActCode(cur_item, GenerateCodeStringFromBlock('ActCodeBlocksList.HybridDroidActCode'));",
                        "ScriptItemData(cur_item, 1, 300);",
