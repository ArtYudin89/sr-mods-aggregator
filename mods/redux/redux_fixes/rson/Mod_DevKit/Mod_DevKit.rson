                    "#": 913,
                    "Type": "Top",
                    "Parent": -1,
                    "Pos.x": 1540,
                    "Pos.y": 1215
                },
                {
                    "Name": "",
                    "Code.Type": "Turn",
                    "Code": [
                        "tint2 = CountBox('Bm.Items.2FuelTanks14s',CT(\"Script.Mod_DevKit.596\"),1,5000);",
                        "",
                        "if(!CurrentMods('Evolution\\\\EvoMC')) {",
                        "    for(i=13;i<25;i=i+1) {",
                        "        ShipHealthFactor(Player(),i,tint2);",
                        "    }",
                        "}",
                        "else {",
                        "    for(i=13;i<25;i=i+1) {",
                        "        ShipHealthFactor(Player(),i,tint2);",
                        "    }",
                        "    unknown stims_array = newarray(1);",
                        "    int tint1;",
                        "    ArrayClear(stims_array);",
                        "    ArrayDelete(stims_array,0);",
                        "    CT('Illness.Stimulant', stims_array);",
                        "        for(i = ArrayDim(stims_array) - 1; i >= 0; i = i - 1)",
                        "        {",
                        "            //Удаляем из составленного массива все лишние элементы",
                        "            if(GetVariableType(stims_array[i]) != 9)",
                        "            {",
                        "                ArrayDelete(stims_array, i);",
                        "                continue;",
                        "            }",
                        "            if(tstr1 == '') continue;",
                        "        }",
                        "",
                        "    for(tint1=0;ArrayDim(stims_array)>tint1;tint1=tint1+1) {",
                        "        //Вешаем ванильный стимулятор",
                        "        if(!findsubstr(stims_array[tint1, 'Designation'], 'Original')) {",
                        "            ShipHealthFactor(Player(), 0 + stims_array[tint1, 'Designation'], tint2);",
                        "        }",
                        "        //Вешаем стимулятор из модов",
                        "        else",
                        "        {",
                        "            str bons_str = '';",
                        "            for(i = 0; i < ArrayDim(stims_array[tint1]); i = i + 1)",
                        "            {",
                        "                if(GetVariableName(stims_array[tint1, i]) == 'AddBonuses')",
                        "                {",
                        "                    for(j = ArrayDim(stims_array[tint1, 'AddBonuses']) - 1; j >= 0; j = j - 1)",
                        "                    {",
                        "                        str bon_str = GetVariableName(stims_array[tint1, 'AddBonuses', j]);",
                        "                        bons_str = bons_str + bon_str + '=' + stims_array[tint1, 'AddBonuses', j];",
                        "                        if(j) bons_str = bons_str + ',';",
                        "",
                        "                        int bon = GetValueFromScript('', bon_str);",
                        "                        ShipSpecialBonuses(Player(), bon, ShipSpecialBonuses(Player(), bon) + stims_array[tint1, 'AddBonuses', j]);",
                        "                    }",
                        "",
                        "                    break;",
                        "                }",
                        "            }",
                        "",
                        "            if(stims_array[tint1, 'Designation'] == 'ExpImplants_Meldonit') GlobalImplantsEnduranceBonus = GlobalImplantsEnduranceBonus + 10;",
                        "            ShipAddCustomShipInfo(Player(), stims_array[tint1, 'Designation'], stims_array[tint1, 'Text'], CurTurn() + tint2, 0, 0, bons_str);",
                        "        }",
                        "    }",
                        "}",
                        "Sound('Sound.Buy');",
                        "DChange(0);",
                        "exit;"
                    ],
