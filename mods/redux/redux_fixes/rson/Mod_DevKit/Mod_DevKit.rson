                    "#": 61,
                    "Type": "Top",
                    "Parent": -1,
                    "Pos.x": 60,
                    "Pos.y": 1435
                },
                {
                    "Name": "",
                    "Code.Type": "Turn",
                    "Code": [
                        "if(ColorFlag) {",
                        "    int red=Rnd(0,255);",
                        "    int green=Rnd(0,255);",
                        "    int blue=Rnd(0,255);",
                        "    SetName(Player(),DeleteTags('<color=,,>'+ShortName(Player())+'</color>'));",
                        "    SetName(Player(),'<color='+red+','+green+','+blue+'>'+ShortName(Player())+'</color>');",
                        "}",
                        "if(ChameleonFlag) {",
                        "    int cmfl=Rnd(0,104);",
                        "    ////Шкурки кораблей",
                        "    ///Акриновые",
                        "    if (cmfl==0) Chameleon(Player(),'Ship.Akrin.1');",
                        "    if (cmfl==1) Chameleon(Player(),'Ship.Akrin.2');",
                        "    if (cmfl==2) Chameleon(Player(),'Ship.Akrin.3');",
                        "    if (cmfl==3) Chameleon(Player(),'Ship.Akrin.A');",
                        "    if (cmfl==4) Chameleon(Player(),'Ship.Akrin.B');",
                        "    if (cmfl==5) Chameleon(Player(),'Ship.Akrin.C');",
                        "    if (cmfl==6) Chameleon(Player(),'Ship.Akrin.D');",
                        "    if (cmfl==7) Chameleon(Player(),'Ship.Akrin.E');",
                        "    if (cmfl==8) Chameleon(Player(),'Ship.Akrin.F');",
                        "    if (cmfl==9) Chameleon(Player(),'Ship.Akrin.G');",
                        "    if (cmfl==10) Chameleon(Player(),'Ship.Akrin.H');",
                        "    if (cmfl==11) Chameleon(Player(),'Ship.Akrin.I');",
                        "    if (cmfl==12) Chameleon(Player(),'Ship.Akrin.J');",
                        "    if (cmfl==13) Chameleon(Player(),'Ship.Akrin.K');",
                        "    if (cmfl==14) Chameleon(Player(),'Ship.Akrin.L');",
                        "    //Шкурка корпуса спецагенток",
                        "    if (cmfl==15) Chameleon(Player(),'Ship.AkrinFemale.J');",
                        "    ///Доминаторские",
                        "    //Блазер",
                        "    if (cmfl==16) Chameleon(Player(),'Ship.Blazer.B1');",
                        "    if (cmfl==17) Chameleon(Player(),'Ship.Blazer.B2');",
                        "    if (cmfl==18) Chameleon(Player(),'Ship.Blazer.B3');",
                        "    if (cmfl==19) Chameleon(Player(),'Ship.Blazer.B4');",
                        "    if (cmfl==20) Chameleon(Player(),'Ship.Blazer.B5');",
                        "    if (cmfl==21) Chameleon(Player(),'Ship.Blazer.B6');",
                        "    if (cmfl==22) Chameleon(Player(),'Ship.Blazer.B7');",
