                {
                    "Name": "",
                    "Code.Type": "Turn",
                    "Code": [
                        "tint = NumberBox('Bm.Items.2FuelTanks14s',CT(\"Script.Mod_DevKit.304\"),0,100);",
                        "if(ShipStatus(Player(),2) < tint) {",
                        "    if(ShipStatus(Player(),0) >= tint) ShipStatus(Player(),0,ShipStatus(Player(),0) + ShipStatus(Player(),1) - tint);",
                        "    else {",
                        "        tint3 = tint;",
                        "        tint3 = tint3 - ShipStatus(Player(),0);",
                        "        ShipStatus(Player(),0,0);",
                        "        if(ShipStatus(Player(),1) <= tint3) {",
                        "            ShipStatus(Player(),1,0);",
                        "        }",
                        "        else ShipStatus(Player(),1,ShipStatus(Player(),1)-tint3);",
                        "    }",
                        "}",
                        "else if(ShipStatus(Player(),2) > tint) {",
                        "    ShipStatus(Player(),1,ShipStatus(Player(),1)+ShipStatus(Player(),2) - tint);",
                        "}",
                        "ShipStatus(Player(),2,tint);",
                        "Sound('Sound.Buy');",
                        "DChange(0);",
                        "exit;"
                    ],
