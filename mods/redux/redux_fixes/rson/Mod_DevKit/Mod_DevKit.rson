                        "for(i = 0; i < BonusCount(); i = i + 1)",
                        "{",
                        "    str bon_section_name = BonusNumInCfg(i);",
                        "    if(BonusIsSpecial(i))",
                        "    {",
                        "        if(!int(CT('MicroModuls.' + bon_section_name + '.UniqueMM'))) continue;",
                        "    }",
                        "    if(CT('MicroModuls.' + bon_section_name + '.Name') == '') continue;",
                        "",
                        "    if(MMFlag) {",
                        "        if(CT('MicroModuls.' + bon_section_name + '.Priority') < 70 && MMFlag == 3) continue;",
                        "        if(CT('MicroModuls.' + bon_section_name + '.Priority') < 31 && CT('MicroModuls.' + bon_section_name + '.Priority') > 69 && MMFlag == 2) continue;",
                        "        if(CT('MicroModuls.' + bon_section_name + '.Priority') > 30 && MMFlag == 1) continue;",
                        "    }",
                        "",
                        "    AddItemToShip(Player(), CreateMM(i));",
                        "}",
                        "Sound('Sound.Buy');",
                        "",
                        "MMFlag = 0;",
                        "DChange(0);",
                        "exit;"
