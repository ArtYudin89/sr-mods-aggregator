                        "if(ShipEqInSlot(Player(),t_Artefact,4) != 0) ItemSize(ShipEqInSlot(Player(),t_Artefact,4),temp_size);",
                        "if(ShipEqInSlot(Player(),t_Artefact,3) != 0) ItemSize(ShipEqInSlot(Player(),t_Artefact,3),temp_size);",
