                        "    if (cmfl==77) Chameleon(Player(),'Ship.Gaal.WarriorBig');",
                        "    ///Прочие шкурки кораблей",
                        "    //??",
                        "    if (cmfl==78) Chameleon(Player(),'Ship.HS.0');",
                        "    if (cmfl==79) Chameleon(Player(),'Ship.HS.1');",
