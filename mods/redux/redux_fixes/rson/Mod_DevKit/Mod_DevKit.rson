                    "Parent": -1,
                    "Pos.x": 340,
                    "Pos.y": 865
                },
                {
                    "Name": "",
                    "Code.Type": "Turn",
                    "Code": [
                        "tint3 = NumberBox('Bm.Items.2FuelTanks14s',CT(\"Script.Mod_DevKit.246\"),0,7,7,'',3,CT(\"Script.Mod_DevKit.364\"),CT(\"Script.Mod_DevKit.363\"),CT(\"Script.Mod_DevKit.362\"),CT(\"Script.Mod_DevKit.361\"),CT(\"Script.Mod_DevKit.360\"),CT(\"Script.Mod_DevKit.466\"),CT(\"Script.Mod_DevKit.465\"),CT(\"Script.Mod_DevKit.359\"));",
                        "tstr=CT('Artefacts.CustomArtefacts.Booster.Size');",
                        "tint=tstr;",
                        "tint=tint+Rnd(-4,4);",
                        "tdwd=CreateCustomArt('Booster',tint,1000,tint3);",
                        "AddItemToShip(Player(),tdwd);",
                        "tstr=CT('Artefacts.CustomArtefacts.Hasker_PROx64.Size');",
                        "tint=tstr;",
                        "tint=tint+Rnd(-4,4);",
                        "tdwd=CreateCustomArt('Hasker_PROx64',tint,1000,tint3);",
                        "AddItemToShip(Player(),tdwd);",
                        "tstr=CT('Artefacts.CustomArtefacts.Reflector.Size');",
                        "tint=tstr;",
                        "tint=tint+Rnd(-4,4);",
                        "tdwd=CreateCustomArt('Reflector',tint,1000,tint3);",
                        "AddItemToShip(Player(),tdwd);",
                        "tstr=CT('Artefacts.CustomArtefacts.Techdisruptor.Size');",
                        "tint=tstr;",
                        "tint=tint+Rnd(-4,4);",
                        "tdwd=CreateCustomArt('Techdisruptor',tint,1000,tint3);",
                        "AddItemToShip(Player(),tdwd);",
                        "tstr=CT('Artefacts.CustomArtefacts.Implosior.Size');",
                        "tint=tstr;",
                        "tint=tint+Rnd(-4,4);",
                        "tdwd=CreateCustomArt('Implosior',tint,1000,tint3);",
                        "AddItemToShip(Player(),tdwd);",
                        "tdwd=CreateQuestItem('ExpArts_BombsContainer');",
                        "AddItemToShip(Player(),tdwd);",
                        "UselessItemData(tdwd,1,Rnd(1,100));",
                        "UselessItemData(tdwd,2,Rnd(1,100));",
                        "tdwd=CreateQuestItem('ExpArts_ModsContainer');",
                        "AddItemToShip(Player(),tdwd);",
                        "UselessItemData(tdwd,1,Rnd(1,14));",
                        "",
                        "for(i=1;i<6;i=i+1) {",
                        "    if(i==1) tstr2 = 'BombDetonator';",
                        "    if(i==2) tstr2 = 'EMP_bomb';",
                        "    if(i==3) tstr2 = 'Hyperlink';",
                        "    if(i==4) tstr2 = 'Null-generator';",
                        "    if(i==5) tstr2 = 'Stun_bomb';",
                        "    if(i==6) {",
                        "        for(k=0;k<14;k=k+1) {",
                        "            tstr2 = 'RNDmoditem_'+k;",
                        "            tdwd=CreateQuestItem(tstr2,7);",
                        "            AddItemToShip(Player(),tdwd);",
                        "            tstr=CT('UselessItems.'+tstr2+'.Size');",
                        "            tint=tstr;",
                        "            tint=tint+Rnd(-4,4);",
                        "            tdwd=CreateQuestItem(tstr2);",
                        "            ItemSize(tdwd,tint);",
                        "            ItemCost(tdwd,ItemCost(tdwd)+(ItemCost(tdwd)*Rnd(10,20))/100);",
                        "            AddItemToShip(Player(),tdwd);",
                        "        }",
                        "    }",
                        "    if(i!=6) {",
                        "        tdwd=CreateQuestItem(tstr2,7);",
                        "        AddItemToShip(Player(),tdwd);",
                        "        tstr=CT('UselessItems.'+tstr2+'.Size');",
                        "        tint=tstr;",
                        "        tint=tint+Rnd(-4,4);",
                        "        tdwd=CreateQuestItem(tstr2);",
                        "        ItemSize(tdwd,tint);",
                        "        ItemCost(tdwd,ItemCost(tdwd)+(ItemCost(tdwd)*Rnd(10,20))/100);",
                        "        AddItemToShip(Player(),tdwd);",
                        "    }",
                        "}",
                        "Sound('Sound.Buy');",
                        "DChange(0);",
                        "exit;"
                    ],
                    "#": 702,
                    "Type": "Top",
                    "Parent": -1,
                    "Pos.x": 580,
                    "Pos.y": 865
                },
                {
                    "Name": "",
                    "Code.Type": "Turn",
                    "Code": [
                        "//Старый вариант",
                        "//if(PlayerBridge()) PlayerBridge(0);",
                        "//TransferShip(Player(), GAnswerData);",
                        "//PlayerBridge(2);",
                        "//PlayerBridge(0);",
                        "//ShipChangeStar(Player(), GAnswerData);",
                        "",
                        "//for(temp_int = 0; temp_int < GalaxySectors(); temp_int = temp_int + 1)",
                        "//{",
                        "//    if(!SectorVisible(GalaxySectors(temp_int))) SectorVisible(GalaxySectors(temp_int), 1);",
                        "//}  Потому что это некруто и раздражает! Если я захочу, то сам открою всю карту, делов - на пару кликов",
                        "RunChildForm('Galaxy');",
                        "if(ShipOrder(Player()) == 7)",
                        "{",
                        "    tdwd = ShipOrderObj(Player());",
                        "    OrderNone(Player());",
                        "    if(PlayerBridge()) PlayerBridge(0);",
                        "    TransferShip(Player(), tdwd);",
                        "    PlayerBridge(2);",
                        "    PlayerBridge(0);",
                        "    ShipChangeStar(Player(), tdwd);",
                        "}",
                        "DChange(10);",
                        "exit;"
                    ],
                    "#": 703,
                    "Type": "Top",
                    "Parent": -1,
                    "Pos.x": 700,
                    "Pos.y": 865
                },
                {
                    "Name": "",
                    "Code.Type": "Turn",
                    "Code": [
                        "if(ShipOnSidePirateClan(Player())) ShipOwner(Player(),ShipPilotRace(Player()));",
                        "",
                        "for(i=0;i<GalaxyStars();i=i+1)",
                        "    {",
                        "    temp_dword=GalaxyStar(i);",
                        "    if(StarOwner(temp_dword)!=2)continue;",
                        "    if(StarRuins(temp_dword,'CB')>0)",
                        "        {",
                        "        temp_dword2=StarRuins(temp_dword,'CB');",
                        "        ShipDestroy(temp_dword2,1);",
                        "        }",
                        "    for(j=0;j<StarPlanets(temp_dword);j=j+1)",
                        "        {",
                        "        temp_dword2=StarPlanets(temp_dword,j);",
                        "        if(PlanetOwner(temp_dword2)==6)continue;",
                        "        PlanetOwner(temp_dword2,PlanetRace(temp_dword2));",
                        "        BuyWarrior(temp_dword2);",
                        "        }",
                        "    for(j=0;j<StarShips(temp_dword);j=j+1)",
                        "        {",
                        "        temp_dword2=StarShips(temp_dword,j);",
                        "        if(ShipTypeN(temp_dword2)!=t_Pirate)continue;",
                        "        OrderNone(temp_dword2);",
                        "        OrderLock(temp_dword2,1);",
                        "        ShipDestroy(temp_dword2,1);",
                        "        }",
                        "    }",
                        "PirateWin(3);",
                        "Sound('Sound.Buy');",
                        "DChange(0);",
                        "exit;"
                    ],
                    "#": 704,
                    "Type": "Top",
                    "Parent": -1,
                    "Pos.x": 940,
                    "Pos.y": 865
                },
                {
                    "Name": "",
                    "Code.Type": "Turn",
                    "Code": [
                        "tint2 = CountBox('Bm.Items.2FuelTanks14s',CT(\"Script.Mod_DevKit.324\"),1,8);",
                        "temp_size=CountBox('Bm.Items.2FuelTanks14s',CT(\"Script.Mod_DevKit.312\"),5,500);",
                        "tint = NumberBox('Bm.Items.2FuelTanks14s',CT(\"Script.Mod_DevKit.365\"),0,6,6,'',3,CT(\"Script.Mod_DevKit.364\"),CT(\"Script.Mod_DevKit.363\"),CT(\"Script.Mod_DevKit.362\"),CT(\"Script.Mod_DevKit.361\"),CT(\"Script.Mod_DevKit.360\"),CT(\"Script.Mod_DevKit.359\"),CT(\"Script.Mod_DevKit.358\"));",
                        "if(tint > -1) {",
                        "    if(tint == 0 || tint == 6) {",
                        "        for(i=0;i<7;i=i+1){",
                        "            temp_dword = RunFunctionFromScript('Mod_ExpAcryn','AddTrionAcryn',Maloc,7,t_FuelTanks+i);",
                        "            AddItemToShip(Player(),temp_dword);",
                        "        }",
                        "    }",
                        "    if(tint == 1 || tint == 6) {",
                        "        for(i=0;i<7;i=i+1){",
                        "            temp_dword = RunFunctionFromScript('Mod_ExpAcryn','AddTrionAcryn',Peleng,7,t_FuelTanks+i);",
                        "            AddItemToShip(Player(),temp_dword);",
                        "        }",
                        "    }",
                        "    if(tint == 2 || tint == 6) {",
                        "        for(i=0;i<7;i=i+1){",
                        "            temp_dword = RunFunctionFromScript('Mod_ExpAcryn','AddTrionAcryn',People,7,t_FuelTanks+i);",
                        "            AddItemToShip(Player(),temp_dword);",
                        "        }",
                        "    }",
                        "    if(tint == 3 || tint == 6) {",
                        "        for(i=0;i<7;i=i+1){",
                        "            temp_dword = RunFunctionFromScript('Mod_ExpAcryn','AddTrionAcryn',Fei,7,t_FuelTanks+i);",
                        "            AddItemToShip(Player(),temp_dword);",
                        "        }",
                        "    }",
                        "    if(tint == 4 || tint == 6) {",
                        "        for(i=0;i<7;i=i+1){",
                        "            temp_dword = RunFunctionFromScript('Mod_ExpAcryn','AddTrionAcryn',Gaal,7,t_FuelTanks+i);",
                        "            AddItemToShip(Player(),temp_dword);",
                        "        }",
                        "    }",
                        "    if(tint == 5 || tint == 6) {",
                        "        for(i=0;i<7;i=i+1){",
                        "            temp_dword = RunFunctionFromScript('Mod_ExpAcryn','AddTrionAcryn',PirateClan,7,t_FuelTanks+i);",
                        "            AddItemToShip(Player(),temp_dword);",
                        "        }",
                        "    }",
                        "}",
                        "Sound('Sound.Buy');",
                        "DChange(0);",
                        "exit;"
