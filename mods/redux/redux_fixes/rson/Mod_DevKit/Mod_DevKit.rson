                {
                    "Name": "",
                    "Code.Type": "Turn",
                    "Code": [
                        "vMaloc = 1;",
                        "",
                        "for(i=0;GalaxyStars()>i;i=i+1) {",
                        "    tdwd = GalaxyStar(i);",
                        "    for(j=0;StarShips(tdwd)>j;j=j+1) {",
                        "        ship = StarShips(tdwd,j);",
                        "        if(ShipPilotRace(ship) != Maloc) continue;",
                        "",
                        "        OrderLock(ship,1);",
                        "        ShipDestroy(ship);",
                        "    }",
                        "",
                        "    for(j=0;StarPlanets(tdwd)>j;j=j+1) {",
                        "        ship = StarPlanets(tdwd,j);",
                        "        if(PlanetRace(ship) != Maloc) continue;",
                        "",
                        "        PlanetRace(ship,ShipPilotRace(Player()));",
                        "        if(PlanetOwner(ship) == Maloc) PlanetOwner(ship,ShipPilotRace(Player()));",
                        "    }",
                        "}",
                        "DChange(0);",
                        "exit;"
                    ],
