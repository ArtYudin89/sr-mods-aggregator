                    "#": 983,
                    "Type": "Top",
                    "Parent": -1,
                    "Pos.x": 1060,
                    "Pos.y": 1340
                },
                {
                    "Name": "",
                    "Code.Type": "Turn",
                    "Code": [
                        "//Накладываем на корпус серию \"Идеал\"",
                        "HullSeries(ShipItems(Player(),0),FindSeriesByName(CT('HullType.99.Name')));",
                        "",
                        "//Выдаём чит-двигатель",
                        "tdwd2=CreateEquipment(t_Engine,0,8,Gaal);",
                        "ShipSpecialBonuses(Player(),bonJump,ShipSpecialBonuses(Player(),bonJump)+1000);",
                        "ItemCost(tdwd2,(ItemCost(tdwd2)/2));",
                        "temp_int=GetEquipmentStats(tdwd2,0)*20;",
                        "SetEquipmentStats(tdwd2,temp_int,0);",
                        "SetEquipmentStats(tdwd2,125,1);",
                        "ItemExtraSpecialsAddByType(tdwd2,FindBonusByNameInCfg('ExtraFragility'),400);",
                        "AddItemToShip(Player(),tdwd2);",
                        "ItemIsInUse(tdwd2,Player(),1);",
                        "//Выдаём чит-радар",
                        "tdwd2=CreateEquipment(t_Radar,0,8,Gaal);",
                        "ItemCost(tdwd2,(ItemCost(tdwd2)/2));",
                        "SetEquipmentStats(tdwd2,32000,0);",
                        "ItemExtraSpecialsAddByType(tdwd2,FindBonusByNameInCfg('ExtraFragility'),400);",
                        "AddItemToShip(Player(),tdwd2);",
                        "ItemIsInUse(tdwd2,Player(),1);",
                        "ShipFuel(Player(),50000);",
                        "//Открываем для тестинга карту",
                        "for(temp_int = 0; temp_int < GalaxySectors(); temp_int = temp_int + 1)",
                        "{",
                        "    if(!SectorVisible(GalaxySectors(temp_int))) SectorVisible(GalaxySectors(temp_int), 1);",
                        "}",
                        "ItemSize(ShipItems(Player(), 0), 1200);",
                        "HullHP(Player(), 'To100');",
                        "ShipRepairEq(Player());",
                        "ShipMoney(Player(), ShipMoney(Player()) + 3000000);",
                        "//Выдаём чит-сканер",
                        "tdwd2=CreateEquipment(t_Scaner,1,8,Gaal);",
                        "SetEquipmentStats(tdwd2,125,0);",
                        "ItemExtraSpecialsAddByType(tdwd2,FindBonusByNameInCfg('ExtraFragility'),400);",
                        "AddItemToShip(Player(),tdwd2);",
                        "ItemIsInUse(tdwd2,Player(),1);",
                        "//Выдаём прочую крутую оборудку и чистим старую",
                        "for(i=5;i>0;i=i+1) {",
                        "    if(ShipWeapon(Player(),i)) FreeItem(GetItemFromShip(Player(),FindItemInShip(Player(),ShipWeapon(Player(),i))));",
                        "}",
                        "for(i=1;i<6;i=i+1) {",
                        "    tdwd2=CreateEquipment(t_Weapon14,1,8,Gaal);",
                        "    SetEquipmentStats(tdwd2,GetEquipmentStats(tdwd2,0)+50000,0);",
                        "    SetEquipmentStats(tdwd2,GetEquipmentStats(tdwd2,1)+10000,1);",
                        "    SetEquipmentStats(tdwd2,GetEquipmentStats(tdwd2,2)+1000,2);",
                        "    ItemExtraSpecialsAddByType(tdwd2,FindBonusByNameInCfg('ExtraFragility'),400);",
                        "    AddItemToShip(Player(),tdwd2);",
                        "    ItemIsInUse(tdwd2,Player(),1,i);",
                        "}",
                        "tdwd2=CreateEquipment(t_RepairRobot,1,8,Gaal);",
                        "ItemExtraSpecialsAddByType(tdwd2,FindBonusByNameInCfg('ExtraFragility'),400);",
                        "AddItemToShip(Player(),tdwd2);",
                        "ItemIsInUse(tdwd2,Player(),1);",
                        "SetEquipmentStats(tdwd2,5000,0);",
                        "tdwd2=CreateEquipment(t_DefGenerator,1,8,Gaal);",
                        "ItemExtraSpecialsAddByType(tdwd2,FindBonusByNameInCfg('ExtraFragility'),400);",
                        "AddItemToShip(Player(),tdwd2);",
                        "ItemIsInUse(tdwd2,Player(),1);",
                        "SetEquipmentStats(tdwd2,80,0);",
                        "tdwd2=CreateEquipment(t_CargoHook,1,8,Gaal);",
                        "ItemExtraSpecialsAddByType(tdwd2,FindBonusByNameInCfg('ExtraFragility'),400);",
                        "AddItemToShip(Player(),tdwd2);",
                        "ItemIsInUse(tdwd2,Player(),1);",
                        "SetEquipmentStats(tdwd2,100000,0);",
                        "SetEquipmentStats(tdwd2,10000,1);",
                        "SetEquipmentStats(tdwd2,1000,2);",
                        "SetEquipmentStats(tdwd2,1000,3);",
                        "//Добавляем в трюм читерный исследовательский зонд",
                        "tdwd2 = CreateZond(5, 6, 255, 255, 255);",
                        "ItemSize(tdwd2, 1);",
                        "SetName(tdwd2, 'Overseer');",
                        "AddItemToShip(Player(), tdwd2);",
                        "",
                        "//Добавляем полезные артефакты",
                        "tdwd2 = CreateArt(t_ArtefactScaner, Gaal);",
                        "ItemSize(tdwd2, 1);",
                        "AddItemToShip(Player(), tdwd2);",
                        "tdwd2 = CreateArt(t_ArtefactRadar, Gaal);",
                        "ItemSize(tdwd2, 1);",
                        "AddItemToShip(Player(), tdwd2);",
                        "tdwd2 = CreateArt(t_ArtefactAnalyzer, Gaal);",
                        "ItemSize(tdwd2, 1);",
                        "AddItemToShip(Player(), tdwd2);",
                        "",
                        "Sound('Sound.Buy');"
                    ],
                    "#": 984,
                    "Type": "Top",
                    "Parent": -1,
                    "Pos.x": 1180,
                    "Pos.y": 1340
                },
