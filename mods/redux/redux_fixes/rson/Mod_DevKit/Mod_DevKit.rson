                        "cur_item = CreateHull(6, CT('Script.Mod_ArtiUniqueShipsPack.FriendParamsList.HullSize'), 8, GetValueFromScript('', CT('Script.Mod_ArtiUniqueShipsPack.FriendParamsList.HullRace')), -1, CT('Script.Mod_ArtiUniqueShipsPack.FriendParamsList.PirateClanAssembly'));",
