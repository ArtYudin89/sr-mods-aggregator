                {
                    "Name": "",
                    "Code.Type": "DialogBegin",
                    "Code": [
                        "if((PlayerBridge() ||",
                        "GetShipRuins(Player()) ||",
                        "GetShipPlanet(Player()) ||",
                        "GetTalkShip()) &&",
                        "DevKitVisibility) {",
                        "  if(DevFlag == 1) {",
                        "      AddDialogInject('DevKit', '', CT(\"Script.Mod_DevKit.3\"), 1000);",
                        "      if(GetTalkShip() && KillFlag) {",
                        "          dialogrnd = Rnd(1,5);",
                        "          if(dialogrnd != 5) AddDialogInject('KillThisShit', '', CT(\"Script.Mod_DevKit.325\"), 50);",
                        "          if(dialogrnd == 5) AddDialogInject('KillThisShit', '', CT(\"Script.Mod_DevKit.445\"), 50);",
                        "      }",
                        "  }",
                        "  if(DevFlag == 0) {",
                        "      if(PlayerBridge() == 11) AddDialogInject('DevKit', '', CT(\"Script.Mod_DevKit.3\"), 1000);",
                        "  }",
                        "}"
                    ],
                    "#": 63,
                    "Type": "Top",
                    "Parent": -1,
                    "Pos.x": 180,
                    "Pos.y": 1435
                },
