                },
                {
                    "Name": "",
                    "Code.Type": "Turn",
                    "Code": [
                        "for(i=0;i<1;i=i+1) {",
                        "    tint = NumberBox('Bm.Items.2FuelTanks14s',CT(\"Script.Mod_DevKit.246\"),0,4,5,'',2,CT(\"Script.Mod_DevKit.13\"),CT(\"Script.Mod_DevKit.14\"),CT(\"Script.Mod_DevKit.130\"),CT(\"Script.Mod_DevKit.231\"),CT(\"Script.Mod_DevKit.17\"));",
                        "    dword inhabitedPlanet=CreatePlanet(ShipStar(Player()));",
                        "    tstr = TextBox(CT(\"Script.Mod_DevKit.467\"), '', 1000000);",
                        "    if(tstr == -1) break;",
                        "    SetName(inhabitedPlanet,tstr);",
                        "    PlanetOwner(inhabitedPlanet,NumberBox('Bm.Items.2FuelTanks14s',CT(\"Script.Mod_DevKit.302\"),1,5,5,'',2,CT(\"Script.Mod_DevKit.13\"),CT(\"Script.Mod_DevKit.14\"),CT(\"Script.Mod_DevKit.130\"),CT(\"Script.Mod_DevKit.231\"),CT(\"Script.Mod_DevKit.17\"))-1);",
                        "    PlanetRace(inhabitedPlanet,NumberBox('Bm.Items.2FuelTanks14s',CT(\"Script.Mod_DevKit.301\"),1,5,5,'',2,CT(\"Script.Mod_DevKit.13\"),CT(\"Script.Mod_DevKit.14\"),CT(\"Script.Mod_DevKit.130\"),CT(\"Script.Mod_DevKit.231\"),CT(\"Script.Mod_DevKit.17\"))-1);",
                        "    PlanetGov(inhabitedPlanet,NumberBox('Bm.Items.2FuelTanks14s',CT(\"Script.Mod_DevKit.300\"),1,5,5,'',2,CT(\"Script.Mod_DevKit.299\"),CT(\"Script.Mod_DevKit.298\"),CT(\"Script.Mod_DevKit.297\"),CT(\"Script.Mod_DevKit.296\"),CT(\"Script.Mod_DevKit.295\"))-1);",
                        "    PlanetEco(inhabitedPlanet,NumberBox('Bm.Items.2FuelTanks14s',CT(\"Script.Mod_DevKit.294\"),1,3,3,'',2,CT(\"Script.Mod_DevKit.293\"),CT(\"Script.Mod_DevKit.292\"),CT(\"Script.Mod_DevKit.291\"))-1);",
                        "    PlanetPopulation(inhabitedPlanet,NumberBox('Bm.Items.2FuelTanks14s',CT(\"Script.Mod_DevKit.290\"),1,30000)*1000);",
                        "    PlanetOrbitalVelocity(inhabitedPlanet,NumberBox('Bm.Items.2FuelTanks14s',CT(\"Script.Mod_DevKit.289\"),0,1000));",
                        "    if(PlanetOwner(inhabitedPlanet)<Kling) RelationToRanger(inhabitedPlanet,Player(), GlobalRelationsPlanets(Player(), 0,int(exp(ln(2)*PlanetOwner(inhabitedPlanet)))));",
                        "}",
                        "Sound('Sound.Buy');",
                        "DChange(0);",
                        "exit;"
