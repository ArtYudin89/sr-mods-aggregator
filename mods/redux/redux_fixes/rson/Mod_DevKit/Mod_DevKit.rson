                    "Code": [
                        "temp_size = CountBox('Bm.Items.2FuelTanks14s', CT(\"Script.Mod_DevKit.312\"), 5,1000);",
                        "tint = NumberBox('Bm.ItemsUseless.2Usl_Elus_s',CT(\"Script.Mod_DevKit.311\"),1,8);",
                        "u = CountBox('Bm.Items.2FuelTanks14s',CT(\"Script.Mod_DevKit.313\"),1,20);",
                        "Sound('Sound.Buy');",
                        "for(i=0;i<u;i=i+1) {",
                        "    int cnt = CT('Items.Weapon.CustomWeapon.ShuEmitter.Count');",
                        "    for(i = 1; i <= cnt; i = i + 1)",
                        "    {",
                        "        //По очереди выбираем системное название каждой новой пушки из Lang",
                        "        str type_name = CT('Items.Weapon.CustomWeapon.ShuEmitter.' + i);",
                        "",
                        "        dword item = CreateCustomWeapon(type_name,temp_size,tint,None);",
                        "        AddItemToShip(Player(),item);",
                        "    }",
                        "}",
                        "DChange(0);",
                        "exit;"
                    ],
