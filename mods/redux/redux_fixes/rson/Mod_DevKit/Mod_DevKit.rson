                        "float r = 250;",
                        "float ang = 0;",
                        "for(i=0; i<StarShips(ShipStar(Player())); i=i+1)",
                        "{",
                        "    if(StarShips(ShipStar(Player()),i) == Player()) continue;",
                        "    CoordX(StarShips(ShipStar(Player()),i), r * cos(ang));",
                        "    CoordY(StarShips(ShipStar(Player()),i), r * sin(ang));",
                        "    r = r + dr;",
                        "    ang = ang + dang;",
                        "}",
                        "DChange(0);",
                        "exit;"
