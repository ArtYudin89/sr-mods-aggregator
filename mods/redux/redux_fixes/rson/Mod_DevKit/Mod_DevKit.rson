                    "Pos.y": 1240
                },
                {
                    "Name": "",
                    "Code.Type": "Turn",
                    "Code": [
                        "vPeople = 1;",
                        "",
                        "for(i=0;GalaxyStars()>i;i=i+1) {",
                        "    tdwd = GalaxyStar(i);",
                        "    for(j=0;StarShips(tdwd)>j;j=j+1) {",
                        "        ship = StarShips(tdwd,j);",
                        "        if(ShipPilotRace(ship) != People) continue;",
                        "",
                        "        OrderLock(ship,1);",
                        "        ShipDestroy(ship);",
                        "    }",
                        "",
                        "    for(j=0;StarPlanets(tdwd)>j;j=j+1) {",
                        "        ship = StarPlanets(tdwd,j);",
                        "        if(PlanetRace(ship) != People) continue;",
                        "",
                        "        PlanetRace(ship,ShipPilotRace(Player()));",
                        "        if(PlanetOwner(ship) == People) PlanetOwner(ship,ShipPilotRace(Player()));",
                        "    }",
                        "}",
                        "DChange(0);",
                        "exit;"
                    ],
