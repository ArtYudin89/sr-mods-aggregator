                    "#": 960,
                    "Type": "Top",
                    "Parent": -1,
                    "Pos.x": 100,
                    "Pos.y": 1315
                },
                {
                    "Name": "",
                    "Code.Type": "Turn",
                    "Code": [
                        "temp_race=5;",
                        "tint2 = NumberBox('Bm.ItemsUseless.2Usl_Elus_s',CT(\"Script.Mod_DevKit.311\"),1,8);",
                        "if (temp_int==1){",
                        "    Sound('Sound.Buy');",
                        "    temp_int=FindSeriesByName('Идеал');",
                        "    temp_gift=CreateHull(hull_type,temp_size,tint2,temp_race,temp_int);",
                        "    AddItemToStorage(GetShipRuins(Player())|GetShipPlanet(Player()),temp_gift);",
                        "}",
                        "else {",
                        "    Sound('Sound.Buy');",
                        "    temp_gift=CreateEquipment(type_equip_str,temp_size,tint2,temp_race);",
                        "    AddItemToShip(Player(),temp_gift);",
                        "    if(AcrynFlag) {",
                        "        for(i = 0; i < BonusCount(); i = i + 1)",
                        "        {",
                        "            if(!BonusIsSpecial(i)) continue;",
                        "            str temp_str_2 = BonusNumInCfg(i);",
                        "            //Никто не знает, как, но ЭТА МРАЗЬ СЮДА ПРОБИРАЕТСЯ",
                        "            if(temp_str_2 == 'Ref_RentAcryn') continue;",
                        "            //Исключение для акринов с тэгом \"Запрещено накладывать\" и \"Запрещено снимать и накладывать\"",
                        "            if(int(CT('MicroModuls.' + temp_str_2 + '.LockedAcryn')) == 2) continue;",
                        "            if(int(CT('MicroModuls.' + temp_str_2 + '.LockedAcryn')) == 3) continue;",
                        "",
                        "            //Если предмет не произведён неизвестной расой",
                        "            if(ItemOwner(temp_gift) != None)",
                        "            {",
                        "                if(!MayAddBonusToEq(i, temp_gift))",
                        "                {",
                        "                    //Проверка на соответствие акрина типу данного предмета с учётом замены предмета при акринации",
                        "                    temp_str_3 = CT('MicroModuls.' + temp_str_2 + '.ImitatedEquipType');",
                        "                    if(temp_str_3 != '')",
                        "                    {",
                        "                        //Узнаём тип предмета, на который необходимо подменить деакринированный",
                        "                        temp_int_2 = GetValueFromScript('', GetParFromString(temp_str_3, ',', 0, 1));",
                        "                        if(temp_int_2 == ItemType(temp_gift))",
                        "                        {",
                        "                            if(temp_int_2 == t_CustomWeapon)",
                        "                            {",
                        "                                //Узнаём тип кастомного оружия",
                        "                                temp_str_4 = GetParFromString(temp_str_3, ',', 1, 1);",
                        "                                if(temp_str_4 != CustomWeaponType(temp_gift)) continue;",
                        "                            }",
                        "                        }",
                        "                        else continue;",
                        "                    }",
                        "                    else continue;",
                        "                }",
                        "            }",
                        "            //Если всё-таки произведён неизвестной, то делаем доп. проверки",
                        "            else",
                        "            {",
                        "                //Если бонус можно наложить на предмет с неизвестной расой, то добавляем ответ как обычно",
                        "                //А если нельзя, то меняем расу предмета и снова делаем проверку на применимость бонуса",
                        "                //Подразумевается, что к предмету с неизвестной расой подойдёт любой другой расовый бонус в принципе",
                        "                int check = 0;",
                        "                for(j = Maloc; j <= PirateClan; j = j + 1)",
                        "                {",
                        "                    ItemOwner(temp_gift, j);",
                        "                    if(MayAddBonusToEq(i, temp_gift))",
                        "                    {",
                        "                        check = 1;",
                        "                        break;",
                        "                    }",
                        "                }",
                        "                //После перебора возвращаем вещи её изначального владельца",
                        "                ItemOwner(temp_gift, 6);",
                        "",
                        "                if(!check)",
                        "                {",
                        "                    //Проверка на соответствие акрина типу данного предмета с учётом замены предмета при акринации",
                        "                    str temp_str_3 = CT('MicroModuls.' + temp_str_2 + '.ImitatedEquipType');",
                        "                    if(temp_str_3 != '')",
                        "                    {",
                        "                        //Узнаём тип предмета, на который необходимо подменить деакринированный",
                        "                        temp_int_2 = GetValueFromScript('', GetParFromString(temp_str_3, ',', 0, 1));",
                        "                        if(temp_int_2 == ItemType(temp_gift))",
                        "                        {",
                        "                            if(temp_int_2 == t_CustomWeapon)",
                        "                            {",
                        "                                //Узнаём тип кастомного оружия",
                        "                                str temp_str_4 = GetParFromString(temp_str_3, ',', 1, 1);",
                        "                                if(temp_str_4 != CustomWeaponType(temp_gift)) continue;",
                        "                            }",
                        "                        }",
                        "                        else continue;",
                        "                    }",
                        "                    else continue;",
                        "                }",
                        "            }",
                        "",
                        "            temp_gift=CreateEquipment(type_equip_str,temp_size,tint2,temp_race);",
                        "            SpecialToEquipment(i,temp_gift);",
                        "            AddItemToShip(Player(),temp_gift);",
                        "        }",
                        "    }",
                        "}",
                        "DChange(0);",
                        "exit;"
                    ],
