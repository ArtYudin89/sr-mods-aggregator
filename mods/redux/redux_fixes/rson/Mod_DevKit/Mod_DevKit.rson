                    "Code.Type": "Turn",
                    "Code": [
                        "temp_size = CountBox('Bm.Items.2FuelTanks14s', CT(\"Script.Mod_DevKit.312\"), 1,1000);",
                        "if(ShipEqInSlot(Player(),t_Weapon1,1) != 0) ItemSize(ShipEqInSlot(Player(),t_Weapon1,1),temp_size);",
