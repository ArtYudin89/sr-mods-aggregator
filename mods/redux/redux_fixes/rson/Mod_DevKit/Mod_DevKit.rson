                    "Code": [
                        "temp_str = TextBox(CT(\"Script.Mod_DevKit.514\"));",
                        "tint = 0;",
                        "if(temp_str != '') {",
                        "    for(i=0;GalaxyStars()>i;i=i+1) {",
                        "        temp_dword = GalaxyStar(i);",
                        "        for(j=0;StarShips(temp_dword)>j;j=j+1) {",
