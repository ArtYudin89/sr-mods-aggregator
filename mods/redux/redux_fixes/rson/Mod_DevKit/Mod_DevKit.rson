                        "        tdwd = BuyRanger(temp_dword,tech_lvl);",
                        "        if(tint != 3) ShipSubType(tdwd,tint);",
                        "        else ShipSubType(tdwd,RndObject(0,2,tdwd));",
                        "        ShipRefit(tdwd);",
                        "    }",
                        "",
                        "    PlanetRace(temp_dword,j);",
                        "    if(TakeOffFlag) {",
                        "        OrderTakeOff(tdwd);",
                        "    }",
                        "",
