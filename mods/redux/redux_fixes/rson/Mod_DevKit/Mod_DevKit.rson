                {
                    "Name": "",
                    "Code.Type": "Turn",
                    "Code": [
                        "BuildRuins(ShipStar(Player()), t_WB);",
                        "BuildRuins(ShipStar(Player()), t_BK);",
                        "BuildRuins(ShipStar(Player()), t_RC);",
                        "BuildRuins(ShipStar(Player()), t_SB);",
                        "BuildRuins(ShipStar(Player()), t_MC);",
