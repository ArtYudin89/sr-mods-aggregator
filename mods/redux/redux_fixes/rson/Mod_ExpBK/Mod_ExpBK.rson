                        "    DeleteEquipment(Player(),t_Scaner);",
                        "    DeleteEquipment(Player(),t_Engine);",
                        "    DeleteEquipment(Player(),t_FuelTanks);",
                        "    DeleteEquipment(Player(),t_RepairRobot);",
                        "    DeleteEquipment(Player(),t_DefGenerator);",
                        "    DeleteEquipment(Player(),t_CargoHook);",
                        "    DeleteEquipment(Player(),t_Radar);",
                        "    ItemIsInUse(CreateEquipment(t_CargoHook,50,1,2),Player(),1);",
                        "    ItemIsInUse(CreateEquipment(t_FuelTanks,30,1,2),Player(),1);",
                        "    ItemIsInUse(CreateEquipment(t_Engine,35,1,2),Player(),1);",
                        "    ItemIsInUse(CreateEquipment(t_Radar,60,1,2),Player(),1);",
                        "    ItemIsInUse(CreateHull(0,250,1,ShipPilotRace(Player())),Player(),1);",
                        "    BancCD = 365;",
                        "    for(k=0;k<4;k=k+1) {",
                        "        temp_dword = ShipEqInSlot(Player(),t_Artefact,k);",
                        "        if(temp_dword == 0) continue;",
                        "        else {",
                        "            GetArtFromShip(Player(),temp_dword);",
                        "            FreeItem(temp_dword);",
                        "        }",
                        "    }",
                        "    for(k=0;k<5;k=k+1) {",
                        "        temp_dword = ShipEqInSlot(Player(),t_Weapon1,k);",
                        "        if(temp_dword == 0) continue;",
