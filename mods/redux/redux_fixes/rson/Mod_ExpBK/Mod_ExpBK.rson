                        "            tstr6 = tstr6 + '</color>' + CT(\"Script.Mod_ExpBK.207\") + ' ' + '<clr>' + Name(tdwd3) + '<clrEnd>' + '(' + CT(\"Script.Mod_ExpBK.206\") + ' ' + '<clr>' + Name(PlanetToStar(tdwd3)) + '<clrEnd>' + ')' + Format('<br>');",
