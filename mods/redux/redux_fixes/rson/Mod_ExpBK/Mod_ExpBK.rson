                        "    //Выбираем товар на станции",
                        "    else tstr1 = tstr1 + '<color=0,50,200>' + type_name[i + 1] + ':</color>' + Format('<td=155'+'>') + temp_str_2 + Format('<td=225'+'>') + temp_str_3 + '<color=120,120,120>' + temp_str_4 + '</color>' + Format('<br>');",
