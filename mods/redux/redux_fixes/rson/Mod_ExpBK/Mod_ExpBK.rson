                {
                    "Name": "",
                    "Code.Type": "Turn",
                    "Code": [
                        "temp_dword = CountBox('Bm.Items.2FuelTanks14s',CT(\"Script.Mod_ExpBK.341\"),0,300,tint1,1,301,301,ShipMoney(Player()),100);",
                        "if(temp_dword < 1) {",
                        "  DChange(64);",
                        "  exit;",
                        "}",
                        "if(temp_dword > 0) {",
                        "  PlayerMedPolicy(PlayerMedPolicy()+temp_dword);",
                        "  Sound('Sound.Buy');",
