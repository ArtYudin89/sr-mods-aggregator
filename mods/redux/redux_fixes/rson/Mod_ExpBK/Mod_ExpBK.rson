                    "Code": [
                        "tstr2 = '</color>' + CT('FormRuins.BK.Policy.PlayerNo');",
                        "tstr1 = '</color>' + CT('Invests.Stations.Base');",
                        "",
                        "temp_int = 0;",
                        "//Осматриваем галактику на предмет недостачи станций",
                        "for(i=0;GalaxySectors()>i;i=i+1) {",
                        "    dword cur_con = GalaxySectors(i);",
                        "    if(!SectorVisible(cur_con)) continue;",
                        "    int BK = 0;",
                        "    int SB = 0;",
                        "    int MC = 0;",
                        "    int RC = 0;",
                        "    int WB = 0;",
                        "  //int TC = 0;",
                        "    int PB = 0;",
                        "    tstr1 = '';",
                        "    tint1 = 255;",
                        "    for(j=0;ConStars(cur_con)>j;j=j+1) {",
                        "        cur_ruin = ConStar(cur_con,j);",
                        "        if(StarRuins(cur_ruin,'BK')) BK = BK + 1;",
                        "        if(StarRuins(cur_ruin,'SB')) SB = SB + 1;",
                        "        if(StarRuins(cur_ruin,'MC')) MC = MC + 1;",
                        "        if(StarRuins(cur_ruin,'RC')) RC = RC + 1;",
                        "        if(StarRuins(cur_ruin,'WB')) WB = WB + 1;",
                        "        if(StarRuins(cur_ruin,'PB')) PB = PB + 1;",
                        "    }",
                        "",
                        "    //Господь покарает вас за 99+ систем",
                        "    if((PB + WB + RC + MC + SB + BK) >= ConStars(cur_con)) continue;",
                        "    else {",
                        "        if(!BK) tint2 = tint2 + 100;",
                        "        if(!PB) tint2 = tint2 + 200;",
                        "        if(!WB) tint2 = tint2 + 400;",
                        "        if(!RC) tint2 = tint2 + 800;",
                        "        if(!MC) tint2 = tint2 + 1600;",
                        "        if(!SB) tint2 = tint2 + 3200;",
                        "    }",
                        "",
                        "    while(tint2 > 0) {",
                        "        dword save_star = 0;",
                        "        for(j=0;ConStars(cur_con)>j;j=j+1) {",
                        "            cur_ruin = ConStar(cur_con,j);",
                        "            if(tint1 > StarRuins(cur_ruin)) {",
                        "                tint1 = StarRuins(cur_ruin);",
                        "                save_star = cur_ruin;",
                        "            }",
                        "        }",
                        "",
                        "        if(save_star > 0) {",
                        "            tint2 = tint2 + Id(save_star);",
                        "            if(tint2 >= 3200) {",
                        "                tstr3 = '</color>'+Format(CT('Invests.Stations.SBBuy'),'star',Name(save_star));",
                        "                InjectAnswer('EndStation',tstr3,tint2);",
                        "                tstr1 = tstr1 + Format('<br>') + '</color>' + CT('Invests.Stations.Divide') + Format(CT('Invests.Stations.SB'),'star',Name(save_star),'con',Name(cur_con),'Money',GalaxyMoney(4,4)*3);",
                        "                tint2 = tint2 - 3200;",
                        "                if(ShipMoney(Player()) < GalaxyMoney(4,4)*3) AddDialogBlock(tstr3,1);",
                        "            }",
                        "            if(tint2 >= 1600) {",
                        "                tstr3 = '</color>'+Format(CT('Invests.Stations.MCBuy'),'star',Name(save_star));",
                        "                InjectAnswer('EndStation',tstr3,tint2);",
                        "                tstr1 = tstr1 + Format('<br>') + '</color>' + CT('Invests.Stations.Divide') + Format(CT('Invests.Stations.MC'),'star',Name(save_star),'con',Name(cur_con),'Money',GalaxyMoney(4,4)*3/2);",
                        "                tint2 = tint2 - 1600;",
                        "                if(ShipMoney(Player()) < GalaxyMoney(4,4)*3/2) AddDialogBlock(tstr3,1);",
                        "            }",
                        "            if(tint2 >= 800) {",
                        "                tstr3 = '</color>'+Format(CT('Invests.Stations.RCBuy'),'star',Name(save_star));",
                        "                InjectAnswer('EndStation',tstr3,tint2);",
                        "                tstr1 = tstr1 + Format('<br>') + '</color>' + CT('Invests.Stations.Divide') + Format(CT('Invests.Stations.RC'),'star',Name(save_star),'con',Name(cur_con),'Money',GalaxyMoney(4,4)*3/2);",
                        "                tint2 = tint2 - 800;",
                        "                if(ShipMoney(Player()) < GalaxyMoney(4,4)*3/2) AddDialogBlock(tstr3,1);",
                        "            }",
                        "            if(tint2 >= 400) {",
                        "                tstr3 = '</color>'+Format(CT('Invests.Stations.WBBuy'),'star',Name(save_star));",
                        "                InjectAnswer('EndStation',tstr3,tint2);",
                        "                tstr1 = tstr1 + Format('<br>') + '</color>' + CT('Invests.Stations.Divide') + Format(CT('Invests.Stations.WB'),'star',Name(save_star),'con',Name(cur_con),'Money',GalaxyMoney(4,4)*7/2);",
                        "                tint2 = tint2 - 400;",
                        "                if(ShipMoney(Player()) < GalaxyMoney(4,4)*7/2) AddDialogBlock(tstr3,1);",
                        "            }",
                        "            if(tint2 >= 200) {",
                        "                tstr3 = '</color>'+Format(CT('Invests.Stations.PBBuy'),'star',Name(save_star));",
                        "                InjectAnswer('EndStation',tstr3,tint2);",
                        "                tstr1 = tstr1 + Format('<br>') + '</color>' + CT('Invests.Stations.Divide') + Format(CT('Invests.Stations.PB'),'star',Name(save_star),'con',Name(cur_con),'Money',GalaxyMoney(4,4)*4);",
                        "                tint2 = tint2 - 200;",
                        "                if(ShipMoney(Player()) < GalaxyMoney(4,4)*4) AddDialogBlock(tstr3,1);",
                        "            }",
                        "            if(tint2 >= 100) {",
                        "                tstr3 = '</color>'+Format(CT('Invests.Stations.BKBuy'),'star',Name(save_star));",
                        "                InjectAnswer('EndStation',tstr3,tint2);",
                        "                tstr1 = tstr1 + Format('<br>') + '</color>' + CT('Invests.Stations.Divide') + Format(CT('Invests.Stations.BK'),'star',Name(save_star),'con',Name(cur_con),'Money',GalaxyMoney(4,4)*2);",
                        "                tint2 = tint2 - 100;",
                        "                if(ShipMoney(Player()) < GalaxyMoney(4,4)*2) AddDialogBlock(tstr3,1);",
                        "            }",
                        "        }",
                        "    }",
                        "}",
                        "DChange(95);",
                        "exit;"
