                    ],
                    "#": 559,
                    "Type": "Top",
                    "Parent": -1,
                    "Pos.x": 100,
                    "Pos.y": 1065
                },
                {
                    "Name": "",
                    "Code.Type": "Turn",
                    "Code": [
                        "tint1 = 0;",
                        "temp_dword_2 = Player();",
                        "for(i=t_Hull;i<t_DefGenerator;i=i+1) {",
                        "    if(ShipEqInSlot(temp_dword_2,i)) {",
                        "        temp_dword_3 = ShipEqInSlot(temp_dword_2,i);",
                        "        if(i == t_Hull) {",
                        "            if(ShipCustomShipInfoData(temp_dword_2,'ExpBK_License',2) < 3) continue;",
                        "            if(!HullDamage(temp_dword_3) && !ShipStatusEffect(temp_dword_2,0) && !ShipStatusEffect(temp_dword_2,1) && !ShipStatusEffect(temp_dword_2,2) && !ShipStatusEffect(temp_dword_2,3) && !ShipStatusEffect(temp_dword_2,4)) {",
                        "                continue;",
                        "            }",
                        "        }",
                        "        else {",
                        "            if(ItemDurability(temp_dword_3) > 25) continue;",
                        "            if((i == t_DefGenerator || i == t_FuelTanks) && ShipCustomShipInfoData(temp_dword_2,'ExpBK_License',2) == 1) continue;",
                        "        }",
                        "        tint1 = tint1 + 1;",
                        "        InjectAnswer('RepairAll',CT(\"Script.Mod_ExpBK.297\")+' '+Name(temp_dword_3),i);",
                        "        //SFT('Цикл обычного шмота');",
                        "    }",
                        "",
                        "    if(ShipCustomShipInfoData(temp_dword_2,'ExpBK_License',2) == 3) {",
                        "        for(j=0;ShipSlots(temp_dword_2,2)>j;j=j+1) {",
                        "            temp_dword_3 = ShipEqInSlot(temp_dword_2,t_Artefact,j);",
                        "            if(ItemDurability(temp_dword_3) > 25) continue;",
                        "            InjectAnswer('RepairA',CT(\"Script.Mod_ExpBK.297\")+' '+Name(temp_dword_3),j);",
                        "            tint1 = tint1 + 1;",
                        "            //SFT('Цикл артов');",
                        "        }",
                        "",
                        "    }",
                        "",
                        "    for(j=0;ShipSlots(temp_dword_2,1)>j;j=j+1) {",
                        "        temp_dword_3 = ShipEqInSlot(temp_dword_2,t_Weapon1,j);",
                        "        if(ItemDurability(temp_dword_3) > 25) continue;",
                        "        InjectAnswer('RepairG',CT(\"Script.Mod_ExpBK.297\")+' '+Name(temp_dword_3),j);",
                        "        tint1 = tint1 + 1;",
                        "        //SFT('Цикл пушек');",
                        "    }",
                        "}",
                        "",
                        "if(tint1) {",
                        "    tstr1 = CT(\"Script.Mod_ExpBK.296\");",
                        "    tstr2 = CT(\"Script.Mod_ExpBK.295\");",
                        "}",
                        "else {",
                        "    tstr1 = CT(\"Script.Mod_ExpBK.294\");",
                        "    tstr2 = CT(\"Script.Mod_ExpBK.293\");",
                        "}",
                        "DChange(66);",
                        "exit;"
