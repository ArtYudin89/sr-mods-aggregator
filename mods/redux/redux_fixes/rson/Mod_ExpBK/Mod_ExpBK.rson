                        "                AddPlanetNews(tstr4,41);",
                        "                ChangeGlobalRelationsPlanets(Player(),0,2,30,31);",
                        "                RelationToRanger(PlanetPirateClan(),Player(),RelationToRanger(PlanetPirateClan(),Player()) - Rnd(2,5));",
                        "            }",
                        "            else if(tint2 >= 200) {",
                        "                tint2 = tint2 - 200;",
                        "                ShipMoney(Player(),ShipMoney(Player()) - GalaxyMoney(4,4)*4);",
                        "                temp_dword = GalaxyStar(tint2 - 1);",
                        "                BuildRuins(temp_dword,t_PB);",
                        "                tstr4 = '</color>' + Format(CT('GalaxyNews.CreateNewObject.PB'+Rnd(0,int(CT('GalaxyNews.CreateNewObject.SBCount')))),'<Name'+'>',Name(cur_ruin),'<Star'+'>',Name(temp_dword),'<Sector'+'>',Name(StarToCon(temp_dword)));",
                        "                NewsAdd(tstr4);",
