                        "        if(StarOwner(tdwd3)) continue;",
                        "        if(StarBattle(tdwd3)) continue;",
                        "        for(j=0;StarPlanets(tdwd3)>j;j=j+1) {",
                        "            if(PlanetOwner(StarPlanets(tdwd3,j)) != 6) continue;",
                        "            if((PlanetTerrain(StarPlanets(tdwd3,j),0) + PlanetTerrain(StarPlanets(tdwd3,j),1) + PlanetTerrain(StarPlanets(tdwd3,j),2)) < 350) continue;",
                        "            if((PlanetTerrain(StarPlanets(tdwd3,j),0) + PlanetTerrain(StarPlanets(tdwd3,j),1) + PlanetTerrain(StarPlanets(tdwd3,j),2)) > 2000) continue;",
                        "            if(PlanetTerrain(StarPlanets(tdwd3,j),0) > 700) continue;",
