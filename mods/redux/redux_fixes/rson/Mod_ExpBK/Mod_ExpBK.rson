                        "                               '<GoodsList'+'>', tstr1,",
                        "                               '<Commission'+'>', '<color=0,50,200>' + round((cur_commission - 1.0) * 100.0) + '%</color>',",
                        "                               '');",
                        "DChange(8);",
                        "exit;"
