                },
                {
                    "Name": "",
                    "Code.Type": "Turn",
                    "Code": [
                        "if(ArrayDim(EconomicsArr) < 2) {",
                        "    ArrayClear(EconomicsArr);",
                        "    ArrayDelete(EconomicsArr,0);",
                        "    for(i=0;GalaxyStars()>i;i=i+1) {",
                        "        tdwd3 = GalaxyStar(i);",
                        "        if(StarOwner(tdwd3)) continue;",
                        "        for(j=0;StarPlanets(tdwd3)>j;j=j+1) {",
                        "            tdwd2 = StarPlanets(tdwd3,j);",
                        "            if(PlanetOwner(tdwd2) > 4) continue;",
                        "            if(PlanetEco(tdwd2) == 2) continue;",
                        "            ArrayAdd(EconomicsArr,Id(tdwd2));",
                        "        }",
                        "    }",
                        "}",
                        "",
                        "if(ArrayDim(EconomicsArr) > 1) {",
                        "    if(ArrayDim(EconomicsArr) > 5) {",
                        "        for(i=0;5>i;i=i+1) {",
                        "            ArrayRandomize(50,EconomicsArr);",
                        "            tdwd3 = IdToPlanet(EconomicsArr[i]);",
                        "            if(GalaxyMoney(4,4)*30 <= ShipMoney(Player())) InjectAnswer('Invest',Format(CT(\"Script.Mod_ExpBK.344\"),'sys',Name(PlanetToStar(tdwd3)),'plan',Name(tdwd3)),tdwd3);",
                        "            //else InjectAnswer('PlanetChoosed',Format(\"Вложиться в экономику планеты plan\",'plan',Name(IdToPlanet(EconomicsArr[i-1]))),EconomicsArr[i-1],'block');",
                        "        }",
                        "    }",
                        "    else {",
                        "        tint1 = ArrayDim(EconomicsArr) - 1;",
                        "        for(i=0;tint1>i;i=i+1) {",
                        "            ArrayRandomize(150,EconomicsArr);",
                        "            tdwd3 = IdToPlanet(EconomicsArr[i]);",
                        "            if(GalaxyMoney(4,4)*30 <= ShipMoney(Player())) InjectAnswer('Invest',Format(CT(\"Script.Mod_ExpBK.344\"),'sys',Name(PlanetToStar(tdwd3)),'plan',Name(tdwd3)),tdwd3);",
