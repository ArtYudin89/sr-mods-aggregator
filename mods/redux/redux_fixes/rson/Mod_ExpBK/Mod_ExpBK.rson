                    "Code": [
                        "//temp_int_3  == -1 - у игрока есть действующая, ещё не истекающая торговая лицензия",
                        "        //temp_int_3  ==  1 - торговая лицензия истечёт через три месяца",
                        "        //temp_int_3  ==  0 - у игрока нет торговой лицензии",
                        "        temp_int_3 = -1;",
                        "        //Проверка на истечение лицензии",
                        "        temp_int = ShipFindCustomShipInfoByType(Player(), 'Trade_license');",
                        "        if(~temp_int)",
                        "        {",
                        "            temp_int = ShipCustomShipInfoData(Player(), temp_int, 1);",
                        "            if(temp_int - CurTurn() <= 89) temp_int_3 = 1;",
                        "        }",
                        "        //Проверка на наличие действующей лицензии",
                        "        else temp_int_3 = 0;",
                        "",
                        "        //Подключение диалогов на БЦ в зависимости от соблюдения различных условий",
                        "        if(!temp_int_3 && ShipStatus(Player(), 0) >= 30 && !LTradeLicenseCheck && BKexist != 3)",
                        "        {",
                        "            InjectAnswer('TradeLicense', CT(\"Script.Mod_ExpBK.123\"), 0);",
                        "        }",
                        "",
                        "        if(!temp_int_3 && ShipStatus(Player(), 0) >= 30 && LTradeLicenseCheck == 1 && BKexist != 3)",
                        "        {",
                        "            InjectAnswer('TradeLicense', CT(\"Script.Mod_ExpBK.125\"), 0);",
                        "        }",
                        "",
                        "        if(temp_int_3 == 1 && BKexist != 3)",
                        "        {",
                        "            InjectAnswer('TradeLicense', CT(\"Script.Mod_ExpBK.117\"), 0);",
                        "        }",
                        "",
                        "        //Если у игрока есть торговая лицензия",
                        "        if(~ShipFindCustomShipInfoByType(Player(), 'Trade_license'))",
                        "        {",
                        "            InjectAnswer('PurchaseTerminalDialog', CT(\"Script.Mod_ExpBK.192\"), 0);",
                        "        }",
                        "",
                        "        InjectAnswer('CreditCard',CT(\"Script.Mod_ExpBK.259\"),0);",
                        "        InjectAnswer('Investment',CT('FormRuins.BK.Investment.PlayerSendMod'),0);",
                        "        InjectAnswer('BuildStation',CT('Invests.StationSend'),0);",
                        "        //InjectAnswer('Trade',CT('FormRuins.BK.Trade.PlayerSendMod'),0);",
                        "        if(!PlayerMedPolicy()) InjectAnswer('Policy',CT('FormRuins.BK.Policy.PlayerSendMod'),0);",
                        "        if(!PlayerDebt()) InjectAnswer('TakeDebt',CT('FormRuins.BK.TakeDebt.PlayerSendMod'),0);",
                        "        if(!PlayerDeposit()) InjectAnswer('GiveDeposit',CT('FormRuins.BK.Deposit.PlayerSendMod'),0);",
                        "        else InjectAnswer('TakeDeposit',Format(CT('FormRuins.BK.RetDeposit.PlayerSendMod'),'<Money'+'>',DepositPercentCalc()),0);",
                        "",
                        "        if(PlayerDepositDay()<30) AddDialogBlock(Format(CT('FormRuins.BK.RetDeposit.PlayerSendMod'),'<Money'+'>',DepositPercentCalc()),1);",
                        "",
                        "        if(ShipMoney(Player()) < 1000) AddDialogBlock(CT('FormRuins.BK.Deposit.PlayerSendMod'));",
                        "        if(CurTurn() - PlayerDepositDate() < 31) AddDialogBlock(Format(CT('FormRuins.BK.RetDeposit.PlayerSendMod'),'<Money'+'>',PlayerDeposit()+DepositPercentCalc()),1);",
                        "if(HolidaysFlag && PlayerDebt()) {",
