                },
                {
                    "Name": "",
                    "Code.Type": "Turn",
                    "Code": [
                        "//А теперь мы начинаем проверять - может ли игрок проинвестировать чего-нибудь, или не время?",
                        "",
                        "//В первую очередь посмотрим ванильные инвестиции",
                        "Inv_str = '';",
                        "tdwd = ControlledSystems(0);",
                        "",
                        "//Теперь настала очередь новых инвестиций",
                        "if(LinerCD < 1) {",
                        "    //Погнали перебирать галакатику (кхе, галакатика)",
                        "    for(i=0;GalaxyStars()>i;i=i+1) {",
                        "        tdwd3 = GalaxyStar(i);",
                        "        for(j=0;StarShips(tdwd3)>j;j=j+1) {",
                        "            if(ShipTypeN(StarShips(tdwd3,j)) == t_Transport) tdwd2 = tdwd2 + 1; //Считаем транспорта",
                        "        }",
                        "    }",
                        "    if(round(tdwd2/GalaxyStars()) < 5) {",
                        "        //Опять перебираем галактику. Только теперь на другой лад",
                        "        for(i=0;GalaxyStars()>i;i=i+1) {",
                        "            StarForLiners = StarNearbyStars(ShipStar(Player()),i);",
                        "",
                        "            if(StarOwner(StarForLiners)) continue;",
                        "            else if(DistToNearestEnemySystem(StarForLiners) < 10) continue;",
                        "            else if(StarCustomFaction(StarForLiners) != '') continue;",
                        "            InjectAnswer('Transports',CT('Invests.TransportsBuy'),3);",
                        "            Inv_str = Inv_str + Format(CT('Invests.Transports'),'money',GalaxyMoney(3,4)*5,'star',Name(StarForLiners))+ CT('FormInfo.br');",
                        "            break;",
                        "        }",
                        "    }",
                        "}",
                        "if(ColonCD < 1) {",
                        "    InjectAnswer('Colonisation',CT('Invests.ColonisationBuy'),4);",
                        "    Inv_str = Inv_str + CT('Invests.Colonisation')+ CT('FormInfo.br');",
                        "}",
                        "if(WarCD < 1) {",
                        "    //Погнали перебирать галакатику (кхе, галакатика)",
                        "    for(i=0;GalaxyStars()>i;i=i+1) {",
                        "        tdwd3 = GalaxyStar(i);",
                        "        for(j=0;StarShips(tdwd3)>j;j=j+1) {",
                        "            if(ShipTypeN(StarShips(tdwd3,j)) == t_Warrior) tdwd2 = tdwd2 + 1; //Считаем военных",
                        "        }",
                        "    }",
                        "    if(round(tdwd2/GalaxyStars()) < 7) {",
                        "        //Опять перебираем галактику. Только теперь на другой лад",
                        "        for(j=0;GalaxyStars()>j;j=j+1) {",
                        "            StarForWarr = StarNearbyStars(ShipStar(Player()),j);",
                        "",
                        "            GetMainData('KemaricNumbers');",
                        "            if(StarOwner(StarForWarr)) continue;",
                        "            else if(StarCustomFaction(StarForWarr) != '') continue;",
                        "            InjectAnswer('MoreWar',CT('Invests.WarrBuy'),5);",
                        "            Inv_str = Inv_str + Format(CT('Invests.Warr'),'money',GalaxyMoney(3,4)*10,'star',Name(StarForWarr))+ CT('FormInfo.br');",
                        "            break;",
                        "        }",
                        "    }",
                        "}",
                        "if(FlagshipCD < 1) {",
                        "    //Погнали перебирать галакатику (кхе, галакатика)",
                        "    for(i=0;GalaxyStars()>i;i=i+1) {",
                        "        tdwd3 = GalaxyStar(i);",
                        "        for(j=0;StarShips(tdwd3)>j;j=j+1) {",
                        "            if(ShipTypeN(StarShips(tdwd3,j)) == t_Warrior) tdwd2 = tdwd2 + 1; //Считаем транспорта",
                        "        }",
                        "    }",
                        "    if(round(tdwd/tdwd2) < 2) {",
                        "        //Опять перебираем галактику. Только теперь на другой лад",
                        "        for(j=0;GalaxyStars()>j;j=j+1) {",
                        "            StarForFlagship = StarNearbyStars(ShipStar(Player()),j);",
                        "",
                        "            CT('ValericNumbers');",
                        "            if(StarOwner(StarForFlagship)) continue;",
                        "            else if(StarCustomFaction(StarForFlagship) != '') continue;",
                        "            InjectAnswer('Flagship',CT('Invests.FlagshipBuy'),6);",
                        "            Inv_str = Inv_str + Format(CT('Invests.Flagship'),'money',GalaxyMoney(4,4)*3,'star',Name(StarForFlagship))+ CT('FormInfo.br');",
                        "            break;",
                        "        }",
                        "    }",
                        "}",
                        "if(EconomicsCD < 1) {",
                        "    InjectAnswer('Economics',CT('Invests.EconomicsBuy'),7);",
                        "    Inv_str = Inv_str + CT('Invests.Economics')+ CT('FormInfo.br');",
                        "}",
                        "if(PirateCD < 1) {",
                        "    //Погнали перебирать галакатику (кхе, галакатика)",
                        "    for(i=0;GalaxyStars()>i;i=i+1) {",
                        "        tdwd3 = GalaxyStar(i);",
                        "        for(j=0;StarShips(tdwd3)>j;j=j+1) {",
                        "            if(ShipTypeN(StarShips(tdwd3,j)) == t_Transport) tdwd2 = tdwd2 + 1; //Считаем Транспорта",
                        "            else if(ShipTypeN(StarShips(tdwd3,j)) == t_Pirate) tdwd = tdwd + 1; //Считаем пиратов",
                        "        }",
                        "    }",
                        "    if(round(tdwd2/tdwd) < 10) {",
                        "        //Опять перебираем галактику. Только теперь на другой лад",
                        "        l = Rnd(10,20);",
                        "        for(i=0;GalaxyStars()>i;i=i+1) {",
                        "            StarForPirate = StarNearbyStars(ShipStar(Player()),i);",
                        "",
                        "            if(StarOwner(StarForPirate) != 2) continue;",
                        "            else if(StarCustomFaction(StarForPirate) != '') continue;",
                        "            if(StarToCon(StarForPirate) == StarToCon(PlanetToStar(PlanetPirateClan()))) continue;",
                        "            InjectAnswer('Pirate',CT('Invests.PirateBuy'),8);",
                        "            Inv_str = Inv_str + Format(CT('Invests.Pirate'),'money',GalaxyMoney(3,4)*l,'star',Name(StarForPirate))+ CT('FormInfo.br');",
                        "            break;",
                        "        }",
                        "    }",
                        "}",
                        "if(MilitiaCD < 1) {",
                        "    tdwd3 = 0;",
                        "    StarForMilitia = 0;",
                        "    //Погнали перебирать галакатику (кхе, галакатика)",
                        "    for(i=0;GalaxyStars()>i;i=i+1) {",
                        "        if(!StarForMilitia) {",
                        "            StarForMilitia = tdwd3;",
                        "            continue;",
                        "        }",
                        "        tdwd3 = GalaxyStar(i);",
                        "        if(StarOwner(tdwd3)) continue;",
                        "        if(StarBattle(tdwd3)) {",
                        "            if(round(sqrt(Dist2Star(ShipStar(Player()),StarForMilitia))) > round(sqrt(Dist2Star(ShipStar(Player()), tdwd3)))) {",
                        "                StarForMilitia = tdwd3;",
                        "            }",
                        "        }",
                        "    }",
                        "    if(StarForMilitia) {",
                        "        k = Rnd(4,7);",
                        "        InjectAnswer('Militia',CT('Invests.MilitiaBuy'),9);",
                        "        Inv_str = Inv_str + Format(CT('Invests.Militia'),'money',GalaxyMoney(2,4)*k,'star',Name(StarForMilitia))+ CT('FormInfo.br');",
                        "    }",
                        "}",
                        "if(PoorCD < 1) {",
                        "    InjectAnswer('Poor',CT('Invests.PoorBuy'),10);",
                        "    Inv_str = Inv_str + Format(CT('Invests.Poor'),'money',2*GalaxyMoney(3,4))+ CT('FormInfo.br');",
                        "}",
                        "if(FamiliesCD < 1) {",
                        "    InjectAnswer('HelpFamilies',CT('Invests.FamiliesBuy'),10);",
                        "    Inv_str = Inv_str + Format(CT('Invests.Families'),'money',3*GalaxyMoney(3,4))+ CT('FormInfo.br');",
                        "}",
                        "DChange(40);",
                        "exit;"
                    ],
                    "#": 412,
                    "Type": "Top",
                    "Parent": -1,
                    "Pos.x": 580,
                    "Pos.y": 600
                },
                {
                    "Name": "",
                    "Code.Type": "Turn",
                    "Code": [
                        "if(!StarBattle(ShipStar(Player()))) {",
                        "  if(CardFlag == 0) {",
                        "    temp_int_4 = GalaxyMoney(4,4);",
                        "    if(temp_int_4 > 100) temp_int_5 = round(GalaxyMoney(4,4),100);",
                        "    if(temp_int_4 > 1000) temp_int_5 = round(GalaxyMoney(4,4),1000);",
                        "    if(temp_int_4 > 10000) temp_int_5 = round(GalaxyMoney(4,4),10000);",
                        "    DChange(34);",
                        "    exit;",
                        "  }",
                        "  if(CardFlag == 1) {",
                        "    temp_int_4 = UselessItemData(IdToItem(CardID),1); //текущий баланс",
                        "    temp_int_5 = UselessItemData(IdToItem(CardID),2); //суммарный баланс;",
                        "    DChange(35);",
                        "    exit;",
