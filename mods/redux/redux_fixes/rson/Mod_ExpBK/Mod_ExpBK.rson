                        "//if(ArrayDim(PlanetsArr) < 2) {",
                        "    ArrayClear(PlanetsArr);",
                        "    ArrayDelete(PlanetsArr,0);",
                        "    for(i=0;GalaxyStars()>i;i=i+1) {",
