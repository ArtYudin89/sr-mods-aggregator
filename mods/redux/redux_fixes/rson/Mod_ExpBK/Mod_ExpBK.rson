                    "Pos.y": 1115,
                    "Type": "TDialogAnswer",
                    "Parent": -1,
                    "#": 368,
                    "Msg": "",
                    "AMsg.Num": "129",
                    "_orig_danswer": "DAnswer('')"
                },
                {
                    "Name": "",
                    "Pos.x": 1200,
                    "Pos.y": 1115,
                    "Type": "TDialogAnswer",
                    "Parent": -1,
                    "#": 369,
                    "Msg": "Да, я согласен. Переводите деньги!",
                    "AMsg.Num": "130",
                    "_orig_danswer": "DAnswer(CT(\"Script.Mod_ExpBK.269\"))"
                },
                {
                    "Name": "",
                    "Pos.x": 1320,
                    "Pos.y": 1115,
                    "Type": "TDialogAnswer",
                    "Parent": -1,
                    "#": 370,
                    "Msg": "Да, я согласен. Переводите деньги!",
                    "AMsg.Num": "131",
                    "_orig_danswer": "DAnswer(CT(\"Script.Mod_ExpBK.269\"))"
                },
                {
                    "Name": "block",
                    "Pos.x": 1440,
                    "Pos.y": 1115,
                    "Type": "TDialogAnswer",
                    "Parent": -1,
                    "#": 371,
                    "Msg": "<0>",
                    "AMsg.Num": "132",
                    "_orig_danswer": "DAnswer('block~'+Format(CT(\"Script.Mod_ExpBK.112\"),\"<0>\",tstr3))"
                },
                {
                    "Name": "block",
                    "Pos.x": 1560,
                    "Pos.y": 1115,
                    "Type": "TDialogAnswer",
                    "Parent": -1,
                    "#": 372,
                    "Msg": "<0>",
                    "AMsg.Num": "133",
                    "_orig_danswer": "DAnswer('block~'+Format(CT(\"Script.Mod_ExpBK.112\"),\"<0>\",tstr4))"
                },
                {
                    "Name": "block",
                    "Pos.x": 1680,
                    "Pos.y": 1115,
