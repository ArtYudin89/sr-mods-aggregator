                        "  //Служба доставки",
                        "  if(!CoalitionDefeated())",
                        "  {",
                        "      if(!cargo_in_way) AddDialogInject('del_serv', '', CT(\"Script.Mod_ExpPilotBridge.500\"), 15);",
                        "      else AddDialogInject('DeliveryInfo', '', CT(\"Script.Mod_ExpPilotBridge.500\"), 15);",
                        "  }",
                        "  ",
                        "  //Распутин",
                        "  if(!HullOnWay) AddDialogInject('HullTrans', '', CT(\"Script.Mod_ExpPilotBridge.1093\"), 14);",
                        "  else AddDialogInject('HullTransInfo', '', CT(\"Script.Mod_ExpPilotBridge.1093\"), 14);",
                        "  ",
                        "  //Интерселлар",
                        "  if(IsScriptActive('Mod_ExpAutoSearch'))",
                        "  {",
                        "      //Также проверяем наличие в Галактике хотя бы одного БЦ",
                        "      if(GetValueFromScript('Mod_ExpAutoSearch', 'TotalBKCount') <= 0) AddDialogBlock(CT(\"Script.Mod_ExpPilotBridge.1537\"), 1);",
                        "      AddDialogInject('Intersellar', '', CT(\"Script.Mod_ExpPilotBridge.1537\"), 9);",
                        "  }",
                        "  else if(IsScriptActive('Mod_ExpBK'))",
                        "  {",
                        "      //Также проверяем наличие в Галактике хотя бы одного БЦ",
                        "      if(GetValueFromScript('Mod_ExpBK','TotalBKCount') <= 0) AddDialogBlock(CT(\"Script.Mod_ExpPilotBridge.1537\"), 1);",
                        "      AddDialogInject('Intersellar', '', CT(\"Script.Mod_ExpPilotBridge.1537\"), 9);",
                        "  }",
                        "  ",
                        "  //Слэпстартер",
                        "  if(!CoalitionDefeated()) AddDialogInject('Slapstarter', '', CT(\"Script.Mod_ExpPilotBridge.970\"), 7);",
                        "  ",
                        "  //Прочее",
                        "  AddDialogInject('ClearSpace', '', CT(\"Script.Mod_ExpPilotBridge.700\"), 5);",
                        "  AddDialogInject('Galapedia', '', CT(\"Script.Mod_ExpPilotBridge.494\"), 5);",
                        "  AddDialogInject('FindPlanets', '', CT(\"Script.Mod_ExpPilotBridge.1598\"), 5);",
                        "  AddDialogInject('BoardComp', '', CT(\"Script.Mod_ExpPilotBridge.154\"), -1);",
                        "}",
                        "if(GetTalkShip()) {",
                        "  if(!TalkByAI()) {",
                        "    if(~ShipFindCustomShipInfoByType(GetTalkShip(), 'PlayerBridge_PiratesPursue')) {",
                        "      if(GCardPursueCheck == 1) {",
                        "        AddDialogOverride('WheresTheMoneyLebowski?', 1000);",
