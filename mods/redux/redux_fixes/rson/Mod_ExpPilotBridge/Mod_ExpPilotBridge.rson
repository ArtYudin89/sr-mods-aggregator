                        "          if(HullFromType==4)",
                        "          {",
                        "              if(StarOwner(PlanetToStar(IdToPlanet(HullDelEndId)))==1 || StarCustomFaction(PlanetToStar(IdToPlanet(HullDelEndId)))!='' && (HullAgentType==1 || HullAgentType==22))",
                        "              {",
                        "                  //Корпус был в пути на планету доставки, но её захватили, а корпус перенаправили (возможно) на станцию отправки",
                        "                  if(!HullFromStExist)",
                        "                  {",
                        "                      if(HullOnWay==1 && HullWasStolen==0 && (HullAgentType==1 || HullAgentType==2))NewsAdd(Format(CT(\"Script.Mod_ExpPilotBridge.1501\"),\"<0>\",StarName(PlanetToStar(IdToPlanet(HullDelEndId))),\"<1>\",PlanetName(IdToPlanet(HullDelEndId)),\"<2>\",ShipName(IdToShip(HullDelFromId)),\"<3>\",StarName(ShipStar(IdToShip(HullDelFromId)))));",
                        "                      else if(HullOnWay==1 && (HullWasStolen>0 || HullAgentType==22 || HullAgentType==3))NewsAdd(Format(CT(\"Script.Mod_ExpPilotBridge.1500\"),\"<0>\",StarName(PlanetToStar(IdToPlanet(HullDelEndId))),\"<1>\",PlanetName(IdToPlanet(HullDelEndId))));",
                        "                      else if(HullOnWay>1 && HullWasStolen==0 && (HullAgentType==1 || HullAgentType==2))NewsAdd(Format(CT(\"Script.Mod_ExpPilotBridge.1499\"),\"<0>\",StarName(PlanetToStar(IdToPlanet(HullDelEndId))),\"<1>\",PlanetName(IdToPlanet(HullDelEndId)),\"<2>\",ShipName(IdToShip(HullDelFromId)),\"<3>\",StarName(ShipStar(IdToShip(HullDelFromId)))));",
                        "                      else if(HullOnWay>1 && HullWasStolen>0 && HullWasStolen<7 && (HullAgentType==1 || HullAgentType==2))NewsAdd(Format(CT(\"Script.Mod_ExpPilotBridge.1498\"),\"<0>\",StarName(PlanetToStar(IdToPlanet(HullDelEndId))),\"<1>\",PlanetName(IdToPlanet(HullDelEndId)),\"<2>\",ShipName(IdToShip(HullDelFromId)),\"<3>\",StarName(ShipStar(IdToShip(HullDelFromId)))));",
                        "                      else if(HullOnWay>1 && (HullWasStolen==7 || HullAgentType==22 || HullAgentType==3))NewsAdd(Format(CT(\"Script.Mod_ExpPilotBridge.1497\"),\"<0>\",StarName(PlanetToStar(IdToPlanet(HullDelEndId))),\"<1>\",PlanetName(IdToPlanet(HullDelEndId))));",
                        "                      if(HullAgentType==22 || HullAgentType==3)HullWasStolen=7;",
                        "                      if(HullWasStolen>0)HullWasStolenThiefCreate(0);",
                        "                      HullDelTime=CurTurn()-HullDelTimeStart;",
                        "                      HullDelTimeExp=HullDelTime+CurTurn();",
                        "                      if(Rnd(1,100)<=35 && HullAgentType==1)HullDelTime=HullDelTime+((HullDelTime*Rnd(15,25))/100);",
                        "                      if(Rnd(1,100)<=65 && HullAgentType==2)HullDelTime=HullDelTime+((HullDelTime*Rnd(25,40))/100);",
