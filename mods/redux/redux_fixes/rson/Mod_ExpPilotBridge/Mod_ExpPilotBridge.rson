                        "                          temp_str_2='</color>'+CT(\"Script.Mod_ExpPilotBridge.1517\");",
                        "                      }",
                        "                      CustomEther('MailFailed',0,'',Format(CT(\"Script.Mod_ExpPilotBridge.1521\"),\"<0>\",point_3_name,\"<1>\",temp_str,\"<2>\",temp_str_2,\"<3>\",ShipName(IdToShip(point_1_id)),\"<4>\",StarName(ShipStar(IdToShip(point_1_id)))));",
                        "                      CargoLostChanceCalc();",
