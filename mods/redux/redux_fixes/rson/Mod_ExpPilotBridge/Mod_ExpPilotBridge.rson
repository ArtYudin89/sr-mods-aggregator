                {
                    "Name": "",
                    "Code.Type": "Turn",
                    "Code": [
                        "//Непосредственно в Id эти переменные превращаются уже в самом конце оформления (так удобнее)",
                        "HullDelFromId=temp_array[temp_int_3];",
                        "HullFromType=ObjectType(HullDelFromId);",
                        "HullFromStarId=temp_array_3[temp_int_3];",
                        "HullDelEndId=GAnswerData;",
                        "HullEndType=ObjectType(HullDelEndId);",
                        "if(HullEndType==3)HullEndStarId=Id(PlanetToStar(HullDelEndId))-1;",
                        "if(HullEndType==4)HullEndStarId=Id(ShipStar(HullDelEndId))-1;",
                        "HullDelTime=0;",
                        "ArrayClear(transfer_list_can);",
                        "",
                        "//Расчёт дистанции до системы назначения и времени в пути",
                        "if(HullEndType==3)",
                        "{",
                        "    full_distance=Dist2Star(GalaxyStar(HullFromStarId),GalaxyStar(HullEndStarId));",
                        "    HullDelFromStr=CT(\"Script.Mod_ExpPilotBridge.777\")+PlanetName(GAnswerData);",
                        "}",
                        "if(HullEndType==4)",
                        "{",
                        "    full_distance=Dist2Star(GalaxyStar(HullFromStarId),GalaxyStar(HullEndStarId));",
                        "    HullDelFromStr=Name(GAnswerData);",
                        "}",
                        "",
                        "temp_int_1=round(sqrt(full_distance));",
                        "//Определяем среднее (при выборе спецов) время доставки",
                        "if(!temp_int_1)HullDelTime=7;",
                        "else if(temp_int_1 && temp_int_1<=9)HullDelTime=10;",
                        "else",
                        "{",
                        "    if(GalaxyTechLevel()==1)HullDelTime=temp_int_1+(temp_int_1-1*(temp_int_1/20));",
                        "    else if(GalaxyTechLevel()==2)HullDelTime=temp_int_1+(temp_int_1-2*(temp_int_1/20));",
                        "    else if(GalaxyTechLevel()==3)HullDelTime=temp_int_1+(temp_int_1-3*(temp_int_1/20));",
                        "    else if(GalaxyTechLevel()==4)HullDelTime=temp_int_1+(temp_int_1-4*(temp_int_1/20));",
                        "    else if(GalaxyTechLevel()==5)HullDelTime=temp_int_1+(temp_int_1-5*(temp_int_1/20));",
                        "    else if(GalaxyTechLevel()==6)HullDelTime=temp_int_1+(temp_int_1-6*(temp_int_1/20));",
                        "    else if(GalaxyTechLevel()==7)HullDelTime=temp_int_1+(temp_int_1-7*(temp_int_1/20));",
                        "    else if(GalaxyTechLevel()==8)HullDelTime=temp_int_1+(temp_int_1-8*(temp_int_1/20));",
                        "}",
                        "//Подсчёт размера корпуса, а также составление массива корпусов на складе пункта отправки",
                        "transfer_cargo_cost=0;",
                        "transfer_cargo_size=0;",
                        "",
                        "for(i=0; i<StorageItems(); i=i+1)",
                        "{",
                        "    if(ItemType(StorageItems(i))!=t_Hull)continue;",
                        "    if(StorageItemLocation(i)==HullDelFromId)",
                        "    {",
                        "        transfer_cargo_size=transfer_cargo_size+ItemSize(StorageItems(i));",
                        "        ArrayAdd(transfer_list_can,StorageItems(i));",
                        "    }",
                        "}",
                        "",
                        "//Переменные для подстановки в диалог",
                        "if(HullFromType==3)point_from=CT(\"Script.Mod_ExpPilotBridge.1105\")+' ';",
                        "if(HullFromType==4)point_from='';",
                        "//Составляем строку со списком корпусов, доступных для перегона",
                        "temp_str='</color>';",
                        "if(ArrayDim(transfer_list_can)>2)",
                        "{",
                        "    for(i=1;i<ArrayDim(transfer_list_can);i=i+1)",
                        "    {",
                        "        temp_str=temp_str+i+'. '+'<color=0,50,200>'+DeleteTags(Name(transfer_list_can[i]))+'</color>'+' (<color=0,50,200>'+ItemSize(transfer_list_can[i])+CT(\"Script.Mod_ExpPilotBridge.1094\")+CT(\"Script.Mod_ExpPilotBridge.67\");",
                        "    }",
                        "}",
                        "",
                        "if(ArrayDim(transfer_list_can)==2) temp_str='</color>'+Format(CT(\"Script.Mod_ExpPilotBridge.1104\"),\"<0>\",DeleteTags(Name(transfer_list_can[1])),\"<1>\",ItemSize(transfer_list_can[1]));",
                        "if(GetGameOptions('FontDialog')==0) DefSplt='</color>-------------------------------------------------------------';",
                        "if(GetGameOptions('FontDialog')==1) DefSplt='</color>------------------------------------------';",
                        "if(GetGameOptions('FontDialog')==2) DefSplt='</color>-----------------------------------------';",
                        "if(GetGameOptions('FontDialog')==3) DefSplt='</color>-------------------------------------';",
                        "if(ArrayDim(transfer_list_can)==2) {",
                        "  DChange(30);",
                        "  exit;",
                        "}",
                        "if(ArrayDim(transfer_list_can)>2) {",
                        "  DChange(29);",
                        "  exit;",
                        "}"
                    ],
                    "#": 529,
                    "Type": "Top",
                    "Parent": -1,
                    "Pos.x": 1270,
                    "Pos.y": 1000
                },
                {
                    "Name": "",
                    "Code.Type": "Turn",
                    "Code": [
                        "//Формирование списка предметов в диалоге и соответствующих ему ответов",
                        "if(GAnswerData>=100000000) temp_int=GAnswerData%100000000;",
                        "else temp_int=GAnswerData;",
                        "temp_int_2=0;",
                        "//Значения переменной temp_int_2: 1 - игрок нажал кнопку \"Добавить\", 2 - игрок нажал кнопку \"Удалить\"",
                        "//Добавляем предмет в список на перевозку",
                        "if(GAnswerData<100000000 && temp_int_2==0)",
                        "{",
                        "    temp_array_5[temp_int]=-1;",
                        "    temp_int_6=temp_int_6+1;",
                        "    temp_int_2=1;",
                        "}",
                        "//Удаляем предмет из списка на перевозку",
                        "if(GAnswerData>=100000000 && temp_int_2==0)",
                        "{",
                        "    temp_array_5[temp_int]=0;",
                        "    temp_int_6=temp_int_6-1;",
                        "    temp_int_2=2;",
                        "}",
                        "",
                        "temp_int=0;",
                        "temp_str='';",
                        "//Заполняем строку с содержанием списка",
                        "for(i=1; i<ArrayDim(temp_array_5); i=i+1)",
                        "{",
                        "    if(temp_array_5[i]==-1)",
                        "    {",
                        "        temp_int=temp_int+1;",
                        "        temp_str=temp_str+'</color>'+temp_int+'. '+temp_array_6[i]+CT(\"Script.Mod_ExpPilotBridge.67\");",
                        "    }",
                        "}",
                        "",
                        "if(!temp_int) temp_str=CT('FormInfo.td_otstup_HullCargoList'+GetGameOptions('FontDialog'))+CT(\"Script.Mod_ExpPilotBridge.1450\");",
                        "//Установка длины \"дефисного разделителя\" в зависимости от выбранного в игре размера шрифта",
                        "if(GetGameOptions('FontDialog') ==' 0') DefSplt='</color>------------------------------';",
                        "else if(GetGameOptions('FontDialog') == '1') DefSplt='</color>--------------------------';",
                        "else if(GetGameOptions('FontDialog') == '2') DefSplt='</color>-----------------------------';",
                        "else DefSplt='</color>--------------------------';",
                        "DChange(31);",
                        "exit;"
                    ],
                    "#": 530,
                    "Type": "Top",
                    "Parent": -1,
                    "Pos.x": 1480,
                    "Pos.y": 1000
                },
                {
                    "Name": "",
                    "Code.Type": "Turn",
                    "Code": [
                        "ArrayClear(transfer_list_done);",
                        "ArrayClear(temp_array_4);",
                        "ArrayClear(temp_array_6);",
                        "transfer_cargo_cost=0;",
                        "transfer_cargo_size=0;",
                        "//Составляем предотправочный список",
                        "for(i = 1; i < ArrayDim(temp_array_5); i = i + 1)",
                        "{",
                        "    if(temp_array_5[i]==-1)",
                        "    {",
                        "        temp_dword=transfer_list_can[i];",
                        "        transfer_cargo_size=transfer_cargo_size+ItemSize(temp_dword);",
                        "        ArrayAdd(transfer_list_done,temp_dword);",
                        "    }",
                        "}",
                        "if(ArrayDim(transfer_list_done)<=2)",
                        "{",
                        "    ArrayAdd(temp_array_4,CT(\"Script.Mod_ExpPilotBridge.1345\"));//1",
                        "    ArrayAdd(temp_array_4,CT(\"Script.Mod_ExpPilotBridge.1154\"));//2",
                        "    ArrayAdd(temp_array_4,CT(\"Script.Mod_ExpPilotBridge.1160\"));//3",
                        "    ArrayAdd(temp_array_4,CT(\"Script.Mod_ExpPilotBridge.1159\"));//4",
                        "    ArrayAdd(temp_array_4,'</color>'+CT(\"Script.Mod_ExpPilotBridge.1128\"));//5",
                        "    ArrayAdd(temp_array_4,'</color>'+CT(\"Script.Mod_ExpPilotBridge.1127\"));//6",
                        "    ArrayAdd(temp_array_4,'</color>'+CT(\"Script.Mod_ExpPilotBridge.1126\"));//7",
                        "    ArrayAdd(temp_array_4,'</color>'+CT(\"Script.Mod_ExpPilotBridge.1158\"));//8",
                        "    ArrayAdd(temp_array_4,'</color>'+CT(\"Script.Mod_ExpPilotBridge.1157\"));//9",
                        "    ArrayAdd(temp_array_4,'</color>'+CT(\"Script.Mod_ExpPilotBridge.1156\"));//10",
                        "}",
                        "else",
                        "{",
                        "    ArrayAdd(temp_array_4,CT(\"Script.Mod_ExpPilotBridge.1344\"));//1",
                        "    ArrayAdd(temp_array_4,CT(\"Script.Mod_ExpPilotBridge.1154\"));//2",
                        "    ArrayAdd(temp_array_4,CT(\"Script.Mod_ExpPilotBridge.1153\"));//3",
                        "    ArrayAdd(temp_array_4,CT(\"Script.Mod_ExpPilotBridge.1152\"));//4",
                        "    ArrayAdd(temp_array_4,'</color>'+CT(\"Script.Mod_ExpPilotBridge.1128\"));//5",
                        "    ArrayAdd(temp_array_4,'</color>'+CT(\"Script.Mod_ExpPilotBridge.1151\"));//6",
                        "    ArrayAdd(temp_array_4,'</color>'+CT(\"Script.Mod_ExpPilotBridge.1150\"));//7",
                        "    ArrayAdd(temp_array_4,'</color>'+CT(\"Script.Mod_ExpPilotBridge.1149\"));//8",
                        "    ArrayAdd(temp_array_4,'</color>'+CT(\"Script.Mod_ExpPilotBridge.1148\"));//9",
                        "    ArrayAdd(temp_array_4,'</color>'+CT(\"Script.Mod_ExpPilotBridge.1147\"));//10",
                        "}",
                        "//Ниже идёт прописка подстановочной (в диалог) переменной для профи доставки",
                        "//Если этого не делать, то разница между профи и спец видом доставки на минимальных временных отрезках будет составлять всего 1 день - не круто",
                        "if(HullDelTime <= 7) temp_int_5 = 5;",
                        "else if(HullDelTime == 8) temp_int_5 = 6;",
                        "else if(HullDelTime == 9) temp_int_5 = 7;",
                        "else temp_int_5 = (-0.25 * HullDelTime) + HullDelTime;",
                        "",
                        "//Если пункт доставки находится в другой системе",
                        "if(temp_int_1)",
                        "{",
                        "    dist_to = Format(CT(\"Script.Mod_ExpPilotBridge.805\"),\"<0>\",temp_int_1);",
                        "    //Определяем стоимость",
                        "    if(GTL <= 1) transfer_cargo_cost = round((0.00315 * transfer_cargo_size) * ((GalaxyMoney(0, 0) / 5) * temp_int_1));",
                        "    else if(GTL == 2) transfer_cargo_cost = round((0.00315 * transfer_cargo_size) * ((GalaxyMoney(0, 0) / 5) * temp_int_1));",
                        "    else if(GTL == 3) transfer_cargo_cost = round((0.00315 * transfer_cargo_size) * ((GalaxyMoney(0, 0) / 5) * temp_int_1));",
                        "    else if(GTL == 4) transfer_cargo_cost = round((0.00315 * transfer_cargo_size) * ((GalaxyMoney(0, 0) / 5) * temp_int_1));",
                        "    else if(GTL == 5) transfer_cargo_cost = round((0.00315 * transfer_cargo_size) * ((GalaxyMoney(0, 0) / 5) * temp_int_1));",
                        "    else if(GTL == 6) transfer_cargo_cost = round((0.00315 * transfer_cargo_size) * ((GalaxyMoney(0, 0) / 5) * temp_int_1));",
