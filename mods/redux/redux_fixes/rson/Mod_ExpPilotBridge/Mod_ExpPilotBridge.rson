                        "        else if(temp_int_5==0 && HullEndType==4) CustomEther('MailGood',0,'',Format(CT(\"Script.Mod_ExpPilotBridge.1207\"),\"<0>\",temp_str_2,\"<1>\",ShipName(IdToShip(HullDelEndId)),\"<2>\",StarName(GalaxyStar(HullEndStarId)),\"<3>\",temp_str));",
                        "        //Украден один корпус из двух прибывших на место",
                        "        else if(temp_int_5==1 && HullEndType==3)",
                        "        {",
                        "            CustomEther('MailGood',0,'',Format(CT(\"Script.Mod_ExpPilotBridge.1206\"),\"<0>\",temp_str,\"<1>\",temp_str_2,\"<2>\",PlanetName(IdToPlanet(HullDelEndId)),\"<3>\",StarName(GalaxyStar(HullEndStarId)),\"<4>\",TransHullCost));",
                        "            ShipMoney(Player(),ShipMoney(Player())+TransHullCost);",
                        "            Sound('Sound.Sell');",
                        "        }",
                        "        else if(temp_int_5==1 && HullEndType==4)",
                        "        {",
                        "            CustomEther('MailGood',0,'',Format(CT(\"Script.Mod_ExpPilotBridge.1206\"),\"<0>\",temp_str,\"<1>\",temp_str_2,\"<2>\",ShipName(IdToShip(HullDelEndId)),\"<3>\",StarName(GalaxyStar(HullEndStarId)),\"<4>\",TransHullCost));",
                        "            ShipMoney(Player(),ShipMoney(Player())+TransHullCost);",
                        "            Sound('Sound.Sell');",
                        "        }",
                        "        //Украдены оба корпуса из двух прибывших на место",
                        "        else if(temp_int_5==2)",
                        "        {",
                        "            CustomEther('MailFailed',0,'',Format(CT(\"Script.Mod_ExpPilotBridge.1202\"),\"<0>\",TransHullCost));",
                        "            ShipMoney(Player(),ShipMoney(Player())+TransHullCost);",
                        "            Sound('Sound.Sell');",
                        "        }",
                        "    }",
                        "    else if(HullOnWay==3)",
                        "    {",
                        "        //Все три корпуса доставлены успешно",
                        "        if(temp_int_5==0 && HullEndType==3) CustomEther('MailGood',0,'',Format(CT(\"Script.Mod_ExpPilotBridge.1205\"),\"<0>\",temp_str_2,\"<1>\",PlanetName(IdToPlanet(HullDelEndId)),\"<2>\",StarName(GalaxyStar(HullEndStarId)),\"<3>\",temp_str));",
                        "        else if(temp_int_5==0 && HullEndType==4) CustomEther('MailGood',0,'',Format(CT(\"Script.Mod_ExpPilotBridge.1205\"),\"<0>\",temp_str_2,\"<1>\",ShipName(IdToShip(HullDelEndId)),\"<2>\",StarName(GalaxyStar(HullEndStarId)),\"<3>\",temp_str));",
                        "        //Один из трёх прибывших корпусов был украден",
                        "        else if(temp_int_5==1 && HullEndType==3)",
                        "        {",
                        "            CustomEther('MailGood',0,'',Format(CT(\"Script.Mod_ExpPilotBridge.1204\"),\"<0>\",temp_str_2,\"<1>\",PlanetName(IdToPlanet(HullDelEndId)),\"<2>\",StarName(GalaxyStar(HullEndStarId)),\"<3>\",TransHullCost,\"<4>\",temp_str));",
                        "            ShipMoney(Player(),ShipMoney(Player())+TransHullCost);",
                        "            Sound('Sound.Sell');",
                        "        }",
                        "        else if(temp_int_5==1 && HullEndType==4)",
                        "        {",
                        "            CustomEther('MailGood',0,'',Format(CT(\"Script.Mod_ExpPilotBridge.1204\"),\"<0>\",temp_str_2,\"<1>\",ShipName(IdToShip(HullDelEndId)),\"<2>\",StarName(GalaxyStar(HullEndStarId)),\"<3>\",TransHullCost,\"<4>\",temp_str));",
                        "            ShipMoney(Player(),ShipMoney(Player())+TransHullCost);",
                        "            Sound('Sound.Sell');",
                        "        }",
                        "        //Два из трёх прибывших корпусов были украдены",
                        "        else if(temp_int_5==2 && HullEndType==3)",
                        "        {",
                        "            CustomEther('MailFailed',0,'',Format(CT(\"Script.Mod_ExpPilotBridge.1203\"),\"<0>\",temp_str,\"<1>\",temp_str_2,\"<2>\",PlanetName(IdToPlanet(HullDelEndId)),\"<3>\",StarName(GalaxyStar(HullEndStarId)),\"<4>\",TransHullCost));",
                        "            ShipMoney(Player(),ShipMoney(Player())+TransHullCost);",
                        "            Sound('Sound.Sell');",
                        "        }",
                        "        else if(temp_int_5==2 && HullEndType==4)",
                        "        {",
                        "            CustomEther('MailFailed',0,'',Format(CT(\"Script.Mod_ExpPilotBridge.1203\"),\"<0>\",temp_str,\"<1>\",temp_str_2,\"<2>\",ShipName(IdToShip(HullDelEndId)),\"<3>\",StarName(GalaxyStar(HullEndStarId)),\"<4>\",TransHullCost));",
                        "            ShipMoney(Player(),ShipMoney(Player())+TransHullCost);",
                        "            Sound('Sound.Sell');",
                        "        }",
                        "        //Все три прибывших корпуса были украдены - бать, вы лох",
                        "        else if(temp_int_5==3)",
                        "        {",
                        "            CustomEther('MailFailed',0,'',Format(CT(\"Script.Mod_ExpPilotBridge.1202\"),\"<0>\",TransHullCost));",
                        "            ShipMoney(Player(),ShipMoney(Player())+TransHullCost);",
                        "            Sound('Sound.Sell');",
                        "        }",
                        "    }",
                        "    //Запускаем обработчик спавна воров для украденных корпусов",
                        "    if(temp_int_5)HullWasStolenThiefCreate(1);",
                        "    //Переносим успешно доставленные корпуса на планету/станцию, формируем строку с их названиями",
                        "    for(i=1;i<=temp_int_6;i=i+1)",
                        "    {",
                        "        temp_dword=GetItemFromVault('HullDelServ_'+i);",
                        "        if(HullEndType==3)AddItemToStorage(IdToPlanet(HullDelEndId),temp_dword);",
                        "        if(HullEndType==4)AddItemToStorage(IdToShip(HullDelEndId),temp_dword);",
                        "        //Запоминаем событие, которое случится с доставленным корпусом при надевании его игроком (также запоминаем его местонахождение)",
                        "        temp_str_4=''+Id(temp_dword)+','+HullDelEndId+'*'+HullEndType+'&'+GAddTArray[i];",
                        "        ArrayAdd(GHullsWaitArray,temp_str_4);",
                        "    }",
                        "    ArrayClear(GAddTArray);",
                        "    temp_dword_4=0;",
                        "    HullOnWay=0;",
                        "    HullDelTime=0;",
                        "    HullDelTimeStart=0;",
                        "    HullDelTimeExp=0;",
                        "    HullDelFromId=0;",
                        "    HullFromStarId=0;",
                        "    HullDelFromStr='';",
                        "    HullDelEndId=0;",
                        "    HullEndStarId=0;",
                        "    TransHullCost=0;",
                        "    HullWasStolen=0;",
                        "    HullFromStExist=0;",
                        "    HullEndStExist=0;",
                        "    StartHullDelTechLvl=0;",
                        "    temp_str='';",
                        "    temp_str_2='';",
                        "    temp_str_3='';",
                        "    temp_str_4='';",
                        "  }",
                        "}",
                        "//Обработчик победы/провала скриптового квеста тюрьмы",
                        "if(GQuestStatus == 2)",
                        "{",
                        "    if(RelationToRanger(GetShipPlanet(Player()), Player()) < 40) RelationToRanger(GetShipPlanet(Player()), Player(), 40);",
                        "    GKillQuestCheck = 2;",
                        "    GotoGov(2);",
                        "    exit;",
                        "}",
                        "else if(GQuestStatus == 3)",
                        "{",
                        "    GKillQuestCheck = -1;",
                        "    temp_dword_4 = GetShipPlanet(Player());",
                        "    ExtremalTakeOff();",
                        "    exit;",
                        "}",
                        "if(CurTurn() == 301) {",
                        "    Tips(19);",
                        "    Tips(20);",
                        "}",
                        "if(lastTurn != CurTurn()) {",
                        "  //Запоминаем ход срабатывания терна, чтобы избежать лишних срабатываний за ход (которые случаются)",
                        "  //Нельзя делать это в предыдущем Op, т.к. тогда не будет работать автосрабатывание терна после завершения скриптового квеста",
                        "  lastTurn = CurTurn();",
                        "  ",
                        "  //Для удобства сразу запоминаем текущий ГТУ в отдельную переменную",
                        "  GTL = GalaxyTechLevel();",
                        "  ",
                        "  //Проверка на появление игрока в системе с Уитли (срабатывает один раз за игровую партию)",
                        "  if(GScriptWheatley == -1)",
                        "  {",
                        "      if(ShipStar(Player()) == GalaxyStar(ScriptItemData(Script_Wheatley, 3))) GScriptWheatley = 1;",
                        "  }",
                        "  ",
                        "  //Смена отношения на враждебное с планетой, с которой игрок совершил побег",
                        "  if(GKillQuestCheck == -1)",
                        "  {",
                        "      RelationToRanger(temp_dword_4, Player(), 0);",
                        "      GKillQuestCheck = 0;",
                        "  }",
                        "  ",
                        "  //Таймер и провал квеста на убийство подставившего игрока пирата",
                        "  if(GKillQuestCheck == 3)",
                        "  {",
                        "      if(ETimeLeft > CurTurn())",
                        "      {",
                        "          CustomEther('QuestNormal', 3, 'CustomQuestKillBridge', CT(\"Script.Mod_ExpPilotBridge.1273\") + CT('FormInfo.br') + CT(\"Script.Mod_ExpPilotBridge.1272\") + (ETimeLeft - CurTurn()) + CT(\"Script.Mod_ExpPilotBridge.1271\") + CT('FormInfo.br') + CT(\"Script.Mod_ExpPilotBridge.1260\") + PlanetName(IdToPlanet(EQuestPlanet)) + CT(\"Script.Mod_ExpPilotBridge.1259\") + StarName(PlanetToStar(IdToPlanet(EQuestPlanet))) + '</color>)' + CT('FormInfo.br') + ' ' + CT('FormInfo.br') + GEQuestText);",
                        "      }",
                        "      if(ETimeLeft <= CurTurn())",
                        "      {",
                        "          CustomEther('QuestCancel', 5, 'CustomQuestKillBridge', CT(\"Script.Mod_ExpPilotBridge.1394\") + CT('FormInfo.br') + CT(\"Script.Mod_ExpPilotBridge.1260\") + PlanetName(IdToPlanet(EQuestPlanet)) + CT(\"Script.Mod_ExpPilotBridge.1259\") + StarName(PlanetToStar(IdToPlanet(EQuestPlanet))) + '</color>)' + CT('FormInfo.br') + ' ' + CT('FormInfo.br') + GEQuestText);",
                        "          NewsAdd(CT(\"Script.Mod_ExpPilotBridge.1280\") + PlanetName(IdToPlanet(EQuestPlanet)) + '</color>.' + CT('FormInfo.br') + CT(\"Script.Mod_ExpPilotBridge.1279\"));",
                        "  ",
                        "          RelationToRanger(IdToPlanet(EQuestPlanet), Player(), min(10, RelationToRanger(IdToPlanet(EQuestPlanet), Player())));",
                        "          NoTalkToShip(IdToShip(ETargetShip), 0);",
                        "          GCustomQuestsFailed = GCustomQuestsFailed + 1;",
                        "          ShipDeleteCustomShipInfo(IdToShip(ETargetShip), 'PlayerBridge_IllWisherInfo');",
                        "  ",
                        "          GEQuestText = '';",
                        "          ETargetShip = 0;",
                        "          EQuestPlanet = 0;",
                        "          EQuestReward = 0;",
                        "          EQuestExpReward = 0;",
                        "          ETimeLeft = 0;",
                        "          GKillQuestCheck = 0;",
                        "      }",
                        "  }",
                        "  //Полное снятие преследования, если все корабли преследователей перебиты или выведены из группы",
                        "  if(GCardPursueCheck > 0)",
                        "  {",
                        "      if(!GroupCount(DebtMG))",
                        "      {",
                        "          GShipJoinGlobal = 0;",
                        "          CardDebt = 0;",
                        "          GCardPursueCheck = 0;",
                        "      }",
                        "      else",
                        "      {",
                        "          for(i = 0; i < GroupCount(DebtMG); i = i + 1)",
                        "          {",
                        "              temp_dword_4 = GroupShip(DebtMG,i);",
                        "              //Заправляем и чиним пиратов, которые оказались на планете к концу хода",
                        "              if(GetShipPlanet(temp_dword_4) || GetShipRuins(temp_dword_4))",
                        "              {",
                        "                  ShipRepairEq(temp_dword_4);",
                        "                  ShipRefuel(temp_dword_4);",
                        "              }",
                        "          }",
                        "      }",
                        "  }",
                        "  ",
                        "  //Узнаём, что станции назначения и/или отправки груза покинули свою текущую систему",
                        "  if(transfer_day >= CurTurn())",
                        "  {",
                        "      if(LTargetType == 2 || LTargetType == 4)",
                        "      {",
                        "          if(LStationDExist != 1)",
                        "          {",
                        "              if(ShipInHyperSpace(IdToShip(point_3)))",
                        "              {",
                        "                  //Станция назначения доставки груза покинула систему",
                        "                  LStationDExist = 2;",
                        "                  point_3_name = ShipName(IdToShip(point_3));",
                        "              }",
                        "          }",
                        "          if(LStationSExist != 1)",
                        "          {",
                        "              if(ShipInHyperSpace(IdToShip(point_1_id)))",
                        "              {",
                        "                  //Станция отправки груза покинула систему",
                        "                  LStationSExist = 2;",
                        "                  point_1_name = ShipName(IdToShip(point_1_id));",
                        "              }",
                        "          }",
                        "      }",
                        "  }",
                        "  ",
                        "  //Узнаём, что станции назначения и/или отправки корпуса покинули свою текущую систему",
                        "  if(HullDelTime >= CurTurn())",
                        "  {",
                        "      if(HullFromType == 4 || HullEndType == 4)",
                        "      {",
                        "          if(HullEndStExist != 1)",
                        "          {",
                        "              if(ShipInHyperSpace(IdToShip(HullDelEndId)))",
                        "              {",
                        "                  //Станция назначения доставки корпуса покинула систему",
                        "                  HullEndStExist = 2;",
                        "                  HullEndName = ShipName(IdToShip(HullDelEndId));",
                        "              }",
                        "          }",
                        "          if(HullFromStExist != 1)",
                        "          {",
                        "              if(ShipInHyperSpace(IdToShip(HullDelFromId)))",
                        "              {",
                        "                  //Станция отправки корпуса покинула систему",
                        "                  HullFromStExist = 2;",
                        "                  HullFromName = ShipName(IdToShip(HullDelFromId));",
                        "              }",
                        "          }",
                        "      }",
                        "  }",
                        "  ",
                        "  //Перебираем все галактические эвенты, совершаем необходимые действия",
                        "  for(j = GalaxyEvents() - 1; j >= 0; j = j - 1)",
                        "  {",
                        "      if(GalaxyEventDate(j) < CurTurn()) break;",
                        "      temp_str_4 = GalaxyEventType(j);",
                        "      if(temp_str_4 == 'RuinsDestroyed')",
                        "      {",
                        "          //Узнаём, что станции назначения и/или отправки груза были уничтожены",
                        "          if(transfer_day >= CurTurn())",
                        "          {",
                        "              if(LTargetType == 2 || LTargetType == 4)",
                        "              {",
                        "                  if(GalaxyEventData(j, 1) == point_3)",
                        "                  {",
                        "                      //Была уничтожена станция назначения доставки груза",
                        "                      LStationDExist = 1; //Не смотрите на 1 - это значит как раз то, что станция уничтожена",
                        "                      point_3_name = GalaxyEventsTextData(j, 0);",
                        "                  }",
                        "                  if(GalaxyEventData(j, 1) == point_1_id)",
                        "                  {",
                        "                      //Была уничтожена станция отправки груза",
                        "                      LStationSExist = 1;",
                        "                      point_1_name = GalaxyEventsTextData(j, 0);",
                        "                  }",
                        "              }",
                        "          }",
                        "  ",
                        "          //Узнаём, что станции назначения и/или отправки корпуса были уничтожены",
                        "          if(HullDelTime >= CurTurn())",
                        "          {",
                        "              if(HullFromType == 4 || HullEndType == 4)",
                        "              {",
                        "                  if(GalaxyEventData(j, 1) == HullDelEndId)",
                        "                  {",
                        "                      //Была уничтожена станция назначения доставки корпуса",
                        "                      HullEndStExist = 1;",
                        "                      HullEndName = GalaxyEventsTextData(j, 0);",
                        "                  }",
                        "                  if(GalaxyEventData(j, 1) == HullDelFromId)",
                        "                  {",
                        "                      //Была уничтожена станция отправки корпуса",
                        "                      HullFromStExist = 1;",
                        "                      HullFromName = GalaxyEventsTextData(j, 0);",
                        "                  }",
                        "              }",
                        "          }",
                        "  ",
                        "          //Пересобираем массив с доставленными корпусами в случае уничтожения доставочной станции",
                        "          if(ArrayDim(GHullsWaitArray) > 1)",
                        "          {",
                        "              temp_dword_1 = 0;",
                        "              //Проверяем, была ли взорвана станция с корпусом",
                        "              for(i = 1; i < ArrayDim(GHullsWaitArray); i = i + 1)",
                        "              {",
                        "                  temp_dword=substr(GHullsWaitArray[i],findsubstr(GHullsWaitArray[i],',')+1,(findsubstr(GHullsWaitArray[i],'*')-findsubstr(GHullsWaitArray[i],',')-1));",
                        "                  if(GalaxyEventData(j,1)==temp_dword)",
                        "                  {",
                        "                      if(ArrayDim(GHullsWaitArray)==2) ArrayClear(GHullsWaitArray);",
                        "                      else",
                        "                      {",
                        "                          GHullsWaitArray[i]=-1;",
                        "                          temp_dword_1=1;",
                        "                      }",
                        "                  }",
                        "              }",
                        "              //Пересобираем массив, исключаем пропавшие со склада корпуса",
                        "              if(temp_dword_1)",
                        "              {",
                        "                  ArrayClear(GAddTArray2);",
                        "                  for(i=1; i<ArrayDim(GHullsWaitArray); i=i+1)",
                        "                  {",
                        "                      if(GHullsWaitArray[i]!=-1) ArrayAdd(GAddTArray2,GHullsWaitArray[i]);",
                        "                  }",
                        "                  ArrayClear(GHullsWaitArray);",
                        "                  for(i=1; i<ArrayDim(GAddTArray2); i=i+1)",
                        "                  {",
                        "                      ArrayAdd(GHullsWaitArray,GAddTArray2[i]);",
                        "                  }",
                        "                  ArrayClear(GAddTArray2);",
                        "              }",
                        "          }",
                        "      }",
                        "      //Счётчики уничтоженных кораблей",
                        "      else if(temp_str_4 == 'PlayerKillsShip')",
                        "      {",
                        "          UpdateKillShipsStatistic(GalaxyEventData(j, 0), GalaxyEventData(j, 5), GalaxyEventsTextData(j, 2), GalaxyEventsTextData(j, 0), GalaxyEventsTextData(j, 1), GalaxyEventData(j, 3), 0);",
                        "      }",
                        "      //Счётчики уничтоженных кораблей в гипере",
                        "      else if(temp_str_4 == 'LabeledShipKilledInAB')",
                        "      {",
                        "          tstr2 = GalaxyEventsTextData(j, 0);",
                        "          if(ParsCountFromString(tstr2, ',') >= 6)",
                        "          {",
                        "              if(~findsubstr(GetParFromString(tstr2, ',', 2, 0), '_Friend')) continue; //Пропускаем уничтоженные в гипере, но дружественные по отношению к игроку корабли",
                        "              UpdateKillShipsStatistic(GetParFromString(tstr2, ',', 0, 0), GetParFromString(tstr2, ',', 1, 0), GetParFromString(tstr2, ',', 2, 0), GetParFromString(tstr2, ',', 3, 0), GetParFromString(tstr2, ',', 4, 0), GetParFromString(tstr2, ',', 5, 0), 1);",
                        "              ShipStatistic(Player(), 7, ShipStatistic(Player(), 7) - 1);",
                        "          }",
                        "      }",
                        "      //Прочие события",
                        "      else if(temp_str_4 == 'PlayerBuysEquipment') money_equip = money_equip + GalaxyEventData(j, 1);",
                        "      else if(temp_str_4 == 'PlayerFinishesPlanetaryBattle')",
                        "      {",
                        "          pb_money = pb_money + GalaxyEventData(j, 1);",
                        "          pb_exp = pb_exp + GalaxyEventData(j, 2);",
                        "      }",
                        "      else if(temp_str_4 == 'PlayerFinishesQuest')",
                        "      {",
                        "          money_quest = money_quest + GalaxyEventData(j, 2);",
                        "          exp_quest = exp_quest + GalaxyEventData(j, 3);",
                        "      }",
                        "      else if(temp_str_4 == 'PlayerExtortsMoney')",
                        "      {",
                        "          temp_int_1 = GalaxyEventData(j, 0);",
                        "          money_take = money_take + temp_int_1;",
                        "      }",
                        "      else if(temp_str_4 == 'PlayerAcceptsMoneyForTruce')",
                        "      {",
                        "          temp_int_1 = GalaxyEventData(j, 0);",
                        "          money_take_peace = money_take_peace + temp_int_1;",
                        "      }",
                        "      else if(temp_str_4 == 'PlayerBuysGoodsFromPlanet')",
                        "      {",
                        "          temp_int_1 = GalaxyEventData(j, 2);",
                        "          money_buys = money_buys + temp_int_1;",
                        "      }",
                        "      else if(temp_str_4 == 'PlayerSellsGoodsToPlanet')",
                        "      {",
                        "          temp_int_1 = GalaxyEventData(j, 2);",
                        "          money_sale = money_sale + temp_int_1;",
                        "      }",
                        "      else if(temp_str_4 == 'PlayerLiberatesSystem')",
                        "      {",
                        "          if(GalaxyEventData(j, 1) == 0) sys_coal = sys_coal + 1;",
                        "          if(GalaxyEventData(j, 1) == 2) sys_pirate = sys_pirate + 1;",
                        "      }",
                        "  }",
                        "  ",
                        "  //Обработчики прерывания доставки груза",
                        "  if(transfer_day > CurTurn())",
                        "  {",
                        "      //Груз был в пути на планету отправки, но её захватили (груз перенаправлен в родную систему)",
                        "      if(LTargetType==3)",
                        "      {",
                        "          if(StarOwner(PlanetToStar(IdToPlanet(point_1_id)))==1 || StarCustomFaction(PlanetToStar(IdToPlanet(point_1_id)))!='')",
                        "          {",
                        "              CustomEther('MailFailed',0,'',Format(CT(\"Script.Mod_ExpPilotBridge.1529\"),\"<0>\",PlanetName(IdToPlanet(point_1_id)),\"<1>\",StarName(PlanetToStar(IdToPlanet(point_1_id))),\"<2>\",StarName(PlanetToStar(GetShipHomePlanet(Player()))),\"<3>\",PlanetName(GetShipHomePlanet(Player()))));",
                        "              CargoLostChanceCalcHome();",
                        "              point_3=Id(GetShipHomePlanet(Player()));",
                        "              LTargetType=5;",
                        "          }",
                        "      }",
                        "      //Груз был в пути на станцию отправки, но она была уничтожена/улетела (груз перенаправлен в родную систему)",
                        "      if(LTargetType==4)",
                        "      {",
                        "          if(LStationSExist)",
                        "          {",
                        "              //Станция отправки была уничтожена",
                        "              if(LStationSExist==1)",
                        "              {",
                        "                  temp_str='</color>'+Format(CT(\"Script.Mod_ExpPilotBridge.1520\"),\"<0>\",StarName(GalaxyStar(point_1_star)));",
                        "                  temp_str_2='</color>'+CT(\"Script.Mod_ExpPilotBridge.1476\");",
                        "              }",
                        "              //Станция отправки покинула систему",
                        "              else",
                        "              {",
                        "                  temp_str='</color>'+Format(CT(\"Script.Mod_ExpPilotBridge.1518\"),\"<0>\",StarName(GalaxyStar(point_1_star)));",
                        "                  temp_str_2='</color>'+CT(\"Script.Mod_ExpPilotBridge.1517\");",
                        "              }",
                        "              CustomEther('MailFailed',0,'',Format(CT(\"Script.Mod_ExpPilotBridge.1528\"),\"<0>\",point_1_name,\"<1>\",temp_str,\"<2>\",temp_str_2,\"<3>\",StarName(PlanetToStar(GetShipHomePlanet(Player()))),\"<4>\",PlanetName(GetShipHomePlanet(Player()))));",
                        "              CargoLostChanceCalcHome();",
                        "              point_3=Id(GetShipHomePlanet(Player()));",
                        "              LTargetType=5;",
                        "          }",
                        "      }",
                        "      //Обработчик прерывания изначальной доставки на планету",
                        "      if(LTargetType==1)",
                        "      {",
                        "          if(point_1==3)",
                        "          {",
                        "              if(StarOwner(PlanetToStar(IdToPlanet(point_3)))==1 || StarCustomFaction(PlanetToStar(IdToPlanet(point_3)))!='')",
                        "              {",
                        "                  //Груз был в пути на планету доставки, но её захватили, а груз перенаправили на планету отправки",
                        "                  if(StarOwner(PlanetToStar(IdToPlanet(point_1_id)))!=1 && StarCustomFaction(PlanetToStar(IdToPlanet(point_1_id)))=='')",
                        "                  {",
                        "                      CustomEther('MailFailed',0,'',Format(CT(\"Script.Mod_ExpPilotBridge.1527\"),\"<0>\",StarName(PlanetToStar(IdToPlanet(point_3))),\"<1>\",PlanetName(IdToPlanet(point_3)),\"<2>\",PlanetName(IdToPlanet(point_1_id)),\"<3>\",StarName(PlanetToStar(IdToPlanet(point_1_id)))));",
                        "                      CargoLostChanceCalc();",
                        "                      point_3=point_1_id;",
                        "                      LTargetType=3;",
                        "                  }",
                        "                  //Груз был в пути на планету доставки, но её захватили, а планета отправки уже была захвачена (груз перенаправлен в родную систему)",
                        "                  else",
                        "                  {",
                        "                      CustomEther('MailFailed',0,'',Format(CT(\"Script.Mod_ExpPilotBridge.1526\"),\"<0>\",StarName(PlanetToStar(IdToPlanet(point_3))),\"<1>\",PlanetName(IdToPlanet(point_3)),\"<2>\",PlanetName(IdToPlanet(point_1_id)),\"<3>\",StarName(PlanetToStar(IdToPlanet(point_1_id))),\"<4>\",StarName(PlanetToStar(GetShipHomePlanet(Player()))),\"<5>\",PlanetName(GetShipHomePlanet(Player()))));",
                        "                      CargoLostChanceCalcHome();",
                        "                      point_3=Id(GetShipHomePlanet(Player()));",
                        "                      LTargetType=5;",
                        "                  }",
                        "              }",
                        "          }",
                        "          if(point_1==4)",
                        "          {",
                        "              if(StarOwner(PlanetToStar(IdToPlanet(point_3)))==1 || StarCustomFaction(PlanetToStar(IdToPlanet(point_3)))!='')",
                        "              {",
