                        "        else",
                        "        {",
                        "            if(temp_int_4==1)temp_int_2=round((0.00315*temp_int_7)*500.0);",
                        "            else if(temp_int_4==2)temp_int_2=round((0.00315*temp_int_7)*666.0);",
                        "            else if(temp_int_4==3)temp_int_2=round((0.00315*temp_int_7)*835.0);",
                        "            else if(temp_int_4==4)temp_int_2=round((0.00315*temp_int_7)*1000.0);",
                        "            else if(temp_int_4==5)temp_int_2=round((0.00315*temp_int_7)*1330.0);",
                        "            else if(temp_int_4==6)temp_int_2=round((0.00315*temp_int_7)*1660.0);",
                        "            else if(temp_int_4==7)temp_int_2=round((0.00315*temp_int_7)*2000.0);",
                        "            else if(temp_int_4>=8)temp_int_2=round((0.00315*temp_int_7)*2500.0);",
                        "        }",
                        "    }",
                        "    //Высчитываем минимальную стоимость исходя из количества доставленных/украденных корпусов",
                        "    //Были украдены все корпуса",
                        "    if(HullOnWay==1 || (HullOnWay==2 && temp_int_5==2) || (HullOnWay==3 && temp_int_5==3))",
                        "    {",
                        "        //Установка минимальной цены (межсистемной)",
                        "        if(temp_int_3)",
                        "        {",
                        "            if(TransHullCost<1250 && (temp_int_4==1 || temp_int_4==2 || temp_int_4==3))TransHullCost=1250;",
                        "            else if(TransHullCost<3125 && (temp_int_4==4 || temp_int_4==5 || temp_int_4==6))TransHullCost=3125;",
                        "            else if(TransHullCost<5000 && (temp_int_4==7 || temp_int_4==8))TransHullCost=5000;",
                        "        }",
                        "        //Установка минимальной цены (внутрисистемной)",
                        "        else",
                        "        {",
                        "            if(TransHullCost<500 && (temp_int_4==1 || temp_int_4==2 || temp_int_4==3))TransHullCost=500;",
                        "            else if(TransHullCost<1000 && (temp_int_4==4 || temp_int_4==5 || temp_int_4==6))TransHullCost=1000;",
                        "            else if(TransHullCost<2000 && (temp_int_4==7 || temp_int_4==8))TransHullCost=2000;",
                        "        }",
                        "    }",
                        "    //Был украден один из двух корпусов",
                        "    if(HullOnWay==2 && temp_int_5==1)",
                        "    {",
                        "        //Установка минимальной цены (межсистемной)",
                        "        if(temp_int_3)",
                        "        {",
                        "            if((TransHullCost+temp_int_2)<1250 && (temp_int_4==1 || temp_int_4==2 || temp_int_4==3))TransHullCost=1250/2;",
                        "            else if((TransHullCost+temp_int_2)<3125 && (temp_int_4==4 || temp_int_4==5 || temp_int_4==6))TransHullCost=3125/2;",
                        "            else if((TransHullCost+temp_int_2)<5000 && (temp_int_4==7 || temp_int_4==8))TransHullCost=5000/2;",
                        "        }",
