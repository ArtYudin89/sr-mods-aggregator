                        "    //Стоимость найма салаги",
                        "    else if(temp_int==3)TransHullCost=(((TransHullCost*40)/100)*25)/100;",
                        "    ",
                        "    if(temp_int_6>1)temp_str=temp_str_3;",
                        "    if(HullEndType==3)temp_str_2=CT(\"Script.Mod_ExpPilotBridge.1211\");",
                        "    if(HullEndType==4)temp_str_2=CT(\"Script.Mod_ExpPilotBridge.1210\");",
                        "    ",
                        "    if(HullOnWay==1)",
                        "    {",
                        "        //Корпус, прибывший на место, доставлен успешно",
                        "        if(temp_int_5==0 && HullEndType==3) CustomEther('MailGood',0,'',Format(CT(\"Script.Mod_ExpPilotBridge.1209\"),\"<0>\",temp_str,\"<1>\",temp_str_2,\"<2>\",PlanetName(IdToPlanet(HullDelEndId)),\"<3>\",StarName(GalaxyStar(HullEndStarId))));",
                        "        else if(temp_int_5==0 && HullEndType==4) CustomEther('MailGood',0,'',Format(CT(\"Script.Mod_ExpPilotBridge.1209\"),\"<0>\",temp_str,\"<1>\",temp_str_2,\"<2>\",ShipName(IdToShip(HullDelEndId)),\"<3>\",StarName(GalaxyStar(HullEndStarId))));",
                        "        //Корпус, прибывший на место, был украден",
