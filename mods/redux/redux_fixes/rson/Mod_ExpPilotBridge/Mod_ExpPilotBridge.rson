                        "                else temp_str_4=Format(CT(\"Script.Mod_ExpPilotBridge.1544\"),\"<0>\",StarName(PlanetToStar(IdToPlanet(point_3))),\"<1>\",temp_str_4);",
                        "                temp_int_2 = 1;",
