                        "                      CustomEther('MailFailed',0,'',Format(CT(\"Script.Mod_ExpPilotBridge.1524\"),\"<0>\",StarName(PlanetToStar(IdToPlanet(point_3))),\"<1>\",PlanetName(IdToPlanet(point_3)),\"<2>\",point_1_name,\"<3>\",temp_str,\"<4>\",temp_str_2,\"<5>\",StarName(PlanetToStar(GetShipHomePlanet(Player()))),\"<6>\",PlanetName(GetShipHomePlanet(Player()))));",
                        "                      CargoLostChanceCalcHome();",
