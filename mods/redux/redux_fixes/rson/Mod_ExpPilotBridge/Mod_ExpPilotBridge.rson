                        "            if(count2==1 || count2==2 || count2==3)temp_str_4='1'+Rnd(1,4)+'01'+Rnd(21,35)+'---';",
                        "            //Событие разведки в доминаторских системах",
                        "            if(count2==4)temp_str_4='1'+Rnd(1,4)+'02'+Rnd(0,2)+Rnd(1,2)+Rnd(10,26)+Rnd(0,1);",
