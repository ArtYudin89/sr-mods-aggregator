                        "  }",
                        "  //Постройка ТЦ, если их нет в Галактике",
                        "  if(InitExpTC) {",
                        "      if(bld_system_Id_TC && wait_day_3<=CurTurn()) {",
                        "          AddDialogInject('ProjTC','',CT(\"Script.Mod_ExpPilotBridge.1586\"),20);",
                        "      }",
                        "      if(wait_day_3>CurTurn()) {",
                        "          AddDialogInject('','',CT(\"Script.Mod_ExpPilotBridge.1585\"),20);",
                        "          AddDialogBlock(CT(\"Script.Mod_ExpPilotBridge.1585\"),1);",
                        "      }",
                        "  }",
                        "  AddDialogInject('Galanet','',CT(\"Script.Mod_ExpPilotBridge.701\"),-1);",
                        "  AddDialogBlock(CT(\"Script.Mod_ExpPilotBridge.701\"),0);",
                        "}",
                        "//Главный экран мостика",
                        "if(PlayerBridge() == 3)",
                        "{",
                        "    //Игрок зашёл на мостик, находясь при этом в космосе",
                        "    if(!GetShipPlanet(GetShipRuins(Player())) && !GetShipRuins(GetShipRuins(Player())))",
                        "    {",
                        "        //Если мостик не ТИ, то добавляем реплику с текстом",
                        "        AddDialogInject('BoardComp', CT(\"Script.Mod_ExpPilotBridge.653\"), CT(\"Script.Mod_ExpPilotBridge.154\"), 0, 1);",
                        "        AddDialogInject('DialogMusic', '', CT(\"Script.Mod_ExpPilotBridge.1592\"), 1);",
                        "    }",
                        "    //Игрок сидит на планете или станции",
                        "    else",
                        "    {",
                        "        //Если мостик не ТИ, то добавляем реплику с текстом",
                        "        AddDialogBlock(CT(\"Script.Mod_ExpPilotBridge.1461\"), 2);",
                        "        AddDialogInject('BoardComp', CT(\"Script.Mod_ExpPilotBridge.653\"), CT(\"Script.Mod_ExpPilotBridge.154\"), 0, 1);",
                        "        if(GotoGov()) AddDialogBlock(CT(\"Script.Mod_ExpPilotBridge.1462\"), 1);",
                        "",
                        "        temp_dword = GetShipPlanet(GetShipRuins(Player()));",
                        "        if(temp_dword)",
                        "        {",
                        "            //Делаем проверку на отношение планеты к рейнджеру",
                        "            if(PlanetOwner(temp_dword) != 7)",
                        "            {",
                        "                if(RelationToRanger(temp_dword, Player()) <= 9)",
                        "                {",
                        "                    AddDialogBlock(CT(\"Script.Mod_ExpPilotBridge.1462\"), 1);",
                        "                }",
                        "            }",
                        "            //Пиратские планеты не имеют своего отношения (вернее их реальное отношение не применяется к игроку, пока планета пиратская) и наследуют его от Роджерии",
                        "            else",
                        "            {",
                        "                if(RelationToRanger(PlanetPirateClan(), Player()) <= 9)",
                        "                {",
                        "                    AddDialogBlock(CT(\"Script.Mod_ExpPilotBridge.1462\"), 1);",
                        "                }",
                        "            }",
                        "        }",
                        "        else if(!ShipInHyperSpace(GetShipRuins(GetShipRuins(Player()))))",
                        "        {",
                        "            //Проверка на блокировку игрока на базе в ExpHullsBases",
                        "            if(IsScriptActive('Mod_ExpHullsBases'))",
                        "            {",
                        "                if(GetValueFromScript('Mod_ExpHullsBases', 'jumpCheck') != '') AddDialogBlock(CT(\"Script.Mod_ExpPilotBridge.1462\"), 1);",
                        "            }",
                        "        }",
                        "",
                        "        AddDialogInject('LunchIt', '', CT(\"Script.Mod_ExpPilotBridge.1462\"), -1);",
                        "        AddDialogInject('LeaveShip', '', CT(\"Script.Mod_ExpPilotBridge.1460\"), -2);",
                        "        AddDialogInject('DialogMusic', '', CT(\"Script.Mod_ExpPilotBridge.1592\"), 1);",
                        "    }",
                        "}",
                        "//Мостик \"Тени Империи\" (используется как главный экран для подстановки перехода в \"Бортовой компьютер\" и т.д.)",
                        "else if(PlayerBridge() == 1)",
                        "{",
                        "    //Игрок зашёл на мостик, находясь при этом в космосе",
                        "    if(!GetShipPlanet(GetShipRuins(Player())) && !GetShipRuins(GetShipRuins(Player())))",
                        "    {",
                        "        //Если мостик ТИ, то добавляем реплику без текста",
                        "        AddDialogInject('BoardComp', '', CT(\"Script.Mod_ExpPilotBridge.154\"), 0);",
                        "        AddDialogInject('DialogMusic', '', CT(\"Script.Mod_ExpPilotBridge.1592\"), 1);",
                        "    }",
                        "    //Игрок сидит на планете или станции",
                        "    else",
                        "    {",
                        "        //Если мостик ТИ, то добавляем реплику без текста",
                        "        AddDialogBlock(CT(\"Script.Mod_ExpPilotBridge.1461\"), 2);",
                        "        AddDialogInject('BoardComp', '', CT(\"Script.Mod_ExpPilotBridge.154\"), 0);",
                        "        if(GotoGov()) AddDialogBlock(CT(\"Script.Mod_ExpPilotBridge.1462\"), 1);",
                        "",
                        "        temp_dword = GetShipPlanet(GetShipRuins(Player()));",
                        "        if(temp_dword)",
                        "        {",
                        "            //Делаем проверку на отношение планеты к рейнджеру",
                        "            if(PlanetOwner(temp_dword) != 7)",
                        "            {",
                        "                if(RelationToRanger(temp_dword, Player()) <= 9)",
                        "                {",
                        "                    AddDialogBlock(CT(\"Script.Mod_ExpPilotBridge.1462\"), 1);",
                        "                }",
                        "            }",
                        "            //Пиратские планеты не имеют своего отношения (вернее их реальное отношение не применяется к игроку, пока планета пиратская) и наследуют его от Роджерии",
                        "            else",
                        "            {",
                        "                if(RelationToRanger(PlanetPirateClan(), Player()) <= 9)",
                        "                {",
                        "                    AddDialogBlock(CT(\"Script.Mod_ExpPilotBridge.1462\"), 1);",
                        "                }",
                        "            }",
                        "        }",
                        "        else if(!ShipInHyperSpace(GetShipRuins(GetShipRuins(Player()))))",
                        "        {",
                        "            //Проверка на блокировку игрока на базе в ExpHullsBases",
                        "            if(IsScriptActive('Mod_ExpHullsBases'))",
                        "            {",
                        "                if(GetValueFromScript('Mod_ExpHullsBases', 'jumpCheck') != '') AddDialogBlock(CT(\"Script.Mod_ExpPilotBridge.1462\"), 1);",
                        "            }",
                        "        }",
                        "",
                        "        AddDialogInject('DialogMusic', '', CT(\"Script.Mod_ExpPilotBridge.1592\"), 1);",
                        "        AddDialogInject('LunchIt', '', CT(\"Script.Mod_ExpPilotBridge.1462\"), -1);",
                        "        AddDialogInject('LeaveShip', '', CT(\"Script.Mod_ExpPilotBridge.1460\"), -2);",
                        "    }",
                        "}"
                    ],
                    "#": 269,
                    "Type": "Top",
                    "Parent": -1,
                    "Pos.x": 180,
                    "Pos.y": 1535
                },
                {
                    "Name": "",
                    "Code.Type": "Turn",
                    "Code": [
                        "if(ShipStar(CurShip) == ShipStar(Player())) {",
                        "  //Дублируем запуск форсажа в стейт код, чтобы в конце хода игрок мог видеть, кто из пиратов его использует",
                        "  //В противном случае боты всегда вырубают форсаж к концу хода",
                        "  if(GCardPursueCheck > 1)",
                        "  {",
                        "      if(Dist(CurShip, Player()) > 190)",
                        "      {",
                        "          if(OrderForsage(Player()) || ShipSpeed(Player()) > ShipSpeed(CurShip)) OrderForsage(CurShip, 1);",
                        "      }",
                        "  }",
                        "}"
                    ],
                    "#": 495,
                    "Type": "Top",
                    "Parent": -1,
                    "Pos.x": 80
                },
                {
                    "Name": "",
                    "Code.Type": "Turn",
                    "Code": [
                        "if(!OrderLock(CurShip)) OrderLock(CurShip,1);",
                        "if(GetShipPlanet(CurShip)) OrderTakeOff(CurShip);",
                        "else if(ShipInNormalSpace(CurShip)) {",
                        "    if(CoordX(CurShip)!=Coord_X_TC && CoordY(CurShip)!=Coord_Y_TC) {",
                        "        OrderMove(CurShip, Coord_X_TC, Coord_Y_TC);",
                        "    }",
                        "    else {",
                        "        if(OrderLock(CurShip)) OrderLock(CurShip,0);",
                        "        ShipOut(CurShip);",
                        "    }",
                        "}",
                        "",
                        "if(!IsPlayer(CurShip)) ShipOut(CurShip);"
                    ],
                    "#": 496,
                    "Type": "Top",
                    "Parent": -1,
                    "Pos.x": 160
                },
                {
                    "Name": "",
                    "Code.Type": "Turn",
                    "Code": [
                        "temp_str='';",
                        "temp_dword=GalaxyStar(GAnswerData);",
                        "temp_int=0;",
                        "for(i=0;i<StarItems(temp_dword);i=i+1)",
                        "{",
                        "    temp_int=temp_int+1;",
                        "    temp_dword_2=StarItems(temp_dword,i);",
                        "    if(ItemName(temp_dword_2)!='')temp_str=temp_str+'</color><clrEnd>'+temp_int+'. <color=0,50,200>'+DeleteTags(ItemName(temp_dword_2))+Format(CT(\"Script.Mod_ExpPilotBridge.1290\"),\"<0>\",ItemSize(temp_dword_2))+CT(\"Script.Mod_ExpPilotBridge.67\");",
                        "    else temp_str=temp_str+'</color><clrEnd>'+temp_int+'. <color=0,50,200>'+DeleteTags(Name(temp_dword_2))+Format(CT(\"Script.Mod_ExpPilotBridge.1290\"),\"<0>\",ItemSize(temp_dword_2))+CT(\"Script.Mod_ExpPilotBridge.67\");",
                        "}",
                        "temp_str=CT(\"Script.Mod_ExpPilotBridge.67\")+temp_str;",
                        "DChange(11);",
                        "exit;"
                    ],
                    "#": 497,
                    "Type": "Top",
                    "Parent": -1,
                    "Pos.x": -20,
                    "Pos.y": 950
                },
                {
                    "Name": "",
                    "Code.Type": "Turn",
                    "Code": [
                        "if(PirateWin()==0)",
                        "{",
                        "    temp_str=CT(\"Script.Mod_ExpPilotBridge.819\");",
                        "    temp_str_2='<clrEnd>*';",
                        "}",
                        "else",
                        "{",
                        "    temp_str='';",
                        "    temp_str_2='';",
                        "}",
                        "DefSplt='';",
                        "DChange(12);",
                        "exit;"
                    ],
                    "#": 498,
                    "Type": "Top",
                    "Parent": -1,
                    "Pos.x": 160,
                    "Pos.y": 950
                },
                {
                    "Name": "",
                    "Code.Type": "Turn",
                    "Code": [
                        "temp_int_4 = GAnswerData;",
                        "DChange(13);",
                        "exit;"
                    ],
                    "#": 499,
                    "Type": "Top",
                    "Parent": -1,
                    "Pos.x": 280,
                    "Pos.y": 950
                },
                {
                    "Name": "",
                    "Code.Type": "Turn",
                    "Code": [
                        "point_1=temp_array[temp_int_3];",
                        "point_1_id=Id(point_1);",
                        "point_1_star=temp_array_3[temp_int_3];",
                        "transfer_day=0;",
                        "ArrayClear(transfer_list_can);",
                        "point_2=GAnswerData;",
                        "",
                        "//Определение типа пункта доставки: 3 - планета, 4 - станция",
                        "//Не обращайте внимания на разницу point_2 и point_3 - это всё система прибытия",
                        "if(ObjectType(GAnswerData)==3)",
                        "{",
                        "    point_2_star=Id(PlanetToStar(GAnswerData))-1;",
                        "    point_3_name=CT(\"Script.Mod_ExpPilotBridge.777\")+PlanetName(GAnswerData);",
                        "    point_3_star_name=StarName(PlanetToStar(GAnswerData));",
                        "    LTargetType=1;",
                        "}",
                        "if(ObjectType(GAnswerData)==4)",
                        "{",
                        "    point_2_star=Id(ShipStar(GAnswerData))-1;",
                        "    point_3_name=Name(GAnswerData);",
                        "    point_3_star_name=StarName(ShipStar(GAnswerData));",
                        "    LTargetType=2;",
                        "}",
                        "",
                        "//Расчёт дистанции до системы назначения и времени в пути",
                        "full_distance=Dist2Star(GalaxyStar(point_1_star),GalaxyStar(point_2_star));",
                        "temp_int_1=round(sqrt(full_distance));",
                        "",
                        "//Определяем среднее (при выборе ускоренной) время доставки",
                        "if(!temp_int_1) transfer_day = 7;",
                        "else if(temp_int_1 && temp_int_1 <= 9) transfer_day = 10;",
                        "else",
                        "{",
                        "    if(GTL == 1) transfer_day=temp_int_1+(temp_int_1-1*(temp_int_1/20));",
                        "    else if(GTL == 2) transfer_day=temp_int_1+(temp_int_1-2*(temp_int_1/20));",
                        "    else if(GTL == 3) transfer_day=temp_int_1+(temp_int_1-3*(temp_int_1/20));",
                        "    else if(GTL == 4) transfer_day=temp_int_1+(temp_int_1-4*(temp_int_1/20));",
                        "    else if(GTL == 5) transfer_day=temp_int_1+(temp_int_1-5*(temp_int_1/20));",
                        "    else if(GTL == 6) transfer_day=temp_int_1+(temp_int_1-6*(temp_int_1/20));",
                        "    else if(GTL == 7) transfer_day=temp_int_1+(temp_int_1-7*(temp_int_1/20));",
                        "    else if(GTL == 8) transfer_day=temp_int_1+(temp_int_1-8*(temp_int_1/20));",
                        "}",
                        "",
                        "//Подсчёт веса грузов, а также составление массива предметов на складе пункта отправки",
                        "transfer_cargo_cost = 0;",
                        "transfer_cargo_size = 0;",
                        "for(i = 0; i < StorageItems(); i = i + 1)",
                        "{",
                        "    cur_item = StorageItems(i);",
                        "",
                        "    if(ItemType(cur_item) == t_Hull) continue;",
                        "    if(ItemType(cur_item) == t_UselessItem) //Запрещённые к перевозке предметы",
                        "    {",
                        "        if(int(CT('UselessItems.' + EquipmentImageName(cur_item) + '.NoDelivery'))) continue;",
                        "    }",
                        "",
                        "    if(StorageItemLocation(i) == point_1)",
                        "    {",
                        "        transfer_cargo_size = transfer_cargo_size + ItemSize(cur_item);",
                        "        ArrayAdd(transfer_list_can, cur_item);",
                        "    }",
                        "}",
                        "",
                        "//Переменные для подстановки в диалог",
                        "if(ObjectType(point_1) == 3) point_from = CT(\"Script.Mod_ExpPilotBridge.1002\")+' ';",
                        "if(ObjectType(point_1) == 4) point_from = '';",
                        "//Составляем строку со списком предметов, доступных для отправки со склада",
