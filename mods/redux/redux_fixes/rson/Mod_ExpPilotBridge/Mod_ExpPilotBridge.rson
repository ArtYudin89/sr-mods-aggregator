                        "  //2 - игрок вышел из тюрьмы - ему предлагают квест",
                        "  //3 - квест взят, находится в процессе выполнения",
                        "  //4 - квест выполнен, осталось забрать деньги",
                        "  ",
                        "  SkipGreeting();",
                        "  if(RelationToRanger(GetShipPlanet(Player()),Player())<50) RelationToRanger(GetShipPlanet(Player()),Player(),50);",
                        "  ",
                        "  //Определяем систему и планету для спавна пирата",
                        "  EQuestPlanet=0;",
                        "  if(StarOwner(StarNearbyStars(ShipStar(Player()),14))!=1 && StarCustomFaction(StarNearbyStars(ShipStar(Player()),14))=='')",
                        "  {",
                        "      while(EQuestPlanet==0)",
                        "      {",
                        "          for(i=0;i<StarPlanets(StarNearbyStars(ShipStar(Player()),14));i=i+1)",
                        "          {",
                        "              if(PlanetOwner(StarPlanets(StarNearbyStars(ShipStar(Player()),14),i))==6)continue;",
                        "              if(Rnd(1,100)<=50)",
                        "              {",
                        "                  EQuestPlanet=StarPlanets(StarNearbyStars(ShipStar(Player()),14),i);",
                        "                  break;",
                        "              }",
                        "          }",
                        "      }",
                        "  }",
                        "  if(StarOwner(StarNearbyStars(ShipStar(Player()),13))!=1 && StarCustomFaction(StarNearbyStars(ShipStar(Player()),13))=='' && EQuestPlanet==0)",
                        "  {",
                        "      while(EQuestPlanet==0)",
                        "      {",
                        "          for(i=0;i<StarPlanets(StarNearbyStars(ShipStar(Player()),13));i=i+1)",
                        "          {",
                        "              if(PlanetOwner(StarPlanets(StarNearbyStars(ShipStar(Player()),13),i))==6)continue;",
                        "              if(Rnd(1,100)<=50)",
                        "              {",
                        "                  EQuestPlanet=StarPlanets(StarNearbyStars(ShipStar(Player()),13),i);",
                        "                  break;",
                        "              }",
                        "          }",
                        "      }",
                        "  }",
                        "  if(StarOwner(StarNearbyStars(ShipStar(Player()),12))!=1 && StarCustomFaction(StarNearbyStars(ShipStar(Player()),12))=='' && EQuestPlanet==0)",
                        "  {",
                        "      while(EQuestPlanet==0)",
                        "      {",
                        "          for(i=0;i<StarPlanets(StarNearbyStars(ShipStar(Player()),12));i=i+1)",
                        "          {",
                        "              if(PlanetOwner(StarPlanets(StarNearbyStars(ShipStar(Player()),12),i))==6)continue;",
                        "              if(Rnd(1,100)<=50)",
                        "              {",
                        "                  EQuestPlanet=StarPlanets(StarNearbyStars(ShipStar(Player()),12),i);",
                        "                  break;",
                        "              }",
                        "          }",
                        "      }",
                        "  }",
                        "  if(StarOwner(StarNearbyStars(ShipStar(Player()),11))!=1 && StarCustomFaction(StarNearbyStars(ShipStar(Player()),11))=='' && EQuestPlanet==0)",
                        "  {",
                        "      while(EQuestPlanet==0)",
                        "      {",
                        "          for(i=0;i<StarPlanets(StarNearbyStars(ShipStar(Player()),11));i=i+1)",
                        "          {",
                        "              if(PlanetOwner(StarPlanets(StarNearbyStars(ShipStar(Player()),11),i))==6)continue;",
                        "              if(Rnd(1,100)<=50)",
                        "              {",
                        "                  EQuestPlanet=StarPlanets(StarNearbyStars(ShipStar(Player()),11),i);",
                        "                  break;",
                        "              }",
                        "          }",
                        "      }",
                        "  }",
                        "  ",
                        "  //Спавним пирата",
                        "  ETargetShip = BuyPirate(EQuestPlanet, 700);",
                        "  HullSeries(ShipItems(ETargetShip, 0), -1);",
                        "  ShipRefit(ETargetShip);",
                        "  ShipRefit(ETargetShip);",
                        "  ShipRefit(ETargetShip);",
                        "  //Добавляем жупи",
                        "  temp_int_3=CreateArt(t_ArtefactHull,ShipPilotRace(ETargetShip));",
                        "  AddItemToShip(ETargetShip,temp_int_3);",
                        "  ItemIsInUse(temp_int_3,ETargetShip,1);",
                        "  //Добавляем пси-ускоритель",
                        "  temp_int_3=CreateArt(t_ArtefactSpeed,ShipPilotRace(ETargetShip));",
                        "  AddItemToShip(ETargetShip,temp_int_3);",
                        "  ItemIsInUse(temp_int_3,ETargetShip,1);",
                        "  NoDropItem(temp_int_3,1);",
                        "  //Добавляем дроида младшего",
                        "  temp_int_3=CreateArt(t_ArtefactDroid,ShipPilotRace(ETargetShip));",
                        "  AddItemToShip(ETargetShip,temp_int_3);",
                        "  ItemIsInUse(temp_int_3,ETargetShip,1);",
                        "  ShipSkill(ETargetShip,0,3);",
                        "  ShipSkill(ETargetShip,1,3);",
                        "  ShipSkill(ETargetShip,2,1);",
                        "  ShipSkill(ETargetShip,3,1);",
                        "  ShipImproveItems(ETargetShip,7);",
                        "  ShipFreeFlight(ETargetShip);",
                        "  ETargetShip=Id(ETargetShip);",
                        "  ",
                        "  EQuestPlanet=Id(GetShipPlanet(Player()));",
                        "  ",
                        "  //Начало расчётов стоимости награды в кредитах идентично игровому (по крайней мере, я на это надеюсь)",
                        "  EQuestReward=round(min(0.01*RangersCapital(),0.01*ShipWealth(Player()))*13)+3000;",
                        "  //Множитель сложности в данном случае намертво задан на 50%",
                        "  EQuestReward=round(1.2*EQuestReward);",
                        "  //Двойной модификатор для дубльплекса (в оригинале расчёт сложнее)",
                        "  if(ShipHealthFactor(Player(), 23) > 0) EQuestReward = EQuestReward * 2;",
                        "  ",
                        "  //Рассчитываем наградной опыт по оригинальной игровой формуле Round10(k1 / k2 * k3 * base)",
                        "  //Вместо рандомного броска от 0.7 до 1.5, k3 всегда имеет значение 1.4",
                        "  //base берём из игрового Lang.dat в параметре QuestPoints",
                        "  //Типы заданий из параметра QuestPoints, по порядку:",
                        "  //SendLetter, KillShip, PlanetQuest, DefSystem, DefShip",
                        "  if(GalaxyTechLevel()<=2) TempFloat4=1;",
                        "  else if(GalaxyTechLevel()==3) TempFloat4=1.20;",
                        "  else if(GalaxyTechLevel()==4) TempFloat4=1.40;",
                        "  else if(GalaxyTechLevel()==5) TempFloat4=1.60;",
                        "  else if(GalaxyTechLevel()==6) TempFloat4=1.80;",
                        "  else if(GalaxyTechLevel()>=7) TempFloat4=2;",
                        "  EQuestExpReward=round(TempFloat4/(0.70+(0.15*(GalaxyDiffLevels(5)/50)))*1.4*600);",
                        "  EQuestExpReward=int(EQuestExpReward/10);",
                        "  EQuestExpReward=EQuestExpReward*10;",
                        "  DChange(45);",
                        "  exit;",
                        "}",
                        "if((StarOwner(StarNearbyStars(ShipStar(Player()), 14)) == 1 || StarCustomFaction(StarNearbyStars(ShipStar(Player()), 14)) != '') &&",
                        "(StarOwner(StarNearbyStars(ShipStar(Player()), 13)) == 1 || StarCustomFaction(StarNearbyStars(ShipStar(Player()), 13)) != '') &&",
                        "(StarOwner(StarNearbyStars(ShipStar(Player()), 12)) == 1 || StarCustomFaction(StarNearbyStars(ShipStar(Player()), 12)) != '') &&",
                        "(StarOwner(StarNearbyStars(ShipStar(Player()), 11)) == 1 || StarCustomFaction(StarNearbyStars(ShipStar(Player()), 11)) != '')) {",
                        "  if(RelationToRanger(GetShipPlanet(Player()),Player())<50)RelationToRanger(GetShipPlanet(Player()),Player(),50);",
                        "  //Определяем расу несуществующего пирата",
                        "  for(i=0;i<StarPlanets(StarNearbyStars(ShipStar(Player()),14));i=i+1)",
                        "  {",
                        "      if(PlanetRace(StarPlanets(StarNearbyStars(ShipStar(Player()),14),i))!=6)",
                        "      {",
                        "          temp_str_3 = CT('Script.Mod_ExpPilotBridge.SillyName_'+PlanetRace(StarPlanets(StarNearbyStars(ShipStar(Player()), 14), i)));",
                        "          break;",
                        "      }",
                        "  }",
                        "  temp_str_4=CT(\"Script.Mod_ExpPilotBridge.1513\");",
                        "  if(StarOwner(StarNearbyStars(ShipStar(Player()),14))==1)temp_str_4=CT(\"Script.Mod_ExpPilotBridge.1286\");",
                        "  if(StarCustomFaction(StarNearbyStars(ShipStar(Player()),14))=='Klissan')temp_str_4=CT(\"Script.Mod_ExpPilotBridge.1285\");",
                        "  GKillQuestCheck=0;",
                        "  GotoGov(0);",
                        "  DChange(50);",
                        "  exit;",
                        "}"
                    ],
