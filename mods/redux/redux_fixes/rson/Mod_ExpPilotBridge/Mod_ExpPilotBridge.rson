                        "                      LHullTargetType=4;",
                        "                  }",
                        "                  //Корпус был в пути на планету доставки, но её захватили, а станция отправки уже была уничтожена (корпус украден)",
                        "                  else",
                        "                  {",
                        "                      //Станция отправки была уничтожена",
                        "                      if(HullFromStExist==1)",
                        "                      {",
                        "                          temp_str='</color>'+Format(CT(\"Script.Mod_ExpPilotBridge.1473\"),\"<0>\",StarName(GalaxyStar(HullFromStarId)));",
                        "                          temp_str_2='</color>'+CT(\"Script.Mod_ExpPilotBridge.1472\");",
                        "                      }",
                        "                      //Станция отправки покинула систему",
                        "                      else",
                        "                      {",
                        "                          temp_str='</color>'+Format(CT(\"Script.Mod_ExpPilotBridge.1471\"),\"<0>\",StarName(GalaxyStar(HullFromStarId)));",
                        "                          temp_str_2='</color>'+CT(\"Script.Mod_ExpPilotBridge.1470\");",
                        "                      }",
                        "                      if(HullOnWay==1)NewsAdd(Format(CT(\"Script.Mod_ExpPilotBridge.1496\"),\"<0>\",StarName(PlanetToStar(IdToPlanet(HullDelEndId))),\"<1>\",PlanetName(IdToPlanet(HullDelEndId)),\"<2>\",HullFromName,\"<3>\",temp_str,\"<4>\",temp_str_2));",
                        "                      else if(HullOnWay>1)NewsAdd(Format(CT(\"Script.Mod_ExpPilotBridge.1495\"),\"<0>\",StarName(PlanetToStar(IdToPlanet(HullDelEndId))),\"<1>\",PlanetName(IdToPlanet(HullDelEndId)),\"<2>\",HullFromName,\"<3>\",temp_str,\"<4>\",temp_str_2));",
                        "                      HullWasStolen=7;",
                        "                      HullWasStolenThiefCreate(0);",
                        "                  }",
                        "              }",
                        "          }",
                        "      }",
                        "      //Обработчик прерывания изначальной доставки на станцию",
                        "      if(LHullTargetType==2)",
                        "      {",
                        "          if(HullFromType==3)",
                        "          {",
                        "              if(HullEndStExist)",
                        "              {",
                        "                  //Корпус был в пути на станцию доставки, но её уничтожили, а корпус перенаправили (возможно) на планету отправки",
                        "                  if(StarOwner(PlanetToStar(IdToPlanet(HullDelFromId)))!=1 && StarCustomFaction(PlanetToStar(IdToPlanet(HullDelFromId)))=='')",
                        "                  {",
                        "                      //Станция доставки была уничтожена",
                        "                      if(HullEndStExist==1)",
                        "                      {",
                        "                          temp_str_2='</color>'+Format(CT(\"Script.Mod_ExpPilotBridge.1477\"),\"<0>\",StarName(GalaxyStar(HullEndStarId)));",
                        "                          temp_str_3='</color>'+CT(\"Script.Mod_ExpPilotBridge.1476\");",
                        "                          temp_str_4='</color>'+CT(\"Script.Mod_ExpPilotBridge.1484\");",
                        "                      }",
                        "                      //Станция доставки покинула систему",
                        "                      else",
                        "                      {",
                        "                          temp_str_2='</color>'+Format(CT(\"Script.Mod_ExpPilotBridge.1475\"),\"<0>\",StarName(GalaxyStar(HullEndStarId)));",
                        "                          temp_str_3='</color>'+CT(\"Script.Mod_ExpPilotBridge.1474\");",
                        "                          temp_str_4='</color>'+CT(\"Script.Mod_ExpPilotBridge.1483\");",
                        "                      }",
                        "                      if(HullOnWay==1 && HullWasStolen==0 && (HullAgentType==1 || HullAgentType==2))NewsAdd(Format(CT(\"Script.Mod_ExpPilotBridge.1494\"),\"<0>\",HullEndName,\"<1>\",temp_str_2,\"<2>\",temp_str_3,\"<3>\",PlanetName(IdToPlanet(HullDelFromId)),\"<4>\",StarName(PlanetToStar(IdToPlanet(HullDelFromId)))));",
                        "                      else if(HullOnWay==1 && (HullWasStolen>0 || HullAgentType==22 || HullAgentType==3))NewsAdd(Format(CT(\"Script.Mod_ExpPilotBridge.1481\"),\"<0>\",HullEndName,\"<1>\",temp_str_2,\"<2>\",temp_str_3,\"<3>\",temp_str_4));",
                        "                      else if(HullOnWay>1 && HullWasStolen==0 && (HullAgentType==1 || HullAgentType==2))NewsAdd(Format(CT(\"Script.Mod_ExpPilotBridge.1493\"),\"<0>\",HullEndName,\"<1>\",temp_str_2,\"<2>\",temp_str_3,\"<3>\",PlanetName(IdToPlanet(HullDelFromId)),\"<4>\",StarName(PlanetToStar(IdToPlanet(HullDelFromId)))));",
                        "                      else if(HullOnWay>1 && HullWasStolen>0 && HullWasStolen<7 && (HullAgentType==1 || HullAgentType==2))NewsAdd(Format(CT(\"Script.Mod_ExpPilotBridge.1492\"),\"<0>\",HullEndName,\"<1>\",temp_str_2,\"<2>\",temp_str_3,\"<3>\",PlanetName(IdToPlanet(HullDelFromId)),\"<4>\",StarName(PlanetToStar(IdToPlanet(HullDelFromId))),\"<5>\",temp_str_4));",
                        "                      else if(HullOnWay>1 && (HullWasStolen==7 || HullAgentType==22 || HullAgentType==3))NewsAdd(Format(CT(\"Script.Mod_ExpPilotBridge.1478\"),\"<0>\",HullEndName,\"<1>\",temp_str_2,\"<2>\",temp_str_3,\"<3>\",temp_str_4));",
                        "                      if(HullAgentType==22 || HullAgentType==3)HullWasStolen=7;",
                        "                      if(HullWasStolen>0)HullWasStolenThiefCreate(0);",
                        "                      HullDelTime=CurTurn()-HullDelTimeStart;",
                        "                      HullDelTimeExp=HullDelTime+CurTurn();",
                        "                      if(Rnd(1,100)<=35 && HullAgentType==1)HullDelTime=HullDelTime+((HullDelTime*Rnd(15,25))/100);",
                        "                      if(Rnd(1,100)<=65 && HullAgentType==2)HullDelTime=HullDelTime+((HullDelTime*Rnd(25,40))/100);",
                        "                      HullDelTime=HullDelTime+CurTurn();",
                        "                      HullDelEndId=HullDelFromId;",
                        "                      temp_int_1=HullFromStarId;",
                        "                      HullEndStarId=HullFromStarId;",
                        "                      HullFromStarId=temp_int_1;",
                        "                      HullEndType=3;",
                        "                      LHullTargetType=3;",
                        "                  }",
                        "                  //Корпус был в пути на станцию доставки, но её уничтожили, а планета отправки уже была захвачена (корпус украден)",
                        "                  else",
                        "                  {",
                        "                      //Станция доставки была уничтожена",
                        "                      if(HullEndStExist==1)",
                        "                      {",
                        "                          temp_str_2='</color>'+Format(CT(\"Script.Mod_ExpPilotBridge.1477\"),\"<0>\",StarName(GalaxyStar(HullEndStarId)));",
                        "                          temp_str_3='</color>'+CT(\"Script.Mod_ExpPilotBridge.1476\");",
                        "                      }",
                        "                      //Станция доставки покинула систему",
                        "                      else",
                        "                      {",
                        "                          temp_str_2='</color>'+Format(CT(\"Script.Mod_ExpPilotBridge.1475\"),\"<0>\",StarName(GalaxyStar(HullEndStarId)));",
                        "                          temp_str_3='</color>'+CT(\"Script.Mod_ExpPilotBridge.1474\");",
                        "                      }",
                        "                      if(HullOnWay==1)NewsAdd(Format(CT(\"Script.Mod_ExpPilotBridge.1491\"),\"<0>\",HullEndName,\"<1>\",temp_str_2,\"<2>\",temp_str_3,\"<3>\",PlanetName(IdToPlanet(HullDelFromId)),\"<4>\",StarName(PlanetToStar(IdToPlanet(HullDelFromId)))));",
                        "                      else if(HullOnWay>1)NewsAdd(Format(CT(\"Script.Mod_ExpPilotBridge.1490\"),\"<0>\",HullEndName,\"<1>\",temp_str_2,\"<2>\",temp_str_3,\"<3>\",PlanetName(IdToPlanet(HullDelFromId)),\"<4>\",StarName(PlanetToStar(IdToPlanet(HullDelFromId)))));",
                        "                      HullWasStolen=7;",
                        "                      HullWasStolenThiefCreate(0);",
                        "                  }",
                        "              }",
                        "          }",
                        "          if(HullFromType==4)",
                        "          {",
                        "              if(HullEndStExist)",
                        "              {",
                        "                  //Корпус был в пути на станцию доставки, но её уничтожили, а корпус перенаправили (возможно) на станцию отправки",
                        "                  if(!HullFromStExist)",
                        "                  {",
                        "                      //Станция доставки была уничтожена",
                        "                      if(HullEndStExist==1)",
                        "                      {",
                        "                          temp_str_3='</color>'+Format(CT(\"Script.Mod_ExpPilotBridge.1477\"),\"<0>\",StarName(GalaxyStar(HullEndStarId)));",
                        "                          temp_str_4='</color>'+CT(\"Script.Mod_ExpPilotBridge.1476\");",
                        "                          temp_str_2='</color>'+CT(\"Script.Mod_ExpPilotBridge.1484\");",
                        "                      }",
                        "                      //Станция доставки покинула систему",
                        "                      else",
                        "                      {",
                        "                          temp_str_3='</color>'+Format(CT(\"Script.Mod_ExpPilotBridge.1475\"),\"<0>\",StarName(GalaxyStar(HullEndStarId)));",
                        "                          temp_str_4='</color>'+CT(\"Script.Mod_ExpPilotBridge.1474\");",
                        "                          temp_str_2='</color>'+CT(\"Script.Mod_ExpPilotBridge.1483\");",
                        "                      }",
                        "                      if(HullOnWay==1 && HullWasStolen==0 && (HullAgentType==1 || HullAgentType==2))NewsAdd(Format(CT(\"Script.Mod_ExpPilotBridge.1489\"),\"<0>\",HullEndName,\"<1>\",temp_str_3,\"<2>\",temp_str_4,\"<3>\",ShipName(IdToShip(HullDelFromId)),\"<4>\",StarName(ShipStar(IdToShip(HullDelFromId)))));",
                        "                      else if(HullOnWay==1 && (HullWasStolen>0 || HullAgentType==22 || HullAgentType==3))NewsAdd(Format(CT(\"Script.Mod_ExpPilotBridge.1481\"),\"<0>\",HullEndName,\"<1>\",temp_str_3,\"<2>\",temp_str_4,\"<3>\",temp_str_2));",
                        "                      else if(HullOnWay>1 && HullWasStolen==0 && (HullAgentType==1 || HullAgentType==2))NewsAdd(Format(CT(\"Script.Mod_ExpPilotBridge.1488\"),\"<0>\",HullEndName,\"<1>\",temp_str_3,\"<2>\",temp_str_4,\"<3>\",ShipName(IdToShip(HullDelFromId)),\"<4>\",StarName(ShipStar(IdToShip(HullDelFromId)))));",
                        "                      else if(HullOnWay>1 && HullWasStolen>0 && HullWasStolen<7 && (HullAgentType==1 || HullAgentType==2))NewsAdd(Format(CT(\"Script.Mod_ExpPilotBridge.1487\"),\"<0>\",HullEndName,\"<1>\",temp_str_3,\"<2>\",temp_str_4,\"<3>\",ShipName(IdToShip(HullDelFromId)),\"<4>\",StarName(ShipStar(IdToShip(HullDelFromId))),\"<5>\",temp_str_2));",
                        "                      else if(HullOnWay>1 && (HullWasStolen==7 || HullAgentType==22 || HullAgentType==3))NewsAdd(Format(CT(\"Script.Mod_ExpPilotBridge.1478\"),\"<0>\",HullEndName,\"<1>\",temp_str_3,\"<2>\",temp_str_4,\"<3>\",temp_str_2));",
                        "                      if(HullAgentType==22 || HullAgentType==3)HullWasStolen=7;",
                        "                      if(HullWasStolen>0)HullWasStolenThiefCreate(0);",
                        "                      HullDelTime=CurTurn()-HullDelTimeStart;",
                        "                      HullDelTimeExp=HullDelTime+CurTurn();",
                        "                      if(Rnd(1,100)<=35 && HullAgentType==1) HullDelTime=HullDelTime+((HullDelTime*Rnd(15,25))/100);",
                        "                      if(Rnd(1,100)<=65 && HullAgentType==2) HullDelTime=HullDelTime+((HullDelTime*Rnd(25,40))/100);",
                        "                      HullDelTime=HullDelTime+CurTurn();",
                        "                      HullDelEndId=HullDelFromId;",
                        "                      temp_int_1=HullFromStarId;",
                        "                      HullEndStarId=HullFromStarId;",
                        "                      HullFromStarId=temp_int_1;",
                        "                      LHullTargetType=4;",
                        "                  }",
                        "                  //Корпус был в пути на станцию доставки, но её уничтожили, а станция отправки уже была уничтожена (корпус украден)",
                        "                  else",
                        "                  {",
                        "                      //Станция доставки была уничтожена",
                        "                      if(HullEndStExist==1)",
                        "                      {",
                        "                          temp_str_3='</color>'+Format(CT(\"Script.Mod_ExpPilotBridge.1477\"),\"<0>\",StarName(GalaxyStar(HullEndStarId)));",
                        "                          temp_str_4='</color>'+CT(\"Script.Mod_ExpPilotBridge.1476\");",
                        "                      }",
                        "                      //Станция доставки покинула систему",
                        "                      else",
                        "                      {",
                        "                          temp_str_3='</color>'+Format(CT(\"Script.Mod_ExpPilotBridge.1475\"),\"<0>\",StarName(GalaxyStar(HullEndStarId)));",
                        "                          temp_str_4='</color>'+CT(\"Script.Mod_ExpPilotBridge.1474\");",
                        "                      }",
                        "                      //Станция отправки была уничтожена",
                        "                      if(HullFromStExist==1)",
                        "                      {",
                        "                          temp_str='</color>'+Format(CT(\"Script.Mod_ExpPilotBridge.1473\"),\"<0>\",StarName(GalaxyStar(HullFromStarId)));",
                        "                          temp_str_2='</color>'+CT(\"Script.Mod_ExpPilotBridge.1472\");",
                        "                      }",
                        "                      //Станция отправки покинула систему",
                        "                      else",
                        "                      {",
                        "                          temp_str='</color>'+Format(CT(\"Script.Mod_ExpPilotBridge.1471\"),\"<0>\",StarName(GalaxyStar(HullFromStarId)));",
                        "                          temp_str_2='</color>'+CT(\"Script.Mod_ExpPilotBridge.1470\");",
                        "                      }",
                        "                      if(HullOnWay==1) NewsAdd(Format(CT(\"Script.Mod_ExpPilotBridge.1486\"),\"<0>\",HullEndName,\"<1>\",temp_str_3,\"<2>\",temp_str_4,\"<3>\",HullFromName,\"<4>\",temp_str,\"<5>\",temp_str_2));",
                        "                      else if(HullOnWay>1) NewsAdd(Format(CT(\"Script.Mod_ExpPilotBridge.1485\"),\"<0>\",HullEndName,\"<1>\",temp_str_3,\"<2>\",temp_str_4,\"<3>\",HullFromName,\"<4>\",temp_str,\"<5>\",temp_str_2));",
                        "                      HullWasStolen=7;",
                        "                      HullWasStolenThiefCreate(0);",
                        "                  }",
                        "              }",
                        "          }",
                        "      }",
                        "  }",
                        "  //Выбор системы для постройки ТЦ, определение стоимости",
                        "  if(InitExpTC) {",
                        "      if(!GlobalVarTcCount && !bld_system_Id_TC) bld_system_Id_TC=SelectSystemTC();",
                        "  //    if(bld_system_Id_TC) bld_cost_TC=GTL*GalaxyDiffLevels()*800+Rnd(GalaxyMoney(2,2),GalaxyMoney(4,4));",
                        "  }",
                        "  //Выставляются планеты для спавна кораблей со Слэпстартера",
                        "  if(!CoalitionDefeated())",
                        "  {",
                        "      if(!bld_planet_chsn_2 || !bld_planet_chsn)",
                        "      {",
                        "          for(i = 0; i < GalaxyStars(); i = i + 1)",
                        "          {",
                        "              temp_dword = GalaxyStar(i);",
                        "              if(StarOwner(temp_dword) == 1) continue;",
                        "              if(StarCustomFaction(temp_dword) != '') continue;",
                        "              if(StarToCon(temp_dword) == StarToCon(PlanetToStar(PlanetPirateClan()))) continue;",
                        "              for(j = 0; j < StarPlanets(temp_dword); j = j + 1)",
                        "              {",
                        "                  temp_dword_2 = StarPlanets(temp_dword, j);",
                        "                  temp_int_2 = PlanetOwner(temp_dword_2);",
                        "                  if(temp_int_2 == 6) continue;",
                        "                  if(!PirateWin() && StarOwner(temp_dword) == 2 && !bld_planet_chsn_2) ArrayAdd(bld_ship_planet_list_2, Id(temp_dword_2));",
                        "                  if(!StarOwner(temp_dword) && !bld_planet_chsn) ArrayAdd(bld_ship_planet_list, Id(temp_dword_2));",
                        "              }",
                        "          }",
                        "      }",
                        "  }",
                        "  ",
                        "  //Создаём Коалиционные проекты Слэпстартера (срабатывает, если предыдущий проект уже завершён)",
                        "  if(!bld_planet_chsn && ArrayDim(bld_ship_planet_list) > 1)",
                        "  {",
                        "      //Обнуляем сумму возврата в случае не набора проектом требуемой суммы (сумма возврата задаётся при внесении донатов игроком)",
                        "      repay = 0;",
                        "  ",
                        "      //Тип коалиционных кораблей (влияет только на название)",
                        "      type_coal = Rnd(1, 3);",
                        "  ",
                        "      //Число коалиционных кораблей",
                        "      ship_count = Rnd(3, 7);",
                        "      temp_int = Rnd(1, ArrayDim(bld_ship_planet_list) - 1);",
                        "      bld_ship_planet = bld_ship_planet_list[temp_int];",
                        "  ",
                        "      //Определяем имя коалиционного отряда",
                        "      tint1 = PlanetRace(IdToPlanet(bld_ship_planet));",
                        "      if(tint1 == Maloc) bld_ship_name = CT('ShipType.Maloc.Militiaman' + type_coal);",
                        "      else if(tint1 == Peleng) bld_ship_name = CT('ShipType.Peleng.Militiaman' + type_coal);",
                        "      else if(tint1 == People) bld_ship_name = CT('ShipType.People.Militiaman' + type_coal);",
                        "      else if(tint1 == Fei) bld_ship_name = CT('ShipType.Fei.Militiaman' + type_coal);",
                        "      else if(tint1 == Gaal) bld_ship_name = CT('ShipType.Gaal.Militiaman' + type_coal);",
                        "  ",
                        "      //Проверочная переменная, что сбор коалиционных донатов начался",
                        "      bld_planet_chsn = 1;",
                        "  ",
                        "      //Устанавливаем общую стоимость реализации проекта",
                        "      bld_cost = GalaxyTechLevel() * GalaxyDiffLevels() * ship_count * 125;",
                        "  ",
                        "      //Устанавливаем общее время сбора донатов (от 45 до 60 дней)",
                        "      bld_day = 45 + CurTurn() + Rnd(0, 15);",
                        "  ",
                        "      //Задаём общий размер всех пассивных взносов, которые поступят на коалиционный проект",
                        "      temp_int_7 = GalaxyDiffLevels();",
                        "      if(temp_int_7 <= 125) dif_koef = bld_cost - round(0.35 * bld_cost) + round((0.01 * Rnd(0, 15)) * bld_cost);",
                        "      else if(temp_int_7 <= 250) dif_koef = bld_cost - round(0.45 * bld_cost) + round((0.01 * Rnd(0, 15)) * bld_cost);",
                        "      else dif_koef = bld_cost - round(0.60 * bld_cost) + round((0.01 * Rnd(0, 15)) * bld_cost);",
                        "  ",
                        "      //Имеется 14% шанс, что проект окупит себя даже без участия игрока",
                        "      if(Rnd(1, 100) <= 14) dif_koef = bld_cost + 33000;",
                        "      temp_int_3 = bld_day - CurTurn();",
                        "  ",
                        "      //Задаём размер ежедневных пассивных взносов на коалиционный проект",
                        "      add_cr_day_1 = dif_koef / temp_int_3;",
                        "  }",
                        "  ",
                        "  //Создаём пиратский проект Слэпстартера (срабатывает, если предыдущий проект завершён)",
                        "  if(!bld_planet_chsn_2 && ArrayDim(bld_ship_planet_list_2) > 1)",
                        "  {",
                        "      //Обнуляем сумму возврата в случае не набора проектом требуемой суммы (сумма возврата задаётся при внесении донатов игроком)",
                        "      repay_2 = 0;",
                        "  ",
                        "      //Число пиратских кораблей",
                        "      ship_count_2 = Rnd(3, 7);",
                        "      temp_int = Rnd(1, ArrayDim(bld_ship_planet_list_2) - 1);",
                        "      bld_ship_planet_2 = bld_ship_planet_list_2[temp_int];",
                        "  ",
                        "      //Определяем имя пиратского отряда",
                        "      tint1 = PlanetRace(IdToPlanet(bld_ship_planet_2));",
                        "      if(tint1 == Maloc) bld_ship_name_2 = CT('ShipType.Maloc.Rebel');",
                        "      else if(tint1 == Peleng) bld_ship_name_2 = CT('ShipType.Peleng.Rebel');",
                        "      else if(tint1 == People) bld_ship_name_2 = CT('ShipType.People.Rebel');",
                        "      else if(tint1 == Fei) bld_ship_name_2 = CT('ShipType.Fei.Rebel');",
                        "      else if(tint1 == Gaal) bld_ship_name_2 = CT('ShipType.Gaal.Rebel');",
                        "  ",
                        "      //Проверочная переменная, что сбор пиратских донатов начался",
                        "      bld_planet_chsn_2 = 1;",
                        "  ",
                        "      //Устанавливаем общую стоимость реализации проекта",
                        "      bld_cost_2 = GalaxyTechLevel() * GalaxyDiffLevels() * ship_count_2 * 120;",
                        "  ",
                        "      //Устанавливаем общее время сбора донатов (от 45 до 60 дней)",
                        "      bld_day_2 = 45 + CurTurn() + Rnd(0, 15);",
                        "  ",
                        "      //Задаём общий размер всех пассивных взносов, которые поступят на пиратский проект",
                        "      temp_int_7 = GalaxyDiffLevels();",
                        "      if(temp_int_7 <= 125) dif_koef_2 = bld_cost_2 - round(0.35 * bld_cost_2) + round((0.01 * Rnd(0, 15)) * bld_cost);",
                        "      else if(temp_int_7 <= 250) dif_koef_2 = bld_cost_2 - round(0.45 * bld_cost_2) + round((0.01 * Rnd(0, 15)) * bld_cost);",
                        "      else dif_koef_2 = bld_cost_2 - round(0.60 * bld_cost_2) + round((0.01 * Rnd(0, 15)) * bld_cost);",
                        "  ",
                        "      //Имеется 10% шанс, что проект окупит себя даже без участия игрока",
                        "      if(Rnd(1, 100) <= 10) dif_koef_2 = bld_cost_2 + 27000;",
                        "      temp_int_3 = bld_day_2 - CurTurn();",
                        "  ",
                        "      //Задаём размер ежедневных пассивных взносов на пиратский проект",
                        "      add_cr_day_2 = dif_koef_2 / temp_int_3;",
                        "  }",
                        "  ",
                        "  //Идёт пассивный набор донатов на реализацию текущего коалиционного проекта",
                        "  if(bld_day != 0 && bld_day > CurTurn() && credits_now < dif_koef)",
                        "  {",
                        "      credits_now = credits_now + add_cr_day_1;",
                        "  }",
                        "  ",
                        "  //Идёт пассивный набор донатов на реализацию текущего пиратского проекта",
                        "  if(bld_day_2 != 0 && bld_day_2 > CurTurn() && credits_now_2 < dif_koef_2)",
                        "  {",
                        "      credits_now_2 = credits_now_2 + add_cr_day_2;",
                        "  }",
                        "  ",
                        "  //Проверка на захват коалиционной системы, в которой находилась планета, собирающая донаты",
                        "  if(bld_day > CurTurn() && ArrayDim(bld_ship_planet_list) > 1)",
                        "  {",
                        "      if(StarOwner(PlanetToStar(IdToPlanet(bld_ship_planet))) != 0)",
                        "      {",
                        "          temp_dword = PlanetToStar(IdToPlanet(bld_ship_planet));",
                        "          bld_day = CurTurn() - 10;",
                        "          if(repay >= 100)",
                        "          {",
                        "              tint1 = PlanetRace(IdToPlanet(bld_ship_planet));",
                        "              if(tint1 == 0) temp_int = round(0.90 * repay);",
                        "              else if(tint1 == 1) temp_int = round(0.5 * repay);",
                        "              else if(tint1 == 2) temp_int = round(0.80 * repay);",
                        "              else if(tint1 == 3) temp_int = round(0.90 * repay);",
                        "              else if(tint1 == 4) temp_int = repay;",
                        "              Ether('mp_Galaxy', '', Format(CT(\"Script.Mod_ExpPilotBridge.708\"),\"<0>\",StarName(temp_dword),\"<1>\",bld_ship_name,\"<2>\",temp_int));",
                        "              ShipMoney(Player(), ShipMoney(Player()) + temp_int);",
                        "              Sound('Sound.Buy');",
                        "          }",
                        "          ArrayClear(bld_ship_planet_list);",
                        "          bld_planet_chsn = 0;",
                        "          credits_now = 0;",
                        "          wait_day = CurTurn() + Rnd(5, 20);",
                        "      }",
                        "  }",
                        "  ",
                        "  //Проверка на захват пиратской системы, в которой находилась планета, собирающая донаты",
                        "  if(bld_day_2 > CurTurn() && ArrayDim(bld_ship_planet_list_2) > 1)",
                        "  {",
                        "      if(StarOwner(PlanetToStar(IdToPlanet(bld_ship_planet_2))) != 2 || StarCustomFaction(PlanetToStar(IdToPlanet(bld_ship_planet_2))) != '')",
                        "      {",
                        "          temp_dword = PlanetToStar(IdToPlanet(bld_ship_planet_2));",
                        "          bld_day_2 = CurTurn() - 10;",
                        "          if(repay_2 >= 100)",
                        "          {",
                        "              temp_int = round(0.75 * repay_2);",
                        "              Ether('mp_Galaxy', '', Format(CT(\"Script.Mod_ExpPilotBridge.708\"),\"<0>\",StarName(temp_dword),\"<1>\",bld_ship_name_2,\"<2>\",temp_int));",
                        "              ShipMoney(Player(), ShipMoney(Player()) + temp_int);",
                        "              Sound('Sound.Buy');",
                        "          }",
                        "          ArrayClear(bld_ship_planet_list_2);",
                        "          bld_planet_chsn_2 = 0;",
                        "          credits_now_2 = 0;",
                        "          wait_day_2 = CurTurn() + Rnd(5, 20);",
                        "      }",
                        "  }",
                        "  ",
                        "  //Спавним военных, либо выводим сообщение о нехватке средств (если игрок тоже вносил платеж)",
                        "  if(bld_day <= CurTurn() && ArrayDim(bld_ship_planet_list) > 1)",
                        "  {",
                        "      if(credits_now >= bld_cost)",
                        "      {",
                        "          for(j = 1; j <= ship_count; j = j + 1)",
                        "          {",
                        "              //Функция спавна военного корабля (тип 1), возвращает корабль",
                        "              SpawnSlapstarter(1, IdToPlanet(bld_ship_planet));",
                        "          }",
                        "          temp_dword = PlanetToStar(IdToPlanet(bld_ship_planet));",
                        "          if(repay >= 100) Ether('mp_Galaxy', CurTurn() + '-1-' + 'MERCS', Format(CT(\"Script.Mod_ExpPilotBridge.1467\"),\"<0>\",StarName(temp_dword),\"<1>\",bld_ship_name));",
                        "          AddPlanetNews(Format(CT(\"Script.Mod_ExpPilotBridge.1467\"),\"<0>\",StarName(temp_dword),\"<1>\",bld_ship_name),50);",
                        "      }",
                        "      if(credits_now < bld_cost && repay >= 100)",
                        "      {",
                        "          tint1 = PlanetRace(IdToPlanet(bld_ship_planet));",
                        "          if(tint1 == 0) temp_int = round(0.90 * repay);",
                        "          else if(tint1 == 1) temp_int = round(0.5 * repay);",
                        "          else if(tint1 == 2) temp_int = round(0.80 * repay);",
                        "          else if(tint1 == 3) temp_int = round(0.90 * repay);",
                        "          else if(tint1 == 4) temp_int = repay;",
                        "          Ether('mp_Galaxy', CurTurn() + '-1-' + 'MERCS', Format(CT(\"Script.Mod_ExpPilotBridge.706\"),\"<0>\",bld_ship_name,\"<1>\",temp_int));",
                        "          ShipMoney(Player(), ShipMoney(Player()) + temp_int);",
                        "          Sound('Sound.Sell');",
                        "      }",
                        "      ArrayClear(bld_ship_planet_list);",
                        "      bld_planet_chsn = 0;",
                        "      credits_now = 0;",
                        "      wait_day = CurTurn() + Rnd(5, 20);",
                        "  }",
                        "  ",
                        "  //Спавним пиратов, либо выводим сообщение о нехватке средств (если игрок тоже вносил платеж)",
                        "  if(bld_day_2 <= CurTurn() && ArrayDim(bld_ship_planet_list_2) > 1)",
                        "  {",
                        "      if(credits_now_2 >= bld_cost_2)",
                        "      {",
                        "          for(j = 1; j <= ship_count_2; j = j + 1)",
                        "          {",
                        "              //Функция спавна пиратского корабля (тип 2), возвращает корабль",
                        "              SpawnSlapstarter(2, IdToPlanet(bld_ship_planet_2));",
                        "          }",
                        "          temp_dword = PlanetToStar(IdToPlanet(bld_ship_planet_2));",
                        "          if(repay_2 >= 100) Ether('mp_Galaxy', CurTurn() + '-2-' + 'MERCS', Format(CT(\"Script.Mod_ExpPilotBridge.1465\"),\"<0>\",bld_ship_name_2,\"<1>\",StarName(temp_dword)));",
                        "          AddPlanetNews(Format(CT(\"Script.Mod_ExpPilotBridge.1465\"),\"<0>\",bld_ship_name_2,\"<1>\",StarName(temp_dword)),50);",
                        "      }",
                        "  ",
                        "      if(credits_now_2 < bld_cost_2 && repay_2 >= 100)",
                        "      {",
                        "          temp_int = round(0.75 * repay_2);",
                        "          Ether('mp_Galaxy', CurTurn() + '-2-' + 'MERCS', Format(CT(\"Script.Mod_ExpPilotBridge.704\"),\"<0>\",bld_ship_name_2,\"<1>\",temp_int));",
                        "          ShipMoney(Player(), ShipMoney(Player()) + temp_int);",
                        "          Sound('Sound.Sell');",
                        "      }",
                        "  ",
                        "      ArrayClear(bld_ship_planet_list_2);",
                        "      bld_planet_chsn_2 = 0;",
                        "      credits_now_2 = 0;",
                        "      wait_day_2 = CurTurn() + Rnd(5, 20);",
                        "  }",
                        "  ",
                        "  if(!InitExpTC) {",
                        "      if(IsScriptActive('Mod_ExpTC')) InitExpTC=1;",
                        "  }",
                        "  ",
                        "  //Создаем проект ТЦ",
                        "  if(!bld_TC_chsn && bld_system_Id_TC) {",
                        "      repay_TC=0;//Обнуляем сумму возврата в случае не набора проектом требуемой суммы",
                        "      temp_int=Rnd(1,ArrayDim(bld_ship_planet_list)-1);",
                        "      bld_TC_chsn=1;//Проверочная переменная, что сбор коалиционных донатов начался",
                        "      bld_cost_TC=GTL*GalaxyDiffLevels()*800+Rnd(GalaxyMoney(2,2),GalaxyMoney(4,4));//Устанавливаем общую стоимость реализации проекта",
                        "      bld_day_TC=CurTurn()+Rnd(45,60);//Устанавливаем общее время сбора донатов (от 45 до 60 дней)",
                        "      temp_int_7=GalaxyDiffLevels();//Задаём общий размер всех пассивных взносов, которые поступят на проект",
                        "      if(temp_int_7<=125) dif_koef_3=bld_cost_TC-round(0.35*bld_cost_TC)+round((0.01*Rnd(0,15))*bld_cost_TC);",
                        "      else if(temp_int_7>125 && temp_int_7<=250) dif_koef_3=bld_cost_TC-round(0.45*bld_cost_TC)+round((0.01*Rnd(0,15))*bld_cost_TC);",
                        "      else dif_koef_3=bld_cost_TC-round(0.60*bld_cost_TC)+round((0.01*Rnd(0,15))*bld_cost_TC);",
                        "      temp_int_3=bld_cost_TC-CurTurn();",
                        "      add_cr_day_TC=dif_koef/temp_int_3;//Задаём размер ежедневных пассивных взносов на проект ТЦ",
                        "  }",
                        "  //Идёт пассивный набор донатов на постройку ТЦ",
                        "  if(bld_day_TC!=0 && bld_day_TC>CurTurn() && credits_now_TC<dif_koef_3) {",
                        "      credits_now_TC=credits_now_TC+add_cr_day_TC;",
                        "  }",
                        "  //Проверка на захват системы, в которой будет построен ТЦ",
                        "  if(bld_day_TC>CurTurn() && bld_system_Id_TC) {",
                        "      temp_dword=GalaxyStar(bld_system_Id_TC-1);",
                        "      if(StarOwner(temp_dword) && StarOwner(temp_dword)!=2) {",
                        "          bld_day_TC=CurTurn()-10;",
                        "          if(repay_TC>=100) {",
                        "              temp_int=round(0.90*repay_TC);",
                        "              Ether('mp_Galaxy','',Format(CT(\"Script.Mod_ExpPilotBridge.1584\"),\"<0>\",StarName(temp_dword),\"<1>\",temp_int));",
                        "              ShipMoney(Player(),ShipMoney(Player())+temp_int);",
                        "              Sound('Sound.Buy');",
                        "          }",
                        "          bld_system_Id_TC=0;",
                        "          bld_TC_chsn=0;",
                        "          credits_now_TC=0;",
                        "          wait_day_3=CurTurn()+Rnd(5,20);",
                        "      }",
                        "  }",
                        "  //Спавним ТЦ или выдаём сообщение о нехватке денег (если игрок вносил платеж)",
                        "  if(bld_day_TC<=CurTurn() && bld_system_Id_TC) {",
                        "      if(credits_now_TC>=bld_cost_TC) {",
                        "          g_BuyTC(GalaxyStar(bld_system_Id_TC-1));",
                        "      }",
                        "      if(credits_now_TC<bld_cost_TC && repay_TC>=100) {",
                        "          temp_int=round(0.90*repay_TC);",
                        "          Ether('mp_Galaxy',CurTurn(),Format(CT(\"Script.Mod_ExpPilotBridge.1583\"),\"<0>\",temp_int));",
                        "          ShipMoney(Player(),ShipMoney(Player())+temp_int);",
                        "          Sound('Sound.Sell');",
                        "      }",
                        "      bld_system_Id_TC=0;",
                        "      bld_TC_chsn=0;",
                        "      credits_now_TC=0;",
                        "      wait_day_3=CurTurn()+Rnd(5,20);",
                        "  }",
                        "}",
                        "//Код уведомлялки",
                        "if(BasesFlag == 1) {",
                        "    if(!ShipIsTakeoff(Player())) {",
                        "        for(i=GalaxyEvents()-1; i>=0; i=i-1) {",
                        "            if(GalaxyEventDate(i) < CurTurn()) break;",
                        "            if(GalaxyEventType(i)=='RuinsDestroyed') {",
                        "                Sound('Sound.NewMsg');",
                        "                if(StarToCon(GalaxyStar(GalaxyEventData(i,2) - 1)) == StarToCon(PlanetToStar(PlanetPirateClan())) && !SectorVisible(StarToCon(PlanetToStar(PlanetPirateClan())))) continue;",
                        "                ",
                        "                if(GalaxyEventData(i,0) == 6) temp_str = CT(\"Script.Mod_ExpPilotBridge.1630\");",
                        "                else if(GalaxyEventData(i,0) == 7) temp_str = CT(\"Script.Mod_ExpPilotBridge.1629\");",
                        "                else if(GalaxyEventData(i,0) == 8) temp_str = CT(\"Script.Mod_ExpPilotBridge.1628\");",
                        "                else if(GalaxyEventData(i,0) == 9) temp_str = CT(\"Script.Mod_ExpPilotBridge.1627\");",
                        "                else if(GalaxyEventData(i,0) == 10) temp_str = CT(\"Script.Mod_ExpPilotBridge.1626\");",
                        "                else if(GalaxyEventData(i,0) == 11) temp_str = CT(\"Script.Mod_ExpPilotBridge.1625\");",
                        "                else if(GalaxyEventData(i,0) == 12) temp_str = CT(\"Script.Mod_ExpPilotBridge.1624\");",
                        "                else if(GalaxyEventsTextData(i,0) == 'BM') break;",
                        "                else if(GalaxyEventsTextData(i,0) == 'PlayerMercHQ') break;",
                        "                else if(GalaxyEventsTextData(i,0) == 'DB') break; //Эти станции сюжетные либо слишком скриптовые,",
                        "                else if(GalaxyEventsTextData(i,0) == 'Handler') break; //И имеют своё собств-ое уведомл-е, либо",
                        "                else if(GalaxyEventsTextData(i,0) == 'SSB') break; //Уведомл-е им не требуется",
                        "                else if(GalaxyEventsTextData(i,0) == 'NisperRuins') break;",
                        "                else temp_str = GalaxyEventsTextData(i,0);",
                        "                if(CT('Script.Mod_ExpPilotBridge.StationsAlarm.'+temp_str) == '') temp_str = CT('Script.Mod_ExpPilotBridge.StationsAlarm.Others');",
                        "                else temp_str = CT('Script.Mod_ExpPilotBridge.StationsAlarm.'+temp_str);",
                        "                NewsAdd(Format(temp_str,'star',Name(GalaxyStar(GalaxyEventData(i,2) - 1))));",
                        "            }",
                        "        }",
                        "    }",
                        "}",
                        "if(HolesFlag == 1) {",
                        "            //Если игрок удалил уведомление из трея, то все новости, которые уже были в нём отображены, повторно выводиться не будут",
                        "            if(EtherState('ExpPilotBridge_HoleNewsEther') == -1) last_trade_news_upd = CurTurn();",
                        "",
                        "            temp_str = CT(\"Script.Mod_ExpPilotBridge.1593\") + CT(\"Script.Mod_ExpPilotBridge.67\") + ' ' + CT(\"Script.Mod_ExpPilotBridge.67\");",
                        "            temp_int = 0;",
                        "            temp_int_2 = PlanetNews() - 7;",
                        "            for(i = PlanetNews() - 1; i > temp_int_2; i = i - 1)",
                        "            {",
                        "                if(PlanetNewsDate(i) < last_trade_news_upd) continue;",
                        "                if(PlanetNewsType(i) != 36 && PlanetNewsType(i) != 90 && PlanetNewsType(i) != 89) continue;",
                        "",
                        "                temp_int = temp_int + 1;",
                        "                temp_str = temp_str + '<clr>' + GameDateTxtByTurn(PlanetNewsDate(i)) + '<clrEnd>' + CT(\"Script.Mod_ExpPilotBridge.67\") + '<clrEnd>' + PlanetNewsText(i) + '<clr>' + CT(\"Script.Mod_ExpPilotBridge.67\") + ' ' + CT(\"Script.Mod_ExpPilotBridge.67\");",
                        "            }",
                        "",
                        "            if(temp_int) CustomEther('News', 7, 'ExpPilotBridge_HoleNewsEther', temp_str);",
                        "}"
                    ],
                    "#": 268,
                    "Type": "Top",
                    "Parent": -1,
                    "Pos.x": 120,
                    "Pos.y": 1535
                },
                {
                    "Name": "",
                    "Code.Type": "DialogBegin",
                    "Code": [
                        "if(GetTalkShip()) {",
                        "  if(!TalkByAI()) {",
                        "    if(~ShipFindCustomShipInfoByType(GetTalkShip(), 'PlayerBridge_ThiefInfo')) {",
                        "      temp_int = ShipFindCustomShipInfoByType(GetTalkShip(), 'PlayerBridge_ThiefInfo');",
                        "      if(ShipCustomShipInfoTextData(GetTalkShip(), temp_int, 1) != 'no_mercy') {",
                        "        if(RelationToRanger(GetTalkShip(), Player()) >= 10 && ShipGetBad(GetTalkShip()) != Player()) {",
                        "          if(ShipCustomShipInfoTextData(GetTalkShip(), temp_int, 1) != 'going_down') {",
                        "            AddDialogInject('ThiefTalk','',CT('Script.Mod_ExpPilotBridge.Oh_hiMark_'+Rnd(1,3)),100);",
                        "          }",
                        "          if(ShipCustomShipInfoTextData(GetTalkShip(), temp_int, 1) == 'going_down') {",
                        "            AddDialogOverride('ISwearIt!',1000);",
                        "          }",
                        "        }",
                        "        if(RelationToRanger(GetTalkShip(), Player()) < 10 || ShipGetBad(GetTalkShip()) == Player()) {",
                        "          temp_int_6=Rnd(1,3);",
                        "          if(temp_int_6==1)temp_str=CT(\"Script.Mod_ExpPilotBridge.1456\");",
                        "          if(temp_int_6==2)temp_str=CT(\"Script.Mod_ExpPilotBridge.1454\");",
                        "          if(temp_int_6==3)temp_str=CT(\"Script.Mod_ExpPilotBridge.1416\");",
                        "          AddDialogInject('NoWay','',temp_str,100);",
                        "        }",
                        "      }",
                        "    }",
                        "  }",
                        "  if(GInitDialogCheck == 2) {",
                        "    GInitDialogCheck=0;",
                        "    AddDialogOverride('DamnYou!',1000);",
                        "  }",
                        "  if(TalkByAI()) {",
                        "    if(~ShipFindCustomShipInfoByType(GetTalkShip(), 'PlayerBridge_ThiefInfo')) {",
                        "      if(GetTalkType() == TalkTruce) {",
                        "        if(!StarBattle(ShipStar(GetTalkShip()))) {",
                        "          temp_int=ShipFindCustomShipInfoByType(GetTalkShip(),'PlayerBridge_ThiefInfo');",
                        "          if(ShipCustomShipInfoTextData(GetTalkShip(),temp_int,1)=='i_will_fear_no_evil')AddDialogOverride('Surrender!',1000);",
                        "          if(ShipCustomShipInfoTextData(GetTalkShip(),temp_int,1)!='i_will_fear_no_evil')",
                        "          {",
                        "              //Данные реплики (из temp_str) не подставляются в текущий диалог, но всё равно содержатся в Lang про запас",
                        "              if(ShipTypeN(GetTalkShip())==1)",
                        "              {",
                        "                  temp_str=CT('Script.Mod_ExpPilotBridge.WhatYouWant_1');",
                        "                  temp_str_3=CT('Script.Mod_ExpPilotBridge.AlrightThan_1');",
                        "              }",
                        "              if(ShipTypeN(GetTalkShip())==2)",
                        "              {",
                        "                  temp_str=CT('Script.Mod_ExpPilotBridge.WhatYouWant_2');",
                        "                  temp_str_3=CT('Script.Mod_ExpPilotBridge.AlrightThan_2');",
                        "              }",
                        "              if(ShipTypeN(GetTalkShip())==3)",
                        "              {",
                        "                  temp_str=CT('Script.Mod_ExpPilotBridge.WhatYouWant_3');",
                        "                  temp_str_3=CT('Script.Mod_ExpPilotBridge.AlrightThan_3');",
                        "              }",
                        "              temp_int_6=Rnd(1,3);",
                        "              if(temp_int_6==1)temp_str_2=CT(\"Script.Mod_ExpPilotBridge.1407\");",
                        "              if(temp_int_6==2)temp_str_2=CT(\"Script.Mod_ExpPilotBridge.1406\");",
                        "              if(temp_int_6==3)temp_str_2=CT(\"Script.Mod_ExpPilotBridge.1216\");",
                        "              GInitDialogCheck=0;",
                        "              AddDialogInject('WhatYouWant?','',CT(\"Script.Mod_ExpPilotBridge.1411\"),100);",
                        "          }",
                        "        }",
                        "      }",
                        "    }",
                        "  }",
                        "}",
                        "if(GetShipPlanet(Player())) {",
                        "  if(GKillQuestCheck == 1) {",
                        "    AddDialogOverride('GoToPrison', 9999);",
                        "  }",
                        "  if(GKillQuestCheck == 2) {",
                        "    AddDialogOverride('OutOfPrison', 9999);",
                        "  }",
                        "}",
                        "if(GetShipPlanet(Player())) {",
                        "  if(GKillQuestCheck==3) {",
                        "    if(GetShipPlanet(Player())==IdToPlanet(EQuestPlanet)) {",
                        "      AddDialogBlock(CT(\"Script.Mod_ExpPilotBridge.1393\"),2);",
                        "      //В нижней фразе использована латинская 'c'",
                        "      AddDialogInject('NotYet','',CT(\"Script.Mod_ExpPilotBridge.1390\"),100);",
                        "    }",
                        "  }",
                        "  if(GKillQuestCheck==4) {",
                        "    if(GetShipPlanet(Player())==IdToPlanet(EQuestPlanet)) {",
                        "      AddDialogInject('',Format(CT(\"Script.Mod_ExpPilotBridge.1398\"),\"<0>\",ShipName(Player()),\"<1>\",EQuestReward)+' '+EQuestExpReward+' '+CT(\"Script.Mod_ExpPilotBridge.1397\"),'set_block',10,1);",
                        "      AddDialogBlock('set_block',2);",
                        "      GCustomQuestsDone=GCustomQuestsDone+1;",
                        "      money_quest=money_quest+EQuestReward;",
                        "      ShipMoney(Player(),ShipMoney(Player())+EQuestReward);",
                        "      exp_quest=exp_quest+EQuestExpReward;",
                        "      ShipFreeExp(Player(), ShipFreeExp(Player()) + EQuestExpReward);",
                        "      SetShipExpByType(Player(), GetShipExpByType(Player()) + EQuestExpReward, 0);",
                        "      RelationToRanger(GetShipPlanet(Player()),Player(),100);",
                        "      CustomEther('QuestOk',4,'CustomQuestKillBridge',CT(\"Script.Mod_ExpPilotBridge.1261\")+CT('FormInfo.br')+CT(\"Script.Mod_ExpPilotBridge.1260\")+PlanetName(IdToPlanet(EQuestPlanet))+CT(\"Script.Mod_ExpPilotBridge.1259\")+StarName(PlanetToStar(IdToPlanet(EQuestPlanet)))+'</color>)'+CT('FormInfo.br')+' '+CT('FormInfo.br')+GEQuestText);",
                        "      EQuestReward=0;",
                        "      EQuestExpReward=0;",
                        "      ETimeLeft=0;",
                        "      EQuestPlanet=0;",
                        "      ETargetShip=0;",
                        "      GEQuestText='';",
                        "      GKillQuestCheck=0;",
                        "    }",
                        "  }",
                        "}",
                        "if(GetTalkShip()) {",
                        "  if(!TalkByAI()) {",
                        "    if(ShipFindCustomShipInfoByType(GetTalkShip(),'PlayerBridge_IllWisherInfo')>-1) {",
                        "      temp_int=ShipFindCustomShipInfoByType(GetTalkShip(),'PlayerBridge_IllWisherInfo');",
                        "      if(ShipCustomShipInfoTextData(GetTalkShip(),temp_int,1)!='talked') {",
                        "        AddDialogInject('IllWisherTalk','',CT('Script.Mod_ExpPilotBridge.WishYouWell_'+Rnd(1,3)),10);",
                        "      }",
                        "    }",
                        "  }",
                        "  if(GInitDialogCheck==3) {",
                        "    temp_int=ShipFindCustomShipInfoByType(GetTalkShip(),'PlayerBridge_IllWisherInfo');",
                        "    GInitDialogCheck=0;",
                        "    AddDialogOverride('IllWisherCall',1000);",
                        "  }",
                        "}",
                        "if(PlayerBridge() == 12) {",
                        "  AddDialogInject('', CT(\"Script.Mod_ExpPilotBridge.802\"), 'BlockThisAnswer', 1, 1);",
                        "  AddDialogBlock('BlockThisAnswer', 2);",
                        "  AddDialogBlock(CT('FormRuins.Bridge.BridgeExit'), 2);",
                        "  ",
                        "  if(!NoTalkToShip(Player()))",
                        "  {",
                        "      temp_str = CT(\"Script.Mod_ExpPilotBridge.698\");",
                        "      AddDialogInject('Comm_OFF', Format(CT(\"Script.Mod_ExpPilotBridge.696\"),\"<0>\",temp_str), CT(\"Script.Mod_ExpPilotBridge.1578\"), 15);",
                        "  }",
                        "  else",
                        "  {",
                        "      temp_str = CT(\"Script.Mod_ExpPilotBridge.697\");",
                        "      AddDialogInject('Comm_ON', Format(CT(\"Script.Mod_ExpPilotBridge.696\"),\"<0>\",temp_str), CT(\"Script.Mod_ExpPilotBridge.1577\"), 15);",
                        "  }",
                        "  if(ShipFindCustomShipInfoByType(Player(), 'PlayerBridge_AutoDisableForsage')==-1)",
                        "  {",
                        "      temp_str_2=CT(\"Script.Mod_ExpPilotBridge.1556\");",
                        "      AddDialogInject('Forsage_ON',Format(CT(\"Script.Mod_ExpPilotBridge.1553\"),\"<0>\",temp_str_2),CT(\"Script.Mod_ExpPilotBridge.1555\"),16);",
                        "  }",
                        "  else",
                        "  {",
                        "      temp_str_2=CT(\"Script.Mod_ExpPilotBridge.1554\");",
                        "      AddDialogInject('Forsage_OFF',Format(CT(\"Script.Mod_ExpPilotBridge.1553\"),\"<0>\",temp_str_2),CT(\"Script.Mod_ExpPilotBridge.1552\"),16);",
                        "  }",
                        "  if(BasesFlag == 0)",
                        "  {",
                        "      temp_str_3=CT(\"Script.Mod_ExpPilotBridge.1556\");",
                        "      AddDialogInject('BasesOn',Format(CT(\"Script.Mod_ExpPilotBridge.1567\"),\"<0>\",temp_str_3),CT(\"Script.Mod_ExpPilotBridge.1568\"),17);",
                        "  }",
                        "  else",
                        "  {",
                        "      temp_str_3=CT(\"Script.Mod_ExpPilotBridge.1554\");",
                        "      AddDialogInject('BasesOff',Format(CT(\"Script.Mod_ExpPilotBridge.1567\"),\"<0>\",temp_str_3),CT(\"Script.Mod_ExpPilotBridge.1566\"),17);",
                        "  }",
                        "  if(HolesFlag == 0)",
                        "  {",
                        "      temp_str_3=CT(\"Script.Mod_ExpPilotBridge.1556\");",
                        "      AddDialogInject('HolesOn',Format(CT(\"Script.Mod_ExpPilotBridge.1601\"),\"<0>\",temp_str_3),CT(\"Script.Mod_ExpPilotBridge.1602\"),17);",
                        "  }",
                        "  else",
                        "  {",
                        "      temp_str_3=CT(\"Script.Mod_ExpPilotBridge.1554\");",
                        "      AddDialogInject('HolesOff',Format(CT(\"Script.Mod_ExpPilotBridge.1601\"),\"<0>\",temp_str_3),CT(\"Script.Mod_ExpPilotBridge.1600\"),17);",
                        "  }",
                        "  ",
                        "  AddDialogInject('BoardComp', '', CT(\"Script.Mod_ExpPilotBridge.668\"), -1);",
                        "}",
                        "if(PlayerBridge() == 14) {",
                        "  //Меняем вступительное описание в зависимости от того, подключён ли мод ExpBK",
                        "  temp_str = CT(\"Script.Mod_ExpPilotBridge.1542\");",
