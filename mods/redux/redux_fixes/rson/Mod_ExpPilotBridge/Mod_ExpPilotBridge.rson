                        "            if((TransHullCost+temp_int_2)<1250 && (temp_int_4==1 || temp_int_4==2 || temp_int_4==3))TransHullCost=840;",
                        "            else if((TransHullCost+temp_int_2)<3125 && (temp_int_4==4 || temp_int_4==5 || temp_int_4==6))TransHullCost=2080;",
                        "            else if((TransHullCost+temp_int_2)<5000 && (temp_int_4==7 || temp_int_4==8))TransHullCost=3350;",
