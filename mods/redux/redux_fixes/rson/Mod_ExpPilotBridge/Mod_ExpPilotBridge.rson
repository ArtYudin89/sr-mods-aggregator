                {
                    "Name": "",
                    "Code.Type": "Turn",
                    "Code": [
                        "//Типы событий:",
                        "//1 - Космический бой (корпус повреждён) (1 - 1, 2, 3; 2 - 1; 3 - 1)",
                        "//2 - Разведка доминаторских систем (игрок находит в трюме камуфляж) (1 - 4; 2 - #; 3 - #)",
                        "//3 - Шпионские игры (в трюме находится зонд-шпион) (1 - 5, 6; 2 - 2; 3 - #)",
                        "//4 - Музыкальная группа (в трюме обнаруживается музыкальный инструмент) (1 - 7; 2 - 3, 4; 3 - #)",
                        "//5 - Доставка почты (в трюме обнаруживаются письма) (1 - #; 2 - 5, 6; 3 - #)",
                        "//6 - Перевозка беженцев (игрок получает продовольствие) (1 - #; 2 - 7; 3 - #)",
                        "//7 - Перевозка больных/раненых (игрок получает болезнь) (1 - #; 2 - 8; 3 - #)",
                        "//8 - Туса в корпусе, аля пативэн (игрок получает алкоголь и наркотики) (1 - #; 2 - #; 3 - 2, 3)",
                        "//9 - Контрабанда (в трюме обнаруживается контрабанда) (1 - #; 2 - #; 3 - 4, 5)",
                        "//10 - подстава игрока, нападение пиратов за карточный долг (корпус проиграли, но затем выкрали у пиратов) (1 - #; 2 - #; 3 - 6)",
                        "//11 - подстава игрока, сажают в тюрьму за убийство известного дипломата (1 - #; 2 - #; 3 - 7)",
                        "//Структура записи строки события:",
                        "//1 число - тип доставщика (профи, умелец, салага)",
                        "//2 число - тип перегоняющего корабля, зависит от типа доставщика (необходим для спавна этого корабля в случае кражи корпуса)",
                        "//3 и 4 числа - тип события, зависит от типа доставщика",
                        "//5 последних чисел - дополнительные данные для события (заранее записанные броски рандомизатора), также зависят от типа события",
                        "",
                        "TransHullCost=0;",
                        "HullWasStolen=0;",
                        "ArrayClear(GAddTArray);",
                        "//Был выбран профи",
                        "if(temp_int_6==1)",
                        "{",
                        "    HullDelTimeStart=CurTurn();",
                        "    if(HullDelTime>9)",
                        "    {",
                        "       HullDelTime=(-0.25*HullDelTime)+HullDelTime;",
                        "    }",
                        "    if(HullDelTime<=7)",
                        "    {",
                        "        HullDelTime=5;",
                        "    }",
                        "    if(HullDelTime==8)",
                        "    {",
                        "        HullDelTime=6;",
                        "    }",
                        "    if(HullDelTime==9)",
                        "    {",
                        "        HullDelTime=7;",
                        "    }",
                        "    HullDelTimeExp=HullDelTime+CurTurn();",
                        "    //Создаём разброс по времени",
                        "    if(Rnd(1,100)<=10)",
                        "    {",
                        "        HullDelTime=HullDelTime+((HullDelTime*Rnd(5,15))/100);",
                        "    }",
                        "    else",
                        "    {",
                        "        if(Rnd(1,100)<=20)HullDelTime=HullDelTime-((HullDelTime*Rnd(5,15))/100);",
                        "    }",
                        "    //Шанс, что корпус(а) попросту сопрут",
                        "    if(HullDelTime>=14)",
                        "    {",
                        "        if(ArrayDim(transfer_list_done)==2)",
                        "        {",
                        "            if(Rnd(1,100)<=3)",
                        "            {",
                        "                HullWasStolen=1;",
                        "            }",
                        "        }",
                        "        else",
                        "        {",
                        "            if(Rnd(1,100)<=3)",
                        "            {",
                        "                HullWasStolen=1;",
                        "            }",
                        "            if(Rnd(1,100)<=3)",
                        "            {",
                        "                HullWasStolen=HullWasStolen+2;",
                        "            }",
                        "            if(Rnd(1,100)<=3)",
                        "            {",
                        "                HullWasStolen=HullWasStolen+4;",
                        "            }",
                        "        }",
                        "    }",
