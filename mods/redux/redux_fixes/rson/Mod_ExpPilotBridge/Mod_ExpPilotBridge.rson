                        "    {",
                        "        if(StarOwner(ShipStar(temp_dword))==1) continue;",
                        "        if(StarCustomFaction(ShipStar(temp_dword))!='') continue;",
                        "        if(StarToCon(ShipStar(temp_dword))==StarToCon(PlanetToStar(PlanetPirateClan())));",
                        "        if(ShipType(temp_dword)=='Inhibitor') continue;",
                        "        if(ShipType(temp_dword)=='SSB_licensed') continue;",
                        "        if(ShipType(temp_dword)=='BM') continue;",
                        "        if(ShipType(temp_dword)=='MercHQ') continue;",
                        "        temp_dword_2=StorageItemLocation(i);",
                        "        ArrayAdd(temp_array,temp_dword_2);",
