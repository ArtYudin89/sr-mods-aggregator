                        "            if(count2==6 && GalaxyTechLevel()>=5)temp_str_4='3'+Rnd(1,6)+'10'+Rnd(2,4)+Rnd(0,9)+Rnd(0,9)+Rnd(0,9)+Rnd(0,9);",
