                        "            else if(temp_int_4==2)temp_int_2=round((0.00315*temp_int_7)*(70*temp_int_3));",
                        "            else if(temp_int_4==3)temp_int_2=round((0.00315*temp_int_7)*(80*temp_int_3));",
                        "            else if(temp_int_4==4)temp_int_2=round((0.00315*temp_int_7)*(90*temp_int_3));",
                        "            else if(temp_int_4==5)temp_int_2=round((0.00315*temp_int_7)*(100*temp_int_3));",
                        "            else if(temp_int_4==6)temp_int_2=round((0.00315*temp_int_7)*(110*temp_int_3));",
                        "            else if(temp_int_4==7)temp_int_2=round((0.00315*temp_int_7)*(130*temp_int_3));",
                        "            else if(temp_int_4>=8)temp_int_2=round((0.00315*temp_int_7)*(150*temp_int_3));",
                        "        }",
