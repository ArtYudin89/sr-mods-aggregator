                },
                {
                    "Name": "",
                    "Code.Type": "Turn",
                    "Code": [
                        "PlayerBridge(13);"
                    ],
                    "#": 514,
                    "Type": "Top",
                    "Parent": -1,
                    "Pos.x": 730,
                    "Pos.y": 975
                },
                {
                    "Name": "",
                    "Code.Type": "Turn",
                    "Code": [
                        "DChange(4);",
                        "exit;"
                    ],
                    "#": 515,
                    "Type": "Top",
                    "Parent": -1,
                    "Pos.x": 910,
                    "Pos.y": 975
                },
                {
                    "Name": "",
                    "Code.Type": "Turn",
                    "Code": [
                        "FormChange('Info');",
                        "InterfacePos('Info', 'PanelRuins', 0, 1000, 0);",
                        "//При переходе на форму инфоцентра мостик выключается и подключается другая станция",
                        "//Меняем тип этой станции, чтоб на неё подгружался нужный нам фон (единственный способ сменить фон на станции)",
                        "//Приписка Alpha в названии фона (а, следовательно, и типа станции) в кэше обязательна для рескейла изображения с сохранением альфа-канала",
                        "temp_dword = GetShipRuins(Player());",
                        "if(GetMainData('Data.SE.' + Chameleon(Player(), 'GraphName') + '.BridgeInfoBG') != '') str ruin_type = GetMainData('Data.SE.' + Chameleon(Player(), 'GraphName') + '.BridgeInfoBG');",
                        "else ruin_type = 'InfoBridge';",
                        "",
                        "if(GetShipPlanet(temp_dword))",
                        "{",
                        "    if(PlanetOwner(GetShipPlanet(temp_dword)) == None) ruin_type = ruin_type + 'PlanetNoneAlpha';",
                        "    else ruin_type = ruin_type + 'HangarAlpha';",
                        "}",
                        "else if(GetShipRuins(temp_dword)) ruin_type = ruin_type + 'HangarAlpha';",
                        "else ruin_type = ruin_type + 'SpaceAlpha';",
                        "",
                        "ShipType(temp_dword, ruin_type);",
                        "SetName(temp_dword, ruin_type); //Выставление имени необходимо для непосредственной проверки из акткода, поскольку запросить текущий ShipType() станции-мостика невозможно, вернётся 'PlayerBridge';"
                    ],
                    "#": 516,
                    "Type": "Top",
                    "Parent": -1,
                    "Pos.x": 1060,
                    "Pos.y": 975
                },
                {
                    "Name": "",
                    "Code.Type": "Turn",
                    "Code": [
                        "tstr1 = '</color>' + Format(CT('Script.Mod_ExpPilotBridge.PersonalStatistic.DetailedShipsStats'),",
                        "                     '<KillKligs'+'>', temp_str + GDomKlgStat,",
                        "                     '<KillRattors'+'>', LDomRatStat,",
                        "                     '<KillShtips'+'>', temp_str + GDomShtStat,",
                        "                     '<KillMenocs'+'>', temp_str + GDomMenStat,",
                        "                     '<KillSmershes'+'>', temp_str + GDomSmrStat,",
                        "                     '<KillUrgants'+'>', temp_str + GDomUrgStat,",
                        "                     '<KillEquantors'+'>', temp_str + GDomIkvStat,",
                        "                     '<KillBertors'+'>', temp_str + GDomBerStat,",
                        "                     '<KillDomikShipyards'+'>', L_DomBStat,",
                        "                     '<DetailedShipsStatsKlissan'+'>', LKlissanLine,",
                        "                     '<KillFreePirates'+'>', temp_str + (GPirFreeStat + ShipStatistic(Player(), 8)), //В зачёт также идут гиперпираты",
                        "                     '<KillClanPirates'+'>', temp_str + GPirClanStat,",
                        "                     '<KillPirateSpecials'+'>', LPirSpecStat,",
                        "                     '<KillPirateCapitals'+'>', LArmPirStat,",
                        "                     '<KillTraitors'+'>', LRangPirStat,",
                        "                     '<KillRebels'+'>', temp_str + GPirRebStat,",
                        "                     '<KillSmugglers'+'>', LPirSmugStat,",
                        "                     '<KillDominions'+'>', temp_str + G_PCBStat,",
                        "                     '<KillPirateBases'+'>', temp_str + G_PBStat,",
                        "                     '<DetailedShipsStatsMercs'+'>', LMercLine,",
