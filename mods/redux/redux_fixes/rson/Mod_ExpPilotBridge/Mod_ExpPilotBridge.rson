                        "                      CargoLostChanceCalc();",
                        "                      point_3=point_1_id;",
                        "                      LTargetType=3;",
                        "                  }",
                        "                  //Груз был в пути на станцию доставки, но её уничтожили, а планета отправки уже была захвачена (груз перенаправлен в родную систему)",
                        "                  else",
                        "                  {",
                        "                      //Станция доставки была уничтожена",
