                        "    for(count2=0;count2<StarItems(temp_dword);count2=count2+1) temp_int_2=temp_int_2+ItemSize(StarItems(temp_dword,count2));",
                        "    ArrayAdd(temp_array_3,temp_int_2);",
                        "    if(temp_int_2<=9)ArrayAdd(temp_array_2,'</color><clrEnd>'+StarName(temp_dword)+': <clr>'+CT('FormInfo.td_otstup_166')+temp_int_2+CT(\"Script.Mod_ExpPilotBridge.1291\"));",
                        "    if(temp_int_2>9 && temp_int_2<=99)ArrayAdd(temp_array_2,'</color><clrEnd>'+StarName(temp_dword)+': <clr>'+CT('FormInfo.td_otstup_158')+temp_int_2+CT(\"Script.Mod_ExpPilotBridge.1291\"));",
                        "    if(temp_int_2>99)ArrayAdd(temp_array_2,'</color><clrEnd>'+StarName(temp_dword)+': <clr>'+CT('FormInfo.td_otstup_150')+temp_int_2+CT(\"Script.Mod_ExpPilotBridge.1291\"));",
                        "}",
