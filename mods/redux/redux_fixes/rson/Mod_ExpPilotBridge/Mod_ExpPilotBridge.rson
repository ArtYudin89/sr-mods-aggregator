                        "        temp_dword_4=GetItemFromVault('HullDelServ_'+i);",
                        "        if(i==1)temp_str='</color>'+Format(CT(\"Script.Mod_ExpPilotBridge.1104\"),\"<0>\",Name(temp_dword_4),\"<1>\",ItemSize(temp_dword_4));",
                        "        temp_str_2=CT('FormInfo.br')+'</color>- <color=255,240,100>'+Name(temp_dword_4)+'</color>'+' <color=255,240,100>[</color><color=0,255,0>'+ItemSize(temp_dword_4)+'</color><color=255,240,100>]</color>';",
                        "        temp_int=substr(GAddTArray[i],0,1);",
                        "        temp_int_4=ItemSize(temp_dword_4);",
                        "        PutItemInVault('HullDelServ_'+i,temp_dword_4);",
                        "        //Считаем украденные корпуса",
                        "        if((i==1 && (HullWasStolen==1 || HullWasStolen==3 || HullWasStolen==5 || HullWasStolen==7)) || (i==2 && (HullWasStolen==2 || HullWasStolen==3 || HullWasStolen==6 || HullWasStolen==7)) || (i==3 && (HullWasStolen==4 || HullWasStolen==5 || HullWasStolen==6 || HullWasStolen==7)))",
                        "        {",
