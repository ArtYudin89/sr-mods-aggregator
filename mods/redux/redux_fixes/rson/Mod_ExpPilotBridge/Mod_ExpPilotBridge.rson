                        "            else if(temp_int_4==3)TransHullCost=round((0.00315*temp_int_1)*(80*temp_int_3));",
                        "            else if(temp_int_4==4)TransHullCost=round((0.00315*temp_int_1)*(90*temp_int_3));",
