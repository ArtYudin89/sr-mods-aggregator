                {
                    "Name": "",
                    "Code.Type": "Turn",
                    "Code": [
                        "//Составляем строку со списком предметов, доступных для отправки со склада",
                        "temp_str='</color>';",
                        "for(i=1; i<ArrayDim(transfer_list_can); i=i+1)",
                        "{",
                        "    temp_str=temp_str+i+'. '+'<color=0,50,200>'+Name(transfer_list_can[i])+'</color>'+' (<color=0,50,200>'+ItemSize(transfer_list_can[i])+CT(\"Script.Mod_ExpPilotBridge.771\")+CT(\"Script.Mod_ExpPilotBridge.67\");",
                        "}",
                        "if(GetGameOptions('FontDialog') == '0') DefSplt = '</color>-------------------------------------------------------------';",
                        "else if(GetGameOptions('FontDialog') == '1') DefSplt = '</color>------------------------------------------';",
