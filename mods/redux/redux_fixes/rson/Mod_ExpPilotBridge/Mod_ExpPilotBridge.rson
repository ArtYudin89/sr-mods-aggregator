                {
                    "Name": "",
                    "Code.Type": "Turn",
                    "Code": [
                        "//Формирование списка предметов в диалоге и соответствующих ему ответов",
                        "if(GAnswerData>=100000000) temp_int=GAnswerData%100000000;",
                        "else temp_int=GAnswerData;",
                        "temp_int_2=0;",
                        "",
                        "//Значения переменной temp_int_2: 1 - игрок нажал кнопку \"Добавить\", 2 - игрок нажал кнопку \"Удалить\"",
                        "//Добавляем предмет в список на перевозку",
                        "if(GAnswerData<100000000 && temp_int_2==0)",
                        "{",
                        "    if(((ItemType(transfer_list_can[temp_int])>=0 && ItemType(transfer_list_can[temp_int])<=7) || ItemType(transfer_list_can[temp_int])==t_Protoplasm || ItemType(transfer_list_can[temp_int])==t_UselessCountableItem) && ItemSize(transfer_list_can[temp_int])>1)",
                        "    {",
                        "        if((ItemType(transfer_list_can[temp_int])>=0 && ItemType(transfer_list_can[temp_int])<=7) || ItemType(transfer_list_can[temp_int])==t_Protoplasm)",
                        "        {",
                        "            if(ItemType(transfer_list_can[temp_int])==0) temp_str='Bm.Items.2Food';",
                        "            else if(ItemType(transfer_list_can[temp_int])==1) temp_str='Bm.Items.2Medicine';",
                        "            else if(ItemType(transfer_list_can[temp_int])==2) temp_str='Bm.Items.2Technics';",
                        "            else if(ItemType(transfer_list_can[temp_int])==3) temp_str='Bm.Items.2Luxury';",
                        "            else if(ItemType(transfer_list_can[temp_int])==4) temp_str='Bm.Items.2Minerals';",
                        "            else if(ItemType(transfer_list_can[temp_int])==5) temp_str='Bm.Items.2Alcohol';",
                        "            else if(ItemType(transfer_list_can[temp_int])==6) temp_str='Bm.Items.2Arms';",
                        "            else if(ItemType(transfer_list_can[temp_int])==7) temp_str='Bm.Items.2Narcotics';",
                        "",
                        "            //Ноды",
                        "            if(ItemType(transfer_list_can[temp_int])==t_Protoplasm)",
                        "            {",
                        "                temp_str='Bm.Items.2Nod4_s';",
                        "                if(ItemSize(transfer_list_can[temp_int])<=79) temp_str='Bm.Items.2Nod3_s';",
                        "                if(ItemSize(transfer_list_can[temp_int])<=59) temp_str='Bm.Items.2Nod2_s';",
                        "                if(ItemSize(transfer_list_can[temp_int])<=39) temp_str='Bm.Items.2Nod1_s';",
                        "                if(ItemSize(transfer_list_can[temp_int])<=19) temp_str='Bm.Items.2Nod0_s';",
                        "            }",
                        "        }",
                        "        if(ItemType(transfer_list_can[temp_int])==t_UselessCountableItem)",
                        "        {",
                        "            temp_str='Bm.Items.2'+EquipmentImageName(transfer_list_can[temp_int])+'4_s';",
                        "            if(ItemSize(transfer_list_can[temp_int])<=79) temp_str='Bm.Items.2'+EquipmentImageName(transfer_list_can[temp_int])+'3_s';",
                        "            if(ItemSize(transfer_list_can[temp_int])<=59) temp_str='Bm.Items.2'+EquipmentImageName(transfer_list_can[temp_int])+'2_s';",
                        "            if(ItemSize(transfer_list_can[temp_int])<=39) temp_str='Bm.Items.2'+EquipmentImageName(transfer_list_can[temp_int])+'1_s';",
                        "            if(ItemSize(transfer_list_can[temp_int])<=19) temp_str='Bm.Items.2'+EquipmentImageName(transfer_list_can[temp_int])+'0_s';",
                        "        }",
                        "",
                        "        temp_str_4=CT(\"Script.Mod_ExpPilotBridge.1013\");",
                        "        if(temp_array_5[temp_int]==0)temp_array_5[temp_int]=CountBox(temp_str,temp_str_4,0,ItemSize(transfer_list_can[temp_int]),0,1,ItemSize(transfer_list_can[temp_int]),ItemSize(transfer_list_can[temp_int]),ItemSize(transfer_list_can[temp_int]),ItemSize(transfer_list_can[temp_int]));",
                        "        else temp_array_5[temp_int]=temp_array_5[temp_int]+CountBox(temp_str,temp_str_4,0,ItemSize(transfer_list_can[temp_int])-temp_array_5[temp_int],0,1,ItemSize(transfer_list_can[temp_int])-temp_array_5[temp_int],ItemSize(transfer_list_can[temp_int])-temp_array_5[temp_int],ItemSize(transfer_list_can[temp_int])-temp_array_5[temp_int],ItemSize(transfer_list_can[temp_int])-temp_array_5[temp_int]);",
                        "        if(temp_array_5[temp_int]==ItemSize(transfer_list_can[temp_int]))temp_array_5[temp_int]=-1;",
                        "    }",
                        "    else temp_array_5[temp_int]=-1;",
                        "    temp_int_2=1;",
                        "}",
                        "",
                        "//Удаляем предмет из списка на перевозку",
                        "if(GAnswerData>=100000000 && temp_int_2==0)",
                        "{",
                        "    if(((ItemType(transfer_list_can[temp_int])>=0 && ItemType(transfer_list_can[temp_int])<=7) || ItemType(transfer_list_can[temp_int])==t_Protoplasm || ItemType(transfer_list_can[temp_int])==t_UselessCountableItem) && ItemSize(transfer_list_can[temp_int])>1)",
                        "    {",
                        "        if((ItemType(transfer_list_can[temp_int])>=0 && ItemType(transfer_list_can[temp_int])<=7) || ItemType(transfer_list_can[temp_int])==t_Protoplasm)",
                        "        {",
                        "            if(ItemType(transfer_list_can[temp_int])==0)temp_str='Bm.Items.2Food';",
                        "            if(ItemType(transfer_list_can[temp_int])==1)temp_str='Bm.Items.2Medicine';",
                        "            if(ItemType(transfer_list_can[temp_int])==2)temp_str='Bm.Items.2Technics';",
                        "            if(ItemType(transfer_list_can[temp_int])==3)temp_str='Bm.Items.2Luxury';",
                        "            if(ItemType(transfer_list_can[temp_int])==4)temp_str='Bm.Items.2Minerals';",
                        "            if(ItemType(transfer_list_can[temp_int])==5)temp_str='Bm.Items.2Alcohol';",
                        "            if(ItemType(transfer_list_can[temp_int])==6)temp_str='Bm.Items.2Arms';",
                        "            if(ItemType(transfer_list_can[temp_int])==7)temp_str='Bm.Items.2Narcotics';",
                        "            //Ноды",
                        "            if(ItemType(transfer_list_can[temp_int])==t_Protoplasm)",
                        "            {",
                        "                temp_str='Bm.Items.2Nod4_s';",
                        "                if(ItemSize(transfer_list_can[temp_int])<=79)temp_str='Bm.Items.2Nod3_s';",
                        "                if(ItemSize(transfer_list_can[temp_int])<=59)temp_str='Bm.Items.2Nod2_s';",
                        "                if(ItemSize(transfer_list_can[temp_int])<=39)temp_str='Bm.Items.2Nod1_s';",
                        "                if(ItemSize(transfer_list_can[temp_int])<=19)temp_str='Bm.Items.2Nod0_s';",
                        "            }",
                        "        }",
                        "        if(ItemType(transfer_list_can[temp_int])==t_UselessCountableItem)",
                        "        {",
                        "            temp_str='Bm.Items.2'+EquipmentImageName(transfer_list_can[temp_int])+'4_s';",
                        "            if(ItemSize(transfer_list_can[temp_int])<=79)temp_str='Bm.Items.2'+EquipmentImageName(transfer_list_can[temp_int])+'3_s';",
                        "            if(ItemSize(transfer_list_can[temp_int])<=59)temp_str='Bm.Items.2'+EquipmentImageName(transfer_list_can[temp_int])+'2_s';",
                        "            if(ItemSize(transfer_list_can[temp_int])<=39)temp_str='Bm.Items.2'+EquipmentImageName(transfer_list_can[temp_int])+'1_s';",
                        "            if(ItemSize(transfer_list_can[temp_int])<=19)temp_str='Bm.Items.2'+EquipmentImageName(transfer_list_can[temp_int])+'0_s';",
                        "        }",
                        "        temp_str_4=CT(\"Script.Mod_ExpPilotBridge.1012\");",
                        "        if(temp_array_5[temp_int]==-1)temp_array_5[temp_int]=ItemSize(transfer_list_can[temp_int])-CountBox(temp_str,temp_str_4,0,ItemSize(transfer_list_can[temp_int]),0,1,ItemSize(transfer_list_can[temp_int]),ItemSize(transfer_list_can[temp_int]),ItemSize(transfer_list_can[temp_int]),ItemSize(transfer_list_can[temp_int]));",
                        "        else temp_array_5[temp_int]=temp_array_5[temp_int]-CountBox(temp_str,temp_str_4,0,temp_array_5[temp_int],0,1,temp_array_5[temp_int],temp_array_5[temp_int],temp_array_5[temp_int],temp_array_5[temp_int]);",
                        "    }",
                        "    else temp_array_5[temp_int]=0;",
                        "    temp_int_2=2;",
                        "}",
                        "temp_int=0;",
                        "temp_str='';",
                        "",
                        "//Заполняем строку с содержанием списка",
                        "for(i=1; i<ArrayDim(temp_array_5); i=i+1)",
                        "{",
                        "    //Нажали \"Добавить\"",
                        "    if(temp_int_2==1)",
                        "    {",
                        "        if(temp_array_5[i]==-1)",
                        "        {",
                        "            temp_array_2[i]=Name(transfer_list_can[i])+' (<color=0,50,200>'+ItemSize(transfer_list_can[i])+'</color>';",
                        "            temp_int=temp_int+1;",
                        "            temp_str=temp_str+'</color>'+temp_int+'. '+temp_array_6[i]+CT(\"Script.Mod_ExpPilotBridge.67\");",
                        "        }",
                        "        else if(temp_array_5[i]>0)",
                        "        {",
                        "            temp_array_2[i]=Name(transfer_list_can[i])+' (<color=0,50,200>'+(ItemSize(transfer_list_can[i])-temp_array_5[i])+'</color>';",
                        "            temp_array_4[i]=Name(transfer_list_can[i])+' (<color=0,50,200>'+temp_array_5[i]+'</color>';",
                        "            temp_int=temp_int+1;",
                        "            temp_str=temp_str+'</color>'+temp_int+'. </color><color=0,50,200>'+DeleteTags(Name(transfer_list_can[i]))+'</color> (<color=0,50,200>'+temp_array_5[i]+CT(\"Script.Mod_ExpPilotBridge.771\")+CT(\"Script.Mod_ExpPilotBridge.67\");",
                        "        }",
                        "    }",
                        "",
                        "    //Нажали \"Удалить\"",
                        "    if(temp_int_2==2)",
                        "    {",
                        "        if(!temp_array_5[i]) temp_array_2[i]=Name(transfer_list_can[i])+' (<color=0,50,200>'+ItemSize(transfer_list_can[i])+'</color>';",
                        "        else if(temp_array_5[i] > 0)",
                        "        {",
                        "            temp_array_2[i]=Name(transfer_list_can[i])+' (<color=0,50,200>'+(ItemSize(transfer_list_can[i])-temp_array_5[i])+'</color>';",
                        "            temp_array_4[i]=Name(transfer_list_can[i])+' (<color=0,50,200>'+temp_array_5[i]+'</color>';",
                        "            temp_int=temp_int+1;",
                        "            temp_str=temp_str+'</color>'+temp_int+'. </color><color=0,50,200>'+DeleteTags(Name(transfer_list_can[i]))+'</color> (<color=0,50,200>'+temp_array_5[i]+CT(\"Script.Mod_ExpPilotBridge.771\")+CT(\"Script.Mod_ExpPilotBridge.67\");",
                        "        }",
                        "    }",
                        "}",
                        "",
                        "if(~temp_int) temp_str = CT('FormInfo.td_otstup_CargoList') + CT(\"Script.Mod_ExpPilotBridge.1009\");",
                        "",
                        "//Установка длины \"дефисного разделителя\" в зависимости от выбранного в игре размера шрифта",
