                        "            else if(temp_int_4==2)TransHullCost=round((0.00315*temp_int_1)*666.0);",
                        "            else if(temp_int_4==3)TransHullCost=round((0.00315*temp_int_1)*835.0);",
                        "            else if(temp_int_4==4)TransHullCost=round((0.00315*temp_int_1)*1000.0);",
                        "            else if(temp_int_4==5)TransHullCost=round((0.00315*temp_int_1)*1330.0);",
                        "            else if(temp_int_4==6)TransHullCost=round((0.00315*temp_int_1)*1660.0);",
                        "            else if(temp_int_4==7)TransHullCost=round((0.00315*temp_int_1)*2000.0);",
                        "            else if(temp_int_4>=8)TransHullCost=round((0.00315*temp_int_1)*2500.0);",
                        "        }",
