            ],
            "Operations": [
                {
                    "Name": "",
                    "Code.Type": "Global",
                    "Code": [
                        "if(!GCntRun(GScriptName)) GRun();"
                    ],
                    "#": 266,
                    "Type": "Top",
                    "Parent": -1,
                    "Pos.x": 0,
                    "Pos.y": 1535
                },
                {
                    "Name": "",
                    "Code.Type": "Init",
                    "Code": [
                        "bld_ship_planet_list = newarray(1);",
                        "bld_ship_planet_list_2 = newarray(1);",
                        "transfer_list_can = newarray(1);",
                        "transfer_list_done = newarray(1);",
                        "GHullsWaitArray = newarray(1);",
                        "GAddTArray = newarray(1);",
                        "GAddTArray2 = newarray(1);",
                        "temp_array = newarray(1);",
                        "temp_array_2 = newarray(1);",
                        "temp_array_3 = newarray(1);",
                        "temp_array_4 = newarray(1);",
                        "temp_array_5 = newarray(1);",
                        "temp_array_6 = newarray(1);",
                        "",
                        "//Для удобства сразу запоминаем текущий ГТУ в отдельную переменную",
                        "GTL = GalaxyTechLevel();",
                        "",
                        "if(CapitalShipStats(ShipItems(Player(), 0)) == 0) CapitalShipStats(ShipItems(Player(), 0), 3);",
                        "else if(CapitalShipStats(ShipItems(Player(), 0)) == 2) CapitalShipStats(ShipItems(Player(), 0), 3);",
                        "ShipAddCustomShipInfo(Player(), 'PlayerBridgeHV_infos', 'NoShow');",
                        "ShipAddCustomShipInfo(Player(), 'PlayerBridge_ContrabandWin', 'NoShow');",
                        "",
                        "//Выставляем самые первые планеты для слэпстартера",
                        "for(i = 0; i < GalaxyStars(); i = i + 1)",
                        "{",
                        "    temp_dword = GalaxyStar(i);",
                        "    if(StarOwner(temp_dword) == 1) continue;",
                        "    if(StarCustomFaction(temp_dword) != '') continue;",
                        "",
                        "    //Исключаем Тортугац и Нифигац",
                        "    if(StarToCon(temp_dword) == StarToCon(PlanetToStar(PlanetPirateClan()))) continue;",
                        "",
                        "    for(j = 0; j < StarPlanets(temp_dword); j = j + 1)",
                        "    {",
                        "        temp_dword_2 = StarPlanets(temp_dword, j);",
                        "        temp_int_2 = PlanetOwner(temp_dword_2);",
                        "        if(temp_int_2 == 6) continue;",
                        "        if(PirateWin() < 3 && StarOwner(temp_dword) == 2 && !bld_planet_chsn_2) ArrayAdd(bld_ship_planet_list_2, Id(temp_dword_2));",
                        "        if(!CoalitionDefeated() && StarOwner(temp_dword) == 0 && !bld_planet_chsn) ArrayAdd(bld_ship_planet_list, Id(temp_dword_2));",
                        "    }",
                        "}",
                        "//Создаём Коалиционные проекты Слэпстартера",
                        "if(!bld_planet_chsn && ArrayDim(bld_ship_planet_list) > 1)",
                        "{",
                        "    //Обнуляем сумму возврата в случае не набора проектом требуемой суммы (сумма возврата задаётся при внесении донатов игроком)",
                        "    repay = 0;",
                        "    //Тип коалиционных кораблей (влияет только на название)",
                        "    type_coal = Rnd(1, 3);",
                        "    //Число коалиционных кораблей",
                        "    ship_count = Rnd(3, 7);",
                        "    temp_int = Rnd(1, ArrayDim(bld_ship_planet_list) - 1);",
                        "    bld_ship_planet = bld_ship_planet_list[temp_int];",
                        "",
                        "    //Определяем имя коалиционного отряда",
                        "    tint1 = PlanetRace(IdToPlanet(bld_ship_planet));",
                        "    if(tint1 == Maloc) bld_ship_name = CT('ShipType.Maloc.Militiaman' + type_coal);",
                        "    else if(tint1 == Peleng) bld_ship_name = CT('ShipType.Peleng.Militiaman' + type_coal);",
                        "    else if(tint1 == People) bld_ship_name = CT('ShipType.People.Militiaman' + type_coal);",
                        "    else if(tint1 == Fei) bld_ship_name = CT('ShipType.Fei.Militiaman' + type_coal);",
                        "    else if(tint1 == Gaal) bld_ship_name = CT('ShipType.Gaal.Militiaman' + type_coal);",
                        "",
                        "    //Проверочная переменная, что сбор коалиционных донатов начался",
                        "    bld_planet_chsn = 1;",
                        "    //Устанавливаем общую стоимость реализации проекта",
                        "    bld_cost = GTL * GalaxyDiffLevels() * ship_count * 125;",
                        "    //Устанавливаем общее время сбора донатов (от 45 до 60 дней)",
                        "    bld_day = 45 + CurTurn() + Rnd(0, 15);",
                        "",
                        "    //Задаём общий размер всех пассивных взносов, которые поступят на коалиционный проект",
                        "    temp_int_7 = GalaxyDiffLevels();",
                        "    if(temp_int_7 <= 125) dif_koef = bld_cost - round(0.35 * bld_cost) + round((0.01 * Rnd(0, 15)) * bld_cost);",
                        "    if(temp_int_7 > 125 && temp_int_7 <= 250) dif_koef = bld_cost - round(0.45 * bld_cost) + round((0.01 * Rnd(0, 15)) * bld_cost);",
                        "    if(temp_int_7 > 250) dif_koef = bld_cost - round(0.60 * bld_cost) + round((0.01 * Rnd(0, 15)) * bld_cost);",
                        "    temp_int_3 = bld_day - CurTurn();",
                        "    //Задаём размер ежедневных пассивных взносов на коалиционный проект",
                        "    add_cr_day_1 = dif_koef / temp_int_3;",
                        "    credits_now = round(0.61 * bld_cost);",
                        "}",
                        "",
                        "//Создаём пиратский проект Слэпстартера (срабатывает, если предыдущий проект завершён)",
                        "if(!bld_planet_chsn_2 && ArrayDim(bld_ship_planet_list_2) > 1)",
                        "{",
                        "    //Обнуляем сумму возврата в случае не набора проектом требуемой суммы (сумма возврата задаётся при внесении донатов игроком)",
                        "    repay_2 = 0;",
                        "",
                        "    //Число пиратских кораблей",
                        "    ship_count_2 = Rnd(3, 7);",
                        "    temp_int = Rnd(1, ArrayDim(bld_ship_planet_list_2) - 1);",
                        "    bld_ship_planet_2 = bld_ship_planet_list_2[temp_int];",
                        "",
                        "    //Определяем имя пиратского отряда",
                        "    tint1 = PlanetRace(IdToPlanet(bld_ship_planet_2));",
                        "    if(tint1 == Maloc) bld_ship_name_2 = CT('ShipType.Maloc.Rebel');",
                        "    else if(tint1 == Peleng) bld_ship_name_2 = CT('ShipType.Peleng.Rebel');",
                        "    else if(tint1 == People) bld_ship_name_2 = CT('ShipType.People.Rebel');",
                        "    else if(tint1 == Fei) bld_ship_name_2 = CT('ShipType.Fei.Rebel');",
                        "    else if(tint1 == Gaal) bld_ship_name_2 = CT('ShipType.Gaal.Rebel');",
                        "",
                        "    //Проверочная переменная, что сбор пиратских донатов начался",
                        "    bld_planet_chsn_2 = 1;",
                        "    //Устанавливаем общую стоимость реализации проекта",
                        "    bld_cost_2 = GTL * GalaxyDiffLevels() * ship_count_2 * 120;",
                        "    //Устанавливаем общее время сбора донатов (от 45 до 60 дней)",
                        "    bld_day_2 = 45 + CurTurn() + Rnd(0, 15);",
                        "    //Задаём общий размер всех пассивных взносов, которые поступят на пиратский проект",
                        "    temp_int_7 = GalaxyDiffLevels();",
                        "",
                        "    if(temp_int_7 <= 125) dif_koef_2 = bld_cost_2 - round(0.35 * bld_cost_2) + round((0.01 * Rnd(0, 15)) * bld_cost);",
                        "    else if(temp_int_7 <= 250) dif_koef_2 = bld_cost_2 - round(0.45 * bld_cost_2) + round((0.01 * Rnd(0, 15)) * bld_cost);",
                        "    else dif_koef_2 = bld_cost_2 - round(0.60 * bld_cost_2) + round((0.01 * Rnd(0, 15)) * bld_cost);",
                        "",
                        "    temp_int_3 = bld_day_2 - CurTurn();",
                        "    //Задаём размер ежедневных пассивных взносов на пиратский проект",
                        "    add_cr_day_2 = dif_koef_2 / temp_int_3;",
                        "    credits_now_2 = round(0.39 * bld_cost_2);",
                        "}",
                        "",
                        "//Спавним Уитли",
                        "temp_dword = StarNearbyStars(PlanetToStar(GetShipHomePlanet(Player())), Rnd(35, 45));",
                        "if(StarToCon(temp_dword) == StarToCon(PlanetToStar(PlanetPirateClan()))) temp_dword = StarNearbyStars(temp_dword, Rnd(5, 6));",
                        "temp_dword_1 = CreateQuestItem('ExpPilotBridge_Wheatley', 6);",
                        "ItemSize(temp_dword_1, 2);",
                        "ItemCost(temp_dword_1, 2011);",
                        "EqCustomFaction(temp_dword_1, 'Aperture_Science');",
                        "UselessItemData(temp_dword_1, 3, temp_dword);",
                        "//Для спавна вычисляем случайную точку на окружности системы (почти у самого её края)",
                        "//Вычислили угол",
                        "TempFloat3 = 0.01 * Rnd(0, 200);",
                        "//Вычислили радиус",
                        "temp_int = PlanetOrbitRadius(StarPlanets(temp_dword, StarPlanets(temp_dword) - 1)) + 800;",
                        "TempFloat2 = round(sin(TempFloat3 * pi) * temp_int);",
                        "temp_int_1 = TempFloat2; //Координата X",
                        "TempFloat2 = round(cos(TempFloat3 * pi) * temp_int);",
                        "temp_int = TempFloat2; //Координата Y",
                        "DropItemInSystem(temp_dword, temp_dword_1, temp_int_1, temp_int, temp_int_1, temp_int);",
                        "StopMovingItem(temp_dword, temp_dword_1);",
                        "//Заносим Уитли в скриптовый объект (чтобы NPC его не трогали)",
                        "LinkItemToScript(temp_dword_1, Script_Wheatley);",
                        "ScriptItemData(Script_Wheatley, 1, temp_int_1); //Запоминаем координату X",
                        "ScriptItemData(Script_Wheatley, 2, temp_int); //Запоминаем координату Y",
                        "ScriptItemData(Script_Wheatley, 3, Id(temp_dword) - 1); //Запоминаем систему, в которой появился Уитли",
                        "GScriptWheatley = -1;",
                        "",
                        "//Акткод для скриптового объекта Уитли",
                        "function OnActCode_ScriptWheatley() //t_OnItemHit, t_OnItemPickUp",
                        "{",
                        "    //Экранируем Уитли от случайного попадания ракет",
                        "    dword wheatley = CurItem();",
                        "    if(ScriptItemActionType(t_OnItemHit))",
                        "    {",
                        "        dword ship = ScriptItemActShip();",
                        "        dword gun = ScriptItemActObject1();",
                        "        //Если предмет ломает сам игрок, то и пошёл он нахер",
                        "        if(ship != Player())",
                        "        {",
                        "            //Если в предмет попал выстрел",
                        "            if(ObjectType(gun) != 7)",
                        "            {",
                        "                WeaponTarget(gun, 0);",
                        "                ItemDestroy(wheatley, 0);",
                        "            }",
                        "            else",
                        "            {",
                        "                //Если предмет целенаправленно не зафокусили ракетами (сами боты этого сделать всё равно не могут)",
                        "                if(MissileTarget(gun) != wheatley)",
                        "                {",
                        "                    MissileTarget(gun, 0);",
                        "                    ItemDestroy(wheatley, -1);",
                        "                }",
                        "            }",
                        "        }",
                        "    }",
                        "    //Выводим Уитли из скриптового объекта при подборе его игроком (больше подбирать его некому)",
                        "    else /*if(ScriptItemActionType() == t_OnItemPickUp)*/ ReleaseItemFromScript(wheatley);",
                        "}",
                        "//Присваиваем объекту вышеописанный акткод",
                        "ItemOnActCode(Script_Wheatley, 'OnActCode_ScriptWheatley();', 't_OnItemHit,t_OnItemPickUp');",
                        "",
                        "//Акткод для костыльных \"семерёнок\"",
                        "function OnActCode_Semerenka(ship)",
                        "{",
                        "    ShipJoin(DebtMG, ship);",
                        "}",
                        "",
                        "function OnActCode_Semerenka_2(ship)",
                        "{",
                        "    ShipOut(ship);",
                        "}",
                        "",
                        "//Костыльные семерёнки для обработки акткода с доступом к переменным скрипта",
                        "temp_dword = CreateQuestItem('Usl_62', 0);",
                        "LinkItemToScript(temp_dword, Semerenka);",
                        "PutItemInVault('Semerenka', temp_dword);",
                        "ItemOnActCode(Semerenka, 'OnActCode_Semerenka(GShipJoinGlobal);');",
                        "",
                        "temp_dword = CreateQuestItem('Usl_62', 0);",
                        "LinkItemToScript(temp_dword, Semerenka_2);",
                        "PutItemInVault('Semerenka_2', temp_dword);",
                        "ItemOnActCode(Semerenka_2, 'OnActCode_Semerenka_2(GShipJoinGlobal);');",
                        "",
                        "//Функция расчёта шанса утери груза при его доставке, либо при его возвращении на планету отправки",
                        "function CargoLostChanceCalc()",
                        "{",
                        "    //Если системы отправки и/или доставки пиратские",
                        "    temp_str_3 = GalaxyStar(DeliveryMainArray[0]); //Система откуда",
                        "    temp_str_4 = GalaxyStar(DeliveryMainArray[1]); //Система куда",
                        "",
                        "    if((StarOwner(temp_str_3) == 2 && StarCustomFaction(temp_str_3) == '') ||",
                        "       (StarOwner(temp_str_4) == 2 && StarCustomFaction(temp_str_4) == '')",
                        "      )",
                        "    {",
                        "        if(LTargetType == 1 || LTargetType == 2)",
                        "        {",
                        "            if(Rnd(1, 100) <= 15)",
                        "            {",
                        "                if(transfer_day_old > 14)",
                        "                {",
                        "                    if(StarOwner(temp_str_3) == 2 && StarCustomFaction(temp_str_3) == '')",
                        "                    {",
                        "                        CargoLost = 2;",
                        "                        transfer_day_orig = transfer_day;",
                        "                        transfer_day = transfer_day - (Rnd(5, 6) * (transfer_day_old / 7));",
                        "                    }",
                        "                    if(StarOwner(temp_str_4) == 2 && StarCustomFaction(temp_str_4) == '')",
                        "                    {",
                        "                        if(CargoLost == 2)",
                        "                        {",
                        "                            CargoLost = 3;",
                        "                        }",
                        "                        else",
                        "                        {",
                        "                            CargoLost = 4;",
                        "                        }",
                        "                        if(CargoLost == 3)",
                        "                        {",
                        "                            transfer_day_orig = transfer_day;",
                        "                            if(Rnd(0, 1))",
                        "                            {",
                        "                                transfer_day = transfer_day - (Rnd(5, 6) * (transfer_day_old / 7));",
                        "                            }",
                        "                            else",
                        "                            {",
                        "                                transfer_day = transfer_day - (Rnd(1, 2) * (transfer_day_old / 7));",
                        "                            }",
                        "                        }",
                        "                        if(CargoLost == 4)",
                        "                        {",
                        "                            transfer_day_orig = transfer_day;",
                        "                            transfer_day = transfer_day - (Rnd(1, 2) * (transfer_day_old / 7));",
                        "                        }",
                        "                    }",
                        "                }",
                        "                else",
                        "                {",
                        "                    transfer_day = transfer_day;",
                        "                    transfer_day_orig = transfer_day;",
                        "                }",
                        "            }",
                        "            else",
                        "            {",
                        "                transfer_day = transfer_day;",
                        "                transfer_day_orig = transfer_day;",
                        "            }",
                        "        }",
                        "        if(LTargetType == 3 || LTargetType == 4)",
                        "        {",
                        "            if(StarOwner(temp_str_4) == 2 && StarCustomFaction(temp_str_4) == '')",
                        "            {",
                        "                if(Rnd(1, 100) <= 15)",
                        "                {",
                        "                    if(transfer_day_old - (transfer_day - CurTurn()) > 14)",
                        "                    {",
                        "                        CargoLost = 4;",
                        "                        transfer_day = (transfer_day_old - (transfer_day - CurTurn())) - (Rnd(1, 2) * ((transfer_day_old - (transfer_day - CurTurn())) / 7)) + CurTurn();",
                        "                        transfer_day_orig = (transfer_day_old - (transfer_day - CurTurn())) + CurTurn();",
                        "                    }",
                        "                    else",
                        "                    {",
                        "                        transfer_day = (transfer_day_old - (transfer_day - CurTurn())) + CurTurn();",
                        "                        transfer_day_orig = transfer_day;",
                        "                    }",
                        "                }",
                        "                else",
                        "                {",
                        "                    transfer_day = (transfer_day_old - (transfer_day - CurTurn())) + CurTurn();",
                        "                    transfer_day_orig = transfer_day;",
                        "                }",
                        "            }",
                        "            else",
                        "            {",
                        "                if(Rnd(1, 100) <= 5)",
                        "                {",
                        "                    if(transfer_day_old - (transfer_day - CurTurn()) > 14)",
                        "                    {",
                        "                        CargoLost = 1;",
                        "                        transfer_day = (transfer_day_old - (transfer_day - CurTurn())) - (Rnd(1, 6) * ((transfer_day_old - (transfer_day - CurTurn())) / 7)) + CurTurn();",
                        "                        transfer_day_orig = (transfer_day_old - (transfer_day - CurTurn())) + CurTurn();",
                        "                    }",
                        "                }",
                        "                else",
                        "                {",
                        "                    transfer_day = (transfer_day_old - (transfer_day - CurTurn())) + CurTurn();",
                        "                    transfer_day_orig = transfer_day;",
                        "                }",
                        "            }",
                        "        }",
                        "    }",
                        "    //Если системы отправки и/или доставки не пиратские",
                        "    else",
                        "    {",
                        "        if(LTargetType == 1 || LTargetType == 2)",
                        "        {",
                        "            if(Rnd(1, 100) <= 5 && transfer_day_old > 14)",
                        "            {",
                        "                CargoLost = 1;",
                        "                transfer_day_orig = transfer_day;",
                        "                transfer_day = transfer_day - (Rnd(1, 6) * (transfer_day_old / 7));",
                        "            }",
                        "            else",
                        "            {",
                        "                transfer_day_orig = transfer_day;",
                        "                transfer_day = transfer_day;",
                        "            }",
                        "        }",
                        "        if(LTargetType == 3 || LTargetType == 4)",
                        "        {",
                        "            if(Rnd(1, 100) <= 5 && (transfer_day_old - (transfer_day - CurTurn())) > 14)",
                        "            {",
                        "                CargoLost = 1;",
                        "                transfer_day = (transfer_day_old - (transfer_day - CurTurn())) - (Rnd(1, 6) * ((transfer_day_old - (transfer_day - CurTurn())) / 7)) + CurTurn();",
                        "                transfer_day_orig = (transfer_day_old - (transfer_day - CurTurn())) + CurTurn();",
                        "            }",
                        "            else",
                        "            {",
                        "                transfer_day = (transfer_day_old - (transfer_day - CurTurn())) + CurTurn();",
                        "                transfer_day_orig = transfer_day;",
                        "            }",
                        "        }",
                        "    }",
                        "}",
                        "",
                        "//Функция расчёта шанса утери груза при его возвращении в домашнюю систему (при возвращении в домашнюю систему к таймеру добавляется 21 дополнительный день доставки)",
                        "function CargoLostChanceCalcHome()",
                        "{",
                        "    if(LTargetType != 5)",
                        "    {",
                        "        //Если домашняя система захвачена доминаторами или клисанами",
                        "        if((StarOwner(PlanetToStar(GetShipHomePlanet(Player()))) == 1 || StarCustomFaction(PlanetToStar(GetShipHomePlanet(Player()))) != ''))",
                        "        {",
                        "            CargoLost = 5;",
                        "            transfer_day = ((transfer_day_old - (transfer_day - CurTurn())) + 21) - (7 * (((transfer_day_old - (transfer_day - CurTurn())) / 8) + 21)) + CurTurn();",
                        "            transfer_day_orig = transfer_day;",
                        "        }",
                        "        //Если домашняя система пиратская и не захватывалась доминаторами/клисанами, пока к ней летел транспорт",
                        "        if((StarOwner(PlanetToStar(GetShipHomePlanet(Player()))) == 2 && StarCustomFaction(PlanetToStar(GetShipHomePlanet(Player()))) == ''))",
                        "        {",
                        "            if(Rnd(1, 100) <= 15)",
                        "            {",
                        "                CargoLost = 4;",
                        "                transfer_day = ((transfer_day_old - (transfer_day - CurTurn())) + 21) - (Rnd(5, 6) * (((transfer_day_old - (transfer_day - CurTurn())) / 7) + 21)) + CurTurn();",
                        "                transfer_day_orig = (transfer_day_old - (transfer_day - CurTurn())) + 21 + CurTurn();",
                        "            }",
                        "            else",
                        "            {",
                        "                CargoLost = 0;",
                        "                transfer_day = (transfer_day_old - (transfer_day - CurTurn())) + 21 + CurTurn();",
                        "                transfer_day_orig = transfer_day;",
                        "            }",
                        "        }",
                        "        //Если домашняя система коалиционная и не захватывалась доминаторами/клисанами, пока к ней летел транспорт",
                        "        if(StarOwner(PlanetToStar(GetShipHomePlanet(Player()))) == 0)",
                        "        {",
                        "            if(Rnd(1, 100) <= 5)",
                        "            {",
                        "                CargoLost = 1;",
                        "                transfer_day = ((transfer_day_old - (transfer_day - CurTurn())) + 21) - (Rnd(1, 6) * (((transfer_day_old - (transfer_day - CurTurn())) / 7) + 21)) + CurTurn();",
                        "                transfer_day_orig = (transfer_day_old - (transfer_day - CurTurn())) + 21 + CurTurn();",
                        "            }",
                        "            else",
                        "            {",
                        "                CargoLost = 0;",
                        "                transfer_day = (transfer_day_old - (transfer_day - CurTurn())) + 21 + CurTurn();",
                        "                transfer_day_orig = transfer_day;",
                        "            }",
                        "        }",
                        "    }",
                        "    else",
                        "    {",
                        "        //Если домашняя система была захвачена доминаторами или клисанами пока к ней летел транспорт",
                        "        if((StarOwner(PlanetToStar(GetShipHomePlanet(Player()))) == 1 || StarCustomFaction(PlanetToStar(GetShipHomePlanet(Player()))) != ''))",
                        "        {",
                        "            CargoLost = 5;",
                        "            transfer_day = ((transfer_day_old - ((transfer_day_start + transfer_day_old) - CurTurn())) + 21) - (7 * (((transfer_day_old - ((transfer_day_start + transfer_day_old) - CurTurn())) / 8) + 21)) + CurTurn();",
                        "            transfer_day_orig = transfer_day;",
                        "        }",
                        "",
                        "        //Если домашняя система пиратская и уже захватывалась доминаторами/клисанами, пока к ней летел транспорт",
                        "        if((StarOwner(PlanetToStar(GetShipHomePlanet(Player()))) == 2 && StarCustomFaction(PlanetToStar(GetShipHomePlanet(Player()))) == ''))",
                        "        {",
                        "            if(Rnd(1, 100) <= 15)",
                        "            {",
                        "                CargoLost = 4;",
                        "                transfer_day = ((transfer_day_old - ((transfer_day_start + transfer_day_old) - CurTurn())) + 21) - (Rnd(5, 6) * (((transfer_day_old - ((transfer_day_start + transfer_day_old) - CurTurn())) / 7) + 21)) + CurTurn();",
                        "                transfer_day_orig = (transfer_day_old - ((transfer_day_start + transfer_day_old) - CurTurn())) + 21 + CurTurn();",
                        "            }",
                        "            else",
                        "            {",
                        "                CargoLost = 0;",
                        "                transfer_day = (transfer_day_old - ((transfer_day_start + transfer_day_old) - CurTurn())) + 21 + CurTurn();",
                        "                transfer_day_orig = transfer_day;",
                        "            }",
                        "        }",
                        "        //Если домашняя система коалиционная и уже захватывалась доминаторами/клисанами, пока к ней летел транспорт",
                        "        if(StarOwner(PlanetToStar(GetShipHomePlanet(Player()))) == 0)",
                        "        {",
                        "            if(Rnd(1, 100) <= 5)",
                        "            {",
                        "                CargoLost = 1;",
                        "                transfer_day = ((transfer_day_old - ((transfer_day_start + transfer_day_old) - CurTurn())) + 21) - (Rnd(1, 6) * (((transfer_day_old - ((transfer_day_start + transfer_day_old) - CurTurn())) / 7) + 21)) + CurTurn();",
                        "                transfer_day_orig = (transfer_day_old - ((transfer_day_start + transfer_day_old) - CurTurn())) + 21 + CurTurn();",
                        "            }",
                        "            else",
                        "            {",
                        "                CargoLost = 0;",
                        "                transfer_day = (transfer_day_old - ((transfer_day_start + transfer_day_old) - CurTurn())) + 21 + CurTurn();",
                        "                transfer_day_orig = transfer_day;",
                        "            }",
                        "        }",
                        "    }",
                        "}",
                        "",
                        "//Функция создания кораблей, присвоивших корпус(а) игрока",
                        "function HullWasStolenThiefCreate(HullDelEndCheck)",
                        "{",
                        "    temp_str_3='';",
                        "    //Просто берём одну из ближайших к доставочной систем, если корпус был украден в конце доставки",
                        "    temp_dword_2=StarNearbyStars(GalaxyStar(HullEndStarId),1);",
                        "    temp_dword_3=StarNearbyStars(GalaxyStar(HullEndStarId),2);",
                        "    if(HullDelEndCheck==1 && ((StarOwner(temp_dword_2)!=1 && StarCustomFaction(temp_dword_2)=='') || (StarOwner(temp_dword_3)!=1 && StarCustomFaction(temp_dword_3)=='')))",
                        "    {",
                        "        if(StarOwner(temp_dword_2)!=1 && StarCustomFaction(temp_dword_2)=='')temp_dword_2=StarNearbyStars(GalaxyStar(HullEndStarId),1);",
                        "        if(StarOwner(temp_dword_3)!=1 && StarCustomFaction(temp_dword_3)=='')temp_dword_2=StarNearbyStars(GalaxyStar(HullEndStarId),2);",
                        "        if((StarOwner(temp_dword_2)!=1 && StarCustomFaction(temp_dword_2)=='') && (StarOwner(temp_dword_3)!=1 && StarCustomFaction(temp_dword_3)==''))temp_dword_2=StarNearbyStars(GalaxyStar(HullEndStarId),Rnd(1,2));",
                        "    }",
                        "    else",
                        "    {",
                        "        //Вычисляем и сравниваем квадрат расстояния от точки условного",
                        "        //местонахождения курьера(ов) (на отрезке пути от системы А к системе Б)",
                        "        //до каждой звезды в рукаве Галактики.",
                        "        //Таким образом определяем условную систему его текущего местоположения",
                        "        TempFloat1=0;",
                        "        TempFloat2=0;",
                        "        TempFloat3=0;",
                        "        temp_dword_2=0;",
                        "        TempFloat4=100000000;",
                        "        temp_dword_3=GalaxyStar(HullFromStarId);",
                        "        temp_dword_4=GalaxyStar(HullEndStarId);",
                        "        //Определяем процент расстояния положения курьера между системами А и Б",
                        "        TempFloat2=min((1.0*(CurTurn()-HullDelTimeStart))/(HullDelTime-HullDelTimeStart));",
                        "        //Определяем точку координат условного местоположения курьера по X и Y",
                        "        TempFloat1=TempFloat2*CoordX(temp_dword_4)+(1-TempFloat2)*CoordX(temp_dword_3);",
                        "        TempFloat2=TempFloat2*CoordY(temp_dword_4)+(1-TempFloat2)*CoordY(temp_dword_3);",
                        "        for(i=0;i<GalaxyStars();i=i+1)",
                        "        {",
                        "            if(StarOwner(GalaxyStar(i))==1)continue;",
                        "            if(StarCustomFaction(GalaxyStar(i))!='')continue;",
                        "            if(StarToCon(GalaxyStar(i))==StarToCon(PlanetToStar(PlanetPirateClan())))continue;",
                        "            //Определяем квадрат расстояния удаления каждой системы от точки условного расположения курьера",
                        "            TempFloat3=sqr(CoordX(GalaxyStar(i))-TempFloat1)+sqr(CoordY(GalaxyStar(i))-TempFloat2);",
                        "            //Сравниваем и запоминаем систему с наименьшим удалением от установленной точки координат",
                        "            if(TempFloat3<TempFloat4)",
                        "            {",
                        "                TempFloat4=TempFloat3;",
                        "                temp_dword_2=GalaxyStar(i);",
                        "            }",
                        "        }",
                        "        //Повтор цикла без пропуска доминаторских и клисанских систем, на случай полного захвата рукава галактики",
                        "        if(temp_dword_2==0)",
                        "        {",
                        "            for(i=0;i<GalaxyStars();i=i+1)",
                        "            {",
                        "                if(StarToCon(GalaxyStar(i))==StarToCon(PlanetToStar(PlanetPirateClan())))continue;",
                        "                //Определяем квадрат расстояния удаления каждой системы от точки условного расположения курьера",
                        "                TempFloat3=sqr(CoordX(GalaxyStar(i))-TempFloat1)+sqr(CoordY(GalaxyStar(i))-TempFloat2);",
                        "                //Сравниваем и запоминаем систему с наименьшим удалением от установленной точки координат",
                        "                if(TempFloat3<TempFloat4)",
                        "                {",
                        "                    TempFloat4=TempFloat3;",
                        "                    temp_dword_2=GalaxyStar(i);",
                        "                }",
                        "            }",
                        "        }",
                        "    }",
                        "    //Перебираем корпуса (если их несколько), определяем, какие именно украли",
                        "    ArrayClear(temp_array_6);",
                        "    temp_int_3=0;",
                        "    for(i=1;i<=HullOnWay;i=i+1)",
                        "    {",
                        "        if((i==1 && (HullWasStolen==1 || HullWasStolen==3 || HullWasStolen==5 || HullWasStolen==7)) || (i==2 && (HullWasStolen==2 || HullWasStolen==3 || HullWasStolen==6 || HullWasStolen==7)) || (i==3 && (HullWasStolen==4 || HullWasStolen==5 || HullWasStolen==6 || HullWasStolen==7)))",
                        "        {",
                        "            //Рандомно определяем планету или станцию спавна корабля вора",
                        "            temp_dword_3=0;",
                        "            while(temp_dword_3==0)",
                        "            {",
                        "                for(j=0;j<StarPlanets(temp_dword_2);j=j+1)",
                        "                {",
                        "                    if(PlanetOwner(StarPlanets(temp_dword_2,j))==6)continue;",
                        "                    if(Rnd(1,100)<=50)",
                        "                    {",
                        "                        temp_dword_3=StarPlanets(temp_dword_2,j);",
                        "                        break;",
                        "                    }",
                        "                }",
                        "            }",
                        "            //Доставлял профи",
                        "            if(substr(GAddTArray[i],0,1)==1)",
                        "            {",
                        "                //Спавним рейнджера",
                        "                if(substr(GAddTArray[i],1,1)==1 || substr(GAddTArray[i],1,1)==2)",
                        "                {",
                        "                    temp_dword_1=ThiefCreate(1,temp_dword_3,Rnd(310,400),i,1);",
                        "                }",
                        "                //Спавним фрилансера (тоже рейнджер)",
                        "                if(substr(GAddTArray[i],1,1)==3 || substr(GAddTArray[i],1,1)==4)",
                        "                {",
                        "                    temp_dword_1=ThiefCreate(1,temp_dword_3,Rnd(310,400),i,1);",
                        "                    ShipType(temp_dword_1,'Freelancer');",
                        "                    ShipStatus(temp_dword_1,0,34);",
                        "                    ShipStatus(temp_dword_1,1,33);",
                        "                    ShipStatus(temp_dword_1,2,33);",
                        "                    RangerExcludedFromRating(temp_dword_1,1);",
                        "                }",
                        "                temp_str_2=CT(\"Script.Mod_ExpPilotBridge.1154\");",
                        "            }",
                        "            //Доставлял умелец",
                        "            if(substr(GAddTArray[i],0,1)==2)",
                        "            {",
                        "                //Спавним рейнджера",
                        "                if(substr(GAddTArray[i],1,1)==1)",
                        "                {",
                        "                    temp_dword_1=ThiefCreate(1,temp_dword_3,Rnd(250,310),i,2);",
                        "                }",
                        "                //Спавним фрилансера (тоже рейнджер)",
                        "                if(substr(GAddTArray[i],1,1)==2)",
                        "                {",
                        "                    temp_dword_1=ThiefCreate(1,temp_dword_3,Rnd(250,310),i,2);",
                        "                    ShipType(temp_dword_1,'Freelancer');",
                        "                    RangerExcludedFromRating(temp_dword_1,1);",
                        "                }",
                        "                //Спавним пирата",
                        "                if(substr(GAddTArray[i],1,1)==3 || substr(GAddTArray[i],1,1)==4)",
                        "                {",
                        "                    temp_dword_1=ThiefCreate(2,temp_dword_3,Rnd(250,310),i,2);",
                        "                }",
                        "                //Спавним транспорт",
                        "                if(substr(GAddTArray[i],1,1)==5)",
                        "                {",
                        "                    temp_dword_1=ThiefCreate(3,temp_dword_3,Rnd(250,310),i,2);",
                        "                }",
                        "                temp_str_2=CT(\"Script.Mod_ExpPilotBridge.1160\");",
                        "            }",
                        "            //Доставлял салага",
                        "            if(substr(GAddTArray[i],0,1)==3)",
                        "            {",
                        "                //Спавним рейнджера",
                        "                if(substr(GAddTArray[i],1,1)==1)",
                        "                {",
                        "                    temp_dword_1=ThiefCreate(1,temp_dword_3,Rnd(160,200),i,3);",
                        "                }",
                        "                //Спавним пирата",
                        "                if(substr(GAddTArray[i],1,1)==2 || substr(GAddTArray[i],1,1)==3 || substr(GAddTArray[i],1,1)==4)",
                        "                {",
                        "                    temp_dword_1=ThiefCreate(2,temp_dword_3,Rnd(160,200),i,3);",
                        "                }",
                        "                //Спавним транспорт",
                        "                if(substr(GAddTArray[i],1,1)==5 || substr(GAddTArray[i],1,1)==6)",
                        "                {",
                        "                    temp_dword_1=ThiefCreate(3,temp_dword_3,Rnd(160,200),i,3);",
                        "                }",
                        "                temp_str_2=CT(\"Script.Mod_ExpPilotBridge.1159\");",
                        "            }",
                        "            //Запоминаем счётчик дней до отправки сообщения о местонахождении воров",
                        "            //Нужен, чтобы дать ворам фору на взлёт с планеты",
                        "            temp_int_3=temp_int_3+1;",
                        "            //Формируем уведомление о кораблях воров",
                        "            if(i>1)temp_str_3=temp_str_3+CT('FormInfo.br')+' '+CT('FormInfo.br');",
                        "            temp_str_3=temp_str_3+CT(\"Script.Mod_ExpPilotBridge.1200\")+Name(temp_dword_1)+'<clrEnd>'+CT('FormInfo.br')+CT(\"Script.Mod_ExpPilotBridge.1199\")+temp_str_2+'<clrEnd>'+CT('FormInfo.br')+CT(\"Script.Mod_ExpPilotBridge.1198\")+ConName(StarToCon(PlanetToStar(temp_dword_3)))+'<clrEnd>'+CT('FormInfo.br')+CT(\"Script.Mod_ExpPilotBridge.1197\")+StarName(PlanetToStar(temp_dword_3))+'<clrEnd>'+CT('FormInfo.br')+CT(\"Script.Mod_ExpPilotBridge.1196\")+Name(ShipItems(temp_dword_1,0))+' [<color=0,255,0>'+ItemSize(ShipItems(temp_dword_1,0))+'</color>]<clrEnd>';",
                        "            ArrayAdd(temp_array_6,0);",
                        "        }",
                        "        else ArrayAdd(temp_array_6,1);//Маркер, что корпус не украли",
                        "    }",
                        "    //Добавляем к уведомлению \"шапку\" и \"подвал\"",
                        "    if(temp_int_3==1)temp_str_3=CT(\"Script.Mod_ExpPilotBridge.1195\")+CT('FormInfo.br')+'<color=127,127,127>--------------------------------------------------------------------------------------------------</color>'+CT('FormInfo.br')+temp_str_3+CT('FormInfo.br')+'<color=127,127,127>--------------------------------------------------------------------------------------------------</color>'+CT('FormInfo.br')+CT(\"Script.Mod_ExpPilotBridge.1193\");",
                        "    if(temp_int_3>1)temp_str_3=CT(\"Script.Mod_ExpPilotBridge.1194\")+CT('FormInfo.br')+'<color=127,127,127>--------------------------------------------------------------------------------------------------</color>'+CT('FormInfo.br')+temp_str_3+CT('FormInfo.br')+'<color=127,127,127>--------------------------------------------------------------------------------------------------</color>'+CT('FormInfo.br')+CT(\"Script.Mod_ExpPilotBridge.1193\");",
                        "    if(temp_int_3>0)",
                        "    {",
                        "        //Ставим вывод уведомления о кораблях-похитителях на таймер",
                        "        if(TLegUpCount==-1)",
                        "        {",
                        "            TForLegUp=temp_str_3;",
                        "            TLegUpCount=4;",
                        "        }",
                        "        //Второй счетчик с переменной нужен на случай, если произойдут две кражи подряд (в теории возможно)",
                        "        else",
                        "        {",
                        "            TForLegUp2=temp_str_3;",
                        "            TLegUpCount2=4;",
                        "        }",
                        "        //Пересобираем массив и счётчик, исключаем украденные корпуса",
                        "        temp_int_3=0;",
                        "        ArrayClear(temp_array_4);",
                        "        ArrayClear(temp_array_5);",
                        "        for(i=1;i<=HullOnWay;i=i+1)",
                        "        {",
                        "            if(temp_array_6[i]!=0)",
                        "            {",
                        "                ArrayAdd(temp_array_5,GAddTArray[i]);",
                        "                ArrayAdd(temp_array_4,GetItemFromVault('HullDelServ_'+i));",
                        "                temp_int_3=temp_int_3+1;",
                        "            }",
                        "        }",
                        "        ArrayClear(GAddTArray);",
                        "        for(i=1;i<ArrayDim(temp_array_5);i=i+1)",
                        "        {",
                        "            ArrayAdd(GAddTArray,temp_array_5[i]);",
                        "            PutItemInVault('HullDelServ_'+i,temp_array_4[i]);",
                        "        }",
                        "        HullOnWay=temp_int_3;",
                        "        HullWasStolen=0;",
                        "    }",
                        "    ArrayClear(temp_array_4);",
                        "    ArrayClear(temp_array_5);",
                        "    ArrayClear(temp_array_6);",
                        "}",
                        "",
                        "//Функция спавна корабля, похитившего корпус (возвращает заспавленный корабль):",
                        "//Stype - тип корабля",
                        "//Splanet - планета спавна",
                        "//Cmode - модификатор стартового капитала",
                        "//Hnumb - номер корпуса игрока в хранилище",
                        "//Dtype - тип агента по перегону",
                        "function ThiefCreate(Stype,Splanet,Cmode,Hnumb,Dtype)",
                        "{",
                        "    if(StarOwner(PlanetToStar(Splanet))==1 || StarCustomFaction(PlanetToStar(Splanet))!='')",
                        "    {",
                        "        temp_dword_4=PlanetOwner(Splanet);",
                        "        PlanetOwner(Splanet,PlanetRace(Splanet));",
                        "    }",
                        "    if(Stype==1 && !CoalitionDefeated())",
                        "    {",
                        "        temp_dword_5=BuyRanger(Splanet,Cmode);",
                        "        ShipSkill(temp_dword_5,0,3);",
                        "        ShipSkill(temp_dword_5,1,3);",
                        "        ShipSkill(temp_dword_5,2,2);",
                        "        ShipSkill(temp_dword_5,3,2);",
                        "        ShipSkill(temp_dword_5,4,2);",
                        "        ShipSkill(temp_dword_5,5,2);",
                        "        temp_int_4=1;",
                        "    }",
                        "    if(Stype==1 && CoalitionDefeated())",
                        "    {",
                        "        temp_dword_5=BuyPirate(Splanet,Cmode);",
                        "        ShipSkill(temp_dword_5,0,3);",
                        "        ShipSkill(temp_dword_5,1,3);",
                        "        ShipSkill(temp_dword_5,2,1);",
                        "        ShipSkill(temp_dword_5,3,1);",
                        "        temp_int_4=2;",
                        "    }",
                        "    if(Stype==2)",
                        "    {",
                        "        temp_dword_5=BuyPirate(Splanet,Cmode);",
                        "        ShipSkill(temp_dword_5,0,3);",
                        "        ShipSkill(temp_dword_5,1,3);",
                        "        ShipSkill(temp_dword_5,2,1);",
                        "        ShipSkill(temp_dword_5,3,1);",
                        "        temp_int_4=2;",
                        "    }",
                        "    if(Stype==3 && !CoalitionDefeated())",
                        "    {",
                        "        temp_dword_5=BuyTransport(Splanet,0,Cmode);",
                        "        ShipSkill(temp_dword_5,0,2);",
                        "        ShipSkill(temp_dword_5,1,2);",
                        "        ShipSkill(temp_dword_5,2,3);",
                        "        ShipSkill(temp_dword_5,3,3);",
                        "        temp_int_4=3;",
                        "    }",
                        "    if(Stype==3 && CoalitionDefeated())",
                        "    {",
                        "        temp_dword_5=BuyPirate(Splanet,Cmode);",
                        "        ShipSkill(temp_dword_5,0,3);",
                        "        ShipSkill(temp_dword_5,1,3);",
                        "        ShipSkill(temp_dword_5,2,1);",
                        "        ShipSkill(temp_dword_5,3,1);",
                        "        temp_int_4=2;",
                        "    }",
                        "    ShipRefit(temp_dword_5);",
                        "    ShipRefit(temp_dword_5);",
                        "    ShipRefit(temp_dword_5);",
                        "    ShipImproveItems(temp_dword_5,Rnd(4,5));",
                        "    if(StarOwner(PlanetToStar(Splanet))==1 || StarCustomFaction(PlanetToStar(Splanet))!='')PlanetOwner(Splanet,temp_dword_4);",
                        "    temp_int_5=0;",
                        "    temp_int_6=0;",
                        "    //Спавним корабль и производим надевание нового корпуса строго по алгоритму:",
                        "    //1. Забрать корпус",
                        "    //2. Забрать у корабля все вещи кроме корпуса (удалить если не нужны, или в массив/воулт положить)",
                        "    //3. Выдать новый корпус (п.1,2 нужны чтобы корпус оказался в 0-й позиции в списке эквипа, это принципиально)",
                        "    //4. Активировать новый корпус",
                        "    //5. Удалить старый корпус (не раньше! до активации нового корпуса у корабля все ещё есть линк на старый)",
                        "    //6. Отдать эквип или сделать новый",
                        "    while(ShipItems(temp_dword_5)!=0)",
                        "    {",
                        "        if(ItemType(ShipItems(temp_dword_5,0))==t_Hull)",
                        "        {",
                        "            temp_dword_4=GetItemFromShip(temp_dword_5,0);",
                        "            continue;",
                        "        }",
                        "        else",
                        "        {",
                        "            if(ItemIsInUse(ShipItems(temp_dword_5,0)))",
                        "            {",
                        "                temp_int_5=temp_int_5+1;",
                        "                PutItemInVault('ExpBridgeUsedItems_'+temp_int_5,GetItemFromShip(temp_dword_5,0));",
                        "            }",
                        "            else",
                        "            {",
                        "                temp_int_6=temp_int_6+1;",
                        "                PutItemInVault('ExpBridgeUslItems_'+temp_int_6,GetItemFromShip(temp_dword_5,0));",
                        "            }",
                        "        }",
                        "    }",
                        "    //Надеваем на корабль корпус игрока",
                        "    AddItemToShip(temp_dword_5,GetItemFromVault('HullDelServ_'+Hnumb));",
                        "    ItemIsInUse(ShipItems(temp_dword_5,0),temp_dword_5,1);",
                        "    Chameleon(temp_dword_5);",
                        "    //Запрещаем кораблю снимать корпус игрока",
                        "    NoDropItem(ShipItems(temp_dword_5,0),1);",
                        "    FreeItem(temp_dword_4);",
                        "    for(count3=1; count3<=temp_int_5; count3=count3+1)",
                        "    {",
                        "        temp_dword_4=GetItemFromVault('ExpBridgeUsedItems_'+count3);",
                        "        AddItemToShip(temp_dword_5,temp_dword_4);",
                        "        ItemIsInUse(temp_dword_4,temp_dword_5,1);",
                        "    }",
                        "    for(count3=1; count3<=temp_int_6; count3=count3+1)",
                        "    {",
                        "        temp_dword_4=GetItemFromVault('ExpBridgeUslItems_'+count3);",
                        "        AddItemToShip(temp_dword_5,temp_dword_4);",
                        "    }",
                        "    //В числе профи чаще оказываются люди, феяне и гаальцы",
                        "    if(Dtype==1)",
                        "    {",
                        "        temp_dword_1=Rnd(1,10);",
                        "        if(temp_dword_1>=1 && temp_dword_1<=7)ShipPilotRace(temp_dword_5,Rnd(2,4));",
                        "        else ShipPilotRace(temp_dword_5,Rnd(0,1));",
                        "    }",
                        "    if(Dtype==2)",
                        "    {",
                        "        ShipPilotRace(temp_dword_5,Rnd(0,4));",
                        "    }",
                        "    //В числе салаг чаще оказываются малоки и пеленги",
                        "    if(Dtype==3)",
                        "    {",
                        "        temp_dword_1=Rnd(1,10);",
                        "        if(temp_dword_1>=1 && temp_dword_1<=7)ShipPilotRace(temp_dword_5,Rnd(0,1));",
                        "        else ShipPilotRace(temp_dword_5,Rnd(2,4));",
                        "    }",
                        "    if(!CoalitionDefeated())ShipOwner(temp_dword_5,ShipPilotRace(temp_dword_5));",
                        "    //Ровняем производителя всех эквипнутых вещей на расу пилота",
                        "    for(count3=1; count3<ShipItems(temp_dword_5); count3=count3+1)",
                        "    {",
                        "        if(ItemIsInUse(ShipItems(temp_dword_5,count3)))ItemOwner(ShipItems(temp_dword_5,count3),ShipPilotRace(temp_dword_5));",
                        "    }",
                        "    //На всякий случай даём кораблю команду проверить оборудку, чтобы пофиксить возможный перевес",
                        "    ShipFreeFlight(temp_dword_5);",
                        "    //Добавляем кораблю воровскую инфошку и запоминаем шанс добровольной сдачи корпуса игроку при соответствующем запросе",
                        "    if(temp_int_4==1) temp_int_4=Rnd(30,50) / Dtype; //Рейнджер",
                        "    if(temp_int_4==2) temp_int_4=Rnd(20,40) / Dtype; //Пират",
                        "    if(temp_int_4==3) temp_int_4=Rnd(50,100) / Dtype; //Транспорт",
                        "    ShipAddCustomShipInfo(temp_dword_5,'PlayerBridge_ThiefInfo','NoShow',-1,temp_int_4);",
                        "    ShipJoin(HullThieves,temp_dword_5);",
                        "    result=temp_dword_5;",
                        "}",
                        "",
                        "//Функция создания кораблей по проекту со Слэпстартера",
                        "function SpawnSlapstarter(type, planet)",
                        "{",
                        "    dword ship;",
                        "    if(type == 1) ship = BuyWarrior(planet, 300);",
                        "    else if(type == 2) ship = BuyWarrior(planet, 300);",
                        "",
                        "    ShipSkill(ship, 0, RndObject(3, 5, ship));",
                        "    ShipSkill(ship, 1, RndObject(3, 5, ship));",
                        "    ShipSkill(ship, 2, RndObject(2, 5, ship));",
                        "    ShipSkill(ship, 3, RndObject(0, 3, ship));",
                        "    ShipSkill(ship, 4, RndObject(0, 3, ship));",
                        "    ShipSkill(ship, 5, RndObject(0, 2, ship));",
                        "",
                        "    dword hull = ShipItems(ship, 0);",
                        "    ItemSize(hull, max(ItemSize(hull), 75 * GTL));",
                        "    ItemSize(hull, ItemSize(hull) + RndObject(-15, 15, ship));",
                        "    HullHP(ship, 'To100');",
                        "",
                        "    for(int i = ShipItems(ship) - 1; i > 0; i = i - 1) FreeItem(GetItemFromShip(ship, i));",
                        "",
                        "    if(ShipOnSidePirateClan(ship)) ShipType(ship, 'Rebel');",
                        "    else ShipType(ship, 'Militiaman' + type_coal);",
                        "",
                        "    ShipMoney(ship, 4 * ShipMoney(ship));",
                        "    for(i = 1; i <= 4; i = i + 1) ShipRefit(ship);",
                        "    ShipImproveItems(ship, RndObject(7, 10, ship));",
                        "",
                        "    result = ship;",
                        "}",
                        "",
                        "//Функция проверки условий для появления ТЦ. Возвращает Id системы для постройки или 0, если нет подходящей системы.",
                        "function SelectSystemTC() {",
                        "    int i, j, k;",
                        "    dword con, system, ruins_count, systems_count;",
                        "    for(i=0; i<GalaxySectors(); i=i+1) {",
                        "        con=GalaxySectors(i);",
                        "        if(con==StarToCon(PlanetToStar(PlanetPirateClan()))) continue;",
                        "        ruins_count=0;",
                        "        systems_count=0;",
                        "        for(j=0; j<ConStars(con); j=j+1) {",
                        "            system=ConStar(con, j);",
                        "            if(!StarOwner(system) || StarOwner(system)==2) systems_count=systems_count+1;",
                        "            if(StarRuins(system)) {",
                        "                ruins_count=ruins_count+StarRuins(system);",
                        "                if(StarRuins(system)>=3) continue;",
                        "            }",
                        "        }",
                        "        if(ruins_count<systems_count) { //Проверка на кол-во станций в секторе",
                        "            for(k=0; k<ConStars(con); k=k+1) {",
                        "                system=ConStar(con, k);",
                        "                if(StarOwner(system)==1) continue; //Пропуск доминаторов",
                        "                if(StarCustomFaction(system)!='') continue; //Пропуск кастомов",
                        "                if(StarBattle(system)) continue; //Пропуск оспариваемых систем",
                        "                if(StarRuins(system)>=3) continue; //Меньше 3 баз в системе",
                        "                ArrayAdd(bld_TC_array, Id(system));",
                        "            }",
                        "        }",
                        "    }",
                        "    if(ArrayDim(bld_TC_array)<=1) system=0;",
                        "    else system=bld_TC_array[Rnd(1,ArrayDim(bld_TC_array)-1)];",
                        "    ArrayClear(bld_TC_array);",
                        "    result=system;",
                        "}",
                        "//Функция создания нового ТЦ (запускается из тернкода)",
                        "function BuyTC(dword system) {",
                        "    dword station, planet; int tint;",
                        "    str station_name, temp_news;",
                        "    station = BuildCustomRuins(system, 'TC', 5); //Если подключён мод ExpBasesAutoUpgrade, то накидываем на ТЦ инфошку для автоулучшения",
                        "    if(BlockExist('ShipInfo.AddInfo.CustomInfos.ExpBasesAutoUpgradeInfo')) ShipAddCustomShipInfo(station, 'ExpBasesAutoUpgradeInfo', 'NoShow');",
                        "    Chameleon(station, 'Ruins.TC'); //Меняем шкурку на ТЦ",
                        "    //Меняем овнера и расу базы на малоков, заодно, на всякий случай, обновляя лицо капитана",
                        "    ShipOwner(station, 0);",
                        "    ShipPilotRace(station, 0);",
                        "    ShipFace(station, -1);",
                        "    station_name = CT('RuinName.TC.'+Rnd(1,CT('RuinName.TC.Name_count'))); //Выбираем имя для нового ТЦ",
                        "    SetName(station, station_name); //Устанавливаем имя новому ТЦ",
                        "    GlobalVarTcCount=GlobalVarTcCount+1; //Глобальный счётчик числа ТЦ в Галактике",
                        "    planet=FindPlanet(system, 'NotNone', 0, 0); //Ищем обитаемую планету, с нее полетит ТЦ",
                        "    ShipJoin(GroupTC, station);",
                        "    Coord_X_TC=CoordX(station); //Запоминаем координаты",
                        "    Coord_Y_TC=CoordY(station);",
                        "    TransferShip(station, planet);",
                        "    CoordX(station, planet); //Меняем координаты, т.к. они сами не поменяются",
                        "    CoordY(station, planet);",
                        "    //Выводим сообщение о постройке нового ТЦ, если у игрока есть карта этого сектора",
                        "    if(SectorVisible(StarToCon(system))) {",
                        "        tint = Rnd(0, 3);",
                        "        if(!tint) temp_news = Format(CT(\"Script.Mod_ExpPilotBridge.1582\"),\"<0>\",StarName(system),\"<1>\",station_name,\"<2>\",Name(StarToCon(system)));",
                        "        else if(tint == 1) temp_news = Format(CT(\"Script.Mod_ExpPilotBridge.1581\"),\"<0>\",StarName(system),\"<1>\",Name(StarToCon(system)),\"<2>\",station_name);",
                        "        else if(tint == 2) temp_news = Format(CT(\"Script.Mod_ExpPilotBridge.1580\"),\"<0>\",station_name,\"<1>\",StarName(system),\"<2>\",Name(StarToCon(system)));",
                        "        else temp_news = Format(CT(\"Script.Mod_ExpPilotBridge.1579\"),\"<0>\",station_name,\"<1>\",StarName(system),\"<2>\",Name(StarToCon(system)));",
                        "        NewsAdd(temp_news);",
                        "        AddPlanetNews(temp_news,51);",
                        "    }",
                        "}",
                        "function g_BuyTC(dword system) {",
                        "    dword station, planet; int tint;",
                        "    str station_name, temp_news;",
                        "    station = BuildCustomRuins(system, 'TC', 5); //Если подключён мод ExpBasesAutoUpgrade, то накидываем на ТЦ инфошку для автоулучшения",
                        "    if(BlockExist('ShipInfo.AddInfo.CustomInfos.ExpBasesAutoUpgradeInfo')) ShipAddCustomShipInfo(station, 'ExpBasesAutoUpgradeInfo', 'NoShow');",
                        "    Chameleon(station, 'Ruins.TC'); //Меняем шкурку на ТЦ",
                        "    //Меняем овнера и расу базы на малоков, заодно, на всякий случай, обновляя лицо капитана",
                        "    ShipOwner(station, 0);",
                        "    ShipPilotRace(station, 0);",
                        "    ShipFace(station, -1);",
                        "    station_name = CT('RuinName.TC.'+Rnd(1,CT('RuinName.TC.Name_count'))); //Выбираем имя для нового ТЦ",
                        "    SetName(station, station_name); //Устанавливаем имя новому ТЦ",
                        "    GlobalVarTcCount=GlobalVarTcCount+1; //Глобальный счётчик числа ТЦ в Галактике",
                        "    planet=FindPlanet(system, 'NotNone', 0, 0); //Ищем обитаемую планету, с нее полетит ТЦ",
                        "    ShipJoin(GroupTC, station);",
                        "    Coord_X_TC=CoordX(station); //Запоминаем координаты",
                        "    Coord_Y_TC=CoordY(station);",
                        "    TransferShip(station, planet);",
                        "    CoordX(station, planet); //Меняем координаты, т.к. они сами не поменяются",
                        "    CoordY(station, planet);",
                        "    //Выводим сообщение о постройке нового ТЦ, если у игрока есть карта этого сектора",
                        "    if(SectorVisible(StarToCon(system))) {",
                        "        tint = Rnd(0, 3);",
                        "        if(!tint) temp_news = Format(CT(\"Script.Mod_ExpPilotBridge.1582\"),\"<0>\",StarName(system),\"<1>\",station_name,\"<2>\",Name(StarToCon(system)));",
                        "        else if(tint == 1) temp_news = Format(CT(\"Script.Mod_ExpPilotBridge.1581\"),\"<0>\",StarName(system),\"<1>\",Name(StarToCon(system)),\"<2>\",station_name);",
                        "        else if(tint == 2) temp_news = Format(CT(\"Script.Mod_ExpPilotBridge.1580\"),\"<0>\",station_name,\"<1>\",StarName(system),\"<2>\",Name(StarToCon(system)));",
                        "        else temp_news = Format(CT(\"Script.Mod_ExpPilotBridge.1579\"),\"<0>\",station_name,\"<1>\",StarName(system),\"<2>\",Name(StarToCon(system)));",
                        "        NewsAdd(temp_news);",
                        "        AddPlanetNews(temp_news,51);",
                        "    }",
                        "",
                        "    result = station;",
                        "}",
                        "",
                        "function UpdateKillShipsStatistic(int type, int sub_type, str str_type, str name, str full_name, int owner, int in_hyper)",
                        "{",
                        "    //Доминаторы и клисане",
                        "    if(type == t_Kling)",
                        "    {",
                        "        //Оригинальные доминаторы",
                        "        if(str_type == '' || str_type == 'Kling')",
                        "        {",
                        "            //Определяем оригинального доминатора по подтипу",
                        "            //Штип",
                        "            if(sub_type == 5)",
                        "            {",
                        "                GDomShtStat = GDomShtStat + 1;",
                        "                GDomStat = GDomStat + 1;",
                        "                if(in_hyper) PlayerDominatorStatistic(5, PlayerDominatorStatistic(5) + 1);",
                        "            }",
                        "            //Менок",
                        "            else if(sub_type == 4)",
                        "            {",
                        "                GDomMenStat = GDomMenStat + 1;",
                        "                GDomStat = GDomStat + 1;",
                        "                if(in_hyper) PlayerDominatorStatistic(4, PlayerDominatorStatistic(4) + 1);",
                        "            }",
                        "            //Смерш",
                        "            else if(sub_type == 3)",
                        "            {",
                        "                GDomSmrStat = GDomSmrStat + 1;",
                        "                GDomStat = GDomStat + 1;",
                        "                if(in_hyper) PlayerDominatorStatistic(3, PlayerDominatorStatistic(3) + 1);",
                        "            }",
                        "            //Ургант",
                        "            else if(sub_type == 2)",
                        "            {",
                        "                GDomUrgStat = GDomUrgStat + 1;",
                        "                GDomStat = GDomStat + 1;",
                        "                if(in_hyper) PlayerDominatorStatistic(2, PlayerDominatorStatistic(2) + 1);",
                        "            }",
                        "            //Эквентор",
                        "            else if(sub_type == 1)",
                        "            {",
                        "                GDomIkvStat = GDomIkvStat + 1;",
                        "                GDomStat = GDomStat + 1;",
                        "                if(in_hyper) PlayerDominatorStatistic(1, PlayerDominatorStatistic(1) + 1);",
                        "            }",
                        "            //Клиг",
                        "            else if(sub_type == 7)",
                        "            {",
                        "                GDomKlgStat = GDomKlgStat + 1;",
                        "                GDomStat = GDomStat + 1;",
                        "                if(in_hyper) PlayerDominatorStatistic(7, PlayerDominatorStatistic(7) + 1);",
                        "            }",
                        "            //Бертор",
                        "            else if(sub_type == 6)",
                        "            {",
                        "                GDomBerStat = GDomBerStat + 1;",
                        "                GDomStat = GDomStat + 1;",
                        "                if(in_hyper) PlayerDominatorStatistic(6, PlayerDominatorStatistic(6) + 1);",
                        "            }",
                        "            //Босс",
                        "            else //if(!sub_type)",
                        "            {",
                        "                //Блазер",
                        "                if(full_name == CT('ShipType.Dominator.Blazer.0'))",
                        "                {",
                        "                    GDomStat = GDomStat + 1;",
                        "                    if(in_hyper) PlayerDominatorStatistic(0, PlayerDominatorStatistic(0) + 1);",
                        "                }",
                        "                //Келлер",
                        "                else if(full_name == CT('ShipType.Dominator.Keller.0'))",
                        "                {",
                        "                    GDomStat = GDomStat + 1;",
                        "                    if(in_hyper) PlayerDominatorStatistic(0, PlayerDominatorStatistic(0) + 1);",
                        "                }",
                        "                //Террон",
                        "                else if(full_name == CT('ShipType.Dominator.Terron.0'))",
                        "                {",
                        "                    GDomStat = GDomStat + 1;",
                        "                    if(in_hyper) PlayerDominatorStatistic(0, PlayerDominatorStatistic(0) + 1);",
                        "                }",
                        "            }",
                        "",
                        "            if(in_hyper) ShipStatistic(Player(), 2, ShipStatistic(Player(), 2) + 1);",
                        "        }",
                        "        else",
                        "        {",
                        "            //Мутенок",
                        "            if(str_type == 'Klissan5')",
                        "            {",
                        "                GKlissMutStat = GKlissMutStat + 1;",
                        "                GKlissanStat = GKlissanStat + 1;",
                        "            }",
                        "            //Рогит",
                        "            else if(str_type == 'Klissan4')",
                        "            {",
                        "                GKlissRogStat = GKlissRogStat + 1;",
                        "                GKlissanStat = GKlissanStat + 1;",
                        "            }",
                        "            //Катаури",
                        "            else if(str_type == 'Klissan3')",
                        "            {",
                        "                GKlissKatStat = GKlissKatStat + 1;",
                        "                GKlissanStat = GKlissanStat + 1;",
                        "            }",
                        "            //Нондус",
                        "            else if(str_type == 'Klissan2')",
                        "            {",
                        "                GKlissNonStat = GKlissNonStat + 1;",
                        "                GKlissanStat = GKlissanStat + 1;",
                        "            }",
                        "            //Эгемон",
                        "            else if(str_type == 'Klissan1')",
                        "            {",
                        "                GKlissEgeStat = GKlissEgeStat + 1;",
                        "                GKlissanStat = GKlissanStat + 1;",
                        "            }",
                        "            //Гигас",
                        "            else if(str_type == 'Klissan0')",
                        "            {",
                        "                GKlissGigStat = GKlissGigStat + 1;",
                        "                GKlissanStat = GKlissanStat + 1;",
                        "            }",
                        "            //Доминаторский раттор",
                        "            else if(str_type == 'Rattor')",
                        "            {",
                        "                GDomRatStat = GDomRatStat + 1;",
                        "                GDomStat = GDomStat + 1;",
                        "                if(in_hyper) ShipStatistic(Player(), 2, ShipStatistic(Player(), 2) + 1);",
                        "            }",
                        "            //Верфь, а точнее эквентор, имитирующий станцию (ShuDomiks)",
                        "            else if(str_type == 'DomRuins')",
                        "            {",
                        "                G_DomBStat = G_DomBStat + 1;",
                        "                if(in_hyper) ShipStatistic(Player(), 2, ShipStatistic(Player(), 2) + 1);",
                        "                else PlayerDominatorStatistic(1, PlayerDominatorStatistic(1) - 1);",
                        "            }",
                        "            //Неизвестный (ShuKlissan)",
                        "            else if(str_type == 'Unknown')",
                        "            {",
                        "                GUnknStat = GUnknStat + 1;",
                        "                if(in_hyper) ShipStatistic(Player(), 7, ShipStatistic(Player(), 7) + 1);",
                        "            }",
                        "            //Клон Келлера, а точнее эквентор с подтипом босса (ShuDomiks)",
                        "            else if(str_type == 'KellerClone')",
                        "            {",
                        "                GDomStat = GDomStat + 1;",
                        "                if(in_hyper) PlayerDominatorStatistic(0, PlayerDominatorStatistic(0) + 1);",
                        "            }",
                        "        }",
                        "    }",
                        "    //Пираты и наёмники",
                        "    else if(type == t_Pirate)",
                        "    {",
                        "        if(str_type == '' || str_type == 'Pirate')",
                        "        {",
                        "            //Вольные пираты",
                        "            if(sub_type == 0)",
                        "            {",
                        "                GPirStat = GPirStat + 1;",
                        "                GPirFreeStat = GPirFreeStat + 1;",
                        "            }",
                        "            //Клановые пираты",
                        "            else",
                        "            {",
                        "                GPirStat = GPirStat + 1;",
                        "                GPirClanStat = GPirClanStat + 1;",
                        "            }",
                        "        }",
                        "        else",
                        "        {",
                        "            if(str_type == 'Rebel')",
                        "            {",
                        "                GPirStat = GPirStat + 1;",
                        "                GPirRebStat = GPirRebStat + 1;",
                        "            }",
                        "            //Пиратские крупные корабли (EvoArmada)",
                        "            else if(str_type == 'PirateCorvette')",
                        "            {",
                        "                GPirStat = GPirStat + 1;",
                        "                GPirCorvStat = GPirCorvStat + 1;",
                        "            }",
                        "            else if(str_type == 'PirateFrigate')",
                        "            {",
                        "                GPirStat = GPirStat + 1;",
                        "                GPirFrigStat = GPirFrigStat + 1;",
                        "            }",
                        "            else if(str_type == 'PirateGalleon')",
                        "            {",
                        "                GPirStat = GPirStat + 1;",
                        "                GPirGallStat = GPirGallStat + 1;",
                        "            }",
                        "            //Пираты-загонщики (событие в ExpPilotBridge)",
                        "            else if(str_type == 'PirateRunner')",
                        "            {",
                        "                GPirStat = GPirStat + 1;",
                        "                GPirFreeStat = GPirFreeStat + 1;",
                        "            }",
                        "            //Головорез (ShuPirates)",
                        "            else if(str_type == 'Thug')",
                        "            {",
                        "                GPirStat = GPirStat + 1;",
                        "                GPirThugStat = GPirThugStat + 1;",
                        "            }",
                        "            //Хан (ShuPirates)",
                        "            else if(str_type == 'Khan')",
                        "            {",
                        "                GPirStat = GPirStat + 1;",
                        "                GPirKhanStat = GPirKhanStat + 1;",
                        "            }",
                        "        }",
                        "",
                        "        if(in_hyper) ShipStatistic(Player(), 1, ShipStatistic(Player(), 1) + 1);",
                        "    }",
                        "    //Рейнджеры и наёмники",
                        "    else if(type == t_Ranger)",
                        "    {",
                        "        //Простые рейнджеры, либо спецагентки",
                        "        if(str_type == '' || str_type == 'Ranger' || str_type == 'FemRanger')",
                        "        {",
                        "            if(str_type == '')",
                        "            {",
                        "                //Спецагентки (ищем по имени корабля, т.к. никак иначе здесь не получится)",
                        "                if(~findsubstr(CT('Script.PC_fem_rangers.SecretAgentNames.' + CT('Script.PC_fem_rangers.SecretAgentNames.' + owner) + '.NameSearchString'), '$' + name + '$'))",
                        "                {",
                        "                    GRangSpecStat = GRangSpecStat + 1;",
                        "                }",
                        "                //Простые рейнджеры",
                        "                else",
                        "                {",
                        "                    GRangStat = GRangStat + 1;",
                        "                }",
                        "            }",
                        "            else if(str_type == 'FemRanger') GRangSpecStat = GRangSpecStat + 1;",
                        "            else GRangStat = GRangStat + 1;",
                        "        }",
                        "        else",
                        "        {",
                        "            //Рейнджер исследователь (проходит в статистике как обычный рейнджер)",
                        "            if(str_type == 'RangerExplorer')",
                        "            {",
                        "                GRangStat = GRangStat + 1;",
                        "            }",
                        "            //Рейнджер изменник, считается пиратом (ExpTraitors)",
                        "            else if(str_type == 'RangerPirate' || str_type == 'RangerPirateExplorer')",
                        "            {",
                        "                GPirStat = GPirStat + 1;",
                        "                LRangPirStat = LRangPirStat + 1;",
                        "            }",
                        "            //Махпелла технически рейнджер (ShuKlissan)",
                        "            else if(str_type == 'Machpella')",
                        "            {",
                        "                GKlissanStat = GKlissanStat + 1;",
                        "            }",
                        "            //Нейролинк технически тоже рейнджер (ShuKlissan)",
                        "            else if(str_type == 'Neurolink')",
                        "            {",
                        "                G_KBStat = G_KBStat + 1;",
                        "            }",
                        "            //Наёмники",
                        "            else if(str_type == 'Merc')",
                        "            {",
                        "                GMercStat = GMercStat + 1;",
                        "                //Принадлежность к организации определяем по приставке к имени",
                        "                if(!findsubstr(full_name, CT('ShipType.People.Merc') + ' '))",
                        "                {",
                        "                    GMercAtlStat = GMercAtlStat + 1;",
                        "                }",
                        "                else if(!findsubstr(full_name, CT('ShipType.Maloc.Merc') + ' '))",
                        "                {",
                        "                    GMercAxeStat = GMercAxeStat + 1;",
                        "                }",
                        "                else if(!findsubstr(full_name, CT('ShipType.Fei.Merc') + ' '))",
                        "                {",
                        "                    GMercFeiStat = GMercFeiStat + 1;",
                        "                }",
                        "            }",
                        "            else if(str_type == 'AtlantLeader')",
                        "            {",
                        "                GMercStat = GMercStat + 1;",
                        "                GMercAtlStat = GMercAtlStat + 1;",
                        "            }",
                        "            else if(str_type == 'RedLeader')",
                        "            {",
                        "                GMercStat = GMercStat + 1;",
                        "                GMercAxeStat = GMercAxeStat + 1;",
                        "            }",
                        "            else if(str_type == 'FeiLeader')",
                        "            {",
                        "                GMercStat = GMercStat + 1;",
                        "                GMercFeiStat = GMercFeiStat + 1;",
                        "            }",
                        "            else if(str_type == 'Freelancer')",
                        "            {",
                        "                GMercStat = GMercStat + 1;",
                        "                GMercFreeStat = GMercFreeStat + 1;",
                        "            }",
                        "            else if(str_type == 'PlayerMerc' || str_type == 'StarCockerel')",
                        "            {",
                        "                GMercStat = GMercStat + 1;",
                        "                GMercOtherStat = GMercOtherStat + 1;",
                        "            }",
                        "        }",
                        "",
                        "        if(in_hyper) ShipStatistic(Player(), 6, ShipStatistic(Player(), 6) + 1);",
                        "    }",
                        "    //Военные Коалиции",
                        "    else if(type == t_Warrior)",
                        "    {",
                        "        //Простые военные, либо флагманы (линкоры)",
                        "        if(str_type == '' || str_type == 'Warrior')",
                        "        {",
                        "            //Простые военные",
                        "            if(!sub_type)",
                        "            {",
                        "                GWarStat = GWarStat + 1;",
                        "                GWarPrivStat = GWarPrivStat + 1;",
                        "            }",
                        "            //Линкоры",
                        "            else",
                        "            {",
                        "                GWarStat = GWarStat + 1;",
                        "                GWarFlagStat = GWarFlagStat + 1;",
                        "            }",
                        "        }",
                        "        //Из модов",
                        "        else",
                        "        {",
                        "            //Дредноуты",
                        "            if(str_type == 'Dreadnought')",
                        "            {",
                        "                GWarStat = GWarStat + 1;",
                        "                GWarDreadStat = GWarDreadStat + 1;",
                        "            }",
                        "            //Ополченцы",
                        "            else if(TrimNumbers(str_type) == 'Militiaman')",
                        "            {",
                        "                GWarStat = GWarStat + 1;",
                        "                GWarMilitStat = GWarMilitStat + 1;",
                        "            }",
                        "        }",
                        "",
                        "        if(in_hyper) ShipStatistic(Player(), 5, ShipStatistic(Player(), 5) + 1);",
                        "    }",
                        "    //Гражданские суда и контрабандисты",
                        "    else if(type == t_Transport)",
                        "    {",
                        "        //Транспорты, лайнеры и дипломаты",
                        "        if(str_type == '' || str_type == 'Transport' || str_type == 'Liner' || str_type == 'Diplomat')",
                        "        {",
                        "            //Транспорты",
                        "            if(!sub_type)",
                        "            {",
                        "                GCivilStat = GCivilStat + 1;",
                        "                GCoalTranStat = GCoalTranStat + 1;",
                        "            }",
                        "            //Лайнеры",
                        "            else if(sub_type == 1)",
                        "            {",
                        "                GCivilStat = GCivilStat + 1;",
                        "                GCoalLinStat = GCoalLinStat + 1;",
                        "            }",
                        "            //Дипломаты",
                        "            else //if(sub_type == 2)",
                        "            {",
                        "                GCivilStat = GCivilStat + 1;",
                        "                GCoalDipStat = GCoalDipStat + 1;",
                        "            }",
                        "        }",
                        "        //Контрабандисты",
                        "        else",
                        "        {",
                        "            if(str_type == 'Smuggler')",
                        "            {",
                        "                GPirStat = GPirStat + 1;",
                        "                GPirSmugStat = GPirSmugStat + 1;",
                        "            }",
                        "        }",
                        "",
                        "        if(in_hyper) ShipStatistic(Player(), 4, ShipStatistic(Player(), 4) + 1);",
                        "    }",
                        "    //Транклюкаторы",
                        "    else if(type == t_Tranclucator)",
                        "    {",
                        "        //if(str_type == '' || str_type == 'Tranclucator')",
                        "        GTrankStat = GTrankStat + 1;",
                        "    }",
                        "    //Счётчики уничтоженных станций",
                        "    //Центры рейнджеров",
                        "    else if(type == t_RC)",
                        "    {",
                        "        G_RCStat = G_RCStat + 1;",
                        "    }",
                        "    //Пиратские базы",
                        "    else if(type == t_PB)",
                        "    {",
                        "        //if(str_type == 'BM') //Чёрный рынок",
                        "        //{}",
                        "        //else",
                        "        G_PBStat = G_PBStat + 1;",
                        "    }",
                        "    //Военные базы",
                        "    else if(type == t_WB)",
                        "    {",
                        "        G_MBStat = G_MBStat + 1;",
                        "    }",
                        "    //Научные базы",
                        "    else if(type == t_SB)",
                        "    {",
                        "        G_SBStat = G_SBStat + 1;",
                        "    }",
                        "    //Бизнес-центры",
                        "    else if(type == t_BK)",
                        "    {",
                        "        G_BCStat = G_BCStat + 1;",
                        "    }",
                        "    //Медицинские центры",
                        "    else if(type == t_MC)",
                        "    {",
                        "        G_MCStat = G_MCStat + 1;",
                        "    }",
                        "    //Доминионы",
                        "    else if(type == t_CB)",
                        "    {",
                        "        G_PCBStat = G_PCBStat + 1;",
                        "    }",
                        "    //Центры наёмников, нейролинки и ингибиторы (определяем по типу и имени)",
                        "    else if(type == t_UB)",
                        "    {",
                        "        str_type = Format(str_type, '_licensed', '', '');",
                        "",
                        "        //Технологический центр (ExpTC)",
                        "        if(str_type == 'TC')",
                        "        {",
                        "            G_TCStat = G_TCStat + 1;",
                        "        }",
                        "        //Центр наёмников (ShuMercs)",
                        "        else if(str_type == 'MB' || str_type == 'Manaan' || str_type == 'PlayerMB' || str_type == 'MercHQ' || str_type == 'PlayerMercHQ')",
                        "        {",
                        "            G_MercCStat = G_MercCStat + 1;",
                        "        }",
                        "        //Ингибитор (ShuDomiks)",
                        "        else if(str_type == 'Inhibitor')",
                        "        {",
                        "            G_IngBStat = G_IngBStat + 1;",
                        "        }",
                        "        //else if(str_type == 'SSB') //ППБ (не может быть уничтожена)",
                        "        //{}",
                        "    }",
                        "}"
                    ],
                    "#": 267,
                    "Type": "Top",
                    "Parent": -1,
                    "Pos.x": 60,
                    "Pos.y": 1535
                },
                {
                    "Name": "",
                    "Code.Type": "Turn",
                    "Code": [
                        "if(cargo_in_way!=0) {",
                        "  if(transfer_day <= CurTurn()) {",
                        "    //Значения переменной LTargetType",
                        "    //1 - Груз в пути к планете назначения",
                        "    //2 - Груз в пути к станции назначения",
                        "    //3 - Груз в пути к планете отправки (если планета назначения захвачена, либо станция назначения уничтожена)",
                        "    //4 - Груз в пути к станции отправки (если планета назначения захвачена, либо станция назначения уничтожена)",
                        "    //5 - Груз в пути к родной планете (если обе планеты назначения и отправки захвачены, либо уничтожены обе станции)",
                        "    ",
                        "    //Значения переменной CargoLost",
                        "    //0 - Груз успешно доставлен или возвращён обратно",
                        "    //1 - Груз будет потерян в пути, а системы отправки и назначения не пиратские",
                        "    //2 - Груз будет разграблен пиратами ближе к началу пути - система отправки пиратская",
                        "    //3 - Груз будет разграблен пиратами ближе к началу или к концу пути - системы отправки и назначения пиратские",
                        "    //4 - Груз будет разграблен пиратами ближе к концу пути - система назначения пиратская",
                        "    //5 - Груз будет потерян по прибытии в родную систему, которая захвачена доминаторами или клисанами",
                        "    ",
                        "    temp_str_4='';",
                        "    transfer_list='';",
                        "    if(LTargetType<5)",
                        "    {",
                        "        if(CargoLost==0)",
                        "        {",
                        "            //Прибытие груза на планету доставки",
                        "            if(LTargetType==1)",
                        "            {",
                        "                point_1=IdToPlanet(point_3);",
                        "                temp_int=1;",
                        "                temp_int_2 = 1;",
                        "                for(i=1; i<=cargo_in_way; i=i+1)",
                        "                {",
                        "                    temp_dword=GetItemFromVault('player_bridge_transverservece_item_'+i);",
