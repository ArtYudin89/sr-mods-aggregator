                        "                          temp_str_2='</color>'+CT(\"Script.Mod_ExpPilotBridge.1517\");",
                        "                      }",
                        "                      CustomEther('MailFailed',0,'',Format(CT(\"Script.Mod_ExpPilotBridge.1522\"),\"<0>\",point_3_name,\"<1>\",temp_str,\"<2>\",temp_str_2,\"<3>\",PlanetName(IdToPlanet(point_1_id)),\"<4>\",StarName(PlanetToStar(IdToPlanet(point_1_id))),\"<5>\",StarName(PlanetToStar(GetShipHomePlanet(Player()))),\"<6>\",PlanetName(GetShipHomePlanet(Player()))));",
                        "                      CargoLostChanceCalcHome();",
                        "                      point_3=Id(GetShipHomePlanet(Player()));",
                        "                      LTargetType=5;",
                        "                  }",
                        "              }",
                        "          }",
                        "          if(point_1==4)",
                        "          {",
                        "              if(LStationDExist)",
                        "              {",
                        "                  //Груз был в пути на станцию доставки, но её уничтожили, а груз перенаправили на станцию отправки",
                        "                  if(!LStationSExist)",
