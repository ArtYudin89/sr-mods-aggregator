                        "      if(PlanetOwner(IdToPlanet(bld_ship_planet))==0)AddDialogInject('ProjMaloc','',CT(\"Script.Mod_ExpPilotBridge.977\"),20);",
                        "      if(PlanetOwner(IdToPlanet(bld_ship_planet))==1)AddDialogInject('ProjPeleng','',CT(\"Script.Mod_ExpPilotBridge.976\"),20);",
                        "      if(PlanetOwner(IdToPlanet(bld_ship_planet))==2)AddDialogInject('ProjPeople','',CT(\"Script.Mod_ExpPilotBridge.975\"),20);",
                        "      if(PlanetOwner(IdToPlanet(bld_ship_planet))==3)AddDialogInject('ProjFei','',CT(\"Script.Mod_ExpPilotBridge.974\"),20);",
                        "      if(PlanetOwner(IdToPlanet(bld_ship_planet))==4)AddDialogInject('ProjGaal','',CT(\"Script.Mod_ExpPilotBridge.973\"),20);",
                        "  }",
                        "  if(wait_day>CurTurn())",
                        "  {",
                        "      if(PlanetOwner(IdToPlanet(bld_ship_planet))==0)AddDialogInject('','',CT(\"Script.Mod_ExpPilotBridge.1562\"),20);",
                        "      if(PlanetOwner(IdToPlanet(bld_ship_planet))==0)AddDialogBlock(CT(\"Script.Mod_ExpPilotBridge.1562\"),1);",
                        "      if(PlanetOwner(IdToPlanet(bld_ship_planet))==1)AddDialogInject('','',CT(\"Script.Mod_ExpPilotBridge.1561\"),20);",
                        "      if(PlanetOwner(IdToPlanet(bld_ship_planet))==1)AddDialogBlock(CT(\"Script.Mod_ExpPilotBridge.1561\"),1);",
                        "      if(PlanetOwner(IdToPlanet(bld_ship_planet))==2)AddDialogInject('','',CT(\"Script.Mod_ExpPilotBridge.1560\"),20);",
                        "      if(PlanetOwner(IdToPlanet(bld_ship_planet))==2)AddDialogBlock(CT(\"Script.Mod_ExpPilotBridge.1560\"),1);",
                        "      if(PlanetOwner(IdToPlanet(bld_ship_planet))==3)AddDialogInject('','',CT(\"Script.Mod_ExpPilotBridge.1559\"),20);",
                        "      if(PlanetOwner(IdToPlanet(bld_ship_planet))==3)AddDialogBlock(CT(\"Script.Mod_ExpPilotBridge.1559\"),1);",
                        "      if(PlanetOwner(IdToPlanet(bld_ship_planet))==4)AddDialogInject('','',CT(\"Script.Mod_ExpPilotBridge.1558\"),20);",
                        "      if(PlanetOwner(IdToPlanet(bld_ship_planet))==4)AddDialogBlock(CT(\"Script.Mod_ExpPilotBridge.1558\"),1);",
                        "  }",
                        "  //Слэпстартер - пиратские проекты",
                        "  if(ArrayDim(bld_ship_planet_list_2)>1 && wait_day_2<=CurTurn())",
                        "  {",
                        "      AddDialogInject('ProjPirat','',CT(\"Script.Mod_ExpPilotBridge.972\"),15);",
                        "  }",
