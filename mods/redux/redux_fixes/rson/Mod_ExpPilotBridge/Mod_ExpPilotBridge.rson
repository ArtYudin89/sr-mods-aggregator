                        "        if(StarToCon(PlanetToStar(temp_dword)) == StarToCon(PlanetToStar(PlanetPirateClan())));",
                        "        temp_dword_2 = StorageItemLocation(i);",
                        "        ArrayAdd(temp_array,temp_dword_2);",
                        "        ArrayAdd(temp_array_2,CT(\"Script.Mod_ExpPilotBridge.943\")+Format(' <0> (<color=0,50,200><1></color>)',\"<0>\",Name(temp_dword_2),\"<1>\",StarName(PlanetToStar(temp_dword_2))));",
