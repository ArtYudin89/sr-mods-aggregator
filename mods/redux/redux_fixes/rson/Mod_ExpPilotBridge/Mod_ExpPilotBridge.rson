                        "      //Груз был в пути в родную систему, но её захватили (передаёт команду обработчику утери груза по прибытии)",
                        "      if(LTargetType==5 && CargoLost!=5)",
                        "      {",
                        "          if(StarOwner(PlanetToStar(IdToPlanet(point_3)))==1 || StarCustomFaction(PlanetToStar(IdToPlanet(point_3)))!='')",
                        "          {",
                        "              CargoLostChanceCalcHome();",
                        "          }",
                        "      }",
                        "      //Груз был в пути в захваченную родную систему, но её освободили (снимает команду на утерю груза по прибытии)",
                        "      if(LTargetType==5 && CargoLost==5)",
