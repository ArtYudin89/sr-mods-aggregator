                        "ShipAddCustomShipInfo(IdToShip(ETargetShip),'PlayerBridge_IllWisherInfo','NoShow');",
                        "//Полноценно взводим таймер",
                        "ETimeLeft=ETimeLeft+CurTurn();",
                        "//Запоминаем текст для уведомления о задании и выводим это уведомление",
                        "GEQuestText='<color=255,240,100>'+ShipName(Player())+CT(\"Script.Mod_ExpPilotBridge.1270\")+Name(IdToShip(ETargetShip))+CT(\"Script.Mod_ExpPilotBridge.1269\")+CT('FormInfo.br')+CT(\"Script.Mod_ExpPilotBridge.1268\")+EQuestReward+CT(\"Script.Mod_ExpPilotBridge.1267\")+(ETimeLeft-CurTurn()+1)+CT(\"Script.Mod_ExpPilotBridge.1266\")+StarName(ShipStar(IdToShip(ETargetShip)))+'</color>.'+CT('FormInfo.br')+CT(\"Script.Mod_ExpPilotBridge.1265\")+ShipName(Player())+CT(\"Script.Mod_ExpPilotBridge.1264\");",
                        "CustomEther('QuestNormal',3,'CustomQuestKillBridge',CT(\"Script.Mod_ExpPilotBridge.1273\")+CT('FormInfo.br')+CT(\"Script.Mod_ExpPilotBridge.1272\")+(ETimeLeft-CurTurn()+1)+CT(\"Script.Mod_ExpPilotBridge.1271\")+CT('FormInfo.br')+CT(\"Script.Mod_ExpPilotBridge.1260\")+PlanetName(IdToPlanet(EQuestPlanet))+CT(\"Script.Mod_ExpPilotBridge.1259\")+StarName(PlanetToStar(IdToPlanet(EQuestPlanet)))+'</color>)'+CT('FormInfo.br')+' '+CT('FormInfo.br')+GEQuestText);",
