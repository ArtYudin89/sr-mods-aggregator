                        "                          else temp_str_4='</color>'+CT(\"Script.Mod_ExpPilotBridge.1516\");",
                        "                      }",
                        "                      CustomEther('MailFailed',0,'',Format(CT(\"Script.Mod_ExpPilotBridge.1515\"),\"<0>\",point_3_name,\"<1>\",temp_str,\"<2>\",temp_str_2,\"<3>\",point_1_name,\"<4>\",temp_str_3,\"<5>\",temp_str_4,\"<6>\",StarName(PlanetToStar(GetShipHomePlanet(Player()))),\"<7>\",PlanetName(GetShipHomePlanet(Player()))));",
