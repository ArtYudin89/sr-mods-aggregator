                    "Code": [
                        "PlayerBridge(11);"
                    ],
                    "#": 511,
                    "Type": "Top",
                    "Parent": -1,
                    "Pos.x": 370,
                    "Pos.y": 975
                },
                {
                    "Name": "",
                    "Code.Type": "Turn",
                    "Code": [
                        "PlayerBridge(12);",
                        "if(!TipsState(22)) {",
                        "    Tips(22);",
                        "}"
                    ],
                    "#": 512,
                    "Type": "Top",
                    "Parent": -1,
                    "Pos.x": 490,
                    "Pos.y": 975
                },
                {
                    "Name": "",
                    "Code.Type": "Turn",
                    "Code": [
                        "NoTalkToShip(Player(), 0);",
                        "DAnswer('main');",
                        "Sound('Sound.ButtonInfoEnter');"
                    ],
                    "#": 513,
                    "Type": "Top",
                    "Parent": -1,
                    "Pos.x": 610,
