                        "        ArrayAdd(GAddTArray,temp_str_4);",
                        "    }",
                        "    HullDelTime=HullDelTime+CurTurn();",
                        "    TransHullCost=(((transfer_cargo_cost+(transfer_cargo_cost*20)/100)*25)/100)+(((transfer_cargo_cost+(transfer_cargo_cost*20)/100)*75)/100);",
                        "    ShipMoney(Player(),ShipMoney(Player())-TransHullCost);",
                        "    TransHullCost=GalaxyTechLevel();",
