                    "Code": [
                        "if(CapitalShipStats(ShipEqInSlot(Player(), t_Hull)) == 1) PlayerBridge(1);",
                        "if(CapitalShipStats(ShipEqInSlot(Player(), t_Hull)) == 2) PlayerBridge(2);",
                        "if(CapitalShipStats(ShipEqInSlot(Player(), t_Hull)) == 3) PlayerBridge(3);"
                    ],
                    "#": 510,
                    "Type": "Top",
                    "Parent": -1,
                    "Pos.x": 250,
                    "Pos.y": 975
                },
                {
                    "Name": "",
