                        "        //Установка минимальной цены (межсистемной)",
                        "        if(temp_int_3)",
                        "        {",
                        "            if((TransHullCost+temp_int_2)<1250 && (temp_int_4==1 || temp_int_4==2 || temp_int_4==3))TransHullCost=1250/3;",
                        "            else if((TransHullCost+temp_int_2)<3125 && (temp_int_4==4 || temp_int_4==5 || temp_int_4==6))TransHullCost=3125/3;",
                        "            else if((TransHullCost+temp_int_2)<5000 && (temp_int_4==7 || temp_int_4==8))TransHullCost=5000/3;",
                        "        }",
                        "        //Установка минимальной цены (внутрисистемной)",
                        "        else",
                        "        {",
                        "            if((TransHullCost+temp_int_2)<500 && (temp_int_4==1 || temp_int_4==2 || temp_int_4==3))TransHullCost=500/3;",
                        "            else if((TransHullCost+temp_int_2)<1000 && (temp_int_4==4 || temp_int_4==5 || temp_int_4==6))TransHullCost=1000/3;",
                        "            else if((TransHullCost+temp_int_2)<2000 && (temp_int_4==7 || temp_int_4==8))TransHullCost=2000/3;",
