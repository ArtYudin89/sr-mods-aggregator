                        "      //Обработчик прерывания изначальной доставки на станцию",
                        "      if(LTargetType==2)",
                        "      {",
                        "          if(point_1==3)",
                        "          {",
                        "              if(LStationDExist)",
                        "              {",
                        "                  //Груз был в пути на станцию доставки, но её уничтожили, а груз перенаправили на планету отправки",
                        "                  if(StarOwner(PlanetToStar(IdToPlanet(point_1_id)))!=1 && StarCustomFaction(PlanetToStar(IdToPlanet(point_1_id)))=='')",
