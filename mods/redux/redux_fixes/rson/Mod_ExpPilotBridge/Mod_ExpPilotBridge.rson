                        "                          if(LStationDExist==1)temp_str_4='</color>'+CT(\"Script.Mod_ExpPilotBridge.1519\");",
                        "                          else temp_str_4='</color>'+CT(\"Script.Mod_ExpPilotBridge.1476\");",
                        "                      }",
