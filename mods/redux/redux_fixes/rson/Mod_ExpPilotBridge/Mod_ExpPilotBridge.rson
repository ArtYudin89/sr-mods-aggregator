                },
                {
                    "Name": "",
                    "Code.Type": "Turn",
                    "Code": [
                        "//Если был выбран стандартный раздел, то добавляем кнопку перехода на следующую страницу (если их там несколько)",
                        "if(temp_int_2!=9999)",
                        "{",
                        "    temp_str=CT('Galapedia.'+temp_int_2+'.PagesCount');",
                        "    temp_int=temp_str;",
                        "    if(temp_int>1)InjectAnswer('GalapediaPage',CT(\"Script.Mod_ExpPilotBridge.82\"),temp_int_3+1);",
                        "}",
                        "//Если был выбран раздел биомодулей, то формируем список доступных биомодулей для текущего ГТУ",
                        "else",
                        "{",
                        "    //Определяем, биомодули до какого ГТУ будем выводить",
                        "    for(i=1;i<=GalaxyTechLevel();i=i+1)",
                        "    {",
                        "        if(!BlockExist('Biomodules.'+i+'_gtu'))continue;",
                        "        temp_int=CT('Biomodules.'+i+'_gtu.ilegal_count');",
                        "        for(count2=1;count2<=temp_int;count2=count2+1)",
                        "        {",
                        "            //Запоминаем в одной строке номер ГТУ и номер импланта",
                        "            temp_str=''+i+count2;",
                        "            temp_int_7=temp_str;",
                        "            //Затем подставляем в ответ его имя и собранный адрес для последующей \"дешифровки\"",
                        "            temp_str=CT('Biomodules.'+i+'_gtu.'+count2+'.Name');",
                        "            InjectAnswer('GalapediaPage',temp_str,temp_int_7);",
                        "        }",
                        "    }",
                        "}",
