                        "              CargoLostChanceCalcHome();",
                        "          }",
                        "      }",
                        "  }",
                        "  ",
                        "  //Восстановление груза, утерянного при доставке в захваченную родную систему",
                        "  if(saved_items)",
                        "  {",
                        "      if(StarOwner(PlanetToStar(GetShipHomePlanet(Player())))!=1 && StarCustomFaction(PlanetToStar(GetShipHomePlanet(Player())))=='')",
                        "      {",
                        "          for(j=1;j<=saved_items;j=j+1)",
                        "          {",
                        "              temp_dword=GetItemFromVault('saved_by_miracle_'+j);",
                        "              AddItemToStorage(GetShipHomePlanet(Player()),temp_dword);",
                        "              CustomEther('MailGood',0,'',Format(CT(\"Script.Mod_ExpPilotBridge.1512\"),\"<0>\",PlanetName(GetShipHomePlanet(Player()))));",
                        "          }",
                        "          saved_items=0;",
                        "      }",
                        "  }",
                        "  ",
                        "  //Обработчики прерывания перегона корпусов",
                        "  if(HullDelTime>CurTurn())",
                        "  {",
                        "      //Корпус был в пути на планету отправки, но её захватили (корпус украден)",
                        "      if(LHullTargetType==3)",
                        "      {",
                        "          if(StarOwner(PlanetToStar(IdToPlanet(HullDelFromId)))==1 || StarCustomFaction(PlanetToStar(IdToPlanet(HullDelFromId)))!='')",
                        "          {",
                        "              if(HullOnWay==1)NewsAdd(Format(CT(\"Script.Mod_ExpPilotBridge.1511\"),\"<0>\",StarName(PlanetToStar(IdToPlanet(HullDelFromId))),\"<1>\",PlanetName(IdToPlanet(HullDelFromId))));",
                        "              else if(HullOnWay>1)NewsAdd(Format(CT(\"Script.Mod_ExpPilotBridge.1510\"),\"<0>\",StarName(PlanetToStar(IdToPlanet(HullDelFromId))),\"<1>\",PlanetName(IdToPlanet(HullDelFromId))));",
                        "              HullWasStolen=7;",
                        "              HullWasStolenThiefCreate(0);",
                        "          }",
                        "      }",
                        "      //Корпус был в пути на станцию отправки, но её уничтожили, либо она покинула систему (корпус украден)",
                        "      if(LHullTargetType==4)",
                        "      {",
                        "          if(HullFromStExist)",
                        "          {",
                        "              //Станция доставки была уничтожена",
                        "              if(HullFromStExist==1)",
                        "              {",
                        "                  temp_str_2='</color>'+Format(CT(\"Script.Mod_ExpPilotBridge.1477\"),\"<0>\",StarName(GalaxyStar(HullFromStarId)));",
                        "                  temp_str_3='</color>'+CT(\"Script.Mod_ExpPilotBridge.1476\");",
                        "              }",
                        "              //Станция доставки покинула систему",
                        "              else",
                        "              {",
                        "                  temp_str_2='</color>'+Format(CT(\"Script.Mod_ExpPilotBridge.1475\"),\"<0>\",StarName(GalaxyStar(HullFromStarId)));",
                        "                  temp_str_3='</color>'+CT(\"Script.Mod_ExpPilotBridge.1474\");",
                        "              }",
                        "              if(HullOnWay==1)NewsAdd(Format(CT(\"Script.Mod_ExpPilotBridge.1509\"),\"<0>\",HullFromName,\"<1>\",temp_str_2,\"<2>\",temp_str_3));",
                        "              else if(HullOnWay>1)NewsAdd(Format(CT(\"Script.Mod_ExpPilotBridge.1508\"),\"<0>\",HullFromName,\"<1>\",temp_str_2,\"<2>\",temp_str_3));",
                        "              HullWasStolen=7;",
                        "              HullWasStolenThiefCreate(0);",
                        "          }",
                        "      }",
                        "      //Обработчик прерывания изначальной доставки корпуса",
                        "      if(LHullTargetType==1)",
                        "      {",
                        "          if(HullFromType==3)",
                        "          {",
                        "              if(StarOwner(PlanetToStar(IdToPlanet(HullDelEndId)))==1 || StarCustomFaction(PlanetToStar(IdToPlanet(HullDelEndId)))!='')",
                        "              {",
                        "                  //Корпус был в пути на планету доставки, но её захватили, а корпус перенаправили (возможно) на планету отправки",
                        "                  if(StarOwner(PlanetToStar(IdToPlanet(HullDelFromId)))!=1 && StarCustomFaction(PlanetToStar(IdToPlanet(HullDelFromId)))=='')",
                        "                  {",
                        "                      if(HullOnWay==1 && HullWasStolen==0 && (HullAgentType==1 || HullAgentType==2))NewsAdd(Format(CT(\"Script.Mod_ExpPilotBridge.1514\"),\"<0>\",StarName(PlanetToStar(IdToPlanet(HullDelEndId))),\"<1>\",PlanetName(IdToPlanet(HullDelEndId)),\"<2>\",PlanetName(IdToPlanet(HullDelFromId)),\"<3>\",StarName(PlanetToStar(IdToPlanet(HullDelFromId)))));",
                        "                      else if(HullOnWay==1 && (HullWasStolen>0 || HullAgentType==22 || HullAgentType==3))NewsAdd(Format(CT(\"Script.Mod_ExpPilotBridge.1500\"),\"<0>\",StarName(PlanetToStar(IdToPlanet(HullDelEndId))),\"<1>\",PlanetName(IdToPlanet(HullDelEndId))));",
                        "                      else if(HullOnWay>1 && HullWasStolen==0 && (HullAgentType==1 || HullAgentType==2))NewsAdd(Format(CT(\"Script.Mod_ExpPilotBridge.1506\"),\"<0>\",StarName(PlanetToStar(IdToPlanet(HullDelEndId))),\"<1>\",PlanetName(IdToPlanet(HullDelEndId)),\"<2>\",PlanetName(IdToPlanet(HullDelFromId)),\"<3>\",StarName(PlanetToStar(IdToPlanet(HullDelFromId)))));",
                        "                      else if(HullOnWay>1 && HullWasStolen>0 && HullWasStolen<7 && (HullAgentType==1 || HullAgentType==2))NewsAdd(Format(CT(\"Script.Mod_ExpPilotBridge.1505\"),\"<0>\",StarName(PlanetToStar(IdToPlanet(HullDelEndId))),\"<1>\",PlanetName(IdToPlanet(HullDelEndId)),\"<2>\",PlanetName(IdToPlanet(HullDelFromId)),\"<3>\",StarName(PlanetToStar(IdToPlanet(HullDelFromId)))));",
                        "                      else if(HullOnWay>1 && (HullWasStolen==7 || HullAgentType==22 || HullAgentType==3))NewsAdd(Format(CT(\"Script.Mod_ExpPilotBridge.1504\"),\"<0>\",StarName(PlanetToStar(IdToPlanet(HullDelEndId))),\"<1>\",PlanetName(IdToPlanet(HullDelEndId))));",
                        "                      if(HullAgentType==22 || HullAgentType==3)HullWasStolen=7;",
                        "                      if(HullWasStolen>0)HullWasStolenThiefCreate(0);",
                        "                      HullDelTime=CurTurn()-HullDelTimeStart;",
                        "                      HullDelTimeExp=HullDelTime+CurTurn();",
                        "                      if(Rnd(1,100)<=35 && HullAgentType==1)HullDelTime=HullDelTime+((HullDelTime*Rnd(15,25))/100);",
                        "                      if(Rnd(1,100)<=65 && HullAgentType==2)HullDelTime=HullDelTime+((HullDelTime*Rnd(25,40))/100);",
                        "                      HullDelTime=HullDelTime+CurTurn();",
                        "                      HullDelEndId=HullDelFromId;",
                        "                      temp_int_1=HullFromStarId;",
                        "                      HullEndStarId=HullFromStarId;",
                        "                      HullFromStarId=temp_int_1;",
                        "                      LHullTargetType=3;",
                        "                  }",
                        "                  //Корпус был в пути на планету доставки, но её захватили, а планета отправки уже была захвачена (корпус украден)",
                        "                  else",
                        "                  {",
                        "                      if(HullOnWay==1)NewsAdd(Format(CT(\"Script.Mod_ExpPilotBridge.1503\"),\"<0>\",StarName(PlanetToStar(IdToPlanet(HullDelEndId))),\"<1>\",PlanetName(IdToPlanet(HullDelEndId)),\"<2>\",PlanetName(IdToPlanet(HullDelFromId)),\"<3>\",StarName(PlanetToStar(IdToPlanet(HullDelFromId)))));",
                        "                      else if(HullOnWay>1)NewsAdd(Format(CT(\"Script.Mod_ExpPilotBridge.1502\"),\"<0>\",StarName(PlanetToStar(IdToPlanet(HullDelEndId))),\"<1>\",PlanetName(IdToPlanet(HullDelEndId)),\"<2>\",PlanetName(IdToPlanet(HullDelFromId)),\"<3>\",StarName(PlanetToStar(IdToPlanet(HullDelFromId)))));",
                        "                      HullWasStolen=7;",
                        "                      HullWasStolenThiefCreate(0);",
