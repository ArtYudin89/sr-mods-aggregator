                        "    for(i=0;i<ArrayDim(transfer_list_done);i=i+1)",
                        "    {",
                        "        if(Rnd(1,100)<=55)",
                        "        {",
                        "            count2=Rnd(1,8);",
                        "            //Событие космического боя",
                        "            if(count2==1)temp_str_4='2'+Rnd(1,5)+'01'+Rnd(39,67)+'---';",
                        "            //Событие \"шпионские игры\"",
                        "            if(count2==2)temp_str_4='2'+Rnd(1,5)+'02'+'-----';",
                        "            //Событие музыкальной группы",
                        "            if(count2==3 || count2==4)temp_str_4='2'+Rnd(1,5)+'04'+Rnd(1,3)+'----';",
                        "            //Событие доставки почты",
                        "            if(count2==5 || count2==6)temp_str_4='2'+Rnd(1,5)+'05'+Rnd(107,163)+'--';",
