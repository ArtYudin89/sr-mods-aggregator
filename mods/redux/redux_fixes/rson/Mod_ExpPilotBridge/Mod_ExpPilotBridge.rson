                {
                    "Name": "",
                    "Code.Type": "Turn",
                    "Code": [
                        "//Собираем текстину",
                        "",
                        "temp_str = '----------------'+CT('FormInfo.br');",
                        "temp_dword_3 = ShipStar(Player());",
                        "",
                        "for(i=0;GalaxyStars()>i;i=i+1) {",
                        "    temp_dword_2 = StarNearbyStars(temp_dword_3,i);",
                        "    if(temp_int_5 >= 5) break;",
                        "    for(j=0;StarPlanets(temp_dword_2)>j;j=j+1) {",
                        "        temp_dword_4 = StarPlanets(temp_dword_2,j);",
                        "        if(PlanetOwner(temp_dword_4) != 6) continue;",
                        "        if(PlanetTerrainExplored(temp_dword_4,0) == PlanetTerrain(temp_dword_4,0) && PlanetTerrainExplored(temp_dword_4,1) == PlanetTerrain(temp_dword_4,1) && PlanetTerrainExplored(temp_dword_4,2) == PlanetTerrain(temp_dword_4,2)) continue;",
                        "        temp_int_2 = 0;",
                        "",
                        "        for(tint1=0;GetPlanetOrbitProbe(temp_dword_4,-1,0)>tint1;tint1=tint1+1) {",
                        "            if(GetPlanetOrbitProbe(temp_dword_4,tint1,0)) {",
                        "                temp_int_2 = 1;",
                        "                break;",
                        "            }",
                        "        }",
                        "",
                        "        if(temp_int_2) continue;",
                        "        //Незаселёнка, не исследована полностью, зонды АНАПЕРЕЙШНБЛ",
                        "        //Можем начинать набивать текст",
                        "",
                        "        temp_int_3 = PlanetTerrain(temp_dword_4,0) - PlanetTerrainExplored(temp_dword_4,0);",
                        "        temp_int_4 = PlanetTerrain(temp_dword_4,1) - PlanetTerrainExplored(temp_dword_4,1);",
                        "        temp_int_5 = PlanetTerrain(temp_dword_4,2) - PlanetTerrainExplored(temp_dword_4,2);",
                        "        if(StarOwner(temp_dword_2) == 0 && StarCustomFaction(temp_dword_2) == '') temp_str_3 = CT(\"Script.Mod_ExpPilotBridge.1616\");",
                        "        else if(StarOwner(temp_dword_2) == 2 && StarCustomFaction(temp_dword_2) == '') temp_str_3 = CT(\"Script.Mod_ExpPilotBridge.1615\");",
                        "        else temp_str_3 = CT(\"Script.Mod_ExpPilotBridge.1614\");",
                        "        temp_str = temp_str + '</color>' + CT(\"Script.Mod_ExpPilotBridge.1613\")+' '+'<clr>'+Name(temp_dword_4)+'<clrEnd>';",
                        "        temp_str = temp_str + CT('FormInfo.br') + '</color>' + CT(\"Script.Mod_ExpPilotBridge.1612\")+' '+'<clr>'+Name(temp_dword_2)+'<clrEnd>'+' '+temp_str_3+CT(\"Script.Mod_ExpPilotBridge.1611\")+' '+'<clr>'+Name(StarToCon(temp_dword_2))+'<clrEnd>';",
                        "        temp_str = temp_str + CT('FormInfo.br') + '</color>' + CT(\"Script.Mod_ExpPilotBridge.1610\")+' '+'<clr>'+round(sqrt(Dist2Star(temp_dword_2,temp_dword_3)))+'<clrEnd>'+' '+CT(\"Script.Mod_ExpPilotBridge.1609\");",
                        "        temp_str = temp_str + CT('FormInfo.br') + CT(\"Script.Mod_ExpPilotBridge.1608\");",
