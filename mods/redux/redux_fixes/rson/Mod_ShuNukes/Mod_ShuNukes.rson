                        "",
                        "            if(check2) InjectAnswer('AlreadyInstalled',CT('Script.Mod_ShuNukes.NukeModifications.'+i+'.Answer'),i);",
                        "            else if(check1) InjectAnswer('ReinstallDialog',CT('Script.Mod_ShuNukes.NukeModifications.'+i+'.Answer'),i);",
                        "            else InjectAnswer('BuyDialog',CT('Script.Mod_ShuNukes.NukeModifications.'+i+'.Answer'),i);",
                        "        }",
                        "        else {",
                        "            tstr3 = Format(tstr3,'money',(GalaxyMoney(4,4) * CT('Script.Mod_ShuNukes.NukeModifications.'+i+'.GTL')));",
                        "        }",
                        "    }",
                        "}",
                        "tstr3 = tstr3 + Format('<br>') + '</color>-------------------------------------';",
                        "tstr1 = Format(tstr1,'#Modifs#',tstr3);",
                        "",
                        "tstr2 = '</color>' + CT('Script.Mod_ShuNukes.' + path + '.PlayerBuyModNo');",
                        "DChange(5);",
                        "exit;"
                    ],
                    "#": 99,
                    "Type": "Top",
                    "Parent": -1,
                    "Pos.x": 1540,
                    "Pos.y": 540
                },
                {
                    "Name": "",
                    "Code.Type": "Turn",
                    "Code": [
                        "Sound('Sound.Buy');",
                        "ShipMoney(Player(),ShipMoney(Player())-tint1);",
                        "",
                        "cur_ship = GetShipRuins(Player());",
                        "//Нейтральные и вялофракционные станции",
                        "int stand_for = ShipStanding(cur_ship);",
                        "if(stand_for >= 4 && stand_for <= 6)",
                        "{",
                        "    nuke_shafts = 1;",
                        "    if(stand_for == 4 || ship_type_num == t_PB) nuke_type = 'DirtyNukeTorpedo';",
                        "    else nuke_type = 'NukeTorpedo';",
                        "}",
                        "else if(stand_for >= 2 && stand_for <= 3) //Коалиционная станция",
                        "{",
                        "    str nuke_type = 'NukeTorpedo';",
                        "    int nuke_max = 6;",
                        "    int nuke_shafts = 2;",
                        "}",
                        "else if(ship_type_num == t_WB) //Коалиционная станция",
                        "{",
                        "    nuke_type = 'DirtyNukeTorpedo'; //А вы что думали?)",
                        "    nuke_max = 8;",
                        "    nuke_shafts = 4;",
                        "}",
                        "else if(ship_type == 'DD') //Коалиционная станция",
                        "{",
                        "    nuke_type = 'DirtyNukeTorpedo'; //А вы что думали?)",
                        "    nuke_max = 10;",
                        "    nuke_shafts = 6;",
                        "}",
                        "else //Пиратская станция",
                        "{",
                        "    nuke_type = 'DirtyNukeTorpedo';",
                        "    nuke_max = 6;",
                        "    nuke_shafts = 2;",
                        "}",
                        "",
                        "",
                        "dword nuke_weight = CreateQuestItem('ShuNukes_NukesWeight');",
                        "ItemSize(nuke_weight, g_NukeParams['WeightPerShaft'] * nuke_shafts);",
                        "AddItemToShip(cur_ship, nuke_weight);",
                        "NoDropItem(nuke_weight, 1);",
                        "",
                        "dword nukes = CreateCustomCountableItem('ShuNukes_' + nuke_type, nuke_max);",
                        "ItemCost(nukes, GalaxyMoney(2, 0) * nuke_max);",
                        "AddItemToShip(cur_ship, nukes);",
                        "//Чтобы имели отдельное уведомление при попытке выбросить их с корабля или уничтожить",
                        "if(nuke_type != 'DirtyNukeTorpedo') NoDropItem(nukes, 92);",
                        "else NoDropItem(nukes, 93);",
                        "",
                        "ItemExtraSpecialsAddByType(ShipEqInSlot(cur_ship,t_Hull), FindBonusByNameInCfg('ShuNukes_NukeShaft'), nuke_shafts);",
                        "",
                        "ShipAddCustomShipInfo(cur_ship, 'ShuNukes_NPCNuclearMissilesNoArmada', '', nuke_max, nuke_max, 0, nuke_type, '' + nuke_shafts + ',' + Id(nuke_weight), Id(nukes));",
                        "ArrangeItems(cur_ship);"
                    ],
                    "#": 100,
                    "Type": "Top",
                    "Parent": -1,
                    "Pos.x": -20,
                    "Pos.y": 565
                },
                {
                    "Name": "",
                    "Code.Type": "Turn",
                    "Code": [
                        "//Нейтральные и вялофракционные станции",
                        "int stand_for = ShipStanding(GetShipRuins(Player()));",
                        "if(stand_for >= 4 && stand_for <= 6)",
                        "{",
                        "    int nuke_shafts = 1;",
                        "    if(stand_for == 4 || ship_type_num == t_PB) {",
                        "        nuke_type = 'DirtyNukeTorpedo';",
                        "        tint1 = 3 * GalaxyMoney(4,4);",
                        "    }",
                        "    else {",
                        "        nuke_type = 'NukeTorpedo';",
                        "        tint1 = 2 * GalaxyMoney(4,4);",
                        "    }",
                        "}",
                        "else if(stand_for >= 2 && stand_for <= 3) //Коалиционная станция",
                        "{",
                        "    str nuke_type = 'NukeTorpedo';",
                        "    tint1 = 2 * GalaxyMoney(4,4);",
                        "}",
                        "else if(ship_type_num == t_WB) //Коалиционная станция",
                        "{",
                        "    nuke_type = 'DirtyNukeTorpedo'; //А вы что думали?)",
                        "    tint1 = 3 * GalaxyMoney(4,4);",
                        "}",
                        "else if(ship_type == 'DD') //Коалиционная станция",
                        "{",
                        "    nuke_type = 'DirtyNukeTorpedo'; //А вы что думали?)",
                        "    tint1 = 3 * GalaxyMoney(4,4);",
                        "}",
                        "else //Пиратская станция",
                        "{",
                        "    nuke_type = 'DirtyNukeTorpedo';",
                        "    tint1 = 3 * GalaxyMoney(4,4);",
                        "}",
                        "",
                        "",
                        "cur_item = CountBox('Bm.Items.2Minerals',CT('Script.Mod_ShuNukes.StationNukesDialogs.AskHowMuchBuy'),1,100,tint1,1,round(ShipMoney(Player())/tint1),round(ShipMoney(Player())/tint1),ShipMoney(Player()));",
                        "",
                        "if(~cur_item) {",
                        "    ShipMoney(Player(),ShipMoney(Player()) - (cur_item * tint1));",
                        "    dword nukes = FindShipItemById(cur_ship, ShipCustomShipInfoTextData(GetShipRuins(Player()), 'ShuNukes_NPCNuclearMissilesNoArmada', 3));",
                        "    if(nukes)",
                        "    {",
                        "        ItemSize(nukes, ItemSize(nukes, 'Count') + cur_item, 'Count');",
                        "        ItemCost(nukes, GalaxyMoney(2, 0) * ItemSize(nukes, 'Count'));",
                        "    }",
                        "",
                        "    Sound('Sound.Buy');",
                        "}"
                    ],
                    "#": 101,
                    "Type": "Top",
                    "Parent": -1,
                    "Pos.x": 100,
                    "Pos.y": 565
                },
                {
                    "Name": "",
                    "Code.Type": "Turn",
                    "Code": [
                        "//Добавляем игроку ядерных торпед",
                        "tint1 = g_NukeParams[nuke_type, 'NukesPerYear'] - g_NukeParams[nuke_type, 'NukesSold'];",
                        "str nukes_cnt = NumberBox('Bm.FormShip2.NukeNumberIcon', CT('Script.Mod_ShuNukes.' + path + '.HowMuchNukes'), 1, tint1, RoundTo(1.0 * ShipMoney(Player()) / nuke_cost, 1.0, -1), '', 1);",
                        "if(int(nukes_cnt) && nukes_cnt != 'Cancel')",
                        "{",
                        "    dword nukes = CreateCustomCountableItem('ShuNukes_' + 'EMNukeTorpedo', nukes_cnt);",
                        "    ItemCost(nukes, nuke_cost * nukes_cnt);",
                        "    AddItemToShip(Player(), nukes);",
                        "    g_NukeParams[nuke_type, 'NukesSold'] = g_NukeParams[nuke_type, 'NukesSold'] + nukes_cnt;",
                        "",
                        "    tstr1 = '</color>' + CT('Script.Mod_ShuNukes.' + path + '.AnswerBuyNukes');",
                        "    ShipMoney(Player(), ShipMoney(Player()) - nuke_cost * nukes_cnt);",
                        "    Sound('Sound.Buy');",
                        "    tint1 = 1;",
                        "}",
                        "else tint1 = 0;",
                        "if(tint1) {",
                        "  DChange(4);",
                        "  exit;",
                        "}",
                        "if(!tint1) {",
                        "  DChange(3);",
                        "  exit;",
                        "}"
                    ],
                    "#": 102,
                    "Type": "Top",
                    "Parent": -1,
                    "Pos.x": 220,
                    "Pos.y": 565
                },
