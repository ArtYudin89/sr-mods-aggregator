                    ],
                    "#": 77,
                    "Type": "Top",
                    "Parent": -1,
                    "Pos.x": 490,
                    "Pos.y": 400
                },
                {
                    "Name": "",
                    "Code.Type": "Turn",
                    "Code": [
                        "//Нейтральные и вялофракционные станции",
                        "int stand_for = ShipStanding(GetShipRuins(Player()));",
                        "if(stand_for >= 4 && stand_for <= 6)",
                        "{",
                        "    nuke_shafts = 1;",
                        "    if(stand_for == 4 || ship_type_num == t_PB) nuke_type = 'DirtyNukeTorpedo';",
                        "    else nuke_type = 'NukeTorpedo';",
                        "}",
                        "else if(stand_for >= 2 && stand_for <= 3) //Коалиционная станция",
                        "{",
                        "    str nuke_type = 'NukeTorpedo';",
                        "    int nuke_max = 6;",
                        "    int nuke_shafts = 2;",
                        "}",
                        "else if(ship_type_num == t_WB) //Коалиционная станция",
                        "{",
                        "    nuke_type = 'DirtyNukeTorpedo'; //А вы что думали?)",
                        "    nuke_max = 8;",
                        "    nuke_shafts = 4;",
                        "}",
                        "else if(ship_type == 'DD') //Коалиционная станция",
                        "{",
                        "    nuke_type = 'DirtyNukeTorpedo'; //А вы что думали?)",
                        "    nuke_max = 10;",
                        "    nuke_shafts = 6;",
                        "}",
                        "else //Пиратская станция",
                        "{",
                        "    nuke_type = 'DirtyNukeTorpedo';",
                        "    nuke_max = 6;",
                        "    nuke_shafts = 2;",
                        "}",
                        "",
                        "tint1 = 10 * GalaxyMoney(4,4) * nuke_shafts;",
                        "",
                        "tstr1 = '</color>' + Format(CT('Script.Mod_ShuNukes.StationNukesDialogs.MainInstall'),'cost',tint1);",
                        "tstr2 = '</color>' + CT('Script.Mod_ShuNukes.StationNukesDialogs.Exit');",
                        "tstr3 = '</color>' + CT('Script.Mod_ShuNukes.StationNukesDialogs.PlayerInstallOk');",
                        "DChange(9);",
                        "exit;"
                    ],
