                    "Pos.x": 1480,
                    "Pos.y": 470
                },
                {
                    "Name": "",
                    "Code.Type": "Turn",
                    "Code": [
                        "tstr1 = '</color>' + CT('Script.Mod_ShuNukes.' + path + '.AnswerNuke');",
                        "g_NukeParams[nuke_type, 'DialogStatus'] = '2';",
                        "cur_item = ShipEqInSlot(Player(), t_Hull);",
                        "check = 0;",
                        "",
                        "//check & 1 - добавляем ответ установки пусковой",
                        "//check & 2 - добавляем ответ демонтажа пусковой",
                        "//check & 4 - добавляем ответ закупки ядерных торпед",
                        "",
                        "//Мне было лень переписывать полностью скрипт этого отстоя, потому что он замечательно автоматизирован",
                        "//Настолько, что под новые типы торпед нужно по-хорошему переписывать скрипт на 30%",
                        "//Поэтому цена на все торпеды одна, и лимит покупки тоже один. Считается в термоядерках для Коалиции и ядерках для Клана",
                        "",
                        "bon = FindBonusByNameInCfg('ShuNukes_NukeShaft');",
                        "if(ShipOwner(cur_ruin) == Maloc) nuke_cost = round(GalaxyMoney(3, Maloc) * 3, 100);",
                        "else nuke_cost = round(GalaxyMoney(3, PirateClan) * 4, 100);",
                        "if(ShipOwner(cur_ruin) == Maloc) launcher_cost = round(GalaxyMoney(4, Maloc) * ItemLevel(cur_item), 100);",
                        "else launcher_cost = round(1.5 * GalaxyMoney(4, PirateClan) * ItemLevel(cur_item), 100);",
                        "",
                        "//Пусковая установка в данном корпусе отсутствует (можно докупить торпед, либо установить её)",
                        "if(!ItemExtraSpecialsCountByType(cur_item, bon))",
                        "{",
                        "    tstr1 = tstr1 + Format('<br>') + CT('Script.Mod_ShuNukes.' + path + '.AnswerNukeNoLauncher');",
                        "    if(g_NukeParams[nuke_type, 'NukesSold'] < g_NukeParams[nuke_type, 'NukesPerYear'])",
                        "    {",
                        "        tstr1 = tstr1 + Format('<br>') + CT('Script.Mod_ShuNukes.' + path + '.AnswerNukeNoLauncherNukes');",
                        "        tstr1 = Format(tstr1, '<Class'+'>', CT('Items.Weapon.LevelToLetter.' + ItemLevel(cur_item)),",
                        "                              '<Cost'+'>', launcher_cost,",
                        "                              '<NukeSize'+'>', g_NukeParams['WeightPerShaft'],",
                        "                              '<NukesCount'+'>', g_NukeParams[nuke_type, 'NukesPerYear'] - g_NukeParams[nuke_type, 'NukesSold'],",
                        "                              '<NukeCost'+'>', nuke_cost);",
                        "",
                        "        tstr2 = '</color>' + Format(CT('Script.Mod_ShuNukes.' + path + '.PlayerBuyNukes'), '<Cost'+'>', nuke_cost);",
                        "        tstr8 = '</color>' + Format(CT('Script.Mod_ShuNukes.' + path + '.PlayerBuyEMNukes'), '<Cost'+'>', nuke_cost);",
                        "        tstr6 = '</color>' + Format(CT('Script.Mod_ShuNukes.' + path + '.PlayerBuyNeutronNukes'), '<Cost'+'>', nuke_cost);",
                        "        tstr7 = '</color>' + Format(CT('Script.Mod_ShuNukes.' + path + '.PlayerBuyCombinedNukes'), '<Cost'+'>', nuke_cost);",
                        "        if(ShipMoney(Player()) < nuke_cost)",
                        "        {",
                        "            tstr2 = '</color>' + Format(CT('Script.Mod_ShuNukes.' + path + '.PlayerBuyNukesNoMoney'), '<Cost'+'>', nuke_cost);",
                        "            tstr2 = DeleteTags(tstr2);",
                        "            AddDialogBlock(tstr2, 1);",
                        "            tstr8 = '</color>' + Format(CT('Script.Mod_ShuNukes.' + path + '.PlayerBuyEMNukesNoMoney'), '<Cost'+'>', nuke_cost);",
                        "            tstr8 = DeleteTags(tstr8);",
                        "            AddDialogBlock(tstr8, 1);",
                        "            tstr6 = '</color>' + Format(CT('Script.Mod_ShuNukes.' + path + '.PlayerBuyNeutronNukesNoMoney'), '<Cost'+'>', nuke_cost);",
                        "            tstr6 = DeleteTags(tstr6);",
                        "            AddDialogBlock(tstr6, 1);",
                        "            tstr7 = '</color>' + Format(CT('Script.Mod_ShuNukes.' + path + '.PlayerBuyCombinedNukesNoMoney'), '<Cost'+'>', nuke_cost);",
                        "            tstr7 = DeleteTags(tstr7);",
                        "            AddDialogBlock(tstr7, 1);",
                        "        }",
                        "",
                        "        if(ItemSize(cur_item) < round(2.5 * g_NukeParams['WeightPerShaft'])) //Корпус игрока слишком мал для пусковой установки",
                        "        {",
                        "            tstr3 = '</color>' + CT('Script.Mod_ShuNukes.' + path + '.PlayerInstallLaunchShaftNoFit');",
                        "            tstr3 = DeleteTags(tstr3);",
                        "            AddDialogBlock(tstr3, 1);",
                        "        }",
                        "        else",
                        "        {",
                        "            tstr3 = '</color>' + Format(CT('Script.Mod_ShuNukes.' + path + '.PlayerInstallLaunchShaft'), '<Cost'+'>', launcher_cost);",
                        "            if(ShipMoney(Player()) < launcher_cost)",
                        "            {",
                        "                tstr3 = '</color>' + Format(CT('Script.Mod_ShuNukes.' + path + '.PlayerInstallLaunchShaftNoMoney'), '<Cost'+'>', launcher_cost);",
                        "                tstr3 = DeleteTags(tstr3);",
                        "                AddDialogBlock(tstr3, 1);",
                        "            }",
                        "        }",
                        "",
                        "        tstr4 = '</color>' + CT('Script.Mod_ShuNukes.' + path + '.PlayerRefuse');",
                        "        check = 1+4;",
                        "    }",
                        "    else",
                        "    {",
                        "        tstr1 = tstr1 + Format('<br>') + CT('Script.Mod_ShuNukes.' + path + '.AnswerNukeNoLauncherNoMoreNukes');",
                        "        tstr1 = Format(tstr1, '<Class'+'>', CT('Items.Weapon.LevelToLetter.' + ItemLevel(cur_item)),",
                        "                              '<Cost'+'>', launcher_cost,",
                        "                              '<NukeSize'+'>', g_NukeParams['WeightPerShaft']);",
                        "",
                        "        tstr2 = '</color>' + Format(CT('Script.Mod_ShuNukes.' + path + '.PlayerBuyNukes'), '<Cost'+'>', nuke_cost, '');",
                        "        AddDialogBlock(tstr2, 1);",
                        "        tstr8 = '</color>' + Format(CT('Script.Mod_ShuNukes.' + path + '.PlayerBuyEMNukes'), '<Cost'+'>', nuke_cost, '');",
                        "        AddDialogBlock(tstr8, 1);",
                        "        tstr6 = '</color>' + Format(CT('Script.Mod_ShuNukes.' + path + '.PlayerBuyNeutronNukes'), '<Cost'+'>', nuke_cost, '');",
                        "        AddDialogBlock(tstr6, 1);",
                        "        tstr7 = '</color>' + Format(CT('Script.Mod_ShuNukes.' + path + '.PlayerBuyCombinedNukes'), '<Cost'+'>', nuke_cost, '');",
                        "        AddDialogBlock(tstr7, 1);",
                        "",
                        "        if(ItemSize(cur_item) < round(2.5 * g_NukeParams['WeightPerShaft'])) //Корпус игрока слишком мал для пусковой установки",
                        "        {",
                        "            tstr3 = '</color>' + CT('Script.Mod_ShuNukes.' + path + '.PlayerInstallLaunchShaftNoFit');",
                        "            tstr3 = DeleteTags(tstr3);",
                        "            AddDialogBlock(tstr3, 1);",
                        "        }",
                        "        else",
                        "        {",
                        "            tstr3 = '</color>' + Format(CT('Script.Mod_ShuNukes.' + path + '.PlayerInstallLaunchShaft'), '<Cost'+'>', launcher_cost);",
                        "            if(ShipMoney(Player()) < launcher_cost)",
                        "            {",
                        "                tstr3 = '</color>' + Format(CT('Script.Mod_ShuNukes.' + path + '.PlayerInstallLaunchShaftNoMoney'), '<Cost'+'>', launcher_cost);",
                        "                tstr3 = DeleteTags(tstr3);",
                        "                AddDialogBlock(tstr3, 1);",
                        "            }",
                        "        }",
                        "",
                        "        tstr4 = '</color>' + CT('Script.Mod_ShuNukes.' + path + '.PlayerRefuse');",
                        "        check = 1+4;",
                        "    }",
                        "}",
                        "//Пусковая установка в корпусе уже имеется (можно докупить торпед, либо демонтировать её)",
                        "else",
                        "{",
                        "    if(g_NukeParams[nuke_type, 'NukesSold'] < g_NukeParams[nuke_type, 'NukesPerYear'])",
                        "    {",
                        "        tstr1 = tstr1 + Format('<br>') + CT('Script.Mod_ShuNukes.' + path + '.AnswerNukeWithLauncher');",
                        "        tstr1 = tstr1 + Format('<br>') + Format(CT('Script.Mod_ShuNukes.' + path + '.AnswerNukeWithLauncherNukes'),",
                        "                                                   '<NukesCount'+'>', g_NukeParams[nuke_type, 'NukesPerYear'] - g_NukeParams[nuke_type, 'NukesSold'],",
                        "                                                   '<NukeCost'+'>', nuke_cost);",
                        "",
                        "        tstr2 = '</color>' + Format(CT('Script.Mod_ShuNukes.' + path + '.PlayerBuyNukes'), '<Cost'+'>', nuke_cost);",
                        "        tstr8 = '</color>' + Format(CT('Script.Mod_ShuNukes.' + path + '.PlayerBuyEMNukes'), '<Cost'+'>', nuke_cost);",
                        "        tstr6 = '</color>' + Format(CT('Script.Mod_ShuNukes.' + path + '.PlayerBuyNeutronNukes'), '<Cost'+'>', nuke_cost);",
                        "        tstr7 = '</color>' + Format(CT('Script.Mod_ShuNukes.' + path + '.PlayerBuyCombinedNukes'), '<Cost'+'>', nuke_cost);",
                        "        if(ShipMoney(Player()) < nuke_cost)",
                        "        {",
                        "            tstr2 = '</color>' + Format(CT('Script.Mod_ShuNukes.' + path + '.PlayerBuyNukesNoMoney'), '<Cost'+'>', nuke_cost);",
                        "            tstr2 = DeleteTags(tstr2);",
                        "            AddDialogBlock(tstr2, 1);",
                        "            tstr8 = '</color>' + Format(CT('Script.Mod_ShuNukes.' + path + '.PlayerBuyEMNukesNoMoney'), '<Cost'+'>', nuke_cost);",
                        "            tstr8 = DeleteTags(tstr8);",
                        "            AddDialogBlock(tstr2, 1);",
                        "            tstr6 = '</color>' + Format(CT('Script.Mod_ShuNukes.' + path + '.PlayerBuyNeutronNukesNoMoney'), '<Cost'+'>', nuke_cost);",
                        "            tstr6 = DeleteTags(tstr6);",
                        "            AddDialogBlock(tstr6, 1);",
                        "            tstr7 = '</color>' + Format(CT('Script.Mod_ShuNukes.' + path + '.PlayerBuyCombinedNukesNoMoney'), '<Cost'+'>', nuke_cost);",
                        "            tstr7 = DeleteTags(tstr7);",
                        "            AddDialogBlock(tstr7, 1);",
                        "        }",
                        "        tstr3 = '</color>' + CT('Script.Mod_ShuNukes.' + path + '.PlayerDeinstallLaunchShaft');",
                        "        tstr4 = '</color>' + CT('Script.Mod_ShuNukes.' + path + '.PlayerRefuse');",
                        "        check = 2+4;",
                        "    }",
                        "    else",
                        "    {",
                        "        tstr1 = tstr1 + Format('<br>') + CT('Script.Mod_ShuNukes.' + path + '.AnswerNukeWithLauncher');",
                        "        tstr1 = tstr1 + Format('<br>') + CT('Script.Mod_ShuNukes.' + path + '.AnswerNukeWithLauncherNoMoreNukes');",
                        "",
                        "        tstr2 = '</color>' + Format(CT('Script.Mod_ShuNukes.' + path + '.PlayerBuyNukes'), '<Cost'+'>', nuke_cost, '');",
                        "        AddDialogBlock(tstr2, 1);",
                        "        tstr8 = '</color>' + Format(CT('Script.Mod_ShuNukes.' + path + '.PlayerBuyEMNukes'), '<Cost'+'>', nuke_cost, '');",
                        "        AddDialogBlock(tstr8, 1);",
                        "        tstr6 = '</color>' + Format(CT('Script.Mod_ShuNukes.' + path + '.PlayerBuyNeutronNukes'), '<Cost'+'>', nuke_cost, '');",
                        "        AddDialogBlock(tstr6, 1);",
                        "        tstr7 = '</color>' + Format(CT('Script.Mod_ShuNukes.' + path + '.PlayerBuyCombinedNukes'), '<Cost'+'>', nuke_cost, '');",
                        "        AddDialogBlock(tstr7, 1);",
                        "        tstr3 = '</color>' + CT('Script.Mod_ShuNukes.' + path + '.PlayerDeinstallLaunchShaft');",
                        "        tstr4 = '</color>' + CT('Script.Mod_ShuNukes.' + path + '.PlayerRefuse');",
                        "        check = 2+4;",
                        "    }",
                        "}",
                        "",
                        "//Составляем диалог модификаций ядрёной бимбы",
                        "tstr5 = '</color>' + CT('Script.Mod_ShuNukes.' + path + '.PlayerBuyMod');",
                        "DChange(3);",
                        "exit;"
                    ],
                    "#": 91,
                    "Type": "Top",
                    "Parent": -1,
                    "Pos.x": 100,
                    "Pos.y": 540
                },
                {
                    "Name": "",
                    "Code.Type": "Turn",
                    "Code": [
                        "DChange(2);",
                        "exit;"
                    ],
                    "#": 92,
                    "Type": "Top",
                    "Parent": -1,
                    "Pos.x": 220,
                    "Pos.y": 540
                },
                {
                    "Name": "",
                    "Code.Type": "Turn",
                    "Code": [
                        "//Устанавливаем пусковую установку в корпус игрока",
                        "ItemExtraSpecialsAddByType(cur_item, bon, 1);",
                        "ShipCustomShipInfoTextData(Player(), 'ShuNukes_NuclearMissiles', 2, SetParFromString(ShipCustomShipInfoTextData(Player(), 'ShuNukes_NuclearMissiles', 2), ',', 0, '1'));",
                        "//CreateActCodeEvent(t_OnPlayerChangeHull, 'ShuNukes_NuclearMissiles', Player(), ShipEqInSlot(Player(), t_Hull)); //Для обновления веса скрытого юзлеса",
                        "dword nuke_weight = IdToItem(GetParFromString(ShipCustomShipInfoTextData(Player(), 'ShuNukes_NuclearMissiles', 2), ',', 1, 0));",
                        "if(nuke_weight) ItemSize(nuke_weight, g_NukeParams['WeightPerShaft'] * ItemExtraSpecialsCountByType(ShipEqInSlot(Player(), t_Hull), FindBonusByNameInCfg('ShuNukes_NukeShaft')));",
                        "else throw 'nuke_weight are missing at hold of ' + Name(Player()) + ', error 1!';",
                        "",
                        "ShipMoney(Player(), ShipMoney(Player()) - launcher_cost);",
                        "Sound('Sound.Buy');",
                        "",
                        "tstr1 = '</color>' + CT('Script.Mod_ShuNukes.' + path + '.AnswerInstallLaunchShaft');",
                        "DChange(4);",
                        "exit;"
                    ],
                    "#": 93,
                    "Type": "Top",
                    "Parent": -1,
                    "Pos.x": 460,
                    "Pos.y": 540
                },
                {
                    "Name": "",
                    "Code.Type": "Turn",
                    "Code": [
                        "//Добавляем игроку ядерных торпед",
                        "tint1 = g_NukeParams[nuke_type, 'NukesPerYear'] - g_NukeParams[nuke_type, 'NukesSold'];",
                        "str nukes_cnt = NumberBox('Bm.FormShip2.NukeNumberIcon', CT('Script.Mod_ShuNukes.' + path + '.HowMuchNukes'), 1, tint1, RoundTo(1.0 * ShipMoney(Player()) / nuke_cost, 1.0, -1), '', 1);",
                        "if(int(nukes_cnt) && nukes_cnt != 'Cancel')",
                        "{",
                        "    dword nukes = CreateCustomCountableItem('ShuNukes_' + nuke_type, nukes_cnt);",
                        "    ItemCost(nukes, nuke_cost * nukes_cnt);",
                        "    AddItemToShip(Player(), nukes);",
                        "    g_NukeParams[nuke_type, 'NukesSold'] = g_NukeParams[nuke_type, 'NukesSold'] + nukes_cnt;",
                        "",
                        "    tstr1 = '</color>' + CT('Script.Mod_ShuNukes.' + path + '.AnswerBuyNukes');",
                        "    ShipMoney(Player(), ShipMoney(Player()) - nuke_cost * nukes_cnt);",
                        "    Sound('Sound.Buy');",
                        "    tint1 = 1;",
                        "}",
                        "else tint1 = 0;",
                        "if(tint1) {",
                        "  DChange(4);",
                        "  exit;",
                        "}",
                        "if(!tint1) {",
                        "  DChange(3);",
                        "  exit;",
                        "}"
                    ],
                    "#": 94,
                    "Type": "Top",
                    "Parent": -1,
                    "Pos.x": 580,
                    "Pos.y": 540
                },
                {
                    "Name": "",
                    "Code.Type": "Turn",
                    "Code": [
                        "//Удаляем пусковую установку из корпуса игрока",
                        "ItemExtraSpecialsDeleteByType(cur_item, bon, ItemExtraSpecialsCountByType(cur_item, bon));",
                        "ShipCustomShipInfoTextData(Player(), 'ShuNukes_NuclearMissiles', 2, SetParFromString(ShipCustomShipInfoTextData(Player(), 'ShuNukes_NuclearMissiles', 2), ',', 0, '0'));",
                        "",
                        "dword nuke_weight = IdToItem(GetParFromString(ShipCustomShipInfoTextData(Player(), 'ShuNukes_NuclearMissiles', 2), ',', 1, 0));",
                        "if(nuke_weight) ItemSize(nuke_weight, 0);",
                        "else throw 'nuke_weight are missing at hold of ' + Name(Player()) + ', error 2!';",
                        "",
                        "Sound('Sound.Repair');",
                        "",
                        "tstr1 = '</color>' + CT('Script.Mod_ShuNukes.' + path + '.AnswerDeinstallLaunchShaft');",
                        "DChange(4);",
                        "exit;"
                    ],
                    "#": 95,
                    "Type": "Top",
                    "Parent": -1,
                    "Pos.x": 700,
                    "Pos.y": 540
                },
                {
                    "Name": "",
                    "Code.Type": "Turn",
                    "Code": [
                        "//Выход из диалога о ядерных торпедах",
                        "tstr1 = '</color>' + CT('Script.Mod_ShuNukes.' + path + '.AnswerRefuse');",
                        "DChange(4);",
                        "exit;"
                    ],
                    "#": 96,
                    "Type": "Top",
                    "Parent": -1,
                    "Pos.x": 820,
                    "Pos.y": 540
                },
                {
                    "Name": "",
                    "Code.Type": "Turn",
                    "Code": [
                        "//Собираем строчку с описанием модификаций",
                        "tstr1 = '</color>' + CT('Script.Mod_ShuNukes.' + path + '.AnswerBuyMod');",
                        "tstr3 = '';",
                        "for(i=1;i<=CT('Script.Mod_ShuNukes.NukeModifications.Count');i=i+1) {",
                        "    if(GetGameOptions('FontDialog') == '0') tstr3 = tstr3 + '</color>-------------------------------------------------------------';",
                        "    else if(GetGameOptions('FontDialog') == '1') tstr3 = tstr3 + '</color>------------------------------------------';",
                        "    else if(GetGameOptions('FontDialog') == '2') tstr3 = tstr3 + '</color>-----------------------------------------';",
                        "    else /*if(GetGameOptions('FontDialog') == '3')*/ tstr3 = tstr3 + '</color>-------------------------------------';",
                        "",
                        "    tstr3 = tstr3 + Format('<br>') + '</color>' + CT('Script.Mod_ShuNukes.NukeModifications.'+i+'.Text') + Format('<br>');",
                        "    if(int(CT('Script.Mod_ShuNukes.NukeModifications.'+i+'.GTL')) > GalaxyTechLevel()){",
                        "        tstr3 = Format(tstr3,'#aviable#',CT('Script.Mod_ShuNukes.NukeModifications.Unaviable'));",
                        "        tstr3 = Format(tstr3,'money',(GalaxyMoney(4,4) * CT('Script.Mod_ShuNukes.NukeModifications.'+i+'.GTL')));",
                        "    }",
                        "    else {",
                        "        tstr3 = Format(tstr3,'#aviable#',CT('Script.Mod_ShuNukes.NukeModifications.Aviable'));",
                        "        if(ShipMoney(Player()) > (GalaxyMoney(4,4) * CT('Script.Mod_ShuNukes.NukeModifications.'+i+'.GTL'))) {",
                        "            tstr3 = Format(tstr3,'money',(GalaxyMoney(4,4) * CT('Script.Mod_ShuNukes.NukeModifications.'+i+'.GTL')));",
                        "",
                        "            //1 - есть хоть какая-то модификация, диалог уточнит у игрока, хочет ли он на самом деле",
                        "            //2 - у игрока такая модификация уже есть, игрок отличается умом и сообразительностью",
                        "            int check1 = 0;",
                        "            int check2 = 0;",
                        "",
                        "            for(j=1;j<=CT('Script.Mod_ShuNukes.NukeModifications.Count');j=j+1) {",
                        "                if(ItemExtraSpecialsCountByType(ShipEqInSlot(Player(),t_Hull),FindBonusByNameInCfg(CT('Script.Mod_ShuNukes.NukeModifications.'+j+'.Info')))) {",
                        "                    if(i == j) check2 = 1;",
                        "                    else check1 = 1;",
                        "                }",
                        "            }",
                        "",
                        "            if(check2) InjectAnswer('AlreadyInstalled',CT('Script.Mod_ShuNukes.NukeModifications.'+i+'.Answer'),i);",
                        "            else if(check1) InjectAnswer('ReinstallDialog',CT('Script.Mod_ShuNukes.NukeModifications.'+i+'.Answer'),i);",
                        "            else InjectAnswer('BuyDialog',CT('Script.Mod_ShuNukes.NukeModifications.'+i+'.Answer'),i);",
                        "        }",
                        "        else {",
                        "            tstr3 = Format(tstr3,'money',(GalaxyMoney(4,4) * CT('Script.Mod_ShuNukes.NukeModifications.'+i+'.GTL')));",
                        "        }",
                        "    }",
                        "}",
                        "tstr3 = tstr3 + Format('<br>') + '</color>-------------------------------------';",
                        "tstr1 = Format(tstr1,'#Modifs#',tstr3);",
                        "",
                        "tstr2 = '</color>' + CT('Script.Mod_ShuNukes.' + path + '.PlayerBuyModNo');",
                        "DChange(5);",
                        "exit;"
                    ],
                    "#": 97,
                    "Type": "Top",
                    "Parent": -1,
                    "Pos.x": 1060,
                    "Pos.y": 540
                },
                {
                    "Name": "",
                    "Code.Type": "Turn",
                    "Code": [
                        "i = GAnswerData;",
                        "",
                        "ClearModifications();",
                        "",
                        "ShipMoney(Player(),ShipMoney(Player()) - (GalaxyMoney(4,4) * CT('Script.Mod_ShuNukes.NukeModifications.'+i+'.GTL')));",
                        "Sound('Sound.Buy');",
                        "",
                        "ItemExtraSpecialsAddByType(ShipEqInSlot(Player(),t_Hull),FindBonusByNameInCfg(CT('Script.Mod_ShuNukes.NukeModifications.'+i+'.Info')));",
                        "",
                        "tstr1 = '</color>' + CT('Script.Mod_ShuNukes.' + path + '.AnswerBuyModEnd');",
                        "tstr2 = '</color>' + CT('Script.Mod_ShuNukes.' + path + '.PlayerBuyModEnd');",
                        "DChange(6);",
                        "exit;"
                    ],
                    "#": 98,
                    "Type": "Top",
                    "Parent": -1,
                    "Pos.x": 1420,
                    "Pos.y": 540
                },
                {
                    "Name": "",
                    "Code.Type": "Turn",
                    "Code": [
                        "//Собираем строчку с описанием модификаций",
                        "tstr1 = '</color>' + CT('Script.Mod_ShuNukes.' + path + '.AnswerBuyMod');",
                        "tstr3 = '';",
                        "for(i=1;i<=CT('Script.Mod_ShuNukes.NukeModifications.Count');i=i+1) {",
                        "    if(GetGameOptions('FontDialog') == '0') tstr3 = tstr3 + '</color>-------------------------------------------------------------';",
                        "    else if(GetGameOptions('FontDialog') == '1') tstr3 = tstr3 + '</color>------------------------------------------';",
                        "    else if(GetGameOptions('FontDialog') == '2') tstr3 = tstr3 + '</color>-----------------------------------------';",
