                    "Parent": -1,
                    "Pos.x": 280,
                    "Pos.y": 400
                },
                {
                    "Name": "",
                    "Code.Type": "Turn",
                    "Code": [
                        "tstr1 = '</color>' + CT('Script.Mod_ShuNukes.' + path + '.AnswerBuyModInstalledSame');",
                        "tstr2 = '</color>' + CT('Script.Mod_ShuNukes.' + path + '.PlayerBuyModReturn');",
                        "DChange(8);",
