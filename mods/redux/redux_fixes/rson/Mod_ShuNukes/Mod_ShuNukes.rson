                {
                    "Name": "",
                    "Code.Type": "Turn",
                    "Code": [
                        "//Нейтральные и вялофракционные станции",
                        "int stand_for = ShipStanding(GetShipRuins(Player()));",
                        "if(stand_for >= 4 && stand_for <= 6)",
                        "{",
                        "    int nuke_shafts = 1;",
                        "    if(stand_for == 4 || ship_type_num == t_PB) {",
                        "        nuke_type = 'DirtyNukeTorpedo';",
                        "        tint1 = 3 * GalaxyMoney(4,4);",
                        "    }",
                        "    else {",
                        "        nuke_type = 'NukeTorpedo';",
                        "        tint1 = 2 * GalaxyMoney(4,4);",
                        "    }",
                        "}",
                        "else if(stand_for >= 2 && stand_for <= 3) //Коалиционная станция",
                        "{",
                        "    str nuke_type = 'NukeTorpedo';",
                        "    tint1 = 2 * GalaxyMoney(4,4);",
                        "}",
                        "else if(ship_type_num == t_WB) //Коалиционная станция",
                        "{",
                        "    nuke_type = 'DirtyNukeTorpedo'; //А вы что думали?)",
                        "    tint1 = 3 * GalaxyMoney(4,4);",
                        "}",
                        "else if(ship_type == 'DD') //Коалиционная станция",
                        "{",
                        "    nuke_type = 'DirtyNukeTorpedo'; //А вы что думали?)",
                        "    tint1 = 3 * GalaxyMoney(4,4);",
                        "}",
                        "else //Пиратская станция",
                        "{",
                        "    nuke_type = 'DirtyNukeTorpedo';",
                        "    tint1 = 3 * GalaxyMoney(4,4);",
                        "}",
                        "",
                        "tstr1 = '</color>' + Format(CT('Script.Mod_ShuNukes.StationNukesDialogs.MainBuy'),'cost',tint1);",
                        "tstr2 = '</color>' + CT('Script.Mod_ShuNukes.StationNukesDialogs.Exit');",
                        "tstr3 = '</color>' + CT('Script.Mod_ShuNukes.StationNukesDialogs.PlayerBuyOk');",
                        "DChange(10);",
                        "exit;"
