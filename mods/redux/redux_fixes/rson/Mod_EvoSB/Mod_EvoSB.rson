                        "  if(ItemType(cur_item) < t_Weapon1) TextCorr1 = '</color>' + lowercase(substr(ShortName(cur_item), 0, 1)) + substr(ShortName(cur_item), 1);",
                        "  else TextCorr1 = DeleteTags(ShortName(cur_item));",
                        "  input = '</color>';",
                        "  if(improv_grade == 2)",
                        "  {",
                        "      if(ArrayDim(items) > 2) input = input + CT(\"Script.Mod_EvoSB.209\");",
                        "      else input = input + CT(\"Script.Mod_EvoSB.208\");",
                        "  }",
                        "  else if(improv_grade == 1)",
                        "  {",
                        "      if(ArrayDim(items) > 2) input = input + CT(\"Script.Mod_EvoSB.169\");",
                        "      else input = input + CT(\"Script.Mod_EvoSB.168\");",
                        "  }",
                        "  else if(improv_grade == 0)",
                        "  {",
                        "      if(ArrayDim(items) > 2) input = input + Format(CT(\"Script.Mod_EvoSB.125\"),\"<0>\",TextCorr1);",
                        "      else input = input + Format(CT(\"Script.Mod_EvoSB.167\"),\"<0>\",TextCorr1);",
                        "  }",
                        "  DChange(5);",
                        "  exit;",
                        "}",
                        "if(part_upgrade) {",
                        "  input = '<clrEnd>' + CT('FormRuins.SB.Improvement.SBDetailImprovement');",
                        "  DChange(4);",
                        "  exit;",
                        "}"
