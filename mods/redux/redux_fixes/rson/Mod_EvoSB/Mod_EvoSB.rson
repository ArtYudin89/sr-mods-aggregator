                },
                {
                    "Name": "",
                    "Code.Type": "Turn",
                    "Code": [
                        "int check = 1;",
                        "if(GetVariableType(tarr1[0]) != 9) check = 0;",
                        "",
                        "tstr1 = CT('FormRuins.SB.Scn.Section0');",
                        "if(DomiksDefeated(0) || GalaxyDominatorResearchPercent(0) >= 100) AddDialogBlock(tstr1, 2);",
                        "else if(!check) AddDialogBlock(tstr1, 1);",
                        "else tstr1 = CT('FormRuins.SB.Scn.SectionColor0') + tstr1 + '</color>';",
                        "InjectAnswer('HandOverDomiksPartsSection', tstr1, 0);",
                        "",
                        "tstr1 = CT('FormRuins.SB.Scn.Section1');",
                        "if(DomiksDefeated(1) || GalaxyDominatorResearchPercent(1) >= 100) AddDialogBlock(tstr1, 2);",
                        "else if(!check) AddDialogBlock(tstr1, 1);",
                        "else tstr1 = CT('FormRuins.SB.Scn.SectionColor1') + tstr1 + '</color>';",
                        "InjectAnswer('HandOverDomiksPartsSection', tstr1, 1);",
                        "",
                        "tstr1 = CT('FormRuins.SB.Scn.Section2');",
                        "if(DomiksDefeated(2) || GalaxyDominatorResearchPercent(2) >= 100) AddDialogBlock(tstr1, 2);",
                        "else if(!check) AddDialogBlock(tstr1, 1);",
                        "else tstr1 = CT('FormRuins.SB.Scn.SectionColor2') + tstr1 + '</color>';",
                        "InjectAnswer('HandOverDomiksPartsSection', tstr1, 2);",
                        "",
                        "tstr2 = '</color>' + CT('FormRuins.SB.Scn.SectionNone');",
                        "tstr3 = '</color>' + CT('FormRuins.SB.Scn.SBAfterSectionNone');",
                        "",
                        "if(CurrentMods('Evolution\\\\EvoArtDominator')) {",
                        "    if(BlockExist('FormRuins.SB.Scn2')) InjectAnswer('Mod_EvoArtDominator:ArtDominator', CT(\"Script.Mod_EvoSB.247\"), 4); //--Получение нового артефакта--}",
                        "    else SFT('Warning Mod_ArtDominator: Не найден раздел ...SB.Scn2, выдача артов невозможна');",
                        "}",
                        "if(CurrentMods('ShusRangers\\\\ShuDomiks')) {",
                        "    if(FindDomModsInStock(GetShipRuins(Player()))) InjectAnswer('Mod_ShuDomiks:FromEvoSB',CT(\"Script.Mod_EvoSB.245\"), 1);",
                        "}",
                        "if(CurrentMods('Kotyanka\\\\Cat_DomScience')) {",
                        "        if(!DomiksDefeated()) {",
                        "            if(FindModule()) {",
                        "                if(ShipType(GetShipRuins(Player())) == 'SB') {",
                        "                    InjectAnswer('Cat_DomScience:UnlockSB',CT(\"Script.Mod_EvoSB.246\"),15);",
                        "                }",
                        "                if(ShipType(GetShipRuins(Player())) == 'DD') {",
                        "                    InjectAnswer('Cat_DomScience:UnlockDD',CT(\"Script.Mod_EvoSB.246\"),15);",
                        "                }",
                        "            }",
                        "        }",
                        "}",
                        "if(CurrentMods('Reflection\\\\RefUniqueSmersh')) {",
                        "    if(GetValueFromScript('Mod_RefUniqueSmersh','Bought') > 0) {",
                        "        InjectAnswer('Mod_RefUniqueSmersh:SmershBuy',CT(\"Script.Mod_EvoSB.256\"),17);",
                        "    }",
                        "}",
                        "if(CurrentMods('Reflection\\\\RefNisper')) {",
                        "    if(GetValueFromScript('Mod_RefNisper','NewsFlag')) {",
                        "            if(!ShipOnSidePirateClan(Player())) {",
                        "                if(GetValueFromScript('Mod_RefNisper','SBDialog')) AddDialogInject('dSB', '', CT(\"Script.Mod_EvoSB.258\"), 0);",
                        "                else AddDialogInject('dSBStart', '', CT(\"Script.Mod_EvoSB.257\"), 100);",
                        "            }",
                        "    }",
                        "}",
                        "DAdd(37);"
                    ],
                    "#": 186,
                    "Type": "Top",
