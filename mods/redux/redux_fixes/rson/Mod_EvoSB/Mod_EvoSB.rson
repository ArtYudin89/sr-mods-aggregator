            "Operations": [
                {
                    "Name": "",
                    "Code.Type": "Global",
                    "Code": [
                        "GRun();"
                    ],
                    "#": 63,
                    "Type": "Top",
                    "Parent": -1,
                    "Pos.x": 0,
                    "Pos.y": 810
                },
                {
                    "Name": "",
                    "Code.Type": "Init",
                    "Code": [
                        "ProbesCheckTime = Rnd(261, 387);",
                        "",
                        "//Перебираем все системы и ищем НБ для записи инфошки с продаваемым базой зондом",
                        "for(i = 0; i < GalaxyStars(); i = i + 1)",
                        "{",
                        "    size = GalaxyStar(i);",
                        "    if(StarOwner(size) != 0) continue;",
                        "    if(!StarRuins(size, 'SB')) continue;",
                        "",
                        "    cur_ruin = StarRuins(size, 'SB');",
                        "    //Создаём зонд и записываем его параметры в свежедобавленную инфошку",
                        "    if(Rnd(1, 1000) <= (45 * GalaxyTechLevel())) tint = GalaxyTechLevel() - 1;",
                        "    else tint = Rnd(1, GalaxyTechLevel()) - 1;",
                        "    //С некоторым шансом генерируем уникальные зонды",
                        "    if(GalaxyTechLevel() == 2 || GalaxyTechLevel() == 3) {",
                        "        //Покоритель",
                        "        if(!Rnd(-1,1)) tint = 11;",
                        "    }",
                        "    else if(GalaxyTechLevel() == 4 || GalaxyTechLevel() == 5) {",
                        "        //Исследователь",
                        "        if(!Rnd(0,1)) tint = 12;",
                        "        //Покоритель",
                        "        else if(!Rnd(-1,2)) tint = 11;",
                        "    }",
                        "    else if(GalaxyTechLevel() == 8) {",
                        "        //Кочевник",
                        "        if(!Rnd(-4,1)) tint = 8;",
                        "        //Отшельник",
                        "        else if(!Rnd(-4,1)) tint = 9;",
                        "        //Наутилус",
                        "        else if(!Rnd(-4,1)) tint = 10;",
                        "        //Исследователь",
                        "        else if(!Rnd(0,3)) tint = 12;",
                        "        //Покоритель",
                        "        else if(!Rnd(-1,4)) tint = 11;",
                        "    }",
                        "    else if(GalaxyTechLevel() != 1) {",
                        "        //Исследователь",
                        "        if(!Rnd(0,2)) tint = 12;",
                        "        //Покоритель",
                        "        else if(!Rnd(-1,3)) tint = 11;",
                        "    }",
                        "    cur_item = CreateZond(tint, Rnd(0, 4));",
                        "",
                        "    //Определяем, к какому конкретно параметру зонд получил бонус (и получил ли его вообще)",
                        "    cost = -1;",
                        "    for(j = 0; j <= 2; j = j + 1)",
                        "    {",
                        "        if(GetEquipmentStats(cur_item, j) != CT('Items.Satellite.' + tint + '.' + j))",
                        "        {",
                        "            cost = j;",
                        "            break;",
                        "        }",
                        "    }",
                        "",
                        "    ShipAddCustomShipInfo(cur_ruin, 'RuinsProbeInStock', 'NoShow', ItemSize(cur_item), ItemCost(cur_item), ItemOwner(cur_item), Name(cur_item), tint, cost);",
                        "    //Удаляем зонд, т.к. сам он больше не нужен",
                        "    FreeItem(cur_item);",
                        "",
                        "    //Повторяем по второму кругу, потому что два зонда",
                        "",
                        "    //Создаём зонд и записываем его параметры в свежедобавленную инфошку",
                        "    if(Rnd(1, 1000) <= (45 * GalaxyTechLevel())) tint = GalaxyTechLevel() - 1;",
                        "    else tint = Rnd(1, GalaxyTechLevel()) - 1;",
                        "    //С некоторым шансом генерируем уникальные зонды",
                        "    if(GalaxyTechLevel() == 2 || GalaxyTechLevel() == 3) {",
                        "        //Покоритель",
                        "        if(!Rnd(-1,1)) tint = 11;",
                        "    }",
                        "    else if(GalaxyTechLevel() == 4 || GalaxyTechLevel() == 5) {",
                        "        //Исследователь",
                        "        if(!Rnd(0,1)) tint = 12;",
                        "        //Покоритель",
                        "        else if(!Rnd(-1,2)) tint = 11;",
                        "    }",
                        "    else if(GalaxyTechLevel() == 8) {",
                        "        //Кочевник",
                        "        if(!Rnd(-4,1)) tint = 8;",
                        "        //Отшельник",
                        "        else if(!Rnd(-4,1)) tint = 9;",
                        "        //Наутилус",
                        "        else if(!Rnd(-4,1)) tint = 10;",
                        "        //Исследователь",
                        "        else if(!Rnd(0,3)) tint = 12;",
                        "        //Покоритель",
                        "        else if(!Rnd(-1,4)) tint = 11;",
                        "    }",
                        "    else if(GalaxyTechLevel() != 1) {",
                        "        //Исследователь",
                        "        if(!Rnd(0,2)) tint = 12;",
                        "        //Покоритель",
                        "        else if(!Rnd(-1,3)) tint = 11;",
                        "    }",
                        "    cur_item = CreateZond(tint, Rnd(0, 4));",
                        "",
                        "    //Определяем, к какому конкретно параметру зонд получил бонус (и получил ли его вообще)",
                        "    cost = -1;",
                        "    for(j = 0; j <= 2; j = j + 1)",
                        "    {",
                        "        if(GetEquipmentStats(cur_item, j) != CT('Items.Satellite.' + tint + '.' + j))",
                        "        {",
                        "            cost = j;",
                        "            break;",
                        "        }",
                        "    }",
                        "",
                        "    ShipAddCustomShipInfo(cur_ruin, 'RuinsProbeInStock2', 'NoShow', ItemSize(cur_item), ItemCost(cur_item), ItemOwner(cur_item), Name(cur_item), tint, cost);",
                        "    //Удаляем зонд, т.к. сам он больше не нужен",
                        "    FreeItem(cur_item);",
                        "}",
                        "",
                        "function ComposeResearchDepartmentsText()",
                        "{",
                        "    //Считаем оставшиеся до окончания исследования дни по наглухо дабанутой ёбаформуле",
                        "    if(!DomiksDefeated(0) && GalaxyDominatorResearchPercent(0) < 100)",
                        "    {",
                        "        str text_blazer = Format(CT('FormRuins.SB.Scn.SBSectionInfoAdd')",
                        "                                              '<Count'+'>', GalaxyDominatorResearchMaterial(0),",
                        "                                              '<Speed'+'>', '' + int(PortionInDiapason(GalaxyDominatorResearchMaterial(0), 0, 300, 20, 100)) + '%',",
                        "                                              '<Day'+'>', DabsShitCalc(0));",
                        "    }",
                        "    else if(DomiksDefeated(0) == 1) text_blazer = 'Исследования остановлены';",
                        "    else text_blazer = CT('FormRuins.SB.Scn.SBSectionInfoEnd');",
                        "",
                        "    if(!DomiksDefeated(1) && GalaxyDominatorResearchPercent(1) < 100)",
                        "    {",
                        "        str text_keller = Format(CT('FormRuins.SB.Scn.SBSectionInfoAdd')",
                        "                                              '<Count'+'>', GalaxyDominatorResearchMaterial(1),",
                        "                                              '<Speed'+'>', '' + int(PortionInDiapason(GalaxyDominatorResearchMaterial(1), 0, 300, 20, 100)) + '%',",
                        "                                              '<Day'+'>', DabsShitCalc(1));",
                        "    }",
                        "    else if(DomiksDefeated(1) == 2 && DomiksDefeated(1) == 3) text_keller = 'Исследования остановлены';",
                        "    else text_keller = CT('FormRuins.SB.Scn.SBSectionInfoEnd');",
                        "",
                        "    if(!DomiksDefeated(2) && GalaxyDominatorResearchPercent(2) < 100)",
                        "    {",
                        "        str text_terron = Format(CT('FormRuins.SB.Scn.SBSectionInfoAdd')",
                        "                                              '<Count'+'>', GalaxyDominatorResearchMaterial(2),",
                        "                                              '<Speed'+'>', '' + int(PortionInDiapason(GalaxyDominatorResearchMaterial(2), 0, 300, 20, 100)) + '%',",
                        "                                              '<Day'+'>', DabsShitCalc(2));",
                        "    }",
                        "    else if(DomiksDefeated(2) == 1 && DomiksDefeated(2) == 3) text_terron = 'Исследования остановлены';",
                        "    else text_terron = CT('FormRuins.SB.Scn.SBSectionInfoEnd');",
                        "",
                        "",
                        "    result = Format(CT('FormRuins.SB.Scn.SBSectionInfo'),",
                        "                                   '<SBAnswerInfoBlazer'+'>', text_blazer,",
                        "                                   '<SBAnswerInfoKeller'+'>', text_keller,",
                        "                                   '<SBAnswerInfoTerron'+'>', text_terron,",
                        "                                   '<SplitLine'+'>', DefSplt,",
                        "                                   '');",
                        "}",
                        "",
                        "//Считаем оставшиеся до окончания исследования дни по наглухо дабанутой ёбаформуле",
                        "function DabsShitCalc(int serie)",
                        "{",
                        "    if(!serie) float serie_mod = 1.0; //Блазер",
                        "    else if(serie == 1) serie_mod = 1.2; //Келлер",
                        "    else serie_mod = 0.8; //Террон",
                        "",
                        "    float max_work_day_mod = GalaxyDiffLevels(2) / 50;",
                        "    if(1 == max_work_day_mod) max_work_day_mod = 0.050;",
                        "    else if(2 == max_work_day_mod) max_work_day_mod = 0.040;",
                        "    else if(3 == max_work_day_mod) max_work_day_mod = 0.030;",
                        "    else if(4 == max_work_day_mod) max_work_day_mod = 0.020;",
                        "    else",
                        "    {",
                        "        int i = int(max_work_day_mod) - 4;",
                        "        max_work_day_mod = 0.020;",
                        "        for(i = i; i >= 1; i = i - 1) max_work_day_mod = max_work_day_mod / 1.5;",
                        "    }",
                        "",
                        "    int speed_percent = PortionInDiapason(GalaxyDominatorResearchMaterial(serie), 0, 300, 20, 100);",
                        "    result = round(max(1.0, (100.0 - GalaxyDominatorResearchPercent(serie)) / PortionInDiapason(speed_percent, 0, 100, 0.00001, max_work_day_mod) * serie_mod));",
                        "}",
                        "",
                        "//Считаем оставшиеся до окончания исследования дни по наглухо дабанутой ёбаформуле",
                        "function g_DaysLeftForDomiks(int serie)",
                        "{",
                        "    if(!serie) float serie_mod = 1.0; //Блазер",
                        "    else if(serie == 1) serie_mod = 1.2; //Келлер",
                        "    else serie_mod = 0.8; //Террон",
                        "",
                        "    float max_work_day_mod = GalaxyDiffLevels(2) / 50;",
                        "    if(1 == max_work_day_mod) max_work_day_mod = 0.050;",
                        "    else if(2 == max_work_day_mod) max_work_day_mod = 0.040;",
                        "    else if(3 == max_work_day_mod) max_work_day_mod = 0.030;",
                        "    else if(4 == max_work_day_mod) max_work_day_mod = 0.020;",
                        "    else",
                        "    {",
                        "        int i = int(max_work_day_mod) - 4;",
                        "        max_work_day_mod = 0.020;",
                        "        for(i = i; i >= 1; i = i - 1) max_work_day_mod = max_work_day_mod / 1.5;",
                        "    }",
                        "",
                        "    int speed_percent = PortionInDiapason(GalaxyDominatorResearchMaterial(serie), 0, 300, 20, 100);",
                        "    result = round(max(1.0, (100.0 - GalaxyDominatorResearchPercent(serie)) / PortionInDiapason(speed_percent, 0, 100, 0.00001, max_work_day_mod) * serie_mod));",
                        "}",
                        "function FindDomModsInStock(dword place = 0)",
                        "{",
                        "    ArrayClear(tarr3);",
                        "    ArrayDelete(tarr3, 0);",
                        "",
                        "    int some_found_cnt = 0;",
                        "    int cnt = ShipItems(Player());",
                        "    for(int i = 1; i < cnt; i = i + 1)",
                        "    {",
                        "        dword item = ShipItems(Player(), i);",
                        "",
                        "        if(ItemType(item) < t_FuelTanks || ItemType(item) > t_CustomWeapon) continue;",
                        "        if(ItemOwner(item) != Kling) continue;",
                        "        if(EqSpecial(item) == -1) continue;",
                        "        if(findsubstr(BonusNumInCfg(EqSpecial(item)), 'DomModLocked') == -1) continue;",
                        "",
                        "        ArrayAdd(tarr3, item);",
                        "        some_found_cnt = some_found_cnt + 1;",
                        "    }",
                        "",
                        "    if(place)",
                        "    {",
                        "        cnt = StorageItems();",
                        "        for(i = 0; i < cnt; i = i + 1)",
                        "        {",
                        "            if(StorageItemLocation(i) != place) continue;",
                        "            item = StorageItems(i);",
                        "",
                        "            if(ItemType(item) < t_FuelTanks || ItemType(item) > t_CustomWeapon) continue;",
                        "            if(ItemOwner(item) != Kling) continue;",
                        "            if(EqSpecial(item) == -1) continue;",
                        "            if(findsubstr(BonusNumInCfg(EqSpecial(item)), 'DomModLocked') == -1) continue;",
                        "",
                        "            ArrayAdd(tarr3, item);",
                        "            some_found_cnt = some_found_cnt + 1;",
                        "        }",
                        "    }",
                        "",
                        "    if(!some_found_cnt) ArrayAdd(tarr3, 0); //Чтоб не крашил, собака",
                        "    result = some_found_cnt;",
                        "}",
                        "",
                        "function FindModule() {",
                        "    int crist_found = 0;",
                        "    int cnt111 = ShipItems(Player());",
                        "    for(i = 1; i < cnt111; i = i + 1)",
                        "    {",
                        "        dword item = ShipItems(Player(), i);",
                        "        if(ItemType(item) != t_UselessItem) continue;",
                        "        if(EquipmentImageName(item) != 'Remains_CatMem') continue;",
                        "        crist_found = crist_found + 1;",
                        "    }",
                        "",
                        "    result = crist_found;",
                        "}"
                    ],
                    "#": 64,
                    "Type": "Top",
                    "Parent": -1,
                    "Pos.x": 60,
                    "Pos.y": 810
                },
                {
                    "Name": "",
                    "Code.Type": "Turn",
                    "Code": [
                        "if(!ShipIsTakeoff(Player())) {",
                        "  if(ProbesCheckTime <= CurTurn())",
                        "  {",
                        "      variable = 0;",
                        "      //Перебираем все незаселённые планеты в Галактике (всего их около 160-170, с учётом мода EvoBG) и считаем полностью исследованные",
                        "      //for(i = 0; i < GalaxyStars(); i = i + 1)",
                        "      //{",
                        "      //    size = GalaxyStar(i);",
                        "      //    for(j = 0; j < StarPlanets(size); j = j + 1)",
                        "      //    {",
                        "      //        cur_item = StarPlanets(size, j);",
                        "      //        if(PlanetOwner(cur_item) != 6) continue;",
                        "      //        //Проверяем, полностью ли исследована незаселённая планета",
                        "      //        if(PlanetTerrain(cur_item, 0) != PlanetTerrainExplored(cur_item, 0)) continue;",
                        "      //        if(PlanetTerrain(cur_item, 1) != PlanetTerrainExplored(cur_item, 1)) continue;",
                        "      //        if(PlanetTerrain(cur_item, 2) != PlanetTerrainExplored(cur_item, 2)) continue;",
                        "      //        //И прибавляем счётчик, если таки да",
                        "      //        variable = variable + 1;",
                        "      //    }",
                        "      //}",
                        "      //",
                        "      //Маршал-вставка",
                        "      //Вы ёбу дали каждый раз галактику перебирать?",
                        "      variable = ArrayDim(ExplArr);",
                        "      //Маршал-вставка",
                        "  ",
                        "      //Накладываем на игрока бонус, увеличивающий лимит зондов под его контролем (до +4 при полном исследовании свыше 40 планет)",
                        "      if(variable >= 10 && ProbesMaxPlus < 1)",
                        "      {",
                        "          ShipSpecialBonuses(Player(), bonZonds, ShipSpecialBonuses(Player(), bonZonds) + 1);",
                        "          ProbesMaxPlus = 1;",
                        "          NewsAdd(Format(CT(\"Script.Mod_EvoSB.104\"),\"<0>\",10,\"<1>\",(ShipSkill(Player(),2)+ShipSpecialBonuses(Player(),bonZonds)+2)));",
                        "      }",
                        "      else if(variable >= 20 && ProbesMaxPlus < 2)",
                        "      {",
                        "          ShipSpecialBonuses(Player(), bonZonds, ShipSpecialBonuses(Player(), bonZonds) + (2 - ProbesMaxPlus));",
                        "          ProbesMaxPlus = 2;",
                        "          NewsAdd(Format(CT(\"Script.Mod_EvoSB.104\"),\"<0>\",20,\"<1>\",(ShipSkill(Player(),2)+ShipSpecialBonuses(Player(),bonZonds)+2)));",
                        "      }",
                        "      else if(variable >= 30 && ProbesMaxPlus < 3)",
                        "      {",
                        "          ShipSpecialBonuses(Player(), bonZonds, ShipSpecialBonuses(Player(), bonZonds) + (3 - ProbesMaxPlus));",
                        "          ProbesMaxPlus = 3;",
                        "          NewsAdd(Format(CT(\"Script.Mod_EvoSB.104\"),\"<0>\",30,\"<1>\",(ShipSkill(Player(),2)+ShipSpecialBonuses(Player(),bonZonds)+2)));",
                        "      }",
                        "      else if(variable >= 40 && ProbesMaxPlus < 4)",
                        "      {",
                        "          ShipSpecialBonuses(Player(), bonZonds, ShipSpecialBonuses(Player(), bonZonds) + (4 - ProbesMaxPlus));",
                        "          ProbesMaxPlus = 4;",
                        "          NewsAdd(Format(CT(\"Script.Mod_EvoSB.104\"),\"<0>\",40,\"<1>\",(ShipSkill(Player(),2)+ShipSpecialBonuses(Player(),bonZonds)+2)));",
                        "      }",
                        "      else if(variable >= 50 && ProbesMaxPlus < 5)",
                        "      {",
                        "          ShipSpecialBonuses(Player(), bonZonds, ShipSpecialBonuses(Player(), bonZonds) + (5 - ProbesMaxPlus));",
                        "          ProbesMaxPlus = 5;",
                        "          NewsAdd(Format(CT(\"Script.Mod_EvoSB.104\"),\"<0>\",50,\"<1>\",(ShipSkill(Player(),2)+ShipSpecialBonuses(Player(),bonZonds)+2)));",
                        "      }",
                        "      else if(variable >= 60 && ProbesMaxPlus < 6)",
                        "      {",
                        "          ShipSpecialBonuses(Player(), bonZonds, ShipSpecialBonuses(Player(), bonZonds) + (6 - ProbesMaxPlus));",
                        "          ProbesMaxPlus = 6;",
                        "          NewsAdd(Format(CT(\"Script.Mod_EvoSB.104\"),\"<0>\",60,\"<1>\",(ShipSkill(Player(),2)+ShipSpecialBonuses(Player(),bonZonds)+2)));",
                        "      }",
                        "      else if(variable >= 70 && ProbesMaxPlus < 7)",
                        "      {",
                        "          ShipSpecialBonuses(Player(), bonZonds, ShipSpecialBonuses(Player(), bonZonds) + (7 - ProbesMaxPlus));",
                        "          ProbesMaxPlus = 7;",
                        "          NewsAdd(Format(CT(\"Script.Mod_EvoSB.104\"),\"<0>\",70,\"<1>\",(ShipSkill(Player(),2)+ShipSpecialBonuses(Player(),bonZonds)+2)));",
                        "      }",
                        "      else if(variable >= 80 && ProbesMaxPlus < 8)",
                        "      {",
                        "          ShipSpecialBonuses(Player(), bonZonds, ShipSpecialBonuses(Player(), bonZonds) + (8 - ProbesMaxPlus));",
                        "          ProbesMaxPlus = 8;",
                        "          NewsAdd(Format(CT(\"Script.Mod_EvoSB.104\"),\"<0>\",80,\"<1>\",(ShipSkill(Player(),2)+ShipSpecialBonuses(Player(),bonZonds)+2)));",
                        "      }",
                        "      else if(variable >= 90 && ProbesMaxPlus < 9)",
                        "      {",
                        "          ShipSpecialBonuses(Player(), bonZonds, ShipSpecialBonuses(Player(), bonZonds) + (9 - ProbesMaxPlus));",
                        "          ProbesMaxPlus = 9;",
                        "          NewsAdd(Format(CT(\"Script.Mod_EvoSB.104\"),\"<0>\",90,\"<1>\",(ShipSkill(Player(),2)+ShipSpecialBonuses(Player(),bonZonds)+2)));",
                        "      }",
                        "      else if(variable >= 100 && ProbesMaxPlus < 10)",
                        "      {",
                        "          ShipSpecialBonuses(Player(), bonZonds, ShipSpecialBonuses(Player(), bonZonds) + (10 - ProbesMaxPlus));",
                        "          ProbesMaxPlus = 10;",
                        "          NewsAdd(Format(CT(\"Script.Mod_EvoSB.104\"),\"<0>\",100,\"<1>\",(ShipSkill(Player(),2)+ShipSpecialBonuses(Player(),bonZonds)+2)));",
                        "      }",
                        "  ",
                        "      //Запоминаем число полностью исследованных незаселённых планет",
                        "      UninhabitedPlanetsExplored = variable;",
                        "  ",
                        "      //Если бонусов уже максимум - ставим таймер проверок на стопор",
                        "      if(ProbesMaxPlus == 10) ProbesCheckTime = CurTurn() + Rnd(32, 47);",
                        "      else ProbesCheckTime = -1;",
                        "  }",
                        "}",
                        "if(ShipIsTakeoff(Player()) && !GetShipRuins(Player())) {",
                        "    dword tplan = GetShipPlanet(Player());",
                        "    if(PlanetOwner(tplan) == 6) {",
                        "        if(PlanetTerrain(tplan, 0) == PlanetTerrainExplored(tplan, 0) && PlanetTerrain(tplan, 1) == PlanetTerrainExplored(tplan, 1) && PlanetTerrain(tplan, 2) == PlanetTerrainExplored(tplan, 2)) {",
                        "            if(ArrayFind(ExplArr,Id(tplan)) == -1) {",
                        "                ArrayAdd(ExplArr,Id(tplan));",
                        "            }",
                        "        }",
                        "    }",
                        "}",
                        "",
                        "if(CurrentMods('Expansion\\\\ExpScienceRanks')) scienceRank = PlayerScienceRank['CurrentRank'];"
                    ],
                    "#": 65,
                    "Type": "Top",
                    "Parent": -1,
                    "Pos.x": 120,
                    "Pos.y": 810
                },
                {
                    "Name": "",
                    "Code.Type": "DialogBegin",
                    "Code": [
                        "cur_ruin = GetShipRuins(Player());",
                        "if(cur_ruin)",
                        "{",
                        "    if(ShipType(cur_ruin) == 'SB')",
                        "    {",
                        "        AddDialogBlock('HideThisAnswer', 2);",
                        "",
                        "        AddDialogInject('Improve', '', CT(\"Script.Mod_EvoSB.137\"), 60);",
                        "        AddDialogInject('ExcludeMM', '', CT(\"Script.Mod_EvoSB.201\"), 50);",
                        "        if(!DomiksDefeated()) AddDialogInject('HandOverDomiksParts', '', CT('FormRuins.SB.Scn.PlayerAskHandOver'), 40);",
                        "        AddDialogInject('ProbesPurchase', '', CT(\"Script.Mod_EvoSB.94\"), 30, 0, 1);",
                        "    }",
                        "}"
                    ],
                    "#": 66,
                    "Type": "Top",
                    "Parent": -1,
                    "Pos.x": 180,
                    "Pos.y": 810
                },
                {
                    "Name": "",
                    "Code.Type": "Turn",
                    "Code": [
                        "DChange(22);",
                        "exit;"
                    ],
                    "#": 150,
                    "Type": "Top",
                    "Parent": -1,
                    "Pos.x": -20,
                    "Pos.y": 475
                },
                {
                    "Name": "",
                    "Code.Type": "Turn",
                    "Code": [
                        "ArrayClear(ship);",
                        "ArrayAdd(ship, Player());",
                        "//Цикл, пока не закончатся все напарники рейнджеры",
                        "for(i = 0; i < ShipPartners(Player()); i = i + 1)",
                        "{",
                        "    cur_ship = ShipPartners(Player(), i);",
                        "    if(GetShipRuins(cur_ship) == GetShipRuins(Player())) ArrayAdd(ship, cur_ship);",
                        "}",
                        "//Цикл, пока не закончатся все напарники пираты",
                        "for(i = 0; i < PlayerPirates(Player()); i = i + 1)",
                        "{",
                        "    cur_ship = PlayerPirates(Player(), i);",
                        "    if(GetShipRuins(cur_ship) == GetShipRuins(Player())) ArrayAdd(ship, cur_ship);",
                        "}",
                        "//Цикл, пока не закончатся все активные транки",
                        "for(i = 0; i < PlayerTranclucators(); i = i + 1)",
                        "{",
                        "    cur_ship = PlayerTranclucators(i);",
                        "    if(GetShipRuins(cur_ship) == GetShipRuins(Player())) ArrayAdd(ship, cur_ship);",
                        "}",
                        "",
                        "//Цикл, пока не закончатся все артефакты в трюме",
                        "for(i = 0; i < ShipArts(Player()); i = i + 1)",
                        "{",
                        "    cur_item = ShipArts(Player(), i);",
                        "    if(ItemType(cur_item) == t_ArtefactTranclucator) ArrayAdd(ship, ArtTranclucatorToShip(cur_item));",
                        "}",
                        "DChange(3);",
                        "exit;"
                    ],
                    "#": 151,
                    "Type": "Top",
                    "Parent": -1,
                    "Pos.x": 130,
                    "Pos.y": 475
                },
                {
                    "Name": "",
                    "Code.Type": "Turn",
                    "Code": [
                        "cur_ship = GAnswerData;",
                        "if(GetGameOptions('FontDialog') == '0') DefSplt = '</color>-------------------------------------------------------------';",
                        "else if(GetGameOptions('FontDialog') == '1') DefSplt = '</color>------------------------------------------';",
                        "else if(GetGameOptions('FontDialog') == '2') DefSplt = '</color>-----------------------------------------';",
                        "else DefSplt = '</color>-------------------------------------';",
                        "variable = 0;",
                        "ArrayClear(items);",
                        "input = '';",
                        "for(i = 0; i < ShipItems(cur_ship); i = i + 1)",
                        "{",
                        "    cur_item = ShipItems(cur_ship, i);",
                        "    acryn_num = EqSpecial(cur_item);",
                        "",
                        "    //Исключаем уже улучшенное",
                        "    if(ItemImprovement(cur_item)) continue;",
                        "",
                        "    //Исключаем скриптовое",
                        "    if(ItemInScript(cur_item) == 1)",
                        "    {",
                        "        //Но добавляем в список предметы с особым параметром в акрине",
                        "        if(~acryn_num)",
                        "        {",
                        "            if(!CT('MicroModuls.' + BonusNumInCfg(acryn_num) + '.ScriptItemIgnore')) continue;",
                        "        }",
                        "        else continue;",
                        "    }",
                        "",
                        "    //Исключаем высокоуровневое нестандартное",
                        "    if(!ShipCanRepairEq(Player(), cur_item)) continue;",
                        "    if(EqCustomFaction(cur_item) != '' && ItemLevel(cur_item) > GalaxyTechLevel()) continue;",
                        "",
                        "    //Оставляем только стандартное оборудование и пушки",
                        "    if(ItemType(cur_item) < t_Hull || ItemType(cur_item) > t_CustomWeapon) continue;",
                        "    if(~acryn_num)",
                        "    {",
                        "        //Исключаем акриновые предметы с пометкой \"Не улучшаемый\"",
                        "        if(CT('MicroModuls.' + BonusNumInCfg(acryn_num) + '.BlockImp')) continue;",
                        "    }",
                        "",
                        "    //Исключаем корпуса, которым изменили восприимчивость на ТЦ",
                        "    /*if(ItemType(cur_item) == t_Hull)",
                        "    {",
                        "        j = FindBonusByNameInCfg('ExpTC_HullSpraying');",
                        "        if(~j) j = ItemExtraSpecialsCountByType(cur_item, j);",
                        "        if(j > 0) continue;",
                        "    }*/",
                        "",
                        "    ArrayAdd(items, cur_item);",
                        "    variable = variable + 1;",
                        "    input = input + '<clrEnd>' + variable + ') ' + DeleteTags(ItemFullName(cur_item)) + ' ' + CT(\"Script.Mod_EvoSB.111\") + ' <clr>' + ItemCost(cur_item) + '<clrEnd> cr.' + CT(\"Script.Mod_EvoSB.45\");",
                        "}",
                        "if(ArrayDim(items) <= 1) {",
                        "  if(cur_ship == Player()) tstr1 = '</color>' + CT(\"Script.Mod_EvoSB.110\");",
                        "  else if(ShipTypeN(cur_ship) == t_Tranclucator) tstr1 = '</color>' + CT(\"Script.Mod_EvoSB.105\");",
                        "  else if(ShipTypeN(cur_ship) == t_Ranger)",
                        "  {",
                        "      if(ShipType(cur_ship) == 'Merc' || ShipType(cur_ship) == 'Freelancer') tstr1 = '</color>' + CT(\"Script.Mod_EvoSB.108\");",
                        "      else if(ShipType(cur_ship) == 'RangerPirate') tstr1 = '</color>' + CT(\"Script.Mod_EvoSB.107\");",
                        "      else if(ShipType(cur_ship) == 'FemRanger') tstr1 = '</color>' + CT(\"Script.Mod_EvoSB.109\");",
                        "      else tstr1 = '</color>' + CT(\"Script.Mod_EvoSB.107\");",
                        "  }",
                        "  else if(ShipTypeN(cur_ship) == t_Pirate)",
                        "  {",
                        "      if(ShipType(cur_ship) == 'Rebel') tstr1 = '</color>' + CT(\"Script.Mod_EvoSB.106\");",
                        "      else if(ShipType(cur_ship) == 'Merc' || ShipType(cur_ship) == 'Freelancer') tstr1 = '</color>' + CT(\"Script.Mod_EvoSB.108\");",
                        "      else tstr1 = '</color>' + CT(\"Script.Mod_EvoSB.107\");",
                        "  }",
                        "  DChange(9);",
                        "  exit;",
                        "}",
                        "if(ArrayDim(items) > 1) {",
                        "  DChange(6);",
                        "  exit;",
                        "}"
                    ],
                    "#": 152,
                    "Type": "Top",
                    "Parent": -1,
                    "Pos.x": 250,
                    "Pos.y": 475
                },
                {
                    "Name": "",
                    "Code.Type": "Turn",
                    "Code": [
                        "cur_item = GAnswerData;",
                        "cost = ItemCost(cur_item) * (10 - scienceRank) / 10;",
                        "//Проверка на доминаторское и клисанское оборудование",
                        "nod_cost = 0;",
                        "if(ItemOwner(cur_item) == Kling)",
                        "{",
                        "    TextCorr2 = '</color>' + CT(\"Script.Mod_EvoSB.116\");",
                        "    TextCorr3 = '</color>' + CT(\"Script.Mod_EvoSB.115\");",
                        "    TextCorr4 = '</color>' + CT(\"Script.Mod_EvoSB.242\") + CT(\"Script.Mod_EvoSB.45\");",
                        "    nod_cost = 1;",
                        "}",
                        "if(EqCustomFaction(cur_item) == 'Klissan')",
                        "{",
                        "    TextCorr2 = '</color>' + CT(\"Script.Mod_EvoSB.241\");",
                        "    TextCorr3 = '</color>' + CT(\"Script.Mod_EvoSB.112\");",
                        "    TextCorr4 = '';",
                        "    nod_cost = 2;",
                        "}",
                        "if(nod_cost) {",
                        "  if(ItemDurability(cur_item) < 26) {",
                        "    DChange(29);",
                        "    exit;",
                        "  }",
                        "  if(ItemDurability(cur_item) >= 26) {",
                        "    DChange(2);",
                        "    exit;",
                        "  }",
                        "}",
                        "if(!nod_cost) {",
                        "  if(ItemDurability(cur_item) < 26) {",
                        "    DChange(29);",
                        "    exit;",
                        "  }",
                        "  if(ItemDurability(cur_item) >= 26) {",
                        "    DChange(10);",
                        "    exit;",
                        "  }",
                        "}"
                    ],
                    "#": 153,
                    "Type": "Top",
                    "Parent": -1,
                    "Pos.x": 430,
                    "Pos.y": 475
                },
                {
                    "Name": "",
                    "Code.Type": "Turn",
                    "Code": [
                        "cur_item = GAnswerData;",
                        "//exlude = 0;",
                        "",
                        "if(ItemType(cur_item) != t_ArtefactTranclucator)",
                        "{",
                        "    ArtTranc = 0;",
                        "    i = EqModule(cur_item);",
                        "    cur_module = CreateMM(i);",
                        "    ModuleToEquipment(-1, cur_item);",
                        "    item_name = DeleteTags(ItemFullName(cur_item));",
                        "    module_name = substr(Name(cur_module), 11);",
                        "    ModuleToEquipment(EqModule(cur_module), cur_item);",
                        "    cost = ItemCost(cur_item) + ItemCost(cur_module);",
                        "}",
                        "else",
                        "{",
                        "    ArtTranc = cur_item;",
                        "    dword tranc_hull = ShipItems(ArtTranclucatorToShip(cur_item), 0);",
                        "    i = EqModule(tranc_hull);",
                        "    cur_module = CreateMM(i);",
                        "    ModuleToEquipment(-1, tranc_hull);",
                        "    item_name = DeleteTags(ItemFullName(cur_item));",
                        "    module_name = substr(Name(cur_module), 11);",
                        "    ModuleToEquipment(EqModule(cur_module), tranc_hull);",
                        "    cost = ItemCost(tranc_hull) + ItemCost(cur_module);",
                        "",
                        "    cur_item = tranc_hull;",
                        "}",
                        "DChange(0);",
                        "exit;"
                    ],
                    "#": 154,
                    "Type": "Top",
                    "Parent": -1,
                    "Pos.x": 610,
                    "Pos.y": 475
                },
                {
                    "Name": "",
                    "Code.Type": "Turn",
                    "Code": [
                        "if(GetGameOptions('FontDialog') == '0') DefSplt = '-------------------------------------------------------------';",
                        "else if(GetGameOptions('FontDialog') == '1') DefSplt = '------------------------------------------';",
                        "else if(GetGameOptions('FontDialog') == '2') DefSplt = '-----------------------------------------';",
                        "else /*if(GetGameOptions('FontDialog') == '3')*/ DefSplt = '-------------------------------------';",
                        "",
                        "if(GAnswerData == 1)",
                        "{",
                        "    //Добавляем стандартный вступительный текст",
                        "    TextCorr1 = '</color>' + CT('FormRuins.SB.Satellite.SBInfo') + CT(\"Script.Mod_EvoSB.45\");",
                        "    //Считаем максимально разрешённое количество зондов у игрока на текущий момент",
                        "    size = ShipSkill(Player(), 'TechnicalCur') + ShipSpecialBonuses(Player(), bonZonds) + 2;",
                        "",
                        "    //Если на станции уже есть инфошка с записанными в неё данными о зонде",
                        "    variable = ShipFindCustomShipInfoByType(cur_ruin, 'RuinsProbeInStock');",
                        "    if(~variable)",
                        "    {",
                        "        //Загружаем описание зонда и подставляем в него информацию о его текущих параметрах",
                        "        tint = ShipCustomShipInfoTextData(cur_ruin, variable, 2);",
                        "        cost = ShipCustomShipInfoTextData(cur_ruin, variable, 3);",
                        "        for(i = 0; i <= 2; i = i + 1)",
                        "        {",
                        "            if(!i)",
                        "            {",
                        "                if(CT('Items.Satellite.' + tint + '.0') == 0 && cost) txtVar0 = '</color>-';",
                        "                else",
                        "                {",
                        "                    if(cost == 0) txtVar0 = 1 + CT('Items.Satellite.' + tint + '.0');",
                        "                    else txtVar0 = CT('Items.Satellite.' + tint + '.0');",
                        "                }",
                        "            }",
                        "            else if(i == 1)",
                        "            {",
                        "                if(CT('Items.Satellite.' + tint + '.1') == 0 && cost != 1) txtVar1 = '</color>-';",
                        "                else",
                        "                {",
                        "                    if(cost == 1) txtVar1 = 1 + CT('Items.Satellite.' + tint + '.1');",
                        "                    else txtVar1 = CT('Items.Satellite.' + tint + '.1');",
                        "                }",
                        "            }",
                        "            else if(i == 2)",
                        "            {",
                        "                if(CT('Items.Satellite.' + tint + '.2') == 0 && cost != 2) txtVar2 = '</color>-';",
                        "                else",
                        "                {",
                        "                    if(cost == 2) txtVar2 = 1 + CT('Items.Satellite.' + tint + '.2');",
                        "                    else txtVar2 = CT('Items.Satellite.' + tint + '.2');",
                        "                }",
                        "            }",
                        "        }",
                        "",
                        "        if(ShipCustomShipInfoData(cur_ruin, variable, 3) == Maloc) tstr4 = CT(\"Script.Mod_EvoSB.252\");",
                        "        if(ShipCustomShipInfoData(cur_ruin, variable, 3) == Peleng) tstr4 = CT(\"Script.Mod_EvoSB.251\");",
                        "        if(ShipCustomShipInfoData(cur_ruin, variable, 3) == People) tstr4 = CT(\"Script.Mod_EvoSB.250\");",
                        "        if(ShipCustomShipInfoData(cur_ruin, variable, 3) == Fei) tstr4 = CT(\"Script.Mod_EvoSB.249\");",
                        "        if(ShipCustomShipInfoData(cur_ruin, variable, 3) == Gaal) tstr4 = CT(\"Script.Mod_EvoSB.248\");",
                        "        if(ShipCustomShipInfoData(cur_ruin, variable, 3) == None) tstr4 = CT(\"Script.Mod_EvoSB.255\");",
                        "        if(ShipCustomShipInfoData(cur_ruin, variable, 3) == Kling) tstr4 = CT(\"Script.Mod_EvoSB.254\");",
                        "        if(ShipCustomShipInfoData(cur_ruin, variable, 3) == PirateClan) tstr4 = CT(\"Script.Mod_EvoSB.253\");",
                        "",
                        "        TextCorr4 = '</color>' + Format(CT('Items.Satellite.' + tint + '.TextDialog'), '<Water'+'>', txtVar0, '<Land'+'>', txtVar1, '<Hill'+'>', txtVar2);",
                        "        //Формируется описание зонда и указатель на максимальное и имеющееся количество",
                        "        TextCorr2 = DefSplt + CT(\"Script.Mod_EvoSB.45\") + Format(CT('FormRuins.SB.Satellite.SBInfo1'), '<SatName'+'>', ShipCustomShipInfoTextData(cur_ruin, variable, 1)) +",
                        "                              CT(\"Script.Mod_EvoSB.45\") + Format(CT('FormRuins.SB.Satellite.SBInfo2'), '<SatText'+'>', TextCorr4) +",
                        "                              CT(\"Script.Mod_EvoSB.45\") + Format(CT('FormRuins.SB.Satellite.SBInfo3'), '<SatMoney'+'>', ShipCustomShipInfoData(cur_ruin, variable, 2)) +",
                        "                              CT(\"Script.Mod_EvoSB.45\") + Format(CT('FormRuins.SB.Satellite.SBInfo4'), '<SatSize'+'>', ShipCustomShipInfoData(cur_ruin, variable, 1)) +",
                        "                              CT(\"Script.Mod_EvoSB.45\") + Format(CT('FormRuins.SB.Satellite.SBInfo5'), '<SatRace'+'>', tstr4) +",
                        "                              CT(\"Script.Mod_EvoSB.45\") + DefSplt;",
                        "",
                        "        //Фраза \"Плачу столько-то за зонд такой-то\"",
                        "        tstr2 = Format(CT('FormRuins.SB.Satellite.PlayerOk'), '<SatMoney'+'>', ShipCustomShipInfoData(cur_ruin, variable, 2), '<SatName'+'>', ShipCustomShipInfoTextData(cur_ruin, variable, 1));",
                        "    }",
                        "    //Если инфошки нет",
                        "    else",
                        "    {",
                        "        //Создаём временный зонд для записи в память базы",
                        "        if(RndObject(1, 1000, cur_ruin) <= (45 * GalaxyTechLevel())) tint = GalaxyTechLevel() - 1;",
                        "        else tint = RndObject(1, GalaxyTechLevel(), cur_ruin) - 1;",
                        "        //С некоторым шансом генерируем уникальные зонды",
                        "        if(GalaxyTechLevel() == 2 || GalaxyTechLevel() == 3) {",
                        "            //Покоритель",
                        "            if(!Rnd(-1,1)) tint = 11;",
                        "        }",
                        "        else if(GalaxyTechLevel() == 4 || GalaxyTechLevel() == 5) {",
                        "            //Исследователь",
                        "            if(!Rnd(0,1)) tint = 12;",
                        "            //Покоритель",
                        "            else if(!Rnd(-1,2)) tint = 11;",
                        "        }",
                        "        else if(GalaxyTechLevel() == 8) {",
                        "            //Кочевник",
                        "            if(!Rnd(-4,1)) tint = 8;",
                        "            //Отшельник",
                        "            else if(!Rnd(-4,1)) tint = 9;",
                        "            //Наутилус",
                        "            else if(!Rnd(-4,1)) tint = 10;",
                        "            //Исследователь",
                        "            else if(!Rnd(0,3)) tint = 12;",
                        "            //Покоритель",
                        "            else if(!Rnd(-1,4)) tint = 11;",
                        "        }",
                        "        else if(GalaxyTechLevel() != 1) {",
                        "            //Исследователь",
                        "            if(!Rnd(0,2)) tint = 12;",
                        "            //Покоритель",
                        "            else if(!Rnd(-1,3)) tint = 11;",
                        "        }",
                        "",
                        "        cur_item = CreateZond(tint, RndObject(0, 4, cur_ruin));",
                        "        if(tint > 8) ItemCost(cur_item,ItemCost(cur_item)*3);",
                        "",
                        "",
                        "        //Определяем, к какому конкретно параметру зонд получил бонус (и получил ли его вообще)",
                        "        cost = -1;",
                        "        for(i = 0; i <= 2; i = i + 1)",
                        "        {",
                        "            if(GetEquipmentStats(cur_item, i) != CT('Items.Satellite.' + tint + '.' + i))",
                        "            {",
                        "                cost = i;",
                        "                break;",
                        "            }",
                        "        }",
                        "",
                        "        //Загружаем описание зонда и подставляем в него информацию о его текущих параметрах",
                        "        for(i = 0; i <= 2; i = i + 1)",
                        "        {",
                        "            if(i == 0)",
                        "            {",
                        "                if(CT('Items.Satellite.' + tint + '.0') == 0 && cost) txtVar0 = '</color>-';",
                        "                else",
                        "                {",
                        "                    if(!cost) txtVar0 = 1 + CT('Items.Satellite.' + tint + '.0');",
                        "                    else txtVar0 = CT('Items.Satellite.' + tint + '.0');",
                        "                }",
                        "            }",
                        "            else if(i == 1)",
                        "            {",
                        "                if(CT('Items.Satellite.'+tint+'.1') == 0 && cost != 1) txtVar1 = '</color>-';",
                        "                else",
                        "                {",
                        "                    if(cost == 1) txtVar1 = 1 + CT('Items.Satellite.' + tint + '.1');",
                        "                    else txtVar1 = CT('Items.Satellite.' + tint + '.1');",
                        "                }",
                        "            }",
                        "            else if(i == 2)",
                        "            {",
                        "                if(CT('Items.Satellite.'+tint+'.2') == 0 && cost != 2)",
                        "                {",
                        "                    txtVar2='</color>-';",
                        "                }",
                        "                else",
                        "                {",
                        "                    if(cost == 2) txtVar2 = 1 + CT('Items.Satellite.' + tint + '.2');",
                        "                    else txtVar2 = CT('Items.Satellite.' + tint + '.2');",
                        "                }",
                        "            }",
                        "        }",
                        "",
                        "        if(ItemOwner(cur_item) == Maloc) tstr4 = CT(\"Script.Mod_EvoSB.252\");",
                        "        if(ItemOwner(cur_item) == Peleng) tstr4 = CT(\"Script.Mod_EvoSB.251\");",
                        "        if(ItemOwner(cur_item) == People) tstr4 = CT(\"Script.Mod_EvoSB.250\");",
                        "        if(ItemOwner(cur_item) == Fei) tstr4 = CT(\"Script.Mod_EvoSB.249\");",
                        "        if(ItemOwner(cur_item) == Gaal) tstr4 = CT(\"Script.Mod_EvoSB.248\");",
                        "        if(ItemOwner(cur_item) == None) tstr4 = CT(\"Script.Mod_EvoSB.255\");",
                        "        if(ItemOwner(cur_item) == Kling) tstr4 = CT(\"Script.Mod_EvoSB.254\");",
                        "        if(ItemOwner(cur_item) == PirateClan) tstr4 = CT(\"Script.Mod_EvoSB.253\");",
                        "",
