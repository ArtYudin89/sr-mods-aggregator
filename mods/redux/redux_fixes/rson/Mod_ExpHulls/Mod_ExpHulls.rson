                        "  DAdd(15);",
                        "}",
                        "if(ShipMoney(Player())>=cost_variation[0] && (GetNodesFromShip(Player())+GetNodesFromStorage(GetShipRuins(Player())))>=nod_cost_variation[0]) {",
                        "  DAdd(6);",
                        "}",
                        "if(ShipMoney(Player())<cost_variation[1] || (GetNodesFromShip(Player())+GetNodesFromStorage(GetShipRuins(Player())))<nod_cost_variation[1]) {",
                        "  DAdd(13);",
                        "}",
                        "if(ShipMoney(Player())>=cost_variation[1] && (GetNodesFromShip(Player())+GetNodesFromStorage(GetShipRuins(Player())))>=nod_cost_variation[1]) {",
                        "  DAdd(7);",
                        "}",
                        "if(ShipMoney(Player())<cost_variation[2] || (GetNodesFromShip(Player())+GetNodesFromStorage(GetShipRuins(Player())))<nod_cost_variation[2]) {",
                        "  DAdd(14);",
                        "}",
                        "if(ShipMoney(Player())>=cost_variation[2] && (GetNodesFromShip(Player())+GetNodesFromStorage(GetShipRuins(Player())))>=nod_cost_variation[2]) {",
                        "  DAdd(8);",
                        "}",
                        "InjectAnswer('ExitSB',CT('FormRuins.WB.BuyHull.PlayerNoAnswer'),-1);"
