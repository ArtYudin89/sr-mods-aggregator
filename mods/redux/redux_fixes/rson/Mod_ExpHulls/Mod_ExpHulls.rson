            "Items": [],
            "Operations": [
                {
                    "Name": "",
                    "Code.Type": "Global",
                    "Code": [
                        "GRun();"
                    ],
                    "#": 23,
                    "Type": "Top",
                    "Parent": -1,
                    "Pos.x": 0,
                    "Pos.y": 635
                },
                {
                    "Name": "",
                    "Code.Type": "Init",
                    "Code": [
                        "basic_size_variation = newarray(3);",
                        "size_variation = newarray(3);",
                        "cost_variation = newarray(3);",
                        "nod_cost_variation = newarray(3);",
                        "SB_countdown = Rnd(350,450 + GalaxyDiffLevels(2)) + 300;",
                        "PB_countdown = Rnd(350,450 + GalaxyDiffLevels(0)) + 300;",
                        "MB_countdown = Rnd(350,450 + GalaxyDiffLevels()) + 300;"
                    ],
                    "#": 24,
                    "Type": "Top",
                    "Parent": -1,
                    "Pos.x": 60,
                    "Pos.y": 635
                },
                {
                    "Name": "",
                    "Code.Type": "Turn",
                    "Code": [
                        "if(SB_countdown > 0) SB_countdown = SB_countdown - 1;",
                        "if(PB_countdown > 0) PB_countdown = PB_countdown - 1;",
                        "if(MB_countdown > 0) MB_countdown = MB_countdown - 1;"
                    ],
                    "#": 25,
                    "Type": "Top",
                    "Parent": -1,
                    "Pos.x": 120,
                    "Pos.y": 635
                },
                {
                    "Name": "",
                    "Code.Type": "DialogBegin",
                    "Code": [
                        "if(!PlayerBridge())",
                        "{",
                        "    cur_ruin = GetShipRuins(Player());",
                        "",
                        "    if(cur_ruin)",
                        "    {",
                        "        temp_str = ShipType(cur_ruin);",
                        "",
                        "        //Диалог на научной базе",
                        "        if(temp_str == 'SB')",
                        "        {",
                        "            if(SB_countdown <= CurTurn())",
                        "            {",
                        "                if(GalaxyTechLevel() > 3)",
                        "                {",
                        "                    if(!CurrentMods('Expansion\\\\ExpHulls')) {",
                        "                        if(GalaxyTechLevel() > 7) bonus_name = GetParFromString(BonusName(FindBonusByNameInCfg('ExpHulls_Bolide5')), CT('FormInfo.DoubleQuote'), 1, 1);",
                        "                        else bonus_name = GetParFromString(BonusName(FindBonusByNameInCfg('ExpHulls_Bolide1')), CT('FormInfo.DoubleQuote'), 1, 1);",
                        "                        AddDialogBlock(CT('FormRuins.SB.SpecialShip.Ask'), 2);",
                        "                        AddDialogInject('RBK_Dialog_SB',Format(CT('FormRuins.'+temp_str+'.BuyHull.DialogStart'),'bonus',bonus_name), Format(CT('FormRuins.'+temp_str+'.BuyHull.PlayerAsk'),'bonus',bonus_name), 0);",
                        "                    }",
                        "                    else if(PlayerScienceRank['CurrentRank'] > 1) {",
                        "                        if(GalaxyTechLevel() > 7) bonus_name = GetParFromString(BonusName(FindBonusByNameInCfg('ExpHulls_Bolide5')), CT('FormInfo.DoubleQuote'), 1, 1);",
                        "                        else bonus_name = GetParFromString(BonusName(FindBonusByNameInCfg('ExpHulls_Bolide1')), CT('FormInfo.DoubleQuote'), 1, 1);",
                        "                        AddDialogBlock(CT('FormRuins.SB.SpecialShip.Ask'), 2);",
                        "                        AddDialogInject('RBK_Dialog_SB',Format(CT('FormRuins.'+temp_str+'.BuyHull.DialogStart'),'bonus',bonus_name), Format(CT('FormRuins.'+temp_str+'.BuyHull.PlayerAsk'),'bonus',bonus_name), 0);",
                        "                    }",
                        "                }",
                        "            }",
                        "        }",
                        "        //Диалог на пиратской базе",
                        "        else if(temp_str == 'PB')",
                        "        {",
                        "            if(PB_countdown <= CurTurn())",
                        "            {",
                        "                if(GetShipPirateRank(Player()) > 2)",
                        "                {",
                        "                    if(GetShipPirateRank(Player()) > 6) bonus_name = GetParFromString(BonusName(FindBonusByNameInCfg('ExpHulls_Killer5')), CT('FormInfo.DoubleQuote'), 1, 1);",
                        "                    else bonus_name = GetParFromString(BonusName(FindBonusByNameInCfg('ExpHulls_Killer1')), CT('FormInfo.DoubleQuote'), 1, 1);",
                        "                    AddDialogBlock(CT('FormRuins.PB.SpecialShip.Ask'), 2);",
                        "                    AddDialogInject('RBK_Dialog_PB', Format(CT('FormRuins.'+temp_str+'.BuyHull.DialogStart'),'bonus',bonus_name), Format(CT('FormRuins.'+temp_str+'.BuyHull.PlayerAsk'),'bonus',bonus_name), 0);",
                        "                }",
                        "            }",
                        "        }",
                        "        //Диалог на военной базе",
                        "        else if(temp_str == 'WB')",
                        "        {",
                        "            if(MB_countdown <= CurTurn())",
                        "            {",
                        "                if(ShipRank(Player()) > 2)",
                        "                {",
                        "                    if(ShipRank(Player()) > 6) bonus_name = GetParFromString(BonusName(FindBonusByNameInCfg('ExpHulls_Rock5')), CT('FormInfo.DoubleQuote'), 1, 1);",
                        "                    else bonus_name = GetParFromString(BonusName(FindBonusByNameInCfg('ExpHulls_Rock1')), CT('FormInfo.DoubleQuote'), 1, 1);",
                        "                    AddDialogBlock(CT('FormRuins.WB.SpecialShip.Ask'), 2);",
                        "                    AddDialogInject('RBK_Dialog_WB', Format(CT('FormRuins.'+temp_str+'.BuyHull.DialogStart'),'bonus',bonus_name), Format(CT('FormRuins.'+temp_str+'.BuyHull.PlayerAsk'),'bonus',bonus_name), 0);",
                        "                }",
                        "            }",
                        "        }",
                        "    }",
                        "}"
                    ],
                    "#": 26,
                    "Type": "Top",
                    "Parent": -1,
                    "Pos.x": 180,
                    "Pos.y": 635
                },
                {
                    "Name": "",
                    "Code.Type": "Turn",
                    "Code": [
                        "if(ShipRank(Player()) == 3) bonus_type = FindBonusByNameInCfg('ExpHulls_Rock1');",
                        "else if(ShipRank(Player()) == 4) bonus_type = FindBonusByNameInCfg('ExpHulls_Rock2');",
                        "else if(ShipRank(Player()) == 5) bonus_type = FindBonusByNameInCfg('ExpHulls_Rock3');",
                        "else if(ShipRank(Player()) == 6) bonus_type = FindBonusByNameInCfg('ExpHulls_Rock4');",
                        "else if(ShipRank(Player()) >= 7) bonus_type = FindBonusByNameInCfg('ExpHulls_Rock5');",
                        "",
                        "i=0;",
                        "while(i < 3)",
                        "{",
                        "    temp_hull = CreateHull(2, 100 + (100 + 25 * i) * GalaxyTechLevel(), GalaxyTechLevel(), 2);",
                        "    basic_size_variation[i] = ItemSize(temp_hull);",
                        "    if(bonus_type > -1)SpecialToEquipment(bonus_type, temp_hull);",
                        "    //ItemCost(temp_hull, ItemCost(temp_hull) / 2);",
                        "    cost_variation[i] = ItemCost(temp_hull);",
                        "    size_variation[i] = ItemSize(temp_hull);",
                        "    FreeItem(temp_hull);",
                        "    i = i + 1;",
                        "}",
                        "if(GetGameOptions('FontDialog') == 0) DefSplt = '</color>-------------------------------------------------------------';",
                        "else if(GetGameOptions('FontDialog') == 1) DefSplt = '</color>------------------------------------------';",
                        "else if(GetGameOptions('FontDialog') == 2) DefSplt = '</color>-----------------------------------------';",
                        "else DefSplt = '</color>-------------------------------------';",
                        "",
                        "temp_str = GetParFromString(BonusName(bonus_type), CT('FormInfo.DoubleQuote'), 1, 1) + GetParFromString(BonusName(bonus_type), CT('FormInfo.DoubleQuote'), 2, 0);",
                        "temp_str = '</color>' + Format(CT(\"Script.Mod_ExpHulls.120\"),\"<0>\",temp_str,\"<1>\",DefSplt)+BonusText(bonus_type) + Format(CT(\"Script.Mod_ExpHulls.110\"),\"<0>\",size_variation[0],\"<1>\",cost_variation[0],\"<2>\",size_variation[1],\"<3>\",cost_variation[1],\"<4>\",size_variation[2],\"<5>\",cost_variation[2],\"<6>\",DefSplt);",
                        "DChange(0);",
                        "exit;"
                    ],
                    "#": 67,
                    "Type": "Top",
                    "Parent": -1,
                    "Pos.x": -20,
                    "Pos.y": 400
                },
                {
                    "Name": "",
                    "Code.Type": "Turn",
                    "Code": [
                        "if(GalaxyTechLevel() == 4 && PlayerScienceRank['CurrentRank'] > 1) bonus_type = FindBonusByNameInCfg('ExpHulls_Bolide1');",
                        "else if(GalaxyTechLevel() == 5 && PlayerScienceRank['CurrentRank'] > 1) bonus_type = FindBonusByNameInCfg('ExpHulls_Bolide2');",
                        "else if(GalaxyTechLevel() == 6 && PlayerScienceRank['CurrentRank'] > 2) bonus_type = FindBonusByNameInCfg('ExpHulls_Bolide3');",
                        "else if(GalaxyTechLevel() == 7 && PlayerScienceRank['CurrentRank'] > 2) bonus_type = FindBonusByNameInCfg('ExpHulls_Bolide4');",
                        "else if(GalaxyTechLevel() >= 8 && PlayerScienceRank['CurrentRank'] > 3) bonus_type = FindBonusByNameInCfg('ExpHulls_Bolide5');",
                        "",
                        "i = 0;",
                        "while(i < 3)",
                        "{",
                        "    temp_hull = CreateHull(2, 100 + (100 + 25 * i) * GalaxyTechLevel(), GalaxyTechLevel(), 2);",
                        "    basic_size_variation[i] = ItemSize(temp_hull);",
                        "    if(bonus_type > -1)SpecialToEquipment(bonus_type, temp_hull);",
                        "    //ItemCost(temp_hull, ItemCost(temp_hull) / 2);",
                        "    cost_variation[i] = ItemCost(temp_hull);",
                        "    size_variation[i] = ItemSize(temp_hull);",
                        "    nod_cost_variation[i] = size_variation[i] * GalaxyTechLevel() * GalaxyTechLevel() / 40;",
                        "    FreeItem(temp_hull);",
                        "    i = i + 1;",
                        "}",
                        "if(GetGameOptions('FontDialog') == 0) DefSplt = '</color>-------------------------------------------------------------';",
                        "else if(GetGameOptions('FontDialog') == 1) DefSplt = '</color>------------------------------------------';",
                        "else if(GetGameOptions('FontDialog') == 2) DefSplt = '</color>-----------------------------------------';",
                        "else DefSplt = '</color>-------------------------------------';",
                        "",
                        "temp_str = GetParFromString(BonusName(bonus_type), CT('FormInfo.DoubleQuote'), 1, 1) + GetParFromString(BonusName(bonus_type), CT('FormInfo.DoubleQuote'), 2, 0);",
                        "temp_str = '</color>' + Format(CT(\"Script.Mod_ExpHulls.121\"),\"<0>\",temp_str,\"<1>\",DefSplt)+BonusText(bonus_type) + Format(CT(\"Script.Mod_ExpHulls.123\"),\"<0>\",size_variation[0],\"<1>\",cost_variation[0],\"<2>\",nod_cost_variation[0],\"<3>\",size_variation[1],\"<4>\",cost_variation[1],\"<5>\",nod_cost_variation[1],\"<6>\",size_variation[2],\"<7>\",cost_variation[2],\"<8>\",nod_cost_variation[2],\"<9>\",DefSplt);",
                        "nod_type = 0;",
                        "DChange(3);",
                        "exit;"
                    ],
