                {
                    "Name": "",
                    "Code.Type": "Turn",
                    "Code": [
                        "if(!ShipInNormalSpace(CurShip) || GetShipPlanet(CurShip) || GetShipRuins(CurShip)) ShipIsTakeoff(CurShip);",
                        "else {",
                        "    //Лидер пошёл воевать",
                        "    if(GroupCount(MercCenter)) {",
                        "        if(ShipInStar(CurShip,ShipStar(GroupToShip(MercCenter)))) {",
                        "            tint1 = 0;",
                        "            //Считаем враждебные лидеру корабли",
                        "            for(i=0;StarShips(ShipStar(CurShip))>i;i=i+1) {",
                        "                if(RelationToShip(CurShip,StarShips(ShipStar(CurShip),i)) < 10) tint1 = tint1 + 1;",
                        "            }",
                        "",
                        "            //Лидерам не кайф воевать за то, что их не касается, поэтому, если дело пахнет керосином, драпают",
                        "            if(HullDamage(CurShip) > 30 || tint1 > 25) {",
                        "                //Чтобы точно не дали прикурить, включаем ребятам форсаж",
                        "                if(ItemDurability(ShipEqInSlot(CurShip,t_Engine)) > 20) OrderForsage(CurShip,1);",
