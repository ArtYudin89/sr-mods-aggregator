                        "        tstr3 = '</color>' + CT('Talk.'+path+'.PlayerNotMoney'+int(Rnd(1,9)));",
                        "    }",
                        "    else {",
                        "        tstr3 = '</color>' + CT('Talk.'+path+'.PlayerOk'+int(Rnd(1,7)));",
                        "    }",
                        "    //Диалог посылания",
                        "    if(Dist(Player(),cur_ship) <= 1500) {",
                        "        tstr2 = '</color>' + CT('Talk.'+path+'.PlayerNo'+int(Rnd(1,7)));",
                        "    }",
                        "    else {",
                        "        tstr2 = '</color>' + CT('Talk.'+path+'.PlayerLongDistance'+int(Rnd(1,8)));",
                        "    }",
                        "}",
                        "else {",
                        "    tint2 = 0;",
                        "    if(GoodsCount(Player(),t_Alcohol)) tint2 = 1;",
                        "    if(GoodsCount(Player(),t_Arms)) tint2 = 1;",
                        "    if(GoodsCount(Player(),t_Minerals)) tint2 = 1;",
                        "    if(GoodsCount(Player(),t_Food)) tint2 = 1;",
                        "    if(GoodsCount(Player(),t_Narcotics)) tint2 = 1;",
                        "    if(GoodsCount(Player(),t_Luxury)) tint2 = 1;",
                        "    if(GoodsCount(Player(),t_Medicine)) tint2 = 1;",
                        "",
                        "    if(tint2) {",
                        "        tstr3 = '</color>' + CT('Talk.'+path+'.PlayerOk'+int(Rnd(1,4)));",
                        "    }",
                        "    else {",
                        "        tstr3 = '</color>' + CT('Talk.'+path+'.PlayerNotGoods'+int(Rnd(1,4)));",
                        "    }",
                        "    //Диалог посылания",
                        "    if(Dist(Player(),cur_ship) <= 1500) {",
                        "        tstr2 = '</color>' + CT('Talk.'+path+'.PlayerNo'+int(Rnd(1,4)));",
                        "    }",
                        "    else {",
                        "        tstr2 = '</color>' + CT('Talk.'+path+'.PlayerLongDistance'+int(Rnd(1,4)));",
                        "    }",
                        "}",
                        "DChange(67);",
                        "exit;"
