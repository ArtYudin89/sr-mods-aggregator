                        "                RelationToRanger(CurShip, GroupToShip(RedAxesLeader), MercOrganisationsData['Atlant', 'RelationToRedAxes']);",
                        "                SetRelationGroup(AtlantLeader, RedAxesMercs, (MercOrganisationsData['Atlant', 'RelationToRedAxes'] + 15) / 25);",
                        "            }",
