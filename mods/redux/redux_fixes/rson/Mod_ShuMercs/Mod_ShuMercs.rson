                        "    }",
                        "    else if(cur_org == AtlantMercs)",
                        "    {",
                        "        coef2 = 200;",
                        "        tstr5 = CT(\"Script.Mod_ShuMercs.113\");",
                        "    }",
                        "    else if(cur_org == FaeyangelionMercs)",
                        "    {",
                        "        coef2 = 450;",
                        "        tstr5 = CT(\"Script.Mod_ShuMercs.111\");",
                        "    }",
                        "}",
                        "else coef2 = 300;",
                        "",
                        "tstr2 = '</color>' + CT('Talk.Exit');",
                        "if(HullDamage(cur_ship) > 50 &&",
                        "RelationToRanger(cur_ship, Player()) > 25 &&",
                        "ShipGetBad(cur_ship) != Player()) {",
                        "  DChange(8);",
                        "  exit;",
                        "}",
                        "if(HullDamage(cur_ship) <= 50 &&",
                        "ShipOrder(cur_ship) == 6 &&",
                        "RelationToRanger(cur_ship, Player()) > 25 &&",
                        "ShipGetBad(cur_ship) != Player()) {",
                        "  DChange(9);",
                        "  exit;",
                        "}",
                        "if(HullDamage(cur_ship) <= 50 &&",
                        "ShipOrder(cur_ship) != 6 &&",
                        "RelationToRanger(cur_ship, Player()) > 25 &&",
                        "ShipGetBad(cur_ship) != Player()) {",
                        "  DChange(10);",
                        "  exit;",
                        "}",
                        "if(RelationToRanger(cur_ship, Player()) <= 25 ||",
                        "ShipGetBad(cur_ship) == Player()) {",
                        "  DChange(11);",
                        "  exit;",
                        "}"
