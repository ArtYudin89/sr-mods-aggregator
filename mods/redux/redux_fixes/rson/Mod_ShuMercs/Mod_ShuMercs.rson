                    "Name": "",
                    "Code.Type": "Turn",
                    "Code": [
                        "rand=GAnswerData;",
                        "tint3=ShipMoney(Player());",
                        "//Добавляем ответы с количеством доступных сессий, число которых можно провести для улучшения выбранного навыка",
                        "for(i=1; i<=6; i=i+1)",
                        "{",
                        "    if(i == 1)tstr1=CT(\"Script.Mod_ShuMercs.166\");",
                        "    else if(i == 2)tstr1=CT(\"Script.Mod_ShuMercs.167\");",
                        "    else if(i == 3)tstr1=CT(\"Script.Mod_ShuMercs.127\");",
                        "    else if(i == 4)tstr1=CT(\"Script.Mod_ShuMercs.128\");",
                        "    else if(i == 5)tstr1=CT(\"Script.Mod_ShuMercs.129\");",
                        "    else if(i == 6)tstr1=CT(\"Script.Mod_ShuMercs.130\");",
                        "",
                        "    if(tint3 < cost*i)                           AddDialogBlock(tstr1, 1);",
                        "    else if(ShipSkill(cur_ship, rand) > (6-i))   AddDialogBlock(tstr1, 1);",
                        "    //else if(tint2 > (6-i))                     AddDialogBlock(tstr1, 1);",
                        "",
                        "    InjectAnswer('TrainMBAct', tstr1, i);",
                        "}",
                        "DAdd(54);"
