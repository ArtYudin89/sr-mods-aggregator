                        "        tstr1 = tstr1 + Format(CT('Script.Mod_ShuMercs.' + dialogs_path + '.OrganisationsListItem'),",
                        "                          '<OrgName'+'>', MercOrganisationsData['Atlant', 'OrganisationName'],",
                        "                          '<OrgRelation'+'>', MercOrganisationsData['Atlant', 'RelationToPlayer'],",
                        "                          '');",
                        "    }",
