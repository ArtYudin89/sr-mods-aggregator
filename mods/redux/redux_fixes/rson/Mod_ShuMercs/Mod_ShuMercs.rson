                        "        tstr1 = tstr1 + Format(CT('Script.Mod_ShuMercs.' + dialogs_path + '.OrganisationsListItem'),",
                        "                          '<OrgName'+'>', MercOrganisationsData['Faeyangelion', 'OrganisationName'],",
                        "                          '<OrgRelation'+'>', MercOrganisationsData['Faeyangelion', 'RelationToPlayer'],",
