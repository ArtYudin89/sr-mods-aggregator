                {
                    "Name": "",
                    "Code.Type": "Turn",
                    "Code": [
                        "MercOrganisationsData['NegotiationsInProgress'] = 2;",
                        "ChangeState('LeaderReturning', cur_ship);",
                        "",
                        "NoTalkToShip(cur_ship, 1);",
                        "TruceBetweenShips(cur_ship, Player());",
