            "Operations": [
                {
                    "Name": "",
                    "Code.Type": "Global",
                    "Code": [
                        "//"
                    ],
                    "#": 34,
                    "Type": "Top",
                    "Parent": -1,
                    "Pos.x": 0,
                    "Pos.y": 1085
                },
                {
                    "Name": "",
                    "Code.Type": "Init",
                    "Code": [
                        "ShipAddCustomShipInfo(Player(),'InfoNomer1','NoShow');",
                        "ShipAddCustomShipInfo(Player(),'InfoNomer2','NoShow');",
                        "ShipAddCustomShipInfo(Player(),'InfoNomer4','NoShow');",
                        "ShipAddCustomShipInfo(Player(),'InfoNomer5','NoShow');",
                        "InventManualCustomGuns();",
                        "gunUpdateCheck = CT('Items.Weapon.CustomWeapon.StatsVersion.ManualGuns');",
                        "",
                        "//",
                        "r = Rnd(0, 4);",
                        "for(n = 1; n <= r; n = n + 1)",
                        "{",
                        "\tif(Rnd(0, 1)) tdwd = CreateCustomWeapon('manual_gun', Rnd(160/2, 160*2), Rnd(1, 5), Peleng);",
                        "\telse tdwd = CreateCustomWeapon('manual_gun2', Rnd(180/2, 180*2), Rnd(1, 5), People);",
                        "\tArrayAdd(tarr1, tdwd);",
                        "}",
                        "//Разбрасываем добавленные в массив орудия по незаселёнкам",
                        "while(ArrayDim(tarr1) > 1)",
                        "{",
                        "    while(1)",
                        "    {",
                        "        //Выбираем случайную систему, с исключением Тортугаца и Нифигаца, а также родой системы игрока",
                        "        cur_star = GalaxyStar(Rnd(0, GalaxyStars() - 1));",
                        "        if(StarToCon(cur_star) == StarToCon(PlanetToStar(PlanetPirateClan()))) continue;",
                        "        if(cur_star == PlanetToStar(GetShipHomePlanet(Player()))) continue;",
                        "        //Перебираем все планеты системы, ищем случайную незаселёнку",
                        "        i = 0;",
                        "        cur_planet = StarPlanets(cur_star, Rnd(0, StarPlanets(cur_star) - 1));",
                        "        while(PlanetOwner(cur_planet) != 6 || i < 30)",
                        "        {",
                        "            cur_planet = StarPlanets(cur_star, Rnd(0, StarPlanets(cur_star) - 1));",
                        "            i = i + 1;",
                        "        }",
                        "        break;",
                        "    }",
                        "    if(PlanetOwner(cur_planet) != 6) continue;",
                        "    //Добавляем на неё случайную пушку из массива",
                        "    r = Rnd(1, ArrayDim(tarr1) - 1);",
                        "    //Пушка добавляется уже будучи изношенной",
                        "    ItemDurability(tarr1[r], Rnd(0, 87));",
                        "    AddItemToPlanet(cur_planet, tarr1[r]);",
                        "    ArrayDelete(tarr1, r);",
                        "}",
                        "",
                        "//Функция для объявления и обновления кастомных орудий",
                        "function InventManualCustomGuns()",
                        "{",
                        "    //поясняю структуру цикла:",
                        "    //i = 1 означает, что переменная в цикле начинает со значения 1",
                        "    //i <= CT('Items.Weapon.CustomWeapon.ManualGuns.Count') означает, что переменная будет расти до тех пор,",
                        "    //пока не достигнет вот этого значения, стоящего после <=",
                        "    //i = i + 1 означает, что с каждым исполнением цикла переменная i возрастает на 1",
                        "    for(i = 1; i <= CT('Items.Weapon.CustomWeapon.ManualGuns.Count'); i = i + 1)",
                        "    {",
                        "        //По очереди выбираем системное название каждой новой пушки из Lang",
                        "        tstr = CT('Items.Weapon.CustomWeapon.ManualGuns.' + i);",
                        "        tstr2 = 'Items.Weapon.CustomWeapon.';",
                        "        //Прописываем пушку/сбрасываем уже прописанную пушку до уровня базовой из оригинальной игры",
                        "        tdwd = InventNewCustomWeapon(tstr, t_Weapon1 - 1 + CT('Items.Weapon.OriginalWeaponType.' + CT(tstr2 + tstr + '.BaseGun')));",
                        "        //Задаём характеристики оружия",
                        "        SetCustomWeaponShotData(tdwd, CT(tstr2 + tstr + '.ShotType'), CT(tstr2 + tstr + '.Speed'), CT(tstr2 + tstr + '.AverageRadius'), CT(tstr2 + tstr + '.SecondaryDamageRadius'), CT(tstr2 + tstr + '.MiningFactor'), CT(tstr2 + tstr + '.ShotsPerTurn'));",
                        "        SetCustomWeaponDamageData(tdwd, CT(tstr2 + tstr + '.MinDamage'), CT(tstr2 + tstr + '.MaxDamage'), CT(tstr2 + tstr + '.DamageSet'), CT(tstr2 + tstr + '.mWeaponDamage'));",
                        "        SetCustomMissileWeaponStats(tdwd, CT(tstr2 + tstr + '.MissileRadius'), CT(tstr2 + tstr + '.MissileMaxSpeed'), CT(tstr2 + tstr + '.MissileMinSpeed'), CT(tstr2 + tstr + '.MissileChanceToBeHit'));",
                        "        SetCustomWeaponPrimaryData(tdwd, CT(tstr2 + tstr + '.TechLevel'), t_Weapon1 - 1 + CT('Items.Weapon.OriginalWeaponType.' + CT(tstr2 + tstr + '.InventTechLevel')), t_Weapon1 - 1 + CT('Items.Weapon.OriginalWeaponType.' + CT(tstr2 + tstr + '.ArcadeType')));",
                        "        SetCustomWeaponSizeAndCost(tdwd, CT(tstr2 + tstr + '.kCost'), CT(tstr2 + tstr + '.AverageSize'));",
                        "        SetCustomWeaponAvailability(tdwd, CT(tstr2 + tstr + '.StoreAvailability'));",
                        "        SetCustomWeaponSE(tdwd, CT(tstr2 + tstr + '.ShotEffectPath'), CT(tstr2 + tstr + '.SplashEffectPath'), CT(tstr2 + tstr + '.MissileExplosionEffectPath'), CT(tstr2 + tstr + '.ShotEffectPalette'));",
                        "    }",
                        "}"
                    ],
                    "#": 35,
                    "Type": "Top",
                    "Parent": -1,
                    "Pos.x": 60,
                    "Pos.y": 1085
                },
                {
                    "Name": "",
                    "Code.Type": "Turn",
                    "Code": [
                        "if(preparation_complete && (!keller_arrived || ((keller_arrived+5)>CurTurn())) && GroupCount(GroupKeller)) {",
                        "  quest_star=GalaxyStar(research_location-1);",
                        "  counter=0;",
                        "  while (counter<StarShips(quest_star)){",
                        "  quest_ship=StarShips(quest_star,counter);",
                        "  if (ShipInNormalSpace(quest_ship)){",
                        "  if (ShipTypeN(quest_ship)==t_Pirate){",
                        "  if (!ShipInScript(quest_ship)){",
                        "  if (ShipIsPartner(quest_ship)!=Player()){",
                        "  OrderJump(quest_ship,PlanetToStar(PlanetPirateClan()),1);",
                        "  OrderLock(quest_ship,1);",
                        "  ShipJoin(GroupRetreatingPirates,quest_ship);",
                        "  }}}}",
                        "  counter=counter+1;}",
                        "  if(ShipInNormalSpace(GroupToShip(GroupKeller)) && !keller_arrived ) {",
                        "    if(Id(ShipStar(GroupToShip(GroupKeller)))==research_location) {",
                        "      keller_arrived=CurTurn();",
                        "      keller_new_research=2;",
                        "    }",
                        "  }",
                        "}",
                        "if((keller_new_research==2) && ((keller_arrived+30)<=CurTurn())) {",
                        "  keller_new_research=3;",
                        "  Ether(0,'30047634-2E59-4C49-9CBE-7329755DEB43',Format(CT(\"Script.MS_Keller.138\"),\"<0>\",Name(GalaxyStar(research_location-1))));",
                        "}",
                        "if(!ShipIsTakeoff(Player())) {",
                        "  if(gunUpdateCheck != CT('Items.Weapon.CustomWeapon.StatsVersion.ManualGuns'))",
                        "  {",
                        "      InventManualCustomGuns();",
                        "      gunUpdateCheck = CT('Items.Weapon.CustomWeapon.StatsVersion.ManualGuns');",
                        "  }",
                        "}"
                    ],
                    "#": 36,
                    "Type": "Top",
                    "Parent": -1,
                    "Pos.x": 120,
                    "Pos.y": 1085
                },
                {
                    "Name": "",
                    "Code.Type": "DialogBegin",
                    "Code": [
                        "if(GetShipPlanet(Player()) && research_location && !preparation_complete) {",
                        "  if(Id(PlanetToStar(GetShipPlanet(Player())))==research_location) {",
                        "    if(PlanetOwner(GetShipPlanet(Player()))!=6) {",
                        "      AddDialogInject('DialogPrepare','',CT(\"Script.MS_Keller.178\"),1);",
                        "    }",
                        "  }",
                        "}",
                        "if(GetShipRuins(Player())>0) {",
                        "  if(ShipType(GetShipRuins(Player()))=='RC' && ShipMoney(Player())>1000000 && ShipRank(Player())>4 && !RangerStatus(Player(1,CT(\"Script.MS_Keller.297\"))) && Talk_to_Kurator == 0) {",
                        "    AddDialogOverride('Dialogue_with_the_curator',1);",
                        "    GotoGov(2);",
                        "  }",
                        "  if(ShipType(GetShipRuins(Player()))=='RC' && !RangerStatus(Player(1,CT(\"Script.MS_Keller.297\"))) && Talk_to_Kurator == 2) {",
                        "    AddDialogInject('Dialogue_with_the_curator2','',CT(\"Script.MS_Keller.281\"),1);",
                        "  }",
                        "}",
                        "if(GetShipRuins(Player())>0) {",
                        "  if(ShipType(GetShipRuins(Player()))=='RC') {",
                        "    AddDialogInject('Test_Dialogue','',CT(\"Script.MS_Keller.309\"),1);",
                        "  }",
                        "}",
                        "if (PlayerBridge() == 1 && Int_for_Keller_Krinator == 1 && Star_Destroyer_Krinator_Dialogue == 0 && Udalenie_Keller_Krinator_for_Star_Destroyer == 0)",
                        "{",
                        "    AddDialogInject('StarDestroyerUpgradeMM', '', CT(\"Script.MS_Keller.319\"), 2);",
                        "}",
                        "if (PlayerBridge() == 1 && Int_for_Keller_Krinator == 2 && Star_Destroyer_Krinator_Dialogue == 0 && Udalenie_Keller_Krinator_for_Star_Destroyer == 0)",
                        "{",
                        "    AddDialogInject('StarDestroyerUpgradeMM', '', CT(\"Script.MS_Keller.326\"), 2);",
                        "}",
                        "if (PlayerBridge() == 1 && EqModule(ShipEqInSlot(Player(),t_Hull)) == FindBonusByNameInCfg('Keller_AcrinatorUpgrade'))",
                        "{",
                        "    Int_for_Keller_Krinator = 1;",
                        "}",
                        "if (PlayerBridge() == 1 && EqModule(ShipEqInSlot(Player(),t_Hull)) == FindBonusByNameInCfg('Keller_New_AcrinatorUpgrade'))",
                        "{",
                        "    Int_for_Keller_Krinator = 2;",
                        "}",
                        "if (PlayerBridge() == 1 && Int_for_Keller_Krinator == 1 && Star_Destroyer_Krinator_Dialogue == 1 && Udalenie_Keller_Krinator_for_Star_Destroyer == 0)",
                        "{",
                        "    AddDialogInject('StarDestroyerUpgradeMM', '', CT(\"Script.MS_Keller.350\"), 2);",
                        "    AddDialogInject('The_ray_of_death_Dialog', '', CT(\"Script.MS_Keller.353\"), 1);",
                        "    AddDialogInject('Armada_Dialog', '', CT(\"Script.MS_Keller.352\"), 3);",
                        "}",
                        "if (PlayerBridge() == 1 && Int_for_Keller_Krinator == 2 && Star_Destroyer_Krinator_Dialogue == 1 && Udalenie_Keller_Krinator_for_Star_Destroyer == 0)",
                        "{",
                        "    AddDialogInject('StarDestroyerUpgradeMM', '', CT(\"Script.MS_Keller.356\"), 2);",
                        "    AddDialogInject('The_ray_of_death_Dialog', '', CT(\"Script.MS_Keller.353\"), 1);",
                        "    AddDialogInject('Armada_Dialog', '', CT(\"Script.MS_Keller.352\"), 3);",
                        "}",
                        "if (EqModule(ShipEqInSlot(Player(),t_Hull))!=FindBonusByNameInCfg('Keller_AcrinatorUpgrade') && EqModule(ShipEqInSlot(Player(),t_Hull))!=FindBonusByNameInCfg('Keller_New_AcrinatorUpgrade'))",
                        "{",
                        "    ShipSpecialBonuses(Player(), bonAttacks, 0);",
                        "    Udalenie_Keller_Krinator_for_Star_Destroyer = 1;",
                        "}",
                        "if (EqModule(ShipEqInSlot(Player(),t_Hull)) == FindBonusByNameInCfg('Keller_AcrinatorUpgrade') || EqModule(ShipEqInSlot(Player(),t_Hull)) == FindBonusByNameInCfg('Keller_New_AcrinatorUpgrade'))",
                        "{",
                        "    Udalenie_Keller_Krinator_for_Star_Destroyer = 0;",
                        "}",
                        "if (HullSpecial(Player())!=FindBonusByNameInCfg('Keller_Newlomatelebala') && HullSpecial(Player())!=FindBonusByNameInCfg('490'))",
                        "{",
                        "    ShipSpecialBonuses(Player(), bonAttacks, 0);",
                        "}"
                    ],
