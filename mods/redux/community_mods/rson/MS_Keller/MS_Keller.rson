                {
                    "Name": "",
                    "Code.Type": "Turn",
                    "Code": [
                        "if(Star_Destroyer_Krinator_Dialogue == 0) {",
                        "  DChange(103);",
                        "  exit;",
                        "}",
                        "if(Star_Destroyer_Krinator_Dialogue == 1) {",
                        "  if(HullSpecial(Player()) == FindBonusByNameInCfg('490') && Int_for_Keller_Krinator == 1) {",
                        "    DChange(104);",
                        "    exit;",
                        "  }",
