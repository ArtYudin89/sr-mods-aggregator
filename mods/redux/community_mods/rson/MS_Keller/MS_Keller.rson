                    "Code": [
                        "The_ray_of_death = CreateEquipment(t_Weapon10,8600,8,6);",
                        "SetEquipmentStats(The_ray_of_death,12000,0);",
                        "SetEquipmentStats(The_ray_of_death,12000,1);",
                        "SetName(The_ray_of_death,CT(\"Script.MS_Keller.355\"));",
                        "ItemCost(The_ray_of_death,ItemCost(The_ray_of_death)*99);",
                        "AddItemToShip(Player(),The_ray_of_death);",
                        "LinkItemToScript(The_ray_of_death,THE_RAY_OF_DEATH); //NoDropItem(The_ray_of_death,1) - запрещает выбрасывать предмет AddDialogBlock('Изменить длительность вылетов', 2); AddDialogInject('Pulse_Shields_Dialog', '', \"Перегрузить импульсные щиты, используя энергию реактора\", 4);",
                        "ShipSpecialBonuses(Player(), bonAttacks, 0); //PutItemInVault(1, GetItemFromShip(Player(),1)); отправит предмет в хранилище. GetItemFromVault(1, GetItemFromShip(Player(),1)); -изымает;",
                        "DChange(108);",
                        "exit;"
                    ],
