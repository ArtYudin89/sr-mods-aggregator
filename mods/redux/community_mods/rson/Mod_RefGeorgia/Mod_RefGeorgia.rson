                },
                {
                    "Name": "",
                    "Code.Type": "DialogBegin",
                    "Code": [
                        "if(GetTalkShip()) {",
                        "    if(!TalkByAI()) {",
                        "        if(ShipType(GetTalkShip()) == 'Warrior' || ShipType(GetTalkShip()) == 'Dreadnought') {",
                        "            if(ShipStatistic(GetTalkShip(),10) == IdToPlanet(GeorgiaID)) {",
                        "                if(GetRelationPlanet(IdToPlanet(GeorgiaID),Player()) > 79) {",
                        "                    int rand = RndObject(1,7,GetTalkShip());",
                        "                    if(rand == 1) tstr = Format(CT(\"Script.Mod_RefGeorgia.39\"),'player',Name(Player()),'plan',Name(IdToPlanet(GeorgiaID)),'name',Name(GetTalkShip()));",
                        "                    if(rand == 2) tstr = Format(CT(\"Script.Mod_RefGeorgia.38\"),'player',Name(Player()),'plan',Name(IdToPlanet(GeorgiaID)),'name',Name(GetTalkShip()));",
                        "                    if(rand == 3) tstr = Format(CT(\"Script.Mod_RefGeorgia.37\"),'player',Name(Player()),'plan',Name(IdToPlanet(GeorgiaID)),'name',Name(GetTalkShip()));",
                        "                    if(rand == 4) tstr = Format(CT(\"Script.Mod_RefGeorgia.36\"),'player',Name(Player()),'plan',Name(IdToPlanet(GeorgiaID)),'name',Name(GetTalkShip()));",
                        "                    if(rand == 5) tstr = Format(CT(\"Script.Mod_RefGeorgia.35\"),'player',Name(Player()),'plan',Name(IdToPlanet(GeorgiaID)),'name',Name(GetTalkShip()));",
                        "                    if(rand == 6) tstr = Format(CT(\"Script.Mod_RefGeorgia.34\"),'player',Name(Player()),'plan',Name(IdToPlanet(GeorgiaID)),'name',Name(GetTalkShip()));",
                        "                    if(rand == 7) tstr = Format(CT(\"Script.Mod_RefGeorgia.33\"),'player',Name(Player()),'plan',Name(IdToPlanet(GeorgiaID)),'name',Name(GetTalkShip()));",
                        "                }",
                        "                else if(GetRelationPlanet(IdToPlanet(GeorgiaID),Player()) > 59) {",
                        "                    rand = RndObject(1,5,GetTalkShip());",
                        "                    if(rand == 1) tstr = Format(CT(\"Script.Mod_RefGeorgia.37\"),'player',Name(Player()),'plan',Name(IdToPlanet(GeorgiaID)),'name',Name(GetTalkShip()));",
                        "                    if(rand == 2) tstr = Format(CT(\"Script.Mod_RefGeorgia.36\"),'player',Name(Player()),'plan',Name(IdToPlanet(GeorgiaID)),'name',Name(GetTalkShip()));",
                        "                    if(rand == 3) tstr = Format(CT(\"Script.Mod_RefGeorgia.35\"),'player',Name(Player()),'plan',Name(IdToPlanet(GeorgiaID)),'name',Name(GetTalkShip()));",
                        "                    if(rand == 4) tstr = Format(CT(\"Script.Mod_RefGeorgia.34\"),'player',Name(Player()),'plan',Name(IdToPlanet(GeorgiaID)),'name',Name(GetTalkShip()));",
                        "                    if(rand == 5) tstr = Format(CT(\"Script.Mod_RefGeorgia.33\"),'player',Name(Player()),'plan',Name(IdToPlanet(GeorgiaID)),'name',Name(GetTalkShip()));",
                        "                }",
                        "                else if(GetRelationPlanet(IdToPlanet(GeorgiaID),Player()) > 29) {",
                        "                    rand = RndObject(1,4,GetTalkShip());",
                        "                    if(rand == 2) tstr = Format(CT(\"Script.Mod_RefGeorgia.36\"),'player',Name(Player()),'plan',Name(IdToPlanet(GeorgiaID)),'name',Name(GetTalkShip()));",
                        "                    if(rand == 3) tstr = Format(CT(\"Script.Mod_RefGeorgia.35\"),'player',Name(Player()),'plan',Name(IdToPlanet(GeorgiaID)),'name',Name(GetTalkShip()));",
                        "                    if(rand == 4) tstr = Format(CT(\"Script.Mod_RefGeorgia.34\"),'player',Name(Player()),'plan',Name(IdToPlanet(GeorgiaID)),'name',Name(GetTalkShip()));",
                        "                    if(rand == 1) tstr = Format(CT(\"Script.Mod_RefGeorgia.33\"),'player',Name(Player()),'plan',Name(IdToPlanet(GeorgiaID)),'name',Name(GetTalkShip()));",
                        "                }",
                        "                else if(GetRelationPlanet(IdToPlanet(GeorgiaID),Player()) > 29) {",
                        "                    rand = RndObject(1,2,GetTalkShip());",
                        "                    if(rand == 2) tstr = Format(CT(\"Script.Mod_RefGeorgia.32\"),'player',Name(Player()),'plan',Name(IdToPlanet(GeorgiaID)),'name',Name(GetTalkShip()));",
                        "                    if(rand == 1) tstr = Format(CT(\"Script.Mod_RefGeorgia.31\"),'player',Name(Player()),'plan',Name(IdToPlanet(GeorgiaID)),'name',Name(GetTalkShip()));",
                        "                }",
                        "                else {",
                        "                    rand = RndObject(1,2,GetTalkShip());",
                        "                    if(rand == 2) tstr = Format(CT(\"Script.Mod_RefGeorgia.30\"),'player',Name(Player()),'plan',Name(IdToPlanet(GeorgiaID)),'name',Name(GetTalkShip()));",
                        "                    if(rand == 1) tstr = Format(CT(\"Script.Mod_RefGeorgia.29\"),'player',Name(Player()),'plan',Name(IdToPlanet(GeorgiaID)),'name',Name(GetTalkShip()));",
                        "                }",
                        "",
                        "                if(~PlayerChameleonCurType()) {",
                        "                    rand = RndObject(1,3,GetTalkShip());",
                        "                    if(rand == 1) tstr = Format(CT(\"Script.Mod_RefGeorgia.28\"),'player',Name(Player()),'plan',Name(IdToPlanet(GeorgiaID)),'name',Name(GetTalkShip()));",
                        "                    if(rand == 2) tstr = Format(CT(\"Script.Mod_RefGeorgia.27\"),'player',Name(Player()),'plan',Name(IdToPlanet(GeorgiaID)),'name',Name(GetTalkShip()));",
                        "                    if(rand == 3) tstr = Format(CT(\"Script.Mod_RefGeorgia.26\"),'player',Name(Player()),'plan',Name(IdToPlanet(GeorgiaID)),'name',Name(GetTalkShip()));",
                        "",
                        "                }",
                        "",
                        "                DText(tstr);",
                        "                if(ShipTypeN(GetTalkShip()) == t_Warrior) {",
                        "                    if(ShipSubType(GetTalkShip())) AddDialogInject('DialogHachapuri','',CT(\"Script.Mod_RefGeorgia.24\"),99);",
                        "                }",
                        "            }",
                        "        }",
                        "    }",
                        "}",
                        "",
                        "if(GetShipPlanet(Player())) {",
                        "    if(GetShipPlanet(Player()) == IdToPlanet(GeorgiaID)) {",
                        "        if(!KhinkaliCD) {",
                        "            int y = 0;",
                        "            for(i=0;GalaxyStars()>i;i=i+1) {",
                        "                if(StarOwner(GalaxyStar(i)) == 1) continue;",
                        "                if(round(sqrt(Dist2Star(ShipStar(Player()), GalaxyStar(i)))) < 15) continue;",
                        "                if(round(sqrt(Dist2Star(ShipStar(Player()), GalaxyStar(i)))) > 50) continue;",
                        "                if(StarToCon(GalaxyStar(i)) == StarToCon(PlanetToStar(PlanetPirateClan()))) continue;",
                        "                for(j=0;StarPlanets(GalaxyStar(i))>j;j=j+1) {",
                        "                    if(PlanetOwner(StarPlanets(GalaxyStar(i),j)) > 4) continue;",
                        "                    AddDialogInject('KhinkaliStart','',CT(\"Script.Mod_RefGeorgia.23\"),1);",
                        "                    y = 1;",
                        "                    break;",
                        "                }",
                        "                if(y) break;",
                        "            }",
                        "        }",
                        "        else {",
                        "            AddDialogInject('KhinkaliFail','',CT(\"Script.Mod_RefGeorgia.23\"),1);",
                        "        }",
                        "    }",
                        "    if(GetShipPlanet(Player()) == IdToPlanet(LastPlanetID)) {",
                        "        if(KhinkaliCD) {",
                        "            for(i=0;ShipItems(Player())>i;i=i+1) {",
                        "                if(ItemType(ShipItems(Player(),i)) != t_UselessItem) continue;",
                        "",
                        "                if(EquipmentImageName(ShipItems(Player(),i)) == 'Khinkali') {",
                        "                    AddDialogInject('KhinkaliEnd','',CT(\"Script.Mod_RefGeorgia.22\"),1);",
                        "                    break;",
                        "                }",
                        "            }",
                        "        }",
                        "    }",
                        "}"
