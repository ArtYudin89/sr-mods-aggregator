            "Items": [],
            "Operations": [
                {
                    "Name": "",
                    "Code.Type": "Global",
                    "Code": [
                        "GRun();"
                    ],
                    "#": 22,
                    "Type": "Top",
                    "Parent": -1,
                    "Pos.x": 0,
                    "Pos.y": 610
                },
                {
                    "Name": "",
                    "Code.Type": "Init",
                    "Code": [
                        "//Генерация планетки",
                        "//--Новая Грузия - Сакартвело--",
                        "//Система привязки",
                        "for(i=0;GalaxyStars()>i;i=i+1) {",
                        "    if(StarOwner(GalaxyStar(i)) != 0) continue;",
                        "    if(StarBattle(GalaxyStar(i))) continue;",
                        "    if(StarPlanets(GalaxyStar(i)) > 6) continue;",
                        "",
                        "    star=GalaxyStar(i);",
                        "}",
                        "//Генерация",
                        "tempRadius=PlanetOrbitRadius(StarPlanets(star, StarPlanets(star)-1));",
                        "planet=CreatePlanet(star,tempRadius+400+round(Rnd(0, 100), 10)); SetName(planet,CT(\"Script.Mod_RefGeorgia.0\")); PlanetSetGraph(planet,181);",
                        "PlanetOrbitalVelocity(planet,40);//вращение по часовой стрелке со скоростью 40",
                        "PlanetSize(planet,70);",
                        "//Раса",
                        "PlanetRace(planet,People);",
                        "PlanetPopulation(planet, 300000+1000*RndObject(-10, 25,planet));",
                        "//Владелец планеты",
                        "if(!StarOwner(star)) PlanetOwner(planet, PlanetRace(planet));",
                        "else if(StarOwner(star)==1) PlanetOwner(planet, Kling);",
                        "else PlanetOwner(planet, PirateClan);",
                        "//Отношение",
                        "if(PlanetOwner(planet)<Kling) RelationToRanger(planet, Player(), GlobalRelationsPlanets(Player(), 0, int(exp(ln(2)*PlanetOwner(planet)))));",
                        "//Правительно и экономика",
                        "PlanetEco(planet,2);",
                        "PlanetGov(planet,Rnd(1,4));",
                        "GeorgiaID=Id(planet);",
                        "//Сакартвело всегда славилось своей техникой!",
                        "PlanetBoostInventions(planet,2000);",
                        "//Немного накинем в магазин барахла",
                        "int rand = RndObject(1,100,planet);",
                        "if(rand > 55) {",
                        "    AddItemToShop(planet,CreateHull(RndObject(0,5,planet),RndObject(round(0.5 * 250), max(250 + 200, round(PortionInDiapason(GalaxyTechLevel(), 1, 8, 0.7, 2.0) * CT('Items.Hull.AverageSize'))),planet),PlanetInventionLevel(planet,0),People));",
                        "}",
                        "rand = RndObject(1,100,planet);",
                        "if(rand > 70) {",
                        "    AddItemToShop(planet,CreateHull(RndObject(0,5,planet),RndObject(round(0.5 * 250), max(250 + 200, round(PortionInDiapason(GalaxyTechLevel(), 1, 8, 0.7, 2.0) * CT('Items.Hull.AverageSize'))),planet),PlanetInventionLevel(planet,0),People));",
                        "}",
                        "rand = RndObject(1,100,planet);",
                        "if(rand > 90) {",
                        "    AddItemToShop(planet,CreateHull(RndObject(0,5,planet),RndObject(round(0.5 * 250), max(250 + 200, round(PortionInDiapason(GalaxyTechLevel(), 1, 8, 0.7, 2.0) * CT('Items.Hull.AverageSize'))),planet),PlanetInventionLevel(planet,0),People));",
                        "}",
                        "rand = RndObject(1,100,planet);",
                        "if(rand > 40) {",
                        "    AddItemToShop(planet,CreateEquipment(t_Radar,RndObject(15,25,planet),PlanetInventionLevel(planet,3),People));",
                        "}",
                        "rand = RndObject(1,100,planet);",
                        "if(rand > 75) {",
                        "    AddItemToShop(planet,CreateEquipment(t_Radar,RndObject(15,25,planet),PlanetInventionLevel(planet,3),People));",
                        "}",
                        "rand = RndObject(1,100,planet);",
                        "if(rand > 50) {",
                        "    AddItemToShop(planet,CreateEquipment(t_Scaner,RndObject(15,25,planet),PlanetInventionLevel(planet,4),People));",
                        "}",
                        "rand = RndObject(1,100,planet);",
                        "if(rand > 35) {",
                        "    AddItemToShop(planet,CreateEquipment(t_CargoHook,RndObject(15,25,planet),PlanetInventionLevel(planet,6),People));",
                        "}",
                        "rand = RndObject(1,100,planet);",
                        "if(rand > 50) {",
                        "    AddItemToShop(planet,CreateEquipment(t_CargoHook,RndObject(15,25,planet),PlanetInventionLevel(planet,6),People));",
                        "}",
                        "rand = RndObject(1,100,planet);",
                        "if(rand > 30) {",
                        "    AddItemToShop(planet,CreateEquipment(t_RepairRobot,RndObject(15,25,planet),PlanetInventionLevel(planet,5),People));",
                        "}",
                        "rand = RndObject(1,100,planet);",
                        "if(rand > 60) {",
                        "    AddItemToShop(planet,CreateEquipment(t_DefGenerator,RndObject(15,25,planet),PlanetInventionLevel(planet,7),People));",
                        "}",
                        "rand = RndObject(1,100,planet);",
                        "if(rand > 10) {",
                        "    AddItemToShop(planet,CreateEquipment(t_FuelTanks,RndObject(15,20,planet),PlanetInventionLevel(planet,1),People));",
                        "}",
                        "rand = RndObject(1,100,planet);",
                        "if(rand > 25) {",
                        "    AddItemToShop(planet,CreateEquipment(t_FuelTanks,RndObject(15,20,planet),PlanetInventionLevel(planet,1),People));",
                        "}",
                        "rand = RndObject(1,100,planet);",
                        "if(rand > 40) {",
                        "    AddItemToShop(planet,CreateEquipment(t_FuelTanks,RndObject(15,20,planet),PlanetInventionLevel(planet,1),People));",
                        "}",
                        "rand = RndObject(1,100,planet);",
                        "if(rand > 20) {",
                        "    AddItemToShop(planet,CreateEquipment(t_Engine,RndObject(15,20,planet),PlanetInventionLevel(planet,2),People));",
                        "}",
                        "rand = RndObject(1,100,planet);",
                        "if(rand > 35) {",
                        "    AddItemToShop(planet,CreateEquipment(t_Engine,RndObject(15,20,planet),PlanetInventionLevel(planet,2),People));",
                        "}",
                        "rand = RndObject(1,100,planet);",
                        "if(rand > 15) {",
                        "    AddItemToShop(planet,CreateEquipment(t_Weapon2,RndObject(15,20,planet),PlanetInventionLevel(planet,2),People));",
                        "}",
                        "rand = RndObject(1,100,planet);",
                        "if(rand > 40) {",
                        "    AddItemToShop(planet,CreateEquipment(t_Weapon2,RndObject(15,20,planet),PlanetInventionLevel(planet,2),People));",
                        "}",
                        "rand = RndObject(1,100,planet);",
                        "if(rand > 30) {",
                        "    AddItemToShop(planet,CreateEquipment(t_Weapon3,RndObject(15,20,planet),PlanetInventionLevel(planet,2),People));",
                        "}",
                        "",
                        "function SetEquip(ship) {",
                        "    dword tdwd1;",
                        "    int power,i;",
                        "",
                        "    if(!ship) exit;",
                        "    if(ObjectType(ship) != 4 && ObjectType(ship) != 5) exit;",
                        "",
                        "    //Обновляем кораблику движок",
                        "    if(ShipEqInSlot(ship,t_Engine)) {",
                        "        DeleteEquipment(ship,t_Engine);",
                        "        ItemIsInUse(CreateEquipment(t_Engine,Rnd(20,35),GalaxyTechLevel(),ShipPilotRace(ship)),ship,1);",
                        "    }",
                        "    else ItemIsInUse(CreateEquipment(t_Engine,Rnd(20,35),GalaxyTechLevel(),ShipPilotRace(ship)),ship,1);",
                        "",
                        "    //Обновляем гражданину ГЗП и дроида, а то чо он как лох",
                        "    if(!ShipEqInSlot(ship,t_DefGenerator)) ItemIsInUse(CreateEquipment(t_DefGenerator,Rnd(30,45),GalaxyTechLevel(),ShipPilotRace(ship)),ship,1);",
                        "    else {",
                        "        DeleteEquipment(ship,t_DefGenerator);",
                        "        ItemIsInUse(CreateEquipment(t_DefGenerator,Rnd(30,45),GalaxyTechLevel(),ShipPilotRace(ship)),ship,1);",
                        "    }",
                        "    if(!ShipEqInSlot(ship,t_RepairRobot)) ItemIsInUse(CreateEquipment(t_RepairRobot,Rnd(25,40),GalaxyTechLevel(),ShipPilotRace(ship)),ship,1);",
                        "    else {",
                        "        DeleteEquipment(ship,t_RepairRobot);",
                        "        ItemIsInUse(CreateEquipment(t_RepairRobot,Rnd(25,40),GalaxyTechLevel(),ShipPilotRace(ship)),ship,1);",
                        "    }",
                        "    //А теперь смотрим, насколько хреновые у него пушки и меняем на нормальные",
                        "    for(i=0;ShipSlots(ship,1)>i;i=i+1) {",
                        "        if(ShipEqInSlot(ship,t_Weapon1,1)) {",
                        "            item = ShipEqInSlot(ship,t_Weapon1,1);",
                        "            if(ItemType(item) < t_CustomWeapon) {",
                        "                if(ItemType(item) + 1 < GiveNormalWeaponType()) {",
                        "                    FreeItem(GetItemFromShip(ship,item));",
                        "                    AddItemToShip(ship,CreateEquipment(GiveNormalWeaponType(),RndObject(15+GiveNormalWeaponType()*3/2,25+GiveNormalWeaponType()*2,ship),GalaxyTechLevel(),People));",
                        "                    ArrangeItems(ship);",
                        "                }",
                        "            }",
                        "        }",
                        "    }",
                        "",
                        "    //Настало время апнуть чувачка",
                        "    ShipImproveItems(ship,7);",
                        "}",
                        "",
                        "function GiveNormalWeaponType() {",
                        "    int GTL = GalaxyTechLevel();",
                        "",
                        "    if(GTL == 3) result = t_Weapon3;",
                        "    if(GTL == 4) result = t_Weapon7;",
                        "    if(GTL == 5) result = t_Weapon9;",
                        "    if(GTL == 6) result = t_Weapon10;",
                        "    if(GTL == 7) result = t_Weapon11;",
                        "    if(GTL == 8) result = t_Weapon12;",
                        "}"
                    ],
                    "#": 23,
                    "Type": "Top",
                    "Parent": -1,
                    "Pos.x": 60,
                    "Pos.y": 610
                },
                {
                    "Name": "",
                    "Code.Type": "Turn",
                    "Code": [
                        "if(PlanetWarriors(IdToPlanet(GeorgiaID)) < 9) {",
                        "    tdwd = BuyWarrior(IdToPlanet(GeorgiaID));",
                        "    if(tdwd > 1) SetEquip(tdwd);",
                        "}",
                        "if(!StarOwner(PlanetToStar(IdToPlanet(GeorgiaID)))) {",
                        "    flag = 0;",
                        "    for(i=0;PlanetWarriors(IdToPlanet(GeorgiaID))>i;i=i+1) {",
                        "        if(ShipSubType(PlanetWarriors(IdToPlanet(GeorgiaID),i)) == 1) int flag = 1;",
                        "    }",
                        "    if(!flag) {",
                        "        if(!BuildindFlagship) {",
                        "            tdwd = BuyBigWarrior(IdToPlanet(GeorgiaID));",
                        "            if(tdwd > 1) SetEquip(tdwd);",
                        "            BuildindFlagship = 75;",
                        "        }",
                        "    }",
                        "}",
                        "for(i=0;PlanetWarriors(IdToPlanet(GeorgiaID))>i;i=i+1) {",
                        "    if(!ShipSpecialBonuses(PlanetWarriors(IdToPlanet(GeorgiaID),i),bonNull)) {",
                        "        if(ShipSubType(PlanetWarriors(IdToPlanet(GeorgiaID),i)) == 1) {",
                        "            int rand = RndObject(1,10,PlanetWarriors(IdToPlanet(GeorgiaID),i));",
                        "            if(rand == 1) SetName(PlanetWarriors(IdToPlanet(GeorgiaID),i),CT(\"Script.Mod_RefGeorgia.21\"));",
                        "            if(rand == 2) SetName(PlanetWarriors(IdToPlanet(GeorgiaID),i),CT(\"Script.Mod_RefGeorgia.20\"));",
                        "            if(rand == 3) SetName(PlanetWarriors(IdToPlanet(GeorgiaID),i),CT(\"Script.Mod_RefGeorgia.19\"));",
                        "            if(rand == 4) SetName(PlanetWarriors(IdToPlanet(GeorgiaID),i),CT(\"Script.Mod_RefGeorgia.18\"));",
                        "            if(rand == 5) SetName(PlanetWarriors(IdToPlanet(GeorgiaID),i),CT(\"Script.Mod_RefGeorgia.17\"));",
                        "            if(rand == 6) SetName(PlanetWarriors(IdToPlanet(GeorgiaID),i),CT(\"Script.Mod_RefGeorgia.16\"));",
                        "            if(rand == 7) SetName(PlanetWarriors(IdToPlanet(GeorgiaID),i),CT(\"Script.Mod_RefGeorgia.15\"));",
                        "            if(rand == 8) SetName(PlanetWarriors(IdToPlanet(GeorgiaID),i),CT(\"Script.Mod_RefGeorgia.14\"));",
                        "            if(rand == 9) SetName(PlanetWarriors(IdToPlanet(GeorgiaID),i),CT(\"Script.Mod_RefGeorgia.13\"));",
                        "            if(rand == 10) SetName(PlanetWarriors(IdToPlanet(GeorgiaID),i),CT(\"Script.Mod_RefGeorgia.12\")); //См. \"Атлантида: Затерянный город\"",
                        "        }",
                        "        else SetName(PlanetWarriors(IdToPlanet(GeorgiaID),i),CT(\"Script.Mod_RefGeorgia.11\")+Rnd(1,999)+'-');",
                        "        ShipSpecialBonuses(PlanetWarriors(IdToPlanet(GeorgiaID),i),bonNull,1);",
                        "    }",
                        "}",
                        "",
                        "if(GalaxyShipId() > lastShipId)",
                        "{",
                        "    tint = BuildListOfNewShips(temp_array, lastShipId, 8+16+64+128+256+512+1024+2048+4096+8192, 1+2+4+8+16+128, 1, '', '');",
                        "",
                        "    //Если нашли хоть один новый корабль",
                        "    if(tint) {",
                        "        for(i = 0; i < ArrayDim(temp_array); i = i + 1) {",
                        "            cur_ship = temp_array[i];",
                        "",
                        "            if(ShipStatistic(cur_ship,10) == IdToPlanet(GeorgiaID)) {",
                        "                if(ShipTypeN == t_Transport) {",
                        "                    rand = RndObject(1,9,cur_ship);",
                        "                    if(rand == 1) SetName(cur_ship,CT(\"Script.Mod_RefGeorgia.10\"));",
                        "                    if(rand == 2) SetName(cur_ship,CT(\"Script.Mod_RefGeorgia.9\"));",
                        "                    if(rand == 3) SetName(cur_ship,CT(\"Script.Mod_RefGeorgia.8\"));",
                        "                    if(rand == 4) SetName(cur_ship,CT(\"Script.Mod_RefGeorgia.7\"));",
                        "                    if(rand == 5) SetName(cur_ship,CT(\"Script.Mod_RefGeorgia.6\"));",
                        "                    if(rand == 6) SetName(cur_ship,CT(\"Script.Mod_RefGeorgia.5\"));",
                        "                    if(rand == 7) SetName(cur_ship,CT(\"Script.Mod_RefGeorgia.4\"));",
                        "                    if(rand == 8) SetName(cur_ship,CT(\"Script.Mod_RefGeorgia.3\"));",
                        "                    if(rand == 9) SetName(cur_ship,CT(\"Script.Mod_RefGeorgia.2\"));",
                        "                }",
                        "            }",
                        "        }",
                        "    }",
                        "",
                        "    lastShipId = GalaxyShipId();",
                        "}",
                        "",
                        "if(KhinkaliCD) {",
                        "    KhinkaliCD = KhinkaliCD - 1;",
                        "    Ether(3,'CargoQuestGeorgia',CT(\"Script.Mod_RefGeorgia.59\")+' '+Name(IdToPlanet(LastPlanetID))+CT(\"Script.Mod_RefGeorgia.58\")+' '+Name(PlanetToStar(IdToPlanet(LastPlanetID)))+Format(CT(\"Script.Mod_RefGeorgia.57\"),\"<0>\",KhinkaliCD),IdToPlanet(LastPlanetID));",
                        "}",
                        "if(KhinkaliFlag && !KhinkaliCD) {",
                        "    KhinkaliFlag = 0;",
                        "    Ether(5,'CargoQuestGeorgia','');",
                        "    NewsAdd(CT(\"Script.Mod_RefGeorgia.1\"));",
                        "    Sound('Sound.QuestCancel');",
                        "    RelationToRanger(IdToPlanet(GeorgiaID),Player(),5);",
                        "}",
                        "",
                        "if(BuildindFlagship) BuildindFlagship = BuildindFlagship - 1;"
                    ],
                    "#": 24,
                    "Type": "Top",
