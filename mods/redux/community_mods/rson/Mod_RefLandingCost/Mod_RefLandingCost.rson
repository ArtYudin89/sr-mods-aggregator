                        "if(GalaxyDiffLevels() > 449) payment = 40;",
                        "if(GalaxyDiffLevels() > 479) payment = 50;",
                        "",
                        "function PlayerActCode() {",
                        "    if(ScriptItemActionType(t_OnPlayerTalkedWithShip)) {",
                        "        if(ShipType(ScriptItemActObject1()) == 'FemRanger') {",
                        "            j = 0;",
                        "            for(i=0;ShipPartners(Player())>i;i=i+1) {",
                        "                if(ShipType(ShipPartners(Player(),i)) == 'FemRanger') j = j + 1;",
                        "            }",
                        "            if(j > WivesCnt) {",
                        "                NewsAdd(CT(\"Script.Mod_RefLandingCost.16\")+' '+mcost+' '+CT(\"Script.Mod_RefLandingCost.15\"));",
                        "                Sound('Sound.NewMsg');",
                        "                MarriageCount = MarriageCount + 1;",
                        "            }",
                        "        }",
                        "    }",
                        "}"
                    ],
                    "#": 16,
                    "Type": "Top",
