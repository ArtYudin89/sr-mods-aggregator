                {
                    "Name": "",
                    "Code.Type": "Init",
                    "Code": [
                        "if(GalaxyDiffLevels() > 49) payment = 3;",
                        "if(GalaxyDiffLevels() > 99) payment = 4;",
                        "if(GalaxyDiffLevels() > 149) payment = 5;",
                        "if(GalaxyDiffLevels() > 199) payment = 7;",
                        "if(GalaxyDiffLevels() > 249) payment = 10;",
