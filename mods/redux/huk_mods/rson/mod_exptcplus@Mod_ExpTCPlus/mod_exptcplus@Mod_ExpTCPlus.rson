                    "#": 99,
                    "Type": "Top",
                    "Parent": -1,
                    "Pos.x": 580,
                    "Pos.y": 495
                },
                {
                    "Name": "",
                    "Code.Type": "Turn",
                    "Code": [
                        "//даты на скриптовом:",
                        "//Data1 сколько и чего добавляет. например, при спецакрине mod_exptcplus_droid и Data1=50 будет чинить на 50",
                        "//Data2 для пух. ид пухи в ваулте",
                        "//Data3 потребление энергии от совмещенного оборудования",
                        "//TextData1 строка имя совмещенного предмета(для инфошки предмета)",
                        "//TextData2 строка маркер пухи в ваулте/строка с тэгом спецакрина дроида или гзп",
                        "//TextData3 строка маркер предмета что он в нашем скрипте(mod_exptcplus)",
                        "",
                        "//если совмещаем не с Энергогенератором",
                        "if(item2>100)",
                        "    {",
                        "//объявляем предмет как скриптовый бесхозный, чтобы работал подстановка строк",
                        "//<Data> и <TextData> в спецакринах и для записи нужных переменных",
                        "    LinkItemToScript(item1);",
                        "//ScriptItemData1 - стат совмещаемого предмета(ремонт дроида, гзп итд.)",
                        "    ScriptItemData(item1, 1, GetEquipmentStats(item2,0));",
                        "//ScriptItemData3 - энергозатраты совмещенного предмета",
                        "    ScriptItemData(item1, 3, -6);",
                        "//ScriptItemTextData1 - имя совмещенного предмета(для оружия ещё и урон, дальность)",
                        "    if(ItemType(item2)<t_Weapon1)ScriptItemTextData(item1,1,DeleteTags(Name(item2)));",
                        "    else ScriptItemTextData(item1,1,DeleteTags(Name(item2)+' (урон: '+GetEquipmentStats(item2,1)+'-'+GetEquipmentStats(item2,0)+', дальность: '+GetEquipmentStats(item2,2)+')'));",
                        "//ScriptItemTextData3 - идентефикатор скриптового предмета 'mod_exptcplus' означает что",
                        "//скриптовый предмет из нашего скрипта, остальные пропускаем в инфошке 'mod_exptcplus_infos'",
                        "    ScriptItemTextData(item1,3,'mod_exptcplus');",
                        "//ScriptItemTextData2 - строка для проверки в инфошке чтобы выполнять нужный акткод совмещенного предмета",
                        "//например, дроид будет чинить, а гзп блокировать урон",
                        "    if(ItemType(item2)==t_RepairRobot)",
                        "        {",
                        "        int1=FindBonusByCustomTag('mod_exptcplus_droid');",
                        "        ScriptItemTextData(item1, 2, 'mod_exptcplus_droid');",
                        "        }",
                        "    if(ItemType(item2)==t_DefGenerator)",
                        "        {",
                        "        int1=FindBonusByCustomTag('mod_exptcplus_gzp');",
                        "        ScriptItemTextData(item1, 2, 'mod_exptcplus_gzp');",
                        "        }",
                        "    if(ItemType(item2)>t_DefGenerator)int1=FindBonusByCustomTag('mod_exptcplus_wpn');",
                        "    ItemExtraSpecialsAddByType(item1,int1);",
                        "//вес и цена обоих предметов суммируется",
                        "    ItemSize(item1,ItemSize(item1) + ItemSize(item2));",
                        "    ItemCost(item1,ItemCost(item1) + ItemCost(item2));",
                        "//штраф -30% надежности при совмещении",
                        "    int1=FindBonusByCustomTag('mod_exptcplus_frag_minus_30');",
                        "    ItemExtraSpecialsAddByType(item1,int1);",
                        "    if(ItemType(item2)<t_Weapon1)",
                        "        {",
                        "        GetItemFromShip(Player(),item2);",
                        "        FreeItem(item2);",
                        "        }",
                        "    else",
                        "        {",
                        "        str0=DeleteTags(Name(item2))+'_'+Id(item2);",
                        "        GetItemFromShip(Player(), item2);",
                        "//ScriptItemData2 - ИД пухи в ваулте которой будем стрелять при совмещении дроида с пухой",
                        "        ScriptItemData(item1, 2, Id(item2));",
                        "        ScriptItemData(item1, 3, -8);",
                        "        ScriptItemTextData(item1, 2, str0);",
                        "        PutItemInVault(str0, item2);",
                        "//добавляем в массив совмещенный предмет, чтобы потом удалить пуху из ваулта, когда совмещенный",
                        "//предмет удалится, продастся, расстреляется итд.",
                        "        ArrayAdd(toDel, Id(item1), str0);",
                        "        }",
                        "    }",
                        "else",
                        "    {",
                        "//если совмещаем с Энергогенератором",
                        "    if(item2==1)int1=FindBonusByCustomTag('mod_exptcplus_enrg');",
                        "    ItemExtraSpecialsAddByType(item1,int1);",
                        "    LinkItemToScript(item1);",
                        "    ScriptItemData(item1, 1, CT('MicroModuls.mod_exptcplus_enrg.mod_exptcplus_enrg_bonus'));",
                        "    ScriptItemData(item1, 3, CT('MicroModuls.mod_exptcplus_enrg.mod_exptcplus_enrg_bonus'));",
                        "    ScriptItemTextData(item1,1,CT(\"Script.mod_exptcplus.34\"));",
                        "    ScriptItemTextData(item1,3,'mod_exptcplus');",
                        "    ItemSize(item1,ItemSize(item1) + 10);",
                        "    ItemCost(item1,ItemCost(item1) + int0);",
                        "    int1=FindBonusByCustomTag('mod_exptcplus_frag_minus_30');",
                        "    ItemExtraSpecialsAddByType(item1,int1);",
                        "    }",
                        "ShipMoney(Player(), ShipMoney(Player()) - int0);",
                        "Sound('Sound.Repair');",
                        "DAdd(1);"
                    ],
