                {
                    "Name": "",
                    "Code.Type": "Turn",
                    "Code": [
                        "ArrayClear(arr0); ArrayDelete(arr0,0);",
                        "ArrayClear(arr1); ArrayDelete(arr1,0);",
                        "int1=0;str0='</color>';",
                        "//создаем массив с поломанными очистителями",
                        "for(a=0;a<ShipItems(Player());a=a+1)",
                        "    {",
                        "    dwd0=ShipItems(Player(),a);",
                        "    if(!ItemInScript(dwd0))continue;",
                        "    if(ItemType(dwd0)!=t_UselessItem)continue;",
                        "    if(ItemDurability(dwd0)>94)continue;",
                        "    if(CT('UselessItems.'+EquipmentImageName(dwd0)+'.mod_exptcplus')!=1)continue;",
                        "    ArrayAdd(arr0,a,Name(dwd0));",
                        "    int0=ItemCost(dwd0) - (ItemCost(dwd0) * ItemDurability(dwd0)) / 100;",
                        "    ArrayAdd(arr1,int0);",
                        "    str0=str0+CT(\"Script.mod_exptcplus.61\")+Name(dwd0)+Format(CT(\"Script.mod_exptcplus.55\"),\"<0>\",int0);",
                        "    int1=int1+int0;",
                        "    }",
                        "if(ArrayDim(arr0)>0) {",
                        "  DChange(10);",
                        "  exit;",
                        "}",
                        "if(ArrayDim(arr0)<=0) {",
                        "  DChange(11);",
                        "  exit;",
                        "}"
