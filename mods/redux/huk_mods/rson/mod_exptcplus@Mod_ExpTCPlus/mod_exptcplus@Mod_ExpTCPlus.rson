                {
                    "Name": "",
                    "Code.Type": "Turn",
                    "Code": [
                        "str0=CT('Items.CustomCountables.mtcp_RefinerRes0.Name');",
                        "str1=CT('Items.CustomCountables.mtcp_RefinerRes1.Name');",
                        "str2=CT('Items.CustomCountables.mtcp_RefinerRes2.Name');",
                        "//каждые 30 ходов цена на ресурсы меняется",
                        "if(CurTurn()>resNewPrice)",
                        "    {",
                        "    resNewPrice=CurTurn() + 30;",
                        "    int1=substr(GameDateTxtByTurn(CurTurn()), findsubstr(GameDateTxtByTurn(CurTurn()), '33') );",
                        "    int1=int1 - 3300;",
                        "    if(int1>30)int1=30;",
                        "    if(int1<0)int1=0;",
                        "    res0Cost=25 * GalaxyTechLevel();",
                        "    res0Cost=res0Cost + ((res0Cost * Rnd(0,50)) / 100) + ((res0Cost * 2 * int1) / 100);",
                        "    res1Cost=25 * GalaxyTechLevel();",
