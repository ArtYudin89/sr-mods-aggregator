                {
                    "Name": "",
                    "Code.Type": "Turn",
                    "Code": [
                        "//создаем юзлес очистителя по выбранному типу и привязываем его к свободному скриптовому предмету",
                        "item1=CreateQuestItem(CurRefiner[1]);",
                        "for(a=1;a<9;a=a+1)",
                        "    {",
                        "    item2=GetValueFromScript('mod_exptcplus','mod_exptcplus_Refiner'+a);",
                        "    if(ScriptItemToItem(item2)!=0)continue;",
                        "    LinkItemToScript(item1,item2);",
                        "    break;",
                        "    }",
                        "//UselessItemData 1 максимальная вместимость очистителя",
                        "UselessItemData(item1,1,CT('UselessItems.'+CurRefiner[1]+'.Tank'));",
                        "//UselessItemData 2 сколько ед. добывает за период",
                        "UselessItemData(item1,2,CT('UselessItems.'+CurRefiner[1]+'.Production_Count'));",
                        "//UselessItemData 3 через сколько ходов следующая добыча",
                        "UselessItemData(item1,3,CT('UselessItems.'+CurRefiner[1]+'.Production_Days'));",
                        "//ScriptItemTextData1 - имя планеты где находится очиститель или пустая строка",
                        "ScriptItemTextData(item2,1,'');",
                        "//ScriptItemTextData2 - имя звезды где находится очиститель или пустая строка",
                        "ScriptItemTextData(item2,2,'');",
                        "//ScriptItemData1 сколько добыто ресурса",
                        "ScriptItemData(item2,1,0);",
                        "//ScriptItemData2 ход следующей добычи",
                        "ScriptItemData(item2,2,0);",
                        "//ScriptItemData 3 тип добываемого ресурса",
                        "ScriptItemData(item2,3,CT('UselessItems.'+CurRefiner[1]+'.Res_Type'));",
                        "UselessItemText(item1,Format(CT('UselessItems.'+CurRefiner[1]+'.Text'),'[durability]',100));",
                        "//выставляем нужные параметры очистителя",
                        "ItemOwner(item1,CurRefiner[5]);",
                        "ItemSize(item1,CurRefiner[4]);",
                        "ItemCost(item1,CurRefiner[6]);",
                        "//разрешаем продажу, так как изначально скриптовые нельзя продавать",
                        "CanSellItem(item1,1);",
                        "SetName(item1,Name(item1)+'-'+Rnd(0,9999));",
                        "AddItemToShip(Player(),item1);",
                        "ShipMoney(Player(),ShipMoney(Player()) - CurRefiner[6]);",
                        "Sound('Sound.Sell');",
                        "//в этом ходу купили очиститель, надо выбирать новый тип при следующем диалоге",
                        "RefinerNewType=0;",
                        "DAdd(7);"
