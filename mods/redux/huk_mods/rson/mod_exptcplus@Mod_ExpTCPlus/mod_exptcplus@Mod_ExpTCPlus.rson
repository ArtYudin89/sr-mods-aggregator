                        "GRun();"
                    ],
                    "#": 45,
                    "Type": "Top",
                    "Parent": -1,
                    "Pos.x": 0,
                    "Pos.y": 685
                },
                {
                    "Name": "",
                    "Code.Type": "Init",
                    "Code": [
                        "//добавляем на игрока инфошку для отслеживания энергозатрат совмещёнки",
                        "//и открытие/закрытие панелек очистителей",
                        "ShipAddCustomShipInfo(Player(), 'mod_exptcplus_infos', 'NoShow');"
                    ],
                    "#": 46,
                    "Type": "Top",
                    "Parent": -1,
                    "Pos.x": 60,
                    "Pos.y": 685
                },
                {
                    "Name": "",
                    "Code.Type": "Turn",
                    "Code": [
                        "if(!ShipIsTakeoff(Player())) {",
                        "  //UselessItemData1  максимальная вместимость очистителя",
                        "  //UselessItemData2 сколько ед. добывает за период",
                        "  //UselessItemData3 через сколько ходов следующая добыча",
                        "  //ScriptItemData1 сколько добыто ресурса",
                        "  //ScriptItemData2 ход следующей добычи",
                        "  //ScriptItemData3 тип добываемого ресурса",
                        "  //ScriptItemTextData1 - имя планеты где находится очиститель или пустая строка",
                        "  //ScriptItemTextData2 - имя звезды где находится очиститель или пустая строка",
                        "  str0='';str1='';",
                        "  //проверяем где очистители и что они должны делать",
                        "  for(a=1;a<9;a=a+1)",
                        "      {",
                        "      dwd0=GetValueFromScript('mod_exptcplus','mod_exptcplus_Refiner'+a);",
                        "  //пропуск если юзлеса привязанного к очистителю нету(игрока продал, расстрелял итд.)",
                        "      if(ScriptItemToItem(dwd0)==0)continue;",
                        "  //пропуск если очиститель не на планете",
                        "      if(ScriptItemTextData(dwd0,1)=='')continue;",
                        "      dwd1=ScriptItemToItem(dwd0);",
                        "      str1=CT('mod_exptcplus.Refiner.ether_ref');",
                        "      int0=ItemDurability(dwd0);",
                        "  //если настало время добычи и очиститель не сломан",
                        "      if(CurTurn()>=ScriptItemData(dwd0,2) && int0>0)",
                        "          {",
                        "  //если есть куда ещё складывать ресурс",
                        "          if(ScriptItemData(dwd0,1)<UselessItemData(dwd1,1))",
                        "              {",
                        "              ScriptItemData(dwd0,2,CurTurn()+UselessItemData(dwd1,3));",
                        "              int0=UselessItemData(dwd1,2);",
                        "              ScriptItemData(dwd0,1,ScriptItemData(dwd0,1)+int0);",
                        "  //рассчитываем на сколько сломается очиститель в этом ходу",
                        "              int0=ItemFragility(dwd0)*100;",
                        "              int0=int0*Rnd(0,3);",
                        "              int0=int0/100;",
                        "  //так как юзлесы не ломаются сами по себе, ломаем вручную",
                        "              ItemDurability(dwd0,ItemDurability(dwd0)-int0);",
                        "              if(ItemDurability(dwd0)<1)ItemDurability(dwd0,0);",
                        "              int0=ItemDurability(dwd0);",
                        "              if(int0<1)Ether(8,'ref_'+a+'_full', Format(CT('mod_exptcplus.Refiner.BrokenInUse'),'[planet]',ScriptItemTextData(dwd0,1),'[name]',Name(dwd0)));",
                        "  //если очиститель добыл максимально возможное кол-во ресурса",
                        "              if(ScriptItemData(dwd0,1)>=UselessItemData(dwd1,1))",
                        "                  {",
                        "                  ScriptItemData(dwd0,1,UselessItemData(dwd1,1));",
                        "  //следующий ход добычи будет нескоро...",
                        "                  ScriptItemData(dwd0,2,CurTurn()+99999);",
                        "                  Ether(2,'ref_'+a+'_full', Format(CT('mod_exptcplus.Refiner.ref_full'),'[planet]',ScriptItemTextData(dwd0,1),'[name]',Name(dwd0)));",
                        "                  }",
                        "  //включаем нужные панельки и меняем изображение очистителя, если игрок на планете очистителя                ",
                        "              if(Name(GetShipPlanet(Player()))==ScriptItemTextData(dwd0,1))",
                        "                  {",
                        "                  InterfaceImage('PlanetNO','ref_btn3','GI,Bm.Items.2mtcp_RefinerRes'+ScriptItemData(dwd0,3)+'0_s');",
                        "                  InterfaceState('PlanetNO','GetResButton',1);",
                        "                  }",
                        "              }",
                        "          }",
                        "  //формируем общую строку для текста эзера очистителей",
                        "      if(ScriptItemData(dwd0,1)>=UselessItemData(dwd1,1))int0=-1;",
                        "      if(int0>0)str1=Format(str1,'[state]',CT('mod_exptcplus.Refiner.ref_wrk'));",
                        "      if(int0<=0)str1=Format(str1,'[state]',CT('mod_exptcplus.Refiner.ref_no_wrk'));",
                        "      str1=Format(str1,'[name]',Name(dwd0));",
                        "      str1=Format(str1,'[planet]',ScriptItemTextData(dwd0,1),'[star]',ScriptItemTextData(dwd0,2));",
                        "      str1=Format(str1,'[res_type]',CT('mod_exptcplus.Refiner.res'+ScriptItemData(dwd0,3)));",
                        "      str1=Format(str1,'[count]',ScriptItemData(dwd0,1),'[max_count]',UselessItemData(dwd1,1));",
                        "      str1=Format(str1,'[add_count]',UselessItemData(dwd1,2),'[turns]',UselessItemData(dwd1,3));",
                        "      str1=Format(str1,'[durab]',ItemDurability(dwd1));",
                        "      str0=str0+str1;",
                        "      }",
                        "  //обновляем эзер о очистителях",
                        "  if(str0!='')",
                        "      {",
                        "      str0=CT('mod_exptcplus.Refiner.ether')+str0;",
                        "      CustomEther('RefinerEther',3,'ref_ether', str0);",
                        "      }",
                        "}"
                    ],
                    "#": 47,
                    "Type": "Top",
                    "Parent": -1,
                    "Pos.x": 120,
                    "Pos.y": 685
                },
                {
                    "Name": "",
                    "Code.Type": "DialogBegin",
                    "Code": [
                        "if(GetShipRuins(Player())) {",
                        "  if(ShipType(GetShipRuins(Player())) == 'TC') {",
                        "    AddDialogInject('TCp0','',CT(\"Script.mod_exptcplus.40\"),3);",
                        "    AddDialogInject('TCp1','',CT(\"Script.mod_exptcplus.60\"),4);",
                        "  }",
                        "}"
                    ],
                    "#": 48,
                    "Type": "Top",
                    "Parent": -1,
                    "Pos.x": 180,
                    "Pos.y": 685
                },
                {
                    "Name": "",
                    "Code.Type": "Turn",
                    "Code": [
                        "//при совмещении с оружием пуха находтся в ваулте, её и стреляем в акткоде инфошки",
                        "if(CurTurn()>clear_array)",
                        "    {",
                        "    clear_array=CurTurn()+180;",
                        "//проверяем существование совмещёнки с оружием, если не существует, достаём пуху из ваулта и удаляем",
                        "    for(a=ArrayDim(toDel)-1;a>0;a=a-1)",
                        "        {",
                        "        dwd0=IdToItem(toDel[a]);",
                        "        if(dwd0)continue;",
                        "        dwd0=GetItemFromVault(GetVariableName(toDel[a]));",
                        "        FreeItem(dwd0);",
                        "        ArrayDelete(toDel, a);",
                        "        }",
                        "    }",
                        "ArrayClear(shipItem);",
                        "int0=FindBonusByCustomTag('mod_exptcplus_frag_minus_30');",
                        "//создаём список оборудки в трюме которую можно совместить(экипированная)",
                        "for(a=0;a<ShipItems(Player());a=a+1)",
                        "    {",
                        "    dwd0=ShipItems(Player(),a);",
                        "    if(!ItemIsInUse(dwd0))continue;",
                        "    if(ItemInScript(dwd0))continue;",
                        "    if(ItemDurability(dwd0)<80)continue;",
                        "    if(ItemOwner(dwd0) == None)continue;",
                        "    if(ItemOwner(dwd0) == Kling)continue;",
                        "    if(ItemType(dwd0)<t_FuelTanks)continue;",
                        "    if(ItemType(dwd0)==t_FuelTanks && !ItemImprovement(dwd0))continue;",
                        "    if(ItemType(dwd0)>t_CustomWeapon)continue;",
                        "    if(ItemType(dwd0)==t_Engine)continue;",
                        "    if(!ShipCanRepairEq(Player(), dwd0))continue;",
                        "    if(EqCustomFaction(dwd0)!= '' && ItemLevel(dwd0) > GalaxyTechLevel())continue;",
                        "    if(ItemExtraSpecialsCountByType(dwd0, int0)>0)continue;",
                        "    int0 = EqSpecial(dwd0);",
                        "    if(CT('MicroModuls.' + BonusNumInCfg(int0) + '.BlockImp'))continue;",
                        "    if(ItemType(dwd0)>t_DefGenerator)",
                        "        {",
                        "        if(GetEquipmentStats(dwd0, 3) == 2)continue;",
                        "        }",
                        "    ArrayAdd(shipItem,dwd0,CT(\"Script.mod_exptcplus.38\")+' '+DeleteTags(Name(dwd0)));",
                        "    }",
                        "//создаём список оборудки в трюме которую можно совместить(не экипированная)",
                        "//2 разных цикла чтобы экипированная всегда была в начале списка",
                        "//если ебашить всё в один цикл экипированная может быть после не экипированной",
                        "for(a=0;a<ShipItems(Player());a=a+1)",
                        "    {",
                        "    dwd0=ShipItems(Player(),a);",
                        "    if(ItemIsInUse(dwd0))continue;",
                        "    if(ItemInScript(dwd0))continue;",
                        "    if(ItemDurability(dwd0)<80)continue;",
                        "    if(ItemOwner(dwd0) == None)continue;",
                        "    if(ItemOwner(dwd0) == Kling)continue;",
                        "    if(ItemType(dwd0)<t_FuelTanks)continue;",
                        "    if(ItemType(dwd0)==t_FuelTanks && !ItemImprovement(dwd0))continue;",
                        "    if(ItemType(dwd0)>t_CustomWeapon)continue;",
                        "    if(ItemType(dwd0)==t_Engine)continue;",
                        "    if(!ShipCanRepairEq(Player(), dwd0))continue;",
                        "    if(EqCustomFaction(dwd0)!= '' && ItemLevel(dwd0) > GalaxyTechLevel())continue;",
                        "    if(ItemExtraSpecialsCountByType(dwd0, int0)>0)continue;",
                        "    int0 = EqSpecial(dwd0);",
                        "    if(CT('MicroModuls.' + BonusNumInCfg(int0) + '.BlockImp'))continue;",
                        "    if(ItemType(dwd0)>t_DefGenerator)",
                        "        {",
                        "        if(GetEquipmentStats(dwd0, 3) == 2)continue;",
                        "        }",
                        "    ArrayAdd(shipItem,dwd0,CT(\"Script.mod_exptcplus.37\")+' '+DeleteTags(Name(dwd0)));",
                        "    }",
                        "DChange(0);",
                        "exit;"
                    ],
                    "#": 90,
                    "Type": "Top",
                    "Parent": -1,
                    "Pos.x": -20,
                    "Pos.y": 425
                },
                {
                    "Name": "",
                    "Code.Type": "Turn",
                    "Code": [
                        "int0=0;",
                        "item1=shipItem[GAnswerData];",
                        "//проверяем есть ли у игрока что-то что можно совместить с выбранным предметом",
                        "for(a=1;a<ArrayDim(shipItem);a=a+1)",
                        "    {",
                        "    if(shipItem[a]==item1)continue;",
                        "    if(ItemType(item1)!=t_RepairRobot)",
                        "        {",
                        "        if(ItemType(shipItem[a])!=t_RepairRobot && ItemType(shipItem[a])!=t_DefGenerator)continue;",
                        "        }",
                        "    if(ItemType(item1)==t_RepairRobot)",
                        "        {",
                        "        if(ItemType(shipItem[a])<t_Weapon1 && ItemType(shipItem[a])!=t_RepairRobot && ItemType(shipItem[a])!=t_DefGenerator)continue;",
                        "        }",
                        "    int0=1;",
                        "    break;",
                        "    }",
                        "int1=FindBonusByCustomTag('mod_exptcplus_enrg');",
                        "if(ItemExtraSpecialsCountByType(item1,int1)<1)int0=1;",
                        "if(int0) {",
                        "  DChange(2);",
                        "  exit;",
                        "}",
                        "if(!int0) {",
                        "  DChange(1);",
                        "  exit;",
                        "}"
                    ],
                    "#": 91,
                    "Type": "Top",
                    "Parent": -1,
                    "Pos.x": 100,
                    "Pos.y": 425
                },
                {
                    "Name": "",
                    "Code.Type": "Turn",
                    "Code": [
                        "stat1=0;stat2=0;",
                        "size1=0;size2=0;",
                        "frag1=0;frag2=0;",
                        "//проверяем вес, надежность обоих предметов на совмещение",
                        "//вес совмещяемого предмета не должен быть больше совмещенного предмета",
                        "//надежность обоих предметов не должна быть ниже \"нормальной\"",
                        "if(ItemFragility(item1)>1.49)str0=CT('FormInfo.Equipment.QualityGrade6');",
                        "if(ItemFragility(item1)<1.50)str0=CT('FormInfo.Equipment.QualityGrade5');",
                        "if(ItemFragility(item1)<1.30)str0=CT('FormInfo.Equipment.QualityGrade4');",
                        "if(ItemFragility(item1)<1.10)str0=CT('FormInfo.Equipment.QualityGrade3');",
                        "if(ItemFragility(item1)<0.95)str0=CT('FormInfo.Equipment.QualityGrade2');",
                        "if(ItemFragility(item1)<0.85)str0=CT('FormInfo.Equipment.QualityGrade1');",
                        "if(ItemFragility(item1)<0.75)str0=CT('FormInfo.Equipment.QualityGrade0');",
                        "if(ItemFragility(item1)>1.10)frag1=1;",
                        "if(ItemType(item1)==t_RepairRobot && GetEquipmentStats(item1,0)<6)stat1=1;",
                        "if(ItemType(item1)==t_DefGenerator && GetEquipmentStats(item1,0)<6)stat1=1;",
                        "if(GAnswerData>0)",
                        "    {",
                        "    item2=shipItem[GAnswerData];",
                        "    item2Name=DeleteTags(Name(item2));",
                        "    int0=ItemSize(item1)*10;",
                        "    int0=int0/ItemSize(item2);",
                        "    if(int0<10)size2=1;",
                        "    if(ItemFragility(item2)>1.49)str1=CT('FormInfo.Equipment.QualityGrade6');",
                        "    if(ItemFragility(item2)<1.50)str1=CT('FormInfo.Equipment.QualityGrade5');",
                        "    if(ItemFragility(item2)<1.30)str1=CT('FormInfo.Equipment.QualityGrade4');",
                        "    if(ItemFragility(item2)<1.10)str1=CT('FormInfo.Equipment.QualityGrade3');",
                        "    if(ItemFragility(item2)<0.95)str1=CT('FormInfo.Equipment.QualityGrade2');",
                        "    if(ItemFragility(item2)<0.85)str1=CT('FormInfo.Equipment.QualityGrade1');",
                        "    if(ItemFragility(item2)<0.75)str1=CT('FormInfo.Equipment.QualityGrade0');",
                        "    if(ItemFragility(item2)>1.10)frag2=1;",
                        "    if(ItemType(item2)==t_RepairRobot && GetEquipmentStats(item2,0)<6)stat2=1;",
                        "    if(ItemType(item2)==t_DefGenerator && GetEquipmentStats(item2,0)<6)stat2=1;",
                        "    }",
                        "else",
                        "    {",
                        "    item2Name=CT(\"Script.mod_exptcplus.34\");",
                        "    int0=ItemSize(item1)/10;",
                        "    if(int0<1)size2=1;",
                        "    item2=1;",
                        "    }",
                        "if(ItemSize(item1)<10)size1=1;",
                        "item1Name=DeleteTags(Name(item1));",
                        "if((stat1 + stat2 + frag1 + frag2 + size1 + size2) == 0) {",
                        "  if(item2>100)",
                        "      {",
                        "      if(ItemType(item2)==t_RepairRobot)str0=CT(\"Script.mod_exptcplus.18\")+GetEquipmentStats(item2,0);",
                        "      if(ItemType(item2)==t_DefGenerator)str0=CT(\"Script.mod_exptcplus.17\")+' '+GetEquipmentStats(item2,0)+CT(\"Script.mod_exptcplus.10\");",
                        "      if(ItemType(item2)>t_DefGenerator)str0=CT(\"Script.mod_exptcplus.16\");",
                        "      int0=ItemCost(item2) + GalaxyTechLevel() * 10000;",
                        "      }",
                        "  else",
                        "      {",
                        "  //при выборе Энергогенератора нету второго предмета",
                        "      if(item2==1)str0=CT(\"Script.mod_exptcplus.36\")+CT('MicroModuls.mod_exptcplus_enrg.mod_exptcplus_enrg_bonus')+CT(\"Script.mod_exptcplus.35\");",
                        "      int0=GalaxyTechLevel() * 10000;",
                        "      }",
                        "  DChange(3);",
                        "  exit;",
                        "}",
                        "if((stat1 + stat2 + frag1 + frag2 + size1 + size2) != 0) {",
                        "  str2='';",
                        "  if(frag1==1)str2=str2+Format(CT(\"Script.mod_exptcplus.26\"),\"<0>\",item1Name)+' '+str0+CT(\"Script.mod_exptcplus.25\");",
                        "  if(frag2==1)str2=str2+Format(CT(\"Script.mod_exptcplus.26\"),\"<0>\",item2Name)+' '+str1+CT(\"Script.mod_exptcplus.25\");",
                        "  if(size1==1)str2=str2+Format(CT(\"Script.mod_exptcplus.32\"),\"<0>\",item1Name);",
                        "  if(size2==1)str2=str2+Format(CT(\"Script.mod_exptcplus.31\"),\"<0>\",item2Name,\"<1>\",item1Name);",
                        "  if(stat1==1)str2=str2+Format(CT(\"Script.mod_exptcplus.24\"),\"<0>\",item1Name);",
                        "  if(stat2==1)str2=str2+Format(CT(\"Script.mod_exptcplus.24\"),\"<0>\",item2Name);",
                        "  str2=str2+CT(\"Script.mod_exptcplus.30\");",
                        "  DChange(4);",
                        "  exit;",
                        "}"
                    ],
                    "#": 92,
                    "Type": "Top",
                    "Parent": -1,
                    "Pos.x": 220,
                    "Pos.y": 425
                },
                {
                    "Name": "",
                    "Code.Type": "Turn",
                    "Code": [
                        "//рассчитываем максимальное кол-во очистителей",
                        "RefinerMax=2 + ShipSkill(Player(),'TechnicalCur');",
                        "if(RefinerMax>8)RefinerMax=8;",
                        "//проверяем кол-во очистителей у игрока",
                        "RefinerCount=0;",
                        "for(a=1;a<9;a=a+1)",
                        "    {",
                        "    dwd0=GetValueFromScript('mod_exptcplus','mod_exptcplus_Refiner'+a);",
                        "    if(ScriptItemToItem(dwd0)==0)continue;",
                        "    RefinerCount=RefinerCount+1;",
                        "    }",
                        "//выбираем новый тип очистителя, если ещё не выбрали в этом ходу",
                        "if(RefinerNewType!=CurTurn())",
                        "    {",
                        "    RefinerNewType=CurTurn();",
                        "    //CurRefiner[1] системное имя очистителя",
                        "    //CurRefiner[2] название очистителя",
                        "    //CurRefiner[3] описание очистителя",
                        "    //CurRefiner[4] размер очистителя",
                        "    //CurRefiner[5] раса очистителя",
                        "    //CurRefiner[6] цена очистителя",
                        "    //CurRefiner[7] надежность очистителя текстовой строкой",
                        "    ArrayClear(arr0);",
                        "    ArrayClear(arr1);ArrayDelete(arr1,0);",
                        "    int0=CT('UselessItems',arr0);",
                        "    for(a=0;a<int0;a=a+1)",
                        "        {",
                        "        int1=CT('UselessItems.'+GetVariableName(arr0[a])+'.mod_exptcplus');",
                        "        if(int1!=1)continue;",
                        "        int1=CT('UselessItems.'+GetVariableName(arr0[a])+'.GTU');",
                        "        if(GalaxyTechLevel()<int1)continue;",
                        "        ArrayAdd(arr1,GetVariableName(arr0[a]));",
                        "        }",
                        "    int0=Rnd(1,ArrayDim(arr1)-1);",
                        "    CurRefiner[1]=arr1[int0];",
                        "    CurRefiner[2]=CT('UselessItems.'+CurRefiner[1]+'.Name');",
                        "    str0=CT('UselessItems.'+CurRefiner[1]+'.Text');",
                        "    str0=Format(str0,'<','','>','');",
                        "    str0='</color>'+str0;",
                        "    str0=Format(str0,'Data1',CT('UselessItems.'+CurRefiner[1]+'.Tank'));",
                        "    str0=Format(str0,'Data2',CT('UselessItems.'+CurRefiner[1]+'.Production_Count'));",
                        "    str0=Format(str0,'Data3',CT('UselessItems.'+CurRefiner[1]+'.Production_Days'));",
                        "    str0=Format(str0,'[durability]',100);",
                        "    CurRefiner[3]=str0;",
                        "    CurRefiner[4]=CT('UselessItems.'+CurRefiner[1]+'.Size');",
                        "    CurRefiner[5]=Rnd(0,4);",
                        "    int0=GalaxyMoney(4,CurRefiner[5]);",
                        "    int1=CT('UselessItems.'+CurRefiner[1]+'.Cost_Add');",
                        "    int0=int0 + (int0 * int1) / 100;",
                        "    CurRefiner[6]=int0;",
                        "    if(CurRefiner[5]==0)str0=CT('FormInfo.Equipment.QualityGrade5');",
                        "    if(CurRefiner[5]==1)str0=CT('FormInfo.Equipment.QualityGrade4');",
                        "    if(CurRefiner[5]==2)str0=CT('FormInfo.Equipment.QualityGrade3');",
                        "    if(CurRefiner[5]==3)str0=CT('FormInfo.Equipment.QualityGrade2');",
                        "    if(CurRefiner[5]==4)str0=CT('FormInfo.Equipment.QualityGrade1');",
                        "    CurRefiner[7]=str0;",
                        "    }",
                        "//проверяем есть ли у игрока в трюме ресурсы на продажу и поломанные очистители для ремонта",
                        "//очистители это юзлесы, а юзлесы нельзя чинить обычным способом, поэтому только так через диалог",
                        "getRes=0;RefinerFix=0;",
                        "for(a=0;a<ShipItems(Player());a=a+1)",
                        "    {",
                        "    dwd0=ShipItems(Player(),a);",
                        "    if(ItemType(dwd0)!=t_UselessCountableItem && ItemType(dwd0)!=t_UselessItem)continue;",
                        "    if(ItemType(dwd0)==t_UselessCountableItem)",
                        "        {",
                        "        if(findsubstr(EquipmentImageName(dwd0), 'mtcp_RefinerRes')!=-1)getRes=1;",
                        "        }",
                        "    if(ItemInScript(dwd0))",
                        "        {",
                        "        if(ItemType(dwd0)==t_UselessItem)",
                        "            {",
                        "            if(ItemDurability(dwd0)<95)",
                        "                {",
                        "                if(CT('UselessItems.'+EquipmentImageName(dwd0)+'.mod_exptcplus')==1)RefinerFix=1;",
                        "                }",
                        "            }",
                        "        }",
                        "    if((getRes + RefinerFix) == 2)break;",
                        "    }",
                        "DChange(6);",
                        "exit;"
                    ],
                    "#": 93,
                    "Type": "Top",
                    "Parent": -1,
                    "Pos.x": 340,
                    "Pos.y": 425
                },
                {
                    "Name": "",
                    "Code.Type": "Turn",
                    "Code": [
                        "Sound('Sound.Repair');",
                        "//чиним поломанный очиститель",
                        "if(GAnswerData!=-1)",
                        "    {",
                        "    dwd0=ShipItems(Player(),arr0[GAnswerData]);",
                        "    ItemDurability(dwd0,100);",
                        "    UselessItemText(dwd0,Format(CT('UselessItems.'+EquipmentImageName(dwd0)+'.Text'),'[durability]',100));",
                        "    ShipMoney(Player(),ShipMoney(Player()) - arr1[GAnswerData]);",
                        "    ArrayDelete(arr0,GAnswerData);ArrayDelete(arr1,GAnswerData);",
                        "    }",
                        "//или все поломанные очистители",
                        "if(GAnswerData==-1)",
                        "    {",
                        "    ShipMoney(Player(),ShipMoney(Player()) - int1);",
                        "    for(a=0;a<ShipItems(Player());a=a+1)",
                        "        {",
                        "        dwd0=ShipItems(Player(),a);",
                        "        if(!ItemInScript(dwd0))continue;",
                        "        if(ItemType(dwd0)!=t_UselessItem)continue;",
                        "        if(ItemDurability(dwd0)>94)continue;",
                        "        if(CT('UselessItems.'+EquipmentImageName(dwd0)+'.mod_exptcplus')!=1)continue;",
                        "        ItemDurability(dwd0,100);",
                        "        UselessItemText(dwd0,Format(CT('UselessItems.'+EquipmentImageName(dwd0)+'.Text'),'[durability]',100));",
                        "        }",
                        "    }",
                        "ArrayClear(arr0); ArrayDelete(arr0,0);",
                        "ArrayClear(arr1); ArrayDelete(arr1,0);",
                        "int1=0;str0='</color>';",
                        "//создаем массив с поломанными очистителями",
                        "for(a=0;a<ShipItems(Player());a=a+1)",
                        "    {",
                        "    dwd0=ShipItems(Player(),a);",
                        "    if(!ItemInScript(dwd0))continue;",
                        "    if(ItemType(dwd0)!=t_UselessItem)continue;",
                        "    if(ItemDurability(dwd0)>94)continue;",
                        "    if(CT('UselessItems.'+EquipmentImageName(dwd0)+'.mod_exptcplus')!=1)continue;",
                        "    ArrayAdd(arr0,a,Name(dwd0));",
                        "    int0=ItemCost(dwd0) - (ItemCost(dwd0) * ItemDurability(dwd0)) / 100;",
                        "    ArrayAdd(arr1,int0);",
                        "    str0=str0+CT(\"Script.mod_exptcplus.61\")+Name(dwd0)+Format(CT(\"Script.mod_exptcplus.55\"),\"<0>\",int0);",
                        "    int1=int1+int0;",
                        "    }",
                        "if(ArrayDim(arr0)>0) {",
                        "  DChange(10);",
                        "  exit;",
                        "}",
                        "if(ArrayDim(arr0)<=0) {",
                        "  DChange(11);",
                        "  exit;",
                        "}"
                    ],
                    "#": 94,
                    "Type": "Top",
                    "Parent": -1,
                    "Pos.x": 460,
                    "Pos.y": 425
                },
                {
                    "Name": "",
