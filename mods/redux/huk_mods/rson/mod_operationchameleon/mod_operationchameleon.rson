                        "else dText=Format(CT(\"Script.mod_operationchameleon.24\"),\"<0>\",str0,\"<1>\",int0,\"<2>\",Name(buyPla),\"<3>\",str1,\"<4>\",int1);",
                        "DChange(2);",
                        "exit;"
