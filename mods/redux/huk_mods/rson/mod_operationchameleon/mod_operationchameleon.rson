                        "if(ShipOwner(ship)!=7)RelationToRanger(buyPla,Player(),10);",
                        "else RelationToRanger(PlanetPirateClan(),Player(),10);",
                        "//прячем и уничтожаем домиков-хамелеонов, на их место переносим настоящих хамелеонов",
                        "for(a=0;a<GroupCount(chameleons);a=a+1)",
                        "    {",
                        "    ship=GroupShip(chameleons,a);",
                        "    dwd0=GroupShip(true_chameleons,a);",
                        "    TransferShip(dwd0,AttackStar);",
                        "    ShipSetCoords(dwd0,CoordX(ship),CoordY(ship));",
                        "    ShipKillFactionInCurSystem(dwd0,1,20);",
                        "    if(ShipOrderObj(ship))",
                        "        {",
                        "        ShipOrder(dwd0,ShipOrder(ship));",
                        "        ShipOrderObj(dwd0,ShipOrderObj(ship));",
                        "        }",
