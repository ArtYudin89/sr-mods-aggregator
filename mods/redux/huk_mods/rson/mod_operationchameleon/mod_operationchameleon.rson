            ],
            "Items": [],
            "Operations": [
                {
                    "Name": "",
                    "Code.Type": "Global",
                    "Code": [
                        "if(GRunFrom==2 && CurTurn()>nextRaid) {",
                        "  GRun();",
                        "}"
                    ],
                    "#": 33,
                    "Type": "Top",
                    "Parent": -1,
                    "Pos.x": 0,
                    "Pos.y": 610
                },
                {
                    "Name": "",
                    "Code.Type": "Init",
                    "Code": [
                        "//скрипт стартует когда игрок прилетает в систему домиков",
                        "//проверяется раз в 10 ходов если не запустился(scrState=4)",
                        "//или через 120 ходов если ситуация нормально отигралась ",
                        "nextRaid=CurTurn()+30;",
                        "//куча дополнительных условий на запуск скрипта",
                        "int0=round(sqrt(Dist2Star(FromThis, AttackStar)));",
                        "if(int0>25)scrState=4;",
                        "if(StarToCon(FromThis) == StarToCon(PlanetToStar(PlanetPirateClan())))scrState=4;",
                        "if(RelationToShip(buyPla,Player())<30)scrState=4;",
                        "if(PlanetOwner(buyPla)<5 && ControlledSystems(0)<10)scrState=4;",
                        "if(PlanetOwner(buyPla)==7 && ControlledSystems(2)<13)scrState=4;",
                        "//SFT(scrState);",
                        "if(Blazer())",
                        "    {",
                        "    if(ShipStar(Blazer())==AttackStar)scrState=4;",
                        "    }",
                        "if(Keller())",
                        "    {",
                        "    if(ShipStar(Keller())==AttackStar)scrState=4;",
                        "    }",
                        "if(Terron())",
                        "    {",
                        "    if(ShipStar(Terron())==AttackStar)scrState=4;",
                        "    }",
                        "if(StarBattle(AttackStar))scrState=4;",
                        "if(StarBattle(FromThis))scrState=4;",
                        "if(StarShips(AttackStar)<8)scrState=4;",
                        "if(StarShips(AttackStar)>16)scrState=4;",
                        "if(NoComeKlingToStar(AttackStar))scrState=4;",
                        "if(NoComeKlingToStar(FromThis))scrState=4;",
                        "if(StarCustomFaction(AttackStar)!='')scrState=4;",
                        "if(StarCustomFaction(FromThis)!='')scrState=4;",
                        "int0=0;",
                        "for(a=0;a<StarShips(AttackStar);a=a+1)",
                        "    {",
                        "    ship=StarShips(AttackStar,a);",
                        "    if(ShipOwner(ship)!=5)continue;",
                        "    if(ShipCustomFaction(ship)!='')int0=1;",
                        "    if(ShipInScript(ship) && !ShipInCurScript(ship))int0=1;",
                        "    }",
                        "if(int0==1)scrState=4;",
                        "//scrState=4; означает что скрипт завершится на следующем ходу",
                        "//NewsAdd('attack: '+Name(AttackStar)+' from this: '+Name(FromThis)+' GLastTurnRun '+GLastTurnRun('mod_operationchameleon')+' curturn '+CurTurn()+' scrState '+scrState);"
                    ],
                    "#": 34,
                    "Type": "Top",
                    "Parent": -1,
                    "Pos.x": 60,
                    "Pos.y": 610
                },
                {
                    "Name": "",
                    "Code.Type": "Turn",
                    "Code": [
                        "if(!ShipIsTakeoff(Player())) {",
                        "  if(scrState==0) {",
                        "    //хамелеоны получают бонусы от мода tryfixbalance, если подключен",
                        "    curMods_copy=CurrentMods(-1);",
                        "    if(findsubstr(curMods_copy,'Mod_TryFixBalance')!=0)",
                        "        {",
                        "        if(IsScriptActive('mod_tryfixbalance'))",
                        "            {",
                        "            curMods_copy=GetValueFromScript('mod_tryfixbalance','curEnemy');",
                        "            if(curMods_copy!='not_start')",
                        "                {",
                        "                CurBalanceLevel_copy=GetValueFromScript('mod_tryfixbalance','CurBalanceLevel');",
                        "                ArrayClear(agHull);",
                        "                str0=CT(curMods_copy+'.Attack_Group.Hull.Special');",
                        "                if(str0!='')ArrayAdd(agHull,'Special',str0);",
                        "                str0=CT(curMods_copy+'.Attack_Group.Hull.ExtraSpecial');",
                        "                if(str0!='')ArrayAdd(agHull,'ExtraSpecial',str0);",
                        "                ArrayClear(agBon);",
                        "                int0=CT(curMods_copy+'.Attack_Group.SpecialBonuses',arr0);",
                        "                for(a=0;a<int0;a=a+1)",
                        "                    {",
                        "                    ArrayAdd(agBon,arr0[a],GetVariableName(arr0[a]));",
                        "                    }",
                        "                //NewsAdd('mod find. cur enemy '+curMods_copy);",
                        "                }",
                        "            }",
                        "        }",
                        "    int0=StarSeries(FromThis);",
                        "    int1=StarShips(AttackStar);",
                        "    domSer=StarSeries(AttackStar);",
                        "    StarSeries(FromThis,StarSeries(AttackStar));",
                        "    //спавним домиков нужной серии и отправляем их в атакуемую систему",
                        "    for(a=0;a<int1;a=a+1)",
                        "        {",
                        "        ship=BuyDomikExtremal(buyPla,Rnd(3,5));",
                        "        item=ShipEqInSlot(ship,t_Engine);",
                        "        if(item)",
                        "            {",
                        "            if(ItemLevel(item)<GalaxyTechLevel())ItemLevel(item,GalaxyTechLevel());",
                        "            if(!ItemImprovement(item))ItemImprovement(item,2,1);",
                        "            }",
                        "        ShipAddCustomShipInfo(ship, 'Mod_OperationChameleon0');",
                        "        ShipJoin(chameleons,ship);",
                        "        MakeShipEnterStar(ship,AttackStar,FromThis,ShipOrderData1(Player())+3);",
                        "        }",
                        "    //возвращаем серию домиков на ту которая была изначально, на всякий случай",
                        "    StarSeries(FromThis,int0);",
                        "    //создаем вояк хамелеонов",
                        "    for(a=0;a<int1;a=a+1)",
                        "        {",
                        "        ship=BuyWarrior(buyPla);",
                        "        ShipAddCustomShipInfo(ship, 'Mod_OperationChameleon2','NoShow');",
                        "        //NoDropToShip(ship,1);",
                        "        ShipRefit(ship);ShipRefit(ship);",
                        "        ShipRefit(ship);ShipRefit(ship);",
                        "        item=ShipEqInSlot(ship,t_Hull);",
                        "        if(ItemSize(item)<800)ItemSize(item, 800);",
                        "        HullHP(ship,'To100');",
                        "        HullSeries(ShipEqInSlot(ship,t_Hull),FindSeriesByName(CT('HullType.32.Name')));",
                        "        if(ShipSlots(ship,5)<1)ShipSpecialBonuses(ship,bonSlotDroid,1);",
                        "        ShipSpecialBonuses(ship,bonSlotHook,-10);",
                        "        if(ShipSlots(ship,7)<1)ShipSpecialBonuses(ship,bonSlotDef,1);",
                        "        if(ShipEqInSlot(ship,t_DefGenerator)==0)",
                        "            {",
                        "            item=CreateEquipment(t_DefGenerator,20,GalaxyTechLevel(),ShipOwner(ship));",
                        "            AddItemToShip(ship,item);",
                        "            ItemIsInUse(item,ship,1);",
                        "            }",
                        "        if(ShipEqInSlot(ship,t_RepairRobot)==0)",
                        "            {",
                        "            item=CreateEquipment(t_RepairRobot,20,GalaxyTechLevel(),ShipOwner(ship));",
                        "            AddItemToShip(ship,item);",
                        "            ItemIsInUse(item,ship,1);",
                        "            }",
                        "        for(b=t_Hull;b<t_Weapon1;b=b+1)",
                        "            {",
                        "            item=ShipEqInSlot(ship,b);",
                        "            if(item==0)continue;",
                        "            if(ItemLevel(item)<GalaxyTechLevel())ItemLevel(item,GalaxyTechLevel());",
                        "            if(!ItemImprovement(item))ItemImprovement(item,2);",
                        "            }",
                        "        for(b=1;b<6;b=b+1)",
                        "            {",
                        "            item=ShipEqInSlot(ship,t_Weapon1,b);",
                        "            if(item==0 && ShipCntWeapon(ship)>=ShipSlots(ship,1))continue;",
                        "            if(item==0 && ShipCntWeapon(ship)<ShipSlots(ship,1))",
                        "                {",
                        "                item=CreateEquipment(t_Weapon3,20,GalaxyTechLevel(),ShipOwner(ship));",
                        "                AddItemToShip(ship,item);",
                        "                ItemIsInUse(item,ship,b);",
                        "                }",
                        "            if(ItemLevel(item)<GalaxyTechLevel())ItemLevel(item,GalaxyTechLevel());",
                        "            if(!ItemImprovement(item))ItemImprovement(item,2);",
                        "            }",
                        "        if(CurBalanceLevel_copy>0)",
                        "            {",
                        "            item=ShipEqInSlot(ship,t_Hull);",
                        "            int0=ArrayFind(agHull,'Special');",
                        "            if(int0>0)",
                        "                {",
                        "                bon=FindBonusByCustomTag(GetVariableName(agHull[int0]));",
                        "                if(EqSpecial(item)!=-1)EqSpecial(item,-1);",
                        "                if(bon>-1 && MayAddBonusToEq(bon,item))SpecialToEquipment(bon,item);",
                        "                }",
                        "            int0=ArrayFind(agHull,'ExtraSpecial');",
                        "            if(int0>0)",
                        "                {",
                        "                bon=FindBonusByCustomTag(GetVariableName(agHull[int0]));",
                        "                if(bon>-1 && CurBalanceLevel_copy>0)ItemExtraSpecialsAddByType(item,bon,CurBalanceLevel_copy);",
                        "                }",
                        "            if(ArrayDim(agBon)>1 && CurBalanceLevel_copy>0)",
                        "                {",
                        "                for(b=1;b<ArrayDim(agBon);b=b+1)",
                        "                    {",
                        "                    int0=GetValueFromScript('',GetVariableName(agBon[b]));",
                        "                    ShipSpecialBonuses(ship,int0,(CurBalanceLevel_copy*agBon[b]));",
                        "                    }",
                        "                }",
                        "            }",
                        "        ArrangeItems(ship);",
                        "        ShipJoin(true_chameleons,ship);",
                        "    //выставляем приказ ждать в гиппере",
                        "        MakeShipEnterStar(ship,AttackStar,FromThis,999);",
                        "        }",
                        "    scrState=1;",
                        "  }",
                        "  if(scrState==1 && GroupCount(chameleons)>0) {",
                        "    if(ShipInNormalSpace(GroupToShip(chameleons))) {",
                        "      //домики-хамелеоны влетают в атакуемую систему и кродутся к самому сильному кораблю target",
                        "      //один раз запускаем диалог dlg1",
                        "      int0=0;",
                        "      if(!IdToShip(target))int0=1;",
                        "      if(int0==1)",
                        "          {",
                        "          starDomiki=0;",
                        "          for(a=0;a<StarShips(AttackStar);a=a+1)",
                        "              {",
                        "              ship=StarShips(AttackStar,a);",
                        "              if(ShipOwner(ship)!=5)continue;",
                        "              if(ShipCustomFaction(ship)!='')continue;",
                        "              if(Blazer())",
                        "                  {",
                        "                  if(ship==Blazer())continue;",
                        "                  }",
                        "              if(Keller())",
                        "                  {",
                        "                  if(ship==Keller())continue;",
                        "                  }",
                        "              if(Terron())",
                        "                  {",
                        "                  if(ship==Terron())continue;",
                        "                  }",
                        "              if(ShipInScript(ship) && !ShipInCurScript(ship))continue;",
                        "              starDomiki=starDomiki+1;",
                        "              if(ShipGroup(ship)==chameleons)continue;",
                        "      //выбираем самый сильный корабль домиков в системе",
                        "              if(ShipAverageDamage(ship)<int0)continue;",
                        "              int0=ShipAverageDamage(ship);",
                        "              target=Id(ship);",
                        "              }",
                        "          }",
                        "      int0=0;int1=0;dwd0=IdToShip(target);",
                        "      for(a=0;a<GroupCount(chameleons);a=a+1)",
                        "          {",
                        "          ship=GroupShip(chameleons,a);",
                        "      //если игрок подстрелил домика-хамелеона выдаем диалог dlg3",
                        "          if(Hit(ship,0))int1=1;",
                        "      //обновляем приказ каждый ход, так как самый сильный корабль может сдохнуть раньше времени",
                        "          if(dwd0 && ShipOrderObj(ship)!=dwd0)",
                        "              {",
                        "              OrderLock(ship,0);",
                        "              OrderFollowShip(ship,dwd0,0,10);",
                        "              OrderLock(ship,1);",
                        "              }",
                        "      //если этот домик-хамелеон приблизился достаточно для скрытой атаки",
                        "          if(ShipOrder(ship)==6 && ShipTurnBeforeEndOrder(ship)<2)int0=int0+1;",
                        "          }",
                        "      //если игрок сваншотил домика=хамелеона",
                        "      if(ShipFindCustomShipInfoByType(Player(),'Mod_OperationChameleon9')!=-1)int1=1;",
                        "      //если домиков-хамелеонов достаточно для скрытой атаки",
                        "      if(int0>=GroupCount(chameleons)-(GroupCount(chameleons)/3))scrState=2;",
                        "      //если единственные домики в системе это домики-хамелеоны, значит игрок всех остальных убил раньше",
                        "      //скрытой атаки, запускаем диалог dlg2",
                        "      if(starDomiki==GroupCount(chameleons))scrState=10;",
                        "      //если игрок сваншотил домика=хамелеона или выстрелил по нему выдаем диалог dlg3",
                        "      if(int1==1)scrState=11;",
                        "      //если других домиков уже нету ещё до старта первого диалога о операции dlg1",
                        "      //делаем из домиков-хамелеонов обычных домиков и завершаем скрипт",
                        "      if(scrState==10 && dialog==0)",
                        "          {",
                        "          scrState=4;",
                        "          for(a=GroupCount(chameleons)-1;a>-1;a=a-1)",
                        "              {",
                        "              ship=GroupShip(chameleons,a);",
                        "              if(ShipFindCustomShipInfoByType(ship,'Mod_OperationChameleon0')!=-1)ShipDeleteCustomShipInfo(ship,'Mod_OperationChameleon0');",
                        "              ShipOut(ship);",
                        "              }",
                        "          }",
                        "    }",
                        "  }",
                        "  if(scrState==1 && GroupCount(chameleons)==0) {",
                        "    //если домики-хамелеоны как то сдохли все сразу завершаем скрипт",
                        "    scrState=4;",
                        "  }",
                        "  if(scrState==2 && GroupCount(chameleons)>0) {",
                        "    //перемещаем домиков-хамелеонов на планету, выставляем приказ ничего не делать",
                        "    //и заблочиваем им приказы. на из место(по координатам) спавним вояк-настоящих-хамелеонов",
                        "    //начинается скрытая атака",
                        "    for(a=0;a<GroupCount(chameleons);a=a+1)",
                        "        {",
                        "        ship=GroupShip(chameleons,a);",
                        "        dwd0=GroupShip(true_chameleons,a);",
                        "        ShipAddCustomShipInfo(dwd0, 'Mod_OperationChameleon1');",
                        "        TransferShip(dwd0,AttackStar);",
                        "        ShipSetCoords(dwd0,CoordX(ship),CoordY(ship));",
                        "        if(ShipOrderObj(ship))",
                        "            {",
                        "            ShipOrder(dwd0,ShipOrder(ship));",
                        "            ShipOrderObj(dwd0,ShipOrderObj(ship));",
                        "            OrderLock(dwd0,1);",
                        "            }",
                        "        TransferShip(ship,StarPlanets(AttackStar,0));",
                        "        OrderNone(ship,1);",
                        "        OrderLock(ship,1);",
                        "        ShipDestroy(ship,1);",
                        "        }",
                        "    scrState=3;",
                        "  }",
                        "  if(scrState==3 && GroupCount(true_chameleons)>0) {",
                        "    //проверяем чтобы игрок не стрелял по настоящим хамелеонам",
                        "    int1=0;",
                        "    for(a=0;a<GroupCount(true_chameleons);a=a+1)",
                        "        {",
                        "        ship=GroupShip(true_chameleons,a);",
                        "        if(Hit(ship,0))int1=1;",
                        "        }",
                        "    //или чтобы не ваншотил их",
                        "    if(ShipFindCustomShipInfoByType(Player(),'Mod_OperationChameleon9')!=-1)int1=1;",
                        "    if(int1==1)",
                        "        {",
                        "        scrState=4;",
                        "        ship=GroupToShip(true_chameleons);",
                        "        if(ShipOwner(ship)!=7)RelationToRanger(buyPla,Player(),0);",
                        "        else RelationToRanger(PlanetPirateClan(),Player(),0);",
                        "        }",
                        "    //проверяем число домиков в системе",
                        "    starDomiki=0;",
                        "    for(a=0;a<StarShips(AttackStar);a=a+1)",
                        "        {",
                        "        ship=StarShips(AttackStar,a);",
                        "        if(ShipOwner(ship)!=5)continue;",
                        "        if(ShipCustomFaction(ship)!='')continue;",
                        "        if(Blazer())",
                        "            {",
                        "            if(ship==Blazer())continue;",
                        "            }",
                        "        if(Keller())",
                        "            {",
                        "            if(ship==Keller())continue;",
                        "            }",
                        "        if(Terron())",
                        "            {",
                        "            if(ship==Terron())continue;",
                        "            }",
                        "        if(ShipInScript(ship) && !ShipInCurScript(ship))continue;",
                        "        starDomiki=starDomiki+1;",
                        "        if(ShipGroup(ship)==chameleons)continue;",
                        "        if(ShipAverageDamage(ship)<int0)continue;",
                        "        int0=ShipAverageDamage(ship);",
                        "        target=Id(ship);",
                        "        }",
                        "    //если игрок улетел из атакуемой системы завершаем скрипт",
                        "    if(dialog==-1 && starDomiki==0)scrState=4;",
                        "  }",
                        "  if(scrState==3 && GroupCount(true_chameleons)==0) {",
                        "    //если настоящие хамелеоны как то сдохли все сразу завершаем скрипт",
                        "    scrState=4;",
                        "  }",
                        "  if(scrState==4 && GroupCount(true_chameleons)>0) {",
                        "    //если какие-то настоящие хамелеоны остались в гиппере - уничтожаем их",
                        "    for(a=GroupCount(true_chameleons)-1;a>-1;a=a-1)",
                        "        {",
                        "        ship=GroupShip(true_chameleons,a);",
                        "        if(ShipInHyperSpace(ship))ShipDestroy(ship);",
                        "        }",
                        "    //если какие-то настоящие хамелеоны остались в атакуемой системе после",
                        "    //последнего диалога и игрок не в этой системе - уничтожаем их",
                        "    for(a=GroupCount(true_chameleons)-1;a>-1;a=a-1)",
                        "        {",
                        "        ship=GroupShip(true_chameleons,a);",
                        "        if(ShipStar(Player())==ShipStar(ship))continue;",
                        "        TransferShip(ship,StarPlanets(AttackStar,0));",
                        "        OrderNone(ship,1);",
                        "        OrderLock(ship,1);",
                        "        ShipDestroy(ship);",
                        "        ShipOut(ship);",
                        "        }",
                        "  }",
                        "  if(scrState==4 && GroupCount(true_chameleons)==0 && GroupCount(chameleons)==0) {",
                        "    scrState=5;",
                        "    if(ShipFindCustomShipInfoByType(Player(),'Mod_OperationChameleon9')!=-1)ShipDeleteCustomShipInfo(Player(),'Mod_OperationChameleon9');",
                        "    //если скрипт не смог запустится из-за условий, то следующая попытка через 10 ходов",
                        "    //если запустился, через 120 ходов",
                        "    if(domSer==-1)nextRaid=CurTurn()+10;",
                        "    else nextRaid=CurTurn()+120;",
                        "    //NewsAdd('script_end at '+CurTurn()+' GLastTurnRun '+GLastTurnRun('mod_operationchameleon')+' nextRaid '+nextRaid);",
                        "    //завершаем скрипт выкидывая игрока из него, на этом моменте он должен быть единственным кораблем",
                        "    ShipOut(Player());",
                        "  }",
                        "}"
                    ],
