                    "Type": "Top",
                    "Parent": -1,
                    "Pos.x": 120,
                    "Pos.y": 610
                },
                {
                    "Name": "",
                    "Code.Type": "Turn",
                    "Code": [
                        "if(ShipInNormalSpace(Player())) {",
                        "  if(dialog==0) {",
                        "    if(scrState==1 && GroupCount(chameleons)>0) {",
                        "      if(ShipInNormalSpace(GroupToShip(chameleons))) {",
                        "        //первый диалог, выставляем координаты и меняем тип домику для нужного портрета, запускаем диалог",
                        "        if(ShipStar(Player())==AttackStar && ShipInNormalSpace(Player()))",
                        "            {",
                        "            ShipSetCoords(GroupToShip(true_chameleons),CoordX(GroupToShip(chameleons)),CoordY(GroupToShip(chameleons)));",
                        "            str0=ShipType(GroupToShip(true_chameleons));str1=Name(GroupToShip(true_chameleons));",
                        "            ShipType(GroupToShip(true_chameleons),ShipType(GroupToShip(chameleons)));",
                        "            SetName(GroupToShip(true_chameleons),Name(GroupToShip(chameleons)));",
                        "            Dialog(dlg1,GroupToShip(true_chameleons));",
                        "            }",
                        "        else",
                        "            {",
                        "        //если игрок улетел из системы до запуска первого диалога...",
                        "        //скрипт продолжится без него и нормально отиграется, а потом завершится",
                        "            dialog=-1;starDomiki=0;int0=0;",
                        "            for(a=0;a<StarShips(AttackStar);a=a+1)",
                        "                {",
                        "                ship=StarShips(AttackStar,a);",
                        "                if(ShipOwner(ship)!=5)continue;",
                        "                if(ShipCustomFaction(ship)!='')continue;",
                        "                if(Blazer())",
                        "                    {",
                        "                    if(ship==Blazer())continue;",
                        "                    }",
                        "                if(Keller())",
                        "                    {",
                        "                    if(ship==Keller())continue;",
                        "                    }",
                        "                if(Terron())",
                        "                    {",
                        "                    if(ship==Terron())continue;",
                        "                    }",
                        "                if(ShipInScript(ship) && !ShipInCurScript(ship))continue;",
                        "                starDomiki=starDomiki+1;",
                        "                if(ShipGroup(ship)==chameleons)continue;",
                        "                if(ShipAverageDamage(ship)<int0)continue;",
                        "                int0=ShipAverageDamage(ship);",
                        "                target=Id(ship);",
                        "                }",
                        "            ship=IdToShip(target);",
                        "            if(ship)",
                        "                {",
                        "                for(a=0;a<GroupCount(chameleons);a=a+1)",
                        "                       {",
                        "                    dwd0=GroupShip(chameleons,a);",
                        "                    OrderFollowShip(dwd0,ship,0,10);",
                        "                    OrderLock(dwd0,1);",
                        "                    }",
                        "                }",
                        "            }",
                        "      }",
                        "    }",
                        "  }",
                        "  if(dialog==1) {",
                        "    if(scrState==10 && GroupCount(chameleons)>0) {",
                        "      if(ShipInNormalSpace(GroupToShip(chameleons))) {",
                        "        if(ShipStar(Player())==AttackStar && ShipInNormalSpace(Player()))",
                        "            {",
                        "            ShipSetCoords(GroupToShip(true_chameleons),CoordX(GroupToShip(chameleons)),CoordY(GroupToShip(chameleons)));",
                        "            Dialog(dlg2,GroupToShip(true_chameleons));",
                        "            }",
                        "      }",
                        "    }",
                        "    if(scrState==11 && GroupCount(chameleons)>0) {",
                        "      if(ShipInNormalSpace(GroupToShip(chameleons))) {",
                        "        if(ShipStar(Player())==AttackStar && ShipInNormalSpace(Player()))",
                        "            {",
                        "            ShipSetCoords(GroupToShip(true_chameleons),CoordX(GroupToShip(chameleons)),CoordY(GroupToShip(chameleons)));",
                        "            Dialog(dlg3,GroupToShip(true_chameleons));",
                        "            }",
                        "      }",
                        "    }",
                        "  }",
                        "  if(dialog!=-1) {",
                        "    if(scrState==3 && GroupCount(true_chameleons)>0) {",
                        "      if(starDomiki==0) {",
                        "        if(ShipStar(Player())==AttackStar && ShipInNormalSpace(Player()))",
                        "            {",
                        "            Dialog(dlgFnl,GroupToShip(true_chameleons));",
                        "            }",
                        "      }",
                        "    }",
                        "  }",
                        "}"
