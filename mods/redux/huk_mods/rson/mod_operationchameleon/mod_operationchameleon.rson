                        "    OrderNone(ship,1);",
                        "    OrderLock(ship,1);",
                        "    ShipDestroy(ship,1);",
                        "    }",
                        "Chameleon(ship,Chameleon(dwd0,'GraphName'),1);",
                        "if(ShipFindCustomShipInfoByType(Player(),'Mod_OperationChameleon9')!=-1)ShipDeleteCustomShipInfo(Player(),'Mod_OperationChameleon9');",
                        "scrState=3;"
                    ],
