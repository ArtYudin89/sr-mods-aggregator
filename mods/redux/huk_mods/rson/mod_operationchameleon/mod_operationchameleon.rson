                },
                {
                    "Name": "",
                    "Code.Type": "Turn",
                    "Code": [
                        "dialog=1;starDomiki=0;int0=0;",
                        "//перебираем всех домиков и выбираем самый сильный корабль",
                        "for(a=0;a<StarShips(AttackStar);a=a+1)",
                        "    {",
                        "    ship=StarShips(AttackStar,a);",
                        "    if(ShipOwner(ship)!=5)continue;",
                        "    if(ShipCustomFaction(ship)!='')continue;",
                        "    if(Blazer())",
                        "        {",
                        "        if(ship==Blazer())continue;",
                        "        }",
                        "    if(Keller())",
                        "        {",
                        "        if(ship==Keller())continue;",
                        "        }",
                        "    if(Terron())",
                        "        {",
                        "        if(ship==Terron())continue;",
                        "        }    if(ShipInScript(ship) && !ShipInCurScript(ship))continue;",
                        "    starDomiki=starDomiki+1;",
                        "    if(ShipGroup(ship)==chameleons)continue;",
                        "    if(ShipAverageDamage(ship)<int0)continue;",
                        "    int0=ShipAverageDamage(ship);",
                        "    target=Id(ship);",
                        "    }",
                        "//выставляем приках домика-хамелеонам следовать к самому сильному кораблю    ",
                        "ship=IdToShip(target);",
                        "if(ship)",
                        "    {",
                        "    for(a=0;a<GroupCount(chameleons);a=a+1)",
                        "        {",
                        "        dwd0=GroupShip(chameleons,a);",
                        "        OrderFollowShip(dwd0,ship,0,10);",
                        "        OrderLock(dwd0,1);",
                        "        }",
                        "    }",
                        "//меняем тип домика для диалога на обычный",
                        "ShipType(GetTalkShip(),str0);",
                        "SetName(GetTalkShip(),str1);"
                    ],
                    "#": 63,
                    "Type": "Top",
                    "Parent": -1,
                    "Pos.x": 100,
                    "Pos.y": 540
                },
                {
                    "Name": "",
                    "Code.Type": "Turn",
                    "Code": [
                        "dialog=2;",
                        "//даем игроку награду",
                        "dwd0=PlayerChameleonCharges(domSer)+int0;",
                        "PlayerChameleonCharges(domSer,dwd0);",
                        "SetProgramm(int2,GetProgramm(int2)+int1);",
                        "//прячем и удаляем домиков-хамелеонов, на их место перемещаем настоящих хамелеонов",
                        "for(a=0;a<GroupCount(chameleons);a=a+1)",
                        "    {",
                        "    ship=GroupShip(chameleons,a);",
                        "    dwd0=GroupShip(true_chameleons,a);",
                        "//чтобы система перешла к настоящим хамелеонам, а то может быть что операцию завершили коалы, а",
                        "//система перешла клану, так как игрок в клане и убил больше и наоборот    ",
                        "    ShipKillFactionInCurSystem(dwd0,1,20);",
                        "    TransferShip(dwd0,AttackStar);",
                        "    ShipSetCoords(dwd0,CoordX(ship),CoordY(ship));",
                        "    ShipFreeFlight(dwd0);",
                        "    TransferShip(ship,StarPlanets(AttackStar,0));",
                        "    OrderNone(ship,1);",
                        "    OrderLock(ship,1);",
                        "    ShipDestroy(ship,1);",
                        "    }",
                        "Chameleon(ship,Chameleon(dwd0,'GraphName'),1);",
                        "scrState=4;"
                    ],
