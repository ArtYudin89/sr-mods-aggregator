                {
                    "Name": "",
                    "Code.Type": "DialogBegin",
                    "Code": [
                        "if(GetShipPlanet(Player())) {",
                        "  if(RelationToRanger(GetShipPlanet(Player()),Player())>59 && mod_merchant_scrState == 2) {",
                        "    if(!StarBattle(ShipStar(Player())) && qst<=CurTurn()) {",
                        "      int0=ShipFindCustomShipInfoByType(Player(), 'AMod_Merchant_player');",
                        "      if(int0!=-1)",
                        "          {",
