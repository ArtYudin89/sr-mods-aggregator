            "Operations": [
                {
                    "Name": "",
                    "Code.Type": "Global",
                    "Code": [
                        "if(!GLastTurnRun(GScriptName)) {",
                        "  GRun();",
                        "}"
                    ],
                    "#": 29,
                    "Type": "Top",
                    "Parent": -1,
                    "Pos.x": 0,
                    "Pos.y": 635
                },
                {
                    "Name": "",
                    "Code.Type": "Init",
                    "Code": [
                        "//создаем и заполняем массивы",
                        "scrArr0 = newarray(1);",
                        "scrArr1 = newarray(1);",
                        "//массив для акринов корпусов торгашей",
                        "acryn = newarray(4);",
                        "acryn[1] = 'mod_merchant_acr0';",
                        "acryn[2] = 'mod_merchant_acr1';",
                        "acryn[3] = 'mod_merchant_acr2';",
                        "//изначально кол-во акринов = 3",
                        "acryn[0] = 3;",
                        "months = newarray(13, 2);",
                        "for (i = 1; i < 13; i = i + 1)",
                        "    {",
                        "    months[i, 0] = CT('mod_merchant.months.m'+i);",
                        "    months[i, 1] = CT('mod_merchant.months.f'+i);",
                        "    }",
                        "mod_merchantArr0 = newarray(12, 13);",
                        "for (i = 1; i < 9; i = i + 1)mod_merchantArr0[0, i] = 0;",
                        "for (i = 2; i < 12; i = i + 1)",
                        "    {",
                        "    for (j = 0; j < 13; j = j + 1)mod_merchantArr0[i, j] = 0;",
                        "    }"
                    ],
                    "#": 30,
                    "Type": "Top",
                    "Parent": -1,
                    "Pos.x": 60,
                    "Pos.y": 635
                },
                {
                    "Name": "",
                    "Code.Type": "Turn",
                    "Code": [
                        "if(!ShipIsTakeoff(Player())) {",
                        "  //если у игрока своя компания",
                        "  if(mod_merchant_scrState==1)",
                        "      {",
                        "  //фикс дя старых версий, надо не забыть удалить",
                        "      if(fix==0)",
                        "          {",
                        "          int2=0;",
                        "          fix=1;",
                        "          for (i = 0; i < GroupCount(MerchantFleet); i = i + 1)",
                        "              {",
                        "              dwd0 = GroupShip(MerchantFleet, i);",
                        "              int0 = ShipFindCustomShipInfoByType(dwd0, 'AMod_Merchant0');",
                        "              int1 = ShipCustomShipInfoData(dwd0, int0, 1);",
                        "              if(int1>100)",
                        "                  {",
                        "                  int2=1;",
                        "                  ShipCustomShipInfoData(dwd0, int0, 1, Rnd(8,12));",
                        "                  ShipCustomShipInfoData(dwd0, int0, 3, 500);",
                        "                  }",
                        "              }",
                        "          if(int2==1)Ether(8,'mod_merchant_fix01','[Mod_Merchant]Обнаружена старая версия скрипта, попытка исправить зарплату и опыт.');",
                        "          }",
                        "      str0 = GameDateTxtByTurn(CurTurn() + 1);",
                        "  //если настал новый месяц",
                        "      if (findsubstr(str0, months[months[0, 0], 1]) == -1)",
                        "      {",
                        "  //если есть долги по зарплате",
                        "  //если баланс позваляет выдать зарплату - списываем долги",
                        "  //если баланс не позволяет, то даём игроку шанс ещё на 1 месяц",
                        "          if (mod_merchantArr0[0, 5] > 0)",
                        "              {",
                        "              if (mod_merchantArr0[0, 1] > 0) mod_merchantArr0[0, 5] = 0;",
                        "              else mod_merchantArr0[0, 5] = 2;",
                        "              }",
                        "  //прибавляем ко всем месяцам 1, для списка отчета",
                        "          for (i = 1; i < 12; i = i + 1)",
                        "              {",
                        "              mod_merchantArr0[1, i] = mod_merchantArr0[1, i + 1];",
                        "              }",
                        "  //формируем строку с текущим месяцем(months[months[0, 0], 0]) и годом(mod_merchantArr0[0, 10])",
                        "          mod_merchantArr0[1, 12] = months[months[0, 0], 0] + ' ' + mod_merchantArr0[0, 10];",
                        "          months[0, 0] = months[0, 0] + 1;",
                        "  //новый год!",
                        "          if (months[0, 0] > 12) {",
                        "              months[0, 0] = 1;",
                        "              mod_merchantArr0[0, 10] = mod_merchantArr0[0, 10] + 1;",
                        "          }",
                        "  //проверяем наших торгашей",
                        "          for (i = 0; i < GroupCount(MerchantFleet); i = i + 1)",
                        "              {",
                        "              dwd0 = GroupShip(MerchantFleet, i);",
                        "              int0 = ShipFindCustomShipInfoByType(dwd0, 'AMod_Merchant0');",
                        "              int1 = ShipCustomShipInfoData(dwd0, int0, 1);",
                        "  //если балан положительный - торгаш рад зарплате и повышает отношение к игроку на 5",
                        "  //иначе понижаем на -15 и создаём задолжность",
                        "              if (mod_merchantArr0[0, 1] > 0)RelationToRanger(dwd0, Player(), RelationToRanger(dwd0, Player()) + 5);",
                        "              else",
                        "                  {",
                        "                  if (mod_merchantArr0[0, 5] == 0) mod_merchantArr0[0, 5] = 1;",
                        "                  RelationToRanger(dwd0, Player(), RelationToRanger(dwd0, Player()) - 15);",
                        "                  }",
                        "              }",
                        "  //рассчитываем кто сколько наторговал и обнуляем значения для следующего периода",
                        "          for (i = 1; i < 12; i = i + 1)",
                        "              {",
                        "              mod_merchantArr0[2, i] = mod_merchantArr0[2, i + 1];",
                        "              mod_merchantArr0[4, i] = mod_merchantArr0[4, i + 1];",
                        "              mod_merchantArr0[5, i] = mod_merchantArr0[5, i + 1];",
                        "              }",
                        "          mod_merchantArr0[2, 12] = mod_merchantArr0[2, 0];",
                        "          mod_merchantArr0[4, 12] = mod_merchantArr0[4, 0];",
                        "          mod_merchantArr0[5, 12] = mod_merchantArr0[5, 0];",
                        "          mod_merchantArr0[0, 1] = mod_merchantArr0[0, 1] + mod_merchantArr0[2, 0] - mod_merchantArr0[5, 0];",
                        "          mod_merchantArr0[2, 0] = 0;",
                        "          mod_merchantArr0[4, 0] = 0;",
                        "          mod_merchantArr0[5, 0] = 0;",
                        "      }",
                        "  //проверяем все ли торгаши покинули игрока, если да - выставляем глобалке -1",
                        "  //торгаши обижаются на: 2 раза задолжность по зарплате, игрок выстрелил в торгаша, низкое отношение к игроку",
                        "      if (mod_merchantArr0[0, 4] == 1)",
                        "          {",
                        "          if (GroupCount(MerchantFleet) == 0) mod_merchant_scrState = -1;",
                        "          }",
                        "      }",
                        "  //если игрок нанят    ",
                        "  if(mod_merchant_scrState==2)",
                        "      {",
                        "  //забераем часть кредитов от продажи оборудки для погашении ссуды, если надо",
                        "      for(i = GalaxyEvents() - 1; i >= 0; i = i - 1)",
                        "          {",
                        "          if(mod_merchantArr0[0,3]==0)break;",
                        "          if(GalaxyEventDate(i) < CurTurn()) break;",
                        "          if(GalaxyEventType(i) == 'PlayerSellsEquipment')",
                        "              {",
                        "              int0=GalaxyEventData(i, 1);",
                        "              int0=int0 / 10;",
                        "              if(ShipMoney(Player())-int0>=0)",
                        "                  {",
                        "                  ShipMoney(Player(), ShipMoney(Player()) - int0);",
                        "                  mod_merchantArr0[0,3]=mod_merchantArr0[0,3]-int0;",
                        "                  }",
                        "              }",
                        "          }",
                        "  //завершение карьеры игрока при найме в компанию        ",
                        "      if(mod_merchantArr0[0,5]==2)",
                        "          {",
                        "          if(CurTurn()>=mod_merchantArr0[0,6])",
                        "              {",
                        "              mod_merchant_scrState=0;",
                        "              qst=1;",
                        "              for (i = 1; i < 9; i = i + 1)mod_merchantArr0[0, i] = 0;",
                        "              Ether(5,'mod_merchant_quest0',CT(\"Script.mod_merchant.39\"));",
                        "              }",
                        "          }",
                        "      }",
                        "  //если игрок уволился из компании    ",
                        "  if(mod_merchant_scrState==4)",
                        "      {",
                        "      if(mod_merchantArr0[0,2]==1)",
                        "          {",
                        "          mod_merchant_scrState=0;",
                        "          qst=1;",
                        "          for (i = 1; i < 9; i = i + 1)mod_merchantArr0[0, i] = 0;",
                        "          }",
                        "      }",
                        "  if(mod_merchant_scrState==-1)",
                        "      {",
                        "      if(GroupCount(MerchantFleet)==0)",
                        "          {",
                        "          SFT('end_script mod_merchant');",
                        "          ShipOut(Player());",
                        "          }",
                        "      }",
                        "}"
                    ],
