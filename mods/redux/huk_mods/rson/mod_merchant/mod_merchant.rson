                {
                    "Name": "",
                    "Code.Type": "Turn",
                    "Code": [
                        "cPlanet=GetShipPlanet(Player());",
                        "//выбираем товар для большой сделки",
                        "int0=Rnd(0,6);",
                        "//если товар нелегален, кол-во меньше 50 или не повезло в рнд - сделка отменяется",
                        "if(Rnd(0,100)>74 || ShipGoodsIllegalOnPlanet(Player(),int0,cPlanet) || ShipFreeSpace(Player())<50)qst=CurTurn()+Rnd(23,37);",
                        "if(qst>CurTurn()) {",
                        "  DChange(7);",
                        "  exit;",
                        "}",
                        "if(qst<=CurTurn()) {",
                        "  //ход следующей сделки",
                        "  qst=CurTurn()+Rnd(23,37);",
                        "  //рассчитываем среднюю стоимость товара на текущий момент",
                        "  int1=0;int2=0;",
                        "  for(i=0;i<GalaxyStars();i=i+1)",
                        "      {",
                        "      cStar=GalaxyStar(i);",
                        "      if(StarOwner(cStar)==1)continue;",
                        "      if(StarCustomFaction(cStar)!='')continue;",
                        "      for(j=0;j<StarPlanets(cStar);j=j+1)",
                        "          {",
                        "          dwd0=StarPlanets(cStar,j);",
                        "          if(PlanetOwner(dwd0)==6)continue;",
                        "          if(NoShopUpdate(dwd0)==1)continue;",
                        "          if(NoShopUpdate(dwd0)==2)continue;",
                        "          int1=int1+GoodsBuyPrice(dwd0,int0);",
                        "          int2=int2+1;",
                        "          }",
                        "      for(j=0;j<StarRuins(cStar);j=j+1)",
                        "          {",
                        "          dwd0=StarRuins(cStar,j);",
                        "          if(NoShopUpdate(dwd0)==1)continue;",
                        "          if(NoShopUpdate(dwd0)==2)continue;",
                        "          int1=int1+GoodsBuyPrice(dwd0,int0);",
                        "          int2=int2+1;",
                        "          }",
                        "      }",
                        "  int1=int1 / int2;",
                        "  //выбираем максимальную цену из средней цены или цены товара на планете",
                        "  int1=max(int1, GoodsBuyPrice(cPlanet,int0));",
                        "  //делаем скидку в зависимости от торгового ранга игрока в компании",
                        "  i=0;j=0;",
                        "  i=ShipFindCustomShipInfoByType(Player(), 'AMod_Merchant_player');",
                        "  if(i!=-1)",
                        "      {",
                        "      i=ShipCustomShipInfoData(Player(), i, 2);",
                        "      j=int1*i*10;",
                        "      j=j/100;",
                        "      }",
                        "  int1=int1 - j;",
                        "  //предлагаем игроку товара на весь трюм, но не более 2000",
                        "  int2=min(ShipFreeSpace(Player()), 2000);",
                        "  str0=CT('Items.Goods.Name.'+(int0+1));",
                        "  DChange(6);",
                        "  exit;",
                        "}"
