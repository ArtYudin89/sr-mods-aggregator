                }
            ],
            "Items": [],
            "Operations": [
                {
                    "Name": "",
                    "Code.Type": "Global",
                    "Code": [
                        "GRun();"
                    ],
                    "#": 20,
                    "Type": "Top",
                    "Parent": -1,
                    "Pos.x": 0,
                    "Pos.y": 585
                },
                {
                    "Name": "",
                    "Code.Type": "Init",
                    "Code": [
                        "//при старте скрипта навешиваем инфошки активации дронов на не скриптовых флагманов и вояк",
                        "for(a=0;a<GalaxyStars();a=a+1)",
                        "    {",
                        "    star=GalaxyStar(a);",
                        "    for(b=0;b<StarShips(star);b=b+1)",
                        "        {",
                        "        ship=StarShips(star,b);",
                        "        if(ship==Player())continue;",
                        "        if(ShipOwner(ship)>4)continue;",
                        "        if(ShipInScript(ship))continue;",
                        "        if(ShipCustomFaction(ship)!='')continue;",
                        "        if(ShipTypeN(ship)!=t_Warrior)continue;",
                        "        if(ShipSubType(ship)==1)ShipAddCustomShipInfo(ship, 'mBtlDrn_NpcDrones','NoShow',0,10+GalaxyTechLevel());",
                        "        else",
                        "            {",
                        "            if(Rnd(0,100)<17)ShipAddCustomShipInfo(ship, 'mBtlDrn_NpcDrones','NoShow',0,3);",
                        "            }",
                        "        }",
                        "    }",
                        "lastIdWarrior=GalaxyShipId();"
                    ],
                    "#": 21,
                    "Type": "Top",
                    "Parent": -1,
                    "Pos.x": 60,
                    "Pos.y": 585
                },
                {
                    "Name": "",
                    "Code.Type": "Turn",
                    "Code": [
                        "if(!ShipIsTakeoff(Player())) {",
                        "  //навешиваем инфошки активации дронов на свежие флагманы и вояк",
                        "  if(GalaxyShipId()>lastIdWarrior)",
                        "      {",
                        "      a=BuildListOfNewShips(arr0, lastIdWarrior, 16, 1+2+4+8+16);",
                        "      if(a)",
                        "          {",
                        "          for(a=0;a<ArrayDim(arr0);a=a+1)",
                        "              {",
                        "              ship=arr0[a];",
                        "              if(ship==Player())continue;",
                        "              if(ShipOwner(ship)>4)continue;",
                        "              if(ShipInScript(ship))continue;",
                        "              if(ShipCustomFaction(ship)!='')continue;",
                        "              if(ShipTypeN(ship)!=t_Warrior)continue;",
                        "              if(ShipSubType(ship)==1)ShipAddCustomShipInfo(ship, 'mBtlDrn_NpcDrones','NoShow',0,2*GalaxyTechLevel());",
                        "              else",
                        "                  {",
                        "                  if(Rnd(0,100)<17)ShipAddCustomShipInfo(ship, 'mBtlDrn_NpcDrones','NoShow',0,GalaxyTechLevel());",
                        "                  }",
                        "              }",
                        "          }",
                        "      lastIdWarrior=GalaxyShipId();",
                        "      }",
                        "}"
                    ],
                    "#": 22,
                    "Type": "Top",
                    "Parent": -1,
                    "Pos.x": 120,
                    "Pos.y": 585
                },
                {
                    "Name": "",
                    "Code.Type": "DialogBegin",
                    "Code": [
                        "if(GetShipRuins(Player())>0) {",
                        "  if(ShipType(GetShipRuins(Player()))=='WB') {",
                        "    if(ShipRank(Player())>2)",
                        "        {",
                        "        if(!ShipOnSidePirateClan(Player()))",
                        "            {",
                        "            AddDialogInject('Dlg0','',CT(\"Script.mod_battledrone.2\"),3);",
                        "            }",
                        "        }",
                        "  }",
                        "}"
                    ],
                    "#": 23,
                    "Type": "Top",
                    "Parent": -1,
                    "Pos.x": 180,
                    "Pos.y": 585
                },
                {
                    "Name": "",
                    "Code.Type": "Turn",
                    "Code": [
                        "//проверяем кол-во дронов у игрока и удаляем несуществующие",
                        "curDrons=0;",
                        "for(a=ArrayDim(dronsArr)-1;a>0;a=a-1)",
                        "    {",
                        "    dwd0=IdToItem(dronsArr[a]);",
                        "    if(dwd0)curDrons=curDrons+1;",
                        "    else ArrayDelete(dronsArr,a);",
                        "    }",
                        "//выбираем тип нового дрона, если ещё не выбирали в этом ходу",
                        "maxDrons=ShipRank(Player()) - 1;",
                        "if(CurTurn()>newDron)",
                        "    {",
                        "    //curDronArr[1] системное имя текущего дрона",
                        "    //curDronArr[2] раса дрона",
                        "    //curDronArr[3] цена дрона",
                        "    //curDronArr[4] описание дрона",
                        "    //curDronArr[5] текстовое имя дрона",
                        "    newDron=CurTurn();",
                        "    ArrayClear(arr0);ArrayClear(arr1);",
                        "    int0=CT('UselessItems',arr0);",
                        "    for(a=0;a<int0;a=a+1)",
                        "        {",
                        "        str0=GetVariableName(arr0[a]);",
                        "        if(CT('UselessItems.'+str0+'.Mod_BattleDrone')!=1)continue;",
                        "        ArrayAdd(arr1,GetVariableName(arr0[a]));",
                        "        }",
                        "    int0=Rnd(1,ArrayDim(arr1)-1);",
                        "    curDronArr[1]=arr1[int0];",
                        "    curDronArr[2]=CT('UselessItems.'+curDronArr[1]+'.Owner');",
                        "    curDronArr[3]=50000*GalaxyTechLevel()+GalaxyMoney(4,curDronArr[2])*2;",
                        "    str0='</color>'+CT('UselessItems.'+curDronArr[1]+'.Text');",
                        "    str0=Format(str0,'minDmg',15*GalaxyTechLevel(),'maxDmg',25*GalaxyTechLevel());",
                        "    str0=Format(str0,'minBDmg',80*GalaxyTechLevel(),'maxBDmg',120*GalaxyTechLevel());",
                        "    curDronArr[4]=str0;",
                        "    curDronArr[5]=CT('UselessItems.'+curDronArr[1]+'.Name');",
                        "    }",
                        "DChange(0);",
                        "exit;"
                    ],
                    "#": 30,
                    "Type": "Top",
                    "Parent": -1,
                    "Pos.x": -20,
                    "Pos.y": 375
                },
                {
                    "Name": "",
                    "Code.Type": "Turn",
                    "Code": [
                        "if(ShipMoney(Player())>=curDronArr[3] && curDrons<maxDrons) {",
                        "  DAdd(0);",
                        "}",
                        "if(ShipMoney(Player())<curDronArr[3] || curDrons>=maxDrons) {",
                        "  DAdd(1);",
                        "}",
                        "DAdd(2);"
                    ],
                    "#": 31,
                    "Type": "Top",
                    "Parent": -1,
                    "Pos.x": -20,
                    "Pos.y": 445
                },
                {
                    "Name": "",
                    "Code.Type": "Turn",
                    "Code": [
                        "newDron=0;",
                        "dwd0=CreateQuestItem(curDronArr[1],curDronArr[2]);",
                        "SetName(dwd0,Name(dwd0)+' MK'+GalaxyTechLevel()+'-'+Rnd(1,9999));",
                        "UselessItemData(dwd0,2,GalaxyTechLevel());",
                        "str0=CT('UselessItems.'+curDronArr[1]+'.Text');",
                        "str0=Format(str0,'minDmg',15*GalaxyTechLevel(),'maxDmg',25*GalaxyTechLevel());",
                        "str0=Format(str0,'minBDmg',80*GalaxyTechLevel(),'maxBDmg',120*GalaxyTechLevel());",
                        "UselessItemText(dwd0,str0);",
                        "ItemCost(dwd0,curDronArr[3]);",
                        "ItemSize(dwd0,50*GalaxyTechLevel());",
                        "ShipMoney(Player(),ShipMoney(Player()) - curDronArr[3]);",
                        "AddItemToShip(Player(),dwd0);",
                        "ArrayAdd(dronsArr,Id(dwd0));",
                        "Sound('Sound.Sell');"
                    ],
                    "#": 32,
                    "Type": "Top",
                    "Parent": -1,
                    "Pos.x": -20,
                    "Pos.y": 515
                }
            ],
