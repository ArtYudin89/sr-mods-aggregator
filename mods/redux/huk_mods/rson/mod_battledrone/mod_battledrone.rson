            "DialogMessages": [
                {
                    "Name": "",
                    "Pos.x": 0,
                    "Pos.y": 445,
                    "Type": "TDialogMsg",
                    "Parent": -1,
                    "#": 26,
                    "Msg": "Боевые дроны - вспомогательные автоматические огневые установки, используемые подразделениями КВСМК для ликвидации особо опасных противников. По окончании эксплуатации самоликвидируются. По запросу Сети ЦР Боевые дроны могут приобрести отличившиеся пилоты Корпуса.\r\n---------------------------------\r\nСегодня мы можем предложить <0>.\r\nОписание: <1>\r\nСтоимость: <2> cr.\r\n---------------------------------\r\nКоличество дронов у вас: <3> шт.\r\nВаш ранг позволяет приобрести <4> шт.\r\n\r\nБудете брать?",
                    "DMsg.Num": "0",
                    "_orig_dtext": "DText(Format(CT(\"Script.mod_battledrone.0\"),\"<0>\",curDronArr[5],\"<1>\",str0,\"<2>\",curDronArr[3],\"<3>\",curDrons,\"<4>\",maxDrons))"
                }
            ],
            "Dialogs": [
                {
                    "Name": "Dlg0",
                    "Type": "TDialog",
                    "Pos.x": 0,
                    "Pos.y": 375,
                    "Parent": -1,
                    "#": 25
                }
            ],
            "Groups": [
                {
                    "Name": "GroupNew",
                    "Owner": 62,
                    "Group.Type": 126,
                    "CntShipMin": 1,
                    "CntShipMax": 1,
                    "SpeedMin": 100,
