                        "GRun();"
                    ],
                    "#": 18,
                    "Type": "Top",
                    "Parent": -1,
                    "Pos.x": 0,
                    "Pos.y": 610
                },
                {
                    "Name": "",
                    "Code.Type": "Init",
                    "Code": [
                        "// Базовая стоимость бомбы в кредитах на разных ГТУ",
                        "baseBombCost[1]=40000;",
                        "baseBombCost[2]=40000;",
                        "baseBombCost[3]=40000;",
                        "baseBombCost[4]=55000;",
                        "baseBombCost[5]=70000;",
                        "baseBombCost[6]=85000;",
                        "baseBombCost[7]=100000;",
                        "baseBombCost[8]=120000;",
                        "",
                        "// Имена рас в диалоге",
                        "raceName[0]='Малокским';",
                        "raceName[1]='Пеленгским';",
                        "raceName[2]='Человеческим';",
                        "raceName[3]='Фэянским';",
                        "raceName[4]='Гаальским';"
                    ],
                    "#": 19,
                    "Type": "Top",
                    "Parent": -1,
                    "Pos.x": 60,
                    "Pos.y": 610
                },
                {
                    "Name": "",
                    "Code.Type": "Turn",
                    "Code": [
                        "if(GetShipRuins(Player())>0) {",
                        "  if(ShipType(GetShipRuins(Player()))=='PB' || ShipType(GetShipRuins(Player()))=='TC') {",
                        "    AddDialogInject('ask_for_advanced_options','',CT(\"Script.AdvancedOptions.8\"),1);",
                        "  }",
                        "}"
                    ],
                    "#": 20,
                    "Type": "Top",
                    "Parent": -1,
                    "Pos.x": 120,
                    "Pos.y": 610
                },
                {
                    "Name": "",
                    "Code.Type": "Turn",
                    "Code": [
                        "DChange(0);",
                        "exit;"
                    ],
                    "#": 41,
                    "Type": "Top",
                    "Parent": -1,
                    "Pos.x": -20,
                    "Pos.y": 400
                },
                {
                    "Name": "",
                    "Code.Type": "Turn",
                    "Code": [
                        "DChange(4);",
                        "exit;"
                    ],
                    "#": 42,
                    "Type": "Top",
                    "Parent": -1,
                    "Pos.x": 340,
                    "Pos.y": 400
                },
                {
                    "Name": "",
                    "Code.Type": "Turn",
                    "Code": [
                        "//Изменение расы",
                        "ItemOwner(pickedItem, GAnswerData);",
                        "",
                        "int currentSizeItem = ItemSize(pickedItem);",
                        "float currentCostItem = ItemCost(pickedItem);",
                        "",
                        "// увеличение веса у всех, кроме корпуса и бака, на 5 тонн + 10% от начального веса",
                        "if((ItemType(pickedItem) != t_Hull && currentSizeItem < 3000) && ItemType(pickedItem) != t_FuelTanks)",
                        "    {",
                        "        ItemSize(pickedItem, currentSizeItem + 5 + currentSizeItem/10);",
                        "    }",
                        "",
                        "// уменьшение объёма у корпуса на 5%",
                        "if(ItemType(pickedItem) == t_Hull && currentSizeItem > 100)",
                        "    {",
                        "        ItemSize(pickedItem, currentSizeItem - currentSizeItem/20);",
                        "        HullHP(pickedItem, currentSizeItem - currentSizeItem/20);",
                        "    }",
                        "",
                        "// увеличение стомости предмета на 25%",
                        "ItemCost(pickedItem, round(min(currentCostItem * 1.25, 100000000)));",
                        "",
                        "// снятие средств с игрока",
                        "ShipMoney(Player(),ShipMoney(Player())-finalCost[GAnswerData]);",
                        "Sound('Sound.Sell');",
                        "DChange(5);",
                        "exit;"
                    ],
                    "#": 43,
                    "Type": "Top",
                    "Parent": -1,
                    "Pos.x": 490,
                    "Pos.y": 400
                },
                {
                    "Name": "",
                    "Code.Type": "Turn",
                    "Code": [
                        "str artSystemName;",
                        "int finalBombCost;",
                        "int item;",
                        "",
                        "// Если выбрана Кварковая бомба",
                        "if (GAnswerData == 1) {finalBombCost = currentBombCost;}",
                        "",
                        "// Если выбрана ЭМП бомба",
                        "if (GAnswerData == 2) {",
                        "        if (BlockExist('UselessItems.EMP_bomb') == 1) {",
                        "        artSystemName = 'EMP_bomb'; // redux/community?",
                        "        } ",
                        "        else {",
                        "        artSystemName = 'RNDbomb_3'; // original/shuniverse",
                        "        }",
                        "        finalBombCost = currentBombCost;",
                        "    }",
                        "",
                        "// Если выбрана Оглушающая бомба",
                        "if (GAnswerData == 3) {",
                        "        if (BlockExist('UselessItems.Stun_bomb') == 1) {",
                        "        artSystemName = 'Stun_bomb'; // redux/community?",
                        "        } ",
                        "        else {",
                        "        artSystemName = 'RNDbomb_2'; // original/shuniverse",
                        "        } ",
                        "        finalBombCost = currentBombCost/2;",
                        "    }",
                        "",
                        "// добавление бомбы на борт",
                        "if (GAnswerData == 1) {",
                        "    item=CreateArt(t_ArtefactBomb, GetOwner(GetShipRuins(Player())));",
                        "}",
                        "if (GAnswerData == 2 || GAnswerData == 3) {",
                        "    item=CreateQuestItem(artSystemName, GetOwner(GetShipRuins(Player())));",
                        "}",
                        "ItemSize(item, currentGalaxyLevel + Rnd(0, currentGalaxyLevel)); // небольшая надбавка к весу в зависимости от ГТУ",
                        "ItemCost(item, finalBombCost);",
                        "AddItemToShip(Player(), item);",
                        "",
                        "// снятие средств с игрока",
                        "ShipMoney(Player(),ShipMoney(Player())-finalBombCost);",
                        "Sound('Sound.Sell');",
                        "DChange(2);",
                        "exit;"
                    ],
                    "#": 44,
                    "Type": "Top",
                    "Parent": -1,
                    "Pos.x": 730,
                    "Pos.y": 400
                },
                {
                    "Name": "",
                    "Code.Type": "Turn",
                    "Code": [
                        "DAdd(2);",
                        "DAdd(0);",
                        "DAdd(1);"
                    ],
                    "#": 45,
                    "Type": "Top",
                    "Parent": -1,
                    "Pos.x": -20,
                    "Pos.y": 470
                },
                {
                    "Name": "",
                    "Code.Type": "Turn",
                    "Code": [
                        "str fullBlock;",
                        "str halfBlock;",
                        "int currentMoney = ShipMoney(Player());",
                        "",
                        "// Если не хватает денег на дорогие бомбы, ответ заблокируется",
                        "if (currentMoney < currentBombCost) {",
                        "    fullBlock = 'block~';",
                        "} else {",
                        "    fullBlock = '';",
                        "}",
                        "",
                        "// Если не хватает денег на дешевые бомбы, ответ заблокируется",
                        "if (currentMoney < currentBombCost/2) {",
                        "    halfBlock = 'block~';",
                        "} else {",
                        "    halfBlock = '';",
                        "}",
                        "",
                        "",
                        "InjectAnswer('pick_bomb', fullBlock + Format('Кварковая бомба, <0> cr.',\"<0>\",currentBombCost), 1);",
                        "if (customArtsEnabled) {",
                        "    InjectAnswer('pick_bomb', fullBlock + Format('ЭМП бомба, <0> cr.',\"<0>\",currentBombCost), 2);",
                        "    InjectAnswer('pick_bomb', halfBlock + Format('Оглушающая бомба, <0> cr.',\"<0>\",currentBombCost/2), 3);",
                        "    }",
                        "DAdd(4);"
                    ],
                    "#": 46,
                    "Type": "Top",
                    "Parent": -1,
                    "Pos.x": 130,
                    "Pos.y": 470
                },
                {
                    "Name": "",
                    "Code.Type": "Turn",
                    "Code": [
                        "DAdd(3);"
                    ],
                    "#": 47,
                    "Type": "Top",
                    "Parent": -1,
                    "Pos.x": 280,
                    "Pos.y": 470
                },
                {
                    "Name": "",
                    "Code.Type": "Turn",
                    "Code": [
                        "playerItemsCount = ShipItems(Player()); // количество вещей на корабле",
                        "int item;",
                        "",
                        "// Добавление оборудования для смены расы в варианты ответа",
                        "if (playerItemsCount > 0)",
                        "{",
                        "    for (i=0;i<playerItemsCount;i=i+1) {",
                        "    item = ShipItems(Player(),i);",
                        "    //SFT(item);",
                        "    //SFT(EqModule(item));",
                        "    if (ItemType(item) < t_Hull || ItemType(item) > t_CustomWeapon) continue; // если не оборудование, не корпус и не кастомные пушки",
                        "    if (ItemOwner(item) > 4) continue; // если оборудование некоалиционное",
                        "    if (EqModule(item) != -1) continue;    // со вставленным ММ",
                        "",
                        "    InjectAnswer('pick_race', DeleteTags(Name(item))+Format(', вес <0>,  <1> cr.',\"<0>\",ItemSize(item),\"<1>\",ItemCost(item)), i);",
                        "    }",
                        "}",
                        "DAdd(6);"
                    ],
                    "#": 48,
                    "Type": "Top",
                    "Parent": -1,
                    "Pos.x": 430,
                    "Pos.y": 470
                },
                {
                    "Name": "",
                    "Code.Type": "Turn",
                    "Code": [
                        "//Коэффициенты для улучшения",
                        "upgradeCoeff[1]=1.2; //+120%",
                        "upgradeCoeff[2]=1.6;",
                        "upgradeCoeff[3]=2.0;",
                        "upgradeCoeff[4]=2.4;",
                        "",
                        "//Коэффициенты при ухудшении расы",
                        "downgradeCoeff[0]=0.6; //+60%",
                        "downgradeCoeff[1]=0.7;",
                        "downgradeCoeff[2]=0.8;",
                        "downgradeCoeff[3]=0.9;",
                        "",
                        "float upgradeIncrease;",
                        "float downgradeIncrease;",
                        "",
                        "pickedItem = ShipItems(Player(),GAnswerData);",
                        "currentRace = ItemOwner(pickedItem);",
                        "currentCost = ItemCost(pickedItem);",
                        "",
                        "str block;",
                        "currentMoney = ShipMoney(Player());",
                        "",
                        "// Вставка вариантов улучшений с расчётом стоимости варианта",
                        "for (i=0;i<5;i=i+1) {",
                        "",
                        "    if (currentRace == i) continue;",
                        "    // Апгрейд",
                        "    if (currentRace < i) {",
                        "        upgradeIncrease = upgradeCoeff[i-currentRace];",
                        "        downgradeIncrease = 0.0;",
                        "        }",
                        "    // Даунгрейд",
                        "    if (currentRace > i) {",
                        "        upgradeIncrease = 0.0;",
                        "        downgradeIncrease = downgradeCoeff[i];",
                        "        }",
                        "    // Итоговая стоимость",
                        "    finalCost[i] = 1000 + round(currentCost * (1.0 + upgradeIncrease + downgradeIncrease));",
                        "",
                        "    if (finalCost[i] > 100000000) {finalCost[i] = 100000000;}",
                        "",
                        "    // перекраска в серый цвет, если не хватает денег",
                        "    if (currentMoney < finalCost[i]) {",
                        "        block = 'block~';",
                        "    } else {",
                        "        block = '';",
                        "    }",
                        "",
                        "    InjectAnswer('pick_race_confirm', block + raceName[i] + Format(', <0> cr.',\"<0>\",finalCost[i]), i);",
                        "}",
                        "DAdd(7);"
                    ],
                    "#": 49,
                    "Type": "Top",
                    "Parent": -1,
                    "Pos.x": 580,
                    "Pos.y": 470
                },
                {
                    "Name": "",
                    "Code.Type": "Turn",
                    "Code": [
                        "DAdd(5);"
                    ],
                    "#": 50,
                    "Type": "Top",
                    "Parent": -1,
                    "Pos.x": 730,
                    "Pos.y": 470
                },
                {
                    "Name": "",
                    "Code.Type": "Turn",
                    "Code": [
                        "str fullBlock;",
                        "str halfBlock;",
                        "int currentMoney = ShipMoney(Player());",
                        "",
                        "// Если не хватает денег на дорогие бомбы, ответ заблокируется",
                        "if (currentMoney < currentBombCost) {",
                        "    fullBlock = 'block~';",
                        "} else {",
                        "    fullBlock = '';",
                        "}",
                        "",
                        "// Если не хватает денег на дешевые бомбы, ответ заблокируется",
                        "if (currentMoney < currentBombCost/2) {",
                        "    halfBlock = 'block~';",
                        "} else {",
                        "    halfBlock = '';",
                        "}",
                        "",
                        "",
                        "InjectAnswer('pick_bomb', fullBlock + Format('Кварковая бомба, <0> cr.',\"<0>\",currentBombCost), 1);",
                        "if (customArtsEnabled) {",
                        "    InjectAnswer('pick_bomb', fullBlock + Format('ЭМП бомба, <0> cr.',\"<0>\",currentBombCost), 2);",
                        "    InjectAnswer('pick_bomb', halfBlock + Format('Оглушающая бомба, <0> cr.',\"<0>\",currentBombCost/2), 3);",
                        "    }",
                        "DAdd(4);"
                    ],
                    "#": 51,
                    "Type": "Top",
                    "Parent": -1,
                    "Pos.x": 880,
                    "Pos.y": 470
                },
                {
                    "Name": "",
                    "Code.Type": "Turn",
                    "Code": [
                        "DChange(3);",
                        "exit;"
                    ],
                    "#": 52,
                    "Type": "Top",
                    "Parent": -1,
                    "Pos.x": -20,
                    "Pos.y": 540
                },
                {
                    "Name": "",
                    "Code.Type": "Turn",
                    "Code": [
                        "// Определение стоимости 1 бомбы в зависимости от ГТУ",
                        "currentGalaxyLevel = GalaxyTechLevel();",
                        "currentBombCost = baseBombCost[currentGalaxyLevel];",
                        "",
                        "// Проверка на подключение ЭМП и оглушающих бомб",
                        "if (BlockExist('Artefacts.CustomArtefacts.Stun_bomb') == 1 && BlockExist('Artefacts.CustomArtefacts.EMP_bomb') == 1) {",
                        "    customArtsEnabled = 1;",
                        "    } else {",
                        "        customArtsEnabled = 0;",
                        "    }",
                        "if(customArtsEnabled == 1) {",
                        "  DChange(6);",
                        "  exit;",
                        "}",
                        "if(customArtsEnabled == 0) {",
                        "  DChange(1);",
                        "  exit;",
                        "}"
                    ],
                    "#": 53,
                    "Type": "Top",
                    "Parent": -1,
                    "Pos.x": 220,
                    "Pos.y": 540
                },
                {
                    "Name": "",
                    "Code.Type": "Turn",
                    "Code": [
                        "if(customArtsEnabled == 1) {",
                        "  DChange(6);",
                        "  exit;",
                        "}",
                        "if(customArtsEnabled == 0) {",
                        "  DChange(1);",
                        "  exit;",
                        "}"
                    ],
