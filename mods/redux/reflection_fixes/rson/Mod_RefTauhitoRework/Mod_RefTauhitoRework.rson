                        "        if(GoodsCost(Player(),t_Luxury) / GoodsCount(Player(),t_Luxury) < cnt6) {",
                        "            t_str = t_str + CT(\"Script.Mod_RefTauhitoRework.9\") + ' ' + GoodsCount(Player(),t_Luxury) + CT(\"Script.Mod_RefTauhitoRework.2\") + ' ' + cnt6 + CT(\"Script.Mod_RefTauhitoRework.1\") + ' ' + pl6 + CT('FormInfo.br');",
                        "        }",
                        "        else t_str = t_str + CT(\"Script.Mod_RefTauhitoRework.8\") + CT('FormInfo.br');",
                        "        i = 1;",
                        "    }",
                        "    if(tehnika) {",
                        "        if(GoodsCost(Player(),t_Technics) / GoodsCount(Player(),t_Technics) < cnt5) {",
                        "            t_str = t_str + CT(\"Script.Mod_RefTauhitoRework.7\") + ' ' + GoodsCount(Player(),t_Technics) + CT(\"Script.Mod_RefTauhitoRework.2\") + ' ' + cnt5 + CT(\"Script.Mod_RefTauhitoRework.1\") + ' ' + pl5 + CT('FormInfo.br');",
                        "        }",
                        "        else t_str = t_str + CT(\"Script.Mod_RefTauhitoRework.6\") + CT('FormInfo.br');",
                        "        i = 1;",
                        "    }",
                        "    if(arms) {",
                        "        if(GoodsCost(Player(),t_Arms) / GoodsCount(Player(),t_Arms) < cnt7) {",
                        "            t_str = t_str + CT(\"Script.Mod_RefTauhitoRework.5\") + ' ' + GoodsCount(Player(),t_Arms) + CT(\"Script.Mod_RefTauhitoRework.2\") + ' ' + cnt7 + CT(\"Script.Mod_RefTauhitoRework.1\") + ' ' + pl7 + CT('FormInfo.br');",
                        "        }",
                        "        else t_str = t_str + CT(\"Script.Mod_RefTauhitoRework.4\") + CT('FormInfo.br');",
                        "        i = 1;",
                        "    }",
                        "    if(drugs) {",
                        "        if(GoodsCost(Player(),t_Narcotics) / GoodsCount(Player(),t_Narcotics) < cnt8) {",
                        "            t_str = t_str + CT(\"Script.Mod_RefTauhitoRework.3\") + ' ' + GoodsCount(Player(),t_Narcotics) + CT(\"Script.Mod_RefTauhitoRework.2\") + ' ' + cnt8 + CT(\"Script.Mod_RefTauhitoRework.1\") + ' ' + pl8 + CT('FormInfo.br');",
                        "        }",
                        "        else t_str = t_str + CT(\"Script.Mod_RefTauhitoRework.0\") + CT('FormInfo.br');",
                        "        i = 1;",
                        "    }",
                        "    //Если говорить не о чем, так как у игрока тупо НЕТ ничего в трюме - вписываем текст-флаг",
                        "    if(!i) t_str = 'Cancel';",
                        "",
                        "    result = t_str;",
                        "}",
                        "function FormInfoSector() {",
                        "    int i,j,cnt1 = 0,cnt2 = 0,cnt3 = 0,cnt4 = 0,cnt5 = 0,cnt6 = 0,cnt7 = 0,cnt8 = 0,bulki,tabletki,shit,tehnika,tabureti,pivo,arms,drugs;",
                        "    dword t_plan;",
                        "    str t_str,pl1,pl2,pl3,pl4,pl5,pl6,pl7,pl8,star1,star2,star3,star4,star5,star6,star7,star8;",
                        "",
                        "    //Смотрим, а чо там у игрока вообще есть?",
                        "    bulki = GoodsCount(Player(),t_Food);",
                        "    tabletki = GoodsCount(Player(),t_Medicine);",
                        "    shit = GoodsCount(Player(),t_Minerals);",
                        "    tehnika = GoodsCount(Player(),t_Technics);",
                        "    tabureti = GoodsCount(Player(),t_Luxury);",
                        "    drugs = GoodsCount(Player(),t_Narcotics);",
                        "    arms = GoodsCount(Player(),t_Arms);",
                        "    pivo = GoodsCount(Player(),t_Alcohol);",
                        "",
                        "    //перебираем секторские системы",
                        "    for(j=0;ConStars(StarToCon(ShipStar(Player())))>j;j=j+1) {",
                        "        //перебираем планеты в секторе в поисках лучшего предложения",
                        "        for(i=0;StarPlanets(ConStar(StarToCon(ShipStar(Player())),j))>i;i=i+1) {",
                        "            t_plan = StarPlanets(ConStar(StarToCon(ShipStar(Player())),j),i);",
                        "            if(PlanetOwner(t_plan) == 5) continue; //пропускаем домикоф",
                        "            if(PlanetOwner(t_plan) == 6) continue; //пропускаем незаселёнки",
                        "            if(RelationToShip(t_plan,Player()) < 30) continue; //пропускаем планеты, которые не будут торговать с игроком",
                        "            //Перебираем стоимость товаров",
                        "            if(cnt1 == 0) {",
                        "                cnt1 = GoodsSellPrice(t_plan,t_Food);",
                        "                pl1 = Name(t_plan);",
                        "                star1 = Name(ConStar(StarToCon(ShipStar(Player())),j));",
                        "            }",
                        "            else {",
                        "                if(cnt1 < GoodsSellPrice(t_plan,t_Food)) {",
                        "                    cnt1 = GoodsSellPrice(t_plan,t_Food);",
                        "                    pl1 = Name(t_plan);",
                        "                    star1 = Name(ConStar(StarToCon(ShipStar(Player())),j));",
                        "                }",
                        "            }",
                        "            if(cnt2 == 0) {",
                        "                cnt2 = GoodsSellPrice(t_plan,t_Medicine);",
                        "                pl2 = Name(t_plan);",
                        "                star2 = Name(ConStar(StarToCon(ShipStar(Player())),j));",
                        "            }",
                        "            else {",
                        "                if(cnt2 < GoodsSellPrice(t_plan,t_Medicine)) {",
                        "                    cnt2 = GoodsSellPrice(t_plan,t_Medicine);",
                        "                    pl2 = Name(t_plan);",
                        "                    star2 = Name(ConStar(StarToCon(ShipStar(Player())),j));",
                        "                }",
                        "            }",
                        "            if(cnt3 == 0) {",
                        "                cnt3 = GoodsSellPrice(t_plan,t_Alcohol);",
                        "                pl3 = Name(t_plan);",
                        "                star3 = Name(ConStar(StarToCon(ShipStar(Player())),j));",
                        "            }",
                        "            else {",
                        "                if(cnt3 < GoodsSellPrice(t_plan,t_Alcohol)) {",
                        "                    cnt3 = GoodsSellPrice(t_plan,t_Alcohol);",
                        "                    pl3 = Name(t_plan);",
                        "                    star3 = Name(ConStar(StarToCon(ShipStar(Player())),j));",
                        "                }",
                        "            }",
                        "            if(cnt4 == 0) {",
                        "                cnt4 = GoodsSellPrice(t_plan,t_Minerals);",
                        "                pl4 = Name(t_plan);",
                        "                star4 = Name(ConStar(StarToCon(ShipStar(Player())),j));",
                        "            }",
                        "            else {",
                        "                if(cnt4 < GoodsSellPrice(t_plan,t_Minerals)) {",
                        "                    cnt4 = GoodsSellPrice(t_plan,t_Minerals);",
                        "                    pl4 = Name(t_plan);",
                        "                    star4 = Name(ConStar(StarToCon(ShipStar(Player())),j));",
                        "                }",
                        "            }",
                        "            if(cnt5 == 0) {",
                        "                cnt5 = GoodsSellPrice(t_plan,t_Technics);",
                        "                pl5 = Name(t_plan);",
                        "                star5 = Name(ConStar(StarToCon(ShipStar(Player())),j));",
                        "            }",
                        "            else {",
                        "                if(cnt5 < GoodsSellPrice(t_plan,t_Technics)) {",
                        "                    cnt5 = GoodsSellPrice(t_plan,t_Technics);",
                        "                    pl5 = Name(t_plan);",
                        "                    star5 = Name(ConStar(StarToCon(ShipStar(Player())),j));",
