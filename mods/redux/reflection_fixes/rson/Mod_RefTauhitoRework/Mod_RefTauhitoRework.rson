                        "                pl6 = Name(t_plan);",
                        "                star6 = Name(ConStar(StarToCon(ShipStar(Player())),j));",
                        "            }",
                        "            else {",
                        "                if(cnt6 < GoodsSellPrice(t_plan,t_Luxury)) {",
                        "                    cnt6 = GoodsSellPrice(t_plan,t_Luxury);",
                        "                    pl6 = Name(t_plan);",
                        "                    star6 = Name(ConStar(StarToCon(ShipStar(Player())),j));",
                        "                }",
                        "            }",
                        "            if(cnt7 == 0) {",
                        "                cnt7 = GoodsSellPrice(t_plan,t_Arms);",
                        "                pl7 = Name(t_plan);",
                        "                star7 = Name(ConStar(StarToCon(ShipStar(Player())),j));",
                        "            }",
                        "            else {",
                        "                if(cnt7 < GoodsSellPrice(t_plan,t_Arms)) {",
