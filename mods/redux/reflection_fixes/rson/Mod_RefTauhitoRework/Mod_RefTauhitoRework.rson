                        "        else t_str = t_str + CT(\"Script.Mod_RefTauhitoRework.12\") + CT('FormInfo.br');",
                        "        i = 1;",
                        "    }",
                        "    if(pivo) {",
                        "        if(GoodsCost(Player(),t_Alcohol) / GoodsCount(Player(),t_Alcohol) < cnt3) {",
                        "            t_str = t_str + CT(\"Script.Mod_RefTauhitoRework.11\") + ' ' + GoodsCount(Player(),t_Alcohol) + CT(\"Script.Mod_RefTauhitoRework.2\") + ' ' + cnt3 + CT(\"Script.Mod_RefTauhitoRework.1\") + ' ' + pl3 + CT('FormInfo.br');",
                        "        }",
                        "        else t_str = t_str + CT(\"Script.Mod_RefTauhitoRework.10\") + CT('FormInfo.br');",
                        "        i = 1;",
                        "    }",
                        "    if(tabureti) {",
                        "        if(GoodsCost(Player(),t_Luxury) / GoodsCount(Player(),t_Luxury) < cnt6) {",
                        "            t_str = t_str + CT(\"Script.Mod_RefTauhitoRework.9\") + ' ' + GoodsCount(Player(),t_Luxury) + CT(\"Script.Mod_RefTauhitoRework.2\") + ' ' + cnt6 + CT(\"Script.Mod_RefTauhitoRework.1\") + ' ' + pl6 + CT('FormInfo.br');",
                        "        }",
                        "        else t_str = t_str + CT(\"Script.Mod_RefTauhitoRework.8\") + CT('FormInfo.br');",
                        "        i = 1;",
                        "    }",
                        "    if(tehnika) {",
                        "        if(GoodsCost(Player(),t_Technics) / GoodsCount(Player(),t_Technics) < cnt5) {",
                        "            t_str = t_str + CT(\"Script.Mod_RefTauhitoRework.7\") + ' ' + GoodsCount(Player(),t_Technics) + CT(\"Script.Mod_RefTauhitoRework.2\") + ' ' + cnt5 + CT(\"Script.Mod_RefTauhitoRework.1\") + ' ' + pl5 + CT('FormInfo.br');",
                        "        }",
                        "        else t_str = t_str + CT(\"Script.Mod_RefTauhitoRework.6\") + CT('FormInfo.br');",
                        "        i = 1;",
                        "    }",
                        "    if(arms) {",
                        "        if(GoodsCost(Player(),t_Arms) / GoodsCount(Player(),t_Arms) < cnt7) {",
                        "            t_str = t_str + CT(\"Script.Mod_RefTauhitoRework.5\") + ' ' + GoodsCount(Player(),t_Arms) + CT(\"Script.Mod_RefTauhitoRework.2\") + ' ' + cnt7 + CT(\"Script.Mod_RefTauhitoRework.1\") + ' ' + pl7 + CT('FormInfo.br');",
                        "        }",
                        "        else t_str = t_str + CT(\"Script.Mod_RefTauhitoRework.4\") + CT('FormInfo.br');",
                        "        i = 1;",
                        "    }",
                        "    if(drugs) {",
                        "        if(GoodsCost(Player(),t_Narcotics) / GoodsCount(Player(),t_Narcotics) < cnt8) {",
                        "            t_str = t_str + CT(\"Script.Mod_RefTauhitoRework.3\") + ' ' + GoodsCount(Player(),t_Narcotics) + CT(\"Script.Mod_RefTauhitoRework.2\") + ' ' + cnt8 + CT(\"Script.Mod_RefTauhitoRework.1\") + ' ' + pl8 + CT('FormInfo.br');",
                        "        }",
                        "        else t_str = t_str + CT(\"Script.Mod_RefTauhitoRework.0\") + CT('FormInfo.br');",
                        "        i = 1;",
                        "    }",
                        "    //Если говорить не о чем, так как у игрока тупо НЕТ ничего в трюме - вписываем текст-флаг",
                        "    if(!i) t_str = 'Cancel';",
                        "",
                        "    result = t_str;",
                        "}",
                        "ShipAddCustomShipInfo(Player(),'RefTauhito_Removing','NoShow');"
