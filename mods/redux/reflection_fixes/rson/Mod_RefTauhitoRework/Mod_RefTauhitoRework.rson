                        "        else {",
                        "            if(cnt1 < GoodsSellPrice(t_plan,t_Food)) {",
                        "                cnt1 = GoodsSellPrice(t_plan,t_Food);",
                        "                pl1 = Name(t_plan);",
                        "            }",
                        "        }",
                        "        if(cnt2 == 0) {",
                        "            cnt2 = GoodsSellPrice(t_plan,t_Medicine);",
                        "            pl2 = Name(t_plan);",
                        "        }",
                        "        else {",
                        "            if(cnt2 < GoodsSellPrice(t_plan,t_Medicine)) {",
                        "                cnt2 = GoodsSellPrice(t_plan,t_Medicine);",
                        "                pl2 = Name(t_plan);",
                        "            }",
                        "        }",
                        "        if(cnt3 == 0) {",
                        "            cnt3 = GoodsSellPrice(t_plan,t_Alcohol);",
                        "            pl3 = Name(t_plan);",
                        "        }",
                        "        else {",
                        "            if(cnt3 < GoodsSellPrice(t_plan,t_Alcohol)) {",
                        "                cnt3 = GoodsSellPrice(t_plan,t_Alcohol);",
                        "                pl3 = Name(t_plan);",
                        "            }",
                        "        }",
                        "        if(cnt4 == 0) {",
                        "            cnt4 = GoodsSellPrice(t_plan,t_Minerals);",
                        "            pl4 = Name(t_plan);",
                        "        }",
                        "        else {",
                        "            if(cnt4 < GoodsSellPrice(t_plan,t_Minerals)) {",
                        "                cnt4 = GoodsSellPrice(t_plan,t_Minerals);",
                        "                pl4 = Name(t_plan);",
                        "            }",
                        "        }",
                        "        if(cnt5 == 0) {",
                        "            cnt5 = GoodsSellPrice(t_plan,t_Technics);",
                        "            pl5 = Name(t_plan);",
                        "        }",
                        "        else {",
                        "            if(cnt5 < GoodsSellPrice(t_plan,t_Technics)) {",
                        "                cnt5 = GoodsSellPrice(t_plan,t_Technics);",
                        "                pl5 = Name(t_plan);",
                        "            }",
                        "        }",
                        "        if(cnt6 == 0) {",
                        "            cnt6 = GoodsSellPrice(t_plan,t_Luxury);",
                        "            pl6 = Name(t_plan);",
                        "        }",
                        "        else {",
                        "            if(cnt6 < GoodsSellPrice(t_plan,t_Luxury)) {",
                        "                cnt6 = GoodsSellPrice(t_plan,t_Luxury);",
                        "                pl6 = Name(t_plan);",
                        "            }",
                        "        }",
                        "        if(cnt7 == 0) {",
                        "            cnt7 = GoodsSellPrice(t_plan,t_Arms);",
                        "            pl7 = Name(t_plan);",
                        "        }",
                        "        else {",
                        "            if(cnt7 < GoodsSellPrice(t_plan,t_Arms)) {",
                        "                cnt7 = GoodsSellPrice(t_plan,t_Arms);",
                        "                pl7 = Name(t_plan);",
                        "            }",
                        "        }",
                        "        if(cnt8 == 0) {",
                        "            cnt8 = GoodsSellPrice(t_plan,t_Narcotics);",
                        "            pl8 = Name(t_plan);",
                        "        }",
                        "        else {",
                        "            if(cnt8 < GoodsSellPrice(t_plan,t_Narcotics)) {",
                        "                cnt8 = GoodsSellPrice(t_plan,t_Narcotics);",
                        "                pl8 = Name(t_plan);",
                        "            }",
                        "        }",
                        "    }",
                        "",
                        "    //Начинаем формировать итоговую текстину",
                        "    t_str = CT(\"Script.Mod_RefTauhitoRework.18\") + CT('FormInfo.br');",
                        "    i=0;",
                        "",
                        "    //Собираем инфу про каждый тип товаров, если есть, конечно, о чём говорити",
                        "    if(bulki) {",
                        "        if(GoodsCost(Player(),t_Food) / GoodsCount(Player(),t_Food) < cnt1) {",
                        "            t_str = t_str + CT(\"Script.Mod_RefTauhitoRework.17\") + ' ' + GoodsCount(Player(),t_Food) + CT(\"Script.Mod_RefTauhitoRework.2\") + ' ' + cnt1 + CT(\"Script.Mod_RefTauhitoRework.1\") + ' ' + pl1 + CT('FormInfo.br');",
                        "        }",
                        "        else t_str = t_str + CT(\"Script.Mod_RefTauhitoRework.16\") + CT('FormInfo.br');",
                        "        i = 1;",
                        "    }",
                        "    if(tabletki) {",
                        "        if(GoodsCost(Player(),t_Medicine) / GoodsCount(Player(),t_Medicine) < cnt2) {",
                        "            t_str = t_str + CT(\"Script.Mod_RefTauhitoRework.15\") + ' ' + GoodsCount(Player(),t_Medicine) + CT(\"Script.Mod_RefTauhitoRework.2\")+ ' ' + cnt2 + CT(\"Script.Mod_RefTauhitoRework.1\") + ' ' + pl2 + CT('FormInfo.br');",
                        "        }",
                        "        else t_str = t_str + CT(\"Script.Mod_RefTauhitoRework.14\") + CT('FormInfo.br');",
                        "        i = 1;",
                        "    }",
                        "    if(shit) {",
                        "        if(GoodsCost(Player(),t_Minerals) / GoodsCount(Player(),t_Minerals) < cnt4) {",
                        "            t_str = t_str + CT(\"Script.Mod_RefTauhitoRework.13\") + ' ' + GoodsCount(Player(),t_Minerals) + CT(\"Script.Mod_RefTauhitoRework.2\") + ' ' + cnt4 + CT(\"Script.Mod_RefTauhitoRework.1\") + ' ' + pl4 + CT('FormInfo.br');",
                        "        }",
                        "        else t_str = t_str + CT(\"Script.Mod_RefTauhitoRework.12\") + CT('FormInfo.br');",
                        "        i = 1;",
