                    "Code": [
                        "DChange(3);",
                        "exit;"
                    ],
                    "#": 67,
                    "Type": "Top",
                    "Parent": -1,
                    "Pos.x": 370,
                    "Pos.y": 375
                },
                {
                    "Name": "",
                    "Code.Type": "Turn",
                    "Code": [
                        "DChange(2);",
                        "exit;"
                    ],
                    "#": 68,
                    "Type": "Top",
                    "Parent": -1,
                    "Pos.x": 490,
                    "Pos.y": 375
                },
                {
                    "Name": "",
                    "Code.Type": "Turn",
                    "Code": [
                        "if(!ShipIsPartner(tship)) {",
                        "  if(!ShipOnSidePirateClan(Player())) {",
                        "    if(ShipSkill(Player(),'LeadershipCur') > ShipPartners(Player())) {",
                        "      if(ShipRank(Player()) >= ShipRank(tship)) {",
                        "        if(RangerPlaceInRating(Player()) + 10 >= RangerPlaceInRating(tship)) {",
                        "          if(ShipStrengthInAverageRanger(Player()) >= ShipStrengthInAverageRanger(tship)) {",
                        "            if(ShipSpeed(Player()) + 150 >= ShipSpeed(tship) && ShipType(tship) == 'RangerExplorer') {",
                        "              Month = 16;",
                        "              money = GalaxyMoney(4,4) + (CostIncrease * GalaxyMoney(3,4));",
                        "              extramoney = 0;",
                        "              DChange(9);",
                        "              exit;",
                        "            }",
                        "            if(ShipSpeed(Player()) + 150 < ShipSpeed(tship) && ShipType(tship) == 'RangerExplorer') {",
                        "              DChange(2);",
                        "              exit;",
                        "            }",
                        "            if(ShipType(tship) != 'RangerExplorer') {",
                        "              Month = 16;",
                        "              money = GalaxyMoney(4,4) + (CostIncrease * GalaxyMoney(3,4));",
                        "              extramoney = 0;",
                        "              DChange(9);",
                        "              exit;",
                        "            }",
                        "          }",
                        "          if(ShipStrengthInAverageRanger(Player()) < ShipStrengthInAverageRanger(tship)) {",
                        "            DChange(3);",
                        "            exit;",
                        "          }",
                        "        }",
                        "        if(RangerPlaceInRating(Player()) + 10 < RangerPlaceInRating(tship)) {",
                        "          DChange(4);",
                        "          exit;",
                        "        }",
                        "        if(ShipStatus(Player(),2) && ShipStatus(tship,1)) {",
                        "          DChange(5);",
                        "          exit;",
                        "        }",
                        "        if(ShipStatus(Player(),1) && ShipStatus(tship,2)) {",
                        "          DChange(5);",
                        "          exit;",
                        "        }",
                        "      }",
                        "      if(ShipRank(Player()) < ShipRank(tship)) {",
                        "        DChange(6);",
                        "        exit;",
                        "      }",
                        "    }",
                        "    if(ShipSkill(Player(),'LeadershipCur') <= ShipPartners(Player())) {",
                        "      DChange(7);",
                        "      exit;",
                        "    }",
                        "  }",
                        "  if(ShipOnSidePirateClan(Player())) {",
                        "    DChange(8);",
                        "    exit;",
                        "  }",
                        "}",
                        "if(ShipIsPartner(tship)) {",
                        "  DChange(12);",
                        "  exit;",
                        "}"
                    ],
