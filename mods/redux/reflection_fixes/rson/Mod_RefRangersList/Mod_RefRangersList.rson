                        "else AddDialogBlock(CT(\"Script.Mod_RefRangersList.31\"),1);",
                        "if(Month < 108) AddDialogInject('SRC','',CT(\"Script.Mod_RefRangersList.30\"),2,100);",
                        "else AddDialogBlock(CT(\"Script.Mod_RefRangersList.30\"),1);",
                        "if((money+extramoney) <= ShipMoney(Player())) {",
                        "  DAdd(11);",
                        "}",
                        "if((money+extramoney) > ShipMoney(Player())) {",
                        "  DAdd(12);",
                        "}"
