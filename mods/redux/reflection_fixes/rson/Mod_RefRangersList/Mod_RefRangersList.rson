                {
                    "Name": "",
                    "Code.Type": "Turn",
                    "Code": [
                        "if(ShipMoney(Player()) >= extramoney) AddDialogInject('SRC2','',CT(\"Script.Mod_RefRangersList.47\"),2,100);",
                        "else AddDialogBlock(CT(\"Script.Mod_RefRangersList.47\"),1);",
                        "DAdd(16);"
                    ],
                    "#": 90,
                    "Type": "Top",
                    "Parent": -1,
                    "Pos.x": 130,
                    "Pos.y": 470
                },
                {
                    "Name": "",
                    "Code.Type": "Turn",
                    "Code": [
                        "RangersList = CT(\"Script.Mod_RefRangersList.46\");",
                        "if(!GetGameOptions('FontDialog')) temp_str='--------------------------------';",
                        "else if(GetGameOptions('FontDialog')==1) temp_str='---------------------------';",
                        "else if(GetGameOptions('FontDialog')==2) temp_str='-----------------------------';",
                        "else temp_str='---------------------------';",
                        "RangersList = RangersList + CT('FormInfo.br') + temp_str + CT('FormInfo.br');",
                        "//Ищем подходящие кандидатуры",
                        "dword cur_star = ShipStar(Player());",
                        "dword tsect = StarToCon(ShipStar(Player()));",
                        "int cnt1=0;",
                        "for(j=0;j<ConStars(tsect);j=j+1) {",
                        "    for(i=0;i<StarShips(ConStar(tsect,j));i=i+1) {",
                        "        dword cur_ship = StarShips(ConStar(tsect,j),i);",
                        "        if(ShipType(Player()) != 'RangerPiratePlayer') {",
                        "            if(ShipType(cur_ship) == 'Ranger' || ShipType(cur_ship) == 'FemRanger' || ShipType(cur_ship) == 'RangerExplorer' || ShipType(cur_ship) == 'Freelancer') {",
                        "                if(ShipRank(Player()) >= ShipRank(cur_ship)) {",
                        "                    if(cur_ship == Player()) continue;",
                        "                    RangersList = RangersList + CT(\"Script.Mod_RefRangersList.43\") + ShortName(cur_ship) + CT('FormInfo.br');",
                        "                    RangersList = RangersList + CT(\"Script.Mod_RefRangersList.42\");",
                        "                    if(ShipType(cur_ship) == 'Ranger') RangersList = RangersList + CT(\"Script.Mod_RefRangersList.44\") + CT('FormInfo.br');",
                        "                    if(ShipType(cur_ship) == 'FemRanger') RangersList = RangersList + CT(\"Script.Mod_RefRangersList.45\") + CT('FormInfo.br');",
                        "                    if(ShipType(cur_ship) == 'RangerExplorer') RangersList = RangersList + CT(\"Script.Mod_RefRangersList.44\") + CT('FormInfo.br');",
                        "                    if(ShipType(cur_ship) == 'Freelancer') RangersList = RangersList + CT(\"Script.Mod_RefRangersList.39\") + CT('FormInfo.br');",
                        "                    cnt1 = 1;",
                        "                    guns = 0;",
                        "                    for(k=0;k<5;k=k+1) {",
                        "                        if(ShipEqInSlot(cur_ship,t_Weapon1,k)) guns = guns + 1;",
                        "                    }",
                        "                    if(ShipInHyperSpace(cur_ship)) RangersList = RangersList + CT(\"Script.Mod_RefRangersList.38\") + CT('FormInfo.br');",
                        "                    else RangersList = RangersList + CT(\"Script.Mod_RefRangersList.37\") + Name(ShipStar(cur_ship)) + CT('FormInfo.br');",
                        "                    RangersList = RangersList + CT(\"Script.Mod_RefRangersList.36\") + guns + CT('FormInfo.br');",
                        "                    RangersList = RangersList + CT(\"Script.Mod_RefRangersList.35\") + ShipAverageDamage(cur_ship) + CT('FormInfo.br');",
                        "                    RangersList = RangersList + CT(\"Script.Mod_RefRangersList.34\") + ShipProtectability(cur_ship) + CT('FormInfo.br');",
                        "                    RangersList = RangersList + CT(\"Script.Mod_RefRangersList.33\") + ShipDroidRepair(cur_ship) + CT('FormInfo.br');",
                        "                    RangersList = RangersList + temp_str + CT('FormInfo.br');",
                        "                    CostIncrease = 1;",
                        "                    AddDialogInject('DialNaim','','Связаться с '+Name(cur_ship),i);",
                        "                }",
                        "            }",
                        "        }",
                        "        else {",
                        "            if(ShipType(cur_ship) == 'Pirate' || ShipType(cur_ship) == 'RangerPirate' || ShipType(cur_ship) == 'RangerPirateExplorer' || ShipType(cur_ship) == 'Freelancer') {",
                        "                RangersList = RangersList + CT(\"Script.Mod_RefRangersList.43\") + ShortName(cur_ship) + CT('FormInfo.br');",
                        "                RangersList = RangersList + CT(\"Script.Mod_RefRangersList.42\");",
                        "                if(ShipType(cur_ship) == 'Pirate') RangersList = RangersList + CT(\"Script.Mod_RefRangersList.41\") + CT('FormInfo.br');",
                        "                if(ShipType(cur_ship) == 'RangerPirate') RangersList = RangersList + CT(\"Script.Mod_RefRangersList.40\") + CT('FormInfo.br');",
                        "                if(ShipType(cur_ship) == 'RangerPirateExplorer') RangersList = RangersList + CT(\"Script.Mod_RefRangersList.40\") + CT('FormInfo.br');",
                        "                if(ShipType(cur_ship) == 'Freelancer') RangersList = RangersList + CT(\"Script.Mod_RefRangersList.39\") + CT('FormInfo.br');",
                        "                cnt1 = 1;",
                        "                guns = 0;",
                        "                for(k=0;k<5;k=k+1) {",
                        "                    if(ShipEqInSlot(cur_ship,t_Weapon1,k)) guns = guns + 1;",
                        "                }",
                        "                if(ShipInHyperSpace(cur_ship)) RangersList = RangersList + CT(\"Script.Mod_RefRangersList.38\") + CT('FormInfo.br');",
                        "                else RangersList = RangersList + CT(\"Script.Mod_RefRangersList.37\") + Name(ShipStar(cur_ship)) + CT('FormInfo.br');",
                        "                RangersList = RangersList + CT(\"Script.Mod_RefRangersList.36\") + guns + CT('FormInfo.br');",
                        "                RangersList = RangersList + CT(\"Script.Mod_RefRangersList.35\") + ShipAverageDamage(cur_ship) + CT('FormInfo.br');",
                        "                RangersList = RangersList + CT(\"Script.Mod_RefRangersList.34\") + ShipProtectability(cur_ship) + CT('FormInfo.br');",
                        "                RangersList = RangersList + CT(\"Script.Mod_RefRangersList.33\") + ShipDroidRepair(cur_ship) + CT('FormInfo.br');",
                        "                RangersList = RangersList + temp_str + CT('FormInfo.br');",
                        "            }",
                        "        }",
                        "    }",
                        "}",
                        "//Если никого не нашли :(",
                        "if(cnt1 != 1) RangersList = RangersList + 'Подходящих кандидатур в текущем секторе не обнаружено';",
                        "DChange(1);",
                        "exit;"
                    ],
