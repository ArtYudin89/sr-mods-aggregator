                {
                    "Name": "",
                    "Code.Type": "Turn",
                    "Code": [
                        "if(GAnswerData == 10) {",
                        "    Month = Month / 2;",
                        "    money = money / 2;",
                        "}",
                        "if(GAnswerData == 100) {",
                        "    Month = Month * 2;",
                        "    money = money * 2;",
                        "    if(Month > 60) money = money + money * 0.25;",
                        "}",
                        "DChange(9);",
                        "exit;"
                    ],
