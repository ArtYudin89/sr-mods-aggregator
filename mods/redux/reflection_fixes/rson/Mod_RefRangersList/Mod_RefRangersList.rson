            "Items": [],
            "Operations": [
                {
                    "Name": "",
                    "Code.Type": "Global",
                    "Code": [
                        "GRun();"
                    ],
                    "#": 16,
                    "Type": "Top",
                    "Parent": -1,
                    "Pos.x": 0,
                    "Pos.y": 635
                },
                {
                    "Name": "",
                    "Code.Type": "Turn",
                    "Code": [
                        "if(ShipPartners(Player()) > 0) {",
                        "    for(i=0;i<ShipPartners(Player());i=i+1) {",
                        "        if(ShipType(ShipPartners(Player(),i)) == 'RangerExplorer') {",
                        "            if(ShipSpeed(Player()) + 275 < ShipSpeed(ShipPartners(Player(),i))) {",
                        "                if(ShipInStar(ShipPartners(Player(),i),ShipStar(Player()))) {",
                        "                    if(ShipInNormalSpace(Player()) && ShipInNormalSpace(ShipPartners(Player(),i))) {",
                        "                        if(Dist(Player(),ShipPartners(Player(),i)) <= GetEquipmentStats(ShipEqInSlot(ShipPartners(Player(),i),t_Radar),0)) {",
                        "                            Dialog(ShipPartners(Player(),i));",
                        "                            AddDialogOverride('BrokeSpeed',10,ShipPartners(Player(),i));",
                        "                        }",
                        "                    }",
                        "                }",
                        "            }",
                        "        }",
                        "    }",
                        "}"
                    ],
                    "#": 17,
                    "Type": "Top",
                    "Parent": -1,
                    "Pos.x": 120,
                    "Pos.y": 635
                },
                {
                    "Name": "",
                    "Code.Type": "DialogBegin",
                    "Code": [
                        "if(ShipInNormalSpace(Player())) {",
                        "    if(GetTalkShip()) {",
                        "        if(!TalkByAI) {",
                        "            if(!ShipInScript(GetTalkShip()))",
                        "                tship = GetTalkShip();",
                        "                if(ShipType(tship) == 'Ranger' || ShipType(tship) == 'FemRanger' || ShipType(tship) == 'RangerExplorer') {",
                        "                    AddDialogBlock(CT('Talk.Female.Partner.PlayerSend'),2);",
                        "                    AddDialogBlock(CT('Talk.Female.Partner.PlayerSend1'),2);",
                        "                    AddDialogBlock(CT('Talk.Female.Partner.PlayerSend2'),2);",
                        "                    AddDialogBlock(CT('Talk.Partner.PlayerSend'),2);",
                        "                    if(Rnd(1,3) == 1) AddDialogInject('DialNaim','',Format(CT(\"Script.Mod_RefRangersList.29\"),'ranger',ShortName(tship)),0);",
                        "                    else if(ShipType(tship) == 'FemRanger') AddDialogInject('DialNaim','',Format(CT(\"Script.Mod_RefRangersList.28\"),'ranger',ShortName(tship)),0);",
                        "                    else if(Rnd(1,3) == 2) AddDialogInject('DialNaim','',Format(CT(\"Script.Mod_RefRangersList.27\"),'ranger',ShortName(tship)),0);",
                        "                    else if(Rnd(1,3) == 3) AddDialogInject('DialNaim','',Format(CT(\"Script.Mod_RefRangersList.26\"),'ranger',ShortName(tship)),0);",
                        "                }",
                        "            }",
                        "        }",
                        "    }",
                        "}",
                        "if(PlayerBridge()==11) {",
                        "  AddDialogInject('RefRangers','',CT(\"Script.Mod_RefRangersList.25\"),30);",
                        "}"
                    ],
                    "#": 18,
                    "Type": "Top",
                    "Parent": -1,
                    "Pos.x": 180,
                    "Pos.y": 635
                },
                {
                    "Name": "",
                    "Code.Type": "Turn",
                    "Code": [
                        "DChange(0);",
                        "exit;"
                    ],
