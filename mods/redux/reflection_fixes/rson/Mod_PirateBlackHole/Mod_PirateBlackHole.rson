            "Items": [],
            "Operations": [
                {
                    "Name": "",
                    "Code.Type": "Global",
                    "Code": [
                        "if(!GCntRun(GScriptName)) GRun();"
                    ],
                    "#": 32,
                    "Type": "Top",
                    "Parent": -1,
                    "Pos.x": 0,
                    "Pos.y": 660
                },
                {
                    "Name": "",
                    "Code.Type": "Init",
                    "Code": [
                        "nextattack=CurTurn()+Rnd(500,1000);",
                        "",
                        "//Функция по созданию кораблей",
                        "//type",
                        "//1 = Спавним Лёгкого",
                        "//2 = Спавним Среднего",
                        "//3 = Спавним Тяжёлого",
                        "//4 = Спавним Шу",
                        "",
                        "function SpawnPirate(int type,dword planet) {",
                        "    //Запоминаем расу планеты чтоб потом её вернуть",
                        "    int planetRace=PlanetRace(planet);",
                        "    int planetOwner=PlanetOwner(planet);",
                        "    //Переменая которая содержит в себе корабль",
                        "    dword ship;",
                        "    dword hullstat;",
                        "    dword equip;",
                        "    dword tequip;",
                        "    //Определяет рандомную расу пирату.Для этого мы временно меняем рассу планете на которой делаем спавн",
                        "    int size;",
                        "    int rndspawner=1;",
                        "    int texlvl = GalaxyTechLevel();",
                        "    rndspawner = Rnd(0,4);",
                        "",
                        "    //На случай всякий поставим планете пиратского овнера, потому что я устал от репортов",
                        "    PlanetOwner(planet,PirateClan);",
                        "",
                        "    if(type == 1) {",
                        "        PlanetRace(planet,rndspawner);",
                        "        //Спавним Лёгкого",
                        "        ship = BuyWarrior(planet,1000);",
                        "",
                        "        //Размер корпуса",
                        "        ItemSize(ShipItems(ship,0),Rnd(280,400)+max(3,GalaxyTechLevel())*20);",
                        "        //Навсякий случай назначаем также и хп",
                        "        HullHP(ship,ItemSize(ShipItems(ship,0)));",
                        "        Chameleon(ship);",
                        "        hullstat=ShipItems(ship,0);",
                        "        //Делаем корпус",
                        "        if(GetEquipmentStats(hullstat,5)<1)ShipSpecialBonuses(ship,bonSlotDroid,1);",
