                        "}",
                        "//Функция по созданию ЧД с автоматическим выбором системы для атаки и откуда нападать",
                        "//Также ЧД СОЗДАЕТСЯ СРАЗУ",
                        "//Запускается из терн кода",
                        "function FormAttackHoleAndFindSystems() {",
                        "    //SFT('REFLECTION-PIRATE-BLACKHOLE-FormAttack-1');",
                        "    dword curSystem, spawnSystem,attackSystem;",
                        "    //curSystem нужно для определения системы на которой текущая итерация",
                        "    //spawnSystem хранит в себе систему откуда будет происходить атака",
                        "    //attackSystem хранит систему которая будет атакова",
                        "    //Ищем систему куда нападать",
                        "    for(i=0; i<GalaxyStars(); i=i+1) {",
                        "      curSystem=GalaxyStar(i);",
                        "      //Проверяем не пиратская ли система",
                        "      if(StarOwner(curSystem) != 2) {",
                        "          //Записываем в массив систему",
                        "          ArrayAdd(systems, curSystem);",
                        "      }",
                        "    }",
                        "    //SFT('REFLECTION-PIRATE-BLACKHOLE-FormAttack-2');",
                        "    //Сразу опредяем систему для атаки",
                        "    tint = ArrayDim(systems);",
                        "    //Проверяем чтоб было хотяб десять систем для выбора атаки",
                        "     if(tint > 9){",
                        "         tint2=Rnd(1,tint-1);",
                        "         //Во избежание возможных ошибок после очисток массивов обращаюсь к массиву систем от первого индекса массива",
                        "         attackSystem = systems[tint2];",
                        "         attackwant = 1;",
                        "     } else {",
                        "         attackwant = 0;",
                        "     }",
                        "     //SFT('REFLECTION-PIRATE-BLACKHOLE-FormAttack-3');",
                        "     //В любом случае чистим массив",
                        "     ArrayClear(systems);",
                        "     //Ищем систему и планету с которой провести и спавним в ней чд",
                        "     //Подготовливаем систему с которой пройдёт атака",
                        "     for(i=0; i<GalaxyStars(); i=i+1) {",
                        "         curSystem=GalaxyStar(i);",
                        "         //Проверяем нет ли в системе игрока",
                        "          if(ShipStar(Player()) != curSystem) {",
                        "              //Проверяем пиратская ли система",
                        "              if(StarOwner(curSystem) == 2) {",
                        "                  //Записываем в массив систему",
                        "                  ArrayAdd(systems, curSystem);",
                        "              }",
                        "          }",
                        "",
                        "     }",
                        "     //SFT('REFLECTION-PIRATE-BLACKHOLE-FormAttack-4');",
                        "     tint = ArrayDim(systems);",
                        "     //Проверяем чтоб было хотяб три возможных системы для атаки(Думаю пираты смогут иметь ещё одну систему даже на 500)",
                        "     //Но в целом это надо чтоб избежать возможных ошибок с очисткой массива",
                        "     //Также не исключаются скрытые сектора для атаки",
                        "     if(tint > 3  && attackwant == 1){",
                        "         tint2=Rnd(1,tint-1);",
                        "         //Во избежание возможных ошибок после очисток массивов обращаюсь к массиву систем от первого индекса массива",
                        "         spawnSystem = systems[tint2];",
                        "         attackwant = 1;",
                        "     } else {",
                        "         attackwant = 0;",
                        "     }",
                        "     ArrayClear(systems);",
                        "",
                        "     if(attackwant == 1) {",
                        "         tHole=HoleCreate2(spawnSystem, attackSystem);",
                        "         idhole=Id(tHole);",
                        "         HoleTurnCreate(tHole,CurTurn()+40);",
                        "         timehole = HoleTurnCreate(tHole);",
                        "         tHolePos1 = Id(spawnSystem);",
                        "         tHolePos2 = Id(attackSystem);",
                        "         //SFT('REFLECTION-PIRATE-BLACKHOLE:SPAWN SYSTEM: '+ Name(GalaxyStar(tHolePos1-1)));",
                        "         //SFT('REFLECTION-PIRATE-BLACKHOLE:ATTACK SYSTEM: '+ Name(GalaxyStar(tHolePos2-1)));",
                        "         HoleMap(tHole, 'NoEntry');",
                        "     }",
                        "",
                        "     result = Id(attackSystem);",
                        "}",
                        "//Функция для открытия чд через которую потом другой функцией удалим Шу и часть пиратов",
                        "function Harakiri(dword system) {",
                        "    //SFT('REFLECTION-PIRATE-BLACKHOLE-Harakiri-State-1');",
                        "    dword curSystem, toSystem;",
                        "    //Снова переберём системы",
                        "     for(i=0; i<GalaxyStars(); i=i+1) {",
                        "         curSystem=GalaxyStar(i);",
                        "         //Проверяем нет ли в системе игрока",
                        "          if(system != curSystem)  {",
                        "              if(ShipStar(Player()) != curSystem) {",
                        "                 //Записываем в массив систему",
                        "                  ArrayAdd(systems, curSystem);",
                        "              }",
                        "          }",
                        "     }",
                        "     tint = ArrayDim(systems);",
                        "     if(tint > 3){",
                        "         tint2=Rnd(1,tint-1);",
                        "         //Во избежание возможных ошибок после очисток массивов обращаюсь к массиву систем от первого индекса массива",
                        "         toSystem = systems[tint2];",
                        "     }",
                        "     ArrayClear(systems);",
                        "     tHole=HoleCreate2(system, toSystem);",
                        "     idhh = Id(toSystem);",
                        "     hHolePos1 = Id(system);",
                        "     hHolePos2 = Id(toSystem);",
                        "     HoleTurnCreate(tHole,CurTurn()+40);",
                        "     timehole2 = HoleTurnCreate(tHole);",
                        "     HoleMap(tHole, 'NoEntry');",
                        "}",
                        "function NormalGetHole (dword idx,int closedate) {",
                        "    dword normal,holet;",
                        "    for(p = 0;p < GalaxyHoles();p = p + 1 ) {",
                        "        holet=GalaxyHoles(p);",
                        "        if(Id(holet) == idx && HoleTurnCreate(holet) == closedate) {",
                        "            normal = holet;",
                        "        }",
                        "    }",
                        "    result = normal;",
                        "}"
                    ],
                    "#": 33,
                    "Type": "Top",
                    "Parent": -1,
                    "Pos.x": 60,
                    "Pos.y": 660
                },
                {
                    "Name": "",
                    "Code.Type": "Turn",
                    "Code": [
                        "if(GroupCount(PiratesWave1) < 1 && GroupCount(PiratesWave2) < 1 && GroupCount(PiratesWave3) < 1 && GroupCount(PirateShu) < 1 && holestate2 == 1){",
                        "    holestate2 = 0;",
                        "    //SFT('REFLECTION-PIRATE-BLACKHOLE-Timer');",
                        "    nextattack=CurTurn()+Rnd(800,1200);",
                        "    zatycka = 0;",
                        "    holestate2=0;",
                        "    idhh = 0;",
                        "    hHolePos1 = 0;",
                        "    hHolePos2 = 0;",
                        "    tHolePos1 = 0;",
                        "    tHolePos2 = 0;",
                        "    timehole=0;",
                        "    timehole2=0;",
                        "    attackwant=0;",
                        "    shudial=0;",
                        "}",
                        "//Перебираем все пиратские системы",
                        "//Отвечает за формирование атаки",
                        "if(CurTurn() >= nextattack && holestate2 == 0) {",
                        "    //SFT('REFLECTION-PIRATE-BLACKHOLE-Start SESSION');",
                        "    zatycka = 0;",
                        "    holestate2=1;",
                        "    idhh = 0;",
                        "    hHolePos1 = 0;",
                        "    hHolePos2 = 0;",
                        "    tHolePos1 = 0;",
                        "    tHolePos2 = 0;",
                        "    timehole=0;",
                        "    timehole2=0;",
                        "    attackwant=0;",
                        "    shudial=0;",
                        "    IDAttacked = FormAttackHoleAndFindSystems();",
                        "    if(attackwant == 1){",
                        "        //SFT('REFLECTION-PIRATE-BLACKHOLE-Start SESSION-SPAWN');",
                        "        planet = FindPlanet(GalaxyStar(tHolePos1-1),'NotNone',0,100);",
                        "        if(ObjectType(planet) == 3) {",
                        "            //Генерируем первую волну",
                        "            int f;",
                        "            int rnd = Rnd(9,11);",
                        "            //SFT('REFLECTION-PIRATE-BLACKHOLE-Start SESSION-SPAWN-1');",
                        "            for(f=0;f < rnd;f = f + 1){",
                        "                tship = SpawnPirate(1,planet);",
                        "                ShipJoin(PiratesWave1,tship);",
                        "            }",
                        "            rnd = Rnd(2,4);",
                        "            //SFT('REFLECTION-PIRATE-BLACKHOLE-Start SESSION-SPAWN2');",
                        "            for(f=0;f < rnd;f = f + 1){",
                        "                tship = SpawnPirate(2,planet);",
                        "                ShipJoin(PiratesWave1,tship);",
                        "            }",
                        "            //Генерируем вторую волну",
                        "            rnd = Rnd(6,8);",
                        "            //SFT('REFLECTION-PIRATE-BLACKHOLE-Start SESSION-SPAWN3');",
                        "            for(f=0;f < rnd;f = f + 1){",
                        "                tship = SpawnPirate(2,planet);",
                        "                ShipJoin(PiratesWave2,tship);",
                        "            }",
                        "            rnd = Rnd(2,4);",
                        "            //SFT('REFLECTION-PIRATE-BLACKHOLE-Start SESSION-SPAWN4');",
                        "            for(f=0;f < rnd;f = f + 1){",
                        "                tship = SpawnPirate(3,planet);",
                        "                ShipJoin(PiratesWave2,tship);",
                        "            }",
                        "            //Генерируем третью волну",
                        "            rnd = Rnd(3,6);",
                        "            //SFT('REFLECTION-PIRATE-BLACKHOLE-Start SESSION-SPAWN5');",
                        "            for(f=0;f < rnd;f = f + 1){",
                        "                tship = SpawnPirate(3,planet);",
                        "                ShipJoin(PiratesWave3,tship);",
                        "            }",
                        "            //ШУ",
                        "            //SFT('REFLECTION-PIRATE-BLACKHOLE-Start SESSION-SPAWN-SHU');",
                        "            tship = SpawnPirate(4,planet);",
                        "            ShipJoin(PirateShu,tship);",
                        "    ",
                        "            if(ArtefactTypeInUse(Player(),t_ArtefactAnalyzer)) {",
                        "                Sound('Sound.NewMsg');",
                        "                NewsAdd(CT(\"Script.Mod_PirateBlackHole.46\"));",
                        "            }",
                        "        }",
                        "        else {",
                        "            //SFT('REFLECTION-PIRATE-BLACKHOLE-Start-ATTACK-WANT-NO');",
                        "            nextattack=CurTurn()+Rnd(10,30);",
                        "        }",
                        "    }",
                        "    else {",
                        "        //SFT('REFLECTION-PIRATE-BLACKHOLE-Start-ATTACK-WANT-NO');",
                        "        nextattack=CurTurn()+Rnd(10,30);",
                        "    }",
                        "",
                        "}",
                        "if(PirateWin()==3 || PirateWin==4) {",
                        "    AllShipOut();",
                        "}"
                    ],
                    "#": 34,
                    "Type": "Top",
                    "Parent": -1,
                    "Pos.x": 120,
                    "Pos.y": 660
                },
                {
                    "Name": "",
                    "Code.Type": "Turn",
                    "Code": [
                        "if(GetShipPlanet(CurShip)) OrderTakeOff(CurShip);",
                        "else if(ShipInNormalSpace(CurShip)) {",
                        "    tHole=NormalGetHole(idhole,timehole);",
                        "    if(tHole) { //Нужная ЧД существует",
                        "        if(ShipStar(CurShip)==GalaxyStar(tHolePos1-1)) {",
                        "            OrderNone(CurShip);",
                        "            OrderJumpHole(CurShip, tHole); //Прыгаем в ЧД",
                        "        }",
                        "    }",
                        "    if(ShipStar(CurShip)==GalaxyStar(tHolePos2-1)) {",
                        "        //SFT('REFLECTION-PIRATE-BLACKHOLE-State2222');",
                        "        if(OrderLock(CurShip)) OrderLock(CurShip, 0);",
                        "        //Проверяем на захват системы",
                        "        if(StarOwner(GalaxyStar(IDAttacked-1)) == 2) {",
                        "            //SFT('REFLECTION-PIRATE-BLACKHOLE-State1111Har');",
                        "            if(StateIs(CurShip,'InitState')){",
                        "                ShipSpecialBonuses(CurShip,bonJump,0);",
                        "                ShipOut(CurShip);",
                        "            }",
                        "            else if (StateIs(CurShip,'InitState3')){",
                        "                ShipSpecialBonuses(CurShip,bonJump,0);",
                        "                ShipOut(CurShip);",
                        "            }",
                        "            else {",
                        "                if(zatycka == 0) {",
                        "                    Harakiri(ShipStar(CurShip));",
                        "                    zatycka = 1;",
                        "                }",
                        "                if(StateIs(CurShip,'InitState2')) {",
                        "                    ChangeState('Harakiri');",
                        "                }",
                        "                else {",
                        "                    ChangeState('HarakiriShu');",
                        "                }",
                        "            }",
                        "        }",
                        "        else {",
                        "            ShipSpecialBonuses(CurShip,bonJump,-50000000);",
                        "        }",
                        "    }",
                        "}",
                        "//Проверка на побег пирата из нужных систем",
                        "if(Id(ShipStar(CurShip))!=tHolePos2){",
                        "    if(Id(ShipStar(CurShip))!=tHolePos1){",
                        "        //SFT('REFLECTION-PIRATE-BLACKHOLE-PIRATE-LEAVING-SYSTEMS');",
                        "        if(StateIs(CurShip,'ShuArgState') || StateIs(CurShip,'InitShuState')) {",
                        "            ShipDestroy(CurShip, 1);",
                        "        }",
                        "        ShipOut(CurShip);",
                        "    }",
                        "}",
                        "if(ShipOrder(CurShip) == 3){",
                        "    OrderNone(CurShip);",
                        "}"
                    ],
