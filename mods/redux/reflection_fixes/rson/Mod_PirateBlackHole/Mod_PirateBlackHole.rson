                        "        ShipSkill(ship,0,6);",
                        "        ShipSkill(ship,1,Rnd(4,6));",
                        "        ShipSkill(ship,2,6);",
                        "        ShipSkill(ship,3,4);",
                        "        ShipSkill(ship,4,5);",
                        "        ShipSkill(ship,5,6);",
                        "",
                        "        //Добавляем гарантировано гзп на гту выше",
                        "        if(!ShipEqInSlot(ship,t_DefGenerator))",
                        "        {",
                        "            size = Rnd(15,25);",
                        "            equip = CreateEquipment(t_DefGenerator,size,min(8,GalaxyTechLevel()+2),ShipOwner(ship));",
                        "            AddItemToShip(ship,equip);",
                        "            ItemIsInUse(equip,ship,1);",
                        "        }",
                        "        //Добавляем гарантировано дроид на гту выше",
                        "        if(!ShipEqInSlot(ship,t_RepairRobot))",
                        "        {",
                        "            size = Rnd(15,25);",
                        "            equip = CreateEquipment(t_RepairRobot,size,min(8,GalaxyTechLevel()+2),ShipOwner(ship));",
                        "            AddItemToShip(ship,equip);",
                        "            ItemIsInUse(equip,ship,1);",
                        "        }",
