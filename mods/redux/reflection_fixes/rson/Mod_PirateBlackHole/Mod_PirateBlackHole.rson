                        "        ShipSpecialBonuses(ship,bonDef,3*max(3,GalaxyTechLevel()));",
                        "        for(i=ShipItems(ship);i>0;i=i-1)",
                        "        {",
                        "            equip=ShipItems(ship,i);",
                        "            if(!ItemIsInUse(equip))continue;",
                        "            if((GalaxyTechLevel() >= ItemLevel(equip)))",
                        "            {",
                        "                //Обнова оборудавния",
                        "                if(ItemType(equip) == t_CustomWeapon) {",
                        "                    tequip=CreateCustomWeapon(CustomWeaponType(equip),ItemSize(equip)+Rnd(7,12),GalaxyTechLevel(),ItemOwner(equip));",
                        "                }",
                        "                else {",
                        "                    tequip=CreateEquipment(ItemType(equip),ItemSize(equip)+Rnd(7,12),GalaxyTechLevel(),ItemOwner(equip));",
                        "                }",
                        "                if(EqSpecial(equip)>-1)SpecialToEquipment(EqSpecial(equip),tequip);",
                        "                if(EqModule(equip)>-1)ModuleToEquipment(EqModule(equip),tequip);",
                        "                ItemLevel(equip,GalaxyTechLevel());",
                        "                ItemCost(equip,ItemCost(tequip));",
                        "                if(Rnd(1,100)<=75)NoDropItem(equip,1);",
                        "                FreeItem(tequip);",
                        "            }",
                        "        }",
                        "        for(i=0;i<3;i=i+1) {",
