                        "        //Делаем корпус",
                        "        if(GetEquipmentStats(hullstat,5)<1)ShipSpecialBonuses(ship,bonSlotDroid,1);",
                        "        if(GetEquipmentStats(hullstat,7)<1)ShipSpecialBonuses(ship,bonSlotDef,1);",
                        "        ShipSpecialBonuses(ship,bonSlotWeapon,5);",
                        "        ShipSpecialBonuses(ship,bonSlotArt,4);",
