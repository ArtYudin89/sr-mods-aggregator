                    "Code": [
                        "if(shudial==1 || shudial==2) {",
                        "  if(ShipInPirateClan(Player())) {",
                        "    if(shudial==0) {",
                        "      DChange(10);",
                        "      exit;",
                        "    }",
                        "    if(shudial==1) {",
                        "      DChange(7);",
                        "      exit;",
                        "    }",
                        "    if(shudial==2) {",
                        "      DChange(9);",
                        "      exit;",
                        "    }",
                        "  }",
                        "  if(!ShipInPirateClan(Player())) {",
                        "    DChange(8);",
                        "    exit;",
                        "  }",
                        "}",
                        "if(shudial==0) {",
                        "  if(ShipInPirateClan(Player())) {",
                        "    DChange(2);",
                        "    exit;",
                        "  }",
                        "  if(!ShipInPirateClan(Player())) {",
                        "    DChange(3);",
                        "    exit;",
                        "  }",
                        "}"
