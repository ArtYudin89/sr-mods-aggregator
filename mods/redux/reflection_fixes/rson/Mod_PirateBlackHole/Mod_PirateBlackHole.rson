                        "        if(ShipPilotRace(ship) != 1) {",
                        "            ShipPilotRace(ship,1);",
                        "        }",
                        "        ShipOwner(ship,7);",
                        "        //Заставляем закупится корабль",
                        "        for(i=0;i<8;i = i +1) {",
                        "            ShipRefit(ship);",
                        "        }",
                        "        //Размер корпуса",
                        "        ItemSize(ShipItems(ship,0),Rnd(1600,2200)+max(3,GalaxyTechLevel())*100);",
                        "        //Навсякий случай назначаем также и хп",
                        "        HullHP(ship,ItemSize(ShipItems(ship,0)));",
                        "        SetName(ship,CT(\"Script.Mod_PirateBlackHole.14\"));",
                        "        ShipType(ship,'ShuType');",
