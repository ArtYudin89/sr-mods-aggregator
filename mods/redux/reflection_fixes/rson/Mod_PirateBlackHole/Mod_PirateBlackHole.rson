                {
                    "Name": "",
                    "Code.Type": "Turn",
                    "Code": [
                        "if(TalkByAI()) {",
                        "  if(GetTalkType() == 0) {",
                        "    DChange(12);",
                        "    exit;",
                        "  }",
                        "  if(GetTalkType() == 1) {",
                        "    DChange(13);",
                        "    exit;",
                        "  }",
                        "  if(GetTalkType() == 3) {",
                        "    DChange(14);",
                        "    exit;",
                        "  }",
                        "  if(GetTalkType() != 0 && GetTalkType() != 1 && GetTalkType() != 3) {",
                        "    DChange(15);",
                        "    exit;",
                        "  }",
                        "}",
                        "if(ShipInPirateClan(Player())) {",
                        "  if(StarOwner(ShipStar(GetTalkShip())) != 2) {",
                        "    DChange(0);",
                        "    exit;",
                        "  }",
                        "  if(StarOwner(ShipStar(GetTalkShip())) == 2) {",
                        "    DChange(18);",
                        "    exit;",
                        "  }",
                        "}",
                        "if(!ShipInPirateClan(Player())) {",
                        "  if(StarOwner(ShipStar(GetTalkShip())) != 2) {",
                        "    DChange(1);",
                        "    exit;",
                        "  }",
                        "  if(StarOwner(ShipStar(GetTalkShip())) == 2) {",
                        "    DChange(17);",
                        "    exit;",
                        "  }",
                        "}"
                    ],
                    "#": 99,
                    "Type": "Top",
                    "Parent": -1,
                    "Pos.x": -20,
                    "Pos.y": 400
                },
