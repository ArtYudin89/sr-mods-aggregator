                        "                equip=CreateArt(t_ArtPDTurret,ShipOwner(ship));",
                        "                NoDropItem(equip,1);",
                        "            }",
                        "            else if(i == 1){",
                        "                equip=CreateArt(t_ArtefactMiniExpl,ShipOwner(ship));",
                        "                NoDropItem(equip,1);",
                        "            }",
                        "            else if(i == 2){",
                        "                equip=CreateArt(t_ArtefactDef,ShipOwner(ship));",
                        "                if(Rnd(1,2) == 2) NoDropItem(equip,1);",
                        "            }",
                        "            else {",
                        "                equip=CreateArt(t_ArtSplinter,ShipOwner(ship));",
                        "                NoDropItem(equip,1);",
                        "            }",
                        "            ItemDurability(equip,100);",
                        "            NoDropItem(equip,1);",
                        "            AddItemToShip(ship,equip);",
